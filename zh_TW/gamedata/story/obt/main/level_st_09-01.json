{"lang": "zh_TW", "eventid": "main_9", "eventName": "風暴瞭望", "entryType": "MAINLINE", "storyCode": "9-1", "avgTag": "幕間", "storyName": "風暴突擊", "storyInfo": "風笛所屬風暴突擊隊為了追查軍用源石製品失竊案，在小丘郡郊區登陸，對情報中的某個倉庫進行了突擊行動。\n", "storyList": [{"id": 0, "prop": "HEADER", "attributes": {"key": "title_test", "is_skippable": "true", "fit_mode": "BLACK_MASK"}}, {"id": 1, "prop": "stopmusic", "attributes": {}}, {"id": 2, "prop": "Dialog", "attributes": {}}, {"id": 3, "prop": "Background", "attributes": {"image": "bg_black", "screenadapt": "coverall"}}, {"id": 4, "prop": "playMusic", "attributes": {"intro": "$drift_intro", "key": "$drift_loop", "volume": 0.4}}, {"id": 5, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 6, "prop": "Subtitle", "attributes": {"text": "“冬眠的山馱著高高的煙囪”", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 7, "prop": "Subtitle", "attributes": {"text": "“履帶拉著我的家嘎吱嘎吱地跑”", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 8, "prop": "Subtitle", "attributes": {"text": "“我在排水溝裡找到了一顆橡果，緊挨著一枚生銹的鉚釘”", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 9, "prop": "subtitle", "attributes": {}}, {"id": 10, "prop": "Dialog", "attributes": {}}, {"id": 11, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 12, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 13, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 14, "prop": "Character", "attributes": {}}, {"id": 15, "prop": "Background", "attributes": {"image": "bg_warehouse", "screenadapt": "coverall"}}, {"id": 16, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 17, "prop": "playMusic", "attributes": {"intro": "$nervous_intro", "key": "$nervous_loop", "volume": 0.4}}, {"id": 18, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0