"false"}}, {"id": 145, "prop": "character", "attributes": {"fadetime": 0.5}}, {"id": 146, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 147, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#6"}}, {"id": 148, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 149, "prop": "name", "attributes": {"content": "我捂住了！大家快跑！", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#6"}, {"id": 150, "prop": "Character", "attributes": {"name": "avg_npc_229_1#4"}}, {"id": 151, "prop": "name", "attributes": {"content": "你——", "name": "號角"}, "figure_art": "avg_npc_229_1#4"}, {"id": 152, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2"}}, {"id": 153, "prop": "name", "attributes": {"content": "——！", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#2"}, {"id": 154, "prop": "dialog", "attributes": {}}, {"id": 155, "prop": "character", "attributes": {}}, {"id": 156, "prop": "name", "attributes": {"content": "隊長，沒有源石反應，風笛身下不是炸彈。", "name": "三角鐵"}}, {"id": 157, "prop": "dialog", "attributes": {}}, {"id": 158, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_222_bpipe_1#5", "fadetime": 0.7}}, {"id": 159, "prop": "delay", "attributes": {"time": 0.7}}, {"id": 160, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_222_bpipe_1#5", "focus": 2.0}}, {"id": 161, "prop": "name", "attributes": {"content": "啊！虛驚一場嘛。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#5"}, {"id": 162, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_222_bpipe_1#5", "focus": 1.0}}, {"id": 163, "prop": "name", "attributes": {"content": "......目標呢？", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 164, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_222_bpipe_1#3", "focus": 2.0}}, {"id": 165, "prop": "name", "attributes": {"content": "不好意思，撞得有點狠。他一時半會站不起來了。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#3"}, {"id": 166, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_222_bpipe_1#3", "focus": 1.0}}, {"id": 167, "prop": "name", "attributes": {"content": "那這些箱子裡......", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 168, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_222_bpipe_1#5", "focus": 2.0}}, {"id": 169, "prop": "name", "attributes": {"content": "我看看啊，全都是馬鈴薯和胡蘿蔔，還有花椰菜欸！被我壓壞了。好可惜，看起來都挺好吃的。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#5"}, {"id": 170, "prop": "Character", "attributes": {"name": "avg_npc_229_1#5", "name2": "avg_222_bpipe_1#5", "focus": 1.0}}, {"id": 171, "prop": "name", "attributes": {"content": "......", "name": "號角"}, "figure_art": "avg_npc_229_1#5"}, {"id": 172, "prop": "name", "attributes": {"content": "不要放鬆警惕。", "name": "號角"}, "figure_art": "avg_npc_229_1#5"}, {"id": 173, "prop": "Character", "attributes": {"name": "avg_npc_229_1#5", "name2": "avg_222_bpipe_1#2", "focus": 2.0}}, {"id": 174, "prop": "name", "attributes": {"content": "這排，這排，還有這排......都一樣。隊長，這倉庫裡全是果蔬糧食啊。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#2"}, {"id": 175, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_222_bpipe_1#2", "focus": 1.0}}, {"id": 176, "prop": "name", "attributes": {"content": "三角鐵，注意周圍有沒有其他人靠近。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 177, "prop": "name", "attributes": {"content": "雙簧管，你和風笛一起搜查倉庫。有發現隨時給信號。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 178, "prop": "name", "attributes": {"content": "大提琴，把這位癱倒在地的先生綁起來。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 179, "prop": "dialog", "attributes": {}}, {"id": 180, "prop": "character", "attributes": {}}, {"id": 181, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 182, "prop": "Character", "attributes": {"name": "avg_npc_242", "fadetime": 1.5}}, {"id": 183, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 184, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown3", "volume": 1.0}}, {"id": 185, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 186, "prop": "name", "attributes": {"content": "唔呃......", "name": "慌張的青年"}, "figure_art": "avg_npc_242"}, {"id": 187, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 188, "prop": "name", "attributes": {"content": "現在，先生，麻煩你回答幾個問題。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 189, "prop": "Character", "attributes": {"name": "avg_npc_242"}}, {"id": 190, "prop": "name", "attributes": {"content": "我、我什麼都不知道，我每天都會在這裡分揀馬鈴薯。", "name": "慌張的青年"}, "figure_art": "avg_npc_242"}, {"id": 191, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 192, "prop": "name", "attributes": {"content": "你是小丘郡的居民？", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 193, "prop": "Character", "attributes": {"name": "avg_npc_242"}}, {"id": 194, "prop": "name", "attributes": {"content": "是......", "name": "慌張的青年"}, "figure_art": "avg_npc_242"}, {"id": 195, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 196, "prop": "name", "attributes": {"content": "你聽說過鬼魂部隊嗎？", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 197, "prop": "Character", "attributes": {"name": "avg_npc_242"}}, {"id": 198, "prop": "name", "attributes": {"content": "鬼......什麼？呵、呵呵......部隊說的不就是你們這些當兵的嗎？", "name": "慌張的青年"}, "figure_art": "avg_npc_242"}, {"id": 199, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 200, "prop": "name", "attributes": {"content": "把洛瑞、朱利亞和克里斯他們抓走......現在是不是、是不是也輪到我了？", "name": "慌張的青年"}, "figure_art": "avg_npc_242"}, {"id": 201, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 202, "prop": "name", "attributes": {"content": "請你冷靜一些。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 203, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 204, "prop": "name", "attributes": {"content": "聽好。有人看到，昨天半夜有一批源石製品被送進了這個倉庫。而如今它們不在這裡。你需要對此作出解釋。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 205, "prop": "Character", "attributes": {"name": "avg_npc_242"}}, {"id": 206, "prop": "name", "attributes": {"content": "解釋？你們真想要這個，而不是直接吊死我？我、我......呸。", "name": "慌張的青年"}, "figure_art": "avg_npc_242"}, {"id": 207, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_222_bpipe_1#4", "focus": 2.0}}, {"id": 208, "prop": "characteraction", "attributes": {"name": "right", "type": "jump", "power": 10.0, "times": 2.0, "fadetime": 0.51, "block": "true"}}, {"id": 209, "prop": "name", "attributes": {"content": "嘿！你怎麼亂吐口水？也太不注意衛生了吧！", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#4"}, {"id": 210, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_222_bpipe_1#4", "focus": 1.0}}, {"id": 211, "prop": "name", "attributes": {"content": "有線索嗎？", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 212, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_222_bpipe_1#7", "focus": 2.0}}, {"id": 213, "prop": "name", "attributes": {"content": "沒有，隊長，到處都是馬鈴薯。如果消息沒錯的話，他們的動作有夠快的。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#7"}, {"id": 214, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_222_bpipe_1#7", "focus": 1.0}}, {"id": 215, "prop": "name", "attributes": {"content": "好。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 216, "prop": "name", "attributes": {"content": "帶走他。他一定知道些什麼，只是還不願意開口。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 217, "prop": "Character", "attributes": {"name": "avg_npc_242"}}, {"id": 218, "prop": "name", "attributes": {"content": "我就說......你們都一樣！費盡心思地找我們的錯處，折磨我們......你們這些維多利亞的吃人惡獸！", "name": "慌張的青年"}, "figure_art": "avg_npc_242"}, {"id": 219, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_222_bpipe_1#7", "focus": 2.0}}, {"id": 220, "prop": "name", "attributes": {"content": "啊？又來？他覺得把一個維多利亞同胞叫作維多利亞人算是種辱駡嗎？真是搞不明白。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#7"}, {"id": 221, "prop": "dialog", "attributes": {}}, {"id": 222, "prop": "character", "attributes": {}}, {"id": 223, "prop": "PlaySound", "attributes": {"key": "$d_gen_transmissionget", "volume": 1.0}}, {"id": 224, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 225, "prop": "name", "attributes": {"content": "隊長，有人來了。", "name": "三角鐵"}}, {"id": 226, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 227, "prop": "name", "attributes": {"content": "幾個？", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 228, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_222_bpipe_1#5", "focus": 1.0}}, {"id": 229, "prop": "name", "attributes": {"content": "（準備散開。）", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 230, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_222_bpipe_1#6", "focus": 2.0}}, {"id": 231, "prop": "name", "attributes": {"content": "（是，隊長。）", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#6"}, {"id": 232, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "xpos": 300.0, "fadetime": 1.0, "block": "true"}}, {"id": 233, "prop": "characteraction", "attributes": {"name": "left", "type": "move", "fadetime": 1.0, "block": "true"}}, {"id": 234, "prop": "dialog", "attributes": {}}, {"id": 235, "prop": "character", "attributes": {"fadetime": 0.5}}, {"id": 236, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 237, "prop": "name", "attributes": {"content": "報告，隊長，他們好像是自己人。", "name": "三角鐵"}}, {"id": 238, "prop": "dialog", "attributes": {}}, {"id": 239, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 240, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 241, "prop": "character", "attributes": {"name": "avg_npc_238", "fadetime": 1.5}}, {"id": 242, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 243, "prop": "name", "attributes": {"content": "人在這裡。", "name": "？？？"}, "figure_art": "avg_npc_238"}, {"id": 244, "prop": "dialog", "attributes": {}}, {"id": 245, "prop": "character", "attributes": {}}, {"id": 246, "prop": "PlaySound", "attributes": {"key": "$d_gen_soldiersrun", "volume": 1.0}}, {"id": 247, "prop": "Character", "attributes": {"name": "avg_npc_241", "name2": "char_empty", "fadetime": 0.5}}, {"id": 248, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 249, "prop": "Character", "attributes": {"name": "char_empty", "name2": "avg_npc_241", "fadetime": 0.5}}, {"id": 250, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 251, "prop": "Character", "attributes": {"name": "avg_npc_241", "name2": "char_empty", "fadetime": 0.5}}, {"id": 252, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 253, "prop": "Character", "attributes": {"name": "avg_npc_241", "name2": "avg_npc_241"}}, {"id": 254, "prop": "name", "attributes": {"content": "......", "name": "維多利亞士兵"}}, {"id": 255, "prop": "Character", "attributes": {"name": "avg_npc_229_1#2", "name2": "avg_222_bpipe_1#5", "focus": 2.0}}, {"id": 256, "prop": "name", "attributes": {"content": "（隊長，我們被包圍了。）", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#5"}, {"id": 257, "prop": "Character", "attributes": {"name": "avg_npc_229_1#2", "name2": "avg_222_bpipe_1#5", "focus": 1.0}}, {"id": 258, "prop": "name", "attributes": {"content": "（從人數上來說，是。）", "name": "號角"}, "figure_art": "avg_npc_229_1#2"}, {"id": 259, "prop": "Character", "attributes": {"name": "avg_npc_229_1#2", "name2": "avg_222_bpipe_1#1", "focus": 2.0}}, {"id": 260, "prop": "name", "attributes": {"content": "（聽聲音的話，留在外面的人好像不是很多。從我手邊破牆的話，我們有機會欸！）", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#1"}, {"id": 261, "prop": "Character", "attributes": {"name": "avg_npc_229_1#2", "name2": "avg_222_bpipe_1#1", "focus": 1.0}}, {"id": 262, "prop": "name", "attributes": {"content": "（稍安勿躁。）", "name": "號角"}, "figure_art": "avg_npc_229_1#2"}, {"id": 263, "prop": "Character", "attributes": {"name": "avg_npc_238"}}, {"id": 264, "prop": "name", "attributes": {"content": "看起來這裡剛剛發生了一場激烈的戰鬥。", "name": "？？？"}, "figure_art": "avg_npc_238"}, {"id": 265, "prop": "dialog", "attributes": {}}, {"id": 266, "prop": "character", "attributes": {}}, {"id": 267, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 268, "prop": "character", "attributes": {"name": "avg_npc_229_1#1", "fadetime": 1.5}}, {"id": 269, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 270, "prop": "name", "attributes": {"content": "麗塔·斯卡曼德羅斯，第七前線步兵營，第二風暴突擊隊隊長。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 271, "prop": "Character", "attributes": {"name": "avg_npc_238"}}, {"id": 272, "prop": "name", "attributes": {"content": "你好，斯卡曼......斯卡曼德羅斯中尉。", "name": "？？？"}, "figure_art": "avg_npc_238"}, {"id": 273, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 274, "prop": "name", "attributes": {"content": "我的名字不算好記。您可以叫我號角，上尉。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 275, "prop": "Character", "attributes": {"name": "avg_npc_238"}}, {"id": 276, "prop": "name", "attributes": {"content": "好的，號角女士。我叫凱利，路易士·凱利。抱歉，我們這裡不流行代號。", "name": "？？？"}, "figure_art": "avg_npc_238"}, {"id": 277, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 278, "prop": "name", "attributes": {"content": "凱利上尉，您和您的部下想必也是為了追查這個倉庫而來。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 279, "prop": "Character", "attributes": {"name": "avg_npc_238"}}, {"id": 280, "prop": "name", "attributes": {"content": "是的，我們也收到了情報。", "name": "凱利上尉"}, "figure_art": "avg_npc_238"}, {"id": 281, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 282, "prop": "name", "attributes": {"content": "那您應當能理解事件的嚴重性。一批數量不少的非法源石製品，兩個月前就被人從軍用運輸路線上竊走，最後消失在這一帶。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 283, "prop": "Character", "attributes": {"name": "avg_npc_238"}}, {"id": 284, "prop": "name", "attributes": {"content": "咳......", "name": "凱利上尉"}, "figure_art": "avg_npc_238"}, {"id": 285, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 286, "prop": "name", "attributes": {"content": "不需要我來提醒您，上尉，這麼多武器，加上周邊各郡近期失竊的那些，如果全部落到不法分子的手裡，受到威脅的可遠不止小丘郡。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 287, "prop": "Character", "attributes": {"name": "avg_npc_238"}}, {"id": 288, "prop": "name", "attributes": {"content": "......好，謝謝你說這些。我明白。", "name": "凱利上尉"}, "figure_art": "avg_npc_238"}, {"id": 289, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 290, "prop": "name", "attributes": {"content": "我們也很感謝您的配合。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 291, "prop": "Character", "attributes": {"name": "avg_npc_238"}}, {"id": 292, "prop": "name", "attributes": {"content": "希爾！", "name": "凱利上尉"}, "figure_art": "avg_npc_238"}, {"id": 293, "prop": "Character", "attributes": {"name": "avg_npc_248"}}, {"id": 294, "prop": "name", "attributes": {"content": "長官。", "name": "副官希爾"}, "figure_art": "avg_npc_248"}, {"id": 295, "prop": "Character", "attributes": {"name": "avg_npc_238"}}, {"id": 296, "prop": "name", "attributes": {"content": "把這個年輕人......這個可疑分子抓回軍營。", "name": "凱利上尉"}, "figure_art": "avg_npc_238"}, {"id": 297, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#6"}}, {"id": 298, "prop": "name", "attributes": {"content": "啊？這人是我們好不容易找到的線索！", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#6"}, {"id": 299, "prop": "Character", "attributes": {"name": "avg_npc_248"}}, {"id": 300, "prop": "name", "attributes": {"content": "長官，她的矛在妨礙我執行任務。", "name": "副官希爾"}, "figure_art": "avg_npc_248"}, {"id": 301, "prop": "Character", "attributes": {"name": "avg_npc_238"}}, {"id": 302, "prop": "name", "attributes": {"content": "呃......", "name": "凱利上尉"}, "figure_art": "avg_npc_238"}, {"id": 303, "prop": "Character", "attributes": {"name": "avg_npc_229_1#7"}}, {"id": 304, "prop": "name", "attributes": {"content": "......", "name": "號角"}, "figure_art": "avg_npc_229_1#7"}, {"id": 305, "prop": "dialog", "attributes": {}}, {"id": 306, "prop": "character", "attributes": {}}, {"id": 307, "prop": "Character", "attributes": {"name": "avg_npc_229_1#2"}}, {"id": 308, "prop": "name", "attributes": {"content": "風笛，鬆手。", "name": "號角"}, "figure_art": "avg_npc_229_1#2"}, {"id": 309, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#5"}}, {"id": 310, "prop": "name", "attributes": {"content": "可是我們的任務——", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#5"}, {"id": 311, "prop": "Character", "attributes": {"name": "avg_npc_229_1#2"}}, {"id": 312, "prop": "name", "attributes": {"content": "——我們現在在小丘郡地界上。", "name": "號角"}, "figure_art": "avg_npc_229_1#2"}, {"id": 313, "prop": "dialog", "attributes": {}}, {"id": 314, "prop": "character", "attributes": {}}, {"id": 315, "prop": "name", "attributes": {"content": "凱利上尉從口袋裡掏出一塊手帕，擦了擦額上的汗。"}}, {"id": 316, "prop": "Character", "attributes": {"name": "avg_npc_238"}}, {"id": 317, "prop": "name", "attributes": {"content": "很高興你想通了，中尉。你與這位年輕的瓦伊凡女士，還有其他諸位......", "name": "凱利上尉"}, "figure_art": "avg_npc_238"}, {"id": 318, "prop": "name", "attributes": {"content": "咳咳，你們一路從倫蒂尼姆趕過來，想必路途艱辛，累得不輕。", "name": "凱利上尉"}, "figure_art": "avg_npc_238"}, {"id": 319, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 320, "prop": "name", "attributes": {"content": "這是我們身為維多利亞軍人的職責。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 321, "prop": "Character", "attributes": {"name": "avg_npc_238"}}, {"id": 322, "prop": "name", "attributes": {"content": "是啊，沒錯。接下來，如果你們還想在小丘郡活動的話......", "name": "凱利上尉"}, "figure_art": "avg_npc_238"}, {"id": 323, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 324, "prop": "name", "attributes": {"content": "我們必須繼續追查源石製品失竊案，這是來自倫蒂尼姆的命令。我想漢密爾頓上校也會理解。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 325, "prop": "Character", "attributes": {"name": "avg_npc_238"}}, {"id": 326, "prop": "name", "attributes": {"content": "當然，當然。你們可以隨我一塊回軍營。", "name": "凱利上尉"}, "figure_art": "avg_npc_238"}, {"id": 327, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#6"}}, {"id": 328, "prop": "name", "attributes": {"content": "隊長，我們真的要把人讓給他們嗎？他們絕對是故意的！從我們進入郊區地塊開始，他們就跟了上來！", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#6"}, {"id": 329, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#5"}}, {"id": 330, "prop": "name", "attributes": {"content": "直到現在我們抓到了人——", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#5"}, {"id": 331, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 332, "prop": "name", "attributes": {"content": "“帝國駐軍有責任對駐地發生的危害公共安全的事件進行響應。”", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 333, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 334, "prop": "name", "attributes": {"content": "他們沒有違反規定。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 335, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#4"}}, {"id": 336, "prop": "name", "attributes": {"content": "唉......好吧。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#4"}, {"id": 337, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 338, "prop": "name", "attributes": {"content": "上尉，人是你們的了。按照規定，我們也可以參與審訊——希望您還記得。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 339, "prop": "Character", "attributes": {"name": "avg_npc_238"}}, {"id": 340, "prop": "name", "attributes": {"content": "哈、哈哈......這確實符合規定。", "name": "凱利上尉"}, "figure_art": "avg_npc_238"}, {"id": 341, "prop": "Character", "attributes": {"name": "avg_npc_248", "name2": "avg_npc_242", "focus": 2.0}}, {"id": 342, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 343, "prop": "name", "attributes": {"content": "不、不要......放開我！不要抓我！", "name": "慌張的青年"}, "figure_art": "avg_npc_242"}, {"id": 344, "prop": "Character", "attributes": {"name": "avg_npc_248", "name2": "avg_npc_242", "focus": 1.0}}, {"id": 345, "prop": "name", "attributes": {"content": "呵......", "name": "副官希爾"}, "figure_art": "avg_npc_248"}, {"id": 346, "prop": "Character", "attributes": {"name": "avg_npc_248", "name2": "avg_npc_242", "focus": 2.0}}, {"id": 347, "prop": "name", "attributes": {"content": "救我......救救我！我什麼都沒幹......我不知道......", "name": "慌張的青年"}, "figure_art": "avg_npc_242"}, {"id": 348, "prop": "CameraShake", "attributes": {"duration": 0.8, "xstrength": 50.0, "ystrength": 50.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 349, "prop": "name", "attributes": {"content": "啊啊啊！", "name": "慌張的青年"}, "figure_art": "avg_npc_242"}, {"id": 350, "prop": "dialog", "attributes": {}}, {"id": 351, "prop": "Character", "attributes": {"name": "avg_npc_248", "name2": "avg_npc_242", "focus": 1.0}}, {"id": 352, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 353, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.03, "block": "true"}}, {"id": 354, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 40.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 355, "prop": "PlaySound", "attributes": {"key": "$fightgeneral", "volume": 1.0}}, {"id": 356, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 357, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 358, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown2", "volume": 1.0}}, {"id": 359, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "fadetime": 2.0, "block": "true"}}, {"id": 360, "prop": "character", "attributes": {"name": "avg_npc_248", "name2": "char_empty", "fadetime": 0.5}}, {"id": 361, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 362, "prop": "Character", "attributes": {"name": "avg_npc_238"}}, {"id": 363, "prop": "name", "attributes": {"content": "希爾......", "name": "凱利上尉"}, "figure_art": "avg_npc_238"}, {"id": 364, "prop": "Character", "attributes": {"name": "avg_npc_248"}}, {"id": 365, "prop": "name", "attributes": {"content": "這些塔拉渣滓總是這麼聒噪。", "name": "副官希爾"}, "figure_art": "avg_npc_248"}, {"id": 366, "prop": "Character", "attributes": {"name": "avg_npc_238"}}, {"id": 367, "prop": "name", "attributes": {"content": "......帶走吧。", "name": "凱利上尉"}, "figure_art": "avg_npc_238"}, {"id": 368, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#4"}}, {"id": 369, "prop": "name", "attributes": {"content": "欸欸，這人怎麼這樣啊！", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#4"}, {"id": 370, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#4"}}, {"id": 371, "prop": "name", "attributes": {"content": "（隊長，我覺得......那個年輕菲林在向我們求救。他很害怕跟他們走。）", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#4"}, {"id": 372, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 373, "prop": "name", "attributes": {"content": "（......）", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 374, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 375, "prop": "name", "attributes": {"content": "（三角鐵？）", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 376, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 377, "prop": "name", "attributes": {"content": "我在，隊長。我還在外面樹上老位置，他們沒注意到我。", "name": "三角鐵"}, "figure_art": "avg_npc_229_1#1"}, {"id": 378, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 379, "prop": "name", "attributes": {"content": "（那就好。你帶著偵察小組，繼續沿附近運輸路線調查。有線索立刻彙報。）", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 380, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 381, "prop": "name", "attributes": {"content": "好。隊長，需要向駐軍通報嗎？", "name": "三角鐵"}, "figure_art": "avg_npc_229_1#1"}, {"id": 382, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 383, "prop": "name", "attributes": {"content": "......", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 384, "prop": "Character", "attributes": {"name": "avg_npc_229_1#2"}}, {"id": 385, "prop": "name", "attributes": {"content": "不用。", "name": "號角"}, "figure_art": "avg_npc_229_1#2"}, {"id": 386, "prop": "Character", "attributes": {"name": "avg_npc_229_1#2"}}, {"id": 387, "prop": "name", "attributes": {"content": "......注意保護自己。", "name": "號角"}, "figure_art": "avg_npc_229_1#2"}, {"id": 388, "prop": "Dialog", "attributes": {}}, {"id": 389, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 390, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 391, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 392, "prop": "Character", "attributes": {}}, {"id": 393, "prop": "Image", "attributes": {}}, {"id": 394, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}