e": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 331, "prop": "Subtitle", "attributes": {"text": "死魂靈永不動搖！", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 332, "prop": "subtitle", "attributes": {}}, {"id": 333, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 334, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 335, "prop": "Blocker", "attributes": {"a": 1.0, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 1.5, "block": "true"}}, {"id": 336, "prop": "charslot", "attributes": {}}, {"id": 337, "prop": "Image", "attributes": {}}, {"id": 338, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 339, "prop": "Background", "attributes": {"image": "43_g1_giantmonstercockpit", "screenadapt": "coverall"}}, {"id": 340, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 341, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 342, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1035_wisdel_1#4$1", "focus": "m"}}, {"id": 343, "prop": "name", "attributes": {"content": "成功了！抓住飛空艇了！", "name": "W"}, "figure_art": "avg_1035_wisdel_1#4$1"}, {"id": 344, "prop": "Dialog", "attributes": {}}, {"id": 345, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1035_wisdel_1#4$1", "focus": "none"}}, {"id": 346, "prop": "Decision", "attributes": {"options": "W，開始行動。;把飛空艇一起帶走。", "values": "1;2"}, "targetLine": {"option1": "line347", "option2": "line347"}}, {"id": 347, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 348, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1035_wisdel_1#4$1", "focus": "m"}}, {"id": 349, "prop": "name", "attributes": {"content": "別指揮我！我知道該怎麼做！", "name": "W"}, "figure_art": "avg_1035_wisdel_1#4$1"}, {"id": 350, "prop": "name", "attributes": {"content": "骨頭架子！到你發揮！快動——", "name": "W"}, "figure_art": "avg_1035_wisdel_1#4$1"}, {"id": 351, "prop": "Dialog", "attributes": {}}, {"id": 352, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 353, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1035_wisdel_1#6$1", "focus": "m"}}, {"id": 354, "prop": "name", "attributes": {"content": "等等——為什麼不動了！", "name": "W"}, "figure_art": "avg_1035_wisdel_1#6$1"}, {"id": 355, "prop": "Dialog", "attributes": {}}, {"id": 356, "prop": "PlaySound", "attributes": {"key": "$d_avg_punch", "channel": "1"}}, {"id": 357, "prop": "CameraShake", "attributes": {"duration": 0.3, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 358, "prop": "PlaySound", "attributes": {"key": "$d_avg_punch", "channel": "2"}}, {"id": 359, "prop": "CameraShake", "attributes": {"duration": 0.3, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 360, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1035_wisdel_1#4$1", "focus": "m"}}, {"id": 361, "prop": "name", "attributes": {"content": "喂喂？給點反應！", "name": "W"}, "figure_art": "avg_1035_wisdel_1#4$1"}, {"id": 362, "prop": "Dialog", "attributes": {}}, {"id": 363, "prop": "PlaySound", "attributes": {"key": "$d_avg_punch", "channel": "1"}}, {"id": 364, "prop": "CameraShake", "attributes": {"duration": 0.3, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 365, "prop": "PlaySound", "attributes": {"key": "$d_avg_punch", "channel": "2"}}, {"id": 366, "prop": "CameraShake", "attributes": {"duration": 0.3, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 367, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_394_1#14$1", "focus": "m"}}, {"id": 368, "prop": "name", "attributes": {"content": "巨獸骸骨受創很嚴重，它的靈魂好像再一次遊走了——", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#14$1"}, {"id": 369, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1035_wisdel_1#4$1", "focus": "m"}}, {"id": 370, "prop": "name", "attributes": {"content": "這種時候？！！", "name": "W"}, "figure_art": "avg_1035_wisdel_1#4$1"}, {"id": 371, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_394_1#14$1", "focus": "m"}}, {"id": 372, "prop": "name", "attributes": {"content": "這樣下去骸骨反而會被飛空艇拖走的！", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#14$1"}, {"id": 373, "prop": "name", "attributes": {"content": "博士，我們該怎麼辦？", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#14$1"}, {"id": 374, "prop": "Dialog", "attributes": {}}, {"id": 375, "prop": "charslot", "attributes": {}}, {"id": 376, "prop": "Decision", "attributes": {"options": "跳幫戰。;靠我們自己去阻止飛空艇。", "values": "1;2"}, "targetLine": {"option1": "line377", "option2": "line377"}}, {"id": 377, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 378, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1035_wisdel_1#1$1", "focus": "m"}}, {"id": 379, "prop": "name", "attributes": {"content": "好傢伙，你的戰術真是越來越大膽，我都忍不住要誇你了。", "name": "W"}, "figure_art": "avg_1035_wisdel_1#1$1"}, {"id": 380, "prop": "Dialog", "attributes": {}}, {"id": 381, "prop": "charslot", "attributes": {}}, {"id": 382, "prop": "Decision", "attributes": {"options": "阿米婭，凱爾希，你們是最熟悉死魂靈的人。", "values": "1"}, "targetLine": {"option1": "line383"}}, {"id": 383, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 384, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_394_1#7$1", "focus": "m"}}, {"id": 385, "prop": "name", "attributes": {"content": "嗯，我準備好了。", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#7$1"}, {"id": 386, "prop": "Dialog", "attributes": {}}, {"id": 387, "prop": "charslot", "attributes": {}}, {"id": 388, "prop": "Decision", "attributes": {"options": "W，你的炸彈在敵人主場更能發揮作用。", "values": "1"}, "targetLine": {"option1": "line389"}}, {"id": 389, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 390, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1035_wisdel_1#1$1", "focus": "m"}}, {"id": 391, "prop": "name", "attributes": {"content": "用不著你說。", "name": "W"}, "figure_art": "avg_1035_wisdel_1#1$1"}, {"id": 392, "prop": "Dialog", "attributes": {}}, {"id": 393, "prop": "charslot", "attributes": {}}, {"id": 394, "prop": "Decision", "attributes": {"options": "Logos，請保護“生命脊椎”。", "values": "1"}, "targetLine": {"option1": "line395"}}, {"id": 395, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 396, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4133_logos_1#1$1", "focus": "m"}}, {"id": 397, "prop": "name", "attributes": {"content": "半小時內，我必不會讓任何敵人靠近。", "name": "Logos"}, "figure_art": "avg_4133_logos_1#1$1"}, {"id": 398, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1", "focus": "m"}}, {"id": 399, "prop": "name", "attributes": {"content": "博士，我需要你與我們一同前往飛空艇。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 400, "prop": "Dialog", "attributes": {}}, {"id": 401, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1", "focus": "none"}}, {"id": 402, "prop": "Decision", "attributes": {"options": "我知道了。", "values": "1"}, "targetLine": {"option1": "line403"}}, {"id": 403, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 404, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1", "focus": "m"}}, {"id": 405, "prop": "name", "attributes": {"content": "……你沒有猶豫，也沒有提問。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 406, "prop": "Dialog", "attributes": {}}, {"id": 407, "prop": "charslot", "attributes": {}}, {"id": 408, "prop": "Decision", "attributes": {"options": "現在還不是時候，對吧。", "values": "1"}, "targetLine": {"option1": "line409"}}, {"id": 409, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 410, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1035_wisdel_1#4$1", "focus": "m"}}, {"id": 411, "prop": "name", "attributes": {"content": "別廢話了，決定了計劃就趕快走！", "name": "W"}, "figure_art": "avg_1035_wisdel_1#4$1"}, {"id": 412, "prop": "name", "attributes": {"content": "小兔子，我們沿著這道神經束滑過去，別讓自己暴露在那些巫靈的射程裡！", "name": "W"}, "figure_art": "avg_1035_wisdel_1#4$1"}, {"id": 413, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_394_1#13$1", "focus": "m"}}, {"id": 414, "prop": "name", "attributes": {"content": "明白，我會攔截那些流彈。", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#13$1"}, {"id": 415, "prop": "name", "attributes": {"content": "博士，凱爾希醫生，我們會清理出登陸場地。", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#13$1"}, {"id": 416, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_394_1#17$1", "focus": "m"}}, {"id": 417, "prop": "name", "attributes": {"content": "請務必小心。", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#17$1"}, {"id": 418, "prop": "Dialog", "attributes": {}}, {"id": 419, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0}}, {"id": 420, "prop": "charslot", "attributes": {"duration": 1.5}}, {"id": 421, "prop": "Delay", "attributes": {"time": 3.0}}, {"id": 422, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1", "focus": "m"}}, {"id": 423, "prop": "name", "attributes": {"content": "Mon3tr。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 424, "prop": "charslot", "attributes": {"slot": "m", "name": "npc_10002", "focus": "m"}}, {"id": 425, "prop": "PlaySound", "attributes": {"key": "$char_Mon3tr", "volume": 1.0}}, {"id": 426, "prop": "name", "attributes": {"content": "（歡快的嘶鳴）", "name": "Mon3tr"}, "figure_art": "npc_10002"}, {"id": 427, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1", "focus": "m"}}, {"id": 428, "prop": "name", "attributes": {"content": "抓緊它，博士。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 429, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#4$1", "focus": "m"}}, {"id": 430, "prop": "name", "attributes": {"content": "有些東西……只有你才能掌控。你也許會是我們艱難時刻中最後的希望。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#4$1"}, {"id": 431, "prop": "name", "attributes": {"content": "就如同你曾經的樣子。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#4$1"}, {"id": 432, "prop": "Dialog", "attributes": {}}, {"id": 433, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 434, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 435, "prop": "charslot", "attributes": {}}, {"id": 436, "prop": "Background", "attributes": {"image": "bg_black", "screenadapt": "coverall"}}, {"id": 437, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 438, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 439, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 440, "prop": "name", "attributes": {"content": "Mon3tr抱住你一躍而下，失重的感覺讓你有些慌張，劇烈的風刮得你睜不開眼。"}}, {"id": 441, "prop": "name", "attributes": {"content": "Logos的咒言與W的歡笑遠遠傳進你的耳朵。爆炸聲連綿不絕，那是薩卡茲的無人機被擊落的聲音。"}}, {"id": 442, "prop": "name", "attributes": {"content": "失重感終於消失，有人牽住了你的手。"}}, {"id": 443, "prop": "Dialog", "attributes": {}}, {"id": 444, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 445, "prop": "Blocker", "attributes": {"a": 1.0, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 2.0, "block": "true"}}, {"id": 446, "prop": "charslot", "attributes": {}}, {"id": 447, "prop": "Background", "attributes": {"image": "50_g9_airshipdeck", "screenadapt": "coverall"}}, {"id": 448, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 449, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 450, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 451, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_394_1#1$1", "focus": "m"}}, {"id": 452, "prop": "name", "attributes": {"content": "博士。", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#1$1"}, {"id": 453, "prop": "name", "attributes": {"content": "我們到了。", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#1$1"}, {"id": 454, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1035_wisdel_1#6$1", "focus": "m"}}, {"id": 455, "prop": "name", "attributes": {"content": "……", "name": "W"}, "figure_art": "avg_1035_wisdel_1#6$1"}, {"id": 456, "prop": "name", "attributes": {"content": "看來有個老傢伙來找我們打招呼了。", "name": "W"}, "figure_art": "avg_1035_wisdel_1#6$1"}, {"id": 457, "prop": "name", "attributes": {"content": "這艘船是隻死魂靈，對吧？看來它不怎麼願意有人站在它的頭皮上。", "name": "W"}, "figure_art": "avg_1035_wisdel_1#6$1"}, {"id": 458, "prop": "Dialog", "attributes": {}}, {"id": 459, "prop": "charslot", "attributes": {}}, {"id": 460, "prop": "name", "attributes": {"content": "怪異的影子自金屬的牆壁中析出，一瞬間就擠滿了飛空艇甲板的每個角落。"}}, {"id": 461, "prop": "name", "attributes": {"content": "它們在微微顫動，它們收縮的節奏就是死魂靈的呼吸本身。"}}, {"id": 462, "prop": "Dialog", "attributes": {}}, {"id": 463, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1340_1#1$1", "duration": 1.5}}, {"id": 464, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1340_1#1$1", "duration": 1.5}}, {"id": 465, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 466, "prop": "name", "attributes": {"content": "……", "name": "怪異的影子"}, "figure_art": "avg_npc_1340_1#1$1"}, {"id": 467, "prop": "Dialog", "attributes": {}}, {"id": 468, "prop": "charslot", "attributes": {}}, {"id": 469, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_394_1#15$1", "focus": "m"}}, {"id": 470, "prop": "name", "attributes": {"content": "這是死魂靈的造物。", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#15$1"}, {"id": 471, "prop": "name", "attributes": {"content": "它早有準備。它不會讓我們輕易將它停下。", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#15$1"}, {"id": 472, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1035_wisdel_1#1$1", "focus": "m"}}, {"id": 473, "prop": "name", "attributes": {"content": "簡單，那我們就揍到它不得不停下。", "name": "W"}, "figure_art": "avg_1035_wisdel_1#1$1"}, {"id": 474, "prop": "name", "attributes": {"content": "這次，我帶好了足量的炸彈。", "name": "W"}, "figure_art": "avg_1035_wisdel_1#1$1"}, {"id": 475, "prop": "Dialog", "attributes": {}}, {"id": 476, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 477, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 478, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 479, "prop": "charslot", "attributes": {}}, {"id": 480, "prop": "Image", "attributes": {}}, {"id": 481, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}