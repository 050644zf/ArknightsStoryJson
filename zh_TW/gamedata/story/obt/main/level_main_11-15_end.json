d", "volume": 0.4}}, {"id": 63, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 10.0, "ystrength": 12.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 64, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 65, "prop": "PlaySound", "attributes": {"key": "$d_avg_originiumcastshort", "volume": 0.9}}, {"id": 66, "prop": "Blocker", "attributes": {"a": 0.7, "r": 0.95, "g": 0.95, "b": 0.95, "fadetime": 0.4, "block": "true"}}, {"id": 67, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.95, "g": 0.95, "b": 0.95, "fadetime": 2.0, "block": "true"}}, {"id": 68, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 69, "prop": "name", "attributes": {"content": "長劍刺向地面，輝光瞬間漫開。"}}, {"id": 70, "prop": "name", "attributes": {"content": "所有人都感到了時間的刹那停滯。"}}, {"id": 71, "prop": "Dialog", "attributes": {}}, {"id": 72, "prop": "character", "attributes": {"name": "avg_npc_062"}}, {"id": 73, "prop": "name", "attributes": {"content": "......赦罪師的巫術。", "name": "特雷西斯"}, "figure_art": "avg_npc_062"}, {"id": 74, "prop": "Character", "attributes": {"name": "avg_npc_404_1#6$1"}}, {"id": 75, "prop": "name", "attributes": {"content": "將軍！", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#6$1"}, {"id": 76, "prop": "name", "attributes": {"content": "凱爾希勳爵她......", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#6$1"}, {"id": 77, "prop": "character", "attributes": {"name": "avg_npc_062"}}, {"id": 78, "prop": "name", "attributes": {"content": "她這一次的生命正走向尾聲。", "name": "特雷西斯"}, "figure_art": "avg_npc_062"}, {"id": 79, "prop": "Character", "attributes": {"name": "avg_npc_404_1#1$1"}}, {"id": 80, "prop": "name", "attributes": {"content": "羅德島的卡特斯也被救走了。血魔大君正在追擊女妖和阿斯卡綸。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 81, "prop": "character", "attributes": {"name": "avg_npc_062"}}, {"id": 82, "prop": "name", "attributes": {"content": "特蕾西婭那邊的情況如何？", "name": "特雷西斯"}, "figure_art": "avg_npc_062"}, {"id": 83, "prop": "Character", "attributes": {"name": "avg_npc_404_1#1$1"}}, {"id": 84, "prop": "name", "attributes": {"content": "將軍，我剛剛收到殿下的信號。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 85, "prop": "name", "attributes": {"content": "它已經準備好了。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 86, "prop": "character", "attributes": {"name": "avg_npc_062"}}, {"id": 87, "prop": "name", "attributes": {"content": "很好。", "name": "特雷西斯"}, "figure_art": "avg_npc_062"}, {"id": 88, "prop": "Dialog", "attributes": {}}, {"id": 89, "prop": "Character", "attributes": {}}, {"id": 90, "prop": "name", "attributes": {"content": "攝政王抬頭看向陰雲遮蔽下的天空和遠處的高牆。"}}, {"id": 91, "prop": "name", "attributes": {"content": "高牆之外，才是薩卡茲真正關注的戰場。"}}, {"id": 92, "prop": "Dialog", "attributes": {}}, {"id": 93, "prop": "character", "attributes": {"name": "avg_npc_062", "fadetime": 0.5}}, {"id": 94, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 95, "prop": "name", "attributes": {"content": "那麼，該開始了。", "name": "特雷西斯"}, "figure_art": "avg_npc_062"}, {"id": 96, "prop": "Dialog", "attributes": {}}, {"id": 97, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 98, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 99, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 100, "prop": "Character", "attributes": {}}, {"id": 101, "prop": "Background", "attributes": {"image": "32_g9_kingrest", "screenadapt": "showall"}}, {"id": 102, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 103, "prop": "PlayMusic", "attributes": {"key": "$calm_loop", "volume": 0.4}}, {"id": 104, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 105, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 106, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$2", "name2": "avg_npc_397_1#1$1", "fadetime": 1.0, "block": "true"}}, {"id": 107, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 108, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$2", "name2": "avg_npc_397_1#1$1", "focus": 2.0}}, {"id": 109, "prop": "name", "attributes": {"content": "......準備好了嗎？", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 110, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$2", "name2": "avg_npc_397_1#1$1", "focus": 1.0}}, {"id": 111, "prop": "name", "attributes": {"content": "沒什麼好準備的。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#1$2"}, {"id": 112, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$2", "name2": "avg_npc_397_1#1$1", "focus": 2.0}}, {"id": 113, "prop": "name", "attributes": {"content": "是啊，我們終於走到了這裡。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 114, "prop": "name", "attributes": {"content": "維娜，我必須——", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 115, "prop": "name", "attributes": {"content": "我們必須，見證這一切。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 116, "prop": "musicvolume", "attributes": {"volume": 0.2, "fadetime": 1.0}}, {"id": 117, "prop": "Dialog", "attributes": {}}, {"id": 118, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 119, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 120, "prop": "Character", "attributes": {}}, {"id": 121, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 122, "prop": "Background", "attributes": {"image": "32_g10_kingrestcore", "screenadapt": "showall"}}, {"id": 123, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 124, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 125, "prop": "musicvolume", "attributes": {"volume": 0.4, "fadetime": 1.0}}, {"id": 126, "prop": "name", "attributes": {"content": "黑色的建築在地下空間的盡頭沉默著，精巧複雜的結構排布其中。"}}, {"id": 127, "prop": "name", "attributes": {"content": "維多利亞一代又一代最傑出的頭腦曾聚集在這裡，他們傾盡心血構造了這一切。"}}, {"id": 128, "prop": "name", "attributes": {"content": "卻只為了將那把劍安放其中。"}}, {"id": 129, "prop": "dialog", "attributes": {}}, {"id": 130, "prop": "Background", "attributes": {"screenadapt": "showall", "image": "32_g10_kingrestcore", "x": 100.0, "y": 0.0, "xScale": 1.3, "yScale": 1.3, "fadetime": 1.0}}, {"id": 131, "prop": "Blocker", "attributes": {"a": 1.0, "r": 1.0, "g": 1.0, "b": 1.0, "block": "true", "image": "blocker_movi", "fadetime": 1.0}}, {"id": 132, "prop": "backgroundTween", "attributes": {"xFrom": 100.0, "yFrom": 0.0, "yTo": 0.0, "xScaleFrom": 1.3, "yScaleFrom": 1.3, "xScaleTo": 1.3, "yScaleTo": 1.3, "duration": 20.0, "block": "false"}}, {"id": 133, "prop": "name", "attributes": {"content": "能握住它劈開天災的英雄實在罕有，那麼就以人類的智慧張開這面抵禦風暴的盾牌。"}}, {"id": 134, "prop": "name", "attributes": {"content": "這些結構，乃至這座建築，都是因此而生。"}}, {"id": 135, "prop": "name", "attributes": {"content": "聲音又出現了。"}}, {"id": 136, "prop": "name", "attributes": {"content": "那些呼喚不再急切，不再尖銳，也沒有了規勸或煽動的意涵。"}}, {"id": 137, "prop": "name", "attributes": {"content": "取而代之的，她感受到某種帶著疲憊的安寧。"}}, {"id": 138, "prop": "name", "attributes": {"content": "是的，她來過這裡，早在記憶成形之前，就有人指引她來到過這個地方。"}}, {"id": 139, "prop": "name", "attributes": {"content": "就和當時一樣，在這一刻，她知道自己該去往何處，該拿起什麼。"}}, {"id": 140, "prop": "name", "attributes": {"content": "它就在那裡，筆直地插在房間中央，無人拱衛，無物保護，普通得就像整座建築中的一件小小裝飾品。"}}, {"id": 141, "prop": "Dialog", "attributes": {}}, {"id": 142, "prop": "musicvolume", "attributes": {"volume": 0.2, "fadetime": 1.0}}, {"id": 143, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 144, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 145, "prop": "Character", "attributes": {}}, {"id": 146, "prop": "Background", "attributes": {}}, {"id": 147, "prop": "Image", "attributes": {}}, {"id": 148, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 149, "prop": "Image", "attributes": {"image": "32_i10", "screenadapt": "coverall"}}, {"id": 150, "prop": "ImageTween", "attributes": {"xFrom": 0.0, "xTo": 0.0, "yTo": 100.0, "xScaleFrom": 1.7, "yScaleFrom": 1.7, "xScaleTo": 1.7, "yScaleTo": 1.7, "duration": 15.0, "block": "false"}}, {"id": 151, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 152, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 153, "prop": "musicvolume", "attributes": {"volume": 0.4, "fadetime": 1.0}}, {"id": 154, "prop": "name", "attributes": {"content": "諸王之息。"}}, {"id": 155, "prop": "name", "attributes": {"content": "經過千年歲月，多次重鑄，它始終在那裡。"}}, {"id": 156, "prop": "name", "attributes": {"content": "推進之王向它伸出手。"}}, {"id": 157, "prop": "name", "attributes": {"content": "破碎的幻影彌漫在整個空間中，他們在起伏，他們在共振。"}}, {"id": 158, "prop": "name", "attributes": {"content": "亞歷山德莉娜。亞歷山德莉娜·維娜·維多利亞。他們在她耳旁反覆呢喃她的名字與姓氏。"}}, {"id": 159, "prop": "Dialog", "attributes": {}}, {"id": 160, "prop": "Image", "attributes": {"image": "32_i10", "screenadapt": "coverall", "fadetime": 2.0}}, {"id": 161, "prop": "name", "attributes": {"content": "她觸碰到了那把劍。"}}, {"id": 162, "prop": "name", "attributes": {"content": "往日的碎片徑直從她的身體裡穿過，轟鳴聲從她的大腦深處炸開。"}}, {"id": 163, "prop": "name", "attributes": {"content": "她忽然明白了。"}}, {"id": 164, "prop": "name", "attributes": {"content": "那些畫面，那些聲音的源頭正是她自己。"}}, {"id": 165, "prop": "name", "attributes": {"content": "是她自己的猶豫、困惑、悔恨、追戀。"}}, {"id": 166, "prop": "name", "attributes": {"content": "是她已經忘卻的和故意忘卻的東西。"}}, {"id": 167, "prop": "name", "attributes": {"content": "一隻巨手將她舉起，倫蒂尼姆在她身下站了起來，托著她行走過維多利亞的土地。"}}, {"id": 168, "prop": "name", "attributes": {"content": "那是她和她的夥伴們曾經行過的土地。"}}, {"id": 169, "prop": "name", "attributes": {"content": "無數個聲音交疊在一起。"}}, {"id": 170, "prop": "name", "attributes": {"content": "維多利亞。維多利亞。"}}, {"id": 171, "prop": "name", "attributes": {"content": "這就是維多利亞。"}}, {"id": 172, "prop": "name", "attributes": {"content": "這就是她的維多利亞。"}}, {"id": 173, "prop": "Dialog", "attributes": {}}, {"id": 174, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 175, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 176, "prop": "Character", "attributes": {}}, {"id": 177, "prop": "Background", "attributes": {}}, {"id": 178, "prop": "Image", "attributes": {}}, {"id": 179, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 180, "prop": "Background", "attributes": {"image": "bg_black", "screenadapt": "showall"}}, {"id": 181, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 182, "prop": "Subtitle", "attributes": {"text": "“維娜，維娜。”", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 183, "prop": "subtitle", "attributes": {}}, {"id": 184, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 185, "prop": "name", "attributes": {"content": "耳畔傳來一連串呼喊。"}}, {"id": 186, "prop": "Dialog", "attributes": {}}, {"id": 187, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 188, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 189, "prop": "Character", "attributes": {}}, {"id": 190, "prop": "Background", "attributes": {"image": "32_g10_kingrestcore", "screenadapt": "showall"}}, {"id": 191, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 192, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 193, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 194, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$2", "fadetime": 1.0, "block": "true"}}, {"id": 195, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 196, "prop": "name", "attributes": {"content": "——", "name": "推進之王"}, "figure_art": "avg_npc_407_1#1$2"}, {"id": 197, "prop": "Dialog", "attributes": {}}, {"id": 198, "prop": "Character", "attributes": {}}, {"id": 199, "prop": "name", "attributes": {"content": "推進之王睜開眼睛，再沒有幻覺，再沒有浪潮，而象徵著維多利亞王權的諸王之息正握在她手裡。"}}, {"id": 200, "prop": "name", "attributes": {"content": "它看起來並沒有傳說中的那麼特別，並不巨大，也沒有什麼誇張的裝飾。"}}, {"id": 201, "prop": "name", "attributes": {"content": "似乎就只是一把普通的劍而已。"}}, {"id": 202, "prop": "Dialog", "attributes": {}}, {"id": 203, "prop": "Character", "attributes": {"name": "avg_npc_397_1#1$1"}}, {"id": 204, "prop": "name", "attributes": {"content": "維娜，你握住了諸王之息。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 205, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$2"}}, {"id": 206, "prop": "name", "attributes": {"content": "它比我想像的......要輕一些。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#1$2"}, {"id": 207, "prop": "Character", "attributes": {"name": "avg_npc_407_1#9$2"}}, {"id": 208, "prop": "multiline", "attributes": {"name": "推進之王", "content": " 走吧，我們該回家了。"}}, {"id": 209, "prop": "Character", "attributes": {"name": "avg_npc_407_1#8$2"}}, {"id": 210, "prop": "multiline", "attributes": {"name": "推進之王", "end": "true", "content": " 我們——", "joined": "我也不想打架的。可是......特蕾西婭把我從閣樓里拉了出來。阿米婭和凱爾希讓我知道了這份工作的責任有多重。 走吧，我們該回家了。 我們——"}}, {"id": 211, "prop": "Dialog", "attributes": {}}, {"id": 212, "prop": "Character", "attributes": {"fadetime": 0.3}}, {"id": 213, "prop": "name", "attributes": {"content": "推進之王想轉過身，和朋友們一同感受這把劍的溫度。"}}, {"id": 214, "prop": "Dialog", "attributes": {}}, {"id": 215, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 216, "prop": "PlaySound", "attributes": {"key": "$d_avg_unsheathe", "volume": 0.5}}, {"id": 217, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 218, "prop": "Character", "attributes": {"name": "avg_npc_397_1#5$1", "fadetime": 0.5}}, {"id": 219, "prop": "name", "attributes": {"content": "......別回頭。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#5$1"}, {"id": 220, "prop": "Dialog", "attributes": {}}, {"id": 221, "prop": "Character", "attributes": {}}, {"id": 222, "prop": "name", "attributes": {"content": "一把更為冰冷的刀卻抵在了她的腰間。"}}, {"id": 223, "prop": "Dialog", "attributes": {}}, {"id": 224, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$2"}}, {"id": 225, "prop": "name", "attributes": {"content": "......阿勒黛。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#1$2"}, {"id": 226, "prop": "playMusic", "attributes": {"intro": "$loneliness_intro", "key": "$loneliness_loop", "volume": 0.4}}, {"id": 227, "prop": "Character", "attributes": {"name": "avg_npc_397_1#5$1"}}, {"id": 228, "prop": "name", "attributes": {"content": "別回頭！求你了，別回頭。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#5$1"}, {"id": 229, "prop": "name", "attributes": {"content": "......把這把劍交給我。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#5$1"}, {"id": 230, "prop": "Character", "attributes": {"name": "avg_npc_407_1#2$2"}}, {"id": 231, "prop": "name", "attributes": {"content": "......", "name": "推進之王"}, "figure_art": "avg_npc_407_1#2$2"}, {"id": 232, "prop": "Character", "attributes": {"name": "avg_npc_397_1#7$1"}}, {"id": 233, "prop": "name", "attributes": {"content": "亞歷山德莉娜殿下，我很抱歉，我真的......非常非常抱歉。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#7$1"}, {"id": 234, "prop": "name", "attributes": {"content": "我必須......", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#7$1"}, {"id": 235, "prop": "Character", "attributes": {"name": "avg_npc_397_1#5$1"}}, {"id": 236, "prop": "name", "attributes": {"content": "......", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#5$1"}, {"id": 237, "prop": "Character", "attributes": {"name": "avg_npc_397_1#7$1"}}, {"id": 238, "prop": "name", "attributes": {"content": "我只能如此。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#7$1"}, {"id": 239, "prop": "Dialog", "attributes": {}}, {"id": 240, "prop": "Character", "attributes": {}}, {"id": 241, "prop": "name", "attributes": {"content": "阿勒黛的聲音平靜如水，卻凝結著恢宏決絕的悲哀。"}}, {"id": 242, "prop": "name", "attributes": {"content": "推進之王突然想起了摩根玩笑似的寫的那本“回憶錄”，還只有寥寥幾頁。"}}, {"id": 243, "prop": "name", "attributes": {"content": "句子結構簡陋，用詞也算不上典雅。"}}, {"id": 244, "prop": "name", "attributes": {"content": "故事以一場胡編亂造的打鬥開始。戰鬥結束後，大家回到據點，故事裡的阿勒黛親自下廚，為大家煮了一鍋奶油燉菜湯。"}}, {"id": 245, "prop": "name", "attributes": {"content": "她在心裡輕輕笑了笑，阿勒黛真的為大家做過燉菜湯，可在回憶錄裡省略的部分是......"}}, {"id": 246, "prop": "name", "attributes": {"content": "口味實在說不上太好。"}}, {"id": 247, "prop": "Dialog", "attributes": {}}, {"id": 248, "prop": "Character", "attributes": {"name": "avg_npc_396_1#7$1"}}, {"id": 249, "prop": "name", "attributes": {"content": "推進之王！", "name": "達格達"}, "figure_art": "avg_npc_396_1#7$1"}, {"id": 250, "prop": "Dialog", "attributes": {}}, {"id": 251, "prop": "Character", "attributes": {"name": "char_empty", "name2": "char_empty"}}, {"id": 252, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0}}, {"id": 253, "prop": "characteraction", "attributes": {"name": "left", "type": "move", "fadetime": 0.0, "block": "true"}}, {"id": 254, "prop": "delay", "attributes": {"time": 0.15}}, {"id": 255, "prop": "Character", "attributes": {"name": "avg_npc_396_1#7$1", "name2": "char_empty", "fadetime": 2.0}}, {"id": 256, "prop": "characteraction", "attributes": {"name": "left", "type": "move", "xpos": 600.0, "fadetime": 0.8, "block": "false"}}, {"id": 257, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 258, "prop": "characteraction", "attributes": {"name": "left", "type": "jump", "times": 1.0, "power": 10.0, "fadetime": 0.4, "block": "false"}}, {"id": 259, "prop": "PlaySound", "attributes": {"key": "$d_avg_runstop"}}, {"id": 260, "prop": "delay", "attributes": {"time": 0.6}}, {"id": 261, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 262, "prop": "name", "attributes": {"content": "呃——！", "name": "達格達"}}, {"id": 263, "prop": "Character", "attributes": {"name": "avg_npc_396_1#5$1", "name2": "avg_4062_totter_1#1$1", "fadetime": 1.0}}, {"id": 264, "prop": "PlaySound", "attributes": {"key": "$d_avg_swordexsheath", "volume": 1.0}}, {"id": 265, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 266, "prop": "Character", "attributes": {"name": "avg_npc_396_1#5$1", "name2": "avg_4062_totter_1#1$1", "focus": 2.0}}, {"id": 267, "prop": "name", "attributes": {"content": "......別動。", "name": "鉛踝"}, "figure_art": "avg_4062_totter_1#1$1"}, {"id": 268, "prop": "dialog", "attributes": {}}, {"id": 269, "prop": "character", "attributes": {}}, {"id": 270, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 271, "prop": "PlaySound", "attributes": {"key": "$d_gen_soldiersrun", "volume": 1.0}}, {"id": 272, "prop": "Character", "attributes": {"name": "avg_npc_399_1#1$1", "enter": "left", "name2": "avg_npc_399_1#1$1", "enter2": "right", "fadetime": 1.5, "block": "true"}}, {"id": 273, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 274, "prop": "Character", "attributes": {"name": "avg_npc_396_1#5$1", "name2": "avg_4062_totter_1#1$1", "focus": 1.0}}, {"id": 275, "prop": "name", "attributes": {"content": "你也......你們都......", "name": "達格達"}, "figure_art": "avg_npc_396_1#5$1"}, {"id": 276, "prop": "Character", "attributes": {"name": "avg_npc_396_1#5$1", "name2": "avg_4062_totter_1#2$1", "focus": 2.0}}, {"id": 277, "prop": "name", "attributes": {"content": "我不想傷害你，騎士小姐。", "name": "鉛踝"}, "figure_art": "avg_4062_totter_1#2$1"}, {"id": 278, "prop": "name", "attributes": {"content": "但我必須還掉以前欠下的人情。", "name": "鉛踝"}, "figure_art": "avg_4062_totter_1#2$1"}, {"id": 279, "prop": "name", "attributes": {"content": "我們的任務是協助這位阿勒黛小姐從諸王長眠之所帶走這把劍。", "name": "鉛踝"}, "figure_art": "avg_4062_totter_1#2$1"}, {"id": 280, "prop": "Character", "attributes": {"name": "avg_npc_396_1#5$1", "name2": "avg_4062_totter_1#9$1", "focus": 2.0}}, {"id": 281, "prop": "name", "attributes": {"content": "嘖，幹完這一單我就能退休了。", "name": "鉛踝"}, "figure_art": "avg_4062_totter_1#9$1"}, {"id": 282, "prop": "name", "attributes": {"content": "......這誘惑真的很大。", "name": "鉛踝"}, "figure_art": "avg_4062_totter_1#9$1"}, {"id": 283, "prop": "Character", "attributes": {"name": "avg_npc_396_1#9$1", "name2": "avg_4062_totter_1#9$1", "focus": 1.0}}, {"id": 284, "prop": "name", "attributes": {"content": "......", "name": "達格達"}, "figure_art": "avg_npc_396_1#9$1"}, {"id": 285, "prop": "Character", "attributes": {"name": "avg_npc_396_1#1$1", "name2": "avg_4062_totter_1#9$1", "focus": 1.0}}, {"id": 286, "prop": "name", "attributes": {"content": "雇傭兵，我們剛剛一起哀悼了死於背叛的英雄。", "name": "達格達"}, "figure_art": "avg_npc_396_1#1$1"}, {"id": 287, "prop": "name", "attributes": {"content": "我還以為，你能理解。", "name": "達格達"}, "figure_art": "avg_npc_396_1#1$1"}, {"id": 288, "prop": "name", "attributes": {"content": "終究你與他們沒什麼不同。", "name": "達格達"}, "figure_art": "avg_npc_396_1#1$1"}, {"id": 289, "prop": "Character", "attributes": {"name": "avg_npc_396_1#7$1", "name2": "avg_4062_totter_1#9$1", "focus": 1.0}}, {"id": 290, "prop": "name", "attributes": {"content": "我對剛才有一瞬間想要信任你......感到恥辱。", "name": "達格達"}, "figure_art": "avg_npc_396_1#7$1"}, {"id": 291, "prop": "Character", "attributes": {"name": "avg_npc_396_1#7$1", "name2": "avg_4062_totter_1#1$1", "focus": 2.0}}, {"id": 292, "prop": "name", "attributes": {"content": "小姑娘，我們剛才聊過，“活著很難”。", "name": "鉛踝"}, "figure_art": "avg_4062_totter_1#1$1"}, {"id": 293, "prop": "name", "attributes": {"content": "對不起，我希望我們都能活下去，我會盡力讓我們都能活下去。", "name": "鉛踝"}, "figure_art": "avg_4062_totter_1#1$1"}, {"id": 294, "prop": "Character", "attributes": {"name": "avg_npc_396_1#7$1", "name2": "avg_4062_totter_1#11$1", "focus": 2.0}}, {"id": 295, "prop": "name", "attributes": {"content": "我們都一樣，都是那個......被同伴推離了死亡的人。", "name": "鉛踝"}, "figure_art": "avg_4062_totter_1#11$1"}, {"id": 296, "prop": "name", "attributes": {"content": "但很遺憾，這次我們的路恰巧並不相同。", "name": "鉛踝"}, "figure_art": "avg_4062_totter_1#11$1"}, {"id": 297, "prop": "Dialog", "attributes": {}}, {"id": 298, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 299, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 300, "prop": "Character", "attributes": {}}, {"id": 301, "prop": "Background", "attributes": {"image": "32_g10_kingrestcore", "screenadapt": "showall"}}, {"id": 302, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 303, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 304, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 305, "prop": "Character", "attributes": {"name": "avg_npc_407_1#5$2", "name2": "avg_npc_397_1#1$1", "focus": 1.0}}, {"id": 306, "prop": "name", "attributes": {"content": "阿勒黛......", "name": "推進之王"}, "figure_art": "avg_npc_407_1#5$2"}, {"id": 307, "prop": "Character", "attributes": {"name": "avg_npc_407_1#5$2", "name2": "avg_npc_397_1#1$1", "focus": 2.0}}, {"id": 308, "prop": "name", "attributes": {"content": "亞歷山德莉娜殿下。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 309, "prop": "name", "attributes": {"content": "為了你的安全，請把諸王之息交給我。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 310, "prop": "Character", "attributes": {"name": "avg_npc_407_1#5$2", "name2": "avg_npc_397_1#1$1", "focus": 1.0}}, {"id": 311, "prop": "name", "attributes": {"content": "......", "name": "推進之王"}, "figure_art": "avg_npc_407_1#5$2"}, {"id": 312, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$2", "name2": "avg_npc_397_1#1$1", "focus": 1.0}}, {"id": 313, "prop": "name", "attributes": {"content": "這是唯一的方法嗎？", "name": "推進之王"}, "figure_art": "avg_npc_407_1#1$2"}, {"id": 314, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$2", "name2": "avg_npc_397_1#5$1", "focus": 2.0}}, {"id": 315, "prop": "name", "attributes": {"content": "我辜負了你的信任，我無話可說。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#5$1"}, {"id": 316, "prop": "name", "attributes": {"content": "你可以告誡我，可以斥責我，可以試圖打倒我，我全部接受。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#5$1"}, {"id": 317, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$2", "name2": "avg_npc_397_1#1$1", "focus": 2.0}}, {"id": 318, "prop": "name", "attributes": {"content": "但我會帶著這把劍離開。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 319, "prop": "name", "attributes": {"content": "這是我在倫蒂尼姆的......“使命”。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 320, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$2", "name2": "avg_npc_397_1#1$1", "focus": 1.0}}, {"id": 321, "prop": "name", "attributes": {"content": "......你說過，諸王之息能從風暴手中守護倫蒂尼姆。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#1$2"}, {"id": 322, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$2", "name2": "avg_npc_397_1#1$1", "focus": 2.0}}, {"id": 323, "prop": "name", "attributes": {"content": "我也並不想把倫蒂尼姆拖入深淵，放心，這把劍不會落入薩卡茲的手中。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 324, "prop": "Character", "attributes": {"name": "avg_npc_407_1#6$2", "name2": "avg_npc_397_1#1$1", "focus": 1.0}}, {"id": 325, "prop": "name", "attributes": {"content": "那麼，就是大公爵們的籌碼了。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 326, "prop": "Character", "attributes": {"name": "avg_npc_407_1#6$2", "name2": "avg_npc_397_1#5$1", "focus": 2.0}}, {"id": 327, "prop": "name", "attributes": {"content": "......", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#5$1"}, {"id": 328, "prop": "Character", "attributes": {"name": "avg_npc_407_1#6$2", "name2": "avg_npc_397_1#5$1", "focus": 1.0}}, {"id": 329, "prop": "name", "attributes": {"content": "阿勒黛，你背後的人想以諸王之息的存在來威懾其他公爵加入自己的陣營。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 330, "prop": "name", "attributes": {"content": "他並不是真正想捍衛維多利亞。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 331, "prop": "name", "attributes": {"content": "而我們，我們的力量很有限，但我們身在其中。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 332, "prop": "name", "attributes": {"content": "與那些被損害的和被侮辱的人在一起。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 333, "prop": "Character", "attributes": {"name": "avg_npc_407_1#6$2", "name2": "avg_npc_397_1#1$1", "focus": 2.0}}, {"id": 334, "prop": "name", "attributes": {"content": "我很清楚。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 335, "prop": "name", "attributes": {"content": "我很清楚她的目的，但這與我無關。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 336, "prop": "name", "attributes": {"content": "我只負責做到，我只關注那些......我能把握的事。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 337, "prop": "Character", "attributes": {"name": "avg_npc_407_1#10$2", "name2": "avg_npc_397_1#1$1", "focus": 1.0}}, {"id": 338, "prop": "name", "attributes": {"content": "那麼自救軍呢？", "name": "推進之王"}, "figure_art": "avg_npc_407_1#10$2"}, {"id": 339, "prop": "name", "attributes": {"content": "你和克洛維希婭一起創建了它，你用自己的榮譽保護它。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#10$2"}, {"id": 340, "prop": "Character", "attributes": {"name": "avg_npc_407_1#10$2", "name2": "avg_npc_397_1#5$1", "focus": 2.0}}, {"id": 341, "prop": "name", "attributes": {"content": "我沒有榮譽。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#5$1"}, {"id": 342, "prop": "Character", "attributes": {"name": "avg_npc_407_1#10$2", "name2": "avg_npc_397_1#5$1", "focus": 1.0}}, {"id": 343, "prop": "name", "attributes": {"content": "那麼，你用生命保護了它。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#10$2"}, {"id": 344, "prop": "name", "attributes": {"content": "如果你就這麼離開，我該怎麼告訴自救軍的戰士們？", "name": "推進之王"}, "figure_art": "avg_npc_407_1#10$2"}, {"id": 345, "prop": "Character", "attributes": {"name": "avg_npc_407_1#10$2", "name2": "avg_npc_397_1#5$1", "focus": 2.0}}, {"id": 346, "prop": "name", "attributes": {"content": "......克洛維希婭會處理好的。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#5$1"}, {"id": 347, "prop": "name", "attributes": {"content": "我沒精力去在乎他們怎麼看我了。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#5$1"}, {"id": 348, "prop": "Character", "attributes": {"name": "avg_npc_407_1#6$2", "name2": "avg_npc_397_1#5$1", "focus": 1.0}}, {"id": 349, "prop": "name", "attributes": {"content": "......", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 350, "prop": "name", "attributes": {"content": "阿勒黛，你聲稱自己只關注那些能把握的東西。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 351, "prop": "name", "attributes": {"content": "你是不是太輕視自己已經擁有的東西了？", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 352, "prop": "Character", "attributes": {"name": "avg_npc_407_1#6$2", "name2": "avg_npc_397_1#3$1", "focus": 2.0}}, {"id": 353, "prop": "name", "attributes": {"content": "當你知道失去它們只是早晚的問題，你還敢於擁有什麼？", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#3$1"}, {"id": 354, "prop": "name", "attributes": {"content": "當所有人信任尊敬的不過是一層偽裝，你還敢於袒露什麼？", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#3$1"}, {"id": 355, "prop": "name", "attributes": {"content": "當你發現走上的道路從一開始就只能通到此處，你還能堅持什麼？", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#3$1"}, {"id": 356, "prop": "Character", "attributes": {"name": "avg_npc_407_1#6$2", "name2": "avg_npc_397_1#7$1", "focus": 2.0}}, {"id": 357, "prop": "name", "attributes": {"content": "這甚至不是我選擇的結果......", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#7$1"}, {"id": 358, "prop": "name", "attributes": {"content": "我只是走到了這裡，維娜。當我發現的時候，命運已經把我推到了這裡。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#7$1"}, {"id": 359, "prop": "Character", "attributes": {"name": "avg_npc_407_1#6$2", "name2": "avg_npc_397_1#5$1", "focus": 2.0}}, {"id": 360, "prop": "name", "attributes": {"content": "從一開始，我們就不可能真的同行。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#5$1"}, {"id": 361, "prop": "name", "attributes": {"content": "......", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#5$1"}, {"id": 362, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$2", "name2": "avg_npc_397_1#5$1", "focus": 1.0}}, {"id": 363, "prop": "name", "attributes": {"content": "我們很小的時候就見過，是嗎？", "name": "推進之王"}, "figure_art": "avg_npc_407_1#1$2"}, {"id": 364, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$2", "name2": "avg_npc_397_1#5$1", "focus": 2.0}}, {"id": 365, "prop": "name", "attributes": {"content": "......", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#5$1"}, {"id": 366, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$2", "name2": "avg_npc_397_1#5$1", "focus": 1.0}}, {"id": 367, "prop": "name", "attributes": {"content": "在坎伯蘭的公爵府。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#1$2"}, {"id": 368, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$2", "name2": "avg_npc_397_1#5$1", "focus": 2.0}}, {"id": 369, "prop": "name", "attributes": {"content": "我原以為你忘記了。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#5$1"}, {"id": 370, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$2", "name2": "avg_npc_397_1#5$1", "focus": 1.0}}, {"id": 371, "prop": "name", "attributes": {"content": "我幾乎忘了......那時，我和高文在一起。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#1$2"}, {"id": 372, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$2", "name2": "avg_npc_397_1#2$1", "focus": 2.0}}, {"id": 373, "prop": "name", "attributes": {"content": "那時，那隻太陽一般的生物告訴我，終有一日，你我會再次相逢。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#2$1"}, {"id": 374, "prop": "name", "attributes": {"content": "但就算是他也一定沒有料到，我們的結局會是這樣。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#2$1"}, {"id": 375, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$2", "name2": "avg_npc_397_1#1$1", "focus": 2.0}}, {"id": 376, "prop": "name", "attributes": {"content": "維娜，你不會把劍交給我的。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 377, "prop": "name", "attributes": {"content": "那麼，揮動它吧。我們只能見證......", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 378, "prop": "Character", "attributes": {"name": "avg_npc_407_1#8$2", "name2": "avg_npc_397_1#1$1", "focus": 1.0}}, {"id": 379, "prop": "name", "attributes": {"content": "阿勒黛。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#8$2"}, {"id": 380, "prop": "name", "attributes": {"content": "還記得我的承諾嗎？", "name": "推進之王"}, "figure_art": "avg_npc_407_1#8$2"}, {"id": 381, "prop": "Character", "attributes": {"name": "avg_npc_407_1#8$2", "name2": "avg_npc_397_1#3$1", "focus": 2.0}}, {"id": 382, "prop": "name", "attributes": {"content": "行了！別說了！", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#3$1"}, {"id": 383, "prop": "Dialog", "attributes": {}}, {"id": 384, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 385, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 386, "prop": "Character", "attributes": {}}, {"id": 387, "prop": "musicvolume", "attributes": {"volume": 0.2, "fadetime": 1.0}}, {"id": 388, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 389, "prop": "Background", "attributes": {"image": "32_g11_victoriaroom_n", "screenadapt": "coverall"}}, {"id": 390, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "amount": 0.8, "keep": "true"}}, {"id": 391, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 392, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 393, "prop": "Character", "attributes": {"name": "avg_npc_407_1#10$1", "name2": "avg_npc_397_1#1$1", "focus": 2.0}}, {"id": 394, "prop": "multiline", "attributes": {"name": "阿勒黛", "content": "我無需背負任何東西，只是你們的智囊..."}}, {"id": 395, "prop": "Character", "attributes": {"name": "avg_npc_407_1#10$1", "name2": "avg_npc_397_1#5$1", "focus": 2.0}}, {"id": 396, "prop": "multiline", "attributes": {"name": "阿勒黛", "content": "...抱歉，忘記你有摩根了。"}}, {"id": 397, "prop": "Character", "attributes": {"name": "avg_npc_407_1#10$1", "name2": "avg_npc_397_1#8$1", "focus": 2.0}}, {"id": 398, "prop": "multiline", "attributes": {"name": "阿勒黛", "end": "true", "content": "那我就做個小混混也好。", "joined": "我無需背負任何東西，只是你們的智囊......抱歉，忘記你有摩根了。那我就做個小混混也好。"}}, {"id": 399, "prop": "Character", "attributes": {"name": "avg_npc_407_1#10$1", "name2": "avg_npc_397_1#10$1", "focus": 2.0}}, {"id": 400, "prop": "name", "attributes": {"content": "我們一起去炸薩卡茲的營地，你來點火，等煙足夠大了以後，我溜進去踹他們指揮官的屁股。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#10$1"}, {"id": 401, "prop": "Character", "attributes": {"name": "avg_npc_407_1#8$1", "name2": "avg_npc_397_1#10$1", "focus": 1.0}}, {"id": 402, "prop": "name", "attributes": {"content": "......", "name": "推進之王"}, "figure_art": "avg_npc_407_1#8$1"}, {"id": 403, "prop": "Character", "attributes": {"name": "avg_npc_407_1#8$1", "name2": "avg_npc_397_1#7$1", "focus": 2.0}}, {"id": 404, "prop": "name", "attributes": {"content": "我開玩笑的。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#7$1"}, {"id": 405, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$1", "name2": "avg_npc_397_1#7$1", "focus": 1.0}}, {"id": 406, "prop": "name", "attributes": {"content": "我知道。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#1$1"}, {"id": 407, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$1", "name2": "avg_npc_397_1#5$1", "focus": 2.0}}, {"id": 408, "prop": "name", "attributes": {"content": "我只能在一條既定的路上走到底了，維娜。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#5$1"}, {"id": 409, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$1", "name2": "avg_npc_397_1#5$1", "focus": 1.0}}, {"id": 410, "prop": "name", "attributes": {"content": "為什麼這麼說？你還和我們在一起，格拉斯哥幫還會有不少新故事。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#1$1"}, {"id": 411, "prop": "Character", "attributes": {"name": "avg_npc_407_1#1$1", "name2": "avg_npc_397_1#4$1", "focus": 2.0}}, {"id": 412, "prop": "name", "attributes": {"content": "這麼說......", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#4$1"}, {"id": 413, "prop": "Character", "attributes": {"name": "avg_npc_407_1#3$1", "name2": "avg_npc_397_1#4$1", "focus": 1.0}}, {"id": 414, "prop": "name", "attributes": {"content": "我答應了。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#3$1"}, {"id": 415, "prop": "Character", "attributes": {"name": "avg_npc_407_1#3$1", "name2": "avg_npc_397_1#4$1", "focus": 1.0}}, {"id": 416, "prop": "name", "attributes": {"content": "我會確保你踹完他們指揮官的屁股之後，還能毫髮無傷地回來。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#3$1"}, {"id": 417, "prop": "Character", "attributes": {"name": "avg_npc_407_1#3$1", "name2": "avg_npc_397_1#4$1", "focus": 1.0}}, {"id": 418, "prop": "name", "attributes": {"content": "這是我的承諾。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#3$1"}, {"id": 419, "prop": "Dialog", "attributes": {}}, {"id": 420, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 421, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 422, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 0.0, "amount": 0.0, "block": "true"}}, {"id": 423, "prop": "Background", "attributes": {"image": "32_g10_kingrestcore", "screenadapt": "coverall"}}, {"id": 424, "prop": "Character", "attributes": {"name": "avg_npc_407_1#8$2", "name2": "avg_npc_397_1#6$1"}}, {"id": 425, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 426, "prop": "musicvolume", "attributes": {"volume": 0.4, "fadetime": 1.0}}, {"id": 427, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 428, "prop": "Character", "attributes": {"name": "avg_npc_407_1#8$2", "name2": "avg_npc_397_1#6$1", "focus": 1.0}}, {"id": 429, "prop": "name", "attributes": {"content": "就算是現在，那也不是玩笑。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#8$2"}, {"id": 430, "prop": "name", "attributes": {"content": "我們都會回去的，毫髮無傷。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#8$2"}, {"id": 431, "prop": "Character", "attributes": {"name": "avg_npc_407_1#8$2", "name2": "avg_npc_397_1#6$1", "focus": 2.0}}, {"id": 432, "prop": "name", "attributes": {"content": "——", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#6$1"}, {"id": 433, "prop": "Dialog", "attributes": {}}, {"id": 434, "prop": "Character", "attributes": {}}, {"id": 435, "prop": "Delay", "attributes": {"time": 0.2}}, {"id": 436, "prop": "stopmusic", "attributes": {"fadetime": 0.5}}, {"id": 437, "prop": "PlaySound", "attributes": {"key": "$d_avg_steamrelease", "volume": 0.3}}, {"id": 438, "prop": "CameraShake", "attributes": {"duration": 1.5, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 439, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 440, "prop": "name", "attributes": {"content": "一個聲音打破了僵持。"}}, {"id": 441, "prop": "name", "attributes": {"content": "是錯覺嗎？"}}, {"id": 442, "prop": "name", "attributes": {"content": "推進之王望向四周。巨大的石像們依舊陷在陰影中一動不動，滿地薩卡茲的屍首也沒有任何死而復生的跡象。"}}, {"id": 443, "prop": "Dialog", "attributes": {}}, {"id": 444, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 445, "prop": "PlaySound", "attributes": {"key": "$d_avg_steamrelease", "volume": 0.3}}, {"id": 446, "prop": "PlaySound", "attributes": {"key": "$d_avg_steamrelease", "volume": 0.5, "loop": "false", "channel": "knight1", "delay": 1.5}}, {"id": 447, "prop": "PlaySound", "attributes": {"key": "$d_avg_steamrelease", "volume": 0.7, "loop": "false", "channel": "knight2", "delay": 2.5}}, {"id": 448, "prop": "CameraShake", "attributes": {"duration": 1.5, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 449, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 450, "prop": "name", "attributes": {"content": "又一次。"}}, {"id": 451, "prop": "name", "attributes": {"content": "就在附近，就在她面前。"}}, {"id": 452, "prop": "name", "attributes": {"content": "噴氣聲的頻率逐漸加快。"}}, {"id": 453, "prop": "name", "attributes": {"content": "越來越響，節奏越來越清晰——直到填滿了整個地下空洞。"}}, {"id": 454, "prop": "Dialog", "attributes": {}}, {"id": 455, "prop": "Character", "attributes": {"name": "avg_npc_396_1#5$1"}}, {"id": 456, "prop": "name", "attributes": {"content": "那是......那是什麼！", "name": "達格達"}, "figure_art": "avg_npc_396_1#5$1"}, {"id": 457, "prop": "Dialog", "attributes": {}}, {"id": 458, "prop": "Character", "attributes": {}}, {"id": 459, "prop": "PlaySound", "attributes": {"key": "$d_gen_heartbeat", "channel": "hb", "volume": 0.8}}, {"id": 460, "prop": "stopsound", "attributes": {"channel": "hb", "fadetime": 1.5}}, {"id": 461, "prop": "name", "attributes": {"content": "阿勒黛突然一陣心悸。"}}, {"id": 462, "prop": "name", "attributes": {"content": "她感受到了。"}}, {"id": 463, "prop": "name", "attributes": {"content": "命運的預兆，如今又一次殘忍迴響。"}}, {"id": 464, "prop": "Dialog", "attributes": {}}, {"id": 465, "prop": "stopmusic", "attributes": {"fadetime": 3.0}}, {"id": 466, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 467, "prop": "Character", "attributes": {}}, {"id": 468, "prop": "Image", "attributes": {}}, {"id": 469, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}