, "block": "true"}}, {"id": 101, "prop": "Character", "attributes": {"fadetime": 0.0}}, {"id": 102, "prop": "Background", "attributes": {"image": "32_g3_school_indoor", "screenadapt": "coverall"}}, {"id": 103, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 104, "prop": "playMusic", "attributes": {"intro": "$darkness01_intro", "key": "$darkness01_loop", "volume": 0.4}}, {"id": 105, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 106, "prop": "Character", "attributes": {"name": "avg_npc_657_1#7$1", "fadetime": 0.5}}, {"id": 107, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 108, "prop": "name", "attributes": {"content": "戈爾丁女士，拉爾夫！你們回來了，太好了！", "name": "茉莉"}, "figure_art": "avg_npc_657_1#7$1"}, {"id": 109, "prop": "Character", "attributes": {"name": "avg_npc_240"}}, {"id": 110, "prop": "name", "attributes": {"content": "對不起，茉莉姐姐。", "name": "頑皮的孩子"}, "figure_art": "avg_npc_240"}, {"id": 111, "prop": "Character", "attributes": {"name": "avg_npc_657_1#2$1"}}, {"id": 112, "prop": "name", "attributes": {"content": "拉爾夫，你差點嚇死我。", "name": "茉莉"}, "figure_art": "avg_npc_657_1#2$1"}, {"id": 113, "prop": "Character", "attributes": {"name": "avg_npc_647_1#6$1"}}, {"id": 114, "prop": "name", "attributes": {"content": "所有孩子是不是都在這裡了？", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#6$1"}, {"id": 115, "prop": "Character", "attributes": {"name": "avg_npc_657_1#5$1"}}, {"id": 116, "prop": "name", "attributes": {"content": "是的，女士，我都數過了。", "name": "茉莉"}, "figure_art": "avg_npc_657_1#5$1"}, {"id": 117, "prop": "Dialog", "attributes": {}}, {"id": 118, "prop": "Character", "attributes": {"name": "avg_npc_647_1#6$1", "name2": "avg_npc_657_1#8$1", "focus": 2.0}}, {"id": 119, "prop": "name", "attributes": {"content": "剛、剛才那是......", "name": "茉莉"}, "figure_art": "avg_npc_657_1#8$1"}, {"id": 120, "prop": "Character", "attributes": {"name": "avg_npc_647_1#6$1", "name2": "avg_npc_657_1#8$1", "focus": 1.0}}, {"id": 121, "prop": "name", "attributes": {"content": "......有炮彈落到了附近。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#6$1"}, {"id": 122, "prop": "Character", "attributes": {"name": "avg_npc_647_1#6$1", "name2": "avg_npc_657_1#8$1", "focus": 2.0}}, {"id": 123, "prop": "name", "attributes": {"content": "怎麼會這樣？到底是誰跟誰在交戰？", "name": "茉莉"}, "figure_art": "avg_npc_657_1#8$1"}, {"id": 124, "prop": "name", "attributes": {"content": "我不明白，上午還好好的，倫蒂尼姆怎麼就突然變成這樣子了？", "name": "茉莉"}, "figure_art": "avg_npc_657_1#8$1"}, {"id": 125, "prop": "Character", "attributes": {"name": "avg_npc_647_1#6$1", "name2": "avg_npc_657_1#2$1", "focus": 2.0}}, {"id": 126, "prop": "name", "attributes": {"content": "嗚......", "name": "茉莉"}, "figure_art": "avg_npc_657_1#2$1"}, {"id": 127, "prop": "Character", "attributes": {"name": "avg_npc_647_1#5$1", "name2": "avg_npc_657_1#2$1", "focus": 1.0}}, {"id": 128, "prop": "name", "attributes": {"content": "別哭，茉莉，別在孩子們面前哭。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#5$1"}, {"id": 129, "prop": "Character", "attributes": {"name": "avg_npc_647_1#5$1", "name2": "avg_npc_657_1#8$1", "focus": 2.0}}, {"id": 130, "prop": "name", "attributes": {"content": "好的，女士。", "name": "茉莉"}, "figure_art": "avg_npc_657_1#8$1"}, {"id": 131, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#8$1", "focus": 1.0}}, {"id": 132, "prop": "name", "attributes": {"content": "握住我的手。至少我們都在一起。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#1$1"}, {"id": 133, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#5$1", "focus": 2.0}}, {"id": 134, "prop": "name", "attributes": {"content": "我們......我們有城防軍，還有蒸汽騎士呢！", "name": "茉莉"}, "figure_art": "avg_npc_657_1#5$1"}, {"id": 135, "prop": "name", "attributes": {"content": "他們會保護倫蒂尼姆，保護維多利亞的！", "name": "茉莉"}, "figure_art": "avg_npc_657_1#5$1"}, {"id": 136, "prop": "Character", "attributes": {"name": "avg_npc_240", "name2": "avg_npc_661_1#1$1", "focus": 1.0}}, {"id": 137, "prop": "name", "attributes": {"content": "蒸汽騎士......", "name": "頑皮的孩子"}, "figure_art": "avg_npc_240"}, {"id": 138, "prop": "name", "attributes": {"content": "我剛剛好像看到了！是不是黑黑的，高高的......", "name": "頑皮的孩子"}, "figure_art": "avg_npc_240"}, {"id": 139, "prop": "Character", "attributes": {"name": "avg_npc_240", "name2": "avg_npc_661_1#1$1", "focus": 2.0}}, {"id": 140, "prop": "name", "attributes": {"content": "那是路燈的影子吧？", "name": "天真的孩子"}, "figure_art": "avg_npc_661_1#1$1"}, {"id": 141, "prop": "Character", "attributes": {"name": "avg_npc_240", "name2": "avg_npc_661_1#1$1", "focus": 1.0}}, {"id": 142, "prop": "name", "attributes": {"content": "胡說！那一定是蒸汽騎士！", "name": "頑皮的孩子"}, "figure_art": "avg_npc_240"}, {"id": 143, "prop": "name", "attributes": {"content": "鞋匠湯姆總是念叨著他們，說他們就是維多利亞偉大的象徵！", "name": "頑皮的孩子"}, "figure_art": "avg_npc_240"}, {"id": 144, "prop": "name", "attributes": {"content": "“踏過山谷，踏過河流，轟隆隆，轟隆隆，是什麼在響？不是打雷，不是颳風，是偉大的騎士，是偉大的維多利亞！”", "name": "頑皮的孩子"}, "figure_art": "avg_npc_240"}, {"id": 145, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#1$1", "focus": 2.0}}, {"id": 146, "prop": "name", "attributes": {"content": "這首歌我小時候也聽過。", "name": "茉莉"}, "figure_art": "avg_npc_657_1#1$1"}, {"id": 147, "prop": "name", "attributes": {"content": "教我唱歌的老師說，每年國王生日的時候，他們都會擠到廣場上，就為了看蒸汽騎士掠過整個方陣。", "name": "茉莉"}, "figure_art": "avg_npc_657_1#1$1"}, {"id": 148, "prop": "Character", "attributes": {"name": "avg_npc_240", "name2": "avg_npc_661_1#1$1", "focus": 1.0}}, {"id": 149, "prop": "name", "attributes": {"content": "蒸汽騎士是不是真的會飛呀？", "name": "頑皮的孩子"}, "figure_art": "avg_npc_240"}, {"id": 150, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#1$1", "focus": 2.0}}, {"id": 151, "prop": "name", "attributes": {"content": "老師說他們只是移動得太快，比落雷和疾風都要快，加上噴出來的蒸汽，看起來就像踩在雲朵上。", "name": "茉莉"}, "figure_art": "avg_npc_657_1#1$1"}, {"id": 152, "prop": "Character", "attributes": {"name": "avg_npc_240", "name2": "avg_npc_661_1#1$1", "focus": 1.0}}, {"id": 153, "prop": "name", "attributes": {"content": "太可惜啦，現在我們都沒有國王陛下了，我還從來沒見過閱兵式呢。", "name": "頑皮的孩子"}, "figure_art": "avg_npc_240"}, {"id": 154, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#1$1", "focus": 2.0}}, {"id": 155, "prop": "name", "attributes": {"content": "老師還說，老師的老師見過更厲害的。", "name": "茉莉"}, "figure_art": "avg_npc_657_1#1$1"}, {"id": 156, "prop": "name", "attributes": {"content": "那一年維多利亞剛剛戰勝了高盧，為了給當時的陛下慶祝誕辰，幾十名蒸汽騎士全部回到了倫蒂尼姆。", "name": "茉莉"}, "figure_art": "avg_npc_657_1#1$1"}, {"id": 157, "prop": "name", "attributes": {"content": "甲胄們身披維多利亞的旗幟，當他們齊步從聖王會西部大堂的台階上走下來的時候，就像有一面巨大的旗幟鋪展開來一樣——", "name": "茉莉"}, "figure_art": "avg_npc_657_1#1$1"}, {"id": 158, "prop": "name", "attributes": {"content": "然後所有人都聽到了比雷聲更響亮的吼叫。", "name": "茉莉"}, "figure_art": "avg_npc_657_1#1$1"}, {"id": 159, "prop": "Character", "attributes": {"name": "avg_npc_240", "name2": "avg_npc_661_1#1$1", "focus": 1.0}}, {"id": 160, "prop": "name", "attributes": {"content": "吼叫？", "name": "頑皮的孩子"}, "figure_art": "avg_npc_240"}, {"id": 161, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#1$1", "focus": 2.0}}, {"id": 162, "prop": "name", "attributes": {"content": "是的，吼叫。在場的人都說，那是我們的旗幟上，維多利亞的象徵活了過來。", "name": "茉莉"}, "figure_art": "avg_npc_657_1#1$1"}, {"id": 163, "prop": "name", "attributes": {"content": "因為自那一天起，維多利亞正式超越高盧，成為泰拉大地上最偉大的國家。", "name": "茉莉"}, "figure_art": "avg_npc_657_1#1$1"}, {"id": 164, "prop": "Character", "attributes": {"name": "avg_npc_647_1#7$1", "name2": "avg_npc_657_1#1$1", "focus": 1.0}}, {"id": 165, "prop": "name", "attributes": {"content": "......", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#7$1"}, {"id": 166, "prop": "Character", "attributes": {"name": "avg_npc_647_1#7$1", "name2": "avg_npc_657_1#4$1", "focus": 2.0}}, {"id": 167, "prop": "name", "attributes": {"content": "抱歉，戈爾丁女士，我忘啦，您的祖父來自高盧......", "name": "茉莉"}, "figure_art": "avg_npc_657_1#4$1"}, {"id": 168, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#4$1", "focus": 1.0}}, {"id": 169, "prop": "name", "attributes": {"content": "不用同我道歉，茉莉。我和你，拉爾夫，還有曾經在這裡長大的千百個孩子一樣......都在倫蒂尼姆長大。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#1$1"}, {"id": 170, "prop": "name", "attributes": {"content": "說不定外面那具蒸汽甲胄裡的人也一樣。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#1$1"}, {"id": 171, "prop": "Character", "attributes": {"name": "avg_npc_240", "name2": "avg_npc_661_1#1$1", "focus": 1.0}}, {"id": 172, "prop": "name", "attributes": {"content": "戈爾丁老師，您認識蒸汽騎士？", "name": "頑皮的孩子"}, "figure_art": "avg_npc_240"}, {"id": 173, "prop": "Character", "attributes": {"name": "avg_npc_647_1#7$1"}}, {"id": 174, "prop": "name", "attributes": {"content": "......查爾斯·林奇。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#7$1"}, {"id": 175, "prop": "name", "attributes": {"content": "他在奧克特里格區生活過。鞋匠湯姆是他的老朋友，所以才總是喜歡念叨陛下與蒸汽騎士的故事。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#7$1"}, {"id": 176, "prop": "name", "attributes": {"content": "實際上，他是陛下生前選中的最後一名蒸汽騎士。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#7$1"}, {"id": 177, "prop": "Character", "attributes": {"name": "avg_npc_647_1#2$1"}}, {"id": 178, "prop": "name", "attributes": {"content": "......也是至今為止最後一名蒸汽騎士。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#2$1"}, {"id": 179, "prop": "Dialog", "attributes": {}}, {"id": 180, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 181, "prop": "Subtitle", "attributes": {"text": "那一夜很漫長。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 182, "prop": "Subtitle", "attributes": {"text": "漫長到孩子們聽完了所有流傳在倫蒂尼姆的蒸汽騎士故事，天才剛剛發亮。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 183, "prop": "Subtitle", "attributes": {"text": "炮聲卻停得比想像中的更快一些。到後半夜的時候，外面的街道就大致恢復了安靜。但是人們很默契地全都躲在屋內，沒人敢急著去確認外面的情況。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 184, "prop": "Subtitle", "attributes": {"text": "幾乎所有倫蒂尼姆人都醒了一整夜。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 185, "prop": "Subtitle", "attributes": {"text": "大家心裡都盤旋著同一個問題——等到了第二天早上，倫蒂尼姆會不會變樣？", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 186, "prop": "subtitle", "attributes": {}}, {"id": 187, "prop": "StopMusic", "attributes": {"fadetime": 2.0}}, {"id": 188, "prop": "Dialog", "attributes": {}}, {"id": 189, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 190, "prop": "Character", "attributes": {"fadetime": 0.0}}, {"id": 191, "prop": "Background", "attributes": {"image": "32_g1_lentiavenue", "screenadapt": "coverall"}}, {"id": 192, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 193, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 194, "prop": "name", "attributes": {"content": "第二天"}}, {"id": 195, "prop": "Dialog", "attributes": {}}, {"id": 196, "prop": "playMusic", "attributes": {"intro": "$distressed_intro", "key": "$distressed_loop", "volume": 0.4}}, {"id": 197, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.7}}, {"id": 198, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#6$1", "fadetime": 1.0}}, {"id": 199, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 200, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#8$1", "focus": 2.0}}, {"id": 201, "prop": "name", "attributes": {"content": "好像什麼都沒變嘛......大公爵的軍隊都到哪裡去了？", "name": "茉莉"}, "figure_art": "avg_npc_657_1#8$1"}, {"id": 202, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#1$1", "focus": 2.0}}, {"id": 203, "prop": "name", "attributes": {"content": "我就知道，如果蒸汽騎士出場，局勢一定會很快控制住！", "name": "茉莉"}, "figure_art": "avg_npc_657_1#1$1"}, {"id": 204, "prop": "name", "attributes": {"content": "就是沒想到會這麼快......", "name": "茉莉"}, "figure_art": "avg_npc_657_1#1$1"}, {"id": 205, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#1$1", "focus": 1.0}}, {"id": 206, "prop": "name", "attributes": {"content": "......茉莉，我們得想辦法去買些必需品回來。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#1$1"}, {"id": 207, "prop": "name", "attributes": {"content": "還不知道接下來會發生什麼......", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#1$1"}, {"id": 208, "prop": "Dialog", "attributes": {}}, {"id": 209, "prop": "Character", "attributes": {}}, {"id": 210, "prop": "PlaySound", "attributes": {"key": "$dooropenquite", "volume": 1.0}}, {"id": 211, "prop": "Character", "attributes": {"name": "avg_npc_416_1#1$1", "fadetime": 0.5}}, {"id": 212, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 213, "prop": "name", "attributes": {"content": "兩位小姐，你們怎麼出來了！", "name": "倫蒂尼姆市民"}, "figure_art": "avg_npc_416_1#1$1"}, {"id": 214, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#1$1", "focus": 2.0}}, {"id": 215, "prop": "name", "attributes": {"content": "亞當斯先生！", "name": "茉莉"}, "figure_art": "avg_npc_657_1#1$1"}, {"id": 216, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#1$1", "focus": 1.0}}, {"id": 217, "prop": "name", "attributes": {"content": "正好，對於那些孩子來說，知識同樣不可或缺。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#1$1"}, {"id": 218, "prop": "name", "attributes": {"content": "......特別是在眼下的情況裡。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#1$1"}, {"id": 219, "prop": "name", "attributes": {"content": "亞當斯先生，請你把昨天那幾本戲劇集給我吧，恐怕我還得再多要一些......", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#1$1"}, {"id": 220, "prop": "PlaySound", "attributes": {"key": "$book_close", "volume": 1.0}}, {"id": 221, "prop": "Character", "attributes": {"name": "avg_npc_647_1#7$1", "name2": "avg_npc_657_1#1$1", "focus": 1.0}}, {"id": 222, "prop": "name", "attributes": {"content": "唔，這些童話，那幾本有關數學與物理的入門書，還有《家庭醫療手冊》，請幫我都包起來......", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#7$1"}, {"id": 223, "prop": "Character", "attributes": {"name": "avg_npc_647_1#7$1", "name2": "avg_npc_657_1#8$1", "focus": 2.0}}, {"id": 224, "prop": "name", "attributes": {"content": "等等，那是什麼聲音？", "name": "茉莉"}, "figure_art": "avg_npc_657_1#8$1"}, {"id": 225, "prop": "Dialog", "attributes": {}}, {"id": 226, "prop": "Character", "attributes": {}}, {"id": 227, "prop": "PlaySound", "attributes": {"key": "$d_avg_soldiersstep", "volume": 1.0}}, {"id": 228, "prop": "name", "attributes": {"content": "不遠處傳來整齊劃一的腳步聲。"}}, {"id": 229, "prop": "name", "attributes": {"content": "不同於倫蒂尼姆人曾在閱兵式上聽到過的那種，這些腳步聲更加沉重，也更加急切。"}}, {"id": 230, "prop": "name", "attributes": {"content": "聖王會西部大堂。碎片大廈。議會廣場。"}}, {"id": 231, "prop": "name", "attributes": {"content": "一陣又一陣，接連不斷，踏過奧克特里格區幾乎空無一人的街道，踏上倫蒂尼姆的中央，維多利亞的心臟。"}}, {"id": 232, "prop": "name", "attributes": {"content": "當腳步聲逼近這條最平凡的街道的時候，一部分躲在路旁的人終於看清了那支正在行進的軍隊——"}}, {"id": 233, "prop": "name", "attributes": {"content": "或者說，看清了士兵們的樣貌。"}}, {"id": 234, "prop": "name", "attributes": {"content": "那些形狀各異的角凝結著不祥的黑色，就連迅速變白的天光都沒有辦法將它們照亮。"}}, {"id": 235, "prop": "CameraShake", "attributes": {"duration": 3.0, "xstrength": 2.0, "ystrength": 3.0, "vibrato": 10.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 236, "prop": "PlaySound", "attributes": {"key": "$d_avg_soldiersstep", "volume": 1.0}}, {"id": 237, "prop": "Dialog", "attributes": {}}, {"id": 238, "prop": "Character", "attributes": {"name": "avg_npc_053", "name2": "avg_npc_053", "fadetime": 1.0}}, {"id": 239, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 240, "prop": "Character", "attributes": {"fadetime": 0.5}}, {"id": 241, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 242, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#8$1", "focus": 1.0}}, {"id": 243, "prop": "name", "attributes": {"content": "......薩卡茲。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#1$1"}, {"id": 244, "prop": "name", "attributes": {"content": "他們是薩卡茲的雇傭兵。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#1$1"}, {"id": 245, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#8$1", "focus": 2.0}}, {"id": 246, "prop": "name", "attributes": {"content": "既然是雇傭兵，他們很快就會離開這裡吧。", "name": "茉莉"}, "figure_art": "avg_npc_657_1#8$1"}, {"id": 247, "prop": "name", "attributes": {"content": "到那時候，倫蒂尼姆會變回老樣子，對嗎？", "name": "茉莉"}, "figure_art": "avg_npc_657_1#8$1"}, {"id": 248, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#8$1", "focus": 1.0}}, {"id": 249, "prop": "name", "attributes": {"content": "......", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#1$1"}, {"id": 250, "prop": "Dialog", "attributes": {}}, {"id": 251, "prop": "Character", "attributes": {"fadetime": 1.0}}, {"id": 252, "prop": "Blocker", "attributes": {"a": 0.8, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 253, "prop": "Subtitle", "attributes": {"text": "那時的人們還不知道，很多事都將在接下來的幾年內徹底改變。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 254, "prop": "Subtitle", "attributes": {"text": "比如說，薩卡茲的軍隊再也沒有離開倫蒂尼姆。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 255, "prop": "Subtitle", "attributes": {"text": "以及——", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 256, "prop": "Subtitle", "attributes": {"text": "自那天起，再也沒有人在倫蒂尼姆的街道上見過蒸汽甲胄的影子。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 257, "prop": "subtitle", "attributes": {}}, {"id": 258, "prop": "Dialog", "attributes": {}}, {"id": 259, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 260, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 261, "prop": "Character", "attributes": {}}, {"id": 262, "prop": "Image", "attributes": {}}, {"id": 263, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}