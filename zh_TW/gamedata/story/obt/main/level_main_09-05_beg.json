去找找他。", "name": "簡妮"}, "figure_art": "avg_479_sleach_1#6$1"}, {"id": 206, "prop": "Dialog", "attributes": {}}, {"id": 207, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 208, "prop": "Character", "attributes": {}}, {"id": 209, "prop": "Background", "attributes": {"image": "bg_manorindoor", "screenadapt": "coverall"}}, {"id": 210, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 211, "prop": "Character", "attributes": {"name": "avg_npc_227_1"}}, {"id": 212, "prop": "name", "attributes": {"content": "  希爾！", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 213, "prop": "Character", "attributes": {"name": "avg_npc_248"}}, {"id": 214, "prop": "name", "attributes": {"content": "  上校，我們剛才在外面的走廊裡抓住了這個人，當時他正在試圖從窗戶裡翻出去。", "name": "副官希爾"}, "figure_art": "avg_npc_248"}, {"id": 215, "prop": "Character", "attributes": {"name": "avg_npc_242"}}, {"id": 216, "prop": "name", "attributes": {"content": "  對不起，對不起......", "name": "恐懼的青年"}, "figure_art": "avg_npc_242"}, {"id": 217, "prop": "Character", "attributes": {"name": "avg_npc_227_1"}}, {"id": 218, "prop": "name", "attributes": {"content": "  讓我猜猜，這傢伙是你們之中哪一位的隨從，又準備向誰通風報信呢？", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 219, "prop": "Character", "attributes": {"name": "avg_npc_177"}}, {"id": 220, "prop": "name", "attributes": {"content": "  我......（擦拭冷汗）", "name": "野心勃勃的男爵"}, "figure_art": "avg_npc_177"}, {"id": 221, "prop": "Character", "attributes": {"name": "avg_npc_176"}}, {"id": 222, "prop": "name", "attributes": {"content": "  我要找律師！我也認識市長和好幾個議員......你們放開，你們沒有權力就這麼困住我們......！", "name": "貪婪的商人"}, "figure_art": "avg_npc_176"}, {"id": 223, "prop": "Character", "attributes": {"name": "avg_npc_227_1"}}, {"id": 224, "prop": "name", "attributes": {"content": "  看來我猜得沒錯，你們每個人都有份。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 225, "prop": "name", "attributes": {"content": "  誰開口都行，我只需要知道你們的同夥到底在哪裡。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 226, "prop": "name", "attributes": {"content": "  這樣吧，我數到三——", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 227, "prop": "Dialog", "attributes": {}}, {"id": 228, "prop": "Character", "attributes": {}}, {"id": 229, "prop": "Character", "attributes": {"name": "avg_npc_242"}}, {"id": 230, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 231, "prop": "CameraShake", "attributes": {"duration": 1.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 232, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.03, "block": "true"}}, {"id": 233, "prop": "PlaySound", "attributes": {"key": "$e_skill_skulsrsword", "volume": 1.0}}, {"id": 234, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 235, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 236, "prop": "name", "attributes": {"content": " 啊啊啊！不、不要殺我！", "name": "恐懼的青年"}, "figure_art": "avg_npc_242"}, {"id": 237, "prop": "PlaySound", "attributes": {"key": "$d_avg_panicwoman2", "volume": 0.7}}, {"id": 238, "prop": "Character", "attributes": {"name": "avg_npc_175"}}, {"id": 239, "prop": "name", "attributes": {"content": " 我的天呐......為什麼要讓我看見如此殘酷的畫面？", "name": "附庸風雅的女貴族"}, "figure_art": "avg_npc_175"}, {"id": 240, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#6"}}, {"id": 241, "prop": "name", "attributes": {"content": "  你不能這樣做！", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#6"}, {"id": 242, "prop": "Character", "attributes": {"name": "avg_npc_227_1"}}, {"id": 243, "prop": "name", "attributes": {"content": "  是嗎？斯卡曼德羅斯，告訴你的下屬，我有沒有資格這麼做？", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 244, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#6", "name2": "avg_npc_229_1#1", "focus": 1.0}}, {"id": 245, "prop": "name", "attributes": {"content": "  隊長......！", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#6"}, {"id": 246, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#6", "name2": "avg_npc_229_1#1", "focus": 2.0}}, {"id": 247, "prop": "name", "attributes": {"content": "  ......臨時管制法。在我們無法得到倫蒂尼姆的直接命令時，漢密爾頓上校作為小丘郡駐軍的最高指揮官，的確擁有啟動全城戒嚴的權力。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 248, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#7", "name2": "avg_npc_229_1#1", "focus": 1.0}}, {"id": 249, "prop": "name", "attributes": {"content": "  我知道！可他真要這麼做的話，就等同於向那支暗處的部隊正式宣戰！", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#7"}, {"id": 250, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#7", "name2": "avg_npc_229_1#2", "focus": 2.0}}, {"id": 251, "prop": "name", "attributes": {"content": "  他們說的恐怕有一點是對的。我們已經身在一場戰爭中了。", "name": "號角"}, "figure_art": "avg_npc_229_1#2"}, {"id": 252, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#7", "name2": "avg_npc_229_1#2", "focus": 1.0}}, {"id": 253, "prop": "name", "attributes": {"content": "  但我們對那支部隊的瞭解比一無所知好不了多少。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#7"}, {"id": 254, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#4", "name2": "avg_npc_229_1#1", "focus": 1.0}}, {"id": 255, "prop": "name", "attributes": {"content": "  敵暗我明，不管怎樣，我都不覺得現在是率先開炮的好時機。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#4"}, {"id": 256, "prop": "Character", "attributes": {"name": "avg_npc_227_1"}}, {"id": 257, "prop": "name", "attributes": {"content": "  時機！他們在對我們發動單方面襲擊的時候，從來不會挑選時機。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 258, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_227_1", "focus": 1.0}}, {"id": 259, "prop": "name", "attributes": {"content": "  上校，即便你不會接受任何我們小隊的建議，我也必須對你現在正要採取的行動表示明確的反對。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 260, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_227_1", "focus": 2.0}}, {"id": 261, "prop": "name", "attributes": {"content": "  多謝你還有那麼點自知之明。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 262, "prop": "name", "attributes": {"content": "  實話說，我也不喜歡這麼做。但凡他們給我留了別的選擇，我都不願意破壞帝國的法律。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 263, "prop": "name", "attributes": {"content": "  可是沒有時間了。暗處的敵人正在步步緊逼。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 264, "prop": "name", "attributes": {"content": "  這不也是你說的嗎，斯卡曼德羅斯？你們也是為了把鬼魂揪到日光下而來！", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 265, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_227_1#2", "focus": 2.0}}, {"id": 266, "prop": "name", "attributes": {"content": "  如果我們不抓緊這機會，把剩下的陰謀都逼出來，等不到明天，我們就會失去小丘郡。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1#2"}, {"id": 267, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_227_1", "focus": 1.0}}, {"id": 268, "prop": "name", "attributes": {"content": "  上校，我相信越是危急關頭，我們選的每一步都越可能會導向不同的結果。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 269, "prop": "name", "attributes": {"content": "  我確定，在場的人裡有很多無辜者，您可以將他們先帶走，然後......", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 270, "prop": "Character", "attributes": {"name": "avg_npc_227_1"}}, {"id": 271, "prop": "name", "attributes": {"content": "  不，我沒法浪費時間在沒意義的審訊上了。現在，就在這裡，這群渣滓必須交代清楚，他們的人手到底藏在哪裡！", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 272, "prop": "name", "attributes": {"content": "  希爾，動手吧！我們耽擱得夠久了——", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 273, "prop": "Character", "attributes": {"name": "avg_npc_239"}}, {"id": 274, "prop": "name", "attributes": {"content": "  ......上校。", "name": "詩人威廉姆斯"}, "figure_art": "avg_npc_239"}, {"id": 275, "prop": "Character", "attributes": {"name": "avg_npc_239", "name2": "avg_npc_227_1#6", "focus": 2.0}}, {"id": 276, "prop": "name", "attributes": {"content": "  你又*維多利亞粗口*是誰？", "name": "漢密爾頓"}, "figure_art": "avg_npc_227_1#6"}, {"id": 277, "prop": "Character", "attributes": {"name": "avg_npc_239", "name2": "avg_npc_227_1#6", "focus": 1.0}}, {"id": 278, "prop": "name", "attributes": {"content": "  請把我抓走吧。我是波頓男爵的客人，我比這位可憐的幾乎失去意識的年輕人要知道得更多。", "name": "詩人威廉姆斯"}, "figure_art": "avg_npc_239"}, {"id": 279, "prop": "Character", "attributes": {"name": "avg_npc_177"}}, {"id": 280, "prop": "name", "attributes": {"content": "  西莫！你又何必站出來？", "name": "野心勃勃的男爵"}, "figure_art": "avg_npc_177"}, {"id": 281, "prop": "Character", "attributes": {"name": "avg_npc_239", "name2": "avg_npc_227_1#6", "focus": 2.0}}, {"id": 282, "prop": "name", "attributes": {"content": "  西莫......西莫·威廉姆斯。你是那個詩人？", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1#6"}, {"id": 283, "prop": "Character", "attributes": {"name": "avg_npc_239", "name2": "avg_npc_227_1#6", "focus": 1.0}}, {"id": 284, "prop": "name", "attributes": {"content": "  是的，上校。", "name": "詩人威廉姆斯"}, "figure_art": "avg_npc_239"}, {"id": 285, "prop": "Character", "attributes": {"name": "avg_npc_239", "name2": "avg_npc_227_1", "focus": 2.0}}, {"id": 286, "prop": "name", "attributes": {"content": "  很好。我本來也想去找你，以免你繼續喋喋不休地煽動那些蠢貨。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 287, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 288, "prop": "name", "attributes": {"content": "  威廉姆斯......", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 289, "prop": "Character", "attributes": {"name": "avg_npc_239"}}, {"id": 290, "prop": "name", "attributes": {"content": "  不必擔心，女士。我該感謝上校，就在剛剛，我想到了我的詩該如何結尾。", "name": "詩人威廉姆斯"}, "figure_art": "avg_npc_239"}, {"id": 291, "prop": "Character", "attributes": {"name": "avg_npc_227_1#2"}}, {"id": 292, "prop": "name", "attributes": {"content": "  抓起來！", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1#2"}, {"id": 293, "prop": "Dialog", "attributes": {}}, {"id": 294, "prop": "Character", "attributes": {}},