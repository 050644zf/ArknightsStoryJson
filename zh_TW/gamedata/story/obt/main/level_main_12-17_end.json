t", "attributes": {"slot": "m", "name": "avg_4071_peper_1#8$1", "focus": "m"}}, {"id": 54, "prop": "name", "attributes": {"content": "我......我不知道......", "name": "明椒"}, "figure_art": "avg_4071_peper_1#8$1"}, {"id": 55, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4071_peper_1#8$1", "focus": "m"}}, {"id": 56, "prop": "name", "attributes": {"content": "我真的不知道！", "name": "明椒"}, "figure_art": "avg_4071_peper_1#8$1"}, {"id": 57, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4087_ines_1#1$1", "focus": "r"}}, {"id": 58, "prop": "name", "attributes": {"content": "......你在這艘船上擔任什麼職位？", "name": "伊內絲"}, "figure_art": "avg_4087_ines_1#1$1"}, {"id": 59, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4071_peper_1#11$1", "focus": "m"}}, {"id": 60, "prop": "name", "attributes": {"content": "呃......薩卡茲雇傭兵？", "name": "明椒"}, "figure_art": "avg_4071_peper_1#11$1"}, {"id": 61, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4087_ines_1#3$1", "focus": "r"}}, {"id": 62, "prop": "name", "attributes": {"content": "哼，一個從來沒殺過人的薩卡茲雇傭兵。", "name": "伊內絲"}, "figure_art": "avg_4087_ines_1#3$1"}, {"id": 63, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4087_ines_1#3$1", "focus": "r"}}, {"id": 64, "prop": "name", "attributes": {"content": "你甚至連怎麼在被人劫持的時候，悄悄拔出自己的武器都不會。", "name": "伊內絲"}, "figure_art": "avg_4087_ines_1#3$1"}, {"id": 65, "prop": "dialog", "attributes": {}}, {"id": 66, "prop": "delay", "attributes": {"time": 0.6}}, {"id": 67, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovement", "volume": 0.7}}, {"id": 68, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4087_ines_1#1$1", "posfrom": "-30,0", "posto": "0,0", "afrom": 1.0, "ato": 1.0, "duration": 0.6}}, {"id": 69, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4071_peper_1#10$1", "posfrom": "10,0", "posto": "-180,0", "afrom": 1.0, "ato": 1.0, "duration": 2.0}}, {"id": 70, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 71, "