": "伊內絲"}, "figure_art": "avg_4087_ines_1#10$1"}, {"id": 19, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4087_ines_1#10$1", "focus": "m"}}, {"id": 20, "prop": "name", "attributes": {"content": "可這裡......是不是有點太高了？", "name": "伊內絲"}, "figure_art": "avg_4087_ines_1#10$1"}, {"id": 21, "prop": "Dialog", "attributes": {}}, {"id": 22, "prop": "charslot", "attributes": {"duration": 0.0}}, {"id": 23, "prop": "Delay", "attributes": {"time": 0.8}}, {"id": 24, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovementsp", "volume": 1.0}}, {"id": 25, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 5.0, "ystrength": 5.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 26, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4087_ines_1#1$1", "posfrom": "0,0", "posto": "-30,0", "afrom": 1.0, "ato": 1.0, "duration": 0.6}}, {"id": 27, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4071_peper_1#10$1", "posfrom": "30,0", "posto": "10,0", "afrom": 1.0, "ato": 1.0, "duration": 0.6}}, {"id": 28, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 29, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4071_peper_1#10$1", "focus": "m"}}, {"id": 30, "prop": "name", "attributes": {"content": "......你能放開我了嗎？", "name": "明椒"}, "figure_art": "avg_4071_peper_1#10$1"}, {"id": 31, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4087_ines_1#1$1", "focus": "r"}}, {"id": 32, "prop": "name", "attributes": {"content": "不行，小姑娘。", "name": "伊內絲"}, "figure_art": "avg_4087_ines_1#1$1"}, {"id": 33, "prop": "name", "attributes": {"content": "別想著給自己找麻煩。", "name": "伊內絲"}, "figure_art": "avg_4087_ines_1#1$1"}, {"id": 34, "prop": "name", "attributes": {"content": "這艘船太大了，如果一個可愛的女孩願意幫我把把風，盯著那些不知道會從哪個走廊裡冒出來的士兵，我會很開心的。", "name": "伊內絲"}, "figure_art": "avg_4087_ines_1#1$1"}, {"id": 35, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4071_peper_1#10$1", "focus": "m"}}, {"id": 36, "pro