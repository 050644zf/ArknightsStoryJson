 15.0, "vibrato": 50.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 247, "prop": "CameraShake", "attributes": {"xstrength": 2.0, "ystrength": 1.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 248, "prop": "name", "attributes": {"content": "公式的畫面也開始消退了！", "name": "阿米婭"}}, {"id": 249, "prop": "dialog", "attributes": {}}, {"id": 250, "prop": "Decision", "attributes": {"options": "撤退，趁通路還未崩潰。", "values": "1"}, "targetLine": {"option1": "line251"}}, {"id": 251, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 252, "prop": "charslot", "attributes": {}}, {"id": 253, "prop": "name", "attributes": {"content": "但我還沒有——", "name": "阿米婭"}}, {"id": 254, "prop": "dialog", "attributes": {}}, {"id": 255, "prop": "Decision", "attributes": {"options": "還有我呢！;我們可以一起還原出來。", "values": "1;2"}, "targetLine": {"option1": "line256", "option2": "line256"}}, {"id": 256, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 257, "prop": "charslot", "attributes": {}}, {"id": 258, "prop": "Dialog", "attributes": {}}, {"id": 259, "prop": "curtain", "attributes": {"direction": 2.0, "fillfrom": 0.35, "fillto": 1.0, "fadetime": 1.0}}, {"id": 260, "prop": "curtain", "attributes": {"direction": 6.0, "fillfrom": 0.35, "fillto": 1.0, "fadetime": 1.0}}, {"id": 261, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 262, "prop": "CameraShake", "attributes": {"duration": 3.0, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 50.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 263, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 264, "prop": "charslot", "attributes": {}}, {"id": 265, "prop": "curtain", "attributes": {}}, {"id": 266, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 267, "prop": "bgeffect", "attributes": {}}, {"id": 268, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 0.0, "amount": 0.0, "block": "true"}}, {"id": 269, "prop": "Background", "attributes": {"image": "bg_white", "screenadapt": "coverall"}}, {"id": 270, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 271, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 272, "prop": "name", "attributes": {"content": "隨即你的思維受到了巨大的衝擊，你感受到了墜落感。"}}, {"id": 273, "prop": "name", "attributes": {"content": "你最後的意識停留在你支撐著阿米婭盡可能遠離了奇點，以及那個你熟悉的身影——"}}, {"id": 274, "prop": "Dialog", "attributes": {}}, {"id": 275, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4134_cetsyr_1#1$1", "duration": 1.0}}, {"id": 276, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 277, "prop": "name", "attributes": {"content": "感謝你幫著阿米婭走到了這裡，接下來……", "name": "魔王"}, "figure_art": "avg_4134_cetsyr_1#1$1"}, {"id": 278, "prop": "name", "attributes": {"content": "離開。", "name": "魔王"}, "figure_art": "avg_4134_cetsyr_1#1$1"}, {"id": 279, "prop": "charslot", "attributes": {}}, {"id": 280, "prop": "name", "attributes": {"content": "你與阿米婭共享的思維連接在這一刻斷裂，你的思維已經疲憊到不足以再記住後面發生的任何事情。"}}, {"id": 281, "prop": "name", "attributes": {"content": "你們離開了“文明的存續”。"}}, {"id": 282, "prop": "Dialog", "attributes": {}}, {"id": 283, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 284, "prop": "charslot", "attributes": {}}, {"id": 285, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 286, "prop": "Background", "attributes": {"image": "60_g1_rhodescorridor_bc", "screenadapt": "coverall"}}, {"id": 287, "prop": "name", "attributes": {"content": "奇點所噴發出的資訊並未停止，其中最微不足道的一個畫面自被記錄以來便再未被存取過——"}}, {"id": 288, "prop": "name", "attributes": {"content": "寂靜的深空中，一束光照亮一片星域的同時帶來了黑暗，也帶來了毋庸置疑的絕望。"}}, {"id": 289, "prop": "name", "attributes": {"content": "當數千萬光年外的探測儀接收到那片星域遙遠過去的影像時，畫面中被恆星照亮的星球已滿是墳場與廢墟。"}}, {"id": 290, "prop": "name", "attributes": {"content": "祂已降臨。"}}, {"id": 291, "prop": "dialog", "attributes": {}}, {"id": 292, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 293, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 294, "prop": "playMusic", "attributes": {"intro": "$newhope01_intro", "key": "$newhope01_loop", "volume": 0.6}}, {"id": 295, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 296, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1725_1#1$1"}}, {"id": 297, "prop": "name", "attributes": {"content": "♫~♫~", "name": "屈光者"}, "figure_art": "avg_npc_1725_1#1$1"}, {"id": 298, "prop": "name", "attributes": {"content": "是幽靈讓你用這樣的言辭來為她辯護嗎？", "name": "屈光者"}, "figure_art": "avg_npc_1725_1#1$1"}, {"id": 299, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1719_1#1$1"}}, {"id": 300, "prop": "name", "attributes": {"content": "不，屈光者，幽靈離開時並未要求我這樣做。", "name": "希爾達"}, "figure_art": "avg_npc_1719_1#1$1"}, {"id": 301, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1725_1#1$1"}}, {"id": 302, "prop": "name", "attributes": {"content": "那就警惕她，不要被她所迷惑。", "name": "屈光者"}, "figure_art": "avg_npc_1725_1#1$1"}, {"id": 303, "prop": "name", "attributes": {"content": "……因為她的魅力而放鬆警惕可能會為你帶來危險，那是他們族群為捕食而發展出的天性。", "name": "屈光者"}, "figure_art": "avg_npc_1725_1#1$1"}, {"id": 304, "prop": "name", "attributes": {"content": "至於你想要找的人，這艘船的主人普瑞賽斯……", "name": "屈光者"}, "figure_art": "avg_npc_1725_1#1$1"}, {"id": 305, "prop": "name", "attributes": {"content": "由於一項正在進行的關鍵研究，她的意識恐怕正穿梭於這片星域的不同研究場所。", "name": "屈光者"}, "figure_art": "avg_npc_1725_1#1$1"}, {"id": 306, "prop": "name", "attributes": {"content": "若非她自願，你很難佔據她的時間。", "name": "屈光者"}, "figure_art": "avg_npc_1725_1#1$1"}, {"id": 307, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1719_1#1$1"}}, {"id": 308, "prop": "name", "attributes": {"content": "……", "name": "希爾達"}, "figure_art": "avg_npc_1719_1#1$1"}, {"id": 309, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1725_1#1$1"}}, {"id": 310, "prop": "name", "attributes": {"content": "希爾達，你如此迫切地想要找到她，只是為了感謝那位救了你的人嗎？", "name": "屈光者"}, "figure_art": "avg_npc_1725_1#1$1"}, {"id": 311, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1719_1#1$1"}}, {"id": 312, "prop": "name", "attributes": {"content": "現在並不完全是這樣了。", "name": "希爾達"}, "figure_art": "avg_npc_1719_1#1$1"}, {"id": 313, "prop": "name", "attributes": {"content": "我理解了我正身處一個名為“宇宙”的奇妙地方，我理解了這裡並非死亡之後才會來到的地方……", "name": "希爾達"}, "figure_art": "avg_npc_1719_1#1$1"}, {"id": 314, "prop": "name", "attributes": {"content": "我甚至有一個大膽的猜測，我的家鄉泰拉，或許也存在於宇宙之中。", "name": "希爾達"}, "figure_art": "avg_npc_1719_1#1$1"}, {"id": 315, "prop": "name", "attributes": {"content": "但更多的知識只會帶來更多的疑惑，我想要請教她——", "name": "希爾達"}, "figure_art": "avg_npc_1719_1#1$1"}, {"id": 316, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1719_1#10$1"}}, {"id": 317, "prop": "name", "attributes": {"content": "為何我並未死去？", "name": "希爾達"}, "figure_art": "avg_npc_1719_1#10$1"}, {"id": 318, "prop": "name", "attributes": {"content": "泰拉，我的家鄉，它又在何方？", "name": "希爾達"}, "figure_art": "avg_npc_1719_1#10$1"}, {"id": 319, "prop": "charslot", "attributes": {}}, {"id": 320, "prop": "name", "attributes": {"content": "卡特斯透過舷窗失落地眺望遠方深空中的群星。"}}, {"id": 321, "prop": "name", "attributes": {"content": "或許依舊牽掛著她的主教和修士仍在只屬於她的大地上為她禱告，但她已無法回應。"}}, {"id": 322, "prop": "name", "attributes": {"content": "她蜷縮在走廊的牆邊，任憑恆星的光芒快速掃過她的臉龐。"}}, {"id": 323, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1719_1#10$1"}}, {"id": 324, "prop": "name", "attributes": {"content": "原來逝去的時間，也能肉眼可見。", "name": "希爾達"}, "figure_art": "avg_npc_1719_1#10$1"}, {"id": 325, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 326, "prop": "name", "attributes": {"content": "在這艘艦船上她偶遇過許多人，不論是沉浸在實驗室中受人尊敬的帽兜天才，還是從毀滅中倖存卻依舊遊歷宇宙的探險家……"}}, {"id": 327, "prop": "name", "attributes": {"content": "他們的樂觀和善意都讓希爾達放下了最初的恐懼，但她同樣清楚，自己永遠也無法真正融入這艘神奇的艦船。"}}, {"id": 328, "prop": "name", "attributes": {"content": "“我想念泰拉了。”"}}, {"id": 329, "prop": "Dialog", "attributes": {}}, {"id": 330, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 331, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 332, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 333, "prop": "Image", "attributes": {}}, {"id": 334, "prop": "charslot", "attributes": {}}, {"id": 335, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}