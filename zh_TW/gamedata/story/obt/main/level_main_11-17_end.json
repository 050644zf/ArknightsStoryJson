, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 400, "prop": "PlaySound", "attributes": {"key": "$d_avg_clapsolo", "volume": 0.7}}, {"id": 401, "prop": "PlaySound", "attributes": {"key": "$d_avg_clapsolo", "volume": 0.8, "delay": 0.5, "channel": "slide1"}}, {"id": 402, "prop": "Dialog", "attributes": {}}, {"id": 403, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 404, "prop": "Character", "attributes": {"fadetime": 0.0}}, {"id": 405, "prop": "Background", "attributes": {"image": "32_g3_school_indoor", "screenadapt": "coverall"}}, {"id": 406, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 407, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 408, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#1$1", "focus": 1.0}}, {"id": 409, "prop": "name", "attributes": {"content": "......結束了。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#1$1"}, {"id": 410, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#1$1", "focus": 2.0}}, {"id": 411, "prop": "name", "attributes": {"content": "太棒了，戈爾丁女士，演出非常成功。", "name": "茉莉"}, "figure_art": "avg_npc_657_1#1$1"}, {"id": 412, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#1$1", "focus": 1.0}}, {"id": 413, "prop": "name", "attributes": {"content": "這是大家辛苦一年多的成果。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#1$1"}, {"id": 414, "prop": "name", "attributes": {"content": "要是城內的局勢不那麼緊張，海蒂也能看到就好了......", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#1$1"}, {"id": 415, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#1$1", "focus": 2.0}}, {"id": 416, "prop": "name", "attributes": {"content": "就是因為這麼緊張，這齣戲才格外有意義嘛。", "name": "茉莉"}, "figure_art": "avg_npc_657_1#1$1"}, {"id": 417, "prop": "name", "attributes": {"content": "您看，孩子們多高興——", "name": "茉莉"}, "figure_art": "avg_npc_657_1#1$1"}, {"id": 418, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#1$1"}}, {"id": 419, "prop": "Dialog", "attributes": {}}, {"id": 420, "prop": "playsound", "attributes": {"key": "$rungeneral", "volume": 0.5}}, {"id": 421, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 422, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#5$1", "focus": 2.0}}, {"id": 423, "prop": "name", "attributes": {"content": "等等，里奧，別穿著道具到處跑！", "name": "茉莉"}, "figure_art": "avg_npc_657_1#5$1"}, {"id": 424, "prop": "Character", "attributes": {"name": "avg_npc_240", "name2": "avg_npc_661_1#1$1", "focus": 1.0}}, {"id": 425, "prop": "name", "attributes": {"content": "別跑！", "name": "頑皮的孩子"}, "figure_art": "avg_npc_240"}, {"id": 426, "prop": "Character", "attributes": {"name": "avg_npc_240", "name2": "avg_npc_661_1#1$1", "focus": 2.0}}, {"id": 427, "prop": "name", "attributes": {"content": "別跑！", "name": "天真的孩子"}, "figure_art": "avg_npc_661_1#1$1"}, {"id": 428, "prop": "Character", "attributes": {"name": "avg_npc_240", "name2": "avg_npc_661_1#1$1", "focus": 1.0}}, {"id": 429, "prop": "name", "attributes": {"content": "哼，逃吧，逃吧，我會追著你，偉大的維多利亞會追著你！", "name": "頑皮的孩子"}, "figure_art": "avg_npc_240"}, {"id": 430, "prop": "name", "attributes": {"content": "踏過山谷，踏過河流，轟隆隆，轟隆隆......", "name": "頑皮的孩子"}, "figure_art": "avg_npc_240"}, {"id": 431, "prop": "name", "attributes": {"content": "碾碎它們！把血液從它們身體裡擠出來！", "name": "頑皮的孩子"}, "figure_art": "avg_npc_240"}, {"id": 432, "prop": "name", "attributes": {"content": "該死，你們全都該死！我會追上你，殺死你！", "name": "頑皮的孩子"}, "figure_art": "avg_npc_240"}, {"id": 433, "prop": "Character", "attributes": {"name": "avg_npc_240", "name2": "avg_npc_661_1#1$1", "focus": 2.0}}, {"id": 434, "prop": "name", "attributes": {"content": "擠出來！", "name": "天真的孩子"}, "figure_art": "avg_npc_661_1#1$1"}, {"id": 435, "prop": "Character", "attributes": {"name": "avg_npc_240", "name2": "avg_npc_661_1#1$1", "focus": 1.0}}, {"id": 436, "prop": "name", "attributes": {"content": "投降吧，薩卡茲！", "name": "頑皮的孩子"}, "figure_art": "avg_npc_240"}, {"id": 437, "prop": "Character", "attributes": {"name": "avg_npc_240", "name2": "avg_npc_661_1#1$1", "focus": 2.0}}, {"id": 438, "prop": "name", "attributes": {"content": "投降吧！", "name": "天真的孩子"}, "figure_art": "avg_npc_661_1#1$1"}, {"id": 439, "prop": "Character", "attributes": {"name": "avg_npc_240", "name2": "avg_npc_661_1#1$1", "focus": 1.0}}, {"id": 440, "prop": "name", "attributes": {"content": "不投降也沒關係，因為我會追上你！", "name": "頑皮的孩子"}, "figure_art": "avg_npc_240"}, {"id": 441, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#4$1", "focus": 2.0}}, {"id": 442, "prop": "name", "attributes": {"content": "快停下，戈爾丁女士親手做的“蒸汽甲胄”都快被你弄壞了......", "name": "茉莉"}, "figure_art": "avg_npc_657_1#4$1"}, {"id": 443, "prop": "Character", "attributes": {"name": "avg_npc_647_1#10$1", "name2": "avg_npc_657_1#4$1", "focus": 1.0}}, {"id": 444, "prop": "name", "attributes": {"content": "......", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#10$1"}, {"id": 445, "prop": "name", "attributes": {"content": "他們......", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#10$1"}, {"id": 446, "prop": "Character", "attributes": {"name": "avg_npc_647_1#10$1", "name2": "avg_npc_657_1#1$1", "focus": 2.0}}, {"id": 447, "prop": "name", "attributes": {"content": "戈爾丁女士，別生氣。他們只是在做遊戲。", "name": "茉莉"}, "figure_art": "avg_npc_657_1#1$1"}, {"id": 448, "prop": "Character", "attributes": {"name": "avg_npc_647_1#7$1", "name2": "avg_npc_657_1#1$1", "focus": 1.0}}, {"id": 449, "prop": "name", "attributes": {"content": "遊戲......嗎？", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#7$1"}, {"id": 450, "prop": "Character", "attributes": {"name": "avg_npc_647_1#7$1", "name2": "avg_npc_657_1#1$1", "focus": 2.0}}, {"id": 451, "prop": "name", "attributes": {"content": "是啊，女士，我們的舞台劇已經演完了。", "name": "茉莉"}, "figure_art": "avg_npc_657_1#1$1"}, {"id": 452, "prop": "Character", "attributes": {"name": "avg_npc_647_1#5$1", "name2": "avg_npc_657_1#1$1", "focus": 1.0}}, {"id": 453, "prop": "name", "attributes": {"content": "......“把血液從它們身體裡擠出來”？", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#5$1"}, {"id": 454, "prop": "name", "attributes": {"content": "這是......薩卡茲......", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#5$1"}, {"id": 455, "prop": "Character", "attributes": {}}, {"id": 456, "prop": "name", "attributes": {"content": "填滿了書店的血紅色再度浮上眼前。"}}, {"id": 457, "prop": "name", "attributes": {"content": "這一次，她甚至沒有力氣乾嘔。"}}, {"id": 458, "prop": "Character", "attributes": {"name": "avg_npc_647_1#5$1", "name2": "avg_npc_657_1#6$1", "focus": 2.0}}, {"id": 459, "prop": "name", "attributes": {"content": "這很正常，女士。", "name": "茉莉"}, "figure_art": "avg_npc_657_1#6$1"}, {"id": 460, "prop": "name", "attributes": {"content": "畢竟......我們正處在一場戰爭中。", "name": "茉莉"}, "figure_art": "avg_npc_657_1#6$1"}, {"id": 461, "prop": "name", "attributes": {"content": "城裡的薩卡茲最近總在到處抓人，手段還很殘暴。孩子們可能看見了，就下意識地模仿了薩卡茲的行為。", "name": "茉莉"}, "figure_art": "avg_npc_657_1#6$1"}, {"id": 462, "prop": "Character", "attributes": {"name": "avg_npc_647_1#2$1", "name2": "avg_npc_657_1#6$1", "focus": 1.0}}, {"id": 463, "prop": "name", "attributes": {"content": "......", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#2$1"}, {"id": 464, "prop": "Character", "attributes": {"name": "avg_npc_647_1#1$1", "name2": "avg_npc_657_1#6$1", "focus": 1.0}}, {"id": 465, "prop": "name", "attributes": {"content": "茉莉，你知道嗎？", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#1$1"}, {"id": 466, "prop": "Character", "attributes": {"name": "avg_npc_647_1#5$1", "name2": "avg_npc_657_1#6$1", "focus": 1.0}}, {"id": 467, "prop": "name", "attributes": {"content": "許多高盧遺民......都對蒸汽騎士心懷恐懼。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#5$1"}, {"id": 468, "prop": "name", "attributes": {"content": "經歷過那場戰爭的人，永遠都不會忘掉那一夜突然出現在窗外的噴氣聲。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#5$1"}, {"id": 469, "prop": "name", "attributes": {"content": "但是......我期盼著蒸汽騎士對孩子們而言，可以不僅是一件用以奪走他人性命的武器。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#5$1"}, {"id": 470, "prop": "Character", "attributes": {"name": "avg_npc_647_1#7$1", "name2": "avg_npc_657_1#6$1", "focus": 1.0}}, {"id": 471, "prop": "name", "attributes": {"content": "我期盼著他們扮演蒸汽騎士這個角色的時候，能在他身上寄託一些美好的希望。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#7$1"}, {"id": 472, "prop": "name", "attributes": {"content": "我曾以為這種對抗能贏。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#7$1"}, {"id": 473, "prop": "Character", "attributes": {}}, {"id": 474, "prop": "name", "attributes": {"content": "戈爾丁望著孩子們追逐打鬧的身影。"}}, {"id": 475, "prop": "name", "attributes": {"content": "泡沫製作而成的蒸汽騎士的甲胄掉落到了地上。她想要把它撿起來，伸出去的手卻彷彿被燙了一下。"}}, {"id": 476, "prop": "Character", "attributes": {"name": "avg_npc_647_1#7$1"}}, {"id": 477, "prop": "name", "attributes": {"content": "我總以為自己在教導孩子們......", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#7$1"}, {"id": 478, "prop": "name", "attributes": {"content": "直到這一刻，我才發覺是孩子們教會了我。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#7$1"}, {"id": 479, "prop": "Character", "attributes": {"name": "avg_npc_647_1#2$1"}}, {"id": 480, "prop": "name", "attributes": {"content": "這就是......孩子們的演出的結尾。一個真正的結尾。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#2$1"}, {"id": 481, "prop": "Character", "attributes": {"name": "avg_npc_647_1#7$1"}}, {"id": 482, "prop": "name", "attributes": {"content": "在如此巨大的時代面前，我們能做的......", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#7$1"}, {"id": 483, "prop": "name", "attributes": {"content": "我們所做的，或許毫無意義。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#7$1"}, {"id": 484, "prop": "name", "attributes": {"content": "書本中的教育遙遠且模糊，而時代——", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#7$1"}, {"id": 485, "prop": "name", "attributes": {"content": "沒有人能擺脫它的形塑。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#7$1"}, {"id": 486, "prop": "name", "attributes": {"content": "若時代屬於鮮血、暴力與戰爭。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#7$1"}, {"id": 487, "prop": "name", "attributes": {"content": "他們......我們的孩子們，誰也無法倖免。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#7$1"}, {"id": 488, "prop": "name", "attributes": {"content": "他們便屬於鮮血、暴力與戰爭。", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#7$1"}, {"id": 489, "prop": "Character", "attributes": {"name": "avg_npc_647_1#5$1"}}, {"id": 490, "prop": "name", "attributes": {"content": "我......我該怎麼......", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#5$1"}, {"id": 491, "prop": "name", "attributes": {"content": "我怎麼可能妄圖對抗它？", "name": "戈爾丁"}, "figure_art": "avg_npc_647_1#5$1"}, {"id": 492, "prop": "Dialog", "attributes": {}}, {"id": 493, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 494, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 495, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 496, "prop": "Character", "attributes": {}}, {"id": 497, "prop": "Image", "attributes": {}}, {"id": 498, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}