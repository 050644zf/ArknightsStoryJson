47, "prop": "PlaySound", "attributes": {"key": "$d_avg_iron_claw", "volume": 0.5}}, {"id": 148, "prop": "Blocker", "attributes": {"a": 0.7, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 0.2, "block": "true"}}, {"id": 149, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 150, "prop": "PlaySound", "attributes": {"key": "$swordtsing4", "volume": 0.5, "loop": "false", "channel": "sword1", "delay": 0.2}}, {"id": 151, "prop": "PlaySound", "attributes": {"key": "$swordtsing3", "volume": 0.5, "loop": "false", "channel": "sword2", "delay": 0.5}}, {"id": 152, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 153, "prop": "character", "attributes": {"name": "avg_npc_396_1#5$1"}}, {"id": 154, "prop": "name", "attributes": {"content": "他、他的動作變快了！", "name": "達格達"}, "figure_art": "avg_npc_396_1#5$1"}, {"id": 155, "prop": "character", "attributes": {"name": "avg_npc_396_1#2$1"}}, {"id": 156, "prop": "name", "attributes": {"content": "我們抵擋不住......", "name": "達格達"}, "figure_art": "avg_npc_396_1#2$1"}, {"id": 157, "prop": "Dialog", "attributes": {}}, {"id": 158, "prop": "Character", "attributes": {}}, {"id": 159, "prop": "PlaySound", "attributes": {"key": "$e_imp_stmwpn_n", "volume": 1.0}}, {"id": 160, "prop": "character", "attributes": {"name": "avg_npc_397_1#6$1"}}, {"id": 161, "prop": "Effect", "attributes": {"name": "$e_slash_hit_02", "y": 100.0, "layer": 1.0}}, {"id": 162, "prop": "Delay", "attributes": {"time": 0.1}}, {"id": 163, "prop": "PlaySound", "attributes": {"key": "$d_avg_magic_3", "delay": 0.1}}, {"id": 164, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 8.0, "ystrength": 6.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 165, "prop": "Effect", "attributes": {"name": "$e_magic_shield_01", "layer": 2.0}}, {"id": 166, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 167, "prop": "Character", "attributes": {"fadetime": 0.5}}, {"id": 168, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 169, "prop": "character", "attributes": {"name": "avg_npc_407_1#3$2"}}, {"id": 170, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 171, "prop": "name", "attributes": {"content": "阿勒黛！", "name": "推進之王"}, "figure_art": "avg_npc_407_1#3$2"}, {"id": 172, "prop": "dialog", "attributes": {}}, {"id": 173, "prop": "character", "attributes": {"fadetime": 0.3}}, {"id": 174, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 175, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 176, "prop": "character", "attributes": {"name": "avg_npc_397_1#7$1", "fadetime": 0.3}}, {"id": 177, "prop": "name", "attributes": {"content": " ......亞歷山德莉娜殿下。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#7$1"}, {"id": 178, "prop": "playMusic", "attributes": {"intro": "$dignified_intro", "key": "$dignified_loop", "volume": 0.4}}, {"id": 179, "prop": "name", "attributes": {"content": "你還記得那天，我們第一次相見的那天。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#7$1"}, {"id": 180, "prop": "name", "attributes": {"content": "我們本該多聊聊的，你帶著那把劍，出現在了公爵府中。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#7$1"}, {"id": 181, "prop": "Dialog", "attributes": {}}, {"id": 182, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 183, "prop": "character", "attributes": {}}, {"id": 184, "prop": "Image", "attributes": {}}, {"id": 185, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 186, "prop": "Background", "attributes": {"image": "bg_light", "screenadapt": "coverall"}}, {"id": 187, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 188, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 189, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 190, "prop": "name", "attributes": {"content": "那是一個......非常美麗的午後。", "name": "阿勒黛"}}, {"id": 191, "prop": "name", "attributes": {"content": "音樂縈繞在庭院，鮮花毫無顧忌地綻放，人們一邊跳舞一邊談論明天，一切都飽含著希望......", "name": "阿勒黛"}}, {"id": 192, "prop": "name", "attributes": {"content": "那時，我還能毫無顧忌地誇口，自己一定能成為蒸汽騎士。", "name": "阿勒黛"}}, {"id": 193, "prop": "name", "attributes": {"content": "而光輝......灑在劍身上......也灑在你的身上。", "name": "阿勒黛"}}, {"id": 194, "prop": "name", "attributes": {"content": "他們都說......那個下午是一個奇跡。", "name": "阿勒黛"}}, {"id": 195, "prop": "name", "attributes": {"content": "她在奔跑。"}}, {"id": 196, "prop": "name", "attributes": {"content": "剛剛修剪過的草坪踩上去又刺又癢。園丁吉姆樂呵呵地站在灌木叢邊上傻笑。艾爾希在背後追著她，提醒她慢一些慢一些。"}}, {"id": 197, "prop": "name", "attributes": {"content": "可她急著奔向那些新開的花。那可是金色的，在陽光下閃閃發光，就和坎伯蘭的家徽一樣。"}}, {"id": 198, "prop": "name", "attributes": {"content": "爸爸將她一把抱了起來，讓她坐在他的肩膀上。他托起她小小的手掌，讓她觸摸蒸汽甲胄上的紋樣。"}}, {"id": 199, "prop": "name", "attributes": {"content": "殘破的甲胄突然站了起來。"}}, {"id": 200, "prop": "name", "attributes": {"content": "爸爸消失了，她長高了，也不再站在盔甲面前。她感到盔甲的重量沉甸甸地壓在自己肩上。"}}, {"id": 201, "prop": "name", "attributes": {"content": "透過頭盔，她看到道路的盡頭走出來了一隻金燦燦的獅子。"}}, {"id": 202, "prop": "Dialog", "attributes": {}}, {"id": 203, "prop": "Dialog", "attributes": {}}, {"id": 204, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 205, "prop": "Character", "attributes": {"fadetime": 0.0}}, {"id": 206, "prop": "image", "attributes": {"image": "32_i01_2", "screenadapt": "coverall"}}, {"id": 207, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 208, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 209, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 210, "prop": "Blocker", "attributes": {"a": 0.5, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 211, "prop": "Subtitle", "attributes": {"text": "“阿勒黛·坎伯蘭。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 212, "prop": "Subtitle", "attributes": {"text": "終有一日，你會與維娜再次相逢。”", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 213, "prop": "subtitle", "attributes": {}}, {"id": 214, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 215, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 216, "prop": "Dialog", "attributes": {}}, {"id": 217, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 218, "prop": "Character", "attributes": {"fadetime": 0.0}}, {"id": 219, "prop": "image", "attributes": {}}, {"id": 220, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 221, "prop": "Background", "attributes": {"image": "32_g9_kingrest", "screenadapt": "coverall"}}, {"id": 222, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 223, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 224, "prop": "character", "attributes": {"name": "avg_npc_397_1#5$1", "fadetime": 0.5}}, {"id": 225, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 226, "prop": "name", "attributes": {"content": "這麼多年過去，我很難再相信奇跡了。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#5$1"}, {"id": 227, "prop": "name", "attributes": {"content": "艾爾希曾告訴我，就連我也不知道將來的自己在哪裡。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#5$1"}, {"id": 228, "prop": "name", "attributes": {"content": "很對不起她，恐怕沒有什麼將來了。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#5$1"}, {"id": 229, "prop": "character", "attributes": {"name": "avg_npc_397_1#2$1"}}, {"id": 230, "prop": "name", "attributes": {"content": "那是我幾歲的時候？記不清了，我向艾爾希保證，我會成為蒸汽騎士，保護所有人。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#2$1"}, {"id": 231, "prop": "character", "attributes": {"name": "avg_npc_397_1#1$1"}}, {"id": 232, "prop": "name", "attributes": {"content": "至少現在，我還有面對一位蒸汽騎士的機會。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 233, "prop": "name", "attributes": {"content": "聽你的，維娜，沒有什麼使命。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 234, "prop": "name", "attributes": {"content": "沒有坎伯蘭的，也沒有大公爵的。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 235, "prop": "character", "attributes": {"name": "avg_npc_397_1#8$1"}}, {"id": 236, "prop": "name", "attributes": {"content": "去*維多利亞粗口*的使命，我已經足夠累了。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#8$1"}, {"id": 237, "prop": "name", "attributes": {"content": "無論是扮演一個貴族，扮演一個領袖，還是扮演一個朋友。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#8$1"}, {"id": 238, "prop": "character", "attributes": {"name": "avg_npc_407_1#6$2"}}, {"id": 239, "prop": "name", "attributes": {"content": "自救軍的戰士信任你，你便是他們的領袖。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 240, "prop": "name", "attributes": {"content": "我稱你為朋友，你便是我的朋友。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 241, "prop": "character", "attributes": {"name": "avg_npc_397_1#8$1"}}, {"id": 242, "prop": "name", "attributes": {"content": "哈，維娜，已經足夠了。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#8$1"}, {"id": 243, "prop": "character", "attributes": {"name": "avg_npc_397_1#1$1"}}, {"id": 244, "prop": "name", "attributes": {"content": "讓我們把那個寓言結束吧，總得畫下句號。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 245, "prop": "name", "attributes": {"content": "達格達，告訴摩根，讓她在她的回憶錄裡把我寫得好一點。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#1$1"}, {"id": 246, "prop": "character", "attributes": {"name": "avg_npc_397_1#10$1"}}, {"id": 247, "prop": "name", "attributes": {"content": "起碼，用些典雅的詞語吧。", "name": "阿勒黛"}, "figure_art": "avg_npc_397_1#10$1"}, {"id": 248, "prop": "Dialog", "attributes": {}}, {"id": 249, "prop": "character", "attributes": {"name": "avg_npc_397_1#6$1"}}, {"id": 250, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 251, "pr