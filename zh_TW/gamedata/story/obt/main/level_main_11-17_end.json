9, "g": 0.25, "b": 0.2, "fadetime": 0.2, "block": "true"}}, {"id": 87, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.9, "g": 0.25, "b": 0.2, "fadetime": 0.5, "block": "true"}}, {"id": 88, "prop": "Character", "attributes": {"fadetime": 0.5}}, {"id": 89, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 90, "prop": "character", "attributes": {"name": "avg_npc_407_1#6$2"}}, {"id": 91, "prop": "name", "attributes": {"content": "你......你還聽得到嗎，騎士？", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 92, "prop": "name", "attributes": {"content": "我無權命令你。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 93, "prop": "name", "attributes": {"content": "我懇請你，懇請你讓我們帶走這把劍。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 94, "prop": "name", "attributes": {"content": "這與我的身份無關。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 95, "prop": "name", "attributes": {"content": "倫蒂尼姆需要它。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 96, "prop": "character", "attributes": {"name": "avg_npc_407_1#7$2"}}, {"id": 97, "prop": "name", "attributes": {"content": "不，不是倫蒂尼姆。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#7$2"}, {"id": 98, "prop": "character", "attributes": {"name": "avg_npc_407_1#6$2"}}, {"id": 99, "prop": "name", "attributes": {"content": "蜷縮在孤兒院的孩子需要它，被戰爭盤剝的農戶需要它。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 100, "prop": "name", "attributes": {"content": "用自己的血汗充作車床潤滑劑的工人需要它，在酒館裡買醉來逃避絕望的市民需要它。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 101, "prop": "name", "attributes": {"content": "為了自己的家園挺身而出的自救軍戰士需要它，想要消弭一場毀滅性災難的羅德島需要它。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 102, "prop": "name", "attributes": {"content": "它能驅散的不是風暴，是恐懼。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 103, "prop": "name", "attributes": {"content": "它必須被如此使用。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#6$2"}, {"id": 104, "prop": "character", "attributes": {"name": "avg_npc_407_1#3$2"}}, {"id": 105, "prop": "name", "attributes": {"content": "騎士，它不是你的維多利亞。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#3$2"}, {"id": 106, "prop": "name", "attributes": {"content": "請讓我通過這裡。", "name": "推進之王"}, "figure_art": "avg_npc_407_1#3$2"}, {"id": 107, "prop": "Dialog", "attributes": {}}, {"id": 108, "prop": "Character", "attributes": {}}, {"id": 109, "prop": "Delay", "attributes": {"time": 0.3}}, {"id": 110, "prop": "character", "attributes": {"name": "avg_npc_651_1#1$1", "fadetime": 0.5}}, {"id": 111, "prop": "PlaySound", "attributes": {"key": "$d_avg_mechawalk", "channel": "a", "loop": "true"}}, {"id": 112, "prop": "Delay", "attributes": {"time": 0.8}}, {"id": 113, "prop": "stopsound", "attributes": {"channel": "a", "fadetime": 0.5}}, {"id": 114, "prop": "name", "attributes": {"content": "不是維多利亞？"}}, {"id": 115, "prop": "name", "attributes": {"content": "那麼，維多利亞在哪裡？"}}, {"id": 116, "prop": "name", "attributes": {"content": "蒸汽騎士的胸腔裡充滿了困惑與憤怒。"}}, {"id": 117, "prop": "Dialog", "attributes": {}}, {"id": 118, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 8.0, "ystrength": 6.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 119, "prop": "PlaySound", "attributes": {"key": "$d_avg_mechawalk", "channel": "a", "loop": "true"}}, {"id": 120, "prop": "Delay", "attributes": {"time": 0.8}}, {"id": 121, "prop": "stopsound", "attributes": {"channel": "a", "fadetime": 0.5}}, {"id": 122, "prop": "Delay", "attributes": {"time": 0.01}}, {"id": 123, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 8.0, "ystrength": 6.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 124, "prop": "PlaySound", "attributes": {"key": "$d_avg_mechawalk", "channel": "b", "loop": "true"}}, {"id": 125, "prop": "Delay", "attributes": {"time": 0.8}}, {"id": 126, "prop": "stopsound", "attributes": {"channel": "b", "fadetime": 0.5}}, {"id": 127, "prop": "name", "attributes"