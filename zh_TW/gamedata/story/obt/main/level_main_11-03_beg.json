d": 19, "prop": "PlaySound", "attributes": {"key": "$d_avg_axehitscrape", "channel": "cakie", "loop": "false", "delay": 0.2, "volume": 0.5}}, {"id": 20, "prop": "Dialog", "attributes": {}}, {"id": 21, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 2.0, "amount": 0.0, "block": "false"}}, {"id": 22, "prop": "SoundVolume", "attributes": {"volume": 0.1, "fadetime": 2.0, "channel": "a"}}, {"id": 23, "prop": "PlaySound", "attributes": {"key": "$d_avg_overheat", "delay": 0.5, "volume": 0.4}}, {"id": 24, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 25, "prop": "Character", "attributes": {"name": "avg_npc_660_1#1$1", "fadetime": 0.5}}, {"id": 26, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 27, "prop": "multiline", "attributes": {"name": "倫蒂尼姆工人", "content": "快，最後一批聚合劑到了嗎？"}}, {"id": 28, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 29, "prop": "multiline", "attributes": {"name": "倫蒂尼姆工人", "content": "什麼——還沒有？！"}}, {"id": 30, "prop": "name", "attributes": {"content": "這下糟了......", "name": "倫蒂尼姆工人"}, "figure_art": "avg_npc_660_1#1$1"}, {"id": 31, "prop": "Character", "attributes": {"name": "avg_npc_648_1#1$1"}}, {"id": 32, "prop": "name", "attributes": {"content": "負責這批材料運輸的人是誰？", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 33, "prop": "Character", "attributes": {"name": "avg_npc_660_1#1$1"}}, {"id": 34, "prop": "name", "attributes": {"content": "頭兒，是......是......", "name": "倫蒂尼姆工人"}, "figure_art": "avg_npc_660_1#1$1"}, {"id": 35, "prop": "Character", "attributes": {"name": "avg_npc_648_1#6$1"}}, {"id": 36, "prop": "name", "attributes": {"content": "怎麼支支吾吾的？", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#6$1"}, {"id": 37, "prop": "Character", "attributes": {"name": "avg_npc_660_1#1$1"}}, {"id": 38, "prop": "name", "attributes": {"content": "......是費斯特。", "name": "倫蒂尼姆工人"}, "figure_art": "avg_npc_660_1#1$1"}, {"id": 39, "prop": "Character", "attributes": {"name": "avg_npc_648_1#9$1"}}, {"id": 40, "prop": "name", "attributes": {"content": "那小子......", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#9$1"}, {"id": 41, "prop": "Character", "attributes": {"name": "avg_npc_660_1#1$1"}}, {"id": 42, "prop": "name", "attributes": {"content": "他一早就出去了，按理說早該回來了。", "name": "倫蒂尼姆工人"}, "figure_art": "avg_npc_660_1#1$1"}, {"id": 43, "prop": "Character", "attributes": {"name": "avg_npc_648_1#1$1"}}, {"id": 44, "prop": "name", "attributes": {"content": "還有誰跟他一起走了？", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 45, "prop": "Character", "attributes": {"name": "avg_npc_660_1#1$1"}}, {"id": 46, "prop": "name", "attributes": {"content": "湯米，帕特和戴。", "name": "倫蒂尼姆工人"}, "figure_art": "avg_npc_660_1#1$1"}, {"id": 47, "prop": "Character", "attributes": {"name": "avg_npc_648_1#6$1"}}, {"id": 48, "prop": "name", "attributes": {"content": "他們不是一個工作室的，怎麼會輪到同一班？", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#6$1"}, {"id": 49, "prop": "Character", "attributes": {"name": "avg_npc_660_1#1$1"}}, {"id": 50, "prop": "name", "attributes": {"content": "他們幾個關係最好，平時就老混在一起，費斯特是他們的小頭頭。", "name": "倫蒂尼姆工人"}, "figure_art": "avg_npc_660_1#1$1"}, {"id": 51, "prop": "Character", "attributes": {"name": "avg_npc_648_1#9$1"}}, {"id": 52, "prop": "name", "attributes": {"content": "......", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#9$1"}, {"id": 53, "prop": "Dialog", "attributes": {}}, {"id": 54, "prop": "Character", "attributes": {}}, {"id": 55, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.7}}, {"id": 56, "prop": "Character", "attributes": {"name": "avg_npc_053", "fadetime": 1.0}}, {"id": 57, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 58, "prop": "name", "attributes": {"content": "聽起來你們遇上麻煩了。", "name": "薩卡茲雇傭兵"}, "figure_art": "avg_npc_053"}, {"id": 59, "prop": "Character", "attributes": {"name": "avg_npc_648_1#1$1"}}, {"id": 60, "prop": "name", "attributes": {"content": "一點小事而已。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 61, "prop": "Character", "attributes": {"name": "avg_npc_053"}}, {"id": 62, "prop": "name", "attributes": {"content": "小事。", "name": "薩卡茲雇傭兵"}, "figure_art": "avg_npc_053"}, {"id": 63, "prop": "name", "attributes": {"content": "凱瑟琳，你知道今天是什麼日子，對吧？", "name": "薩卡茲雇傭兵"}, "figure_art": "avg_npc_053"}, {"id": 64, "prop": "Character", "attributes": {"name": "avg_npc_648_1#1$1"}}, {"id": 65, "prop": "name", "attributes": {"content": "我怎麼會忘？", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 66, "prop": "name", "attributes": {"content": "我從十天前開始，就在練習自己的簽名，生怕到時候簽字簽難看了，惹了長官不高興。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 67, "prop": "Character", "attributes": {"name": "avg_npc_053"}}, {"id": 68, "prop": "name", "attributes": {"content": "那你可有的練了，將軍很重視後天的交接儀式，據說，城防軍的頭頭也會來。", "name": "薩卡茲雇傭兵"}, "figure_art": "avg_npc_053"}, {"id": 69, "prop": "Character", "attributes": {"name": "avg_npc_648_1#9$1"}}, {"id": 70, "prop": "name", "attributes": {"content": "......", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#9$1"}, {"id": 71, "prop": "Character", "attributes": {"name": "avg_npc_648_1#1$1"}}, {"id": 72, "prop": "name", "attributes": {"content": "抽煙嗎？", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 73, "prop": "Character", "attributes": {"name": "avg_npc_053"}}, {"id": 74, "prop": "name", "attributes": {"content": "......呵，來一根。", "name": "薩卡茲雇傭兵"}, "figure_art": "avg_npc_053"}, {"id": 75, "prop": "Dialog", "attributes": {}}, {"id": 76, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 77, "prop": "name", "attributes": {"content": "到目前為止，你們廠的工人都還在，你清楚這是為什麼吧？", "name": "薩卡茲雇傭兵"}}, {"id": 78, "prop": "Character", "attributes": {"name": "avg_npc_648_1#1$1"}}, {"id": 79, "prop": "name", "attributes": {"content": "我們工作很努力。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 80, "prop": "Character", "attributes": {"name": "avg_npc_053"}}, {"id": 81, "prop": "name", "attributes": {"content": "努力，當然。", "name": "薩卡茲雇傭兵"}, "figure_art": "avg_npc_053"}, {"id": 82, "prop": "name", "attributes": {"content": "你們把工作做得很好。這一點上我們是一樣的，工作，拿錢，活命。", "name": "薩卡茲雇傭兵"}, "figure_art": "avg_npc_053"}, {"id": 83, "prop": "name", "attributes": {"content": "但是雇主們都很清楚，工作越出色的傭兵，就越不值得信任。", "name": "薩卡茲雇傭兵"}, "figure_art": "avg_npc_053"}, {"id": 84, "prop": "Character", "attributes": {"name": "avg_npc_648_1#1$1"}}, {"id": 85, "prop": "name", "attributes": {"content": "正常。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 86, "prop": "name", "attributes": {"content": "在被你們抓走之前，分管這片廠區的漢弗萊爵士也從來沒信任過我們。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 87, "prop": "Character", "attributes": {"name": "avg_npc_053"}}, {"id": 88, "prop": "name", "attributes": {"content": "別給我找麻煩，凱瑟琳。", "name": "薩卡茲雇傭兵"}, "figure_art": "avg_npc_053"}, {"id": 89, "prop": "Character", "attributes": {}}, {"id": 90, "prop": "name", "attributes": {"content": "雇傭兵的語氣很平靜，就跟往常很多次走過來問凱瑟琳要煙差不多。"}}, {"id": 91, "prop": "name", "attributes": {"content": "這就是他的工作，殺幾個不聽話的倫蒂尼姆工人對他來說，就跟她每天擰幾顆螺絲沒什麼分別。"}}, {"id": 92, "prop": "name", "attributes": {"content": "凱瑟琳往兜裡彈了彈煙。可不能讓灰掉進機器裡。"}}, {"id": 93, "prop": "Character", "attributes": {"name": "avg_npc_648_1#1$1"}}, {"id": 94, "prop": "name", "attributes": {"content": "我跟你說過很多次了。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 95, "prop": "name", "attributes": {"content": "想要維持效率的話，我們廠的人一個都不能少。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 96, "prop": "Character", "attributes": {"name": "avg_npc_053"}}, {"id": 97, "prop": "name", "attributes": {"content": "我挺佩服你的，凱瑟琳，一般的雇傭兵都不一定有你這個膽子。", "name": "薩卡茲雇傭兵"}, "figure_art": "avg_npc_053"}, {"id": 98, "prop": "name", "attributes": {"content": "你確實有這個資本。只是，凡事不要做過火。", "name": "薩卡茲雇傭兵"}, "figure_art": "avg_npc_053"}, {"id": 99, "prop": "name", "attributes": {"content": "像你們這樣的軍工廠，倫蒂尼姆還有上百號。就算你們整個廠都空了，攝政王也不會在意。", "name": "薩卡茲雇傭兵"}, "figure_art": "avg_npc_053"}, {"id": 100, "prop": "Character", "attributes": {"name": "avg_npc_648_1#1$1"}}, {"id": 101, "prop": "name", "attributes": {"content": "沒有事情會變化，後天的交接儀式，我們會交上約定好的東西，所有的工人也會在場。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 102, "prop": "name", "attributes": {"content": "你們不需要擔心任何事情。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 103, "prop": "Character", "attributes": {"name": "avg_npc_053"}}, {"id": 104, "prop": "name", "attributes": {"content": "我就當是這麼回事吧。", "name": "薩卡茲雇傭兵"}, "figure_art": "avg_npc_053"}, {"id": 105, "prop": "Character", "attributes": {"name": "avg_npc_648_1#1$1"}}, {"id": 106, "prop": "name", "attributes": {"content": "當然。沒帶火嗎？煙還夾在手裡......", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 107, "prop": "Character", "attributes": {"name": "avg_npc_053"}}, {"id": 108, "prop": "name", "attributes": {"content": "這煙你還是自己收著。倫蒂尼姆的煙總是夾著一股機油味，我再怎麼抽都抽不慣。", "name": "薩卡茲雇傭兵"}, "figure_art": "avg_npc_053"}, {"id": 109, "prop": "Dialog", "attributes": {}}, {"id": 110, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.7}}, {"id": 111, "prop": "Character", "attributes": {"fadetime": 0.5}}, {"id": 112, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 113, "prop": "Character", "attributes": {"name": "avg_npc_660_1#1$1"}}, {"id": 114, "prop": "name", "attributes": {"content": "凱瑟琳，我們該怎麼辦？", "name": "倫蒂尼姆工人"}, "figure_art": "avg_npc_660_1#1$1"}, {"id": 115, "prop": "dialog", "attributes": {}}, {"id": 116, "prop": "Character", "attributes": {"name": "avg_npc_648_1#7$1"}}, {"id": 117, "prop": "PlaySound", "attributes": {"key": "$d_avg_smokeblow", "volume": 0.7}}, {"id": 118, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 119, "prop": "name", "attributes": {"content": "（掐滅煙頭）", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#7$1"}, {"id": 120, "prop": "Character", "attributes": {"name": "avg_npc_648_1#8$1"}}, {"id": 121, "prop": "name", "attributes": {"content": "......去卸貨區。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#8$1"}, {"id": 122, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.7}}, {"id": 123, "prop": "StopSound", "attributes": {"fadetime": 2.0, "channel": "a"}}, {"id": 124, "prop": "Dialog", "attributes": {}}, {"id": 125, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 126, "prop": "Character", "attributes": {"fadetime": 0.0}}, {"id": 127, "prop": "Background", "attributes": {"image": "32_g5_ordnancefactory_ex", "screenadapt": "coverall"}}, {"id": 128, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 129, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 130, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1"}}, {"id": 131, "prop": "name", "attributes": {"content": "帕特！都幹完了嗎？", "name": "費斯特"}, "figure_art": "avg_npc_402_1#6$1"}, {"id": 132, "prop": "Character", "attributes": {"name": "avg_npc_659_1#1$1"}}, {"id": 133, "prop": "name", "attributes": {"content": "......就差這顆螺絲！", "name": "倫蒂尼姆工人"}, "figure_art": "avg_npc_659_1#1$1"}, {"id": 134, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1"}}, {"id": 135, "prop": "name", "attributes": {"content": "搞定它。這樣一來，他們想要接收更多聚合劑的話，至少得再等一個禮拜。", "name": "費斯特"}, "figure_art": "avg_npc_402_1#6$1"}, {"id": 136, "prop": "Character", "attributes": {"name": "avg_npc_659_1#1$1"}}, {"id": 137, "prop": "name", "attributes": {"content": "這麼多聚合劑，一批又一批送進來。薩卡茲到底要建什麼？", "name": "倫蒂尼姆工人"}, "figure_art": "avg_npc_659_1#1$1"}, {"id": 138, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1"}}, {"id": 139, "prop": "name", "attributes": {"content": "我還沒瞧見。奶奶不肯讓我靠近組裝線。只有她最信任的老工人們才能爬上那片高架。", "name": "費斯特"}, "figure_art": "avg_npc_402_1#6$1"}, {"id": 140, "prop": "name", "attributes": {"content": "越是這樣，就越說明這東西對薩卡茲來說很重要。", "name": "費斯特"}, "figure_art": "avg_npc_402_1#6$1"}, {"id": 141, "prop": "Character", "attributes": {"name": "avg_npc_659_1#1$1"}}, {"id": 142, "prop": "name", "attributes": {"content": "應該還是武器吧？我們工作室前幾天一直在幫薩卡茲打造自動弩。", "name": "倫蒂尼姆工人"}, "figure_art": "avg_npc_659_1#1$1"}, {"id": 143, "prop": "Character", "attributes": {"name": "avg_npc_402_1#4$1"}}, {"id": 144, "prop": "name", "attributes": {"content": "只可能是武器。外頭可還有那麼多公爵的軍隊盯著呢......", "name": "費斯特"}, "figure_art": "avg_npc_402_1#4$1"}, {"id": 145, "prop": "Character", "attributes": {"name": "avg_npc_659_1#1$1"}}, {"id": 146, "prop": "name", "attributes": {"content": "真讓薩卡茲得逞可就糟了......", "name": "倫蒂尼姆工人"}, "figure_art": "avg_npc_659_1#1$1"}, {"id": 147, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1"}}, {"id": 148, "prop": "name", "attributes": {"content": "我們得阻止他們，帕特。我們不能幫薩卡茲對付自己人。", "name": "費斯特"}, "figure_art": "avg_npc_402_1#6$1"}, {"id": 149, "prop": "Character", "attributes": {"name": "avg_npc_659_1#1$1"}}, {"id": 150, "prop": "name", "attributes": {"content": "毀掉這批聚合劑能管用嗎？我們會不會受罰？", "name": "倫蒂尼姆工人"}, "figure_art": "avg_npc_659_1#1$1"}, {"id": 151, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1"}}, {"id": 152, "prop": "name", "attributes": {"content": "大不了我站出來。我不怕被抓走。", "name": "費斯特"}, "figure_art": "avg_npc_402_1#6$1"}, {"id": 153, "prop": "Dialog", "attributes": {}}, {"id": 154, "prop": "Character", "attributes": {}}, {"id": 155, "prop": "StopMusic", "attributes": {"fadetime": 1.0}}, {"id": 156, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.7}}, {"id": 157, "prop": "Character", "attributes": {"name": "avg_npc_648_1#1$1", "fadetime": 1.0}}, {"id": 158, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 159, "prop": "name", "attributes": {"content": "你不能這麼做。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 160, "prop": "Character", "attributes": {"name": "avg_npc_402_1#11$1"}}, {"id": 161, "prop": "name", "attributes": {"content": "......奶奶？", "name": "費斯特"}, "figure_art": "avg_npc_402_1#11$1"}, {"id": 162, "prop": "playMusic", "attributes": {"intro": "$batmeeting_intro", "key": "$batmeeting_loop", "volume": 0.4}}, {"id": 163, "prop": "Character", "attributes": {"name": "avg_npc_648_1#1$1"}}, {"id": 164, "prop": "name", "attributes": {"content": "抓住他們。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 165, "prop": "Character", "attributes": {"name": "avg_npc_402_1#10$1"}}, {"id": 166, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 167, "prop": "name", "attributes": {"content": "帕特——快動手！", "name": "費斯特"}, "figure_art": "avg_npc_402_1#10$1"}, {"id": 168, "prop": "Character", "attributes": {"name": "avg_npc_659_1#1$1"}}, {"id": 169, "prop": "name", "attributes": {"content": "呃——？", "name": "倫蒂尼姆工人"}, "figure_art": "avg_npc_659_1#1$1"}, {"id": 170, "prop": "Character", "attributes": {"name": "avg_npc_648_1#8$1"}}, {"id": 171, "prop": "name", "attributes": {"content": "——", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#8$1"}, {"id": 172, "prop": "Dialog", "attributes": {}}, {"id": 173, "prop": "Character", "attributes": {}}, {"id": 174, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 10.0, "ystrength": 5.0, "vibrato": 10.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 175, "prop": "PlaySound", "attributes": {"key": "$d_avg_iron_claw", "volume": 0.7}}, {"id": 176, "prop": "name", "attributes": {"content": "她隨手抓起一把小銼刀丟了出去。"}}, {"id": 177, "prop": "PlaySound", "attributes": {"key": "$swordtsing1", "volume": 0.7}}, {"id": 178, "prop": "PlaySound", "attributes": {"key": "$swordtsing2", "volume": 0.3, "delay": 0.2}}, {"id": 179, "prop": "name", "attributes": {"content": "叮噹一聲，工人手裡的扳手落了地。"}}, {"id": 180, "prop": "Character", "attributes": {"name": "avg_npc_402_1#2$1"}}, {"id": 181, "prop": "name", "attributes": {"content": "唔......", "name": "費斯特"}, "figure_art": "avg_npc_402_1#2$1"}, {"id": 182, "prop": "Character", "attributes": {"name": "avg_npc_402_1#2$1", "name2": "avg_npc_648_1#8$1", "focus": 2.0}}, {"id": 183, "prop": "name", "attributes": {"content": "你知不知道自己在幹什麼？", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#8$1"}, {"id": 184, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1", "name2": "avg_npc_648_1#8$1", "focus": 1.0}}, {"id": 185, "prop": "name", "attributes": {"content": "我在阻止薩卡茲！", "name": "費斯特"}, "figure_art": "avg_npc_402_1#6$1"}, {"id": 186, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1", "name2": "avg_npc_648_1#8$1", "focus": 2.0}}, {"id": 187, "prop": "name", "attributes": {"content": "你在胡鬧。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#8$1"}, {"id": 188, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1", "name2": "avg_npc_648_1#8$1", "focus": 1.0}}, {"id": 189, "prop": "name", "attributes": {"content": "我都計劃好了，不會連累你們，我會告訴薩卡茲是我幹的，然後——", "name": "費斯特"}, "figure_art": "avg_npc_402_1#6$1"}, {"id": 190, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1", "name2": "avg_npc_648_1#3$1", "focus": 2.0}}, {"id": 191, "prop": "name", "attributes": {"content": "——然後死在薩卡茲手上。你把自己當成英雄了，是不是？", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#3$1"}, {"id": 192, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1", "name2": "avg_npc_648_1#3$1", "focus": 1.0}}, {"id": 193, "prop": "name", "attributes": {"content": "我會試著逃走。我計劃了很久——", "name": "費斯特"}, "figure_art": "avg_npc_402_1#6$1"}, {"id": 194, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1", "name2": "avg_npc_648_1#8$1", "focus": 2.0}}, {"id": 195, "prop": "name", "attributes": {"content": "用你改造過的爬行者。你想藏在貨運線路裡，逃出海布里區。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#8$1"}, {"id": 196, "prop": "Character", "attributes": {"name": "avg_npc_402_1#11$1", "name2": "avg_npc_648_1#8$1", "focus": 1.0}}, {"id": 197, "prop": "name", "attributes": {"content": "你都知道......", "name": "費斯特"}, "figure_art": "avg_npc_402_1#11$1"}, {"id": 198, "prop": "Character", "attributes": {"name": "avg_npc_402_1#11$1", "name2": "avg_npc_648_1#8$1", "focus": 2.0}}, {"id": 199, "prop": "name", "attributes": {"content": "我在這片廠區生活了五十多年，你想幹的蠢事還瞞不過我的眼睛。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#8$1"}, {"id": 200, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1", "name2": "avg_npc_648_1#8$1", "focus": 1.0}}, {"id": 201, "prop": "name", "attributes": {"content": "奶奶，聽我說。", "name": "費斯特"}, "figure_art": "avg_npc_402_1#6$1"}, {"id": 202, "prop": "name", "attributes": {"content": "我收到了一些消息，有一個反抗組織正在薩迪恩區活躍。他們從薩卡茲手底下救出來了不少人，甚至成功奪回了幾個地塊！", "name": "費斯特"}, "figure_art": "avg_npc_402_1#6$1"}, {"id": 203, "prop": "name", "attributes": {"content": "他們管自己叫倫蒂尼姆市民自救軍——我要去找他們！", "name": "費斯特"}, "figure_art": "avg_npc_402_1#6$1"}, {"id": 204, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1", "name2": "avg_npc_648_1#8$1", "focus": 2.0}}, {"id": 205, "prop": "name", "attributes": {"content": "......找他們。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#8$1"}, {"id": 206, "prop": "name", "attributes": {"content": "找到之後呢？", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#8$1"}, {"id": 207, "prop": "Character", "attributes": {"name": "avg_npc_402_1#2$1", "name2": "avg_npc_648_1#8$1", "focus": 1.0}}, {"id": 208, "prop": "name", "attributes": {"content": "呃......什麼？", "name": "費斯特"}, "figure_art": "avg_npc_402_1#2$1"}, {"id": 209, "prop": "Character", "attributes": {"name": "avg_npc_402_1#2$1", "name2": "avg_npc_648_1#8$1", "focus": 2.0}}, {"id": 210, "prop": "name", "attributes": {"content": "他們缺工匠嗎？你要替他們組裝自動化生產流水線，還是設計下一代爬行者？", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#8$1"}, {"id": 211, "prop": "Character", "attributes": {"name": "avg_npc_402_1#4$1", "name2": "avg_npc_648_1#8$1", "focus": 1.0}}, {"id": 212, "prop": "name", "attributes": {"content": "我......", "name": "費斯特"}, "figure_art": "avg_npc_402_1#4$1"}, {"id": 213, "prop": "Character", "attributes": {"name": "avg_npc_402_1#4$1", "name2": "avg_npc_648_1#8$1", "focus": 2.0}}, {"id": 214, "prop": "name", "attributes": {"content": "你連打造武器都不會。你是不是準備告訴那些自稱自救軍的人，你想用扳手去敲薩卡茲的腦袋？", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#8$1"}, {"id": 215, "prop": "Character", "attributes": {"name": "avg_npc_402_1#10$1", "name2": "avg_npc_648_1#8$1", "focus": 1.0}}, {"id": 216, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 217, "prop": "name", "attributes": {"content": "我在學！", "name": "費斯特"}, "figure_art": "avg_npc_402_1#10$1"}, {"id": 218, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1", "name2": "avg_npc_648_1#8$1", "focus": 1.0}}, {"id": 219, "prop": "name", "attributes": {"content": "我聽你說過那些故事，那些你年輕時如何被選上打造蒸汽甲胄的故事，也聽過你在一個又一個夜晚打磨動力管線的聲音。", "name": "費斯特"}, "figure_art": "avg_npc_402_1#6$1"}, {"id": 220, "prop": "Character", "attributes": {"name": "avg_npc_402_1#3$1", "name2": "avg_npc_648_1#8$1", "focus": 1.0}}, {"id": 221, "prop": "name", "attributes": {"content": "我不明白......我們是倫蒂尼姆的工人，你從小就這麼教導我，你說我們的工廠怎樣創造了現在的維多利亞——", "name": "費斯特"}, "figure_art": "avg_npc_402_1#3$1"}, {"id": 222, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1", "name2": "avg_npc_648_1#8$1", "focus": 1.0}}, {"id": 223, "prop": "name", "attributes": {"content": "現在呢？我們要在交接儀式上降下我們的旗幟，換上薩卡茲的軍旗。", "name": "費斯特"}, "figure_art": "avg_npc_402_1#6$1"}, {"id": 224, "prop": "name", "attributes": {"content": "接下來，我們引以為傲的流水線將要為薩卡茲生產武器，而那些武器最終都會指向維多利亞人！", "name": "費斯特"}, "figure_art": "avg_npc_402_1#6$1"}, {"id": 225, "prop": "name", "attributes": {"content": "你怎麼能忍受過這樣的日子？", "name": "費斯特"}, "figure_art": "avg_npc_402_1#6$1"}, {"id": 226, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1", "name2": "avg_npc_648_1#7$1", "focus": 2.0}}, {"id": 227, "prop": "name", "attributes": {"content": "......這樣的日子？", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#7$1"}, {"id": 228, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1", "name2": "avg_npc_648_1#8$1", "focus": 2.0}}, {"id": 229, "prop": "name", "attributes": {"content": "這樣的日子就是我們的生活，是我和你的父母一直過著的生活。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#8$1"}, {"id": 230, "prop": "name", "attributes": {"content": "看看你眼前的這座工廠吧。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#8$1"}, {"id": 231, "prop": "name", "attributes": {"content": "頭銜比姓氏還長的貴族，靠貿易發家的生意人，又或者是薩卡茲......自詡是它主人的人來了又去。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#8$1"}, {"id": 232, "prop": "name", "attributes": {"content": "可流水線還在那裡。機器也從未停止過運作。經過我們雙手的每一顆鉚釘都還在它本來該在的位置上。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#8$1"}, {"id": 233, "prop": "name", "attributes": {"content": "不管佔據著倫蒂尼姆中心那座宮殿的人是誰，這座由我們建起來的城市都還要經歷明天和下一個明天。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#8$1"}, {"id": 234, "prop": "Character", "attributes": {"name": "avg_npc_402_1#10$1", "name2": "avg_npc_648_1#8$1", "focus": 1.0}}, {"id": 235, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 236, "prop": "name", "attributes": {"content": "可我不想要這樣的明天！", "name": "費斯特"}, "figure_art": "avg_npc_402_1#10$1"}, {"id": 237, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1", "name2": "avg_npc_648_1#8$1", "focus": 1.0}}, {"id": 238, "prop": "name", "attributes": {"content": "失去自由的生活哪裡算得上是生活？最多就是活著而已。", "name": "費斯特"}, "figure_art": "avg_npc_402_1#6$1"}, {"id": 239, "prop": "name", "attributes": {"content": "如果這座工廠......如果倫蒂尼姆不再屬於我們，我們為它做的每一件事又有什麼意義？！", "name": "費斯特"}, "figure_art": "avg_npc_402_1#6$1"}, {"id": 240, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1", "name2": "avg_npc_648_1#5$1", "focus": 2.0}}, {"id": 241, "prop": "name", "attributes": {"content": "......", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#5$1"}, {"id": 242, "prop": "Character", "attributes": {"name": "avg_npc_402_1#6$1", "name2": "avg_npc_648_1#6$1", "focus": 2.0}}, {"id": 243, "prop": "name", "attributes": {"content": "你知道嗎，費斯特......", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#6$1"}, {"id": 244, "prop": "name", "attributes": {"content": "二十五年前那個被火光照亮的夜晚，你爸爸也是這麼對我說的。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#6$1"}, {"id": 245, "prop": "Character", "attributes": {"name": "avg_npc_402_1#3$1", "name2": "avg_npc_648_1#6$1", "focus": 1.0}}, {"id": 246, "prop": "name", "attributes": {"content": "......", "name": "費斯特"}, "figure_art": "avg_npc_402_1#3$1"}, {"id": 247, "prop": "Character", "attributes": {"name": "avg_npc_660_1#1$1"}}, {"id": 248, "prop": "name", "attributes": {"content": "頭兒，薩卡茲快回來了——", "name": "倫蒂尼姆工人"}, "figure_art": "avg_npc_660_1#1$1"}, {"id": 249, "prop": "Character", "attributes": {"name": "avg_npc_402_1#3$1", "name2": "avg_npc_648_1#1$1", "focus": 2.0}}, {"id": 250, "prop": "name", "attributes": {"content": "你想去哪裡都是你的自由。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 251, "prop": "name", "attributes": {"content": "但是從現在開始，你不准再進入工廠，費斯特。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 252, "prop": "name", "attributes": {"content": "一個不願意用雙手完成工作的工人是不合格的。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 253, "prop": "Character", "attributes": {"name": "avg_npc_402_1#4$1", "name2": "avg_npc_648_1#1$1", "focus": 1.0}}, {"id": 254, "prop": "name", "attributes": {"content": "......", "name": "費斯特"}, "figure_art": "avg_npc_402_1#4$1"}, {"id": 255, "prop": "Character", "attributes": {"name": "avg_npc_402_1#4$1", "name2": "avg_npc_648_1#1$1", "focus": 2.0}}, {"id": 256, "prop": "name", "attributes": {"content": "想跟著他走的人，我同樣不會阻止你們。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 257, "prop": "name", "attributes": {"content": "記住——只要走出這扇門，你們就不再是我們中的一員。", "name": "凱瑟琳"}, "figure_art": "avg_npc_648_1#1$1"}, {"id": 258, "prop": "Dialog", "attributes": {}}, {"id": 259, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 260, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 261, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 262, "prop": "Character", "attributes": {}}, {"id": 263, "prop": "Image", "attributes": {}}, {"id": 264, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}