ion": 0.5}}, {"id": 116, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_419_1#1$1", "afrom": 1.0, "ato": 0.0, "duration": 0.5}}, {"id": 117, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 118, "prop": "musicvolume", "attributes": {"volume": 0.6, "fadetime": 1.0}}, {"id": 119, "prop": "charslot", "attributes": {}}, {"id": 120, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_414_1#1$1", "focus": "m"}}, {"id": 121, "prop": "name", "attributes": {"content": "那個羅德島的薩卡茲，是叫Logos嗎？", "name": "羅本"}, "figure_art": "avg_npc_414_1#1$1"}, {"id": 122, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_229_1#1", "focus": "m"}}, {"id": 123, "prop": "name", "attributes": {"content": "我還以為，在與Misery先生並肩作戰這麼久以後，我們都已經不會再為羅德島的作戰方式感到驚訝了。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 124, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_414_1#1$1", "focus": "m"}}, {"id": 125, "prop": "name", "attributes": {"content": "也對。不管那位Logos先生是什麼身份，他的那些咒術都幫了我們大忙。", "name": "羅本"}, "figure_art": "avg_npc_414_1#1$1"}, {"id": 126, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_398_1#1$1", "focus": "m"}}, {"id": 127, "prop": "name", "attributes": {"content": "......哈，而且他玩飛鏢很有一手。", "name": "自救軍戰士"}, "figure_art": "avg_npc_398_1#1$1"}, {"id": 128, "prop": "name", "attributes": {"content": "我有幸跟他比過幾次，他的準頭可能和他的那些法術一樣恐怖。", "name": "自救軍戰士"}, "figure_art": "avg_npc_398_1#1$1"}, {"id": 129, "prop": "Dialog", "attributes": {}}, {"id": 130, "prop": "charslot", "attributes": {}}, {"id": 131, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.6}}, {"id": 132, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_650_1#1$1", "duration": 1.0}}, {"id": 133, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 134, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_650_1#1$1", "focus": "m"}}, {"id": 135, "prop": "name", "attributes": {"content": "......我的一位朋友，教過我一些小技巧罷了。", "name": "Logos"}, "figure_art": "avg_npc_650_1#1$1"}, {"id": 136, "prop": "name", "attributes": {"content": "那傢伙圓凳滑行賽比不過我，但玩起飛鏢來......不差。", "name": "Logos"}, "figure_art": "avg_npc_650_1#1$1"}, {"id": 137, "prop": "name", "attributes": {"content": "號角女士，薩卡茲的部隊已經暫時退卻，抓緊機會。", "name": "Logos"}, "figure_art": "avg_npc_650_1#1$1"}, {"id": 138, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_229_1#1", "focus": "m"}}, {"id": 139, "prop": "name", "attributes": {"content": "根據計劃，羅德島和自救軍會通過補給線，撤往那條運輸通道的起點，一個叫布倫特伍德的鎮子附近，並嘗試重新建立安全屋。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 140, "prop": "name", "attributes": {"content": "我們去那裡與他們會合。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 141, "prop": "name", "attributes": {"content": "我建議向城牆的方向突圍，諾伯特區被拋離了，薩卡茲雖然合攏了城牆，但還來不及新建一個地塊填補那裡。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 142, "prop": "name", "attributes": {"content": "那些裸露的地下結構會幫上我們的忙的。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 143, "prop": "Dialog", "attributes": {}}, {"id": 144, "prop": "charslot", "attributes": {}}, {"id": 145, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 146, "prop": "PlaySound", "attributes": {"key": "$d_avg_runstop", "volume": 1.0}}, {"id": 147, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_657_1#1$1", "posfrom": "200,0", "posto": "0,0", "afrom": 0.0, "ato": 1.0, "duration": 1.0, "isblock": "true"}}, {"id": 148, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 149, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_657_1#1$1", "posfrom": "0,0", "posto": "-300,0", "duration": 0.7}}, {"id": 150, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_657_1#1$1", "afrom": 1.0, "ato": 0.0, "duration": 0.4, "isblock": "true"}}, {"id": 151, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 152, "prop": "Dialog", "attributes": {}}, {"id": 153, "prop": "charslot", "attributes": {}}, {"id": 154, "prop": "PlayMusic", "attributes": {"intro": "$mist_intro", "key": "$mist_loop", "volume": 0.6}}, {"id": 155, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_650_1#4$1", "focus": "m"}}, {"id": 156, "prop": "name", "attributes": {"content": "......", "name": "Logos"}, "figure_art": "avg_npc_650_1#4$1"}, {"id": 157, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_650_1#3$1", "focus": "m"}}, {"id": 158, "prop": "name", "attributes": {"content": "看來，我又遇到了一位故人。", "name": "Logos"}, "figure_art": "avg_npc_650_1#3$1"}, {"id": 159, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_398_1#1$1", "focus": "m"}}, {"id": 160, "prop": "name", "attributes": {"content": "是那位教飛鏢的朋友嗎？", "name": "自救軍戰士"}, "figure_art": "avg_npc_398_1#1$1"}, {"id": 161, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_650_1#3$1", "focus": "m"}}, {"id": 162, "prop": "name", "attributes": {"content": "很遺憾，並不是。", "name": "Logos"}, "figure_art": "avg_npc_650_1#3$1"}, {"id": 163, "prop": "name", "attributes": {"content": "與這位故人不同，我的朋友們至死如一。", "name": "Logos"}, "figure_art": "avg_npc_650_1#3$1"}, {"id": 164, "prop": "name", "attributes": {"content": "各位，我在城內恐怕還有些小事需要處理，號角女士有能力帶你們離開倫蒂尼姆。我的同事Misery也會在必要時刻支援你們。", "name": "Logos"}, "figure_art": "avg_npc_650_1#3$1"}, {"id": 165, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_229_1#1", "focus": "m"}}, {"id": 166, "prop": "name", "attributes": {"content": "......我明白了。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 167, "prop": "name", "attributes": {"content": "各位，保持隱蔽，跟我來。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 168, "prop": "Dialog", "attributes": {}}, {"id": 169, "prop": "playsound", "attributes": {"key": "$d_gen_soldiersrun", "volume": 0.7}}, {"id": 170, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_229_1#1", "afrom": 1.0, "ato": 0.0, "duration": 1.0}}, {"id": 171, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 172, "prop": "Dialog", "attributes": {}}, {"id": 173, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 174, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 175, "prop": "charslot", "attributes": {}}, {"id": 176, "prop": "Background", "attributes": {"image": "27_g7_subway", "screenadapt": "coverall", "block": "true"}}, {"id": 177, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_650_1#1$1"}}, {"id": 178, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_657_1#8$1"}}, {"id": 179, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 180, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 181, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 182, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_650_1#1$1", "focus": "l"}}, {"id": 183, "prop": "name", "attributes": {"content": "往日的山巔當真如此值得懷念？淚與血並不值得你為之著迷。", "name": "Logos"}, "figure_art": "avg_npc_650_1#1$1"}, {"id": 184, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_657_1#8$1", "focus": "r"}}, {"id": 185, "prop": "name", "attributes": {"content": "我承認，我對這些並沒有如此興致盎然。", "name": "“茉莉”"}, "figure_art": "avg_npc_657_1#8$1"}, {"id": 186, "prop": "name", "attributes": {"content": "但倘若，只剩下山巔可供棲身，只有榮光可得溫暖呢？", "name": "“茉莉”"}, "figure_art": "avg_npc_657_1#8$1"}, {"id": 187, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_650_1#1$1", "focus": "l"}}, {"id": 188, "prop": "name", "attributes": {"content": "......", "name": "Logos"}, "figure_art": "avg_npc_650_1#1$1"}, {"id": 189, "prop": "name", "attributes": {"content": "我以為我已經追獵了足夠多的你。", "name": "Logos"}, "figure_art": "avg_npc_650_1#1$1"}, {"id": 190, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_657_1#6$1", "focus": "r"}}, {"id": 191, "prop": "name", "attributes": {"content": "三十一個“茉莉”，你很努力，女妖。", "name": "“茉莉”"}, "figure_art": "avg_npc_657_1#6$1"}, {"id": 192, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_650_1#2$1", "focus": "l"}}, {"id": 193, "prop": "name", "attributes": {"content": "但你還是得逞了，你幫助特雷西斯瓦解了自救軍。", "name": "Logos"}, "figure_art": "avg_npc_650_1#2$1"}, {"id": 194, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_657_1#6$1", "focus": "r"}}, {"id": 195, "prop": "name", "attributes": {"content": "工作而已。", "name": "“茉莉”"}, "figure_art": "avg_npc_657_1#6$1"}, {"id": 196, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_650_1#2$1", "focus": "l"}}, {"id": 197, "prop": "name", "attributes": {"content": "......我會撬開倫蒂尼姆的每一片瓦，找到每一個躲藏在暗處的你的碎片，變形者。", "name": "Logos"}, "figure_art": "avg_npc_650_1#2$1"}, {"id": 198, "prop": "name", "attributes": {"content": "你仍拒絕相信改變的可能，這從來就是你的選擇。", "name": "Logos"}, "figure_art": "avg_npc_650_1#2$1"}, {"id": 199, "prop": "Dialog", "attributes": {}}, {"id": 200, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_657_1#6$1", "focus": "all"}}, {"id": 201, "prop": "delay", "attributes": {"time": 0.2}}, {"id": 202, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_657_1#6$1", "afrom": 1.0, "ato": 0.0, "duration": 0.5}}, {"id": 203, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 204, "prop": "playsound", "attributes": {"key": "$d_avg_humanchange"}}, {"id": 205, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_426_1#1$1", "afrom": 0.0, "ato": 1.0, "duration": 1.0}}, {"id": 206, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 207, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_426_1#1$1", "focus": "r"}}, {"id": 208, "prop": "name", "attributes": {"content": "你是不是有些太自大了，年輕的女妖？我們瞭解變化，我們自變化中而來。", "name": "變形者集群"}, "figure_art": "avg_npc_426_1#1$1"}, {"id": 209, "prop": "name", "attributes": {"content": "但變化不過是適應的手段，任何改變都有其最終的目的。", "name": "變形者集群"}, "figure_art": "avg_npc_426_1#1$1"}, {"id": 210, "prop": "name", "attributes": {"content": "在薩卡茲還未獲得如此模樣之時，我們便行走於大地之上。", "name": "變形者集群"}, "figure_art": "avg_npc_426_1#1$1"}, {"id": 211, "prop": "name", "attributes": {"content": "理念、信仰、宗旨、口號，無一逃得過歲月的沖刷。", "name": "變形者集群"}, "figure_art": "avg_npc_426_1#1$1"}, {"id": 212, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_426_1#10$1", "focus": "r"}}, {"id": 213, "prop": "name", "attributes": {"content": "你那些自以為新鮮的發想早有人想過，你那些自以為高尚的道途早有人踐行。", "name": "變形者集群"}, "figure_art": "avg_npc_426_1#10$1"}, {"id": 214, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_426_1#1$1", "focus": "r"}}, {"id": 215, "prop": "name", "attributes": {"content": "他們如今在哪裡？", "name": "變形者集群"}, "figure_art": "avg_npc_426_1#1$1"}, {"id": 216, "prop": "name", "attributes": {"content": "我們卻仍站在你的面前。", "name": "變形者集群"}, "figure_art": "avg_npc_426_1#1$1"}, {"id": 217, "prop": "name", "attributes": {"content": "這便是最好的證明。", "name": "變形者集群"}, "figure_art": "avg_npc_426_1#1$1"}, {"id": 218, "prop": "Dialog", "attributes": {}}, {"id": 219, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 220, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 221, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 222, "prop": "charslot", "attributes": {}}, {"id": 223, "prop": "Background", "attributes": {"image": "37_g1_glasgowboxinggym", "screenadapt": "coverall", "block": "true"}}, {"id": 224, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 225, "prop": "PlayMusic", "attributes": {"key": "$normal_loop", "volume": 0.6}}, {"id": 226, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 227, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 228, "prop": "PlaySound", "attributes": {"key": "$d_avg_punchsp2"}}, {"id": 229, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 230, "prop": "name", "attributes": {"content": "“砰！”"}}, {"id": 231, "prop": "Dialog", "attributes": {}}, {"id": 232, "prop": "PlaySound", "attributes": {"key": "$d_avg_punchsp1", "volume": 0.3}}, {"id": 233, "prop": "PlaySound", "attributes": {"key": "$d_avg_punch02", "volume": 0.4, "delay": 0.2}}, {"id": 234, "prop": "CameraShake", "attributes": {"duration": 0.6, "xstrength": 30.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 235, "prop": "name", "attributes": {"content": "“砰、砰！”"}}, {"id": 236, "prop": "Dialog", "attributes": {}}, {"id": 237, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_862_1#11$1", "duration": 0.7}}, {"id": 238, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_863_1#1$1", "duration": 0.7}}, {"id": 239, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 240, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_862_1#11$1", "focus": "l"}}, {"id": 241, "prop": "name", "attributes": {"content": "呼——", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#11$1"}, {"id": 242, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_863_1#1$1", "focus": "r"}}, {"id": 243, "prop": "name", "attributes": {"content": "你該節省些體力，卡鐸爾，你吃的已經夠多的了。", "name": "貝爾德"}, "figure_art": "avg_npc_863_1#1$1"}, {"id": 244, "prop": "name", "attributes": {"content": "戴菲恩已經反映過好幾次你的食量問題了，現在可比不得以往。", "name": "貝爾德"}, "figure_art": "avg_npc_863_1#1$1"}, {"id": 245, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_862_1#1$1", "focus": "l"}}, {"id": 246, "prop": "name", "attributes": {"content": "放輕鬆點，貝爾德，情況還沒有那麼糟。", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#1$1"}, {"id": 247, "prop": "name", "attributes": {"content": "那幫魔族佬沒他們看起來的那麼強大，他們只是打了我們一個措手不及。", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#1$1"}, {"id": 248, "prop": "name", "attributes": {"content": "運輸工會的馬歇爾找我聊過一次，他們那裡也團結了一批人。只要我們再多拉些人入夥，那幫薩卡茲也並非不可戰勝。", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#1$1"}, {"id": 249, "prop": "name", "attributes": {"content": "就像以前我們幾個幫派團結起來對付那些條子們一樣。", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#1$1"}, {"id": 250, "prop": "name", "attributes": {"content": "背後突襲，乾淨俐落，“咻咻”，“啪”！", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#1$1"}, {"id": 251, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_862_1#4$1", "focus": "l"}}, {"id": 252, "prop": "name", "attributes": {"content": "幾拳放倒，就這麼簡單。", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#4$1"}, {"id": 253, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_863_1#1$1", "focus": "r"}}, {"id": 254, "prop": "name", "attributes": {"content": "薩卡茲的軍隊可不是條子。", "name": "貝爾德"}, "figure_art": "avg_npc_863_1#1$1"}, {"id": 255, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_862_1#11$1", "focus": "l"}}, {"id": 256, "prop": "name", "attributes": {"content": "我知道，他們很厲害。", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#11$1"}, {"id": 257, "prop": "name", "attributes": {"content": "但我們不怕流血，不怕犧牲！我們會越過倒下的同胞，再把拳頭狠狠砸在他們的臉上——", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#11$1"}, {"id": 258, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_862_1#1$1", "focus": "l"}}, {"id": 259, "prop": "name", "attributes": {"content": "就像拳館的名字，“揍歪下巴”！", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#1$1"}, {"id": 260, "prop": "name", "attributes": {"content": "我和馬歇爾盤算過了，我們絕對能贏！", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#1$1"}, {"id": 261, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_863_1#9$1", "focus": "r"}}, {"id": 262, "prop": "name", "attributes": {"content": "和你收藏的那些龍門劣質錄製影片裡一樣，嗯？", "name": "貝爾德"}, "figure_art": "avg_npc_863_1#9$1"}, {"id": 263, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_862_1#10$1", "focus": "l"}}, {"id": 264, "prop": "name", "attributes": {"content": "我是認真的，我在諾伯特區街頭摸爬滾打的時間比你短不了多少。", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#10$1"}, {"id": 265, "prop": "name", "attributes": {"content": "我們得為自己謀一條出路，就像以前一樣。", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#10$1"}, {"id": 266, "prop": "name", "attributes": {"content": "你們的那位推進之王當時就這麼離開了格拉斯哥幫，我們那些地盤都拱手讓給了別人，是你和我想盡辦法重新在這裡站穩了腳跟。", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#10$1"}, {"id": 267, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_862_1#1$1", "focus": "l"}}, {"id": 268, "prop": "name", "attributes": {"content": "現在無非像以前一樣，團結起來，做好準備，然後揍翻他們，反正我們一直是這麼過來的。", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#1$1"}, {"id": 269, "prop": "name", "attributes": {"content": "不管外面情況怎樣，街頭總有街頭的辦法。", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#1$1"}, {"id": 270, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_862_1#11$1", "focus": "l"}}, {"id": 271, "prop": "name", "attributes": {"content": "接下來，只要尋找到一個時機......", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#11$1"}, {"id": 272, "prop": "Dialog", "attributes": {}}, {"id": 273, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 274, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_862_1#11$1", "focus": "none"}}, {"id": 275, "prop": "PlaySound", "attributes": {"key": "$d_avg_knockdoorfast", "volume": 0.5}}, {"id": 276, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 277, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_863_1#9$1", "focus": "r"}}, {"id": 278, "prop": "name", "attributes": {"content": "看來戴菲恩他們回來了。", "name": "貝爾德"}, "figure_art": "avg_npc_863_1#9$1"}, {"id": 279, "prop": "Dialog", "attributes": {}}, {"id": 280, "prop": "charslot", "attributes": {}}, {"id": 281, "prop": "PlaySound", "attributes": {"key": "$dooropenquite", "volume": 1.0}}, {"id": 282, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 283, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_866_1#6$1", "duration": 0.7}}, {"id": 284, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_177", "duration": 0.7}}, {"id": 285, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 286, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_866_1#6$1", "focus": "l"}}, {"id": 287, "prop": "name", "attributes": {"content": "......", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#6$1"}, {"id": 288, "prop": "Dialog", "attributes": {}}, {"id": 289, "prop": "charslot", "attributes": {}}, {"id": 290, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#1$1", "focus": "m"}}, {"id": 291, "prop": "name", "attributes": {"content": "禿頭佩爾鬆口了嗎？就算是眼下的情況，我們給的價格也相當高，他應該——", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#1$1"}, {"id": 292, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#5$1", "focus": "m"}}, {"id": 293, "prop": "name", "attributes": {"content": "怎麼了？這是......血？", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#5$1"}, {"id": 294, "prop": "playMusic", "attributes": {"intro": "$calamity_intro", "key": "$calamity_loop", "volume": 0.6}}, {"id": 295, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_866_1#6$1", "focus": "m"}}, {"id": 296, "prop": "name", "attributes": {"content": "禿頭佩爾死了。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#6$1"}, {"id": 297, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#5$1", "focus": "m"}}, {"id": 298, "prop": "name", "attributes": {"content": "！", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#5$1"}, {"id": 299, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#8$1", "focus": "m"}}, {"id": 300, "prop": "name", "attributes": {"content": "薩卡茲——", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#8$1"}, {"id": 301, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_177", "focus": "m"}}, {"id": 302, "prop": "name", "attributes": {"content": "不，不是薩卡茲！該死的，我不知道那些都是誰，我們到那家店的時候就已經打起來了！", "name": "膽怯的市民"}, "figure_art": "avg_npc_177"}, {"id": 303, "prop": "name", "attributes": {"content": "他們殺紅了眼！我親眼看到有個拿撬棍的傢伙，把另一個人按在地上，那傢伙甚至——", "name": "膽怯的市民"}, "figure_art": "avg_npc_177"}, {"id": 304, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 12.0, "ystrength": 15.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 305, "prop": "name", "attributes": {"content": "嘔——咳咳咳！", "name": "膽怯的市民"}, "figure_art": "avg_npc_177"}, {"id": 306, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_866_1#6$1", "focus": "m"}}, {"id": 307, "prop": "name", "attributes": {"content": "情況很糟，大概是哪個餓瘋了的流浪漢盯上了佩爾的店，那蠢貨還把麵包放在玻璃櫥窗裡。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#6$1"}, {"id": 308, "prop": "name", "attributes": {"content": "結果可想而知。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#6$1"}, {"id": 309, "prop": "name", "attributes": {"content": "你可以猜猜，現在這一片被封鎖的街區裡，這種“流浪漢”有多少。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#6$1"}, {"id": 310, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#12$1", "focus": "m"}}, {"id": 311, "prop": "name", "attributes": {"content": "......", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#12$1"}, {"id": 312, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#8$1", "focus": "m"}}, {"id": 313, "prop": "name", "attributes": {"content": "這些該死的瘋子，大概是什麼違禁品把他們的腦子燒壞了！", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#8$1"}, {"id": 314, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_866_1#7$1", "focus": "m"}}, {"id": 315, "prop": "name", "attributes": {"content": "......我認識那個拿撬棍的傢伙，是個賣尾巴毛髮護理膏的推銷員，平時臉上總掛著笑容。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#7$1"}, {"id": 316, "prop": "name", "attributes": {"content": "我買過幾次他的產品，他給我打了折，不過談不上好用。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#7$1"}, {"id": 317, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_866_1#6$1", "focus": "m"}}, {"id": 318, "prop": "name", "attributes": {"content": "剛才......我看見他雙眼通紅，嘴角淌著血，那把撬棍已經被他砸得變了形。我幾乎......認不出他來了。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#6$1"}, {"id": 319, "prop": "name", "attributes": {"content": "恐慌在蔓延，卡鐸爾。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#6$1"}, {"id": 320, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#12$1", "focus": "m"}}, {"id": 321, "prop": "name", "attributes": {"content": "——運輸工會的人說過這種情況，他們說可能有些膽小鬼會發瘋，可是怎麼......", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#12$1"}, {"id": 322, "prop": "Dialog", "attributes": {}}, {"id": 323, "prop": "charslot", "attributes": {}}, {"id": 324, "prop": "PlaySound", "attributes": {"key": "$bottlebroken", "volume": 0.6}}, {"id": 325, "prop": "PlaySound", "attributes": {"key": "$d_avg_glass_break", "volume": 1.0, "delay": 0.4}}, {"id": 326, "prop": "PlaySound", "attributes": {"key": "$d_avg_windowbreak", "volume": 1.0, "delay": 0.9}}, {"id": 327, "prop": "CameraShake", "attributes": {"duration": 1.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 328, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 329, "prop": "PlaySound", "attributes": {"key": "$d_avg_knockdoorfast", "volume": 0.7}}, {"id": 330, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 331, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 332, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_866_1#3$1", "focus": "m"}}, {"id": 333, "prop": "name", "attributes": {"content": "抵住門！", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#3$1"}, {"id": 334, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_177", "focus": "m"}}, {"id": 335, "prop": "name", "attributes": {"content": "我，我......", "name": "膽怯的市民"}, "figure_art": "avg_npc_177"}, {"id": 336, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_863_1#7$1", "focus": "m"}}, {"id": 337, "prop": "name", "attributes": {"content": "還愣著幹什麼，快點來幫忙！卡鐸爾，去把沙發推過來！", "name": "貝爾德"}, "figure_art": "avg_npc_863_1#7$1"}, {"id": 338, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#7$1", "focus": "m"}}, {"id": 339, "prop": "name", "attributes": {"content": "混蛋，你們找死嗎？你們*維多利亞粗口*想幹嘛？", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#7$1"}, {"id": 340, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#7$1", "focus": "none"}}, {"id": 341, "prop": "name", "attributes": {"content": "......", "name": "門外的聲音"}}, {"id": 342, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#7$1", "focus": "m"}}, {"id": 343, "prop": "name", "attributes": {"content": "滾開，這裡還*維多利亞粗口*有活人呢，這裡是格拉斯哥幫的地盤！", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#7$1"}, {"id": 344, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#7$1", "focus": "none"}}, {"id": 345, "prop": "name", "attributes": {"content": "......", "name": "門外的聲音"}}, {"id": 346, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#7$1", "focus": "m"}}, {"id": 347, "prop": "name", "attributes": {"content": "貝爾德，小心！", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#7$1"}, {"id": 348, "prop": "Dialog", "attributes": {}}, {"id": 349, "prop": "charslot", "attributes": {}}, {"id": 350, "prop": "PlaySound", "attributes": {"key": "$d_avg_axeimp", "volume": 1.0}}, {"id": 351, "prop": "PlaySound", "attributes": {"key": "$d_avg_doorbreak", "volume": 1.0, "delay": 0.4}}, {"id": 352, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.95, "g": 0.95, "b": 0.95, "fadetime": 0.1, "block": "true"}}, {"id": 353, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 40.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 354, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.95, "g": 0.95, "b": 0.95, "fadetime": 0.3, "block": "true"}}, {"id": 355, "prop": "Delay", "attributes": {"time": 1.2}}, {"id": 356, "prop": "name", "attributes": {"content": "一柄消防斧將拳館厚重的門板劈開一道縫隙，鋒利的斧刃擦著貝爾德的髮梢而過。"}}, {"id": 357, "prop": "name", "attributes": {"content": "幾根髮絲飄落。"}}, {"id": 358, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#7$1", "focus": "m"}}, {"id": 359, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 12.0, "ystrength": 12.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 360, "prop": "name", "attributes": {"content": "我說了，這裡還*維多利亞粗口*有活人呢！", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#7$1"}, {"id": 361, "prop": "Dialog", "attributes": {}}, {"id": 362, "prop": "PlaySound", "attributes": {"key": "$d_avg_woodenladder", "volume": 0.4}}, {"id": 363, "prop": "PlaySound", "attributes": {"key": "$d_gen_doorclose", "volume": 0.6, "delay": 0.3}}, {"id": 364, "prop": "CameraShake", "attributes": {"duration": 0.7, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 365, "prop": "Delay", "attributes": {"time": 1.2}}, {"id": 366, "prop": "name", "attributes": {"content": "卡鐸爾抵住門，兩隻手緊緊攥住穿過門板的斧刃，門外的人試了幾次，都沒有成功把斧子重新抽出。"}}, {"id": 367, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#7$1", "focus": "m"}}, {"id": 368, "prop": "name", "attributes": {"content": "不管你是誰，給我滾！否則我會把這把斧頭嵌進你的腦袋裡！我說到做到！", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#7$1"}, {"id": 369, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#7$1", "focus": "none"}}, {"id": 370, "prop": "name", "attributes": {"content": "......", "name": "門外的聲音"}}, {"id": 371, "prop": "Dialog", "attributes": {}}, {"id": 372, "prop": "charslot", "attributes": {}}, {"id": 373, "prop": "PlaySound", "attributes": {"key": "$gavel1", "volume": 0.5}}, {"id": 374, "prop": "PlaySound", "attributes": {"key": "$sheildimpact", "volume": 0.6, "delay": 0.3}}, {"id": 375, "prop": "PlaySound", "attributes": {"key": "$d_gen_doorclose", "volume": 0.6, "delay": 0.8}}, {"id": 376, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 40.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 377, "prop": "name", "attributes": {"content": "斧子又搖晃了幾下，幾次沉重的踹門聲過後，門外的人終於放棄了努力，紛亂的腳步聲逐漸遠去。"}}, {"id": 378, "prop": "Dialog", "attributes": {}}, {"id": 379, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_177", "focus": "m"}}, {"id": 380, "prop": "name", "attributes": {"content": "你手上......你的手指......", "name": "膽怯的市民"}, "figure_art": "avg_npc_177"}, {"id": 381, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#8$1", "focus": "m"}}, {"id": 382, "prop": "name", "attributes": {"content": "......", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#8$1"}, {"id": 383, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#3$1", "focus": "m"}}, {"id": 384, "prop": "name", "attributes": {"content": "謝天謝地，拳館最不缺的就是繃帶。", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#3$1"}, {"id": 385, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#8$1", "focus": "m"}}, {"id": 386, "prop": "name", "attributes": {"content": "貝爾德，戴菲恩，我們得重新清點一遍所有物資。", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#8$1"}, {"id": 387, "prop": "name", "attributes": {"content": "我去卸幾個沙袋下來，重新加固一下大門。", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#8$1"}, {"id": 388, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_177", "focus": "m"}}, {"id": 389, "prop": "name", "attributes": {"content": "這......這些人，他們難道都瘋了嗎？！", "name": "膽怯的市民"}, "figure_art": "avg_npc_177"}, {"id": 390, "prop": "name", "attributes": {"content": "他們......諾伯特區本該都是有道德的市民，基本上......警察呢？他們平時開罰單比誰都勤快！", "name": "膽怯的市民"}, "figure_art": "avg_npc_177"}, {"id": 391, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#8$1", "focus": "m"}}, {"id": 392, "prop": "name", "attributes": {"content": "我要是個沒來得及溜出地塊的倒楣條子，現在一定揣好武器把自己鎖在家裡。", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#8$1"}, {"id": 393, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#12$1", "focus": "m"}}, {"id": 394, "prop": "name", "attributes": {"content": "我......之後我得再去運輸工會一趟，馬歇爾的話住在這裡的人們總還是認的。", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#12$1"}, {"id": 395, "prop": "name", "attributes": {"content": "他——大家平常都願意聽他的，他能想出辦法來的。", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#12$1"}, {"id": 396, "prop": "name", "attributes": {"content": "該死......該死！薩卡茲還在外面，這幫人昏了頭，怎麼能——", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#12$1"}, {"id": 397, "prop": "Dialog", "attributes": {}}, {"id": 398, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.6}}, {"id": 399, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#12$1", "afrom": 1.0, "ato": 0.0, "duration": 1.0}}, {"id": 400, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 401, "prop": "charslot", "attributes": {}}, {"id": 402, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_177", "duration": 0.5, "focus": "l"}}, {"id": 403, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_863_1#7$1", "duration": 0.5, "focus": "l"}}, {"id": 404, "prop": "Delay", "attributes": {"time": 0.6}}, {"id": 405, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_177", "focus": "l"}}, {"id": 406, "prop": "name", "attributes": {"content": "我們......接下來怎麼辦？卡鐸爾之前說，只要等......", "name": "膽怯的市民"}, "figure_art": "avg_npc_177"}, {"id": 407, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_863_1#7$1", "focus": "r"}}, {"id": 408, "prop": "name", "attributes": {"content": "一個機會？", "name": "貝爾德"}, "figure_art": "avg_npc_863_1#7$1"}, {"id": 409, "prop": "name", "attributes": {"content": "“下個院士”先生，你知道十五年前諾伯特區的那場大火嗎？", "name": "貝爾德"}, "figure_art": "avg_npc_863_1#7$1"}, {"id": 410, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_177", "focus": "l"}}, {"id": 411, "prop": "name", "attributes": {"content": "啊，我聽說過，好像是在碼頭......", "name": "膽怯的市民"}, "figure_art": "avg_npc_177"}, {"id": 412, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_863_1#7$1", "focus": "r"}}, {"id": 413, "prop": "name", "attributes": {"content": "燒掉整個碼頭並沒有什麼困難的。", "name": "貝爾德"}, "figure_art": "avg_npc_863_1#7$1"}, {"id": 414, "prop": "name", "attributes": {"content": "熱得要死的天氣，堆滿刨花的庫房，和一顆沒掐滅的煙頭，就足以釀成那一切。", "name": "貝爾德"}, "figure_art": "avg_npc_863_1#7$1"}, {"id": 415, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_863_1#8$1", "focus": "r"}}, {"id": 416, "prop": "name", "attributes": {"content": "這種火，沒人能撲得滅的。", "name": "貝爾德"}, "figure_art": "avg_npc_863_1#8$1"}, {"id": 417, "prop": "name", "attributes": {"content": "我們只能眼睜睜看著一切都燒成灰燼。", "name": "貝爾德"}, "figure_art": "avg_npc_863_1#8$1"}, {"id": 418, "prop": "Dialog", "attributes": {}}, {"id": 419, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 420, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 421, "prop": "stopmusic", "attributes": {"fadetime": 3.0}}, {"id": 422, "prop": "charslot", "attributes": {}}, {"id": 423, "prop": "Image", "attributes": {}}, {"id": 424, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}