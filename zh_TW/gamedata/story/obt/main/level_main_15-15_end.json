 "prop": "delay", "attributes": {"time": 0.4}}, {"id": 42, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 43, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 44, "prop": "Background", "attributes": {}}, {"id": 45, "prop": "charslot", "attributes": {}}, {"id": 46, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "amount": 0.8, "keep": "true"}}, {"id": 47, "prop": "Image", "attributes": {"image": "50_i16", "screenadapt": "coverall"}}, {"id": 48, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 49, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 50, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 51, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 52, "prop": "Image", "attributes": {}}, {"id": 53, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "amount": 0.0, "keep": "true"}}, {"id": 54, "prop": "Background", "attributes": {"image": "60_g13_rhodesdeck_origin", "screenadapt": "coverall"}}, {"id": 55, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#6$1"}}, {"id": 56, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 57, "prop": "name", "attributes": {"content": "在這種情況下，真正殺死你已經是不可能的事。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#6$1"}, {"id": 58, "prop": "name", "attributes": {"content": "但是特蕾西婭和特雷西斯做到的事，讓我確信了一點。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#6$1"}, {"id": 59, "prop": "name", "attributes": {"content": "你對源石的控制並非無可動搖，依然存在一些手段來限制你對於源石的權限。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#6$1"}, {"id": 60, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1718_1#1$1"}}, {"id": 61, "prop": "name", "attributes": {"content": "你所說的兩個人，我的確在源石內部見過他們。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_1718_1#1$1"}, {"id": 62, "prop": "name", "attributes": {"content": "他們的努力的確出人意料，是令人驚喜的掙扎。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_1718_1#1$1"}, {"id": 63, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1718_1#10$1"}}, {"id": 64, "prop": "name", "attributes": {"content": "所以呢？你又如何確信，在這裡殺了我不是徒勞之舉？", "name": "普瑞賽斯"}, "figure_art": "avg_npc_1718_1#10$1"}, {"id": 65, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1"}}, {"id": 66, "prop": "name", "attributes": {"content": "Mon3tr攻擊你的時候，你選擇了防禦。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 67, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1718_1#2$1"}}, {"id": 68, "prop": "name", "attributes": {"content": "……", "name": "普瑞賽斯"}, "figure_art": "avg_npc_1718_1#2$1"}, {"id": 69, "prop": "name", "attributes": {"content": "……你怎麼能做到？", "name": "普瑞賽斯"}, "figure_art": "avg_npc_1718_1#2$1"}, {"id": 70, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#11$1"}}, {"id": 71, "prop": "name", "attributes": {"content": "看來你已經察覺到了。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#11$1"}, {"id": 72, "prop": "name", "attributes": {"content": "基於特蕾西婭對源石的研究，同樣是模仿你對Dr.{@nickname}設下的陷阱，我對你所處的喚醒室加入了一些設計。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#11$1"}, {"id": 73, "prop": "name", "attributes": {"content": "只要你在這裡醒來，你的意識，同樣會困於這具身體，而無法重新回到源石內部的資訊海洋。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#11$1"}, {"id": 74, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1718_1#3$1"}}, {"id": 75, "prop": "name", "attributes": {"content": "……？", "name": "普瑞賽斯"}, "figure_art": "avg_npc_1718_1#3$1"}, {"id": 76, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#6$1"}}, {"id": 77, "prop": "name", "attributes": {"content": "或許你遲早能突破這一層限制，而且你依然有操作源石的權限，但此刻的你，也只是一個人類。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#6$1"}, {"id": 78, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1718_1#7$1"}}, {"id": 79, "prop": "name", "attributes": {"content": "你為了反抗我，竟然會做到這一步——", "name": "普瑞賽斯"}, "figure_art": "avg_npc_1718_1#7$1"}, {"id": 80, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#6$1"}}, {"id": 81, "prop": "name", "attributes": {"content": "普瑞賽斯，你不是泰拉的造物主。這片大地上的一切生命，沒有義務順應你的意願。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#6$1"}, {"id": 82, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#7$1"}}, {"id": 83, "prop": "name", "attributes": {"content": "……這是我對你的報復，也是最後的反抗。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#7$1"}, {"id": 84, "prop": "charslot", "attributes": {}}, {"id": 85, "prop": "name", "attributes": {"content": "你看到站在對面的女性臉上露出了一絲猶疑，但緊接著，源石開始在她的身旁環繞。"}}, {"id": 86, "prop": "dialog", "attributes": {}}, {"id": 87, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 10.0, "ystrength": 10.0, "vibrato": 90.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 88, "prop": "PlaySound", "attributes": {"key": "$d_avg_icecrystlncrse", "volume": 1.0}}, {"id": 89, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 90, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#6$1"}}, {"id": 91, "prop": "name", "attributes": {"content": "……太遲了。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#6$1"}, {"id": 92, "prop": "dialog", "attributes": {}}, {"id": 93, "prop": "charslot", "attributes": {}}, {"id": 94, "prop": "Decision", "attributes": {"options": "阿米婭！幫助凱爾希！", "values": "1"}, "targetLine": {"option1": "line95"}}, {"id": 95, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 96, "prop": "Effect", "attributes": {"name": "$e_amiya_atk_01", "layer": 1.0}}, {"id": 97, "prop": "PlaySound", "attributes": {"key": "$p_skill_chimera", "volume": 1.0}}, {"id": 98, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, 