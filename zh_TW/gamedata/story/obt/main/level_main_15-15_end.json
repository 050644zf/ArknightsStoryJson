12, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 413, "prop": "name", "attributes": {"content": "意外發生得無比突然，但已經足以讓你理解這個殘酷的事實。"}}, {"id": 414, "prop": "name", "attributes": {"content": "你們所對抗的，並不是可被常理理解的敵人，她擁有著操控一切源石的權限。"}}, {"id": 415, "prop": "name", "attributes": {"content": "凱爾希右肩上的那一點源石結晶，是她生而為人的證據，也是奪走她生命的根源。"}}, {"id": 416, "prop": "name", "attributes": {"content": "源石結晶開始擴散，直至吞噬了她整個身軀，然後碎裂，隨風消散——你的眼睛來不及捕捉這一完整過程。"}}, {"id": 417, "prop": "name", "attributes": {"content": "越是強大，越是脆弱。"}}, {"id": 418, "prop": "name", "attributes": {"content": "長生之人的生命在此終結。"}}, {"id": 419, "prop": "name", "attributes": {"content": "她已經完成了她的諾言。"}}, {"id": 420, "prop": "dialog", "attributes": {}}, {"id": 421, "prop": "stopmusic", "attributes": {"fadetime": 4.0}}, {"id": 422, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 423, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 4.0, "block": "true"}}, {"id": 424, "prop": "charslot", "attributes": {}}, {"id": 425, "prop": "Background", "attributes": {}}, {"id": 426, "prop": "Image", "attributes": {}}, {"id": 427, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}