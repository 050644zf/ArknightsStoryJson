ime": 4.0}}, {"id": 400, "prop": "animtext", "attributes": {"content": "<p=1>Abyss內</><p=2>同一時間</>", "id": "at1", "name": "group_location_stamp", "style": "avg_both", "pos": "-400,-200", "block": "false", "p": 2.0}}, {"id": 401, "prop": "delay", "attributes": {"time": 3.0}}, {"id": 402, "prop": "animtextclean", "attributes": {}}, {"id": 403, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 404, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1730_1#3$1"}}, {"id": 405, "prop": "name", "attributes": {"content": "已經恢復了和博士的聯繫。", "name": "Raidian"}, "figure_art": "avg_npc_1730_1#3$1"}, {"id": 406, "prop": "name", "attributes": {"content": "我們按照原定計劃繼續行動。", "name": "Raidian"}, "figure_art": "avg_npc_1730_1#3$1"}, {"id": 407, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_391_rosmon_1#1$2"}}, {"id": 408, "prop": "name", "attributes": {"content": "沒有感知到更多的敵人。", "name": "迷迭香"}, "figure_art": "avg_391_rosmon_1#1$2"}, {"id": 409, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1730_1#2$1"}}, {"id": 410, "prop": "name", "attributes": {"content": "我也沒有捕捉到PRTS核心產生任何新的數據傳輸。", "name": "Raidian"}, "figure_art": "avg_npc_1730_1#2$1"}, {"id": 411, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4133_logos_1#7$1"}}, {"id": 412, "prop": "name", "attributes": {"content": "太安靜了。", "name": "Logos"}, "figure_art": "avg_4133_logos_1#7$1"}, {"id": 413, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4132_ascln_1#1$1"}}, {"id": 414, "prop": "name", "attributes": {"content": "Raidian，麻煩分享核心的位置。", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#1$1"}, {"id": 415, "prop": "dialog", "attributes": {}}, {"id": 416, "prop": "charslot", "attributes": {}}, {"id": 417, "prop": "PlaySound", "attributes": {"key": "$transmission", "volume": 1.0}}, {"id": 418, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 419, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1730_1#3$1"}}, {"id": 420, "prop": "name", "attributes": {"content": "已同步。", "name": "Raidian"}, "figure_art": "avg_npc_1730_1#3$1"}, {"id": 421, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4132_ascln_1#1$1"}}, {"id": 422, "prop": "name", "attributes": {"content": "繼續向核心方位推進，嘗試解除核心的運作。", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#1$1"}, {"id": 423, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_017_huang_1#11$2"}}, {"id": 424, "prop": "name", "attributes": {"content": "我走前面！PRTS一定會安排新一波次的敵人攔截我們。", "name": "煌"}, "figure_art": "avg_017_huang_1#11$2"}, {"id": 425, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_521_1#1$1"}}, {"id": 426, "prop": "name", "attributes": {"content": "解析核心的工作交給我。", "name": "Mechanist"}, "figure_art": "avg_npc_521_1#1$1"}, {"id": 427, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4133_logos_1#3$1"}}, {"id": 428, "prop": "name", "attributes": {"content": "“極光”。", "name": "Logos"}, "figure_art": "avg_4133_logos_1#3$1"}, {"id": 429, "prop": "name", "attributes": {"content": "微光指引前路——", "name": "Logos"}, "figure_art": "avg_4133_logos_1#3$1"}, {"id": 430, "prop": "dialog", "attributes": {}}, {"id": 431, "prop": "PlaySound", "attributes": {"key": "$d_avg_magic_2", "volume": 1.0}}, {"id": 432, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 433, "prop": "background", "attributes": {}}, {"id": 434, "prop": "charslot", "attributes": {}}, {"id": 435, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 436, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.1, "block": "true"}}, {"id": 437, "prop": "name", "attributes": {"content": "——？", "name": "Logos"}}, {"id": 438, "prop": "name", "attributes": {"content": "怎麼了，Logos？", "name": "Mechanist"}}, {"id": 439, "prop": "name", "attributes": {"content": "那並非我的光……", "name": "Logos"}}, {"id": 440, "prop": "dialog", "attributes": {}}, {"id": 441, "prop": "playMusic", "attributes": {"intro": "$lab_intro", "key": "$lab_loop", "volume": 0.6}}, {"id": 442, "prop": "cgitem", "attributes": {"image": "cgitem_60_i16", "style": "cg", "sfrom": 1.0, "sto": 1.5, "sduration": 0.01, "pfrom": "0,0", "pto": "-55,-300", "pduration": 0.01, "rduration": 0.1, "afrom": 0.0, "ato": 1.0, "aduration": 0.5, "layer": 1.0}}, {"id": 443, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 444, "prop": "name", "attributes": {"content": "黑暗中，高懸的菱形光環微微晃動著。"}}, {"id": 445, "prop": "name", "attributes": {"content": "如同一顆冰冷的眼睛，俯瞰著在場的所有人。"}}, {"id": 446, "prop": "name", "attributes": {"content": "戒備……", "name": "阿斯卡綸"}}, {"id": 447, "prop": "name", "attributes": {"content": "……是凱爾希醫生提到的“普瑞賽斯”嗎？", "name": "煌"}}, {"id": 448, "prop": "name", "attributes": {"content": "恐怕不是。", "name": "Raidian"}}, {"id": 449, "prop": "name", "attributes": {"content": "我偵測到突然出現了大量雜亂但熟悉的訊號。", "name": "Raidian"}}, {"id": 450, "prop": "name", "attributes": {"content": "那些訊號來自羅德島本身。", "name": "Raidian"}}, {"id": 451, "prop": "dialog", "attributes": {}}, {"id": 452, "prop": "StopSound", "attributes": {"channel": "en", "fadetime": 4.0}}, {"id": 453, "prop": "cgitem", "attributes": {"image": "cgitem_60_i16", "style": "cg", "sfrom": 1.5, "sto": 1.2, "sduration": 4.0, "pfrom": "-55,-300", "pto": "-70,-45", "pduration": 4.0, "rto": 0.0, "rduration": 4.0, "layer": 1.0}}, {"id": 454, "prop": "Delay", "attributes": {"time": 3.0}}, {"id": 455, "prop": "PlaySound", "attributes": {"key": "$d_avg_systemstart_weird", "volume": 1.0}}, {"id": 456, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 457, "prop": "cgitem", "attributes": {"image": "cgitem_60_i16", "style": "cg", "sfrom": 1.2, "sto": 1.0, "sduration": 22.0, "pfrom": "-70,-45", "pto": "-55,0", "pduration": 22.0, "layer": 1.0}}, {"id": 458, "prop": "Image", "attributes": {"image": "60_i16", "screenadapt": "coverall", "xScale": 1.2, "yScale": 1.2, "fadetime": 0.5}}, {"id": 459, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.2, "yScaleFrom": 1.2, "xScaleTo": 1.0, "yScaleTo": 1.0, "yTo": 0.0, "duration": 20.0, "block": "false"}}, {"id": 460, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 461, "prop": "name", "attributes": {"content": "這是……什麼東西？", "name": "Misery"}}, {"id": 462, "prop": "name", "attributes": {"content": "龐大的機械構造物在無盡的白噪音中緩緩浮現在了所有人的面前——"}}, {"id": 463, "prop": "name", "attributes": {"content": "構成其主體的部件，在場之人都很熟悉。"}}, {"id": 464, "prop": "name", "attributes": {"content": "可露希爾曾許多次向大家展示這些她對羅德島不同模組改造時所用的部件，甚至一些特殊部件就出自精英幹員之手。"}}, {"id": 465, "prop": "name", "attributes": {"content": "PRTS重組了羅德島的設備作為武器。", "name": "Touch"}}, {"id": 466, "prop": "name", "attributes": {"content": "但……這些部件是從哪冒出來的？Abyss裡明明沒有……", "name": "Touch"}}, {"id": 467, "prop": "name", "attributes": {"content": "源石。", "name": "阿斯卡綸"}}, {"id": 468, "prop": "name", "attributes": {"content": "源石的晶簇不規則地遍布在這尊造型獨特的機械上。"}}, {"id": 469, "prop": "name", "attributes": {"content": "它們不再僅僅吞噬，而是開始了創造。"}}, {"id": 470, "prop": "name", "attributes": {"content": "等等，源石能做到再現羅德島的東西？", "name": "Misery"}}, {"id": 471, "prop": "name", "attributes": {"content": "Logos想起了內化宇宙中那座高塔，也想起了殿下。"}}, {"id": 472, "prop": "name", "attributes": {"content": "沒這麼簡單。", "name": "Logos"}}, {"id": 473, "prop": "name", "attributes": {"content": "PRTS並沒有解碼源石數據的能力，其中必然有他人介入。", "name": "Logos"}}, {"id": 474, "prop": "name", "attributes": {"content": "普瑞賽斯。", "name": "阿斯卡綸"}}, {"id": 475, "prop": "name", "attributes": {"content": "它的數據正透過我無法理解的方式和PRTS的核心相連，這個東西和之前那些源石結晶體不一樣！", "name": "Raidian"}}, {"id": 476, "prop": "name", "attributes": {"content": "無論如何，看起來怎麼都得打一架了。", "name": "煌"}}, {"id": 477, "prop": "name", "attributes": {"content": "的確沒有其他辦法了。", "name": "Stormeye"}}, {"id": 478, "prop": "name", "attributes": {"content": "各位？", "name": "Stormeye"}}, {"id": 479, "prop": "dialog", "attributes": {}}, {"id": 480, "prop": "PlaySound", "attributes": {"key": "$d_avg_attack_ready", "volume": 1.0}}, {"id": 481, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 482, "prop": "name", "attributes": {"content": "可以動手。", "name": "迷迭香"}}, {"id": 483, "prop": "name", "attributes": {"content": "此時，菱形的眼睛光芒更甚。"}}, {"id": 484, "prop": "name", "attributes": {"content": "由PRTS控制形成的擬態機械開始蓄積能量……"}}, {"id": 485, "prop": "dialog", "attributes": {}}, {"id": 486, "prop": "PlaySound", "attributes": {"key": "$d_avg_energygather", "volume": 1.0}}, {"id": 487, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 488, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 489, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "目標，不限。戰鬥風格已破解。", "x": 180.0, "y": 170.0, "alignment": "left", "size": 24.0, "delay": 0.04, "width": 700.0, "block": "true"}}, {"id": 490, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n調用能源，無限制。", "block": "true"}}, {"id": 491, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\nPRTS最終清除協議已載入——", "block": "true"}}, {"id": 492, "prop": "Sticker", "attributes": {"id": "st1", "duration": 0.5, "block": "false"}}, {"id": 493, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 494, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 495, "prop": "charslot", "attributes": {}}, {"id": 496, "prop": "Background", "attributes": {}}, {"id": 497, "prop": "Image", "attributes": {}}, {"id": 498, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}