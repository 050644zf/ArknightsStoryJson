ue"}}, {"id": 58, "prop": "Blocker", "attributes": {"a": 0.1, "r": 0.0, "g": 0.0, "b": 0.0, "afrom": 0.8, "rfrom": 1.0, "gfrom": 1.0, "bfrom": 1.0, "fadetime": 0.3, "block": "true"}}, {"id": 59, "prop": "Blocker", "attributes": {"a": 0.1, "r": 0.0, "g": 0.0, "b": 0.0, "afrom": 0.0, "rfrom": 0.0, "gfrom": 0.0, "bfrom": 0.0, "fadetime": 0.3, "block": "true"}}, {"id": 60, "prop": "Blocker", "attributes": {"a": 0.1, "fadetime": 2.0, "block": "true"}}, {"id": 61, "prop": "name", "attributes": {"content": "絲線從阿米婭的法杖上散開，試圖阻攔普瑞賽斯前進的腳步……"}}, {"id": 62, "prop": "name", "attributes": {"content": "但地面上的源石總是能從刁鑽的角度生長出來，內化阿米婭的所有法術。"}}, {"id": 63, "prop": "name", "attributes": {"content": "你能看出來阿米婭很吃力。"}}, {"id": 64, "prop": "name", "attributes": {"content": "眼前這個幾乎無法抗衡的普瑞賽斯，還有凱爾希唯一留存下來的東西——"}}, {"id": 65, "prop": "dialog", "attributes": {}}, {"id": 66, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1718_1#1$1"}}, {"id": 67, "prop": "name", "attributes": {"content": "你想要救牠？", "name": "普瑞賽斯"}, "figure_art": "avg_npc_1718_1#1$1"}, {"id": 68, "prop": "dialog", "attributes": {}}, {"id": 69, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 70, "prop": "Decision", "attributes": {"options": "……", "values": "1"}, "targetLine": {"option1": "line71"}}, {"id": 71, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 72, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1718_1#8$1"}}, {"id": 73, "prop": "name", "attributes": {"content": "我也想修好牠，和你一樣。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_1718_1#8$1"}, {"id": 74, "prop": "name", "attributes": {"content": "AMa-10不僅承載了我們共同的期待，牠還保存了一段對我而言極為關鍵的記錄。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_1718_1#8$1"}, {"id": 75, "prop": "charslot", "attributes": {}}, {"id": 76, "prop": "name", "attributes": {"content": "你依舊沒有從剛剛的衝擊中緩過來。"}}, {"id": 77, "prop": "name", "attributes": {"content": "面對眼前的威脅，你甚至沒有悲傷的餘力。"}}, {"id": 78, "prop": "name", "attributes": {"content": "普瑞賽斯，她還會有怎樣的行動？你又該如何保護阿米婭……"}}, {"id": 79, "prop": "name", "attributes": {"content": "而普瑞賽斯顯然注意到了你的心思——"}}, {"id": 80, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1718_1#6$1"}}, {"id": 81, "prop": "name", "attributes": {"content": "Dr.{@nickname}，你……為什麼在害怕我？", "name": "普瑞賽斯"}, "figure_art": "avg_npc_1718_1#6$1"}, {"id": 82, "prop": "charslot", "attributes": {}}, {"id": 83, "prop": "name", "attributes": {"content": "她與你越來越接近。"}}, {"id": 84, "prop": "dialog", "attributes": {}}, {"id": 85, "prop": "Decision", "attributes": {"options": "（……想出辦法。）;（快想出辦法！）", "values": "1;2"}, "targetLine": {"option1": "line86", "option2": "line86"}}, {"id": 86, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 87, "prop": "name", "attributes": {"content": "你和阿米婭被腳下蔓延的源石完全限制，無法動彈。"}}, {"id": 88, "prop": "name", "attributes": {"content": "你第一次如此近距離地見到了她。"}}, {"id": 89, "prop": "dialog", "attributes": {}}, {"id": 90, "prop": "stopmusic", "attributes": {"fadetime": 0.5}}, {"id": 91, "prop": "StopSound", "attributes": {"channel": "d", "fadetime": 0.5}}, {"id": 92, "prop": "musicvolume", "attributes": {"volume": 0.2, "fadetime": 2.0}}, {"id": 93, "prop": "PlaySound", "attributes": {"key": "$flashback", "volume": 0.8}}, {"id": 94, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 95, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 96, "prop": "charslot", "attributes": {}}, {"id": 97, "prop": "Background", "attributes": {"image": "bg_graduate", "screenadapt": "coverall"}}, {"id": 98, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1"}}, {"id": 99, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "amount": 0.8, "keep": "true"}}, {"id": 100, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 101, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 102, "prop": "Decision", "attributes": {"options": "你究竟要做什麼？！", "values": "1"}, "targetLine": {"option1": "line103"}}, {"id": 103, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 104, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1"}}, {"id": 105, "prop": "name", "attributes": {"content": "……保護你。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 106, "prop": "name", "attributes": {"content": "就像我承諾過的那樣。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 107, "prop": "name", "attributes": {"content": "我承諾過，我會保護阿米婭，也會保護你。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 108, "prop": "name", "attributes": {"content": "我會保護你至你生命的最後一刻，博士。這是我的職責。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 109, "prop": "name", "attributes": {"content": "但我不會停止恨你。我無力教育和指責迷迭香，因為我也害怕自己會忍不住報復你。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 110, "prop": "dialog", "attributes": {}}, {"id": 111, "prop": "charslot", "attributes": {}}, {"id": 112, "prop": "Decision", "attributes": {"options": "……你……", "values": "1"}, "targetLine": {"option1": "line113"}}, {"id": 113, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 114, "prop": "name", "attributes": {"content": "類似的場景、類似的話語，不同的情感與不同的時代在你記憶的空洞裡架起了橋梁。"}}, {"id": 115, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1"}}, {"id": 116, "prop": "name", "attributes": {"content": "……", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 117, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#6$1"}}, {"id": 118, "prop": "name", "attributes": {"content": "你……想起了什麼？", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#6$1"}, {"id": 119, "prop": "dialog", "attributes": {}}, {"id": 120, "prop": "PlaySound", "attributes": {"key": "$d_avg_humanchange", "volume": 1.0}}, {"id": 121, "prop":