style": "horiz_expand_center", "fadetime": 0.0, "offsetx": 300.0, "width": 200.0, "block": "true"}}, {"id": 17, "prop": "name", "attributes": {"content": "抓穩扶好，各位，我們又要過坡道啦。", "name": "W"}}, {"id": 18, "prop": "Dialog", "attributes": {}}, {"id": 19, "prop": "CharacterCutin", "attributes": {"widgetID": "1", "fadetime": 0.3, "block": "false"}}, {"id": 20, "prop": "CharacterCutin", "attributes": {"widgetID": "2", "fadetime": 0.3, "block": "false"}}, {"id": 21, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 22, "prop": "playsound", "attributes": {"key": "$d_avg_carjolt", "volume": 0.8}}, {"id": 23, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 24, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 25, "prop": "Dialog", "attributes": {}}, {"id": 26, "prop": "CharacterCutin", "attributes": {"widgetID": "1", "name": "char_147_shining_1", "style": "cutin", "fadestyle": "horiz_expand_center", "fadetime": 0.5, "width": 200.0, "block": "true"}}, {"id": 27, "prop": "name", "attributes": {"content": "這種顛簸可能並不有利於凱爾希的恢復。", "name": "閃靈"}}, {"id": 28, "prop": "Dialog", "attributes": {}}, {"id": 29, "prop": "CharacterCutin", "attributes": {"widgetID": "2", "name": "avg_npc_412_1#1$1", "style": "cutin", "fadestyle": "horiz_expand_center", "fadetime": 0.5, "offsetx": 300.0, "width": 200.0, "block": "true"}}, {"id": 30, "prop": "name", "attributes": {"content": "那又怎樣，特雷西斯沒砍死她，這一點小小的顛簸難道還會要了她的命？", "name": "W"}}, {"id": 31, "prop": "name", "attributes": {"content": "哇喔，這裡的路況真差，我們得穿過這片彈坑。", "name": "W"}}, {"id": 32, "prop": "name", "attributes": {"content": "你可以繞開。", "name": "閃靈"}}, {"id": 33, "prop": "CharacterCutin", "attributes": {"widgetID": "2", "name": "avg_npc_412_1#2$1", "style": "cutin", "fadestyle": "horiz_expand_center", "fadetime": 0.0, "offsetx": 300.0, "width": 200.0, "block": "true"}}, {"id": 34, "prop": "name", "attributes": {"content": "太晚了，我已經開進去了。", "name": "W"}}, {"id": 35, "prop": "Dialog", "attributes": {}}, {"id": 36, "prop": "CharacterCutin", "attributes": {"widgetID": "1", "fadetime": 0.2, "block": "false"}}, {"id": 37, "prop": "CharacterCutin", "attributes": {"widgetID": "2", "fadetime": 0.2, "block": "false"}}, {"id": 38, "prop": "delay", "attributes": {"time": 0.3}}, {"id": 39, "prop": "PlaySound", "attributes": {"key": "$drift", "volume": 0.6}}, {"id": 40, "prop": "playsound", "attributes": {"key": "$d_avg_carjolt", "volume": 0.8, "delay": 0.4}}, {"id": 41, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 40.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 42, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 43, "prop": "Dialog", "attributes": {}}, {"id": 44, "prop": "PlaySound", "attributes": {"key": "$p_skill_Mon3trburst", "volume": 0.4}}, {"id": 45, "prop": "name", "attributes": {"content": "（威脅的低吼）", "name": "Mon3tr"}}, {"id": 46, "prop": "Dialog", "attributes": {}}, {"id": 47, "prop": "CharacterCutin", "attributes": {"widgetID": "2", "name": "avg_npc_412_1#8$1", "style": "cutin", "fadestyle": "horiz_expand_center", "fadetime": 0.5, "offsetx": 300.0, "width": 200.0, "block": "true"}}, {"id": 48, "prop": "name", "attributes": {"content": "行了，凱爾希的小寵物，把你的爪子從我身上挪開。", "name": "W"}}, {"id": 49, "prop": "CharacterCutin", "attributes": {"widgetID": "2", "name": "avg_npc_412_1#7$1", "style": "cutin", "fadestyle": "horiz_expand_center", "fadetime": 0.0, "offsetx": 300.0, "width": 200.0, "block": "true"}}, {"id": 50, "prop": "name", "attributes": {"content": "或者你可以滾下車，拖著你的可憐主人跟著我們，你自己選。", "name": "W"}}, {"id": 51, "prop": "playsound", "attributes": {"key": "$Mon3tr_n"}}, {"id": 52, "prop": "name", "attributes": {"content": "（高昂的嘶鳴）", "name": "Mon3tr"}}, {"id": 53, "prop": "CharacterCutin", "attributes": {"widgetID": "2", "name": "avg_npc_412_1#10$1", "style": "cutin", "fadestyle": "horiz_expand_center", "fadetime": 0.0, "offsetx": 300.0, "width": 200.0, "block": "true"}}, {"id": 54, "prop": "name", "attributes": {"content": "你的那個金屬腦殼裡在琢磨什麼小計劃？你可以試試，我樂意奉陪。", "name": "W"}}, {"id": 55, "prop": "name", "attributes": {"content": "或者，我該直接把你丟到車輪子底下鋪路。", "name": "W"}}, {"id": 56, "prop": "Dialog", "attributes": {}}, {"id": 57, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 58, "prop": "CharacterCutin", "attributes": {"widgetID": "1", "name": "char_147_shining_1", "style": "cutin", "fadestyle": "horiz_expand_center", "fadetime": 0.2, "width": 200.0, "block": "true"}}, {"id": 59, "prop": "name", "attributes": {"content": "W，趕路要緊。", "name": "閃靈"}}, {"id": 60, "prop": "CharacterCutin", "attributes": {"widgetID": "2", "name": "avg_npc_412_1#14$1", "style": "cutin", "fadestyle": "horiz_expand_center", "fadetime": 0.0, "offsetx": 300.0, "width": 200.0, "block": "true"}}, {"id": 61, "prop": "name", "attributes": {"content": "現在這女人的嘴裡可是一個字都吐不出來，瞧她那小寵物急得要死，又畏畏縮縮的樣子！我這輩子還沒心情這麼好過！", "name": "W"}}, {"id": 62, "prop": "name", "attributes": {"content": "你就不想報復報復自己的上司嗎？在醫療部呼風喚雨的凱爾希，如今落得個這副下場啦！", "name": "W"}}, {"id": 63, "prop": "name", "attributes": {"content": "現在她是我的病人。", "name": "閃靈"}}, {"id": 64, "prop": "CharacterCutin", "attributes": {"widgetID": "2", "name": "avg_npc_412_1#8$1", "style": "cutin", "fadestyle": "horiz_expand_center", "fadetime": 0.0, "offsetx": 300.0, "width": 200.0, "block": "true"}}, {"id": 65, "prop": "name", "attributes": {"content": "嘖，你還是和以前一樣無聊。", "name": "W"}}, {"id": 66, "prop": "name", "attributes": {"content": "告訴可露希爾那幫人，按照我們走的路線跟上來，大公爵和薩卡茲打得熱火朝天，也就我知道哪裡還有口子了。", "name": "W"}}, {"id": 67, "prop": "name", "attributes": {"content": "你很熟悉這一帶的地形和情況。", "name": "閃靈"}}, {"id": 68, "prop": "CharacterCutin", "attributes": {"widgetID": "2", "name": "avg_npc_412_1#1$1", "style": "cutin", "fadestyle": "horiz_expand_center", "fadetime": 0.0, "offsetx": 300.0, "width": 200.0, "block": "true"}}, {"id": 69, "prop": "name", "attributes": {"content": "你以為這幾年我是怎麼活下來的？靠在倫蒂尼姆的下水道裡游泳嗎？", "name": "W"}}, {"id": 70, "prop": "name", "attributes": {"content": "傭兵向來用傭兵的辦法。", "name": "W"}}, {"id": 71, "prop": "name", "attributes": {"content": "穿過這一片廢墟，就到了我們的目的地了。", "name": "W"}}, {"id": 72, "prop": "name", "attributes": {"content": "她已經在那裡了嗎？", "name": "閃靈"}}, {"id": 73, "prop": "CharacterCutin", "attributes": {"widgetID": "2", "name": "avg_npc_412_1#7$1", "style": "cutin", "fadestyle": "horiz_expand_center", "fadetime": 0.0, "offsetx": 300.0, "width": 200.0, "block": "true"}}, {"id": 74, "prop": "name", "attributes": {"content": "當然，我可不會放過讓別人欠我人情的機會。", "name": "W"}}, {"id": 75, "prop": "name", "attributes": {"content": "不過，搬輪椅要另外收費，你多欠我一次。", "name": "W"}}, {"id": 76, "prop": "name", "attributes": {"content": "......好。", "name": "閃靈"}}, {"id": 77, "prop": "CharacterCutin", "attributes": {"widgetID": "2", "name": "avg_npc_412_1#4$1", "style": "cutin", "fadestyle": "horiz_expand_center", "fadetime": 0.0, "offsetx": 300.0, "width": 200.0, "block": "true"}}, {"id": 78, "prop": "name", "attributes": {"content": "說起來，你和那女的什麼關係？把殘疾人拖進倫蒂尼姆可不是個好主意。", "name": "W"}}, {"id": 79, "prop": "name", "attributes": {"content": "她是我的......", "name": "閃靈"}}, {"id": 80, "prop": "name", "attributes": {"content": "不，我是她的罪惡。", "name": "閃靈"}}, {"id": 81, "prop": "Dialog", "attributes": {}}, {"id": 82, "prop": "musicvolume", "attributes": {"volume": 0.3, "fadetime": 2.0}}, {"id": 83, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 84, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 85, "prop": "CharacterCutin", "attributes": {"widgetID": "1", "fadetime": 0.0, "block": "false"}}, {"id": 86, "prop": "CharacterCutin", "attributes": {"widgetID": "2", "fadetime": 0.0, "block": "false"}}, {"id": 87, "prop": "StopSound", "attributes": {"channel": "dr", "fadetime": 1.0}}, {"id": 88, "prop": "charslot", "attributes": {}}, {"id": 89, "prop": "Background", "attributes": {"image": "37_g1_glasgowboxinggym", "screenadapt": "coverall", "block": "true"}}, {"id": 90, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 91, "prop": "musicvolume", "attributes": {"volume": 0.6, "fadetime": 1.0}}, {"id": 92, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 93, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 94, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_394_1#18$1", "focus": "m"}}, {"id": 95, "prop": "name", "attributes": {"content": "......一座通訊站？", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#18$1"}, {"id": 96, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_866_1#1$1", "focus": "m"}}, {"id": 97, "prop": "name", "attributes": {"content": "我們需要把我們的存在廣播出去。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#1$1"}, {"id": 98, "prop": "Dialog", "attributes": {}}, {"id": 99, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_866_1#1$1", "focus": "none"}}, {"id": 100, "prop": "Decision", "attributes": {"options": "這是一次邀請。", "values": "1"}, "targetLine": {"option1": "line101"}}, {"id": 101, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 102, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_866_1#9$1", "focus": "m"}}, {"id": 103, "prop": "name", "attributes": {"content": "您很敏銳，羅德島的博士。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#9$1"}, {"id": 104, "prop": "Dialog", "attributes": {}}, {"id": 105, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_866_1#9$1", "focus": "none"}}, {"id": 106, "prop": "Decision", "attributes": {"options": "大公爵們需要知道這一點。", "values": "1"}, "targetLine": {"option1": "line107"}}, {"id": 107, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 108, "prop": "Decision", "attributes": {"options": "如果有人不行動，這就是其他大公爵指責他們的把柄。", "values": "1"}, "targetLine": {"option1": "line109"}}, {"id": 109, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 110, "prop": "Decision", "attributes": {"options": "在王冠空懸的此刻，誰都不會想給競爭對手留下話柄。", "values": "1"}, "targetLine": {"option1": "line111"}}, {"id": 111, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 112, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_866_1#9$1", "focus": "m"}}, {"id": 113, "prop": "name", "attributes": {"content": "您比我想像的還要瞭解維多利亞。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#9$1"}, {"id": 114, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4087_ines_1#14$1", "focus": "m"}}, {"id": 115, "prop": "name", "attributes": {"content": "哪裡能找到通訊站？", "name": "伊內絲"}, "figure_art": "avg_4087_ines_1#14$1"}, {"id": 116, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_866_1#1$1", "focus": "m"}}, {"id": 117, "prop": "name", "attributes": {"content": "這座地塊的訊號中樞在一開始就被薩卡茲摧毀了，但我知道，還有一處小型通訊站也許可以使用。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#1$1"}, {"id": 118, "prop": "name", "attributes": {"content": "它在一家酒店裡。這家酒店在諾伯特區衰落之前，是倫蒂尼姆最好的住處之一。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#1$1"}, {"id": 119, "prop": "name", "attributes": {"content": "為了滿足各個國家旅客的要求，他們給酒店裝上了一台功率十分強勁的訊號收發裝置。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#1$1"}, {"id": 120, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_866_1#8$1", "focus": "m"}}, {"id": 121, "prop": "name", "attributes": {"content": "那裡現在從外面看已經被落石堵死了，但如果我們能找到進去的路，並且使用那裡殘存的設備，應該......", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#8$1"}, {"id": 122, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4087_ines_1#1$1", "focus": "m"}}, {"id": 123, "prop": "name", "attributes": {"content": "這會是個十分危險的行動，按你剛剛的描述，就算那座可憐的通訊站依然可以運行，恐怕發出的訊號也無法實現加密。", "name": "伊內絲"}, "figure_art": "avg_4087_ines_1#1$1"}, {"id": 124, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_866_1#1$1", "focus": "m"}}, {"id": 125, "prop": "name", "attributes": {"content": "沒錯，那是個老舊的民用型號。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#1$1"}, {"id": 126, "prop": "name", "attributes": {"content": "無論是誰，都能馬上知道我們想說的是什麼。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#1$1"}, {"id": 127, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4087_ines_1#1$1", "focus": "m"}}, {"id": 128, "prop": "name", "attributes": {"content": "薩卡茲們也會馬上行動起來。", "name": "伊內絲"}, "figure_art": "avg_4087_ines_1#1$1"}, {"id": 129, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_866_1#1$1", "focus": "m"}}, {"id": 130, "prop": "name", "attributes": {"content": "我們只能賭那些公爵們不想背上坐視一場屠殺發生的惡名。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#1$1"}, {"id": 131, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_866_1#8$1", "focus": "m"}}, {"id": 132, "prop": "name", "attributes": {"content": "並且，我相信......會有大公爵挺身而出的，終究他們也不想看到一個淪為廢墟的維多利亞。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#8$1"}, {"id": 133, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4087_ines_1#3$1", "focus": "m"}}, {"id": 134, "prop": "name", "attributes": {"content": "比如那位溫德米爾公爵？", "name": "伊內絲"}, "figure_art": "avg_4087_ines_1#3$1"}, {"id": 135, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_866_1#5$1", "focus": "m"}}, {"id": 136, "prop": "name", "attributes": {"content": "......", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#5$1"}, {"id": 137, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_866_1#1$1", "focus": "m"}}, {"id": 138, "prop": "name", "attributes": {"content": "也許她會是其中之一。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#1$1"}, {"id": 139, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4087_ines_1#4$1", "focus": "m"}}, {"id": 140, "prop": "name", "attributes": {"content": "很有意思，看來你確實看了很多報紙，戴菲恩。", "name": "伊內絲"}, "figure_art": "avg_4087_ines_1#4$1"}, {"id": 141, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4087_ines_1#1$1", "focus": "m"}}, {"id": 142, "prop": "name", "attributes": {"content": "博士，阿米婭，我認為這個計劃確實有可行之處，我們需要一點混亂來打破僵局。", "name": "伊內絲"}, "figure_art": "avg_4087_ines_1#1$1"}, {"id": 143, "prop": "name", "attributes": {"content": "無論是引出那艘不知道藏在哪裡的飛空艇，還是給撤離被拋出的地塊上的人提供機會，一位或幾位大公爵的進攻都能成為我們的掩護。", "name": "伊內絲"}, "figure_art": "avg_4087_ines_1#1$1"}, {"id": 144, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_112_siege_1#1$1", "focus": "m"}}, {"id": 145, "prop": "name", "attributes": {"content": "那麼，在此之前，我們就需要停止這片封鎖區中毫無意義的互相爭搶、互相殺戮。", "name": "推進之王"}, "figure_art": "avgnew_112_siege_1#1$1"}, {"id": 146, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_394_1#19$1", "focus": "m"}}, {"id": 147, "prop": "name", "attributes": {"content": "我們必須得給他們一個重新團結在一起的理由。", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#19$1"}, {"id": 148, "prop": "Dialog", "attributes": {}}, {"id": 149, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_394_1#19$1", "focus": "none"}}, {"id": 150, "prop": "Decision", "attributes": {"options": "比如，讓每個人都知道希望的存在。", "values": "1"}, "targetLine": {"option1": "line151"}}, {"id": 151, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 152, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_394_1#21$1", "focus": "m"}}, {"id": 153, "prop": "name", "attributes": {"content": "是的。", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#21$1"}, {"id": 154, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_394_1#17$1", "focus": "m"}}, {"id": 155, "prop": "name", "attributes": {"content": "如果我們能更進一步，讓封鎖區裡剩下的物資能夠更好地分配給有需要的人......也許我們堅持的時間還能更長。", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#17$1"}, {"id": 156, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_394_1#19$1", "focus": "m"}}, {"id": 157, "prop": "name", "attributes": {"content": "正如您之前說的，重新建立起已經崩塌的信任。", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#19$1"}, {"id": 158, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4087_ines_1#4$1", "focus": "m"}}, {"id": 159, "prop": "name", "attributes": {"content": "哼，不管是真是假，希望總歸是希望。", "name": "伊內絲"}, "figure_art": "avg_4087_ines_1#4$1"}, {"id": 160, "prop": "Dialog", "attributes": {}}, {"id": 161, "prop": "charslot", "attributes": {}}, {"id": 162, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_866_1#7$1", "focus": "r"}}, {"id": 163, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_862_1#12$1", "focus": "r"}}, {"id": 164, "prop": "name", "attributes": {"content": "所以，這就是各位的天才計劃，去那老酒店找到個老通訊站，然後告訴外面的那幫公爵我們在這裡生不如死，求他們救救我們？", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#12$1"}, {"id": 165, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_862_1#6$1", "focus": "r"}}, {"id": 166, "prop": "name", "attributes": {"content": "太精彩了，我簡直要為你們鼓掌。", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#6$1"}, {"id": 167, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_866_1#7$1", "focus": "l"}}, {"id": 168, "prop": "name", "attributes": {"content": "如果你有什麼好主意，可以大大方方說出來，卡鐸爾。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#7$1"}, {"id": 169, "prop": "name", "attributes": {"content": "除了沖倒薩卡茲的封鎖牆之外。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#7$1"}, {"id": 170, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_862_1#6$1", "focus": "r"}}, {"id": 171, "prop": "name", "attributes": {"content": "我只是沒有想到，在成為小偷和騙子之後，我們終究要向那幫讓人噁心的大人物搖尾乞憐了。", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#6$1"}, {"id": 172, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_866_1#1$1", "focus": "l"}}, {"id": 173, "prop": "name", "attributes": {"content": "如果你不喜歡稱這次行動為一次求援，你也可以認為這是一次博弈。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#1$1"}, {"id": 174, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_862_1#10$1", "focus": "r"}}, {"id": 175, "prop": "name", "attributes": {"content": "看看，多高級的詞啊，“博弈”！我們居然能有和那幫藏在城堡裡的人博弈的機會！", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#10$1"}, {"id": 176, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_866_1#7$1", "focus": "l"}}, {"id": 177, "prop": "name", "attributes": {"content": "你也可以繼續選擇去街上搶人，我不攔著你。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#7$1"}, {"id": 178, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_862_1#7$1", "focus": "r"}}, {"id": 179, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 5.0, "ystrength": 10.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 180, "prop": "name", "attributes": {"content": "這是兩碼事！", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#7$1"}, {"id": 181, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_866_1#1$1", "focus": "l"}}, {"id": 182, "prop": "name", "attributes": {"content": "卡鐸爾，我知道你很在乎你的那些“尊嚴”，但眼下不是說這些的時候。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#1$1"}, {"id": 183, "prop": "name", "attributes": {"content": "如果大公爵的進攻能夠幫助我們，邀請他們就是個選擇。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#1$1"}, {"id": 184, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_862_1#8$1", "focus": "r"}}, {"id": 185, "prop": "name", "attributes": {"content": "那麼，你想過結果嗎？", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#8$1"}, {"id": 186, "prop": "name", "attributes": {"content": "大公爵們幫助了我們，多美好，然後呢？", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#8$1"}, {"id": 187, "prop": "name", "attributes": {"content": "登上他們的戰艦，向我們偉大的倫蒂尼姆進軍？還是成為他們的屬民，在開斯特或者威靈頓的工廠把自餵給那些車床？", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#8$1"}, {"id": 188, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_862_1#7$1", "focus": "r"}}, {"id": 189, "prop": "name", "attributes": {"content": "這*維多利亞粗口*不會是一次恩典，這只會是把我們的命賣給了那些貴族老爺！", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#7$1"}, {"id": 190, "prop": "name", "attributes": {"content": "從此，我們就再也不是諾伯特人，而是一幫任由他們揉捏的難民！", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#7$1"}, {"id": 191, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_866_1#3$1", "focus": "l"}}, {"id": 192, "prop": "name", "attributes": {"content": "難道我們現在不是嗎？！", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#3$1"}, {"id": 193, "prop": "name", "attributes": {"content": "卡鐸爾！難道現在我們就是什麼自由愜意的諾伯特人嗎？！", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#3$1"}, {"id": 194, "prop": "name", "attributes": {"content": "戰爭開始了！我們已經身在其中了！", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#3$1"}, {"id": 195, "prop": "name", "attributes": {"content": "你以為，按照你的那些想法，倘若真的有一位什麼天降英雄和你一起帶領諾伯特區的人，把外面的那些薩卡茲打得落花流水——", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#3$1"}, {"id": 196, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_866_1#6$1", "focus": "l"}}, {"id": 197, "prop": "name", "attributes": {"content": "原來的一切就能回來嗎？", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#6$1"}, {"id": 198, "prop": "name", "attributes": {"content": "“尊嚴”，看看我們吧！卡鐸爾！", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#6$1"}, {"id": 199, "prop": "name", "attributes": {"content": "我們都清楚......自己幹了什麼！", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#6$1"}, {"id": 200, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_862_1#2$1", "focus": "r"}}, {"id": 201, "prop": "name", "attributes": {"content": "......", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#2$1"}, {"id": 202, "prop": "name", "attributes": {"content": "我——", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#2$1"}, {"id": 203, "prop": "Dialog", "attributes": {}}, {"id": 204, "prop": "charslot", "attributes": {}}, {"id": 205, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 206, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 207, "prop": "PlaySound", "attributes": {"key": "$d_gen_explo_n"}}, {"id": 208, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 209, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 210, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 211, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 212, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.7, "block": "true"}}, {"id": 213, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 214, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_112_siege_1#7$1", "focus": "m"}}, {"id": 215, "prop": "name", "attributes": {"content": "該死，怎麼了！", "name": "推進之王"}, "figure_art": "avgnew_112_siege_1#7$1"}, {"id": 216, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#7$1", "focus": "m"}}, {"id": 217, "prop": "PlayMusic", "attributes": {"intro": "$exciting_intro", "key": "$exciting_loop", "volume": 0.6}}, {"id": 218, "prop": "name", "attributes": {"content": "街上！都拿起武器！", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#7$1"}, {"id": 219, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_863_1#10$1", "focus": "m"}}, {"id": 220, "prop": "name", "attributes": {"content": "先別急，我們得弄清楚——", "name": "貝爾德"}, "figure_art": "avg_npc_863_1#10$1"}, {"id": 221, "prop": "Dialog", "attributes": {}}, {"id": 222, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_863_1#10$1", "focus": "none"}}, {"id": 223, "prop": "playsound", "attributes": {"key": "$d_avg_explosion_stone", "volume": 1.0}}, {"id": 224, "prop": "PlaySound", "attributes": {"key": "$d_sp_ballista", "volume": 0.9, "delay": 0.5}}, {"id": 225, "prop": "CameraShake", "attributes": {"duration": 2.0, "xstrength": 50.0, "ystrength": 50.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 226, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 227, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 228, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 229, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 230, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 1.0, "block": "true"}}, {"id": 231, "prop": "delay", "attributes": {"time": 0.8}}, {"id": 232, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_863_1#7$1", "focus": "m"}}, {"id": 233, "prop": "name", "attributes": {"content": "他們是不想活命了嗎？誰還有力氣去打一場這麼激烈的架？", "name": "貝爾德"}, "figure_art": "avg_npc_863_1#7$1"}, {"id": 234, "prop": "name", "attributes": {"content": "現在每個躲在封鎖區裡的小集團應該都和我們一樣，物資告急了才對——", "name": "貝爾德"}, "figure_art": "avg_npc_863_1#7$1"}, {"id": 235, "prop": "Dialog", "attributes": {}}, {"id": 236, "prop": "charslot", "attributes": {}}, {"id": 237, "prop": "playsound", "attributes": {"key": "$d_avg_collapse", "volume": 0.6}}, {"id": 238, "prop": "playsound", "attributes": {"key": "$d_avg_armycrowd", "loop": "true", "channel": "b", "volume": 0.4}}, {"id": 239, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 240, "prop": "StopSound", "attributes": {"channel": "b", "fadetime": 2.0}}, {"id": 241, "prop": "name", "attributes": {"content": "透過被釘上的窗戶，只能看到還未消散的煙塵。"}}, {"id": 242, "prop": "name", "attributes": {"content": "然後就是吼叫與咒駡，還有哭泣與求饒。在這些日子裡，他們已經不得不習慣對它們充耳不聞，熟視無睹。"}}, {"id": 243, "prop": "name", "attributes": {"content": "然而這次，它不再是在暗巷中短暫炸響，不再伴隨著忐忑或猶豫，遮掩或偽裝。"}}, {"id": 244, "prop": "name", "attributes": {"content": "煙塵中，一輛行李車正在街道上緩緩滑動，它或許曾經屬於某家酒店，用來搬運遠道而來的客人們攜帶的大小提箱。"}}, {"id": 245, "prop": "name", "attributes": {"content": "如今，它卻被爆炸的餘波推出煙塵，它成了這一刻所有人目光聚集的焦點，所有人熾烈的渴望。"}}, {"id": 246, "prop": "name", "attributes": {"content": "那輛行李車上，竟載滿了物資。一箱箱罐頭，乾淨的水，粗糙而甜美的乾糧......"}}, {"id": 247, "prop": "Dialog", "attributes": {}}, {"id": 248, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_863_1#4$1", "focus": "m"}}, {"id": 249, "prop": "name", "attributes": {"content": "那是......", "name": "貝爾德"}, "figure_art": "avg_npc_863_1#4$1"}, {"id": 250, "prop": "Dialog", "attributes": {}}, {"id": 251, "prop": "charslot", "attributes": {}}, {"id": 252, "prop": "name", "attributes": {"content": "她的聲音含混不清，她察覺到自己......無法移開眼睛。"}}, {"id": 253, "prop": "Dialog", "attributes": {}}, {"id": 254, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 255, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 256, "prop": "charslot", "attributes": {}}, {"id": 257, "prop": "Background", "attributes": {"image": "37_g3_fogblockadestreet_d", "screenadapt": "coverall", "block": "true"}}, {"id": 258, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_416_1#1$1"}}, {"id": 259, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_417_1#1$1"}}, {"id": 260, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 261, "prop": "PlaySound", "attributes": {"key": "$d_avg_battlefield_environment", "volume": 0.4, "loop": "true", "channel": "arg"}}, {"id": 262, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 263, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 264, "prop": "PlaySound", "attributes": {"key": "$d_avg_punch", "volume": 0.8}}, {"id": 265, "prop": "PlaySound", "attributes": {"key": "$fightgeneral", "volume": 0.6, "delay": 0.2}}, {"id": 266, "prop": "CameraShake", "attributes": {"duration": 0.8, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 267, "prop": "charslot", "attributes": {"slot": "l", "action": "jump", "posfrom": "0,0", "posto": "100,0", "power": 0.0, "times": 1.0, "afrom": 1.0, "ato": 1.0, "duration": 0.1}}, {"id": 268, "prop": "charslot", "attributes": {"slot": "r", "action": "jump", "posfrom": "0,0", "posto": "-100,0", "power": 0.0, "times": 1.0, "afrom": 1.0, "ato": 1.0, "duration": 0.2, "isblock": "true"}}, {"id": 269, "prop": "delay", "attributes": {"time": 0.1}}, {"id": 270, "prop": "charslot", "attributes": {"slot": "l", "action": "jump", "posfrom": "100,0", "posto": "-10,0", "power": 5.0, "times": 1.0, "afrom": 1.0, "ato": 1.0, "duration": 0.2}}, {"id": 271, "prop": "charslot", "attributes": {"slot": "r", "action": "jump", "posfrom": "-100,0", "posto": "30,0", "power": 10.0, "times": 2.0, "afrom": 1.0, "ato": 1.0, "duration": 0.3, "isblock": "false"}}, {"id": 272, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 273, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_416_1#1$1", "focus": "l"}}, {"id": 274, "prop": "name", "attributes": {"content": "我......我需要這些食物，給我滾開！", "name": "絕望的暴徒"}, "figure_art": "avg_npc_416_1#1$1"}, {"id": 275, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_417_1#1$1", "focus": "r"}}, {"id": 276, "prop": "name", "attributes": {"content": "該躲開的是你，該死的，我不想找你的麻煩，你吃不了那麼多！", "name": "激動的暴徒"}, "figure_art": "avg_npc_417_1#1$1"}, {"id": 277, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_416_1#1$1", "focus": "l"}}, {"id": 278, "prop": "name", "attributes": {"content": "你可以分我一點，哪怕是幾塊麵包都足夠了......", "name": "絕望的暴徒"}, "figure_art": "avg_npc_416_1#1$1"}, {"id": 279, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_417_1#1$1", "focus": "r"}}, {"id": 280, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 12.0, "ystrength": 15.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 281, "prop": "name", "attributes": {"content": "先把你的手從那堆東西上放下來！", "name": "激動的暴徒"}, "figure_art": "avg_npc_417_1#1$1"}, {"id": 282, "prop": "Dialog", "attributes": {}}, {"id": 283, "prop": "charslot", "attributes": {}}, {"id": 284, "prop": "name", "attributes": {"content": "人群在爭吵著，撕扯著，行李車從一群人的手中被爭搶到另一群人手中。"}}, {"id": 285, "prop": "name", "attributes": {"content": "人們倒下，再度爬起，撲向那堆積如山的希望，期冀於從中攫取到自己的那一份。"}}, {"id": 286, "prop": "name", "attributes": {"content": "卻往往無人遂願。"}}, {"id": 287, "prop": "Dialog", "attributes": {}}, {"id": 288, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#7$1", "focus": "m"}}, {"id": 289, "prop": "name", "attributes": {"content": "*維多利亞粗口*，這些東西是從哪裡來的？！", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#7$1"}, {"id": 290, "prop": "name", "attributes": {"content": "再過上半個鐘頭，他們能把自己人都殺光！", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#7$1"}, {"id": 291, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 12.0, "ystrength": 15.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 292, "prop": "name", "attributes": {"content": "喂，停下，停下！", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#7$1"}, {"id": 293, "prop": "Dialog", "attributes": {}}, {"id": 294, "prop": "charslot", "attributes": {}}, {"id": 295, "prop": "PlaySound", "attributes": {"key": "$d_avg_arrowshot"}}, {"id": 296, "prop": "PlaySound", "attributes": {"key": "$e_atk_arrow_h", "volume": 1.0, "delay": 0.2}}, {"id": 297, "prop": "delay", "attributes": {"time": 0.2}}, {"id": 298, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 10.0, "ystrength": 12.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 299, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 300, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 301, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 302, "prop": "delay", "attributes": {"time": 0.2}}, {"id": 303, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_863_1#7$2", "focus": "m"}}, {"id