", "focus": "m"}}, {"id": 324, "prop": "name", "attributes": {"content": "推進之王！", "name": "貝爾德"}, "figure_art": "avg_npc_863_1#4$2"}, {"id": 325, "prop": "Dialog", "attributes": {}}, {"id": 326, "prop": "charslot", "attributes": {}}, {"id": 327, "prop": "PlaySound", "attributes": {"key": "$d_avg_twohandedblunt"}}, {"id": 328, "prop": "PlaySound", "attributes": {"key": "$d_avg_axeimp", "delay": 0.3}}, {"id": 329, "prop": "PlaySound", "attributes": {"key": "$p_imp_axe_h", "delay": 0.3}}, {"id": 330, "prop": "PlaySound", "attributes": {"key": "$e_imp_rock1_n", "delay": 0.5}}, {"id": 331, "prop": "CameraShake", "attributes": {"duration": 1.5, "xstrength": 40.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 332, "prop": "Blocker", "attributes": {"a": 0.3, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 0.1, "block": "true"}}, {"id": 333, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.1, "block": "true"}}, {"id": 334, "prop": "Blocker", "attributes": {"a": 0.7, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 0.1, "block": "true"}}, {"id": 335, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 336, "prop": "StopSound", "attributes": {"channel": "arg", "fadetime": 1.0}}, {"id": 337, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 338, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_112_siege_1#10$2", "duration": 1.0}}, {"id": 339, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 340, "prop": "musicvolume", "attributes": {"volume": 0.6, "fadetime": 1.5}}, {"id": 341, "prop": "name", "attributes": {"content": "推進之王的錘子狠狠砸在地上，氣流蕩開了彌漫在街道上的煙塵與血腥。"}}, {"id": 342, "prop": "name", "attributes": {"content": "她看著眼前的這些人，這些人也都死死地盯著她。"}}, {"id": 343, "prop": "Dialog", "attributes": {}}, {"id": 344, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_417_1#1$1", "focus": "m"}}, {"id": 345, "prop": "name", "attributes": {"content": "推進之王......", "name": "激動的暴徒"}, "figure_art": "avg_npc_417_1#1$1"}, {"id": 346, "prop": "name", "attributes": {"content": "你為什麼會在這裡？你想幹什麼？", "name": "激動的暴徒"}, "figure_art": "avg_npc_417_1#1$1"}, {"id": 347, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_112_siege_1#1$2", "focus": "m"}}, {"id": 348, "prop": "name", "attributes": {"content": "我認得你，阿勒傑，你家的三個小子還好嗎？", "name": "推進之王"}, "figure_art": "avgnew_112_siege_1#1$2"}, {"id": 349, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_417_1#1$1", "focus": "m"}}, {"id": 350, "prop": "name", "attributes": {"content": "哈哈哈哈哈，還好嗎？", "name": "激動的暴徒"}, "figure_art": "avg_npc_417_1#1$1"}, {"id": 351, "prop": "name", "attributes": {"content": "見到他們就知道了，等你死後，或者等我死後。", "name": "激動的暴徒"}, "figure_art": "avg_npc_417_1#1$1"}, {"id": 352, "prop": "name", "attributes": {"content": "這是好事，他們解脫了，他們不用在這裡像畜生一樣搶食，他們死得純潔。", "name": "激動的暴徒"}, "figure_art": "avg_npc_417_1#1$1"}, {"id": 353, "prop": "name", "attributes": {"content": "你呢，推進之王？你打算行行好，送我去見他們嗎？", "name": "激動的暴徒"}, "figure_art": "avg_npc_417_1#1$1"}, {"id": 354, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_112_siege_1#12$2", "focus": "m"}}, {"id": 355, "prop": "name", "attributes": {"content": "我們不必如此，在這裡對自己的鄰居刀劍相向沒有意義。", "name": "推進之王"}, "figure_art": "avgnew_112_siege_1#12$2"}, {"id": 356, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_417_1#1$1", "focus": "m"}}, {"id": 357, "prop": "name", "attributes": {"content": "太有意義了。", "name": "激動的暴徒"}, "figure_art": "avg_npc_417_1#1$1"}, {"id": 358, "prop": "name", "attributes": {"content": "太有意義了，推進之王，一塊麵包就足以讓我活著度過今晚，如果運氣好，還有明晚。", "name": "激動的暴徒"}, "figure_art": "avg_npc_417_1#1$1"}, {"id": 359, "prop": "name", "attributes": {"content": "你不餓嗎？你不渴嗎？你還有工夫去想著做選擇嗎？", "name": "激動的暴徒"}, "figure_art": "avg_npc_417_1#1$1"}, {"id": 360, "prop": "name", "attributes": {"content": "那就說明你還沒有充分地被它折磨，你仍置身事外。", "name": "激動的暴徒"}, "figure_art": "avg_npc_417_1#1$1"}, {"id": 361, "prop": "name", "attributes": {"content": "給我個答案，推進之王，你想從我這裡搶走多少希望？", "name": "激動的暴徒"}, "figure_art": "avg_npc_417_1#1$1"}, {"id": 362, "prop": "name", "attributes": {"content": "以前我打不過你，但現在，我可以——", "name": "激動的暴徒"}, "figure_art": "avg_npc_417_1#1$1"}, {"id": 363, "prop": "Dialog", "attributes": {}}, {"id": 364, "prop": "PlaySound", "attributes": {"key": "$p_field_magloop", "channel": "2", "volume": 0.8}}, {"id": 365, "prop": "PlaySound", "attributes": {"key": "$p_skill_explocar_cast", "volume": 1.0, "delay": 0.3}}, {"id": 366, "prop": "stopsound", "attributes": {"channel": "2", "fadetime": 1.5}}, {"id": 367, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 368, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 10.0, "ystrength": 12.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 369, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 370, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.2, "block": "true"}}, {"id": 371, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.2, "block": "true"}}, {"id": 372, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.2, "block": "true"}}, {"id": 373, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.2, "block": "true"}}, {"id": 374, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.2, "block": "true"}}, {"id": 375, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.4, "block": "true"}}, {"id": 376, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 377, "prop": "name", "attributes": {"content": "嗚——呃啊——", "name": "激動的暴徒"}}, {"id": 378, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_394_1#20$1", "focus": "m"}}, {"id": 379, "prop": "name", "attributes": {"content": "不，停下！先生！", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#20$1"}, {"id": 380, "prop": "name", "attributes": {"content": "您不是在施術，您正在毀了自己的身體！這種對於源石技藝適應性的增長只是急性感染的病理性影響！", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#20$1"}, {"id": 381, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_394_1#7$1", "focus": "m"}}, {"id": 382, "prop": "name", "attributes": {"content": "我們可以幫助您，請停下吧！", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#7$1"}, {"id": 383, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_417_1#1$1", "focus": "m"}}, {"id": 384, "prop": "name", "attributes": {"content": "滾開，滾開！你們這些體面的好人，要不然藏回你們的屋子裡，要不然就加入這場爭奪！", "name": "激動的暴徒"}, "figure_art": "avg_npc_417_1#1$1"}, {"id": 385, "prop": "name", "attributes": {"content": "誰都想活下去，這是我所知的最可靠的方法。", "name": "激動的暴徒"}, "figure_art": "avg_npc_417_1#1$1"}, {"id": 386, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#7$1", "focus": "m"}}, {"id": 387, "prop": "name", "attributes": {"content": "該死，阿勒傑，你就那麼想讓我把你揍趴下嗎？！", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#7$1"}, {"id": 388, "prop": "name", "attributes": {"content": "那麼我就——", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#7$1"}, {"id": 389, "prop": "Dialog", "attributes": {}}, {"id": 390, "prop": "charslot", "attributes": {}}, {"id": 391, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 392, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_405_1#11$1", "focus": "m"}}, {"id": 393, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 10.0, "ystrength": 12.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 394, "prop": "name", "attributes": {"content": "行了，已經夠了！", "name": "摩根"}, "figure_art": "avg_npc_405_1#11$1"}, {"id": 395, "prop": "name", "attributes": {"content": "亞歷山德莉娜·維娜·維多利亞殿下在這裡！", "name": "摩根"}, "figure_art": "avg_npc_405_1#11$1"}, {"id": 396, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_112_siege_1#10$2", "focus": "m"}}, {"id": 397, "prop": "name", "attributes": {"content": "摩根！", "name": "推進之王"}, "figure_art": "avgnew_112_siege_1#10$2"}, {"id": 398, "prop": "playMusic", "attributes": {"intro": "$newhope01_intro", "key": "$newhope01_loop", "volume": 0.6}}, {"id": 399, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_405_1#11$1", "focus": "m"}}, {"id": 400, "prop": "name", "attributes": {"content": "阿斯蘭王的後裔，亞歷山德莉娜·維娜·維多利亞殿下，帶著諸王之息回來了！", "name": "摩根"}, "figure_art": "avg_npc_405_1#11$1"}, {"id": 401, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_416_1#1$1", "focus": "m"}}, {"id": 402, "prop": "name", "attributes": {"content": "維多利亞......推進之王，原來你姓維多利亞？！", "name": "絕望的暴徒"}, "figure_art": "avg_npc_416_1#1$1"}, {"id": 403, "prop": "name", "attributes": {"content": "那把劍......諸王之息？", "name": "絕望的暴徒"}, "figure_art": "avg_npc_416_1#1$1"}, {"id": 404, "prop": "name", "attributes": {"content": "可是......", "name": "絕望的暴徒"}, "figure_art": "avg_npc_416_1#1$1"}, {"id": 405, "prop": "name", "attributes": {"content": "我早就懷疑過......你不是普通的菲林。", "name": "絕望的暴徒"}, "figure_art": "avg_npc_416_1#1$1"}, {"id": 406, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_866_1#1$1", "focus": "m"}}, {"id": 407, "prop": "name", "attributes": {"content": "......", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#1$1"}, {"id": 408, "prop": "name", "attributes": {"content": "遵照殿下的要求，大公爵們的部隊已經在前往這裡的路上了。", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#1$1"}, {"id": 409, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_866_1#10$1", "focus": "m"}}, {"id": 410, "prop": "name", "attributes": {"content": "那幫薩卡茲攔不住他們，就算加上那艘船也不行！我們現在有救了！", "name": "戴菲恩"}, "figure_art": "avg_npc_866_1#10$1"}, {"id": 411, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_112_siege_1#5$2", "focus": "m"}}, {"id": 412, "prop": "name", "attributes": {"content": "戴菲恩，連你也......", "name": "推進之王"}, "figure_art": "avgnew_112_siege_1#5$2"}, {"id": 413, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#12$1", "focus": "m"}}, {"id": 414, "prop": "name", "attributes": {"content": "殿下？", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#12$1"}, {"id": 415, "prop": "name", "attributes": {"content": "推進之王......你*維多利亞粗口*是個王室？", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#12$1"}, {"id": 416, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_862_1#6$1", "focus": "m"}}, {"id": 417, "prop": "name", "attributes": {"content": "哈哈哈......", "name": "卡鐸爾"}, "figure_art": "avg_npc_862_1#6$1"}, {"id": 418, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_416_1#1$1", "focus": "m"}}, {"id": 419, "prop": "name", "attributes": {"content": "大公爵，他們終於——", "name": "絕望的暴徒"}, "figure_art": "avg_npc_416_1#1$1"}, {"id": 420, "prop": "name", "attributes": {"content": "推進之王......不，亞歷山德莉娜殿下，我得......", "name": "絕望的暴徒"}, "figure_art": "avg_npc_416_1#1$1"}, {"id": 421, "prop": "Dialog", "attributes": {}}, {"id": 422, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_416_1#1$1", "afrom": 1.0, "ato": 0.0, "duration": 0.2}}, {"id": 423, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 424, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_417_1#1$1", "focus": "m"}}, {"id": 425, "prop": "Delay", "attributes": {"time": 0.2}}, {"id": 426, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown1", "volume": 1.0}}, {"id": 427, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 428, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_417_1#1$1", "posfrom": "0,0", "posto": "0,-50", "duration": 1.0, "isblock": "false"}}, {"id": 429, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_417_1#1$1", "afrom": 1.0, "ato": 0.0, "duration": 0.5}}, {"id": 430, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 431, "prop": "charslot", "attributes": {}}, {"id": 432, "prop": "name", "attributes": {"content": "呃呃——", "name": "激動的暴徒"}, "figure_art": "avg_npc_417_1#1$1"}, {"id": 433, "prop": "charslot", "attributes": {"duration": 0.0}}, {"id": 434, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_394_1#7$1", "focus": "m"}}, {"id": 435, "prop": "name", "attributes": {"content": "......礦石病的急性症狀。", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#7$1"}, {"id": 436, "prop": "name", "attributes": {"content": "我馬上準備抑制劑注射，他的狀況很糟。", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#7$1"}, {"id": 437, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_405_1#5$1", "focus": "m"}}, {"id": 438, "prop": "name", "attributes": {"content": "看到了嗎，我們還有藥品！我們只需要再堅持一下——", "name": "摩根"}, "figure_art": "avg_npc_405_1#5$1"}, {"id": 439, "prop": "name", "attributes": {"content": "......真的，我們只需要再堅持一下。", "name": "摩根"}, "figure_art": "avg_npc_405_1#5$1"}, {"id": 440, "prop": "Dialog", "attributes": {}}, {"id": 441, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 442, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 443, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 444, "prop": "charslot", "attributes": {}}, {"id": 445, "prop": "Image", "attributes": {}}, {"id": 446, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}