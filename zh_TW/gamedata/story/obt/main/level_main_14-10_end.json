": 255.0, "fadetime": 0.03, "block": "true"}}, {"id": 56, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 57, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 58, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4133_logos_1#10$1", "duration": 1.5}}, {"id": 59, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 60, "prop": "name", "attributes": {"content": "……", "name": "Logos"}, "figure_art": "avg_4133_logos_1#10$1"}, {"id": 61, "prop": "Dialog", "attributes": {}}, {"id": 62, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown1", "volume": 1.0}}, {"id": 63, "prop": "charslot", "attributes": {"duration": 1.5}}, {"id": 64, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 65, "prop": "name", "attributes": {"content": "骨哨碎裂，骨筆已經折斷，他的唇角滲出縷縷血絲。"}}, {"id": 66, "prop": "PlayMusic", "attributes": {"intro": "$dignified_intro", "key": "$dignified_loop", "volume": 0.6}}, {"id": 67, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1339_1#1$1"}}, {"id": 68, "prop": "name", "attributes": {"content": "你已無法再施展任何咒術。", "name": "孽茨雷"}, "figure_art": "avg_npc_1339_1#1$1"}, {"id": 69, "prop": "name", "attributes": {"content": "你把自己逼到極限，點燃了全身的血，吹響這一聲骨哨……只為了攔住我一時半刻。", "name": "孽茨雷"}, "figure_art": "avg_npc_1339_1#1$1"}, {"id": 70, "prop": "name", "attributes": {"content": "哀琺尼爾……", "name": "孽茨雷"}, "figure_art": "avg_npc_1339_1#1$1"}, {"id": 71, "prop": "name", "attributes": {"content": "作為戰士，你合格了。", "name": "孽茨雷"}, "figure_art": "avg_npc_1339_1#1$1"}, {"id": 72, "prop": "Dialog", "attributes": {}}, {"id": 73, "prop": "charslot", "attributes": {}}, {"id": 74, "prop": "name", "attributes": {"content": "食腐者的王張開雙臂。"}}, {"id": 75, "prop": "name", "attributes": {"content": "披在他身上的破碎旗幟紛紛揚起，彷彿薩卡茲經歷過的無數戰爭再現。"}}, {"id": 76, "prop": "name", "attributes": {"content": "從他的新舊傷口處掉落的血與腐肉，正滋養著這片戰場。新的枝條破土而出，填補了受到咒文重創的戰士們的身軀。"}}, {"id": 77, "prop": "name", "attributes": {"content": "所有倒下的“靈幛”再度站了起來。"}}, {"id": 78, "prop": "Dialog", "attributes": {}}, {"id": 79, "prop": "playsound", "attributes": {"key": "$a_bat_buildingshaking_1", "volume": 1.0, "channel": "2"}}, {"id": 80, "prop": "playsound", "attributes": {"key": "$d_avg_darkwhisper", "volume": 1.0, "channel": "1"}}, {"id": 81, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1331_1#1$1", "duration": 1.5}}, {"id": 82, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1331_1#1$1", "duration": 1.5}}, {"id": 83, "prop": "CameraShake", "attributes": {"duration": 3.0, "xstrength": 10.0, "ystrength": 10.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 84, "prop": "Delay", "attributes": {"time": 3.5}}, {"id": 85, "prop": "charslot", "attributes": {}}, {"id": 86, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1339_1#1$1"}}, {"id": 87, "prop": "name", "attributes": {"content": "但你要對抗的，絕不是一個或者幾個具體的人。", "name": "孽茨雷"}, "figure_art": "avg_npc_1331_1#1$1"}, {"id": 88, "prop": "name", "attributes": {"content": "薩卡茲之中乃至王庭內部，都從來不缺變革者。他們終究失敗。就像當年的特蕾西婭。", "name": "孽茨雷"}, "figure_art": "avg_npc_1331_1#1$1"}, {"id": 89, "prop": "name", "attributes": {"content": "戰爭如巨石，而薩卡茲注定站在深淵中。石頭永遠會一次次落下。", "name": "孽茨雷"}, "figure_art": "avg_npc_1331_1#1$1"}, {"id": 90, "prop": "name", "attributes": {"content": "而你……", "name": "孽茨雷"}, "figure_art": "avg_npc_1331_1#1$1"}, {"id": 91, "prop": "name", "attributes": {"content": "你獲得了食腐者的敬意，接下來，由我來賜予你死亡。", "name": "孽茨雷"}, "figure_art": "avg_npc_1331_1#1$1"}, {"id": 92, "prop": "Dialog", "attributes": {}}, {"id": 93, "prop": "charslot", "attributes": {"duration": 1.5}}, {"id": 94, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 95, "prop": "name", "attributes": {"content": "食腐者踏著腐敗之霧，緩步走向年輕的女妖。"}}, {"id": 96, "prop": "Dialog", "attributes": {}}, {"id": 97, "prop": "bgeffect", "attributes": {"name": "$eb_dim_closeeye", "layer": 1.0}}, {"id": 98, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 99, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 100, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 101, "prop": "PlaySound", "attributes": {"key": "$d_avg_cnstrctnck", "volume": 1.0}}, {"id": 102, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1339_1#1$1", "posfrom": "0,-120", "posto": "0,-120"}}, {"id": 103, "prop": "charslot", "attributes": {"slot": "m", "action": "zoom", "poszoom": "0.5,0.65", "scale": 2.0, "focus": "all"}}, {"id": 104, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 105, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 106, "prop": "CameraShake", "attributes": {"duration": 2.5, "xstrength": 10.0, "ystrength": 10.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 107, "prop": "PlaySound", "attributes": {"key": "$d_avg_magicscreen", "volume": 1.0, "channel": "1"}}, {"id": 108, "prop": "Blocker", "attributes": {"a": 0.5, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.5, "block": "true"}}, {"id": 109, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 110, "prop": "bgeffect", "attributes": {}}, {"id": 111, "prop": "name", "attributes": {"content": "“斬斷”。", "name": "Logos"}}, {"id": 112, "prop": "Dialog", "attributes": {}}, {"id": 113, "prop": "Blocker", "attributes": {"a": 0.5, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 114, "prop": "PlaySound", "attributes": {"key": "$d_avg_magic_5", "volume": 1.0}}, {"id": 115, "prop": "Blocker", "attributes": {"a": 1.0, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 0.03, "block": "true"}}, {"id": 116, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 117, "prop": "name", "attributes": {"content": "女妖以幾乎微不可聞的聲音念出最後的咒言，鋒利的字詞，化為有形的利刃，他將利刃緊握在手——"}}, {"id": 118, "prop": "Dialog", "attributes": {}}, {"id": 119, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 120, "prop": "Effect", "attributes": {"name": "$e_bladeline_01_large", "y": 42.4, "rox": 8.6, "roz": 29.2, "layer": 1.0}}, {"id": 121, "prop": "CameraShake", "attributes": {"duration": 1.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 122, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.03, "block": "true"}}, {"id": 123, "prop": "PlaySound", "attributes": {"key": "$e_skill_skulsrsword", "volume": 1.0}}, {"id": 124, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 1.5, "block": "true"}}, {"id": 125, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 126, "prop": "name", "attributes": {"content": "斬下了食腐者之王的右臂。"}}, {"id": 127, "prop": "Dialog", "attributes": {}}, {"id": 128, "prop": "PlaySound", "attributes": {"key": "$d_avg_darkwhisper", "volume": 1.0}}, {"id": 129, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,-120", "posto": "0,0", "duration": 0.5}}, {"id": 130, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 131, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 132, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown1", "volume": 1.0, "channel": "1"}}, {"id": 133, "prop": "charslot", "attributes": {}}, {"id": 134, "prop": "name", "attributes": {"content": "竟然是……特雷西斯的劍術——", "name": "孽茨雷"}}, {"id": 135, "prop": "Dialog", "attributes": {}}, {"id": 136, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 137, "prop": "PlaySound", "attributes": {"key": "$d_avg_explosion_stone", "volume": 1.0, "channel": "1"}}, {"id": 138, "prop": "PlaySound", "attributes": {"key": "$d_avg_punch", "volume": 1.0, "channel": "2"}}, {"id": 139, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 140, "prop": "name", "attributes": {"content": "凝聚了食腐者之王全力的法術擊中了Logos的胸膛。"}}, {"id": 141, "prop": "name", "attributes": {"content": "他的身軀墜下山崖。"}}, {"id": 142, "prop": "Dialog", "attributes": {}}, {"id": 143, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 144, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 145, "prop": "PlaySound", "attributes": {"key": "$d_avg_jump_water", "volume": 1.0}}, {"id": 146, "prop": "Background", "attributes": {"image": "49_g12_diving", "screenadapt": "coverall"}}, {"id": 147, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 148, "prop": "PlaySound", "attributes": {"key": "$d_avg_underwateramb", "volume": 1.0, "loop": "true", "channel": "1"}}, {"id": 149, "prop": "BackgroundTween", "attributes": {"xScaleFrom": 1.3, "yScaleFrom": 1.3, "xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 50.0, "block": "false", "screenadapt": "coverall"}}, {"id": 150, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 151, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 152, "prop": "name", "attributes": {"content": "源石地面正轟隆隆地崩解。"}}, {"id": 153, "prop": "name", "attributes": {"content": "Logos想像著那艘熟悉的船碾過山巒與河岸，她的履帶也會發出類似的轟鳴。"}}, {"id": 154, "prop": "name", "attributes": {"content": "他想起自己第一次登上羅德島，特蕾西婭與他並肩站在甲板上。特蕾西婭注視著卡茲戴爾，而他仔細聽著風中傳來的嚎哭。"}}, {"id": 155, "prop": "name", "attributes": {"content": "他想起Mechanist弓著背擺弄零件，教訓可露希爾浪費材料。Outcast和煌打賭這場教訓會持續多長時間，被機械臂一把摘掉了帽子。"}}, {"id": 156, "prop": "name", "attributes": {"content": "他想起Ace沾血的手，放在盾牌上和酒杯旁。Scout的掌心還要更涼些，和他的弩溫度差不多，握起來和擊掌時不用看就能分辨。"}}, {"id": 157, "prop": "name", "attributes": {"content": "他想起博士和阿米婭在走廊上互道晚安，阿米婭突然叫住他，詢問他是否準備好了來倫蒂尼姆。"}}, {"id": 158, "prop": "name", "attributes": {"content": "他想起凱爾希醫生牽著阿米婭的手，來到他們中間——"}}, {"id": 159, "prop": "name", "attributes": {"content": "“特蕾西婭不在了。以後，阿米婭就是羅德島的領袖。”"}}, {"id": 160, "prop": "name", "attributes": {"content": "Logos不斷地下墜著——"}}, {"id": 161, "prop": "name", "attributes": {"content": "直到冰涼的水沒過頭頂。"}}, {"id": 162, "prop": "name", "attributes": {"content": "他想起許多年前的自己。"}}, {"id": 163, "prop": "Dialog", "attributes": {}}, {"id": 164, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 165, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 166, "prop": "stopsound", "attributes": {"channel": "1", "fadetime": 1.5}}, {"id": 167, "prop": "charslot", "attributes": {}}, {"id": 168, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 169, "prop": "bgEffect", "attributes": {"name": "$eb_sunlight_01", "layer": 1.0}}, {"id": 170, "prop": "image", "attributes": {"image": "50_i07", "screenadapt": "coverall", "xScale": 1.1, "yScale": 1.1, "y": 30.0}}, {"id": 171, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.1, "yScaleFrom": 1.1, "xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 30.0, "yTo": 0.0}}, {"id": 172, "prop": "PlayMusic", "attributes": {"key": "$calm_loop", "volume": 0.6}}, {"id": 173, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 174, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 175, "prop": "name", "attributes": {"content": "你已經想好了。", "name": "菈瑪蓮"}}, {"id": 176, "prop": "name", "attributes": {"content": "是的。", "name": "哀琺尼爾"}}, {"id": 177, "prop": "name", "attributes": {"content": "我會留在羅德島，與那艘船一起航行於大地。", "name": "哀琺尼爾"}}, {"id": 178, "prop": "name", "attributes": {"content": "特蕾西婭……不在了。", "name": "菈瑪蓮"}}, {"id": 179, "prop": "name", "attributes": {"content": "巴別塔的理想……", "name": "菈瑪蓮"}}, {"id": 180, "prop": "name", "attributes": {"content": "……依然在。", "name": "哀琺尼爾"}}, {"id": 181, "prop": "name", "attributes": {"content": "殿下已選定一位繼承人。她尚年幼，眼裡卻有著熟悉的屬於理想者的火焰。", "name": "哀琺尼爾"}}, {"id": 182, "prop": "name", "attributes": {"content": "而我留在羅德島，並非只為她一人。", "name": "哀琺尼爾"}}, {"id": 183, "prop": "name", "attributes": {"content": "殿下的探求與尋覓並沒有，也不該就此結束。既然關於薩卡茲未來的答案仍在別處，我便會不斷地踏上旅途。", "name": "哀琺尼爾"}}, {"id": 184, "prop": "name", "attributes": {"content": "這意味著，我可能有很長時間不會回到河谷。", "name": "哀琺尼爾"}}, {"id": 185, "prop": "name", "attributes": {"content": "你感到了歉疚……是因為無法留在我們身邊嗎？", "name": "菈瑪蓮"}}, {"id": 186, "prop": "name", "attributes": {"content": "在河谷之外，我並不會以王庭之主身分行事。", "name": "哀琺尼爾"}}, {"id": 187, "prop": "name", "attributes": {"content": "可仍會有許多人視我的意志為王庭的意志。他們可能會因此對女妖心懷敵意，而我……恐怕無法替你們擋下任何來自谷外的風雨。", "name": "哀琺尼爾"}}, {"id": 188, "prop": "name", "attributes": {"content": "如果有老朋友願意拜訪我，我一定會好好招待他們。", "name": "菈瑪蓮"}}, {"id": 189, "prop": "name", "attributes": {"content": "當然。我不會質疑女妖河谷曾經的主人……", "name": "哀琺尼爾"}}, {"id": 190, "prop": "name", "attributes": {"content": "我和姐妹們也同樣憂心著你。", "name": "菈瑪蓮"}}, {"id": 191, "prop": "name", "attributes": {"content": "……", "name": "哀琺尼爾"}}, {"id": 192, "prop": "name", "attributes": {"content": "所以，請帶走我們的思念吧。", "name": "菈瑪蓮"}}, {"id": 193, "prop": "Dialog", "attributes": {}}, {"id": 194, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 195, "prop": "Blocker", "attributes": {"a": 1.0, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 2.0, "block": "true"}}, {"id": 196, "prop": "charslot", "attributes": {}}, {"id": 197, "prop": "bgEffect", "attributes": {}}, {"id": 198, "prop": "Background", "attributes": {"image": "49_g12_diving", "screenadapt": "coverall"}}, {"id": 199, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 200, "prop": "image", "attributes": {}}, {"id": 201, "prop": "PlaySound", "attributes": {"key": "$d_avg_underwateramb", "volume": 1.0, "loop": "true", "channel": "1"}}, {"id": 202, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 203, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 204, "prop": "name", "attributes": {"content": "女妖的歌聲環繞著年輕的女妖之主。"}}, {"id": 205, "prop": "name", "attributes": {"content": "水流變得暖和了起來，如一雙雙手，溫柔地拉住了下墜的人。"}}, {"id": 206, "prop": "name", "attributes": {"content": "Logos睜開眼睛。"}}, {"id": 207, "prop": "name", "attributes": {"content": "他彷彿看到了母親，還有無數親人的身影。"}}, {"id": 208, "prop": "name", "attributes": {"content": "“哀琺尼爾，河谷最美的波光，最動人的歌聲……我們不得不留在原地，注視著你遠行……”"}}, {"id": 209, "prop": "name", "attributes": {"content": "“但無論你去往何方，我們的祝福都將陪伴著你。”"}}, {"id": 210, "prop": "name", "attributes": {"content": "……", "name": "Logos"}}, {"id": 211, "prop": "Dialog", "attributes": {}}, {"id": 212, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1334_1#1$1", "bstart": 0.3, "bend": 0.8, "duration": 1.5}}, {"id": 213, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 214, "prop": "name", "attributes": {"content": "哀琺尼爾，挺住。", "name": "？？？"}, "figure_art": "avg_npc_1334_1#1$1"}, {"id": 215, "prop": "name", "attributes": {"content": "我們就在你身邊……我們始終都在一起。", "name": "？？？"}, "figure_art": "avg_npc_1334_1#1$1"}, {"id": 216, "prop": "Dialog", "attributes": {}}, {"id": 217, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 218, "prop": "PlaySound", "attributes": {"key": "$d_avg_magic_2"}}, {"id": 219, "prop": "Blocker", "attributes": {"a": 0.4, "r": 1.0, "g": 1.0, "b": 0.0, "fadetime": 0.05, "block": "true"}}, {"id": 220, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 221, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 222, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 223, "prop": "PlaySound", "attributes": {"key": "$d_avg_magic_2"}}, {"id": 224, "prop": "Blocker", "attributes": {"a": 0.4, "r": 1.0, "g": 1.0, "b": 0.0, "fadetime": 0.05, "block": "true"}}, {"id": 225, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 226, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 227, "prop": "charslot", "attributes": {}}, {"id": 228, "prop": "name", "attributes": {"content": "咒文的力量緩緩注入Logos的四肢百骸。"}}, {"id": 229, "prop": "name", "attributes": {"content": "他再一次啟唇。"}}, {"id": 230, "prop": "name", "attributes": {"content": "飽含力量的歌聲迴盪在河面上，反射出最美麗的波光。"}}, {"id": 231, "prop": "name", "attributes": {"content": "所有的追擊者，都不得不停下了腳步。"}}, {"id": 232, "prop": "Dialog", "attributes": {}}, {"id": 233, "prop": "stopsound", "attributes": {"channel": "1", "fadetime": 1.5}}, {"id": 234, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 235, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 236, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 237, "prop": "charslot", "attributes": {}}, {"id": 238, "prop": "Background", "attributes": {"image": "50_g1_originiumcanyon", "screenadapt": "coverall"}}, {"id": 239, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 240, "prop": "PlayMusic", "attributes": {"intro": "$mist_intro", "key": "$mist_loop", "volume": 0.6}}, {"id": 241, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 242, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 243, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1339_1#1$1", "bstart": 0.3, "bend": 0.5}}, {"id": 244, "prop": "name", "attributes": {"content": "……", "name": "孽茨雷"}, "figure_art": "avg_npc_1339_1#1$1"}, {"id": 245, "prop": "name", "attributes": {"content": "沒想到，我會在這異國的峽谷中，聽到女妖齊聲歌唱。", "name": "孽茨雷"}, "figure_art": "avg_npc_1339_1#1$1"}, {"id": 246, "prop": "name", "attributes": {"content": "新生與死亡相伴……", "name": "孽茨雷"}, "figure_art": "avg_npc_1339_1#1$1"}, {"id": 247, "prop": "name", "attributes": {"content": "年輕人，到了最後，你還想用歌聲……勸告我嗎？", "name": "孽茨雷"}, "figure_art": "avg_npc_1339_1#1$1"}, {"id": 248, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1331_1#1$1"}}, {"id": 249, "prop": "name", "attributes": {"content": "宗長，只是女妖的咒言。", "name": "“靈幛”"}, "figure_art": "avg_npc_1331_1#1$1"}, {"id": 250, "prop": "name", "attributes": {"content": "她們並未真的參戰。我們的敵人，依然只是那個小女妖一人。", "name": "“靈幛”"}, "figure_art": "avg_npc_1331_1#1$1"}, {"id": 251, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1339_1#1$1", "bstart": 0.3, "bend": 0.5}}, {"id": 252, "prop": "name", "attributes": {"content": "……", "name": "孽茨雷"}, "figure_art": "avg_npc_1339_1#1$1"}, {"id": 253, "prop": "name", "attributes": {"content": "嗯……", "name": "孽茨雷"}, "figure_art": "avg_npc_1339_1#1$1"}, {"id": 254, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1331_1#1$1"}}, {"id": 255, "prop": "name", "attributes": {"content": "您的傷……竟這麼重。", "name": "“靈幛”"}, "figure_art": "avg_npc_1331_1#1$1"}, {"id": 256, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1339_1#1$1", "bstart": 0.3, "bend": 0.5}}, {"id": 257, "prop": "name", "attributes": {"content": "哀琺尼爾的詛咒，令腐朽的歸於腐朽。我暫時，無法恢復。但這副軀體……也足以支撐到打完這一仗了。", "name": "孽茨雷"}, "figure_art": "avg_npc_1339_1#1$1"}, {"id": 258, "prop": "name", "attributes": {"content": "至於現在……就讓我先聽完他和女妖們的歌聲吧。", "name": "孽茨雷"}, "figure_art": "avg_npc_1339_1#1$1"}, {"id": 259, "prop": "Dialog", "attributes": {}}, {"id": 260, "prop": "charslot", "attributes": {}}, {"id": 261, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 262, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 263, "prop": "name", "attributes": {"content": "沒有依靠任何法術飄浮，孽茨雷走到了懸崖邊。"}}, {"id": 264, "prop": "name", "attributes": {"content": "在這一刻，他格外像一個樣貌普通的老者。"}}, {"id": 265, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1339_1#1$1", "bstart": 0.3, "bend": 0.5}}, {"id": 266, "prop": "name", "attributes": {"content": "還記得……博卓卡斯替嗎？", "name": "孽茨雷"}, "figure_art": "avg_npc_1339_1#1$1"}, {"id": 267, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1331_1#1$1"}}, {"id": 268, "prop": "name", "attributes": {"content": "記得。", "name": "“靈幛”"}, "figure_art": "avg_npc_1331_1#1$1"}, {"id": 269, "prop": "name", "attributes": {"content": "您對他，視如己出。", "name": "“靈幛”"}, "figure_art": "avg_npc_1331_1#1$1"}, {"id": 270, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1339_1#1$1", "bstart": 0.3, "bend": 0.5}}, {"id": 271, "prop": "name", "attributes": {"content": "他是那樣天賦卓絕，無疑可以成為卡茲戴爾的英雄。", "name": "孽茨雷"}, "figure_art": "avg_npc_1339_1#1$1"}, {"id": 272, "prop": "name", "attributes": {"content": "他本是我最為欣賞的學徒。", "name": "孽茨雷"}, "figure_art": "avg_npc_1339_1#1$1"}, {"id": 273, "prop": "name", "attributes": {"content": "可惜他離開了卡茲戴爾，又死在一場異國的陰謀中。", "name": "孽茨雷"}, "figure_art": "avg_npc_1339_1#1$1"}, {"id": 274, "prop": "name", "attributes": {"content": "好在，他仍是以戰士的面貌死去。他透過戰爭踐行了生的意義，並在死時回歸了眾魂。", "name": "孽茨雷"}, "figure_art": "avg_npc_1339_1#1$1"}, {"id": 275, "prop": "name", "attributes": {"content": "而在那之後……在那之後……", "name": "孽茨雷"}, "figure_art": "avg_npc_1339_1#1$1"}, {"id": 276, "prop": "name", "attributes": {"content": "卡茲戴爾的下一位英雄……在哪裡？", "name": "孽茨雷"}, "figure_art": "avg_npc_1339_1#1$1"}, {"id": 277, "prop": "Dialog", "attributes": {}}, {"id": 278, "prop": "charslot", "attributes": {}}, {"id": 279, "prop": "name", "attributes": {"content": "孽茨雷看向懸崖之下。"}}, {"id": 280, "prop": "name", "attributes": {"content": "風穿過他軀幹上未能癒合的空洞，吹出些許沒有意義的聲音。"}}, {"id": 281, "prop": "Dialog", "attributes": {}}, {"id": 282, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 283, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 284, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 285, "prop": "charslot", "attributes": {}}, {"id": 286, "prop": "Background", "attributes": {"image": "50_g18_originiumcave", "screenadapt": "coverall"}}, {"id": 287, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 288, "prop": "PlayMusic", "attributes": {"intro": "$darkness01_intro", "key": "$darkness01_loop", "volume": 0.6}}, {"id": 289, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 290, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 291, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_394_1#2$1"}}, {"id": 292, "prop": "name", "attributes": {"content": "眾魂的哀歌變輕了。", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#2$1"}, {"id": 293, "prop": "name", "attributes": {"content": "“提卡茲之血”與源石的聯繫……被Logos先生的骨哨壓住了片刻。", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#2$1"}, {"id": 294, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_394_1#7$1"}}, {"id": 295, "prop": "name", "attributes": {"content": "這是我們最好的機會。", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#7$1"}, {"id": 296, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_394_1#7$1"}}, {"id": 297, "prop": "name", "attributes": {"content": "博士，凱爾希醫生……這一次，我絕不會錯過。", "name": "阿米婭"}, "figure_art": "avg_npc_394_1#7$1"}, {"id": 298, "prop": "Dialog", "attributes": {}}, {"id": 299, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 300, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 301, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 302, "prop": "charslot", "attributes": {}}, {"id": 303, "prop": "Background", "attributes": {"image": "50_g8_altarcoreandblood", "screenadapt": "coverall"}}, {"id": 304, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 305, "prop": "PlayMusic", "attributes": {"intro": "$nervous_intro", "key": "$nervous_loop", "volume": 0.6}}, {"id": 306, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 307, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 308, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 309, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_653_1#1$1", "duration": 1.5}}, {"id": 310, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 311, "prop": "name", "attributes": {"content": "……追上來了啊。", "name": "薩盧斯"}, "figure_art": "avg_npc_653_1#1$1"}, {"id": 312, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_653_1#5$1"}}, {"id": 313, "prop": "name", "attributes": {"content": "親愛的奎薩辛娜，你是不是也快到了？", "name": "薩盧斯"}, "figure_art": "avg_npc_653_1#5$1"}, {"id": 314, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_653_1#9$1"}}, {"id": 315, "prop": "name", "attributes": {"content": "你和首領……我們敬愛的父親，誰會成為那個……走到王座面前的人呢？", "name": "薩盧斯"}, "figure_art": "avg_npc_653_1#9$1"}, {"id": 316, "prop": "Delay", "attributes": {}}, {"id": 317, "prop": "charslot", "attributes": {}}, {"id": 318, "prop": "name", "attributes": {"content": "薩盧斯向祭壇上方的那滴血伸出手。"}}, {"id": 319, "prop": "Dialog", "attributes": {}}, {"id": 320, "prop": "PlaySound", "attributes": {"key": "$fireburst", "volume": 0.6}}, {"id": 321, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 322, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 323, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.03, "block": "true"}}, {"id": 324, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 325, "prop": "Delay", "attributes": {"time": 3.5}}, {"id": 326, "prop": "name", "attributes": {"content": "源石燃燒，眾魂咆哮。"}}, {"id": 327, "prop": "name", "attributes": {"content": "強大的巫術作用下，她的指尖很快就變成了焦黑色的結晶。"}}, {"id": 328, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_653_1#10$1"}}, {"id": 329, "prop": "name", "attributes": {"content": "真想看見啊……", "name": "薩盧斯"}, "figure_art": "avg_npc_653_1#10$1"}, {"id": 330, "prop": "name", "attributes": {"content": "原點，已經那麼近那麼近。", "name": "薩盧斯"}, "figure_art": "avg_npc_653_1#10$1"}, {"id": 331, "prop": "Dialog", "attributes": {}}, {"id": 332, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 333, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 334, "prop": "charslot", "attributes": {}}, {"id": 335, "prop": "Background", "attributes": {"image": "50_g7_confessariusaltar_on", "screenadapt": "coverall"}}, {"id": 336, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 337, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 338, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 339, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_425_1#1$1"}}, {"id": 340, "prop": "name", "attributes": {"content": "你——", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 341, "prop": "Dialog", "attributes": {}}, {"id": 342, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 343, "prop": "CameraShake", "attributes": {"duration": 1.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 344, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.03, "block": "true"}}, {"id": 345, "prop": "PlaySound", "attributes": {"key": "$swordtsing4", "volume": 1.0}}, {"id": 346, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 347, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 348, "prop": "charslot", "attributes": {}}, {"id": 349, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 350, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_147_shining_1#5$1", "duration": 1.5}}, {"id": 351, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 352, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_147_shining_1#5$1"}}, {"id": 353, "prop": "name", "attributes": {"content": "你們躲藏得很好。", "name": "閃靈"}, "figure_art": "avgnew_147_shining_1#5$1"}, {"id": 354, "prop": "name", "attributes": {"content": "找到你們……花去了太多時間。", "name": "閃靈"}, "figure_art": "avgnew_147_shining_1#5$1"}, {"id": 355, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_425_1#1$1"}}, {"id": 356, "prop": "name", "attributes": {"content": "叛徒！", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 357, "prop": "name", "attributes": {"content": "該死，你這一路上殺了多少人？", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 358, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_147_shining_1#5$1"}}, {"id": 359, "prop": "name", "attributes": {"content": "……不比當年逃出來的時候，殺得多。", "name": "閃靈"}, "figure_art": "avgnew_147_shining_1#5$1"}, {"id": 360, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_425_1#1$1"}}, {"id": 361, "prop": "name", "attributes": {"content": "那個時候……地下實驗區裡堆滿了我們的人的屍體。", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 362, "prop": "name", "attributes": {"content": "你害得首領在皇家科學院的部署幾乎白費。那麼大動靜，維多利亞人險些就要發現我們的計劃了！", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 363, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_147_shining_1#2$1"}}, {"id": 364, "prop": "name", "attributes": {"content": "我寧可他從未成功過。", "name": "閃靈"}, "figure_art": "avgnew_147_shining_1#2$1"}, {"id": 365, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_425_1#1$1"}}, {"id": 366, "prop": "name", "attributes": {"content": "哈……你以前可不是這麼說的！", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 367, "prop": "name", "attributes": {"content": "你是怎麼能夠裝得跟個正義使者一樣的？當年都是你指揮著我們忙進忙出！", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 368, "prop": "name", "attributes": {"content": "倫蒂尼姆城外，那麼大的地窟，那麼多處實驗基地……哪一處不是由你負責？", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 369, "prop": "name", "attributes": {"content": "那時候首領大多數時間都在卡茲戴爾。你才是那個主導研究的人，你戴著面具，看起來就和首領一模一樣——", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 370, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_147_shining_1#4$1"}}, {"id": 371, "prop": "name", "attributes": {"content": "那個時候，我並不能選擇。", "name": "閃靈"}, "figure_art": "avgnew_147_shining_1#4$1"}, {"id": 372, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_425_1#1$1"}}, {"id": 373, "prop": "name", "attributes": {"content": "不能選擇？那你把我們拉到倫蒂尼姆，給我們戴上這個面具的時候，說的那些話呢？", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 374, "prop": "name", "attributes": {"content": "我們最開始也只是雇傭兵，但我們相信了赦罪師的信仰，相信你們所說的，“薩卡茲最終和最初的道路”！", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 375, "prop": "name", "attributes": {"content": "我們與生俱來的罪孽——我們被外族人施加的罪，都將在那個終會抵達的時刻，盡數洗去。", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 376, "prop": "name", "attributes": {"content": "那是假的嗎？", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 377, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_147_shining_1#2$1"}}, {"id": 378, "prop": "name", "attributes": {"content": "……", "name": "閃靈"}, "figure_art": "avgnew_147_shining_1#2$1"}, {"id": 379, "prop": "name", "attributes": {"content": "我確實希望，那是一個謊言。", "name": "閃靈"}, "figure_art": "avgnew_147_shining_1#2$1"}, {"id": 380, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_425_1#1$1"}}, {"id": 381, "prop": "name", "attributes": {"content": "那是真的……不是什麼騙人話。每次首領對我們許下諾言，都是真誠的。你也是，奎薩辛娜，即便你後來走偏了……", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 382, "prop": "name", "attributes": {"content": "首領和攝政王，的確就要成功了。", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 383, "prop": "name", "attributes": {"content": "丟失萬年的自由與權力，即將回到所有薩卡茲的手中。", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 384, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_147_shining_1#2$1"}}, {"id": 385, "prop": "name", "attributes": {"content": "……", "name": "閃靈"}, "figure_art": "avgnew_147_shining_1#2$1"}, {"id": 386, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_425_1#1$1"}}, {"id": 387, "prop": "name", "attributes": {"content": "你要殺我，你就殺吧。", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 388, "prop": "name", "attributes": {"content": "去見首領，見你的父親。", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 389, "prop": "name", "attributes": {"content": "在那條道路的盡頭，他在等你。他們都在等你。", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 390, "prop": "name", "attributes": {"content": "你會替我，替我們每一個……死在你劍下的亡魂看見的。", "name": "赦罪師直屬衛兵"}, "figure_art": "avg_npc_425_1#1$1"}, {"id": 391, "prop": "Dialog", "attributes": {}}, {"id": 392, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 393, "prop": "CameraShake", "attributes": {"duration": 1.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 394, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.03, "block": "true"}}, {"id": 395, "prop": "PlaySound", "attributes": {"key": "$e_skill_skulsrsword", "volume": 1.0}}, {"id": 396, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 397, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 398, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown1", "volume": 1.0}}, {"id": 399, "prop": "charslot", "attributes": {"duration": 1.5}}, {"id": 400, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 401, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_147_shining_1#2$1"}}, {"id": 402, "prop": "name", "attributes": {"content": "……", "name": "閃靈"}, "figure_art": "avgnew_147_shining_1#2$1"}, {"id": 403, "prop": "Dialog", "attributes": {}}, {"id": 404, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,0", "posto": "0,-50", "duration": 1.0}}, {"id": 405, "prop": "playsound", "attributes": {"key": "$d_avg_clothmovement", "volume": 1.0}}, {"id": 406, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 407, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,-50", "posto": "0,0", "duration": 1.0}}, {"id": 408, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 409, "prop": "name", "attributes": {"content": "閃靈取下那名衛兵的面具。"}}, {"id": 410, "prop": "name", "attributes": {"content": "她確實記得這張臉。他屬於頭一批被赦罪師帶到倫蒂尼姆的雇傭兵。"}}, {"id": 411, "prop": "name", "attributes": {"content": "他們最初什麼都不知道，只是負責城外的遺跡挖掘。"}}, {"id": 412, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_147_shining_1#3$1"}}, {"id": 413, "prop": "name", "attributes": {"content": "這個年輕人還當面對她表達過謝意，感謝赦罪師給了他們一份收入豐厚，又很安全的工作。"}}, {"id": 414, "prop": "name", "attributes": {"content": "但很快，她就再也聽不到他們說這些話了。"}}, {"id": 415, "prop": "name", "attributes": {"content": "赦罪師的首領來到了倫蒂尼姆。"}}, {"id": 416, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_147_shining_1#2$1"}}, {"id": 417, "prop": "name", "attributes": {"content": "不再有四處閒聊、喝酒玩遊戲的雇傭兵。周圍的人們都戴上了一模一樣的面具，除非必要的時刻，都不會再開口。"}}, {"id": 418, "prop": "name", "attributes": {"content": "他們並沒有特殊血脈，奎薩圖什塔本不該能夠輕鬆操控他們的意志。"}}, {"id": 419, "prop": "name", "attributes": {"content": "可他們屬於自己的那一部分，還是在赦罪師的宏大理想面前死去了。"}}, {"id": 420, "prop": "name", "attributes": {"content": "而最初殺死他們的，就是她。"}}, {"id": 421, "prop": "Dialog", "attributes": {}}, {"id": 422, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_147_shining_1#2$1"}}, {"id": 423, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 424, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_147_shining_1#3$1"}}, {"id": 425, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 426, "prop": "charslot", "attributes": {"slot": "m", "name": "avgnew_147_shining_1#5$1"}}, {"id": 427, "prop": "name", "attributes": {"content": "這份罪孽……", "name": "閃靈"}, "figure_art": "avgnew_147_shining_1#5$1"}, {"id": 428, "prop": "name", "attributes": {"content": "……不該再延續了。", "name": "閃靈"}, "figure_art": "avgnew_147_shining_1#5$1"}, {"id": 429, "prop": "Dialog", "attributes": {}}, {"id": 430, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 431, "prop": "charslot", "attributes": {"duration": 1.5}}, {"id": 432, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 433, "prop": "playsound", "attributes": {"key": "$d_avg_glassbroken", "volume": 1.0}}, {"id": 434, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 435, "prop": "name", "attributes": {"content": "面具裂開了，碎屑刺痛著閃靈的掌心。"}}, {"id": 436, "prop": "name", "attributes": {"content": "她繼續往山頂走去。"}}, {"id": 437, "prop": "Dialog", "attributes": {}}, {"id": 438, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 439, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 440, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 441, "prop": "charslot", "attributes": {}}, {"id": 442, "prop": "Image", "attributes": {}}, {"id": 443, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}