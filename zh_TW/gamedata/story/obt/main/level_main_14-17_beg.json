eenadapt": "coverall"}}, {"id": 243, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 244, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 245, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 246, "prop": "name", "attributes": {"content": "——她。"}}, {"id": 247, "prop": "Dialog", "attributes": {}}, {"id": 248, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 249, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 250, "prop": "name", "attributes": {"content": "她從未離開你。"}}, {"id": 251, "prop": "Dialog", "attributes": {}}, {"id": 252, "prop": "charslot", "attributes": {}}, {"id": 253, "prop": "image", "attributes": {}}, {"id": 254, "prop": "cameraEffect", "attributes": {"effect": "Grayscale", "keep": "true", "amount": 0.8, "fadetime": 0.0}}, {"id": 255, "prop": "Image", "attributes": {"image": "avg_0_1", "screenadapt": "coverall"}}, {"id": 256, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 257, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 258, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 259, "prop": "name", "attributes": {"content": "他們都從未離開。"}}, {"id": 260, "prop": "Dialog", "attributes": {}}, {"id": 261, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 262, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 263, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 264, "prop": "charslot", "attributes": {}}, {"id": 265, "prop": "image", "attributes": {}}, {"id": 266, "prop": "Background", "attributes": {"image": "bg_black", "screenadapt": "coverall", "block": "true"}}, {"id": 267, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 268, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 269, "prop": "name", "attributes": {"content": "“博士……”"}}, {"id": 270, "prop": "name", "attributes": {"content": "“博士！”"}}, {"id": 271, "prop": "Dialog", "attributes": {}}, {"id": 272, "prop": "Decision", "attributes": {"options": "（“未知語言”）阿米婭……", "values": "1"}, "targetLine": {}}, {"id": 273, "prop": "Predicate", "attributes": {"references": "1"}}, {"id": 274, "prop": "Dialog", "attributes": {}}, {"id": 275, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 276, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 277, "prop": "image", "attributes": {}}, {"id": 278, "prop": "charslot", "attributes": {}}, {"id": 279, "prop": "Background", "attributes": {"image": "bg_abyss_1", "screenadapt": "coverall", "xScale": 1.08, "yScale": 1.08, "block": "true"}}, {"id": 280, "prop": "cameraEffect", "attributes": {"effect": "Grayscale", "keep": "true", "amount": 0.0, "fadetime": 0.0}}, {"id": 281, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083"}}, {"id": 282, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 283, "prop": "PlayMusic", "attributes": {"intro": "$loneliness_intro", "key": "$loneliness_loop", "volume": 0.6}}, {"id": 284, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 285, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 286, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "m"}}, {"id": 287, "prop": "name", "attributes": {"content": "博士！", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 288, "prop": "name", "attributes": {"content": "你又走神了，嘴裡又開始唸著這些不屬於我們的語言。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 289, "prop": "Dialog", "attributes": {}}, {"id": 290, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "n"}}, {"id": 291, "prop": "Decision", "attributes": {"options": "那些經歷……很真實。;那不是夢。", "values": "1;2"}, "targetLine": {}}, {"id": 292, "prop": "Predicate", "attributes": {"references": "1;2"}}, {"id": 293, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "m"}}, {"id": 294, "prop": "name", "attributes": {"content": "這不是很正常嗎？", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 295, "prop": "name", "attributes": {"content": "定義夢與現實的權力，一直都掌握在我們手中，{@nickname}。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 296, "prop": "name", "attributes": {"content": "當我們的思維在寰宇中穿梭億萬光年，參加那些於冰凍曠野中向白矮星祭拜生命的儀式時，我們該如何定義這樣的體驗呢？", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 297, "prop": "name", "attributes": {"content": "等你的思維回到這具身體後，你又如何分辨億萬年後才會被捕獲的資訊是夢還是現實？", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 298, "prop": "Dialog", "attributes": {}}, {"id": 299, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "n"}}, {"id": 300, "prop": "Decision", "attributes": {"options": "……", "values": "1"}, "targetLine": {}}, {"id": 301, "prop": "Predicate", "attributes": {"references": "1"}}, {"id": 302, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "m"}}, {"id": 303, "prop": "name", "attributes": {"content": "等等，你該不會真的在思考這件事吧？", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 304, "prop": "Dialog", "attributes": {}}, {"id": 305, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "n"}}, {"id": 306, "prop": "Decision", "attributes": {"options": "普瑞賽斯……", "values": "1"}, "targetLine": {}}, {"id": 307, "prop": "Predicate", "attributes": {"references": "1"}}, {"id": 308, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "m"}}, {"id": 309, "prop": "name", "attributes": {"content": "怎麼了，{@nickname}？", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 310, "prop": "Dialog", "attributes": {}}, {"id": 311, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "n"}}, {"id": 312, "prop": "Decision", "attributes": {"options": "我不曾見過你，可為何你的名字，我卻能脫口而出？", "values": "1"}, "targetLine": {}}, {"id": 313, "prop": "Predicate", "attributes": {"references": "1"}}, {"id": 314, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "m"}}, {"id": 315, "prop": "name", "attributes": {"content": "不曾見過……你還是發現了啊。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 316, "prop": "name", "attributes": {"content": "我很高興聽到你這麼說，這意味著你距離找到真正的我，已經很近了。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 317, "prop": "name", "attributes": {"content": "可是我還是忍不住有些失望。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 318, "prop": "name", "attributes": {"content": "因為那個小小的意外，你的記憶……的確受到了無法逆轉的損傷，就連我也無能為力。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 319, "prop": "Dialog", "attributes": {}}, {"id": 320, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "n"}}, {"id": 321, "prop": "Decision", "attributes": {"options": "這裡……也是羅德島？;我以前來過這裡嗎？", "values": "1;2"}, "targetLine": {}}, {"id": 322, "prop": "Predicate", "attributes": {"references": "1;2"}}, {"id": 323, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "m"}}, {"id": 324, "prop": "name", "attributes": {"content": "這裡嘛……“不可知”。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 325, "prop": "name", "attributes": {"content": "我們一起建造這個地方的時候，曾經許下過一個共同的願望。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 326, "prop": "name", "attributes": {"content": "等到群星的最後一絲溫熱消散，時間的路網完全陷入混亂的那一天，就讓黑暗成為我們共同的被子吧。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 327, "prop": "Dialog", "attributes": {}}, {"id": 328, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "n"}}, {"id": 329, "prop": "Decision", "attributes": {"options": "……聽起來很像一座墳墓。", "values": "1"}, "targetLine": {}}, {"id": 330, "prop": "Predicate", "attributes": {"references": "1"}}, {"id": 331, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "m"}}, {"id": 332, "prop": "name", "attributes": {"content": "等到這個世界，這片星空迎來最後的時刻……我們的宇宙本來就會變成一座巨大的墳墓。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 333, "prop": "name", "attributes": {"content": "沒有任何一顆星球的角落藏著希望。但凡有一顆宇宙碎片的微粒上藏著救贖的答案，它也一定已經被我們打撈起來了。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 334, "prop": "name", "attributes": {"content": "每一次的反抗都以提前毀滅告終，每一次的探索只會帶來更深重的絕望……", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 335, "prop": "name", "attributes": {"content": "結論是那麼簡單。任何以正常物質為基礎的生命形式都無法逃離。任何一種已知的技術，都無法克服那絕對的終結。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 336, "prop": "name", "attributes": {"content": "抱歉，{@nickname}……", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 337, "prop": "name", "attributes": {"content": "我只是，很久沒有機會向你傾訴了。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 338, "prop": "Dialog", "attributes": {}}, {"id": 339, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "n"}}, {"id": 340, "prop": "Decision", "attributes": {"options": "我們的關係……很親密？", "values": "1"}, "targetLine": {}}, {"id": 341, "prop": "Predicate", "attributes": {"references": "1"}}, {"id": 342, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "m"}}, {"id": 343, "prop": "name", "attributes": {"content": "親密？我不會用這種字眼來形容我們之間的關係。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 344, "prop": "name", "attributes": {"content": "這是對我們過去所經歷的一切的貶低。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 345, "prop": "Dialog", "attributes": {}}, {"id": 346, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "n"}}, {"id": 347, "prop": "Decision", "attributes": {"options": "我並不記得。", "values": "1"}, "targetLine": {}}, {"id": 348, "prop": "Predicate", "attributes": {"references": "1"}}, {"id": 349, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "m"}}, {"id": 350, "prop": "name", "attributes": {"content": "沒關係的，我並不生氣。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 351, "prop": "name", "attributes": {"content": "就算你的大腦不再記得，你的意識深處，那些任何儀器都無法捕捉到的地方……一定還留存著我的痕跡。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 352, "prop": "name", "attributes": {"content": "不然的話……你怎麼會任由我像這樣，一直拉著你的手呢？", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 353, "prop": "Dialog", "attributes": {}}, {"id": 354, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "n"}}, {"id": 355, "prop": "Decision", "attributes": {"options": "嗯……;過去我們也常常這麼做嗎？", "values": "1;2"}, "targetLine": {}}, {"id": 356, "prop": "Predicate", "attributes": {"references": "1;2"}}, {"id": 357, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "m"}}, {"id": 358, "prop": "name", "attributes": {"content": "“牽手”——嗯，我們有很多種不同方式的“牽手”。很多時候並不需要借助軀體的某些特定部分。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 359, "prop": "name", "attributes": {"content": "我們第一次見面的時候……我正在環繞著一顆海洋星球飛行。我把恆星當作不變的錨，沿著晝夜分界線，飛了一圈又一圈。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 360, "prop": "name", "attributes": {"content": "恆星的死亡來得很快。我身下的海洋幾乎在一瞬間離解了，露出了星球赤裸的暗紅色脊骨。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 361, "prop": "name", "attributes": {"content": "有人從身後拉住了我，把我拽到了一處更安靜的星雲裡。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 362, "prop": "name", "attributes": {"content": "那個人向我解釋，知道我很可能不會有危險，但那個人來不及確認我的本體在哪個星場中，只能用自己的船打撈了我的意識信標。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 363, "prop": "name", "attributes": {"content": "那是我第一次登上那艘卵形的船。它並不大，可是很靈活，已經去過無數個星系。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 364, "prop": "name", "attributes": {"content": "我把船帶到了一顆並不算熱鬧的行星上。我向船的主人展示了我面向大海的小實驗室，並且走到了那個人的面前。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 365, "prop": "name", "attributes": {"content": "就像這樣……我握住了對方的手。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 366, "prop": "name", "attributes": {"content": "“我叫普瑞賽斯，語言學家。我正在研究行星死去時發出的最後聲波。我喜歡安靜地獨處，但也想和合適的人一起探索宇宙。”", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 367, "prop": "name", "attributes": {"content": "接下來……", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 368, "prop": "name", "attributes": {"content": "該你啦。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 369, "prop": "Dialog", "attributes": {}}, {"id": 370, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "n"}}, {"id": 371, "prop": "Decision", "attributes": {"options": "我？自我介紹嗎？", "values": "1"}, "targetLine": {}}, {"id": 372, "prop": "Predicate", "attributes": {"references": "1"}}, {"id": 373, "prop": "Decision", "attributes": {"options": "我是……{@nickname}。", "values": "1"}, "targetLine": {}}, {"id": 374, "prop": "Predicate", "attributes": {"references": "1"}}, {"id": 375, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "m"}}, {"id": 376, "prop": "name", "attributes": {"content": "真好啊，我們又認識了一回。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 377, "prop": "name", "attributes": {"content": "對了，你當時也有些猶豫。在那個時代……人們已經越來越少像這樣親密相處。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 378, "prop": "name", "attributes": {"content": "好在，我們是同類。你無私地向我分享了你的旅行見聞，並對我發起了邀請。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 379, "prop": "name", "attributes": {"content": "我們跳躍在時間與空間之中，去往宇宙的各個角落。有時是乘坐著你的船，更多時候是透過意識穿梭。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 380, "prop": "name", "attributes": {"content": "你向我描繪不同文明的興衰迭起、隱藏在群星誕生與毀滅中的規律。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 381, "prop": "name", "attributes": {"content": "我們的思維在相互碰撞中無限迭代，直至駐足回首時才發現，我們已經超越了其他人太多太多……", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 382, "prop": "Dialog", "attributes": {}}, {"id": 383, "prop": "charslot", "attributes": {}}, {"id": 384, "prop": "name", "attributes": {"content": "她的手中翻轉出一枚無比純淨的晶體。"}}, {"id": 385, "prop": "Dialog", "attributes": {}}, {"id": 386, "prop": "Decision", "attributes": {"options": "……源石。", "values": "1"}, "targetLine": {}}, {"id": 387, "prop": "Predicate", "attributes": {"references": "1"}}, {"id": 388, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "m"}}, {"id": 389, "prop": "name", "attributes": {"content": "我們爭論與碰撞的結晶，凝結了無數先驅守望宇宙時留下的真理。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 390, "prop": "name", "attributes": {"content": "它是如此美麗……", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 391, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "n"}}, {"id": 392, "prop": "name", "attributes": {"content": "她將源石輕輕地放在了你的手中，握住你的手，共同捧起這美輪美奐的造物。"}}, {"id": 393, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "m"}}, {"id": 394, "prop": "name", "attributes": {"content": "所有人都說，我是那個創造了源石與未來，像“神明”一般的人。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 395, "prop": "name", "attributes": {"content": "但我一直都知道，真正的天才是你，{@nickname}。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 396, "prop": "Dialog", "attributes": {}}, {"id": 397, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "n"}}, {"id": 398, "prop": "Decision", "attributes": {"options": "……", "values": "1"}, "targetLine": {}}, {"id": 399, "prop": "Predicate", "attributes": {"references": "1"}}, {"id": 400, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "m"}}, {"id": 401, "prop": "name", "attributes": {"content": " 你忘記了……但你不該忘記。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 402, "prop": "name", "attributes": {"content": "在創造它的路上，我不斷地追趕你的腳步。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 403, "prop": "name", "attributes": {"content": "我害怕在某一次與你辯論時掉隊，害怕讓你發現我本來不如你。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 404, "prop": "name", "attributes": {"content": "不，或許你發現了……也許你也曾放慢腳步等我，等待我追上你。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 405, "prop": "name", "attributes": {"content": "可是現在，我永遠都不會知道答案了……", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 406, "prop": "Dialog", "attributes": {}}, {"id": 407, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "n"}}, {"id": 408, "prop": "Decision", "attributes": {"options": "你……很在意？", "values": "1"}, "targetLine": {}}, {"id": 409, "prop": "Predicate", "attributes": {"references": "1"}}, {"id": 410, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "m"}}, {"id": 411, "prop": "name", "attributes": {"content": "在意，但我接受這個事實。倒不如說，這讓我喜悅。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 412, "prop": "name", "attributes": {"content": "你依舊藏著許多令我著迷的秘密。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 413, "prop": "name", "attributes": {"content": "況且，對你而言，現在的我同樣如此。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 414, "prop": "name", "attributes": {"content": "難道不是嗎，{@nickname}？", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 415, "prop": "Dialog", "attributes": {}}, {"id": 416, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "n"}}, {"id": 417, "prop": "Decision", "attributes": {"options": "我……的確還有很多的困惑。", "values": "1"}, "targetLine": {}}, {"id": 418, "prop": "Predicate", "attributes": {"references": "1"}}, {"id": 419, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "m"}}, {"id": 420, "prop": "name", "attributes": {"content": "那就繼續在這個地方尋找答案吧。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 421, "prop": "name", "attributes": {"content": "這是我們共同的造物，共同的過去，也藏著我們共同的秘密。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 422, "prop": "name", "attributes": {"content": "只要你和我同行——", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 423, "prop": "Dialog", "attributes": {}}, {"id": 424, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "n"}}, {"id": 425, "prop": "Decision", "attributes": {"options": "抱歉，但現在我有更在意的事。;我必須先確認更重要的事。", "values": "1;2"}, "targetLine": {}}, {"id": 426, "prop": "Predicate", "attributes": {"references": "1;2"}}, {"id": 427, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "m"}}, {"id": 428, "prop": "name", "attributes": {"content": "……", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 429, "prop": "name", "attributes": {"content": "我本來想跟你分享一些我一直替你保存的東西。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 430, "prop": "name", "attributes": {"content": "那些你曾經向我描繪，如今你自己卻已全然忘記的理念和願景……", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 431, "prop": "name", "attributes": {"content": "我想讓你知道我們所取得的成就。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 432, "prop": "name", "attributes": {"content": "也許是這樣，你能想起過去，想起我——", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 433, "prop": "name", "attributes": {"content": "但我能看見你所想，我能感受你所思。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 434, "prop": "name", "attributes": {"content": "就像此刻，你的腦海中依舊縈繞著無窮的疑惑……", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 435, "prop": "name", "attributes": {"content": "“阿米婭”“凱爾希”——", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 436, "prop": "Dialog", "attributes": {}}, {"id": 437, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "n"}}, {"id": 438, "prop": "Decision", "attributes": {"options": "——！", "values": "1"}, "targetLine": {}}, {"id": 439, "prop": "Predicate", "attributes": {"references": "1"}}, {"id": 440, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_083", "focus": "m"}}, {"id": 441, "prop": "name", "attributes": {"content": "我……不想讓你為難，我尊重你的選擇。", "name": "普瑞賽斯"}, "figure_art": "avg_npc_083"}, {"id": 442, "prop": "Dialog", "attributes": {}}, {"id": 443, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 444, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 445, "prop": "Dialog", "attributes": {}}, {"id": 446, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 447, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 448, "prop": "name", "attributes": {"content": "她的手觸碰到了黑暗——"}}, {"id": 449, "prop": "Dialog", "attributes": {}}, {"id": 450, "prop": "Image", "attributes": {"image": "50_i16", "screenadapt": "coverall", "block": "true"}}, {"id": 451, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 452, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 453, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 454, "prop": "name", "attributes": {"content": "但我很確定……{@nickname}……", "name": "普瑞賽斯"}}, {"id": 455, "prop": "name", "attributes": {"content": "當你真正對一切感到困惑的時候，你會想起——答案一直都在這裡。", "name": "普瑞賽斯"}}, {"id": 456, "prop": "name", "attributes": {"content": "我在這裡。", "name": "普瑞賽斯"}}, {"id": 457, "prop": "Dialog", "attributes": {}}, {"id": 458, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 3.0, "block": "true"}}, {"id": 459, "prop": "image", "attributes": {}}, {"id": 460, "prop": "Background", "attributes": {"image": "bg_white", "screenadapt": "coverall"}}, {"id": 461, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 462, "prop": "Subtitle", "attributes": {"text": "<color=#000000>去吧，“博士”，去解開你的困惑。</color>", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 463, "prop": "Subtitle", "attributes": {"text": "<color=#000000>你所有的願望，我都能夠實現。</color>", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 464, "prop": "Subtitle", "attributes": {"text": "<color=#000000>而在所有宏大的搏動和微小的悸動都歸於寂靜之後——</color>", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 465, "prop": "Subtitle", "attributes": {"text": "<color=#000000>我的身邊將是你的歸處。</color>", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 466, "prop": "subtitle", "attributes": {}}, {"id": 467, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 468, "prop": "Dialog", "attributes": {}}, {"id": 469, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 470, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 471, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 472, "prop": "charslot", "attributes": {}}, {"id": 473, "prop": "Image", "attributes": {}}, {"id": 474, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": false}