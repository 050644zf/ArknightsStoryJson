: "avg_4179_monstr_1#2$1"}, {"id": 39, "prop": "Dialog", "attributes": {}}, {"id": 40, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 41, "prop": "Decision", "attributes": {"options": "她顯然還隱藏著許多秘密。;來自聖駿堡的特使與地方貴族之間的關係的確很微妙。", "values": "1;2"}, "targetLine": {"option1": "line42", "option2": "line42"}}, {"id": 42, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 43, "prop": "Decision", "attributes": {"options": "但她也明確表示過，需要我們和她一起進入礦區。", "values": "1"}, "targetLine": {"option1": "line44"}}, {"id": 44, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 45, "prop": "Decision", "attributes": {"options": "無論如何，我們與她的合作都是必要的。;這是我們目前僅有的能夠進入礦區的機會。", "values": "1;2"}, "targetLine": {"option1": "line46", "option2": "line46"}}, {"id": 46, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 47, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_1037_amiya3_1#1$1", "focus": "l"}}, {"id": 48, "prop": "name", "attributes": {"content": "但畢竟羅德島的確曾出現在烏薩斯官方的視野內，我們現在還無法確定這裡的管理者對我們的態度。", "name": "阿米婭"}}, {"id": 49, "prop": "Dialog", "attributes": {}}, {"id": 50, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 51, "prop": "Decision", "attributes": {"options": "我從過去的事中累積到了一些經驗。;這樣的場合對我來說不完全算是陌生……", "values": "1;2"}, "targetLine": {"option1": "line52", "option2": "line52"}}, {"id": 52, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 53, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_1037_amiya3_1#6$1", "focus": "l"}}, {"id": 54, "prop": "name", "attributes": {"content": "博士，我會支持你的決定，但請你務必小心。", "name": "阿米婭"}}, {"id": 55, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4179_monstr_1#6$1", "focus": "r"}}, {"id": 56, "prop": "name", "attributes": {"content": "帶好通訊終端！要是出現了什麼意外狀況請立刻通知我們，就算要撞破這棟大樓我們也會第一時間衝進去把博士你救出來的！", "name": "Mon3tr"}, "figure_art": "avg_4179_monstr_1#6$1"}