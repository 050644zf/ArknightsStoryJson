, "block": "true"}}, {"id": 80, "prop": "charslot", "attributes": {}}, {"id": 81, "prop": "Image", "attributes": {"image": "66_i05", "fadetime": 0.0, "xScale": 1.0, "yScale": 1.0, "screenadapt": "coverall"}}, {"id": 82, "prop": "Background", "attributes": {"image": "bg_black", "screenadapt": "coverall"}}, {"id": 83, "prop": "PlaySound", "attributes": {"key": "$d_avg_gateopen"}}, {"id": 84, "prop": "playsound", "attributes": {"key": "$d_avg_woodcracle", "loop": "true", "channel": "bgs", "volume": 0.0}}, {"id": 85, "prop": "SoundVolume", "attributes": {"volume": 0.7, "channel": "bgs", "fadetime": 2.0}}, {"id": 86, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 87, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 88, "prop": "playMusic", "attributes": {"key": "$m_avg_ursusdaily_loop", "volume": 0.6}}, {"id": 89, "prop": "name", "attributes": {"content": "這是個幽寂的房間。"}}, {"id": 90, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.0, "yScaleFrom": 1.0, "xScaleTo": 1.3, "yScaleTo": 1.3, "duration": 60.0}}, {"id": 91, "prop": "name", "attributes": {"content": "彷彿是巨大而沉默的石壁在這座陰冷的城市中隔絕出了一處不容打擾的空間。"}}, {"id": 92, "prop": "name", "attributes": {"content": "目之所及，只有一抹雍容的灰藍色身影佇立在空闊房間的盡頭。"}}, {"id": 93, "prop": "Dialog", "attributes": {}}, {"id": 94, "prop": "Decision", "attributes": {"options": "您好。", "values": "1"}, "targetLine": {"option1": "line95"}}, {"id": 95, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 96, "prop": "Decision", "attributes": {"options": "尊敬的葉莉薩維塔·康斯坦丁諾夫娜·拉齊薩拉女大公殿下。;……", "values": "1;2"}, "targetLine": {"option1": "line97", "option2": "line100"}}, {"id": 97, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false, "targetLine": "line105"}, {"id": 98, "prop": "name", "attributes": {"content": "我可以感受到你的敬意。不必拘謹，你可以像我的朋友一樣，稱我為葉莉莎女大公。", "name": "葉莉莎女大公"}}, {"id": 99, "prop": "name", "attributes": {"content": "我能感覺到，你一定是位心思機敏的人。", "name": "葉莉莎女大公"}}, {"id": 100, "prop": "Predicate", "attributes": {"references": "2"}, "endOfOpt": false, "targetLine": "line105"}, {"id": 101, "prop": "name", "attributes": {"content": "你可以稱呼她葉莉莎女大公。", "name": "阿洛伊澤"}}, {"id": 102, "prop": "name", "attributes": {"content": "……我很抱歉，女大公殿下。我應該提醒此人注意禮數的。", "name": "阿洛伊澤"}}, {"id": 103, "prop": "name", "attributes": {"content": "這有什麼關係呢？", "name": "葉莉莎女大公"}}, {"id": 104, "prop": "name", "attributes": {"content": "真誠的善意是不依賴於禮數而存在的，讓我們的客人放鬆一點吧。", "name": "葉莉莎女大公"}}, {"id": 105, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": true}, {"id": 106, "prop": "name", "attributes": {"content": "那是一道出乎你意料的、柔和而天真的聲音。"}}, {"id": 107, "prop": "name", "attributes": {"content": "這裡的主人緩緩轉過身。"}}, {"id": 108, "prop": "Dialog", "attributes": {}}, {"id": 109, "prop": "SoundVolume", "attributes": {"volume": 0.4, "channel": "bgs", "fadetime": 2.0}}, {"id": 110, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 111, "prop": "charslot", "attributes": {}}, {"id": 112, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 113, "prop": "image", "attributes": {}}, {"id": 114, "prop": "Background", "attributes": {"image": "66_g2_farnorthgovernment", "screenadapt": "coverall"}}, {"id": 115, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 116, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 117, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#3$1", "duration": 1.5}}, {"id": 118, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 119, "prop": "name", "attributes": {"content": "我歡迎每一位到訪布列斯克的客人……", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#3$1"}, {"id": 120, "prop": "name", "attributes": {"content": "阿洛達，是不是該向我介紹一下你的朋友？", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#3$1"}, {"id": 121, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 122, "prop": "name", "attributes": {"content": "哦，當然……這位就是我剛剛和您提起的，來自羅德島製藥公司的博士——", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 123, "prop": "Dialog", "attributes": {}}, {"id": 124, "prop": "charslot", "attributes": {}}, {"id": 125, "prop": "Decision", "attributes": {"options": "我的名字是{@nickname}。;您可以叫我Dr.{@nickname}。", "values": "1;2"}, "targetLine": {"option1": "line126", "option2": "line126"}}, {"id": 126, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 127, "prop": "Decision", "attributes": {"options": "很榮幸能受到您的接見。;希望我的拜訪並不冒昧。", "values": "1;2"}, "targetLine": {"option1": "line128", "option2": "line128"}}, {"id": 128, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 129, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#3$1"}}, {"id": 130, "prop": "name", "attributes": {"content": "不必那麼拘束，請上前一點吧，坐在離火爐更近一點的地方。侍從馬上會端熱茶過來。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#3$1"}, {"id": 131, "prop": "name", "attributes": {"content": "遠道而來的客人或許很難適應這個季節的布列斯克，雖然此地偏遠，但實際上也有溫和宜人的時候。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#3$1"}, {"id": 132, "prop": "name", "attributes": {"content": "那麼，您來這裡的路上還順利嗎？", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#3$1"}, {"id": 133, "prop": "Dialog", "attributes": {}}, {"id": 134, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 135, "prop": "Decision", "attributes": {"options": "恐怕很難稱為順利……;布列斯克是一座治安很好的城市。", "values": "1;2"}, "targetLine": {"option1": "line136", "option2": "line136"}}, {"id": 136, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 137, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#1$1"}}, {"id": 138, "prop": "name", "attributes": {"content": "請您相信，您在這裡所見到的一切，其目的都是維護這座城市來之不易的安寧。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 139, "prop": "name", "attributes": {"content": "阿洛達已經向我充分說明了，她新結識的朋友是多麼優秀的礦石病專家，正是這座城市如今非常需要的人才。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 140, "prop": "Dialog", "attributes": {}}, {"id": 141, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 142, "prop": "Decision", "attributes": {"options": "這裡需要礦石病專家？;烏薩斯……需要礦石病專家？", "values": "1;2"}, "targetLine": {"option1": "line143", "option2": "line143"}}, {"id": 143, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 144, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#1$1"}}, {"id": 145, "prop": "name", "attributes": {"content": "我們年輕的皇帝陛下有意要將他的恩寵平等地降在每一位帝國的子民身上，他甚至不願意讓感染與否成為區分他的子民的一道標準。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 146, "prop": "name", "attributes": {"content": "陛下為此付出了萬分辛苦的努力，甚至到了每一位臣子看了都要心痛的程度。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 147, "prop": "name", "attributes": {"content": "但很少有人真正理解，陛下這樣純真的心性是多麼珍貴的寶物。身為他的追隨者，我們應當努力踐行他的意志。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 148, "prop": "name", "attributes": {"content": "布列斯克與遠北最大的礦區毗鄰，但這裡對礦石病的醫療手段還達不到陛下的理想。所以，我們需要一些有能力的醫生。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 149, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 150, "prop": "name", "attributes": {"content": "若是出於這樣的目的，Dr.{@nickname}一定是您能在此處尋找到的最優秀的合作夥伴。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 151, "prop": "name", "attributes": {"content": "我曾見識過羅德島發表的學術巨著——和帝國大學中那些只會拾人牙慧的蛀蟲學究不同，羅德島在礦石病方面擁有領先的知識。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 152, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#3$1"}}, {"id": 153, "prop": "name", "attributes": {"content": "哦……我還從來沒有在任何場合聽到這位驕傲的青年軍官對任何人表達過欣賞。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#3$1"}, {"id": 154, "prop": "name", "attributes": {"content": "是聖駿堡的工作改變了你的脾氣嗎？我清楚地記得，你的父親抱怨過你是如何一次次在公爵的宴會上讓他下不了台階的。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#3$1"}, {"id": 155, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 156, "prop": "name", "attributes": {"content": "讓您見笑了，女大公殿下。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 157, "prop": "name", "attributes": {"content": "我還是想說些傲慢的辯解——我向來敬佩有真才實學的人，如您，還有我身邊的這位Dr.{@nickname}。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 158, "prop": "name", "attributes": {"content": "承蒙您還記得家父，我都差點忘了替他向您問好。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 159, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#3$1"}}, {"id": 160, "prop": "name", "attributes": {"content": "至少他的工廠還在為遠北的每一位戰士生產最好的軍裝，邊境舉辦的每一場宴會上也都還能聽到他的名字。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#3$1"}, {"id": 161, "prop": "name", "attributes": {"content": "……還是說回我們的這位朋友吧。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#3$1"}, {"id": 162, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#1$1"}}, {"id": 163, "prop": "name", "attributes": {"content": "讓我們開誠布公地談談吧——羅德島，在布列斯克都有什麼打算呢？", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 164, "prop": "Dialog", "attributes": {}}, {"id": 165, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 166, "prop": "Decision", "attributes": {"options": "我們希望您能夠准許我們進入遠北礦區。;我們有一支流動醫療隊在中心礦區失聯了。", "values": "1;2"}, "targetLine": {"option1": "line167", "option2": "line167"}}, {"id": 167, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 168, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#2$1"}}, {"id": 169, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 170, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 171, "prop": "name", "attributes": {"content": "聽到你的話語，女大公在一瞬間表現出了不至失態的驚訝。"}}, {"id": 172, "prop": "name", "attributes": {"content": "她看向了阿洛伊澤，而你準確地捕捉到了這位年輕近衛軍眼神中的閃躲。"}}, {"id": 173, "prop": "name", "attributes": {"content": "女大公長嘆了一口氣，似乎在很認真地苦惱著。"}}, {"id": 174, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#4$1"}}, {"id": 175, "prop": "name", "attributes": {"content": "唉……Dr.{@nickname}——是這樣稱呼，對嗎？", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#4$1"}, {"id": 176, "prop": "name", "attributes": {"content": "如果是這位年輕人讓您產生了不該有的誤會，那我感到遺憾。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#4$1"}, {"id": 177, "prop": "name", "attributes": {"content": "我們歡迎羅德島在布列斯克建設辦事處，我願意提供一些力所能及的幫助……", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#4$1"}, {"id": 178, "prop": "name", "attributes": {"content": "但遠北的礦區，目前並不是可供客人遊覽的時候。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#4$1"}, {"id": 179, "prop": "name", "attributes": {"content": "如果您的夥伴們在礦區走丟了，留下他們最後的行蹤和外貌描述吧，我會派遣足夠的人手幫您找到他們的。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#4$1"}, {"id": 180, "prop": "Dialog", "attributes": {}}, {"id": 181, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 182, "prop": "Decision", "attributes": {"options": "請原諒，但我認為我們還需要再仔細談談……", "values": "1"}, "targetLine": {"option1": "line183"}}, {"id": 183, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 184, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#4$1"}}, {"id": 185, "prop": "name", "attributes": {"content": "那恐怕……", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#4$1"}, {"id": 186, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 187, "prop": "name", "attributes": {"content": "女大公殿下。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 188, "prop": "name", "attributes": {"content": "如果是以我的名義，邀請他們與我同行呢？", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 189, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#4$1"}}, {"id": 190, "prop": "name", "attributes": {"content": "哦，阿洛達……你總是有這樣淘氣的小把戲。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#4$1"}, {"id": 191, "prop": "name", "attributes": {"content": "你明明知道，布列斯克需要專業的礦石病醫生。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#4$1"}, {"id": 192, "prop": "name", "attributes": {"content": "明明只要有你的推薦，我甚至不會將此當作一個人情，我會允許你的朋友在這裡開展業務。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#4$1"}, {"id": 193, "prop": "name", "attributes": {"content": "但你看看，你現在在做什麼？讓我們寶貴的客人捲入泥雪一樣的麻煩？", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#4$1"}, {"id": 194, "prop": "name", "attributes": {"content": "阿洛達……你正在把事情變得更複雜。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#4$1"}, {"id": 195, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 196, "prop": "name", "attributes": {"content": "這不是一件複雜的事情——請原諒，女大公殿下。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 197, "prop": "name", "attributes": {"content": "我從來都沒有隱瞞過我這次來的目的。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 198, "prop": "name", "attributes": {"content": "皇帝在上，聖駿堡不會有半個人擔憂您治下的布列斯克會有任何不安定的可能。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 199, "prop": "name", "attributes": {"content": "但是對此時此刻正在封閉的礦區，對感染者異變感到好奇的人，不在少數。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 200, "prop": "name", "attributes": {"content": "來到這裡的可能會是某個遊手好閒的年輕新貴族，或者是研究礦石病的專家。當然也有可能是某個集團軍的上尉，或者是議會的大人物。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 201, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 202, "prop": "name", "attributes": {"content": "年輕近衛軍的語氣依舊輕佻，令人幾乎無法辨別其話語中的尖銳是不懂禮數的冒犯，還是別有深意的刺探。"}}, {"id": 203, "prop": "name", "attributes": {"content": "葉莉莎女大公的眼睛眯了起來。"}}, {"id": 204, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#1$1"}}, {"id": 205, "prop": "name", "attributes": {"content": "要是他們有疑問，那就讓他們帶著疑問來吧。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 206, "prop": "name", "attributes": {"content": "集團軍眼中討好新貴族的牆頭草派，議會眼中的邊境女大公，我已經習慣所有人對布列斯克抱有疑問與獵奇心理了。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 207, "prop": "name", "attributes": {"content": "那麼，親愛的阿洛達，你又是代表著誰，來向我問責的呢？", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 208, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#11$1"}}, {"id": 209, "prop": "name", "attributes": {"content": "不不不！您一定是誤會我的意思了！", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#11$1"}, {"id": 210, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 211, "prop": "name", "attributes": {"content": "您知道的，拜訪您的封地，對我來說是再好不過的美差。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 212, "prop": "name", "attributes": {"content": "我來到這裡，只是想向您請願，能否允許這些礦石病專家，與我一同去礦區查明感染者的異狀呢？", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 213, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#1$1"}}, {"id": 214, "prop": "name", "attributes": {"content": "……", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 215, "prop": "Dialog", "attributes": {}}, {"id": 216, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 217, "prop": "Decision", "attributes": {"options": "兩位，能否容我插一句話？", "values": "1"}, "targetLine": {"option1": "line218"}}, {"id": 218, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 219, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#1$1"}}, {"id": 220, "prop": "name", "attributes": {"content": "見諒，尊敬的客人，請說吧。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 221, "prop": "Dialog", "attributes": {}}, {"id": 222, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 223, "prop": "Decision", "attributes": {"options": "我希望說明羅德島的立場。", "values": "1"}, "targetLine": {"option1": "line224"}}, {"id": 224, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 225, "prop": "Decision", "attributes": {"options": "羅德島只是一家嘗試解決感染者問題的醫藥公司。;我們擔憂失聯的朋友的安危，需要儘快找到他們。", "values": "1;2"}, "targetLine": {"option1": "line226", "option2": "line226"}}, {"id": 226, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 227, "prop": "Decision", "attributes": {"options": "對於其他的事，羅德島不會，也無從插手。", "values": "1"}, "targetLine": {"option1": "line228"}}, {"id": 228, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 229, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#1$1"}}, {"id": 230, "prop": "name", "attributes": {"content": "雖然剛才沒有問起，但是我不得不好奇——", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 231, "prop": "name", "attributes": {"content": "您的同伴，又是為何前往中心礦區的呢？", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 232, "prop": "Dialog", "attributes": {}}, {"id": 233, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 234, "prop": "Decision", "attributes": {"options": "他們去那裡蒐集礦石病的病例。;他們是烏薩斯人。", "values": "1;2"}, "targetLine": {"option1": "line235", "option2": "line235"}}, {"id": 235, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 236, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#1$1"}}, {"id": 237, "prop": "name", "attributes": {"content": "哦……", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 238, "prop": "Dialog", "attributes": {}}, {"id": 239, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 240, "prop": "Decision", "attributes": {"options": "羅德島的目的很純粹。", "values": "1"}, "targetLine": {"option1": "line241"}}, {"id": 241, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 242, "prop": "Decision", "attributes": {"options": "畢竟，羅德島的背後沒有任何勢力。;畢竟，羅德島對這裡一無所知。", "values": "1;2"}, "targetLine": {"option1": "line243", "option2": "line246"}}, {"id": 243, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false, "targetLine": "line249"}, {"id": 244, "prop": "name", "attributes": {"content": "話音剛落，你突然意識到過於直白的話語反而讓承諾顯得不可信，但這樣輕率的表態又很難讓人懷疑背後有所陰私。"}}, {"id": 245, "prop": "name", "attributes": {"content": "女大公的表情帶著一絲玩味。"}}, {"id": 246, "prop": "Predicate", "attributes": {"references": "2"}, "endOfOpt": false, "targetLine": "line249"}, {"id": 247, "prop": "name", "attributes": {"content": "一直認真聽著你說話的女大公，終於在此時表現出了一絲鬆動。"}}, {"id": 248, "prop": "name", "attributes": {"content": "她臉上的表情變化十分地克制，但你似乎能感覺到她的眼神的確緩和了幾分。"}}, {"id": 249, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": true}, {"id": 250, "prop": "Dialog", "attributes": {}}, {"id": 251, "prop": "Decision", "attributes": {"options": "總之，一切都只是為了找到我們的同伴。;這是我們僅有的訴求。", "values": "1;2"}, "targetLine": {"option1": "line252", "option2": "line252"}}, {"id": 252, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 253, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#1$1"}}, {"id": 254, "prop": "name", "attributes": {"content": "一邊是我關懷的後輩，一邊是只是想找回同伴的礦石病醫生……", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 255, "prop": "name", "attributes": {"content": "如果我再拒絕的話，是否會顯得我過於不近人情了呢？", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 256, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 257, "prop": "name", "attributes": {"content": "我很明白，您只是在擔憂遠道而來的朋友，害怕他們會陷入危險。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 258, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#1$1"}}, {"id": 259, "prop": "name", "attributes": {"content": "我當然不希望有任何人在這片土地上遭遇不幸，如果我有足夠的時間，我情願為每一個凍土之上的人送去火爐。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 260, "prop": "name", "attributes": {"content": "阿洛達，你願意保證，會儘力保障朋友的安全嗎？", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 261, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 262, "prop": "name", "attributes": {"content": "……懇請您相信。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 263, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#1$1"}}, {"id": 264, "prop": "name", "attributes": {"content": "好，好。Dr.{@nickname}，去吧，去找回你的同伴。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 265, "prop": "name", "attributes": {"content": "我准許羅德島在遠北礦區通行。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 266, "prop": "Dialog", "attributes": {}}, {"id": 267, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 268, "prop": "Decision", "attributes": {"options": "謝謝您的仁慈。", "values": "1"}, "targetLine": {"option1": "line269"}}, {"id": 269, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 270, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1962_1#1$1"}}, {"id": 271, "prop": "name", "attributes": {"content": "我希望我的確是仁慈的，可是真的很少有人會感謝他人的仁慈。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 272, "prop": "name", "attributes": {"content": "人們會敬畏將權利從他們手中奪走的人，又會對將其中一部分權利歸還給他們的人感恩戴德。但我想，這無論如何都稱不上是仁慈。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 273, "prop": "name", "attributes": {"content": "遠北的風很冷，請準備好禦寒的衣服，Dr.{@nickname}。", "name": "葉莉莎女大公"}, "figure_art": "avg_npc_1962_1#1$1"}, {"id": 274, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 275, "prop": "Dialog", "attributes": {}}, {"id": 276, "prop": "StopSound", "attributes": {"channel": "bgs", "fadetime": 2.0}}, {"id": 277, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 278, "prop": "charslot", "attributes": {}}, {"id": 279, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 280, "prop": "Background", "attributes": {"image": "66_g1_bleskstreet", "screenadapt": "coverall"}}, {"id": 281, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 282, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 283, "prop": "playMusic", "attributes": {"intro": "$darkness01_intro", "key": "$darkness01_loop", "volume": 0.6}}, {"id": 284, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1037_amiya3_1#8$1", "duration": 0.5}}, {"id": 285, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 286, "prop": "name", "attributes": {"content": "博士，你們出來了！", "name": "阿米婭"}, "figure_art": "avg_1037_amiya3_1#8$1"}, {"id": 287, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 288, "prop": "name", "attributes": {"content": "呃……也不用這麼激動吧，阿米婭小姐。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 289, "prop": "name", "attributes": {"content": "這裡是布列斯克的行政中樞，又不是什麼魔窟——我們聊得還算順利，對嗎？", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 290, "prop": "Dialog", "attributes": {}}, {"id": 291, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 292, "prop": "Dialog", "attributes": {}}, {"id": 293, "prop": "Decision", "attributes": {"options": "非常順利。;有一些意外的插曲。", "values": "1;2"}, "targetLine": {"option1": "line294", "option2": "line294"}}, {"id": 294, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 295, "prop": "Decision", "attributes": {"options": "你還是有所隱瞞。;無論是對我們，還是對那位女大公。", "values": "1;2"}, "targetLine": {"option1": "line296", "option2": "line296"}}, {"id": 296, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 297, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#2$1"}}, {"id": 298, "prop": "name", "attributes": {"content": "好吧，我承認。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#2$1"}, {"id": 299, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 300, "prop": "name", "attributes": {"content": "但這的確是我能創造的最理想的對話機會了。就結果而言，還不錯吧？", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 301, "prop": "Dialog", "attributes": {}}, {"id": 302, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 303, "prop": "Decision", "attributes": {"options": "那位女大公……", "values": "1"}, "targetLine": {"option1": "line304"}}, {"id": 304, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 305, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 306, "prop": "name", "attributes": {"content": "怎麼了？", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 307, "prop": "Dialog", "attributes": {}}, {"id": 308, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 309, "prop": "Decision", "attributes": {"options": "和我的預期有點不同。", "values": "1"}, "targetLine": {"option1": "line310"}}, {"id": 310, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 311, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 312, "prop": "name", "attributes": {"content": "哦？你預期的是什麼樣子的？", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 313, "prop": "Dialog", "attributes": {}}, {"id": 314, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 315, "prop": "Decision", "attributes": {"options": "更冷酷。;更難以說服。", "values": "1;2"}, "targetLine": {"option1": "line316", "option2": "line323"}}, {"id": 316, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false, "targetLine": "line330"}, {"id": 317, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 318, "prop": "name", "attributes": {"content": "如果只針對她處理異常事務的手段，那你這麼說也沒錯。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 319, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#3$1"}}, {"id": 320, "prop": "name", "attributes": {"content": "異變發生之後，相關感染者立刻被送往礦區研究所進行管控，她還要求研究員們在一週之內查明原因，否則就會被流放或驅逐。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#3$1"}, {"id": 321, "prop": "name", "attributes": {"content": "隨後她又宣布遠北地區戒嚴，將礦工全部封鎖在礦區內，封鎖所有通訊手段，使外界得不到半點消息。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#3$1"}, {"id": 322, "prop": "name", "attributes": {"content": "高效，卻也算得上冷酷。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#3$1"}, {"id": 323, "prop": "Predicate", "attributes": {"references": "2"}, "endOfOpt": false, "targetLine": "line330"}, {"id": 324, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 325, "prop": "name", "attributes": {"content": "只要你能一針見血地指出她想迴避或隱藏的內容，想說服她就不算困難。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 326, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#3$1"}}, {"id": 327, "prop": "name", "attributes": {"content": "問題在於，很多時候，你可能都會被她蒙在鼓裡，找不到那些切入點。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#3$1"}, {"id": 328, "prop": "name", "attributes": {"content": "比如那些感染者。他們發生的是病理性異變，是某種礦石病的新病徵，還是其他呢？", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#3$1"}, {"id": 329, "prop": "name", "attributes": {"content": "沒有更多細節，這就是問題所在。消息傳到聖駿堡時內容只有這麼多——感染者一發生異變就立刻被送往礦區研究所進行管控了。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#3$1"}, {"id": 330, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": true}, {"id": 331, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#4$1"}}, {"id": 332, "prop": "name", "attributes": {"content": "我看過你們羅德島發表的那篇關於源石變化和礦石病新病徵的論文，烏薩斯各地的研究所也都已經參考該論文開始展開研究。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#4$1"}, {"id": 333, "prop": "name", "attributes": {"content": "如果是論文中提及的變異情況，不至於引起這樣的反應。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#4$1"}, {"id": 334, "prop": "name", "attributes": {"content": "礦區發生的感染者異變極有可能代表某種全新的威脅出現了。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#4$1"}, {"id": 335, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1037_amiya3_1#6$1"}}, {"id": 336, "prop": "name", "attributes": {"content": "全新的威脅……", "name": "阿米婭"}, "figure_art": "avg_1037_amiya3_1#6$1"}, {"id": 337, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#4$1"}}, {"id": 338, "prop": "name", "attributes": {"content": "研究所著手查明原因，礦區整體戒嚴，所有礦工全部隔離。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#4$1"}, {"id": 339, "prop": "name", "attributes": {"content": "這樣，大家就覺得事情已經解決了，但實際上呢？", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#4$1"}, {"id": 340, "prop": "name", "attributes": {"content": "事發以來，礦區作業停止，通訊中斷，聖駿堡的追問卻遲遲沒有得到回應。沒人能夠，也沒人膽敢深入其中。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#4$1"}, {"id": 341, "prop": "Dialog", "attributes": {}}, {"id": 342, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 343, "prop": "Decision", "attributes": {"options": "但如果你說的這位女大公有心隱瞞……;那我們從一開始就進不了布列斯克。", "values": "1;2"}, "targetLine": {"option1": "line344", "option2": "line344"}}, {"id": 344, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 345, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#4$1"}}, {"id": 346, "prop": "name", "attributes": {"content": "你已經見過她了，或許會以為她其實算得上是一位“仁慈”的管理者。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#4$1"}, {"id": 347, "prop": "name", "attributes": {"content": "她當然會讓我們進來，畢竟這裡是“烏薩斯境內對感染者最友好的地界”、“遠北明珠”、“烏薩斯北方的天堂”——", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#4$1"}, {"id": 348, "prop": "name", "attributes": {"content": "布列潔諾伊的首府，布列斯克。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#4$1"}, {"id": 349, "prop": "name", "attributes": {"content": "除了看起來人煙稀少外，這兩天你們沒在城裡發現任何異常，這就是她治理遠北的方式。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#4$1"}, {"id": 350, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#5$1"}}, {"id": 351, "prop": "name", "attributes": {"content": "就像從她上任總督之後，轄區內從未有人被判處死刑，但這裡枉死的人因此減少了嗎？從未。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#5$1"}, {"id": 352, "prop": "Dialog", "attributes": {}}, {"id": 353, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 354, "prop": "Decision", "attributes": {"options": "你好像對她有很大的意見。", "values": "1"}, "targetLine": {"option1": "line355"}}, {"id": 355, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 356, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 357, "prop": "name", "attributes": {"content": "哦，這你就錯怪我了。我發誓剛才的評論沒有夾雜任何私人的感情，只是有問必答罷了。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 358, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 359, "prop": "name", "attributes": {"content": "畢竟我們要合作，不是嗎？", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 360, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1037_amiya3_1#1$1"}}, {"id": 361, "prop": "name", "attributes": {"content": "我明白了，阿洛伊澤小姐。那麼這些異變感染者如今還處在礦區研究所的管控之下嗎？", "name": "阿米婭"}, "figure_art": "avg_1037_amiya3_1#1$1"}, {"id": 362, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 363, "prop": "name", "attributes": {"content": "沒錯。準確地說，他們是在遠北中心礦區研究所。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 364, "prop": "Dialog", "attributes": {}}, {"id": 365, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 366, "prop": "Decision", "attributes": {"options": "那是不是……？;……", "values": "1;2"}, "targetLine": {"option1": "line367", "option2": "line367"}}, {"id": 367, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 368, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1037_amiya3_1#5$1"}}, {"id": 369, "prop": "name", "attributes": {"content": "那也是我們要去的第一站。", "name": "阿米婭"}, "figure_art": "avg_1037_amiya3_1#5$1"}, {"id": 370, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 371, "prop": "name", "attributes": {"content": "是這樣嗎？如果目的地本來就相同，那就好辦了。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 372, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 373, "prop": "name", "attributes": {"content": "你們還有什麼想問的嗎？", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 374, "prop": "Dialog", "attributes": {}}, {"id": 375, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 376, "prop": "Decision", "attributes": {"options": "你很真誠。;你很急切。", "values": "1;2"}, "targetLine": {"option1": "line377", "option2": "line377"}}, {"id": 377, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 378, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 379, "prop": "name", "attributes": {"content": "沒錯，所以一開始我就沒打算跟你們拐彎抹角。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 380, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1037_amiya3_1#1$1"}}, {"id": 381, "prop": "name", "attributes": {"content": "阿洛伊澤小姐，我還有一個問題。", "name": "阿米婭"}, "figure_art": "avg_1037_amiya3_1#1$1"}, {"id": 382, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 383, "prop": "name", "attributes": {"content": "請說。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 384, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1037_amiya3_1#1$1"}}, {"id": 385, "prop": "name", "attributes": {"content": "先前在您朋友家裡，我們的交談結束得很匆忙。這個問題是我一開始就應該詢問的，卻一直沒有找到機會。", "name": "阿米婭"}, "figure_art": "avg_1037_amiya3_1#1$1"}, {"id": 386, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1037_amiya3_1#6$1"}}, {"id": 387, "prop": "name", "attributes": {"content": "就您個人而言，您想從這場調查中，得到怎樣的結果呢？", "name": "阿米婭"}, "figure_art": "avg_1037_amiya3_1#6$1"}, {"id": 388, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#1$1"}}, {"id": 389, "prop": "name", "attributes": {"content": "……認真地說？", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#1$1"}, {"id": 390, "prop": "Dialog", "attributes": {}}, {"id": 391, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#3$1"}}, {"id": 392, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 393, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#10$1"}}, {"id": 394, "prop": "name", "attributes": {"content": "我想要一個真相，一個關於中心礦區感染者異變的真相。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#10$1"}, {"id": 395, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#4$1"}}, {"id": 396, "prop": "name", "attributes": {"content": "我不希望感染者礦工無故受難，也不希望烏薩斯人民對可能發生的災難一無所知。", "name": "阿洛伊澤"}, "figure_art": "avg_npc_1966_1#4$1"}, {"id": 397, "prop": "Dialog", "attributes": {}}, {"id": 398, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 399, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 400, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 401, "prop": "hidecgitem", "attributes": {}}, {"id": 402, "prop": "Image", "attributes": {}}, {"id": 403, "prop": "charslot", "attributes": {}}, {"id": 404, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}