g_npc_242"}}, {"id": 226, "prop": "name", "attributes": {"content": "這是我們的家，該滾的不是我們！", "name": "憤怒的男性"}, "figure_art": "avg_npc_242"}, {"id": 227, "prop": "Character", "attributes": {"name": "avg_npc_241"}}, {"id": 228, "prop": "name", "attributes": {"content": "——誰敢這麼說話？", "name": "維多利亞士兵"}, "figure_art": "avg_npc_241"}, {"id": 229, "prop": "dialog", "attributes": {}}, {"id": 230, "prop": "PlaySound", "attributes": {"key": "$fightgeneral", "volume": 0.2}}, {"id": 231, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 232, "prop": "characteraction", "attributes": {"name": "middle", "type": "jump", "power": 10.0, "times": 2.0, "fadetime": 0.51, "block": "true"}}, {"id": 233, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 234, "prop": "Character", "attributes": {"name": "avg_npc_241"}}, {"id": 235, "prop": "name", "attributes": {"content": "什麼東西......爛菜葉？", "name": "維多利亞士兵"}, "figure_art": "avg_npc_241"}, {"id": 236, "prop": "Character", "attributes": {"name": "avg_npc_241"}}, {"id": 237, "prop": "name", "attributes": {"content": "給我出來！", "name": "維多利亞士兵"}, "figure_art": "avg_npc_241"}, {"id": 238, "prop": "PlaySound", "attributes": {"key": "$fightgeneral", "volume": 0.2}}, {"id": 239, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 240, "prop": "characteraction", "attributes": {"name": "middle", "type": "jump", "power": 10.0, "times": 2.0, "fadetime": 0.51, "block": "true"}}, {"id": 241, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 242, "prop": "Character", "attributes": {"name": "avg_npc_241"}}, {"id": 243, "prop": "name", "attributes": {"content": "這群塔拉渣滓，看我不——", "name": "維多利亞士兵"}, "figure_art": "avg_npc_241"}, {"id": 244, "prop": "Dialog", "attributes": {}}, {"id": 245, "prop": "Character", "attributes": {}}, {"id": 246, "prop": "Character", "attributes": {"name": "char_empty", "name2": "avg_npc_241"}}, {"id": 247, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 0.2}}, {"id": 248, "prop": "characteraction", "attributes": {"name": "left", "type": "move", "fadetime": 0.3, "block": "true"}}, {"id": 249, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 250, "prop": "characteraction", "attributes": {"name": "left", "type": "move", "xpos": 200.0, "fadetime": 1.0, "block": "false"}}, {"id": 251, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "avg_npc_241", "fadetime": 0.7}}, {"id": 252, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 253, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "avg_npc_241", "focus": 1.0}}, {"id": 254, "prop": "name", "attributes": {"content": "在街道上舉弩箭，真的很危險欸！", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#2"}, {"id": 255, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "avg_npc_241", "focus": 2.0}}, {"id": 256, "prop": "name", "attributes": {"content": "......你是誰？", "name": "維多利亞士兵"}, "figure_art": "avg_npc_241"}, {"id": 257, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#8", "name2": "avg_npc_241", "focus": 1.0}}, {"id": 258, "prop": "name", "attributes": {"content": "啊，我有軍令在身，來調查案件的。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#8"}, {"id": 259, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#8", "name2": "avg_npc_241", "focus": 2.0}}, {"id": 260, "prop": "name", "attributes": {"content": "你是來查酒吧謀殺案的嗎？", "name": "維多利亞士兵"}, "figure_art": "avg_npc_241"}, {"id": 261, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "avg_npc_241", "focus": 1.0}}, {"id": 262, "prop": "name", "attributes": {"content": "呃，什麼謀殺？", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#2"}, {"id": 263, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "avg_npc_241", "focus": 2.0}}, {"id": 264, "prop": "name", "attributes": {"content": "就這群渣滓，殺了我們好幾個人。", "name": "維多利亞士兵"}, "figure_art": "avg_npc_241"}, {"id": 265, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "avg_npc_241", "focus": 1.0}}, {"id": 266, "prop": "name", "attributes": {"content": "......達米安·巴里？", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#2"}, {"id": 267, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "avg_npc_241", "focus": 2.0}}, {"id": 268, "prop": "name", "attributes": {"content": "對了，我聽說他已經被處死了，這麼說，這人是你們抓的？挺好，謝謝你了。", "name": "維多利亞士兵"}, "figure_art": "avg_npc_241"}, {"id": 269, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#7", "name2": "avg_npc_241", "focus": 1.0}}, {"id": 270, "prop": "name", "attributes": {"content": "我們抓他的時候還不知道......難道他真的是鬼魂部隊的人？呃......算了。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#7"}, {"id": 271, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#7", "name2": "avg_npc_241", "focus": 2.0}}, {"id": 272, "prop": "name", "attributes": {"content": "管他什麼來頭，死了都是活該！", "name": "維多利亞士兵"}, "figure_art": "avg_npc_241"}, {"id": 273, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#7", "name2": "avg_npc_241", "focus": 2.0}}, {"id": 274, "prop": "name", "attributes": {"content": "都聽見沒？不許——聚集！凡是暗地裡搞什麼集會的，全部按嫌犯處置！", "name": "維多利亞士兵"}, "figure_art": "avg_npc_241"}, {"id": 275, "prop": "dialog", "attributes": {}}, {"id": 276, "prop": "PlaySound", "attributes": {"key": "$fightgeneral", "volume": 0.2}}, {"id": 277, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 278, "prop": "characteraction", "attributes": {"name": "right", "type": "jump", "power": 10.0, "times": 2.0, "fadetime": 0.51, "block": "true"}}, {"id": 279, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 280, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#7", "name2": "avg_npc_241", "focus": 2.0}}, {"id": 281, "prop": "name", "attributes": {"content": "你們*維多利亞粗口*——", "name": "維多利亞士兵"}, "figure_art": "avg_npc_241"}, {"id": 282, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "avg_npc_241", "focus": 1.0}}, {"id": 283, "prop": "name", "attributes": {"content": "別、別衝動啊！我看他們中的大部分都是普通市民，親人死了，他們聚在一起悼念他，這是人之常情。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#2"}, {"id": 284, "prop": "PlaySound", "attributes": {"key": "$fightgeneral", "volume": 0.2}}, {"id": 285, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 286, "prop": "characteraction", "attributes": {"name": "left", "type": "jump", "power": 10.0, "times": 2.0, "fadetime": 0.51, "block": "true"}}, {"id": 287, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 288, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "avg_npc_241", "focus": 1.0}}, {"id": 289, "prop": "name", "attributes": {"content": "呃——爛、爛馬鈴薯？", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#2"}, {"id": 290, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "avg_npc_241", "focus": 2.0}}, {"id": 291, "prop": "name", "attributes": {"content": "哈哈，瞧啊，你還替他們說話，也挨打了吧？", "name": "維多利亞士兵"}, "figure_art": "avg_npc_241"}, {"id": 292, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "avg_npc_241", "focus": 2.0}}, {"id": 293, "prop": "name", "attributes": {"content": "這地方你愛待就待，我只要確保這群渣滓老老實實不鬧事就行，領到這巡邏任務也算我倒楣。", "name": "維多利亞士兵"}, "figure_art": "avg_npc_241"}, {"id": 294, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "avg_npc_241", "focus": 2.0}}, {"id": 295, "prop": "name", "attributes": {"content": "渣滓們，再說一遍，不許聚集！！", "name": "維多利亞士兵"}, "figure_art": "avg_npc_241"}, {"id": 296, "prop": "dialog", "attributes": {}}, {"id": 297, "prop": "PlaySound", "attributes": {"key": "$d_avg_policewhistle", "volume": 0.8}}, {"id": 298, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 0.6}}, {"id": 299, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "xpos": 300.0, "fadetime": 2.0, "block": "false"}}, {"id": 300, "prop": "character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "char_empty", "fadetime": 0.5}}, {"id": 301, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 302, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#5"}}, {"id": 303, "prop": "name", "attributes": {"content": "我......", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#5"}, {"id": 304, "prop": "PlaySound", "attributes": {"key": "$fightgeneral", "volume": 0.3}}, {"id": 305, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 306, "prop": "characteraction", "attributes": {"name": "middle", "type": "jump", "power": 10.0, "times": 2.0, "fadetime": 0.51, "block": "true"}}, {"id": 307, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 308, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#4"}}, {"id": 309, "prop": "name", "attributes": {"content": "唉，爛菜葉子越來越多了......", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#4"}, {"id": 310, "prop": "Character", "attributes": {"name": "avg_479_sleach_1#8$1"}}, {"id": 311, "prop": "name", "attributes": {"content": "這邊走。", "name": "簡妮"}, "figure_art": "avg_479_sleach_1#8$1"}, {"id": 312, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2"}}, {"id": 313, "prop": "name", "attributes": {"content": "欸欸？", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#2"}, {"id": 314, "prop": "dialog", "attributes": {}}, {"id": 315, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 0.6}}, {"id": 316, "prop": "character", "attributes": {"fadetime": 1.5}}, {"id": 317, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 318, "prop": "Dialog", "attributes": {}}, {"id": 319, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 320, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 321, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 322, "prop": "Character", "attributes": {}}, {"id": 323, "prop": "Background", "attributes": {"image": "21_G2_opera_room", "screenadapt": "coverall"}}, {"id": 324, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 325, "prop": "playMusic", "attributes": {"intro": "$nervous_intro", "key": "$nervous_loop", "volume": 0.4}}, {"id": 326, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 327, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 328, "prop": "PlaySound", "attributes": {"key": "$d_gen_transmissionget", "volume": 1.0}}, {"id": 329, "prop": "name", "attributes": {"content": "“報告，第九防衛隊遇襲......”"}}, {"id": 330, "prop": "PlaySound", "attributes": {"key": "$transmission", "volume": 1.0}}, {"id": 331, "prop": "name", "attributes": {"content": "“報告，第十三防衛隊正在交火......”"}}, {"id": 332, "prop": "dialog", "attributes": {}}, {"id": 333, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_241", "fadetime": 0.7}}, {"id": 334, "prop": "delay", "attributes": {"time": 0.7}}, {"id": 335, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_241", "focus": 1.0}}, {"id": 336, "prop": "name", "attributes": {"content": "麻煩再通報一次，我要見漢密爾頓上校。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 337, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_241", "focus": 2.0}}, {"id": 338, "prop": "name", "attributes": {"content": "上校在處理一些緊急事務。", "name": "維多利亞士兵"}, "figure_art": "avg_npc_241"}, {"id": 339, "prop": "Character", "attributes": {"name": "avg_npc_229_1#7", "name2": "avg_npc_241", "focus": 1.0}}, {"id": 340, "prop": "name", "attributes": {"content": "兩個小時前你就是這麼說的。", "name": "號角"}, "figure_art": "avg_npc_229_1#7"}, {"id": 341, "prop": "name", "attributes": {"content": "我們已經嚴格按照流程，在昨天剛進入小丘郡時就提交了任務說明。", "name": "號角"}, "figure_art": "avg_npc_229_1#7"}, {"id": 342, "prop": "name", "attributes": {"content": "上校不讓我們參與對嫌疑人的審訊，又將嫌疑人提前處決，眼下還拒絕我的會面請求——", "name": "號角"}, "figure_art": "avg_npc_229_1#7"}, {"id": 343, "prop": "name", "attributes": {"content": "換作旁人，恐怕會把這一系列行為視作有意阻撓我們執行軍令吧？", "name": "號角"}, "figure_art": "avg_npc_229_1#7"}, {"id": 344, "prop": "Character", "attributes": {"name": "avg_npc_229_1#7", "name2": "avg_npc_241", "focus": 2.0}}, {"id": 345, "prop": "name", "attributes": {"content": "我無權回答你的問題，中尉。", "name": "維多利亞士兵"}, "figure_art": "avg_npc_241"}, {"id": 346, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_241", "focus": 1.0}}, {"id": 347, "prop": "name", "attributes": {"content": "沒關係，我說我的，有人聽著就行。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 348, "prop": "name", "attributes": {"content": "我說過了，這批失竊的源石製品數目不小，足以武裝一支能攻下一座小型城鎮的軍隊，或者炸掉支撐一座中型移動城市的履帶。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 349, "prop": "name", "attributes": {"content": "誰會想得到這批源石製品？", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 350, "prop": "name", "attributes": {"content": "普通的盜匪可不想要，偷渡成本太高。這麼大批量的維多利亞軍用品，就連受到哥倫比亞保護的最大的薩爾貢黑市都不敢提供交易管道。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 351, "prop": "name", "attributes": {"content": "剩下的還有誰？在本地賺取一些中間改造費用的私人武器商？他們沒這個胃口，更沒這個膽子。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 352, "prop": "name", "attributes": {"content": "敢拿著這批東西，還能避開我們的眼線的，只有一支訓練有素、深諳軍方運作模式的部隊。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 353, "prop": "name", "attributes": {"content": "這支部隊拿到了這麼大量的源石製品，他們的目的是什麼？", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 354, "prop": "name", "attributes": {"content": "是陰謀顛覆，還是仗著遠離倫蒂尼姆，想借機監守自盜、勾結外部勢力，以細水長流的方式中飽私囊？", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 355, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_241", "focus": 2.0}}, {"id": 356, "prop": "name", "attributes": {"content": "中尉......", "name": "維多利亞士兵"}, "figure_art": "avg_npc_241"}, {"id": 357, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_241", "focus": 1.0}}, {"id": 358, "prop": "name", "attributes": {"content": "你不用這麼慌，這只是毫無根據的推理，誰讓我現在乾等著，什麼事都做不了。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 359, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_241", "focus": 2.0}}, {"id": 360, "prop": "PlaySound", "attributes": {"key": "$transmission", "volume": 1.0}}, {"id": 361, "prop": "name", "attributes": {"content": "（低聲通訊）", "name": "維多利亞士兵"}, "figure_art": "avg_npc_241"}, {"id": 362, "prop": "dialog", "attributes": {}}, {"id": 363, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 364, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_241", "focus": 2.0}}, {"id": 365, "prop": "name", "attributes": {"content": "中尉，上校說他馬上就到。", "name": "維多利亞士兵"}, "figure_art": "avg_npc_241"}, {"id": 366, "prop": "Dialog", "attributes": {}}, {"id": 367, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 368, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 369, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 370, "prop": "Character", "attributes": {}}, {"id": 371, "prop": "Image", "attributes": {}}, {"id": 372, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}