e": "avg_npc_410_1#1$1", "fadetime": 0.3}}, {"id": 421, "prop": "name", "attributes": {"content": "原來如此。", "name": "血魔大君"}, "figure_art": "avg_npc_410_1#1$1"}, {"id": 422, "prop": "name", "attributes": {"content": "除了那位充當先鋒的刺客，你還帶著一位臣子與你同行。", "name": "血魔大君"}, "figure_art": "avg_npc_410_1#1$1"}, {"id": 423, "prop": "dialog", "attributes": {}}, {"id": 424, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 425, "prop": "character", "attributes": {"name": "avg_npc_650_1#1$1", "fadetime": 1.5}}, {"id": 426, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 427, "prop": "musicvolume", "attributes": {"volume": 0.4, "fadetime": 1.0}}, {"id": 428, "prop": "name", "attributes": {"content": "......我是阿米婭的下屬，卻並非她的附臣。", "name": "Logos"}, "figure_art": "avg_npc_650_1#1$1"}, {"id": 429, "prop": "character", "attributes": {"name": "avg_npc_410_1#1$1"}}, {"id": 430, "prop": "name", "attributes": {"content": "女妖。", "name": "血魔大君"}, "figure_art": "avg_npc_410_1#1$1"}, {"id": 431, "prop": "name", "attributes": {"content": "莫非你膽怯了？", "name": "血魔大君"}, "figure_art": "avg_npc_410_1#1$1"}, {"id": 432, "prop": "name", "attributes": {"content": "你以為......躲在那個名為羅德島的殼子裡，就能否認自己與這贗品的關係，躲過卡茲戴爾對叛徒的審判？", "name": "血魔大君"}, "figure_art": "avg_npc_410_1#1$1"}, {"id": 433, "prop": "character", "attributes": {"name": "avg_npc_650_1#1$1"}}, {"id": 434, "prop": "name", "attributes": {"content": "你的言辭總是充滿謬誤，血魔。", "name": "Logos"}, "figure_art": "avg_npc_650_1#1$1"}, {"id": 435, "prop": "name", "attributes": {"content": "從決定前來倫蒂尼姆的那一刻起，我便已暫時脫下羅德島的精英幹員制服。", "name": "Logos"}, "figure_art": "avg_npc_650_1#1$1"}, {"id": 436, "prop": "name", "attributes": {"content": "我是女妖之主。", "name": "Logos"}, "figure_art": "avg_npc_650_1#1$1"}, {"id": 437, "prop": "name", "attributes": {"content": "我於此言語，即是喪鐘的王庭。", "name": "Logos"}, "figure_art": "avg_npc_650_1#1$1"}, {"id": 438, "prop": "Character", "attributes": {"fadetime": 0.5}}, {"id": 439, "prop": "name", "attributes": {"content": "年輕的女妖抬起手。"}}, {"id": 440,