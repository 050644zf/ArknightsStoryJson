": "野心勃勃的男爵"}, "figure_art": "avg_npc_177"}, {"id": 154, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "avg_npc_229_1#4", "focus": 1.0}}, {"id": 155, "prop": "name", "attributes": {"content": " 你們不是一夥的嗎？你什麼都不知道就敢把人領進家門？！", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#2"}, {"id": 156, "prop": "Character", "attributes": {"name": "avg_npc_177"}}, {"id": 157, "prop": "name", "attributes": {"content": " 她是......公爵的客......", "name": "野心勃勃的男爵"}, "figure_art": "avg_npc_177"}, {"id": 158, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "avg_npc_229_1#7", "focus": 2.0}}, {"id": 159, "prop": "name", "attributes": {"content": " ......公爵？哪一個？！", "name": "號角"}, "figure_art": "avg_npc_229_1#7"}, {"id": 160, "prop": "Character", "attributes": {"name": "avg_npc_177"}}, {"id": 161, "prop": "name", "attributes": {"content": " 我不能......", "name": "野心勃勃的男爵"}, "figure_art": "avg_npc_177"}, {"id": 162, "prop": "dialog", "attributes": {}}, {"id": 163, "prop": "PlaySound", "attributes": {"key": "$e_atk_arrow_h", "volume": 0.7}}, {"id": 164, "prop": "delay", "attributes": {"time": 0.7}}, {"id": 165, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 166, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.03, "block": "true"}}, {"id": 167, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 40.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 168, "prop": "PlaySound", "attributes": {"key": "$fightgeneral", "volume": 0.2}}, {"id": 169, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 170, "prop": "Dialog", "attributes": {}}, {"id": 171, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 172, "prop": "Character", "attributes": {"name": "avg_npc_177"}}, {"id": 173, "prop": "name", "attributes": {"content": " 唔——", "name": "野心勃勃的男爵"}, "figure_art": "avg_npc_177"}, {"id": 174, "prop": "Dialog", "attributes": {}}, {"id": 175, "prop": "delay", "attributes": {"time": 0.7}}, {"id": 176, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown2", "volume": 1.0}}, {"id": 177, "prop": "characteraction", "attributes": {"name": "middle", "type": "move", "fadetime": 2.0, "block": "true"}}, {"id": 178, "prop": "character", "attributes": {"fadetime": 0.5}}, {"id": 179, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 180, "prop": "dialog", "attributes": {}}, {"id": 181, "prop": "character", "attributes": {}}, {"id": 182, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "avg_npc_229_1#1", "focus": 1.0}}, {"id": 183, "prop": "name", "attributes": {"content": " 他......死了？", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#2"}, {"id": 184, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "avg_npc_229_1#1", "focus": 1.0}}, {"id": 185, "prop": "name", "attributes": {"content": " 鬼魂部隊動的手......？", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#2"}, {"id": 186, "prop": "Character", "attributes": {"name": "avg_npc_244"}}, {"id": 187, "prop": "name", "attributes": {"content": "——", "name": "深池士兵"}, "figure_art": "avg_npc_244"}, {"id": 188, "prop": "dialog", "attributes": {}}, {"id": 189, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 190, "prop": "CameraShake", "attributes": {"duration": 1.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 191, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.03, "block": "true"}}, {"id": 192, "prop": "PlaySound", "attributes": {"key": "$e_skill_skulsrsword", "volume": 1.0}}, {"id": 193, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 194, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 195, "prop": "Dialog", "attributes": {}}, {"id": 196, "prop": "delay", "attributes": {"time": 0.7}}, {"id": 197, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown2", "volume": 1.0}}, {"id": 198, "prop": "characteraction", "attributes": {"name": "middle", "type": "move", "fadetime": 2.0, "block": "true"}}, {"id": 199, "prop": "character", "attributes": {"fadetime": 0.5}}, {"id": 200, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 201, "prop": "dialog", "attributes": {}}, {"id": 202, "prop": "character", "attributes": {}}, {"id": 203, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#6", "name2": "avg_npc_229_1#1", "focus": 1.0}}, {"id": 204, "prop": "name", "attributes": {"content": " 他們不是一夥的嗎？鬼魂部隊怎麼專挑自己人下手？", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#6"}, {"id": 205, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#6", "name2": "avg_npc_229_1#1", "focus": 2.0}}, {"id": 206, "prop": "name", "attributes": {"content": " ......先離開這裡。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 207, "prop": "StopSound", "attributes": {"channel": "bgs", "fadetime": 1.0}}, {"id": 208, "prop": "musicvolume", "attributes": {"volume": 0.2, "fadetime": 1.0}}, {"id": 209, "prop": "Dialog", "attributes": {}}, {"id": 210, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 211, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 212, "prop": "character", "attributes": {}}, {"id": 213, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 214, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 215, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 216, "prop": "musicvolume", "attributes": {"volume": 0.4, "fadetime": 1.0}}, {"id": 217, "prop": "Character", "attributes": {"name": "avg_npc_244"}}, {"id": 218, "prop": "name", "attributes": {"content": "你，站住。", "name": "深池士兵"}, "figure_art": "avg_npc_244"}, {"id": 219, "prop": "Character", "attributes": {"name": "avg_npc_090"}}, {"id": 220, "prop": "name", "attributes": {"content": "......", "name": "幹員威爾"}, "figure_art": "avg_npc_090"}, {"id": 221, "prop": "Character", "attributes": {"name": "avg_npc_244"}}, {"id": 222, "prop": "name", "attributes": {"content": "你是什麼人？躲在這裡幹什麼？", "name": "深池士兵"}, "figure_art": "avg_npc_244"}, {"id": 223, "prop": "Character", "attributes": {"name": "avg_npc_090"}}, {"id": 224, "prop": "name", "attributes": {"content": "我那個......我本來只是送個藥......誰知你們打起來了。", "name": "幹員威爾"}, "figure_art": "avg_npc_090"}, {"id": 225, "prop": "Character", "attributes": {"name": "avg_npc_244"}}, {"id": 226, "prop": "name", "attributes": {"content": "送藥？給誰送？給維多利亞士兵？", "name": "深池士兵"}, "figure_art": "avg_npc_244"}, {"id": 227, "prop": "Character", "attributes": {"name": "avg_npc_090"}}, {"id": 228, "prop": "name", "attributes": {"content": "我......呵呵......羅德島的藥，是給感染者用的，我們不關心病人的身份......", "name": "幹員威爾"}, "figure_art": "avg_npc_090"}, {"id": 229, "prop": "Character", "attributes": {"name": "avg_npc_244"}}, {"id": 230, "prop": "name", "attributes": {"content": "行跡可疑。", "name": "深池士兵"}, "figure_art": "avg_npc_244"}, {"id": 231, "prop": "dialog", "attributes": {}}, {"id": 232, "prop": "dialog", "attributes": {}}, {"id": 233, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 234, "prop": "CameraShake", "attributes": {"duration": 1.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 235, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.03, "block": "true"}}, {"id": 236, "prop": "PlaySound", "attributes": {"key": "$fightgeneral", "volume": 0.4}}, {"id": 237, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 238, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 239, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown2", "volume": 1.0}}, {"id": 240, "prop": "characteraction", "attributes": {"name": "middle", "type": "move", "fadetime": 1.0, "block": "true"}}, {"id": 241, "prop": "character", "attributes": {"name": "char_empty", "fadetime": 0.5}}, {"id": 242, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 243, "prop": "dialog", "attributes": {}}, {"id": 244, "prop": "character", "attributes": {}}, {"id": 245, "prop": "Character", "attributes": {"name": "avg_npc_090"}}, {"id": 246, "prop": "name", "attributes": {"content": "啊......！", "name": "幹員威爾"}, "figure_art": "avg_npc_090"}, {"id": 247, "prop": "Character", "attributes": {"name": "avg_npc_245_1#1"}}, {"id": 248, "prop": "name", "attributes": {"content": "沒事了，威爾。", "name": "Outcast"}, "figure_art": "avg_npc_245_1#1"}, {"id": 249, "prop": "Character", "attributes": {"name": "avg_npc_090"}}, {"id": 250, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 251, "prop": "name", "attributes": {"content": "Outcast女士！您、您來得太及時了！", "name": "幹員威爾"}, "figure_art": "avg_npc_090"}, {"id": 252, "prop": "Character", "attributes": {"name": "avg_npc_245_1#1"}}, {"id": 253, "prop": "name", "attributes": {"content": "唉，你收到下午的通訊了吧？羅德島將緊急停止在小丘郡的一切日常業務。", "name": "Outcast"}, "figure_art": "avg_npc_245_1#1"}, {"id": 254, "prop": "Character", "attributes": {"name": "avg_npc_090"}}, {"id": 255, "prop": "name", "attributes": {"content": "收是收到了，但......", "name": "幹員威爾"}, "figure_art": "avg_npc_090"}, {"id": 256, "prop": "Character", "attributes": {"name": "avg_npc_245_1#4"}}, {"id": 257, "prop": "name", "attributes": {"content": "——想把剩下的藥送完？", "name": "Outcast"}, "figure_art": "avg_npc_245_1#4"}, {"id": 258, "prop": "Character", "attributes": {"name": "avg_npc_245_1#6"}}, {"id": 259, "prop": "name", "attributes": {"content": "你是個好孩子。先把藥給我吧，剩下的我替你送。", "name": "Outcast"}, "figure_art": "avg_npc_245_1#6"}, {"id": 260, "prop": "Character", "attributes": {"name": "avg_npc_090"}}, {"id": 261, "prop": "name", "attributes": {"content": "女士，外面到底怎麼回事？一眨眼，到處都在打仗！", "name": "幹員威爾"}, "figure_art": "avg_npc_090"}, {"id": 262, "prop": "Character", "attributes": {"name": "avg_npc_245_1#1"}}, {"id": 263, "prop": "name", "attributes": {"content": "累積了數百年的仇怨被人利用，成了一把試圖摧毀一切的火。", "name": "Outcast"}, "figure_art": "avg_npc_245_1#1"}, {"id": 264, "prop": "Character", "attributes": {"name": "avg_npc_245_1#2"}}, {"id": 265, "prop": "name", "attributes": {"content": "而且，這才剛剛開始。", "name": "Outcast"}, "figure_art": "avg_npc_245_1#2"}, {"id": 266, "prop": "Character", "attributes": {"name": "avg_npc_245_1#1"}}, {"id": 267, "prop": "name", "attributes": {"content": "你趕緊回去吧。既然我在這裡，我最優先要確保的，就是我們羅德島的人，一個都不能少。", "name": "Outcast"}, "figure_art": "avg_npc_245_1#1"}, {"id": 268, "prop": "Character", "attributes": {"name": "avg_npc_090"}}, {"id": 269, "prop": "name", "attributes": {"content": "好的，女士......對了，我剛才在十七區附近還見到了簡小姐......她......她經常來辦事處，我們都當她是半個羅德島幹員！", "name": "幹員威爾"}, "figure_art": "avg_npc_090"}, {"id": 270, "prop": "Character", "attributes": {"name": "avg_npc_090"}}, {"id": 271, "prop": "name", "attributes": {"content": "她是維多利亞士兵，看這群暴徒的意思，他們不會放過她的！", "name": "幹員威爾"}, "figure_art": "avg_npc_090"}, {"id": 272, "prop": "Character", "attributes": {"name": "avg_npc_245_1#1"}}, {"id": 273, "prop": "name", "attributes": {"content": "好。", "name": "Outcast"}, "figure_art": "avg_npc_245_1#1"}, {"id": 274, "prop": "Character", "attributes": {"name": "avg_npc_245_1#7"}}, {"id": 275, "prop": "name", "attributes": {"content": "我修改下剛才那句話——羅德島的人，半個都不能少。", "name": "Outcast"}, "figure_art": "avg_npc_245_1#7"}, {"id": 276, "prop": "Dialog", "attributes": {}}, {"id": 277, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 278, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 279, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 280, "prop": "Character", "attributes": {}}, {"id": 281, "prop": "Background", "attributes": {"image": "21_G3_victoria_street_d", "screenadapt": "coverall"}}, {"id": 282, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 283, "prop": "playMusic", "attributes": {"intro": "$darkness01_intro", "key": "$darkness01_loop", "volume": 0.4}}, {"id": 284, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 285, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 286, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#5", "name2": "avg_npc_229_1#1", "fadetime": 0.7}}, {"id": 287, "prop": "delay", "attributes": {"time": 0.7}}, {"id": 288, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#5", "name2": "avg_npc_229_1#1", "focus": 1.0}}, {"id": 289, "prop": "name", "attributes": {"content": "  隊長，能轉移的人都轉移了。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#5"}, {"id": 290, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#5", "name2": "avg_npc_229_1#1", "focus": 2.0}}, {"id": 291, "prop": "name", "attributes": {"content": "  很好。你有沒有受傷？", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 292, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#7", "name2": "avg_npc_229_1#1", "focus": 1.0}}, {"id": 293, "prop": "name", "attributes": {"content": "  沒有。這一夜交手下來，我算是放心了一點。除了那個領頭的術師，還有幾個厲害角色，剩下的大多數士兵還是普通人。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#7"}, {"id": 294, "prop": "name", "attributes": {"content": "  他們是受過一些訓練，但紀律說不上好。如果人數相當，正面碰上的話，不會是我們小隊的對手。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#7"}, {"id": 295, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#7", "name2": "avg_npc_229_1#1", "focus": 2.0}}, {"id": 296, "prop": "name", "attributes": {"content": "  你也說了前提。而且，他們的主要對手是駐軍。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 297, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#5", "name2": "avg_npc_229_1#1", "focus": 1.0}}, {"id": 298, "prop": "name", "attributes": {"content": "  隊長，你說得對，要和他們打的話，駐軍占不到上風。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#5"}, {"id": 299, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#5", "name2": "avg_npc_229_1#1", "focus": 2.0}}, {"id": 300, "prop": "name", "attributes": {"content": "  還有沒有什麼發現？", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 301, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#5", "name2": "avg_npc_229_1#1", "focus": 1.0}}, {"id": 302, "prop": "name", "attributes": {"content": "  他們的武器裝備都很精良。我剛剛去救那幾個官員和貴族的時候，有人想從拐角處偷襲我，被我敲暈以後，我從他手裡拿了這個回來。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#5"}, {"id": 303, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#5", "name2": "avg_npc_229_1#4", "focus": 2.0}}, {"id": 304, "prop": "name", "attributes": {"content": "  維多利亞制式軍弩？", "name": "號角"}, "figure_art": "avg_npc_229_1#4"}, {"id": 305, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#5", "name2": "avg_npc_229_1#4", "focus": 1.0}}, {"id": 306, "prop": "name", "attributes": {"content": "  是兩年前的型號，不過有改裝，你看這兩個線圈和下面的導軌。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#5"}, {"id": 307, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#5", "name2": "avg_npc_229_1#2", "focus": 2.0}}, {"id": 308, "prop": "name", "attributes": {"content": "  是破盾彈加速裝置。", "name": "號角"}, "figure_art": "avg_npc_229_1#2"}, {"id": 309, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#7", "name2": "avg_npc_229_1#2", "focus": 1.0}}, {"id": 310, "prop": "name", "attributes": {"content": "  我對弩不是很在行，隊長，我沒在軍隊和學校裡見過這個。這是我們的技術嗎？", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#7"}, {"id": 311, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#7", "name2": "avg_npc_229_1#2", "focus": 2.0}}, {"id": 312, "prop": "name", "attributes": {"content": "  不是很像。", "name": "號角"}, "figure_art": "avg_npc_229_1#2"}, {"id": 313, "prop": "name", "attributes": {"content": "  風笛，我是不是遺漏了什麼......我們是來調查源石製品失竊案的，對吧？", "name": "號角"}, "figure_art": "avg_npc_229_1#2"}, {"id": 314, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#5", "name2": "avg_npc_229_1#1", "focus": 1.0}}, {"id": 315, "prop": "name", "attributes": {"content": "  是，毫無疑問，鬼魂部隊想和我們正規軍抗衡，就一定需要大量武器。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#5"}, {"id": 316, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#5", "name2": "avg_npc_229_1#1", "focus": 2.0}}, {"id": 317, "prop": "name", "attributes": {"content": "  但我們手上這把弩透露了很多資訊。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 318, "prop": "name", "attributes": {"content": "  首先，敵人暗中謀劃的時間比我們想得更久；其次，除了從我們手裡搶過去的物資，另外有勢力在長期資助他們的行動。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 319, "prop": "name", "attributes": {"content": "  也就是說，這一回，在這裡，他們並沒有打算拿上新裝備就匆匆上陣。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 320, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "avg_npc_229_1#1", "focus": 1.0}}, {"id": 321, "prop": "name", "attributes": {"content": "  對哦！這麼說的話，最近這批丟了的武器去了哪裡？", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#2"}, {"id": 322, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "avg_npc_229_1#2", "focus": 2.0}}, {"id": 323, "prop": "name", "attributes": {"content": "  你也發現了問題所在——鬼魂部隊終於現身，可消失在小丘郡的源石製品，到現在都沒有露面。", "name": "號角"}, "figure_art": "avg_npc_229_1#2"}, {"id": 324, "prop": "name", "attributes": {"content": "  希望三角鐵找到了一些新的線索。", "name": "號角"}, "figure_art": "avg_npc_229_1#2"}, {"id": 325, "prop": "Dialog", "attributes": {}}, {"id": 326, "prop": "Character", "attributes": {}}, {"id": 327, "prop": "PlaySound", "attributes": {"key": "$d_gen_transmissionget", "volume": 0.6}}, {"id": 328, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 329, "prop": "name", "attributes": {"content": "  （小聲）我在，隊長。", "name": "三角鐵"}}, {"id": 330, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 331, "prop": "name", "attributes": {"content": "  你們小組現在還好嗎？", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 332, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 333, "prop": "name", "attributes": {"content": "  小鼓受了點傷，其他人都還能行動，就是大家都又累又餓，狀態肯定沒那麼好了。", "name": "三角鐵"}, "figure_art": "avg_npc_229_1#1"}, {"id": 334, "prop": "Character", "attributes": {"name": "avg_npc_229_1#4"}}, {"id": 335, "prop": "name", "attributes": {"content": "  你們昨天也參與戰鬥了嗎？", "name": "號角"}, "figure_art": "avg_npc_229_1#4"}, {"id": 336, "prop": "Character", "attributes": {"name": "avg_npc_229_1#4"}}, {"id": 337, "prop": "name", "attributes": {"content": "  是的。昨天傍晚開始，突然有大量敵人湧了出來，他們就跟一直埋伏在大棚和灌溉系統裡似的——", "name": "三角鐵"}, "figure_art": "avg_npc_229_1#4"}, {"id": 338, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 339, "prop": "name", "attributes": {"content": "  看來這就是他們之前的藏身之地了。不熟悉農用地塊的駐軍，很難贏下這場捉迷藏。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 340, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 341, "prop": "name", "attributes": {"content": "  我們和其中一小波打了個照面，我看敵人實在太多，就帶人躲了起來，直到天亮。", "name": "三角鐵"}, "figure_art": "avg_npc_229_1#1"}, {"id": 342, "prop": "Character", "attributes": {"name": "avg_npc_229_1#6"}}, {"id": 343, "prop": "name", "attributes": {"content": "  你做得很好。能回城裡來嗎？", "name": "號角"}, "figure_art": "avg_npc_229_1#6"}, {"id": 344, "prop": "Character", "attributes": {"name": "avg_npc_229_1#6"}}, {"id": 345, "prop": "name", "attributes": {"content": "  哈哈，隊長，有點困難。他們中的一半進了城，另一半仍然到處都是。", "name": "三角鐵"}, "figure_art": "avg_npc_229_1#6"}, {"id": 346, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 347, "prop": "name", "attributes": {"content": "  ......", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 348, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 349, "prop": "name", "attributes": {"content": "  隊長，我們小組一致認為，我們應該繼續最初的任務。", "name": "三角鐵"}, "figure_art": "avg_npc_229_1#1"}, {"id": 350, "prop": "name", "attributes": {"content": "  我們查到了一輛運輸車，你猜得沒錯，確實有人在利用農產品運輸路線把這批源石製品運往某個地方。", "name": "三角鐵"}, "figure_art": "avg_npc_229_1#1"}, {"id": 351, "prop": "name", "attributes": {"content": "  每次都不算多，今天這些很可能是最後一批。", "name": "三角鐵"}, "figure_art": "avg_npc_229_1#1"}, {"id": 352, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 353, "prop": "name", "attributes": {"content": "  今天這些？你們在哪裡？！", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 354, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 355, "prop": "name", "attributes": {"content": "  我們現在就藏在運輸車上。", "name": "三角鐵"}, "figure_art": "avg_npc_229_1#1"}, {"id": 356, "prop": "name", "attributes": {"content": "  隊長，我不敢說太多，怕他們聽見。下次聯絡，你就知道到底誰是小偷了。", "name": "三角鐵"}, "figure_art": "avg_npc_229_1#1"}, {"id": 357, "prop": "Character", "attributes": {"name": "avg_npc_229_1#7"}}, {"id": 358, "prop": "name", "attributes": {"content": "  這太冒險了！", "name": "號角"}, "figure_art": "avg_npc_229_1#7"}, {"id": 359, "prop": "Character", "attributes": {"name": "avg_npc_229_1#7"}}, {"id": 360, "prop": "name", "attributes": {"content": "  哈哈......隊長，你和風笛也要小心。", "name": "三角鐵"}, "figure_art": "avg_npc_229_1#7"}, {"id": 361, "prop": "name", "attributes": {"content": "  三角鐵，通訊完畢。", "name": "三角鐵"}, "figure_art": "avg_npc_229_1#7"}, {"id": 362, "prop": "Dialog", "attributes": {}}, {"id": 363, "prop": "Character", "attributes": {}}, {"id": 364, "prop": "PlaySound", "attributes": {"key": "$d_gen_transmissionget", "volume": 0.6}}, {"id": 365, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 366, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1"}}, {"id": 367, "prop": "name", "attributes": {"content": "  ......", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 368, "prop": "name", "attributes": {"content": "  風笛，馬上通知大提琴，我們這就回軍營。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 369, "prop": "Dialog", "attributes": {}}, {"id": 370, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 371, "prop": "Character", "attributes": {}}, {"id": 372, "prop": "Background", "attributes": {"image": "21_G2_opera_room", "screenadapt": "coverall"}}, {"id": 373, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 374, "prop": "playsound", "attributes": {"key": "$transmission", "volume": 1.0}}, {"id": 375, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 376, "prop": "name", "attributes": {"content": "“......第三到第九城區失守......”"}}, {"id": 377, "prop": "name", "attributes": {"content": "“......市政廳、報社、瑪麗醫院同時遭到敵人攻擊......”"}}, {"id": 378, "prop": "name", "attributes": {"content": "“......波萊男爵的夫人發來急電，她的丈夫於凌晨後失聯，她請求駐軍施以援手......”"}}, {"id": 379, "prop": "dialog", "attributes": {}}, {"id": 380, "prop": "character", "attributes": {}}, {"id": 381, "prop": "name", "attributes": {"content": "  上校！我有話要說。", "name": "號角"}}, {"id": 382, "prop": "Character", "attributes": {"name": "avg_npc_227_1"}}, {"id": 383, "prop": "name", "attributes": {"content": "  讓她進來。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 384, "prop": "dialog", "attributes": {}}, {"id": 385, "prop": "character", "attributes": {}}, {"id": 386, "prop": "PlaySound", "attributes": {"key": "$dooropenquite", "volume": 1.0}}, {"id": 387, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 388, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_227_1", "fadetime": 1.0}}, {"id": 389, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 390, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_227_1", "focus": 2.0}}, {"id": 391, "prop": "name", "attributes": {"content": "  我希望你不是來說廢話的，斯卡曼德羅斯。如你所見，我們的敵人十分猖狂，我沒空再和你爭辯。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 392, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_227_1", "focus": 1.0}}, {"id": 393, "prop": "name", "attributes": {"content": "  上校，敵人躲在農用地塊。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 394, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_227_1#6", "focus": 2.0}}, {"id": 395, "prop": "name", "attributes": {"content": "  什麼？", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1#6"}, {"id": 396, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_227_1#6", "focus": 1.0}}, {"id": 397, "prop": "name", "attributes": {"content": "  他們之前就藏在那裡。而且，現在在城裡的也不是全部，他們還有更多人。", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 398, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_227_1", "focus": 2.0}}, {"id": 399, "prop": "name", "attributes": {"content": "  ......", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 400, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_227_1#5", "focus": 2.0}}, {"id": 401, "prop": "name", "attributes": {"content": "  我就知道。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1#5"}, {"id": 402, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_227_1#5", "focus": 1.0}}, {"id": 403, "prop": "name", "attributes": {"content": "  我建議您馬上派人去農用地塊撤離平民，並儘快實施中央城區和農用地塊的緊急脫鉤，以免讓更多敵人進入城區！", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 404, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_227_1#4", "focus": 2.0}}, {"id": 405, "prop": "name", "attributes": {"content": "  我不用你教我怎麼做。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1#4"}, {"id": 406, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_227_1#4", "focus": 1.0}}, {"id": 407, "prop": "name", "attributes": {"content": "  上校！僅憑駐軍兵力和我們突擊隊的人，對付滲透進城內的敵軍都未必能很快取得勝利，我們必須確保敵人不會再有援軍——", "name": "號角"}, "figure_art": "avg_npc_229_1#1"}, {"id": 408, "prop": "Character", "attributes": {"name": "avg_npc_229_1#1", "name2": "avg_npc_227_1", "focus": 2.0}}, {"id": 409, "prop": "name", "attributes": {"content": "  你走吧。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 410, "prop": "Character", "attributes": {"name": "avg_npc_229_1#4", "name2": "avg_npc_227_1", "focus": 1.0}}, {"id": 411, "prop": "name", "attributes": {"content": "  上校？！", "name": "號角"}, "figure_art": "avg_npc_229_1#4"}, {"id": 412, "prop": "Character", "attributes": {"name": "avg_npc_229_1#4", "name2": "avg_npc_227_1", "focus": 2.0}}, {"id": 413, "prop": "name", "attributes": {"content": "  如何保住小丘郡是我的事。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 414, "prop": "Character", "attributes": {"name": "avg_npc_229_1#7", "name2": "avg_npc_227_1", "focus": 1.0}}, {"id": 415, "prop": "name", "attributes": {"content": "  在捍衛維多利亞國土安全這件首要任務上，我們該站在一起！", "name": "號角"}, "figure_art": "avg_npc_229_1#7"}, {"id": 416, "prop": "Character", "attributes": {"name": "avg_npc_227_1"}}, {"id": 417, "prop": "name", "attributes": {"content": "  希爾，送客。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 418, "prop": "Dialog", "attributes": {}}, {"id": 419, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 420, "prop": "Character", "attributes": {}}, {"id": 421, "prop": "Background", "attributes": {"image": "21_G2_opera_room", "screenadapt": "coverall"}}, {"id": 422, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 423, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 424, "prop": "Character", "attributes": {"name": "avg_npc_227_1#5"}}, {"id": 425, "prop": "name", "attributes": {"content": "  你聽到了嗎，希爾？農用地塊，哈，他們藏在農用地塊！我早該想到了，還有誰會給鬼魂開門？！", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1#5"}, {"id": 426, "prop": "Character", "attributes": {"name": "avg_npc_227_1", "name2": "avg_npc_248", "focus": 2.0}}, {"id": 427, "prop": "name", "attributes": {"content": "  是的，上校，塔拉人在幫他們。", "name": "副官希爾"}, "figure_art": "avg_npc_248"}, {"id": 428, "prop": "Character", "attributes": {"name": "avg_npc_227_1#5", "name2": "avg_npc_248", "focus": 1.0}}, {"id": 429, "prop": "name", "attributes": {"content": "  炮兵營準備得如何了？", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1#5"}, {"id": 430, "prop": "Character", "attributes": {"name": "avg_npc_227_1", "name2": "avg_npc_248", "focus": 2.0}}, {"id": 431, "prop": "name", "attributes": {"content": "  按計劃，最後一批原料會在中午左右送達。", "name": "副官希爾"}, "figure_art": "avg_npc_248"}, {"id": 432, "prop": "Character", "attributes": {"name": "avg_npc_227_1#5", "name2": "avg_npc_248", "focus": 1.0}}, {"id": 433, "prop": "name", "attributes": {"content": "  好，你讓他們加緊改造。只要一想到令人作嘔的東西正在我的城市裡蹦躂，我就一秒鐘都不想多等。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1#5"}, {"id": 434, "prop": "name", "attributes": {"content": "  對了，還有斯卡曼德羅斯和她的手下，倫蒂尼姆來的狼還死死咬著不放。你都聽見了吧？他們有人在外面。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1#5"}, {"id": 435, "prop": "name", "attributes": {"content": "  吩咐下去，不管採取什麼手段，都不能讓任何人妨礙到我們的計畫。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1#5"}, {"id": 436, "prop": "Character", "attributes": {"name": "avg_npc_227_1#5", "name2": "avg_npc_248", "focus": 2.0}}, {"id": 437, "prop": "name", "attributes": {"content": "  是，上校。", "name": "副官希爾"}, "figure_art": "avg_npc_248"}, {"id": 438, "prop": "Character", "attributes": {"name": "avg_npc_227_1", "name2": "avg_npc_248", "focus": 1.0}}, {"id": 439, "prop": "name", "attributes": {"content": "  至於斯卡曼德羅斯，在事成之前，也不能放任她自由行動。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1"}, {"id": 440, "prop": "Character", "attributes": {"name": "avg_npc_227_1", "name2": "avg_npc_248", "focus": 2.0}}, {"id": 441, "prop": "name", "attributes": {"content": "  我明白。", "name": "副官希爾"}, "figure_art": "avg_npc_248"}, {"id": 442, "prop": "Character", "attributes": {"name": "avg_npc_227_1#1", "name2": "avg_npc_248", "focus": 1.0}}, {"id": 443, "prop": "name", "attributes": {"content": "  ......被她這麼一說，我倒是想到了。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1#1"}, {"id": 444, "prop": "Character", "attributes": {"name": "avg_npc_227_1#2", "name2": "avg_npc_248", "focus": 1.0}}, {"id": 445, "prop": "name", "attributes": {"content": "  為什麼我們昨夜在波頓家的行動會被敵人提前知道？！", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1#2"}, {"id": 446, "prop": "Character", "attributes": {"name": "avg_npc_227_1#6", "name2": "avg_npc_248", "focus": 1.0}}, {"id": 447, "prop": "name", "attributes": {"content": "  斯卡曼德羅斯......不，不會的。這人雖然和那類貴族一樣天真又軟弱，但她對帝國的忠誠很有保障。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1#6"}, {"id": 448, "prop": "Character", "attributes": {"name": "avg_npc_227_1", "name2": "avg_npc_248", "focus": 2.0}}, {"id": 449, "prop": "name", "attributes": {"content": "  ......", "name": "副官希爾"}, "figure_art": "avg_npc_248"}, {"id": 450, "prop": "Character", "attributes": {"name": "avg_npc_227_1#2"}}, {"id": 451, "prop": "name", "attributes": {"content": "  嘖......看來渣滓終究是渣滓，卑劣的天性始終難改。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1#2"}, {"id": 452, "prop": "name", "attributes": {"content": "  在這最後的幾個小時裡，還有件早該完成的事情必須完成。", "name": "漢密爾頓上校"}, "figure_art": "avg_npc_227_1#2"}, {"id": 453, "prop": "Dialog", "attributes": {}}, {"id": 454, "prop": "Dialog", "attributes": {}}, {"id": 455, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 456, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 457, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 458, "prop": "Character", "attributes": {}}, {"id": 459, "prop": "Image", "attributes": {}}, {"id": 460, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}