lot", "attributes": {"slot": "m", "name": "avg_npc_177", "focus": "m"}}, {"id": 288, "prop": "charslot", "attributes": {"slot": "m", "action": "shake", "random": "true", "power": 5.0, "times": 60.0, "duration": 0.3}}, {"id": 289, "prop": "name", "attributes": {"content": "救、救命！", "name": "膽怯的市民"}, "figure_art": "avg_npc_177"}, {"id": 290, "prop": "Dialog", "attributes": {}}, {"id": 291, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_177", "focus": "m"}}, {"id": 292, "prop": "delay", "attributes": {"time": 0.2}}, {"id": 293, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 0.6}}, {"id": 294, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_177", "posfrom": "0,0", "posto": "300,0", "duration": 1.2}}, {"id": 295, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_177", "afrom": 1.0, "ato": 0.0, "duration": 0.5}}, {"id": 296, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 297, "prop": "charslot", "attributes": {"duration": 0.0}}, {"id": 298, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_053", "focus": "m"}}, {"id": 299, "prop": "name", "attributes": {"content": "跑吧，跑吧，可憐的維多利亞佬！你們已經享受得夠久了！現在，輪到你們感受曾經屬於我們的生活了！", "name": "薩卡茲士兵"}, "figure_art": "avg_npc_053"}, {"id": 300, "prop": "name", "attributes": {"content": "躲藏在廢墟中，躲藏在陰影裡！揉碎自己的道德，吞下自己的尊嚴！這是我們薩卡茲曾經歷的一切！現在，恭喜，它也屬於你們了！", "name": "薩卡茲士兵"}, "figure_art": "avg_npc_053"}, {"id": 301, "prop": "name", "attributes": {"content": "喚它為平等吧，喚它為你們未曾瞭解的平等！", "name": "薩卡茲士兵"}, "figure_art": "avg_npc_053"}, {"id": 302, "prop": "name", "attributes": {"content": "解釋？說法？", "name": "薩卡茲士兵"}, "figure_art": "avg_npc_053"}, {"id": 303, "prop": "name", "attributes": {"content": "戰爭開始了，蠢貨們！", "name": "薩卡茲士兵"}, "figure_art": "avg_npc_053"}, {"id": 304, "prop": "name", "attributes": {"content": "學習它，擁抱它！就像千百年來的我們一樣！", "name": "薩卡茲士兵"}, "figure_art": "avg_npc_053"}, {"id": 305, "prop": "Dialog", "attributes": {}}, {"id": 306, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 307, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 308, "prop": "charslot", "attributes": {}}, {"id": 309, "prop": "Background", "attributes": {"image": "21_G7_decisivebattlealley_d", "screenadapt": "coverall", "block": "true"}}, {"id": 310, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 311, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 312, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 313, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 0.6}}, {"id": 314, "prop": "PlaySound", "attributes": {"key": "$d_avg_runstop", "volume": 1.0, "delay": 1.5}}, {"id": 315, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 316, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_177", "posfrom": "300,0", "posto": "0,0", "afrom": 0.0, "ato": 1.0, "duration": 1.0, "isblock": "true"}}, {"id": 317, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 318, "prop": "name", "attributes": {"content": "呼......呼......", "name": "膽怯的市民"}, "figure_art": "avg_npc_177"}, {"id": 319, "prop": "name", "attributes": {"content": "我......嗚——這裡是......", "name": "膽怯的市民"}, "figure_art": "avg_npc_177"}, {"id": 320, "prop": "Dialog", "attributes": {}}, {"id": 321, "prop": "charslot", "attributes": {}}, {"id": 322, "prop": "charslot", "attributes": {"slot": "m", "bstart": 0.2, "bend": 0.7, "name": "avg_npc_863_1#1$1", "duration": 0.7}}, {"id": 323, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 324, "prop": "name", "attributes": {"content": "別哭哭啼啼的。", "name": "？？？"}, "figure_art": "avg_npc_863_1#1$1"}, {"id": 325, "prop": "name", "attributes": {"content": "你以為你是被他們邀請進這個街區野餐的嗎？你可以猜猜，那些不怎麼願意來的人現在在哪裡。", "name": "？？？"}, "figure_art": "avg_npc_863_1#1$1"}, {"id": 326, "prop": "charslot", "attributes": {"slot": "m", "name": "av