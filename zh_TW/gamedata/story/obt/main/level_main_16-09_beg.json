{"lang": "zh_TW", "eventid": "main_16", "eventName": "反常光譜", "entryType": "MAINLINE", "storyCode": "16-9", "avgTag": "行動前", "storyName": "瘋人的辯護", "storyInfo": "在礦工領袖雷爾金的惡夢之中，他們從未真正殺死那個內衛。\n", "storyList": [{"id": 0, "prop": "HEADER", "attributes": {"key": "title_test", "is_skippable": "true", "fit_mode": "BLACK_MASK"}}, {"id": 1, "prop": "stopmusic", "attributes": {}}, {"id": 2, "prop": "dialog", "attributes": {}}, {"id": 3, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 4, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 5, "prop": "charslot", "attributes": {}}, {"id": 6, "prop": "PlayMusic", "attributes": {"key": "$m_bat_act37d0d0_02_loop", "volume": 0.6}}, {"id": 7, "prop": "Background", "attributes": {"image": "66_g4_miningarea_polluted", "screenadapt": "coverall"}}, {"id": 8, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 9, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 10, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1970_1#1$1", "duration": 1.0, "isblock": "true"}}, {"id": 11, "prop": "name", "attributes": {"content": "不要……不……", "name": "年輕的礦工"}, "figure_art": "avg_npc_1970_1#1$1"}, {"id": 12, "prop": "dialog", "attributes": {}}, {"id": 13, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 14, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.03, "block": "true"}}, {"id": 15, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 16, "prop": "PlaySound", "attributes": {"key": "$d_avg_attack_heavy", "volume": 1.0}}, {"id": 17, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 18, "prop": "name", "attributes": {"content": "唔！", "name": "年輕的礦工"}}, {"id": 19, "prop": "dialog", "attributes": {}}, {"id": 20, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,0", "posto": "0,-50", "afrom": 1.0, "ato": 0.0, "duration": 0.5}}, {"id": 21, "prop": "playsound", "attributes": {"key": "$bodyfalldown2"}}, {"id": 22, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 23, "prop": "charslot", "attributes": {}}, {"id": 24, "prop": "name", "attributes": {"content": "你看到年輕的女人倒在你的眼前，黑色的長矛從她的屍體上慢慢“生長”出來。"}}, {"id": 25, "prop": "name", "attributes": {"content": "在她很快就不再動彈的身體旁邊，另一個人彈動著雙腳，試圖將自己推離這片危險的區域。"}}, {"id": 26, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 27, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1969_1#1$1"}}, {"id": 28, "prop": "name", "attributes": {"content": "怪、怪物……！", "name": "恐懼的礦工"}, "figure_art": "avg_npc_1969_1#1$1"}, {"id": 29, "prop": "dialog", "attributes": {}}, {"id": 30, "prop": "PlaySound", "attributes": {"key": "$d_avg_wtchkgopenftstp", "volume": 1.0}}, {"id": 31, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 32, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 33, "prop": "Background", "attributes": {}}, {"id": 34, "prop": "bgeffect", "attributes": {"name": "$eb_blacksmoke_01", "layer": 1.0}}, {"id": 35, "prop": "Image", "attributes": {"image": "avg_8_29", "screenadapt": "coverall", "xScale": 1.2, "yScale": 1.2, "fadetime": 0.0}}, {"id": 36, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.2, "yScaleFrom": 1.2, "xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 30.0, "block": "false"}}, {"id": 37, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 38, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 39, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 40, "prop": "name", "attributes": {"content": "黑色不斷逼近著。黑色、黑色、黑色。一切都是黑色，只有血是鮮紅的。你甚至無法確認自己面對的是否為活物。"}}, {"id": 41, "prop": "dialog", "attributes": {}}, {"id": 42, "prop": "name", "attributes": {"content": "不要怕——不要退後！", "name": "？？？"}}, {"id": 43, "prop": "name", "attributes": {"content": "還有力氣的，都站起來——", "name": "？？？"}}, {"id": 44, "prop": "name", "attributes": {"content": "啊！！！！", "name": "礦工"}}, {"id": 45, "prop": "name", "attributes": {"content": "黑色繼續從屍山血海中蹚過。地上有礦工、衛兵，也有普通的烏薩斯人。"}}, {"id": 46, "prop": "name", "attributes": {"content": "不間斷的尖叫聲使你清楚，無論自己是否轉身逃跑，那些幾乎憑空出現的長矛都會追上你。"}}, {"id": 47, "prop": "name", "attributes": {"content": "於是你只能眼看著穿透了無數軀體的長矛不斷從大地之中拔起，幾乎要將整個地面覆蓋。"}}, {"id": 48, "prop": "name", "attributes": {"content": "——", "name": "“皇帝的利刃”"}}, {"id": 49, "prop": "dialog", "attributes": {}}, {"id": 50, "prop": "PlaySound", "attributes": {"key": "$d_avg_daggerslow", "volume": 1.0}}, {"id": 51, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 52, "prop": "name", "attributes": {"content": "突然，一根根長矛從屍山上抽離，在黑影的手中重組成了一柄長劍。"}}, {"id": 53, "prop": "name", "attributes": {"content": "而後那辨不清話音的存在將手中長劍高高舉起，指向你。"}}, {"id": 54, "prop": "dialog", "attributes": {}}, {"id": 55, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 56, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 57, "prop": "image", "attributes": {}}, {"id": 58, "prop": "Background", "attributes": {"image": "66_g4_miningarea_polluted", "screenadapt": "coverall"}}, {"id": 59, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_077"}}, {"id": 60, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 61, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 62, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 63, "prop": "name", "attributes": {"content": "你想要站著死去。", "name": "“皇帝的利刃”"}, "figure_art": "avg_npc_077"}, {"id": 64, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 65, "prop": "name", "attributes": {"content": "不……我不會死……", "name": "？？？"}}, {"id": 66, "prop": "name", "attributes": {"content": "不會死在這裡。", "name": "？？？"}}, {"id": 67, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_077"}}, {"id": 68, "prop": "name", "attributes": {"content": "不錯的期許。", "name": "“皇帝的利刃”"}, "figure_art": "avg_npc_077"}, {"id": 69, "prop": "name", "attributes": {"content": "可惜，不切實際。", "name": "“皇帝的利刃”"}, "figure_art": "avg_npc_077"}, {"id": 70, "prop": "dialog", "attributes": {}}, {"id": 71, "prop": "charslot", "attributes": {}}, {"id": 72, "prop": "PlaySound", "attributes": {"key": "$d_avg_oldman_walk", "volume": 1.0}}, {"id": 73, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1964_1#1$1", "bstart": 0.2, "bend": 0.7, "duration": 1.5, "isblock": "true"}}, {"id": 74, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 75, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_077"}}, {"id": 76, "prop": "name", "attributes": {"content": "……", "name": "“皇帝的利刃”"}, "figure_art": "avg_npc_077"}, {"id": 77, "prop": "name", "attributes": {"content": "那是……？", "name": "“皇帝的利刃”"}, "figure_art": "avg_npc_077"}, {"id": 78, "prop": "dialog", "attributes": {}}, {"id": 79, "prop": "charslot", "attributes": {}}, {"id": 80, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1976_1#1$1", "bstart": 0.2, "bend": 0.7, "duration": 1.5}}, {"id": 81, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1976_1#1$1", "bstart": 0.2, "bend": 0.7, "duration": 1.5, "isblock": "true"}}, {"id": 82, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 83, "prop": "charslot", "attributes": {"slot": "l", "focus": "l"}}, {"id": 84, "prop": "name", "attributes": {"content": "雷爾金，我們來幫你！", "name": "軍人？"}, "figure_art": "avg_npc_1976_1#1$1"}, {"id": 85, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 86, "prop": "name", "attributes": {"content": "雷爾金——", "name": "軍人？"}, "figure_art": "avg_npc_1976_1#1$1"}, {"id": 87, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 88, "prop": "name", "attributes": {"content": "你們——列尼亞，怎麼是你？", "name": "？？？"}}, {"id": 89, "prop": "charslot", "attributes": {"slot": "l", "focus": "l"}}, {"id": 90, "prop": "name", "attributes": {"content": "我們來幫你了！", "name": "軍人？"}, "figure_art": "avg_npc_1976_1#1$1"}, {"id": 91, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 92, "prop": "name", "attributes": {"content": "你們來了，你們來幫我了！我的戰友，你們也在這裡——", "name": "？？？"}}, {"id": 93, "prop": "name", "attributes": {"content": "我們並肩作戰，就像以前那樣！", "name": "？？？"}}, {"id": 94, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 95, "prop": "name", "attributes": {"content": "就像以前那樣！", "name": "軍人？"}, "figure_art": "avg_npc_1976_1#1$1"}, {"id": 96, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 97, "prop": "name", "attributes": {"content": "來！幫我圍住他，就像以前那樣！一個人倒下了，另一個人就填補他的位置；一群人倒下了，另一群人就填補他們的位置！", "name": "？？？"}}, {"id": 98, "prop": "name", "attributes": {"content": "跟在我身後！", "name": "？？？"}}, {"id": 99, "prop": "charslot", "attributes": {}}, {"id": 100, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_077"}}, {"id": 101, "prop": "name", "attributes": {"content": "愚蠢……", "name": "“皇帝的利刃”"}}, {"id": 102, "prop": "charslot", "attributes": {}}, {"id": 103, "prop": "name", "attributes": {"content": "你能感到身後的熱源，灼燒感彷彿滾燙的爐火在身上蔓延。那些使你血液沸騰的，也使你雙眼清明，他們高喊你的名字，將你向前推去。"}}, {"id": 104, "prop": "name", "attributes": {"content": "在這堅實的簇擁之下，你一躍而起，對準那黑色身軀上狀似胸腔的位置——"}}, {"id": 105, "prop": "name", "attributes": {"content": "捅下去。"}}, {"id": 106, "prop": "dialog", "attributes": {}}, {"id": 107, "prop": "CameraShake", "attributes": {"duration": 3.0, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 108, "prop": "PlaySound", "attributes": {"key": "$d_gen_soldiersrun", "volume": 1.0}}, {"id": 109, "prop": "backgroundTween", "attributes": {"xScaleFrom": 1.0, "xScaleTo": 1.2, "yScaleFrom": 1.0, "yScaleTo": 1.2, "duration": 3.0, "block": "false"}}, {"id": 110, "prop": "PlaySound", "attributes": {"key": "$d_avg_audience_chaos", "volume": 1.0}}, {"id": 111, "prop": "Delay", "attributes": {"time": 3.0}}, {"id": 112, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovement", "volume": 1.0}}, {"id": 113, "prop": "backgroundTween", "attributes": {"xScaleFrom": 1.2, "xScaleTo": 1.8, "yScaleFrom": 1.2, "yScaleTo": 1.8, "duration": 0.4, "block": "false"}}, {"id": 114, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 115, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.4, "block": "true"}}, {"id": 116, "prop": "Background", "attributes": {}}, {"id": 117, "prop": "bgeffect", "attributes": {}}, {"id": 118, "prop": "Image", "attributes": {"image": "66_i01", "screenadapt": "coverall", "x": 0.0}}, {"id": 119, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.6, "yScaleFrom": 1.6, "xScaleTo": 1.5, "yScaleTo": 1.5, "duration": 10.0, "block": "false"}}, {"id": 120, "prop": "Delay", "attributes": {"time": 0.1}}, {"id": 121, "prop": "PlaySound", "attributes": {"key": "$d_avg_piercechest", "volume": 1.0}}, {"id": 122, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 50.0, "ystrength": 50.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 123, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 124, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 125, "prop": "name", "attributes": {"content": "——死——", "name": "？？？"}}, {"id": 126, "prop": "name", "attributes": {"content": "——", "name": "“皇帝的利刃”"}}, {"id": 127, "prop": "name", "attributes": {"content": "呵……", "name": "“皇帝的利刃”"}}, {"id": 128, "prop": "name", "attributes": {"content": "沒有血滴落的聲音。沒有抽搐的反應。"}}, {"id": 129, "prop": "name", "attributes": {"content": "只是刀刃的阻力在一點點變小，直到完全消失。"}}, {"id": 130, "prop": "dialog", "attributes": {}}, {"id": 131, "prop": "Image", "attributes": {"image": "66_i01", "screenadapt": "coverall", "fadetime": 3.0}}, {"id": 132, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.1, "yScaleFrom": 1.1, "xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 20.0, "block": "false"}}, {"id": 133, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 134, "prop": "name", "attributes": {"content": "原來……原來……", "name": "“皇帝的利刃”"}}, {"id": 135, "prop": "name", "attributes": {"content": "……“迦弗里伊爾”——", "name": "“皇帝的利刃”"}}, {"id": 136, "prop": "name", "attributes": {"content": "最後一個音節說出口，原本被黑影撐起的制服像突然脫力一般，再無反抗的痕跡。"}}, {"id": 137, "prop": "name", "attributes": {"content": "……", "name": "？？？"}}, {"id": 138, "prop": "name", "attributes": {"content": "你終結了這個怪物。以勇氣，以果決，以膽魄。"}}, {"id": 139, "prop": "name", "attributes": {"content": "以不存在的“友人”的支持。"}}, {"id": 140, "prop": "dialog", "attributes": {}}, {"id": 141, "prop": "musicvolume", "attributes": {"volume": 0.2, "fadetime": 2.0}}, {"id": 142, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 143, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 144, "prop": "charslot", "attributes": {}}, {"id": 145, "prop": "image", "attributes": {}}, {"id": 146, "prop": "Image", "attributes": {"image": "avg_5_7_shining", "screenadapt": "coverall"}}, {"id": 147, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 148, "prop": "PlaySound", "attributes": {"key": "$d_avg_atmosphere_horror", "volume": 0.0, "loop": "true", "channel": "at"}}, {"id": 149, "prop": "SoundVolume", "attributes": {"volume": 0.2, "channel": "at", "fadetime": 2.0}}, {"id": 150, "prop": "bgeffect", "attributes": {"name": "$eb_dim_openeye", "layer": 1.0}}, {"id": 151, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 152, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 153, "prop": "Subtitle", "attributes": {"text": "呼……呼……", "x": 300.0, "y": 350.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 154, "prop": "Subtitle", "attributes": {"text": "雙手好沉重。這裡是哪裡？", "x": 300.0, "y": 350.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 155, "prop": "subtitle", "attributes": {}}, {"id": 156, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 157, "prop": "name", "attributes": {"content": "“——倒下了，他倒下了！”"}}, {"id": 158, "prop": "dialog", "attributes": {}}, {"id": 159, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 160, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 161, "prop": "Subtitle", "attributes": {"text": "……誰？", "x": 300.0, "y": 350.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 162, "prop": "subtitle", "attributes": {}}, {"id": 163, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 164, "prop": "SoundVolume", "attributes": {"volume": 0.6, "channel": "at", "fadetime": 2.0}}, {"id": 165, "prop": "name", "attributes": {"content": "“雷爾金，你——我們，我們殺死了——”"}}, {"id": 166, "prop": "name", "attributes": {"content": "“我們殺死了他！！”"}}, {"id": 167, "prop": "dialog", "attributes": {}}, {"id": 168, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 169, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 170, "prop": "Subtitle", "attributes": {"text": "殺死了誰？這些黑色的……雪……", "x": 300.0, "y": 350.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 171, "prop": "Subtitle", "attributes": {"text": "不，還不夠。死了一個擋路的，也還有這些到處都是的、煩人的雪……", "x": 300.0, "y": 350.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 172, "prop": "Subtitle", "attributes": {"text": "不管怎麼樣也不會停下來的雪。", "x": 300.0, "y": 350.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 173, "prop": "subtitle", "attributes": {}}, {"id": 174, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 175, "prop": "name", "attributes": {"content": "“雷爾金，雷爾金？我們接下來該怎麼辦？”"}}, {"id": 176, "prop": "name", "attributes": {"content": "“雷爾金——”"}}, {"id": 177, "prop": "dialog", "attributes": {}}, {"id": 178, "prop": "StopSound", "attributes": {"channel": "at", "fadetime": 2.0}}, {"id": 179, "prop": "PlaySound", "attributes": {"key": "$d_avg_tinnitus", "volume": 1.0}}, {"id": 180, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 181, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 182, "prop": "image", "attributes": {}}, {"id": 183, "prop": "curtain", "attributes": {"direction": 0.0, "fillfrom": 0.01, "fillto": 0.2, "fadetime": 0.1}}, {"id": 184, "prop": "curtain", "attributes": {"direction": 4.0, "fillfrom": 0.01, "fillto": 0.2, "fadetime": 0.1}}, {"id": 185, "prop": "Background", "attributes": {"image": "bg_newiceforest_2", "screenadapt": "coverall", "xScale": 1.4, "yScale": 1.4, "y": 0.0, "fadetime": 0.0}}, {"id": 186, "prop": "backgroundTween", "attributes": {"xFrom": 200.0, "duration": 30.0}}, {"id": 187, "prop": "focusout", "attributes": {"type": "bg", "id": "bg_newiceforest_2", "from": 0.0, "to": 1.0, "duration": 0.1, "block": "false"}}, {"id": 188, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1976_1#1$1", "bstart": 0.1, "bend": 0.3, "posfrom": "0,-160", "posto": "0,-160", "duration": 4.0}}, {"id": 189, "prop": "charslot", "attributes": {"slot": "m", "action": "zoom", "poszoom": "0.5,0.5", "scale": 1.4, "duration": 0.0}}, {"id": 190, "prop": "bgeffect", "attributes": {"name": "$eb_whitemask", "layer": 2.0}}, {"id": 191, "prop": "focusparam", "attributes": {"blur": "false", "effect": "Grayscale"}}, {"id": 192, "prop": "Blocker", "attributes": {"a": 0.3, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 193, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 194, "prop": "name", "attributes": {"content": "雷爾金！", "name": "軍人？"}, "figure_art": "avg_npc_1976_1#1$1"}, {"id": 195, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 196, "prop": "name", "attributes": {"content": "我是……", "name": "？？？"}}, {"id": 197, "prop": "name", "attributes": {"content": "雷爾金！雷爾金！", "name": "礦工"}}, {"id": 198, "prop": "name", "attributes": {"content": "人群如潮水一般湧向你。他們將你托起，又將你拉下。這種失重的感覺，你從前也曾有過。"}}, {"id": 199, "prop": "name", "attributes": {"content": "人群歡呼，人群吵嚷。震耳欲聾的迴響中，絕不應該出現在這裡的人喊出你的名字。"}}, {"id": 200, "prop": "charslot", "attributes": {"slot": "m", "focus": "m"}}, {"id": 201, "prop": "name", "attributes": {"content": "——雷爾金——", "name": "軍人？"}, "figure_art": "avg_npc_1976_1#1$1"}, {"id": 202, "prop": "dialog", "attributes": {}}, {"id": 203, "prop": "Effect", "attributes": {"name": "$e_whitemask", "layer": 2.0}}, {"id": 204, "prop": "Delay", "attributes": {"time": 3.0}}, {"id": 205, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 206, "prop": "charslot", "attributes": {}}, {"id": 207, "prop": "bgeffect", "attributes": {}}, {"id": 208, "prop": "Background", "attributes": {}}, {"id": 209, "prop": "focusparam", "attributes": {}}, {"id": 210, "prop": "curtain", "attributes": {}}, {"id": 211, "prop": "name", "attributes": {"content": "你閉上眼睛，隨他的話語回到那片森林中。一支邊防駐軍，一次有去無回的任務。"}}, {"id": 212, "prop": "name", "attributes": {"content": "現在，你不在那裡。"}}, {"id": 213, "prop": "name", "attributes": {"content": "贏了……", "name": "？？？"}}, {"id": 214, "prop": "name", "attributes": {"content": "我們贏了。", "name": "？？？"}}, {"id": 215, "prop": "dialog", "attributes": {}}, {"id": 216, "prop": "PlaySound", "attributes": {"key": "$d_avg_atmosphere_horror", "volume": 0.0, "loop": "true", "channel": "at"}}, {"id": 217, "prop": "SoundVolume", "attributes": {"volume": 0.5, "channel": "at", "fadetime": 2.0}}, {"id": 218, "prop": "focusout", "attributes": {"type": "bg", "id": "bg_newiceforest_2", "from": 1.0, "to": 0.0, "duration": 4.0, "block": "false"}}, {"id": 219, "prop": "Background", "attributes": {"image": "66_g16_smokeonblackgroud", "screenadapt": "coverall"}}, {"id": 220, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.2, "yScaleFrom": 1.2, "xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 20.0, "block": "false"}}, {"id": 221, "prop": "musicvolume", "attributes": {"volume": 0.6, "fadetime": 2.0}}, {"id": 222, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 223, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 224, "prop": "name", "attributes": {"content": "升起又墜落的瞬間，你看向遠處那團仍未散盡的黑塵。"}}, {"id": 225, "prop": "dialog", "attributes": {}}, {"id": 226, "prop": "StopSound", "attributes": {"channel": "at", "fadetime": 2.0}}, {"id": 227, "prop": "name", "attributes": {"content": "……", "name": "“黑色的雪”"}}, {"id": 228, "prop": "name", "attributes": {"content": "黑色的塵煙如同無數條細小蜿蜒的根鬚，從那制服的每一個孔隙中鑽出，貪婪地纏繞著、覆蓋著、吸附著，直到將其完全包覆。"}}, {"id": 229, "prop": "name", "attributes": {"content": "在黑煙的包裹下，那制服漸漸又顯現出人形，彷彿——"}}, {"id": 230, "prop": "dialog", "attributes": {}}, {"id": 231, "prop": "PlaySound", "attributes": {"key": "$d_avg_smokeconverge", "volume": 1.0}}, {"id": 232, "prop": "Image", "attributes": {"image": "avg_8_30", "screenadapt": "coverall", "xScale": 1.2, "yScale": 1.2, "fadetime": 3.0}}, {"id": 233, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.2, "yScaleFrom": 1.2, "xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 20.0, "block": "false"}}, {"id": 234, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 235, "prop": "name", "attributes": {"content": "彷彿“他”從未死去。"}}, {"id": 236, "prop": "dialog", "attributes": {}}, {"id": 237, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 238, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 4.0, "block": "true"}}, {"id": 239, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 240, "prop": "charslot", "attributes": {}}, {"id": 241, "prop": "Background", "attributes": {}}, {"id": 242, "prop": "Image", "attributes": {}}, {"id": 243, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}