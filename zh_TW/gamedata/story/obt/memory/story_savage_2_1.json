{"lang": "zh_TW", "eventid": "story_savage_set_2", "eventName": "自有一“派”", "entryType": "NONE", "storyCode": null, "avgTag": "幕間", "storyName": "自有一“派”", "storyInfo": "暴行做了一頓胡蘿蔔派大餐，邀請大家一起品嘗。\n", "storyList": [{"id": 0, "prop": "HEADER", "attributes": {"key": "title_test", "is_skippable": "true", "fit_mode": "BLACK_MASK"}}, {"id": 1, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 2, "prop": "stopmusic", "attributes": {}}, {"id": 3, "prop": "Dialog", "attributes": {}}, {"id": 4, "prop": "Background", "attributes": {"image": "bg_corridor_2"}}, {"id": 5, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 6, "prop": "PlayMusic", "attributes": {"intro": "$path_intro", "key": "$path_loop", "volume": 0.4}}, {"id": 7, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 8, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 9, "prop": "name", "attributes": {"content": "羅德島內部 雷姆必拓礦業公司駐羅德島辦事處"}}, {"id": 10, "prop": "dialog", "attributes": {}}, {"id": 11, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 12, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 13, "prop": "character", "attributes": {"name": "avg_npc_051", "fadetime": 1.5}}, {"id": 14, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 15, "prop": "name", "attributes": {"content": "暴行姐姐，你在忙嗎......", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 16, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 17, "prop": "name", "attributes": {"content": "咦？阿米婭，今天來得好早啊。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 18, "prop": "name", "attributes": {"content": "今天沒有需要交付的貨物，也沒什麼特別急著要處理的事情。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 19, "prop": "name", "attributes": {"content": "怎麼啦，阿米婭，今天沒有要做的事情嗎？", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 20, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 21, "prop": "name", "attributes": {"content": "今天，博士和凱爾希、特蕾西婭出門了，讓我暫時一個人在房間待一會......到晚飯的時候就會回來。", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 22, "prop": "name", "attributes": {"content": "可是，我不知道在房間裡一個人該做什麼......", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 23, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 24, "prop": "name", "attributes": {"content": "哼——哼，所以你就想到偷偷來找我了吧？", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 25, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 26, "prop": "name", "attributes": {"content": "嘿嘿......", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 27, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 28, "prop": "name", "attributes": {"content": "唉，大人就是這樣，總有做不完的麻煩工作。更別說這三個人給人的感覺，都是不知疲倦的“工作狂”......", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 29, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 30, "prop": "name", "attributes": {"content": "長大以後，大家都會變成這樣嗎？", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 31, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 32, "prop": "name", "attributes": {"content": "也不是啦......雖然有些人是迫不得已，不過，確實也有發自內心地認為完全投入工作會變得充實的人。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 33, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 34, "prop": "name", "attributes": {"content": "那麼，暴行姐姐是哪種呢？", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 35, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 36, "prop": "name", "attributes": {"content": "我嘛......工作的時候會好好做完自己該做的部分，也算是挺喜歡的？", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 37, "prop": "name", "attributes": {"content": "但是現在是可以休息的時間，那當然是陪阿米婭更快樂啦！", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 38, "prop": "name", "attributes": {"content": "對了，阿米婭，趁這個時間，不如今天來試試做飯吧？", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 39, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 40, "prop": "name", "attributes": {"content": "做飯？", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 41, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 42, "prop": "name", "attributes": {"content": "學習做你最喜歡的雷姆必拓菜餚，比如......胡蘿蔔派！不想體驗一次做出來的過程嗎？", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 43, "prop": "name", "attributes": {"content": "烹飪和烘焙可是很多人都難以割捨的，最使人心情愉悅的樂趣哦。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 44, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 45, "prop": "name", "attributes": {"content": "可以和暴行姐姐一起做胡蘿蔔派......", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 46, "prop": "name", "attributes": {"content": "嗯，我想做！", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 47, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 48, "prop": "name", "attributes": {"content": "好啊，那就一起做吧。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 49, "prop": "name", "attributes": {"content": "之前和博士一起品嘗的時候，博士也說很愛吃，我們就做好派等博士回來，三個人開心地吃一頓。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 50, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 51, "prop": "name", "attributes": {"content": "太、太好了......", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 52, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 53, "prop": "name", "attributes": {"content": "好，就這麼定了。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 54, "prop": "name", "attributes": {"content": "跟我來，阿米婭，上次拜託同事帶給我的胡蘿蔔就備在廚房冷凍室裡，還有起司、羽卵應該是放在......", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 55, "prop": "Dialog", "attributes": {}}, {"id": 56, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 57, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 58, "prop": "Background", "attributes": {"image": "bg_canteen"}}, {"id": 59, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 60, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 61, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 62, "prop": "name", "attributes": {"content": "暴行姐姐，我打好羽卵了！", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 63, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 64, "prop": "name", "attributes": {"content": "這麼快嗎，讓我看看......", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 65, "prop": "name", "attributes": {"content": "呃。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 66, "prop": "name", "attributes": {"content": "（蛋液怎麼只剩一半了......而且殼全碎在裡面了......）", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 67, "prop": "name", "attributes": {"content": "......嗯，還......還不錯，讓我再加工一下應該可以放進去......", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 68, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 69, "prop": "name", "attributes": {"content": "我，我做得不好嗎......", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 70, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 71, "prop": "name", "attributes": {"content": "怎、怎麼會呢，哈哈，阿米婭這是第一次做飯，只是不太熟練啦。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 72, "prop": "name", "attributes": {"content": "對了，阿米婭，可以幫我洗一洗胡蘿蔔嗎？嗯，就放在籃子裡的......", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 73, "prop": "name", "attributes": {"content": "啊啊，不用洗那麼多，對，這樣就好......", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 74, "prop": "name", "attributes": {"content": "......等等，處理胡蘿蔔不需要用指甲，用刮皮刀就可以了......坑坑窪窪很正常啦，畢竟是第一次嘛。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 75, "prop": "name", "attributes": {"content": "......和麵稍微有點難度，還是我自己來吧......", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 76, "prop": "name", "attributes": {"content": "不，烤爐還是讓我來設定吧，果然難度還是太大了......", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 77, "prop": "name", "attributes": {"content": "......等等，阿米婭，麵粉不能這樣收拾——", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 78, "prop": "dialog", "attributes": {}}, {"id": 79, "prop": "character", "attributes": {}}, {"id": 80, "prop": "musicvolume", "attributes": {"volume": 0.0, "fadetime": 1.0}}, {"id": 81, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 82, "prop": "delay", "attributes": {"time": 0.7}}, {"id": 83, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 84, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.03, "block": "true"}}, {"id": 85, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 86, "prop": "Blocker", "attributes": {"a": 0.6, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 1.0, "block": "true"}}, {"id": 87, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 88, "prop": "musicvolume", "attributes": {"volume": 0.4, "fadetime": 1.0}}, {"id": 89, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 90, "prop": "name", "attributes": {"content": "咳咳......咳......嗚嗚，暴行姐姐，救救我......", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 91, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 92, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 93, "prop": "name", "attributes": {"content": "噗......噗哈哈......", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 94, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 95, "prop": "name", "attributes": {"content": "嗚嗚，我的眼睛好痛......", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 96, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 97, "prop": "name", "attributes": {"content": "抱歉，抱歉，我來幫阿米婭擦一擦......咳、咳咳，咳哈哈......", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 98, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 99, "prop": "name", "attributes": {"content": "別取笑我啦，暴行姐姐......！", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 100, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 101, "prop": "name", "attributes": {"content": "才不是取笑呢，噗......只是，現在的阿米婭特別可愛罷了。哎呀，真想把這個瞬間記錄下來。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 102, "prop": "name", "attributes": {"content": "不過，麵粉全都撒在身上了，果然還是先帶阿米婭去清理一下......", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 103, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 104, "prop": "name", "attributes": {"content": "不、不行，現在重要的是派......來不及做完就糟糕了！", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 105, "prop": "name", "attributes": {"content": "暴行姐姐，等到做完再清理吧！", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 106, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 107, "prop": "name", "attributes": {"content": " 哈哈，那好啊。阿米婭，來，我來幫你擦一擦臉。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 108, "prop": "name", "attributes": {"content": " 等到把派完成放進烤爐，我們就去好好洗個澡......", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 109, "prop": "Dialog", "attributes": {}}, {"id": 110, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.8, "block": "true"}}, {"id": 111, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.8, "block": "true"}}, {"id": 112, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 113, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 114, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 115, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 116, "prop": "name", "attributes": {"content": "......呼，還算不錯，剛好趕上了。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 117, "prop": "name", "attributes": {"content": "你看，三個派都烤得剛剛好哦。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 118, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 119, "prop": "name", "attributes": {"content": "嗯，好香......", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 120, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 121, "prop": "name", "attributes": {"content": "接下來只需要撒一點糖在上面然後保溫，一切就大功告成啦。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 122, "prop": "name", "attributes": {"content": "說起來......我記得博士喜歡的口感要特別一些，阿米婭，你還有印象嗎？", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 123, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 124, "prop": "name", "attributes": {"content": "嗯！博士喜歡的菜餚口味我都記得。還有......暴行姐姐喜歡的菜餚，我也全部記得。", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 125, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 126, "prop": "name", "attributes": {"content": "什麼什麼？阿米婭竟然一直記得我的事嗎？", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 127, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 128, "prop": "name", "attributes": {"content": "嘿嘿......暴行姐姐一直都非常關照我，看到暴行姐姐吃喜歡吃的東西的樣子我也會很高興。", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 129, "prop": "name", "attributes": {"content": "我想把這些讓暴行姐姐開心的事情都記住！", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 130, "prop": "name", "attributes": {"content": "還有，暴行姐姐，以後我也想和你一起做各種各樣的美食！", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 131, "prop": "name", "attributes": {"content": "所以，如果......能一直在一起就好了......就像博士一樣，我希望可以一直找暴行姐姐玩......", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 132, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 133, "prop": "name", "attributes": {"content": "阿米婭......", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 134, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 135, "prop": "name", "attributes": {"content": "不、不過，如果暴行姐姐有工作要忙，就去忙好了！我知道，工作很重要......", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 136, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 137, "prop": "name", "attributes": {"content": "......我會陪著你。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 138, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 139, "prop": "name", "attributes": {"content": "真的嗎？", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 140, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 141, "prop": "name", "attributes": {"content": "真的。放心吧，阿米婭，我們已經是非常、非常要好的朋友了。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 142, "prop": "name", "attributes": {"content": "對卡特斯來說，姐姐和妹妹就應該相親相愛地一起生活、互相幫助。所以......", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 143, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 144, "prop": "name", "attributes": {"content": "但是......凱爾希醫生說過，再過不久，巴別塔和雷姆必拓礦業公司的合作專案就要結束了， 暴行姐姐就會......", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 145, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 146, "prop": "name", "attributes": {"content": "......你已經知道啦。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 147, "prop": "name", "attributes": {"content": "嗯，是的。之後，我可能要回雷姆必拓工作一段時間。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 148, "prop": "name", "attributes": {"content": "我已經是大人了，所以有必須要承擔的責任。現在，雷姆必拓還有一些很需要我去完成的工作。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 149, "prop": "name", "attributes": {"content": "但是，我會儘快回來找你的，阿米婭。不管離開多遠，我們都是朋友，只要你需要幫助，暴行姐姐一定會來保護你的。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 150, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 151, "prop": "name", "attributes": {"content": "嗯......我知道。", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 152, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 153, "prop": "name", "attributes": {"content": "好、好啦，不說這種事情了。說不定雷姆必拓把我忘記了，不召回我了，我就只能做個無業遊民了呢......", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 154, "prop": "name", "attributes": {"content": "或者，阿米婭現在好好學習，以後做個大人物，也開一家大公司，然後我來做阿米婭的員工？", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 155, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 156, "prop": "name", "attributes": {"content": "咦？我來開公司？......唔，我可以做到嗎......", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 157, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 158, "prop": "name", "attributes": {"content": "只要現在開始努力，總有一天會有機會的。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 159, "prop": "name", "attributes": {"content": "博士、凱爾希、特蕾西婭，幾位都是特別厲害的人，阿米婭一定要好好跟著老師們學習哦。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 160, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 161, "prop": "name", "attributes": {"content": "嗯，我知道。暴行姐姐也是很厲害的人。在雷姆必拓的時候——", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 162, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 163, "prop": "name", "attributes": {"content": "哪有哪有，和那幾位相比......", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 164, "prop": "character", "attributes": {"name": "avg_npc_051"}}, {"id": 165, "prop": "name", "attributes": {"content": "對我來說，暴行姐姐就是非常厲害的老師！會做美食給我吃，工作也做得很好，會和我講很多雷姆必拓的故事......", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 166, "prop": "name", "attributes": {"content": "還有，我知道，暴行姐姐願意陪著我......會像真正的姐姐一樣照顧我。", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 167, "prop": "name", "attributes": {"content": "我知道暴行姐姐要離開的時候很害怕......但是，今天的烹飪讓我很開心，有了這份回憶，以後我應該不會那麼害怕了。", "name": "阿米婭"}, "figure_art": "avg_npc_051"}, {"id": 168, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 169, "prop": "name", "attributes": {"content": "我也是，阿米婭。來到巴別塔，能夠看到你開心地來找我聊天，一起玩遊戲、烹飪......我一直非常高興。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 170, "prop": "name", "attributes": {"content": "所以，知道即將要分開，我也會很難過。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 171, "prop": "name", "attributes": {"content": "不過，我不會露出讓你擔心的表情的。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 172, "prop": "name", "attributes": {"content": "阿米婭，生活在這片大地上，我們各自都有必須要做的事。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 173, "prop": "name", "attributes": {"content": "將來的你也一定會找到屬於自己前進的方向。如果我們有著一樣的信念......就一定會再一次重逢。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 174, "prop": "name", "attributes": {"content": "我會努力前進。阿米婭，你也要......", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 175, "prop": "name", "attributes": {"content": "平安長大。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 176, "prop": "Dialog", "attributes": {}}, {"id": 177, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 178, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 179, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 180, "prop": "Character", "attributes": {}}, {"id": 181, "prop": "Background", "attributes": {"image": "bg_corridor"}}, {"id": 182, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 183, "prop": "playMusic", "attributes": {"intro": "$farce_intro", "key": "$farce_loop", "volume": 0.4}}, {"id": 184, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 185, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 186, "prop": "name", "attributes": {"content": "......"}}, {"id": 187, "prop": "name", "attributes": {"content": "平平無奇的一日。"}}, {"id": 188, "prop": "name", "attributes": {"content": "阿米婭意外地很早便找到你，期待地說起今天中午有來自雷姆必拓的美味菜餚。"}}, {"id": 189, "prop": "name", "attributes": {"content": "顯然，在連續享用了五頓健康餐之後，這是一項很難抗拒的邀請。"}}, {"id": 190, "prop": "dialog", "attributes": {}}, {"id": 191, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 192, "prop": "character", "attributes": {"name": "char_002_amiya_1#3"}}, {"id": 193, "prop": "name", "attributes": {"content": "這頓“大餐”我可是期待很久了。暴行姐姐幾乎什麼要求都會滿足我，但是唯獨在烹飪這件事上不會讓步呢。", "name": "阿米婭"}, "figure_art": "char_002_amiya_1#3"}, {"id": 194, "prop": "name", "attributes": {"content": "不到材料準備齊全為止，都不能正式地請客。缺一點都不行。", "name": "阿米婭"}, "figure_art": "char_002_amiya_1#3"}, {"id": 195, "prop": "dialog", "attributes": {}}, {"id": 196, "prop": "Decision", "attributes": {"options": "暴行對你非常體貼啊。", "values": "1"}, "targetLine": {"option1": "line197"}}, {"id": 197, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 198, "prop": "name", "attributes": {"content": "嘿嘿......從很久以前開始，暴行姐姐就總是讓我對她多多撒嬌。而且，暴行姐姐做的菜餚可好吃了。", "name": "阿米婭"}}, {"id": 199, "prop": "name", "attributes": {"content": "唔，對一些幹員來說或許口味會比較清淡，但是卻很合我的口味。怎麼說呢，有股令人懷念的，來自家鄉的味道......", "name": "阿米婭"}}, {"id": 200, "prop": "name", "attributes": {"content": "啊，但是我相信博士也會喜歡的，畢竟......", "name": "阿米婭"}}, {"id": 201, "prop": "dialog", "attributes": {}}, {"id": 202, "prop": "Decision", "attributes": {"options": "怎麼了？", "values": "1"}, "targetLine": {"option1": "line203"}}, {"id": 203, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 204, "prop": "name", "attributes": {"content": "沒什麼！只是我很想和博士分享......暴行姐姐也特別歡迎博士做客。", "name": "阿米婭"}}, {"id": 205, "prop": "name", "attributes": {"content": "我們和暴行姐姐從很早開始就是朋友了，所以我知道，暴行姐姐做的飯真的很好吃！", "name": "阿米婭"}}, {"id": 206, "prop": "dialog", "attributes": {}}, {"id": 207, "prop": "Decision", "attributes": {"options": "說到“我們”......暴行說過記得我，但又不能說更多事情。", "values": "1"}, "targetLine": {"option1": "line208"}}, {"id": 208, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 209, "prop": "name", "attributes": {"content": "是啊，暴行姐姐認識過去的博士，還為博士做過很多次雷姆必拓美食呢。", "name": "阿米婭"}}, {"id": 210, "prop": "dialog", "attributes": {}}, {"id": 211, "prop": "Decision", "attributes": {"options": "暴行她......是怎麼看我的？", "values": "1"}, "targetLine": {"option1": "line212"}}, {"id": 212, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 213, "prop": "name", "attributes": {"content": "不必擔心，博士。對我和暴行姐姐來說，博士都是十分可靠、值得信任的人。", "name": "阿米婭"}}, {"id": 214, "prop": "name", "attributes": {"content": "我想，她也期待著將這頓飯當做和博士您再次見面後的禮物。", "name": "阿米婭"}}, {"id": 215, "prop": "name", "attributes": {"content": "暴行姐姐不僅擁有嫺熟的菜餚手藝，對於食材原料也很講究。", "name": "阿米婭"}}, {"id": 216, "prop": "name", "attributes": {"content": "唔嗯，不過，不知道是因為什麼原因，作為最重要的原材料，產自雷姆必拓的胡蘿蔔罐頭，今年特別難買呢......", "name": "阿米婭"}}, {"id": 217, "prop": "name", "attributes": {"content": "不僅價格升高，購買途徑也減少了。", "name": "阿米婭"}}, {"id": 218, "prop": "name", "attributes": {"content": "對於雷姆必拓人來說，胡蘿蔔幾乎是最喜愛的食物，在本地市場已經供不應求，想要訂購能發送到羅德島的貨源就更加稀缺了......", "name": "阿米婭"}}, {"id": 219, "prop": "name", "attributes": {"content": "當然，不僅是雷姆必拓會種植胡蘿蔔，在不同的地區也會有很多不同的品種。但是暴行姐姐說......", "name": "阿米婭"}}, {"id": 220, "prop": "name", "attributes": {"content": "“不是雷姆必拓那種甜甜的、脆脆的口感可不行，阿米婭，我絕對要讓你嘗到和記憶中一樣的美味！”", "name": "阿米婭"}}, {"id": 221, "prop": "dialog", "attributes": {}}, {"id": 222, "prop": "Decision", "attributes": {"options": "聽得我也流口水了。;胡蘿蔔也會很自豪的。", "values": "1;2"}, "targetLine": {"option1": "line223", "option2": "line223"}}, {"id": 223, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 224, "prop": "name", "attributes": {"content": "哈哈......好期待啊，博士。", "name": "阿米婭"}}, {"id": 225, "prop": "name", "attributes": {"content": "我和暴行姐姐已經很久沒有見面了。", "name": "阿米婭"}}, {"id": 226, "prop": "name", "attributes": {"content": "但是，現在的暴行姐姐還願意和過去一樣對待我，這讓我......很安心......", "name": "阿米婭"}}, {"id": 227, "prop": "character", "attributes": {}}, {"id": 228, "prop": "dialog", "attributes": {}}, {"id": 229, "prop": "name", "attributes": {"content": "......安靜......坐好！", "name": "？？？"}}, {"id": 230, "prop": "character", "attributes": {"name": "char_002_amiya_1#5"}}, {"id": 231, "prop": "name", "attributes": {"content": "咿！", "name": "阿米婭"}, "figure_art": "char_002_amiya_1#5"}, {"id": 232, "prop": "character", "attributes": {"name": "char_002_amiya_1#3"}}, {"id": 233, "prop": "name", "attributes": {"content": "這個聲音是來自餐廳......暴行姐姐那邊發生什麼事了嗎？", "name": "阿米婭"}, "figure_art": "char_002_amiya_1#3"}, {"id": 234, "prop": "Dialog", "attributes": {}}, {"id": 235, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 236, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 237, "prop": "Background", "attributes": {"image": "bg_canteen"}}, {"id": 238, "prop": "character", "attributes": {"name": "char_294_ayer", "name2": "char_373_Leonhardt_1"}}, {"id": 239, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 240, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 241, "prop": "character", "attributes": {"name": "char_294_ayer", "name2": "char_373_Leonhardt_1", "focus": 2.0}}, {"id": 242, "prop": "name", "attributes": {"content": "啊——嗚！......好吃！謝謝暴行大姐為我們做的菜餚！", "name": "萊恩哈特"}, "figure_art": "char_373_Leonhardt_1"}, {"id": 243, "prop": "character", "attributes": {"name": "char_294_ayer", "name2": "char_373_Leonhardt_1", "focus": 1.0}}, {"id": 244, "prop": "name", "attributes": {"content": "（快速咀嚼）", "name": "斷崖"}, "figure_art": "char_294_ayer"}, {"id": 245, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 246, "prop": "name", "attributes": {"content": "哎呀，不客氣。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 247, "prop": "character", "attributes": {"name": "char_365_aprl"}}, {"id": 248, "prop": "name", "attributes": {"content": "這，這派的味道可真是......太專業了。", "name": "四月"}, "figure_art": "char_365_aprl"}, {"id": 249, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 250, "prop": "name", "attributes": {"content": "哼哼......意料之中、意料之中，我的手藝可沒人敢輕易否定。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 251, "prop": "character", "attributes": {"name": "char_294_ayer", "name2": "char_373_Leonhardt_1", "focus": 2.0}}, {"id": 252, "prop": "name", "attributes": {"content": "四月，要不要也來嘗一塊我的？這可是維多利亞時下最流行的吃法，在任何菜品中都可以加上很——多很多番茄醬來吃！", "name": "萊恩哈特"}, "figure_art": "char_373_Leonhardt_1"}, {"id": 253, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 254, "prop": "name", "attributes": {"content": "不行，你的這份都已經加了兩瓶進去了，哪裡還嘗得出食物本來的味道啊，壞小子！", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 255, "prop": "character", "attributes": {"name": "char_294_ayer", "name2": "char_373_Leonhardt_1", "focus": 2.0}}, {"id": 256, "prop": "name", "attributes": {"content": "嘿嘿，那艾爾斯你來嘗嘗我的特製款吧？這味道可創新了！", "name": "萊恩哈特"}, "figure_art": "char_373_Leonhardt_1"}, {"id": 257, "prop": "character", "attributes": {"name": "char_294_ayer", "name2": "char_373_Leonhardt_1", "focus": 1.0}}, {"id": 258, "prop": "name", "attributes": {"content": "我一直都遵循原本風味。你那奇怪的改良派就自己去吃......", "name": "斷崖"}, "figure_art": "char_294_ayer"}, {"id": 259, "prop": "character", "attributes": {"name": "char_294_ayer", "name2": "char_373_Leonhardt_1", "focus": 2.0}}, {"id": 260, "prop": "name", "attributes": {"content": "誒？多沒意思啊，艾爾斯，要多有一些創新精神。", "name": "萊恩哈特"}, "figure_art": "char_373_Leonhardt_1"}, {"id": 261, "prop": "name", "attributes": {"content": "在維多利亞的時候，每次去餐館，就會看到客人們像這樣點上一個派，然後至少放上四袋番茄醬。", "name": "萊恩哈特"}, "figure_art": "char_373_Leonhardt_1"}, {"id": 262, "prop": "name", "attributes": {"content": "“食物裡最健康的其實是贈送的番茄醬料包”，在速食店裡不是經常會有這樣的說法嗎？", "name": "萊恩哈特"}, "figure_art": "char_373_Leonhardt_1"}, {"id": 263, "prop": "character", "attributes": {"name": "char_365_aprl"}}, {"id": 264, "prop": "name", "attributes": {"content": "可不要拿暴行大姐的派和速食店的品質相提並論啊。", "name": "四月"}, "figure_art": "char_365_aprl"}, {"id": 265, "prop": "name", "attributes": {"content": "從火候到味道都是這麼完美......", "name": "四月"}, "figure_art": "char_365_aprl"}, {"id": 266, "prop": "name", "attributes": {"content": "感覺有好久沒嘗到這個味道了，這就是奔波在外時會有的......懷念嗎......", "name": "四月"}, "figure_art": "char_365_aprl"}, {"id": 267, "prop": "character", "attributes": {"name": "char_294_ayer", "name2": "char_373_Leonhardt_1", "focus": 2.0}}, {"id": 268, "prop": "name", "attributes": {"content": "是嘛，我覺得還好誒？", "name": "萊恩哈特"}, "figure_art": "char_373_Leonhardt_1"}, {"id": 269, "prop": "character", "attributes": {"name": "char_365_aprl"}}, {"id": 270, "prop": "name", "attributes": {"content": "你怎麼一點也不懂看氣氛？", "name": "四月"}, "figure_art": "char_365_aprl"}, {"id": 271, "prop": "character", "attributes": {"name": "char_294_ayer", "name2": "char_373_Leonhardt_1", "focus": 1.0}}, {"id": 272, "prop": "name", "attributes": {"content": "萊特是說，身為天災信使，他對於長期吃不到雷姆必拓食物的生活已經習慣了。太依賴家鄉的美食......很難在野外支撐下去。", "name": "斷崖"}, "figure_art": "char_294_ayer"}, {"id": 273, "prop": "character", "attributes": {"name": "char_373_Leonhardt_1"}}, {"id": 274, "prop": "name", "attributes": {"content": "沒錯，順便告訴四月你一件很酷的事情吧，我們在外旅行的時候，還見過另一種派的吃法，就是要用手拿著派然後跑跳到空中——", "name": "萊恩哈特"}, "figure_art": "char_373_Leonhardt_1"}, {"id": 275, "prop": "character", "attributes": {"name": "char_365_aprl"}}, {"id": 276, "prop": "name", "attributes": {"content": "哇！小心，要掉下來了，派要掉下來了......！", "name": "四月"}, "figure_art": "char_365_aprl"}, {"id": 277, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 278, "prop": "name", "attributes": {"content": "等、等等，現在還是別人的工作時間，安靜一些......萊恩哈特，坐好！", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 279, "prop": "character", "attributes": {"name": "char_373_Leonhardt_1"}}, {"id": 280, "prop": "name", "attributes": {"content": "唔，好吧......", "name": "萊恩哈特"}, "figure_art": "char_373_Leonhardt_1"}, {"id": 281, "prop": "dialog", "attributes": {}}, {"id": 282, "prop": "character", "attributes": {}}, {"id": 283, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 284, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 285, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 286, "prop": "character", "attributes": {"name": "char_002_amiya_1#3", "fadetime": 1.5}}, {"id": 287, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 288, "prop": "name", "attributes": {"content": "打擾一下......", "name": "阿米婭"}, "figure_art": "char_002_amiya_1#3"}, {"id": 289, "prop": "character", "attributes": {"name": "char_365_aprl", "name2": "char_294_ayer"}}, {"id": 290, "prop": "name", "attributes": {"content": "啊。", "name": "四月&斷崖"}, "figure_art": "char_002_amiya_1#3"}, {"id": 291, "prop": "character", "attributes": {"name": "char_373_Leonhardt_1"}}, {"id": 292, "prop": "name", "attributes": {"content": "哇啊，是阿米婭和博士——", "name": "萊恩哈特"}, "figure_art": "char_373_Leonhardt_1"}, {"id": 293, "prop": "character", "attributes": {"name": "char_002_amiya_1#2"}}, {"id": 294, "prop": "name", "attributes": {"content": "原來是大家在用餐啊。", "name": "阿米婭"}, "figure_art": "char_002_amiya_1#2"}, {"id": 295, "prop": "character", "attributes": {"name": "char_373_Leonhardt_1"}}, {"id": 296, "prop": "name", "attributes": {"content": "不、不是的，這個是，呃，暴行大姐邀請我們參與的“家鄉美食品嘗會”......", "name": "萊恩哈特"}, "figure_art": "char_373_Leonhardt_1"}, {"id": 297, "prop": "Character", "attributes": {"name": "char_230_savage_1"}}, {"id": 298, "prop": "name", "attributes": {"content": "把餐廳弄得這麼亂，抱歉啊阿米婭、博士，我會好好收拾的。", "name": "暴行"}, "figure_art": "char_230_savage_1"}, {"id": 299, "prop": "character", "attributes": {"name": "char_002_amiya_1#10"}}, {"id": 300, "prop": "name", "attributes": {"content": "沒關係，我們也是來品嘗暴行姐姐的烹飪的美食的，之後一起打掃吧。", "name": "阿米婭"}, "figure_art": "char_002_amiya_1#10"}, {"id": 301, "prop": "character", "attributes": {"name": "char_365_aprl", "name2": "char_294_ayer", "focus": 2.0}}, {"id": 302, "prop": "name", "attributes": {"content": "糗大了呢，萊特。", "name": "斷崖"}, "figure_art": "char_294_ayer"}, {"id": 303, "prop": "character", "attributes": {"name": "char_373_Leonhardt_1"}}, {"id": 304, "prop": "name", "attributes": {"content": "我還以為就我們四個人，耍一耍酷也沒關係呢......四月，下次再給你表演那種特別的吃法吧。", "name": "萊恩哈特"}, "figure_art": "char_373_Leonhardt_1"}, {"id": 305, "prop": "dialog", "attributes": {}}, {"id": 306, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 307, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 308, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 309, "prop": "Character", "attributes": {}}, {"id": 310, "prop": "Image", "attributes": {}}, {"id": 311, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}