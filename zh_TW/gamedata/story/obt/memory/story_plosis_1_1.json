ributes": {"time": 1.5}}, {"id": 348, "prop": "character", "attributes": {"name": "char_134_ifrit_5#10", "fadetime": 1.5}}, {"id": 349, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 350, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 351, "prop": "name", "attributes": {"content": "  是赫默！", "name": "伊芙利特"}, "figure_art": "char_134_ifrit_5#10"}, {"id": 352, "prop": "Dialog", "attributes": {}}, {"id": 353, "prop": "character", "attributes": {}}, {"id": 354, "prop": "playsound", "attributes": {"key": "$dooropenquite"}}, {"id": 355, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 356, "prop": "character", "attributes": {"name": "avg_128_plosis_1#1$1", "fadetime": 1.5}}, {"id": 357, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 358, "prop": "name", "attributes": {"content": "  否定。", "name": "白面鴞"}, "figure_art": "avg_128_plosis_1#1$1"}, {"id": 359, "prop": "Character", "attributes": {"name": "avg_128_plosis_1#1$1", "name2": "char_134_ifrit_5#6", "focus": 2.0}}, {"id": 360, "prop": "name", "attributes": {"content": "  是喬伊絲姐姐！", "name": "伊芙利特"}, "figure_art": "char_134_ifrit_5#6"}, {"id": 361, "prop": "Character", "attributes": {"name": "char_242_mayer#3"}}, {"id": 362, "prop": "name", "attributes": {"content": "  赫默又加班了？", "name": "梅爾"}, "figure_art": "char_242_mayer#3"}, {"id": 363, "prop": "Character", "attributes": {"name": "avg_128_plosis_1#1$1", "name2": "char_134_ifrit_5", "focus": 1.0}}, {"id": 364, "prop": "name", "attributes": {"content": "  是。", "name": "白面鴞"}, "figure_art": "avg_128_plosis_1#1$1"}, {"id": 365, "prop": "name", "attributes": {"content": "  這是伊芙利特的藥。", "name": "白面鴞"}, "figure_art": "avg_128_plosis_1#1$1"}, {"id": 366, "prop": "Character", "attributes": {"name": "avg_128_plosis_1#1$1", "name2": "char_134_ifrit_5#9", "focus": 2.0}}, {"id": 367, "prop": "name", "attributes": {"content": "  唉......又是很苦的那種......", "name": "伊芙利特"}, "figure_art": "char_134_ifrit_5#9"}, {"id": 368, "prop": "Character", "attributes": {"name": "char_242_mayer#2"}}, {"id": 369, "prop": "name", "attributes": {"content": "  放在那邊吧，一會我收起來。", "name": "梅爾"}, "figure_art": "char_242_mayer#2"}, {"id": 370, "prop": "Character", "attributes": {"name": "avg_128_plosis_1#1$1", "name2": "char_134_ifrit_5", "focus": 1.0}}, {"id": 371, "prop": "name", "attributes": {"content": "  這是給伊芙利特的點心。", "name": "白面鴞"}, "figure_art": "avg_128_plosis_1#1$1"}, {"id": 372, "prop": "Character", "attributes": {"name": "avg_128_plosis_1#1$1", "name2": "char_134_ifrit_5#5", "focus": 2.0}}, {"id": 373, "prop": "name", "attributes": {"content": "  好欸！謝謝喬伊絲姐姐！", "name": "伊芙利特"}, "figure_art": "char_134_ifrit_5#5"}, {"id": 374, "prop": "Character", "attributes": {"name": "char_242_mayer#3"}}, {"id": 375, "prop": "name", "attributes": {"content": "  等一下！作業寫完之前不准吃點心！", "name": "梅爾"}, "figure_art": "char_242_mayer#3"}, {"id": 376, "prop": "Character", "attributes": {"name": "avg_128_plosis_1#1$1", "name2": "char_134_ifrit_5", "focus": 2.0}}, {"id": 377, "prop": "name", "attributes": {"content": "  我這就去寫！", "name": "伊芙利特"}, "figure_art": "char_134_ifrit_5"}, {"id": 378, "prop": "Character", "attributes": {"name": "avg_128_plosis_1#1$1", "name2": "char_134_ifrit_5#5", "focus": 2.0}}, {"id": 379, "prop": "name", "attributes": {"content": "  我今天測驗得了七十分哦！誇我吧！", "name": "伊芙利特"}, "figure_art": "char_134_ifrit_5#5"}, {"id": 380, "prop": "Character", "attributes": {"name": "avg_128_plosis_1#3$1", "name2": "char_134_ifrit_5#5", "focus": 1.0}}, {"id": 381, "prop": "name", "attributes": {"content": "  努力是有收獲的，請繼續保持。", "name": "白面鴞"}, "figure_art": "avg_128_plosis_1#3$1"}, {"id": 382, "prop": "Character", "attributes": {"name": "char_242_mayer#3"}}, {"id": 383, "prop": "name", "attributes": {"content": "  才七十分哦，我出的題一點都不難，再加把勁吧，伊芙利特。", "name": "梅爾"}, "figure_art": "char_242_mayer#3"}, {"id": 384, "prop": "Character", "attributes": {"name": "avg_128_plosis_1#1$1", "name2": "char_134_ifrit_5#7", "focus": 2.0}}, {"id": 385, "prop": "name", "attributes": {"content": "  好吧......", "name": "伊芙利特"}, "figure_art": "char_134_ifrit_5#7"}, {"id": 386, "prop": "name", "attributes": {"content": "  說起來......", "name": "伊芙利特"}, "figure_art": "char_134_ifrit_5#7"}, {"id": 387, "prop": "Character", "attributes": {"name": "avg_128_plosis_1#1$1", "name2": "char_134_ifrit_5#4", "focus": 2.0}}, {"id": 388, "prop": "name", "attributes": {"content": "  喬伊絲姐姐今天為什麼這麼高興？", "name": "伊芙利特"}, "figure_art": "char_134_ifrit_5#4"}, {"id": 389, "prop": "Character", "attributes": {"name": "avg_128_plosis_1#5$1", "name2": "char_134_ifrit_5#4", "focus": 1.0}}, {"id": 390, "prop": "name", "attributes": {"content": "  遇到了一些正面偶發情況。尚未到達需要表現出強情緒波動的程度。", "name": "白面鴞"}, "figure_art": "avg_128_plosis_1#5$1"}, {"id": 391, "prop": "Character", "attributes": {"name": "char_242_mayer#3"}}, {"id": 392, "prop": "name", "attributes": {"content": "  ？？？", "name": "梅爾"}, "figure_art": "char_242_mayer#3"}, {"id": 393, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 394, "prop": "name", "attributes": {"content": "  稍等，伊芙利特你是怎麼看出來喬伊絲很高興的？", "name": "梅爾"}, "figure_art": "char_242_mayer#3"}, {"id": 395, "prop": "character", "attributes": {"name": "char_134_ifrit_5"}}, {"id": 396, "prop": "name", "attributes": {"content": "  誒？很容易看出來吧。喬伊絲姐姐高興的時候，眉毛會上揚一點，額頭會緊湊一點，嘴角也有變化。", "name": "伊芙利特"}, "figure_art": "char_134_ifrit_5"}, {"id": 397, "prop": "Character", "attributes": {"name": "char_242_mayer#3"}}, {"id": 398, "prop": "name", "attributes": {"content": "  ......這怎麼總結出來的？", "name": "梅爾"}, "figure_art": "char_242_mayer#3"}, {"id": 399, "prop": "character", "attributes": {"name": "char_134_ifrit_5#5"}}, {"id": 400, "prop": "name", "attributes": {"content": "  你習慣就好啦！", "name": "伊芙利特"}, "figure_art": "char_134_ifrit_5#5"}, {"id": 401, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 402, "prop": "Dialog", "attributes": {}}, {"id": 403, "prop": "Character", "attributes": {}}, {"id": 404, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 405, "prop": "Background", "attributes": {"image": "bg_room_2", "screenadapt": "coverall"}}, {"id": 406, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 407, "prop": "playMusic", "attributes": {"intro": "$darkness01_intro", "key": "$darkness01_loop", "volume": 0.4}}, {"id": 408, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.5, "isblock": "true"}}, {"id": 409, "prop": "name", "attributes": {"content": "  6月23日 天氣多雲", "name": "日記"}}, {"id": 410, "prop": "name", "attributes": {"content": "  赫默醫生說我是她的朋友，我很感激她。", "name": "日記"}}, {"id": 411, "prop": "name", "attributes": {"content": "  赫默醫生是一個好人，但正是這樣，我才不想給她增添額外的負擔。", "name": "日記"}}, {"id": 412, "prop": "name", "attributes": {"content": "  赫默醫生身上的重擔已經太多了。", "name": "日記"}}, {"id": 413, "prop": "name", "attributes": {"content": "  伊芙利特身上的“炎魔”，以及她與塞雷婭要面對的問題。", "name": "日記"}}, {"id": 414, "prop": "name", "attributes": {"content": "  但是......如果我的命運已經註定。", "name": "日記"}}, {"id": 415, "prop": "name", "attributes": {"content": "  我多麼希望赫默醫生與伊芙利特能有一個好的結局。", "name": "日記"}}, {"id": 416, "prop": "name", "attributes": {"content": "  我和她們的情況有著很大區別，但又都可以歸結到萊茵生命的常見實驗問題裡去。", "name": "日記"}}, {"id": 417, "prop": "name", "attributes": {"content": "  萊茵生命中有很多我們這樣的人。", "name": "日記"}}, {"id": 418, "prop": "name", "attributes": {"content": "  外人認為哥倫比亞科研涉及了許多人體實驗。", "name": "日記"}}, {"id": 419, "prop": "name", "attributes": {"content": "  但實際情況還要再多加一句描述，許多實驗都是過於“熱忱”的科研人員在自己身上進行的。", "name": "日記"}}, {"id": 420, "prop": "name", "attributes": {"content": "  ......有好結果的，只是其中少數。", "name": "日記"}}, {"id": 421, "prop": "dialog", "attributes": {}}, {"id": 422, "prop": "Character", "attributes": {}}, {"id": 423, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 424, "prop": "Background", "attributes": {"image": "bg_black", "screenadapt": "coverall"}}, {"id": 425, "prop": "character", "attributes": {"name": "avg_128_plosis_1#8$1"}}, {"id": 426, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.5, "isblock": "true"}}, {"id": 427, "prop": "name", "attributes": {"content": "夢——"}}, {"id": 428, "prop": "name", "attributes": {"content": "喬伊絲的夢中充斥著幻覺與低語，虛幻世界裡充盈了太多她不理解的事物。"}}, {"id": 429, "prop": "name", "attributes": {"content": "她在日復一日的漫長夢境中行走，即便無法理解，這些光景也早已成為了習慣。"}}, {"id": 430, "prop": "name", "attributes": {"content": "然而，在這短暫的一瞬間，她突然意識到，夢境正在變得清晰。"}}, {"id": 431, "prop": "character", "attributes": {"name": "avg_128_plosis_1#6$1"}}, {"id": 432, "prop": "name", "attributes": {"content": "耳邊傳來的陣陣低鳴逐漸成為可以辨別的詞句。"}}, {"id": 433, "prop": "name", "attributes": {"content": "籠罩在視野裡的薄霧也開始緩緩散去。"}}, {"id": 434, "prop": "character", "attributes": {"name": "avg_128_plosis_1#1$1"}}, {"id": 435, "prop": "name", "attributes": {"content": "她站立在巍峨的高山上，她俯瞰著下方的一切。"}}, {"id": 436, "prop": "name", "attributes": {"content": "在她面前，宏偉的城市在閃爍著金屬光澤的沙塵中崩塌，高聳的鋼架結構黏土一般地融化。"}}, {"id": 437, "prop": "name", "attributes": {"content": "在她面前，可怖的巨物之影飄浮在雲層中，扭動的巨大黑影蓋過了太陽，籠罩了一切。"}}, {"id": 438, "prop": "name", "attributes": {"content": "在她面前，城市中遊蕩著淒厲的尖嘯聲與絕望的呼喊聲。"}}, {"id": 439, "prop": "name", "attributes": {"content": "在她身後，源石結晶閃耀著奇詭的光芒。"}}, {"id": 440, "prop": "Dialog", "attributes": {}}, {"id": 441, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 442, "prop": "Character", "attributes": {}}, {"id": 443, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 444, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 445, "prop": "Subtitle", "attributes": {"text": "閃耀著。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 446, "prop": "Subtitle", "attributes": {"text": "閃耀著。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 447, "prop": "Subtitle", "attributes": {"text": "閃耀著。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 448, "prop": "subtitle", "attributes": {}}, {"id": 449, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 450, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 451, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 452, "prop": "Image", "attributes": {}}, {"id": 453, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}