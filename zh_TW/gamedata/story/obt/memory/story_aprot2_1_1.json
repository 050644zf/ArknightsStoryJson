", "name": "avg_4025_aprot2_1#2$1", "focus": "m"}}, {"id": 65, "prop": "name", "attributes": {"content": "給你，你走吧。", "name": "沉淵"}, "figure_art": "avg_4025_aprot2_1#2$1"}, {"id": 66, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_701_1#1$1", "focus": "m"}}, {"id": 67, "prop": "name", "attributes": {"content": "可是，沉淵！", "name": "悲傷的男性"}, "figure_art": "avg_npc_701_1#1$1"}, {"id": 68, "prop": "name", "attributes": {"content": "放走了我，你要怎麼辦？", "name": "悲傷的男性"}, "figure_art": "avg_npc_701_1#1$1"}, {"id": 69, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4025_aprot2_1#4$1", "focus": "m"}}, {"id": 70, "prop": "name", "attributes": {"content": "我……", "name": "沉淵"}, "figure_art": "avg_4025_aprot2_1#4$1"}, {"id": 71, "prop": "Dialog", "attributes": {}}, {"id": 72, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 73, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 74, "prop": "charslot", "attributes": {}}, {"id": 75, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 76, "prop": "Background", "attributes": {"image": "bg_black", "screenadapt": "showall"}}, {"id": 77, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 78, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 79, "prop": "name", "attributes": {"content": "你又一次做出了選擇。"}}, {"id": 80, "prop": "name", "attributes": {"content": "你已經很清楚自己要怎麼做了，不是嗎？"}}, {"id": 81, "prop": "Dialog", "attributes": {}}, {"id": 82, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 83, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 84, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 85, "prop": "charslot", "attributes": {}}, {"id": 86, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 87, "prop": "Background", "attributes": {"image": "bg_county_1", "screenadapt": "showall"}}, {"id": 88, "prop": "playMusic", "attributes": {"intro": "$distressed_intro", "key": "$distressed_loop", "volume": 0.6}}, {"id": 89, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 90, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 91, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 92, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_005", "duration": 1.5}}, {"id": 93, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 94, "prop": "name", "attributes": {"content": "小伙子，多謝你這幾天幫著照顧孩子們。", "name": "和善的村人"}, "figure_art": "avg_npc_005"}, {"id": 95, "prop": "name", "attributes": {"content": "幾個小崽子都說你講故事講得好聽咧！", "name": "和善的村人"}, "figure_art": "avg_npc_005"}, {"id": 96, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4025_aprot2_1#1$1"}}, {"id": 97, "prop": "name", "attributes": {"content": "不用謝，老伯。", "name": "沉淵"}, "figure_art": "avg_4025_aprot2_1#1$1"}, {"id": 98, "prop": "name", "attributes": {"content": "孩子們都很聽話，反而是我們借住在這裡，給各位添麻煩了。", "name": "沉淵"}, "figure_art": "avg_4025_aprot2_1#1$1"}, {"id": 99, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_005"}}, {"id": 100, "prop": "name", "attributes": {"content": "不麻煩不麻煩。", "name": "和善的村人"}, "figure_art": "avg_npc_005"}, {"id": 101, "prop": "name", "attributes": {"content": "哎，那我就不耽擱你們幹活了。", "name": "和善的村人"}, "figure_art": "avg_npc_005"}, {"id": 102, "prop": "Dialog", "attributes": {}}, {"id": 103, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 104, "prop": "charslot", "attributes": {"duration": 1.5}}, {"id": 105, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 106, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_012", "focus": "l"}}, {"id": 107, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4025_aprot2_1#1$1", "focus": "l"}}, {"id": 108, "prop": "name", "attributes": {"content": "給小孩講故事？", "name": "羅德島幹員"}, "figure_art": "avg_npc_012"}, {"id": 109, "prop": "name", "attributes": {"content": "看來你和村裡人相處得挺不錯。", "name": "羅德島幹員"}, "figure_art": "avg_npc_012"}, {"id": 110, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4025_aprot2_1#10$1", "focus": "r"}}, {"id": 111, "prop": "name", "attributes": {"content": "動動嘴而已，也不費什麼功夫。", "name": "沉淵"}, "figure_art": "avg_4025_aprot2_1#10$1"}, {"id": 112, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_012", "focus": "l"}}, {"id": 113, "prop": "name", "attributes": {"content": "那也是你有這個耐心，我就不太行。", "name": "羅德島幹員"}, "figure_art": "avg_npc_012"}, {"id": 114, "prop": "name", "attributes": {"content": "這幾天過得太平靜了，任務也沒出什麼意外，我都不太習慣了。", "name": "羅德島幹員"}, "figure_art": "avg_npc_012"}, {"id": 115, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4025_aprot2_1#9$1", "focus": "r"}}, {"id": 116, "prop": "name", "attributes": {"content": "平靜一點也很好。", "name": "沉淵"}, "figure_art": "avg_4025_aprot2_1#9$1"}, {"id": 117, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4025_aprot2_1#1$1", "focus": "r"}}, {"id": 118, "prop": "name", "attributes": {"content": "我倒是希望不要出任何意外……", "name": "沉淵"}, "figure_art": "avg_4025_aprot2_1#1$1"}, {"id": 119, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_012", "focus": "l"}}, {"id": 120, "prop": "name", "attributes": {"content": "你的理想是隱居嘛。我知道。", "name": "羅德島幹員"}, "figure_art": "avg_npc_012"}, {"id": 121, "prop": "name", "attributes": {"content": "對了，沉淵。", "name": "羅德島幹員"}, "figure_art": "avg_npc_012"}, {"id": 122, "prop": "name", "attributes": {"content": "我這有件禮物要給你。", "name": "羅德島幹員"}, "figure_art": "avg_npc_012"}, {"id": 123, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 124, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4025_aprot2_1#4$1", "focus": "r"}}, {"id": 125, "prop": "name", "attributes": {"content": "禮物？是什麼……