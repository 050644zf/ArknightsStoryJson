{"lang": "zh_TW", "eventid": "story_aprot2_set_1", "eventName": "那一場戲", "entryType": "NONE", "storyCode": null, "avgTag": "幕間", "storyName": "那一場戲", "storyInfo": "暮落總是夢到過去的事。\n", "storyList": [{"id": 0, "prop": "HEADER", "attributes": {"key": "title_test", "is_skippable": "true", "fit_mode": "BLACK_MASK"}}, {"id": 1, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 2, "prop": "stopmusic", "attributes": {}}, {"id": 3, "prop": "Dialog", "attributes": {}}, {"id": 4, "prop": "Background", "attributes": {"image": "bg_black", "screenadapt": "coverall"}}, {"id": 5, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 6, "prop": "playMusic", "attributes": {"intro": "$darkness01_intro", "key": "$darkness01_loop", "volume": 0.6}}, {"id": 7, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 8, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 9, "prop": "name", "attributes": {"content": "天空的顏色很古怪。"}}, {"id": 10, "prop": "name", "attributes": {"content": "太陽暗淡無光，雲朵染著灰色，天幕從遠處開始破碎，裂痕向著中心蔓延。"}}, {"id": 11, "prop": "name", "attributes": {"content": "但這一切在此時都不再重要。"}}, {"id": 12, "prop": "name", "attributes": {"content": "你還記得這一天。"}}, {"id": 13, "prop": "name", "attributes": {"content": "你總是忘不掉這一天。"}}, {"id": 14, "prop": "name", "attributes": {"content": "這一天好似一個注定會來的預言，早已被所有人知曉。"}}, {"id": 15, "prop": "name", "attributes": {"content": "這一天又像一個無法擺脫的噩夢，從無一刻停止糾纏。"}}, {"id": 16, "prop": "name", "attributes": {"content": "你已經分不清這是否是一場戲。"}}, {"id": 17, "prop": "name", "attributes": {"content": "你的生活，或許從來只是他人眼中的一場戲。"}}, {"id": 18, "prop": "name", "attributes": {"content": "沉淵。"}}, {"id": 19, "prop": "name", "attributes": {"content": "你問你自己。"}}, {"id": 20, "prop": "name", "attributes": {"content": "台上的演員只有劇本，可是你呢？"}}, {"id": 21, "prop": "name", "attributes": {"content": "你要怎麼選擇？"}}, {"id": 22, "prop": "Dialog", "attributes": {}}, {"id": 23, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 24, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 25, "prop": "charslot", "attributes": {}}, {"id": 26, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 27, "prop": "Background", "attributes": {"image": "bg_indoor_u", "screenadapt": "showall"}}, {"id": 28, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 29, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 30, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 31, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4025_aprot2_1#6$1", "duration": 1.5}}, {"id": 32, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 33, "prop": "playsound", "attributes": {"key": "$d_avg_daggerexsheath"}}, {"id": 34, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 35, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4025_aprot2_1#6$1"}}, {"id": 36, "prop": "name", "attributes": {"content": "……", "name": "沉淵"}, "figure_art": "avg_4025_aprot2_1#6$1"}, {"id": 37, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4025_aprot2_1#5$1"}}, {"id": 38, "prop": "name", "attributes": {"content": "我還是做不到。", "name": "沉淵"}, "figure_art": "avg_4025_aprot2_1#5$1"}, {"id": 39, "prop": "Dialog", "attributes": {}}, {"id": 40, "prop": "charslot", "attributes": {}}, {"id": 41, "prop": "playsound", "attributes": {"key": "$d_avg_clothmovement"}}, {"id": 42, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 43, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_701_1#1$1", "focus": "m"}}, {"id": 44, "prop": "name", "attributes": {"content": "沉淵，你不該心軟。", "name": "悲傷的男性"}, "figure_art": "avg_npc_701_1#1$1"}, {"id": 45, "prop": "name", "attributes": {"content": "如果不是我搞砸了我們的計劃，其他人也不會死。", "name": "悲傷的男性"}, "figure_art": "avg_npc_701_1#1$1"},