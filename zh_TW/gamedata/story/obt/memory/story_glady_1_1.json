.05, "block": "true"}}, {"id": 344, "prop": "characteraction", "attributes": {"name": "left", "type": "jump", "power": 5.0, "times": 1.0, "fadetime": 1.0, "block": "true"}}, {"id": 345, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 346, "prop": "Character", "attributes": {}}, {"id": 347, "prop": "Dialog", "attributes": {}}, {"id": 348, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 349, "prop": "character", "attributes": {"name": "char_003_kalts_1", "blackstart": 0.2, "blackend": 0.7, "fadetime": 1.5, "block": "true"}}, {"id": 350, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 351, "prop": "name", "attributes": {"content": "  我建議你停止下次攻擊。", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 352, "prop": "Character", "attributes": {"name": "avg_474_gladiia_1#5"}}, {"id": 353, "prop": "name", "attributes": {"content": "  雖然您的力量不俗，但恐怕沒人能讓我停下。", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#5"}, {"id": 354, "prop": "MusicVolume", "attributes": {"volume": 0.4, "fadetime": 1.0}}, {"id": 355, "prop": "Character", "attributes": {"name": "char_003_kalts_1", "blackstart": 0.2, "blackend": 0.7, "name2": "avg_474_gladiia_1", "focus": 1.0}}, {"id": 356, "prop": "name", "attributes": {"content": "  再來一次，這教堂就該塌了。", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 357, "prop": "name", "attributes": {"content": "  你不在乎懲戒軍，然而我向你保證，就算是你，也不會想讓伊比利亞的審判官盯上。", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 358, "prop": "Character", "attributes": {"name": "char_003_kalts_1", "blackstart": 0.2, "blackend": 0.7, "name2": "avg_474_gladiia_1", "focus": 2.0}}, {"id": 359, "prop": "name", "attributes": {"content": "  陸上的鳥兒......", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1"}, {"id": 360, "prop": "Character", "attributes": {"name": "char_003_kalts_1", "blackstart": 0.2, "blackend": 0.7, "name2": "avg_474_gladiia_1", "focus": 1.0}}, {"id": 361, "prop": "name", "attributes": {"content": "  這些無謂的衝突只會影響你尋找同伴的速度。", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 362, "prop": "name", "attributes": {"content": "  （阿戈爾語）海底的國度或許還能等待。", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 363, "prop": "name", "attributes": {"content": "  （阿戈爾語）擱淺的獵人就不一定了。", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 364, "prop": "Character", "attributes": {"name": "char_003_kalts_1", "blackstart": 0.2, "blackend": 0.7, "name2": "avg_474_gladiia_1#5", "focus": 2.0}}, {"id": 365, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 366, "prop": "name", "attributes": {"content": "  你......你知道阿戈爾？！你甚至知道我們......", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#5"}, {"id": 367, "prop": "Character", "attributes": {"name": "char_003_kalts_1", "blackstart": 0.2, "blackend": 0.7, "name2": "avg_474_gladiia_1", "focus": 1.0}}, {"id": 368, "prop": "name", "attributes": {"content": "  三個月零七天前，伊比利亞以南的海域再次發生了強烈的海洋異象。這消息迅速地被伊比利亞官方封鎖，但我有我獲知資訊的手段。", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 369, "prop": "Character", "attributes": {"name": "char_003_kalts_1", "blackstart": 0.2, "blackend": 0.7, "name2": "avg_474_gladiia_1", "focus": 2.0}}, {"id": 370, "prop": "name", "attributes": {"content": "  您有意找我，又或者您和我一樣，也找到了這裡？", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1"}, {"id": 371, "prop": "Character", "attributes": {"name": "char_003_kalts_1", "blackstart": 0.2, "blackend": 0.7, "name2": "avg_474_gladiia_1", "focus": 1.0}}, {"id": 372, "prop": "name", "attributes": {"content": "  你甚至可以理解成，我在等你，且等了很久。", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 373, "prop": "name", "attributes": {"content": "  你被特殊的洋流送到了岸上，這對你來說也許很痛苦，但對我們和阿戈爾來說都是機會。", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 374, "prop": "Character", "attributes": {"name": "char_003_kalts_1", "blackstart": 0.2, "blackend": 0.7, "name2": "avg_474_gladiia_1", "focus": 2.0}}, {"id": 375, "prop": "name", "attributes": {"content": "  您沒有敵意，否則，您透露出來的這些資訊，已足夠讓我奪走您的性命。", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1"}, {"id": 376, "prop": "Character", "attributes": {"name": "char_003_kalts_1", "blackstart": 0.2, "blackend": 0.7, "name2": "avg_474_gladiia_1", "focus": 1.0}}, {"id": 377, "prop": "name", "attributes": {"content": "  你能做到，但，沒這個必要。", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 378, "prop": "name", "attributes": {"content": "  你早已聞見，我和大海沒有關係。可陸地與海洋，其實並沒有距離。", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 379, "prop": "name", "attributes": {"content": "  海洋或許驕傲到很少關注大地，大地卻不能對海洋裡正在發生的災難熟視無睹。", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 380, "prop": "Character", "attributes": {"name": "char_003_kalts_1", "blackstart": 0.2, "blackend": 0.7, "name2": "avg_474_gladiia_1", "focus": 2.0}}, {"id": 381, "prop": "name", "attributes": {"content": "  ......我來到這裡以後，您是第一個讓我感到驚訝的人。", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1"}, {"id": 382, "prop": "Character", "attributes": {"name": "char_003_kalts_1", "blackstart": 0.2, "blackend": 0.7, "name2": "avg_474_gladiia_1", "focus": 1.0}}, {"id": 383, "prop": "name", "attributes": {"content": "  你很清楚，這算不上一個合格的談話場所。", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 384, "prop": "name", "attributes": {"content": "  而且，拖著重傷的身軀來到一個全然陌生的環境，你撐不了太長時間。", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 385, "prop": "Character", "attributes": {"name": "char_003_kalts_1", "blackstart": 0.2, "blackend": 0.7, "name2": "avg_474_gladiia_1#5", "focus": 2.0}}, {"id": 386, "prop": "name", "attributes": {"content": "  足夠我把這些垃圾都找出來切碎。", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#5"}, {"id": 387, "prop": "Character", "attributes": {"name": "char_003_kalts_1", "blackstart": 0.2, "blackend": 0.7, "name2": "avg_474_gladiia_1", "focus": 1.0}}, {"id": 388, "prop": "name", "attributes": {"content": "  你清楚這場戰爭還會持續多久。", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 389, "prop": "name", "attributes": {"content": "  如果他們不是這麼擅長躲藏，阿戈爾會容許他們存在至今？", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 390, "prop": "Character", "attributes": {"name": "char_003_kalts_1", "blackstart": 0.2, "blackend": 0.7, "name2": "avg_474_gladiia_1", "focus": 2.0}}, {"id": 391, "prop": "name", "attributes": {"content": "  他們的所作所為，對阿戈爾還構不成威脅。", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1"}, {"id": 392, "prop": "Character", "attributes": {"name": "char_003_kalts_1", "blackstart": 0.2, "blackend": 0.7, "name2": "avg_474_gladiia_1", "focus": 1.0}}, {"id": 393, "prop": "name", "attributes": {"content": "  你想把他們和它們區分開，但恐怕他們自己不這麼想。", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 394, "prop": "name", "attributes": {"content": "  是留在這裡，繼續朝我揮舞你的長槊，還是先同我一起離開，好好談談可能的合作——", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 395, "prop": "name", "attributes": {"content": "  你可以選。", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 396, "prop": "name", "attributes": {"content": "  阿戈爾的命運，你和你同伴的命運，伊比利亞乃至這片大地的命運......都在你手上。", "name": "？？？"}, "figure_art": "char_003_kalts_1"}, {"id": 397, "prop": "stopmusic", "attributes": {"fadetime": 0.5}}, {"id": 398, "prop": "Character", "attributes": {"name": "avg_474_gladiia_1#4"}}, {"id": 399, "prop": "name", "attributes": {"content": "  ......", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#4"}, {"id": 400, "prop": "name", "attributes": {"content": "  在我們就具體合作事項展開討論之前，您是否可以先告訴我您的名字？", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#4"}, {"id": 401, "prop": "Dialog", "attributes": {}}, {"id": 402, "prop": "Character", "attributes": {}}, {"id": 403, "prop": "character", "attributes": {"name": "char_003_kalts_1", "fadetime": 1.5}}, {"id": 404, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 405, "prop": "name", "attributes": {"content": "  當然。", "name": "凱爾希"}, "figure_art": "char_003_kalts_1"}, {"id": 406, "prop": "Dialog", "attributes": {}}, {"id": 407, "prop": "Character", "attributes": {}}, {"id": 408, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 409, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 410, "prop": "Image", "attributes": {}}, {"id": 411, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}