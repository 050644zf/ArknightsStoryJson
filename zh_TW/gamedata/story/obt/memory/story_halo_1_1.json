", "attributes": {"content": "繼續整理吧。", "name": "埃琳娜"}, "figure_art": "avg_135_halo_1#1$1"}, {"id": 403, "prop": "Dialog", "attributes": {}}, {"id": 404, "prop": "charslot", "attributes": {}}, {"id": 405, "prop": "playsound", "attributes": {"key": "$d_avg_clothmovement"}}, {"id": 406, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 407, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_135_halo_1#12$1"}}, {"id": 408, "prop": "name", "attributes": {"content": "嗯......這是什麼？", "name": "埃琳娜"}, "figure_art": "avg_135_halo_1#12$1"}, {"id": 409, "prop": "Dialog", "attributes": {}}, {"id": 410, "prop": "charslot", "attributes": {}}, {"id": 411, "prop": "name", "attributes": {"content": "已經被自己收拾過的桌面上放著兩份文件。"}}, {"id": 412, "prop": "name", "attributes": {"content": "埃琳娜拿了起來，上面那份是她搶出來的實驗數據的報告。"}}, {"id": 413, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_135_halo_1#12$1"}}, {"id": 414, "prop": "name", "attributes": {"content": "可惜實驗材料已經被毀了，以後有機會再嘗試復原一下吧。也不知道下家公司有沒有現在這種條件......", "name": "埃琳娜"}, "figure_art": "avg_135_halo_1#12$1"}, {"id": 415, "prop": "Dialog", "attributes": {}}, {"id": 416, "prop": "playsound", "attributes": {"key": "$d_avg_clothmovement"}}, {"id": 417, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 418, "prop": "name", "attributes": {"content": "這是......", "name": "埃琳娜"}}, {"id": 419, "prop": "name", "attributes": {"content": "能量科主任斐爾迪南直屬項目調入確認......？", "name": "埃琳娜"}}, {"id": 420, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_135_halo_1#7$1"}}, {"id": 421, "prop": "name", "attributes": {"content": "啊！", "name": "埃琳娜"}, "figure_art": "avg_135_halo_1#7$1"}, {"id": 422, "prop": "name", "attributes": {"content": "啊？", "name": "埃琳娜"}, "figure_art": "avg_135_halo_1#7$1"}, {"id": 423, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_135_halo_1#2$1"}}, {"id": 424, "prop": "name", "attributes": {"content": "啊！！真的？", "name": "埃琳娜"}, "figure_art": "avg_135_halo_1#2$1"}, {"id": 425, "prop": "name", "attributes": {"content": "真的真的？", "name": "埃琳娜"}, "figure_art": "avg_135_halo_1#2$1"}, {"id": 426, "prop": "Dialog", "attributes": {}}, {"id": 427, "prop": "charslot", "attributes": {}}, {"id": 428, "prop": "playsound", "attributes": {"key": "$d_avg_smashtable", "volume": 1.0}}, {"id": 429, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 430, "prop": "name", "attributes": {"content": "埃琳娜舉著調入確認，一下子蹦了起來，頭結結實實地撞到了櫃角。"}}, {"id": 431, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_135_halo_1#12$1"}}, {"id": 432, "prop": "name", "attributes": {"content": "啊嗚......！", "name": "埃琳娜"}, "figure_art": "avg_135_halo_1#12$1"}, {"id": 433, "prop": "Dialog", "attributes": {}}, {"id": 434, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_135_halo_1#1$1"}}, {"id": 435, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 436, "prop": "charslot", "attributes": {"duration": 1.5}}, {"id": 437, "prop": "playsound", "attributes": {"key": "$d_avg_clothmovement"}}, {"id": 438, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 439, "prop": "playsound", "attributes": {"key": "$d_avg_paper1"}}, {"id": 440, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 441, "prop": "name", "attributes": {"content": "她歡呼著倒在自己已經收拾好的背包上，在半空中狠狠地蹬腳，反覆確認文件上的內容。"}}, {"id": 442, "prop": "name", "attributes": {"content": "直到呼吸終於平穩，她小心地收好這份調入確認，撫平了剛才因為興奮而翹起來的髮羽，重新坐回座位上，打開自己的背包。"}}, {"id": 443, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_135_halo_1#5$1"}}, {"id": 444, "prop": "name", "attributes": {"content": "早知道剛才就不把數據報告收起來了。", "name": "埃琳娜"}, "figure_art": "avg_135_halo_1#5$1"}, {"id": 445, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_135_halo_1#1$1"}}, {"id": 446, "prop": "name", "attributes": {"content": "咳，冷靜......！冷靜！", "name": "埃琳娜"}, "figure_art": "avg_135_halo_1#1$1"}, {"id": 447, "prop": "charslot", "attributes": {"sl