{"lang": "zh_TW", "eventid": "story_ascln_set_1", "eventName": "同行人", "entryType": "NONE", "storyCode": null, "avgTag": "幕間", "storyName": "同行人", "storyInfo": "特蕾西婭遇刺後，一群不再與羅德島同行的薩卡茲在羅德島必經的航道上設伏，意圖阻截，而阿斯卡綸找上了他們。\n", "storyList": [{"id": 0, "prop": "HEADER", "attributes": {"key": "title_test", "is_skippable": "true", "fit_mode": "BLACK_MASK"}}, {"id": 1, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 2, "prop": "stopmusic", "attributes": {}}, {"id": 3, "prop": "Dialog", "attributes": {}}, {"id": 4, "prop": "Background", "attributes": {"image": "49_g4_kazdelstreet_shabby", "screenadapt": "coverall"}}, {"id": 5, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 6, "prop": "playMusic", "attributes": {"intro": "$ponder_intro", "key": "$ponder_loop", "volume": 0.6}}, {"id": 7, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 8, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 9, "prop": "name", "attributes": {"content": "1072年秋"}}, {"id": 10, "prop": "Dialog", "attributes": {}}, {"id": 11, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 12, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 13, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1297_1#1$1", "duration": 1.5, "posfrom": "-200,0", "posto": "0,0"}}, {"id": 14, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 15, "prop": "PlaySound", "attributes": {"key": "$d_avg_wind", "volume": 1.0}}, {"id": 16, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 17, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.3, "block": "true"}}, {"id": 18, "prop": "charslot", "attributes": {}}, {"id": 19, "prop": "Background", "attributes": {"image": "bg_black", "screenadapt": "coverall"}}, {"id": 20, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.3, "block": "true"}}, {"id": 21, "prop": "PlaySound", "attributes": {"key": "$d_avg_bldwhoosh"}}, {"id": 22, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1301_1#4$1", "posfrom": "50,0", "posto": "250,0", "duration": 0.3}}, {"id": 23, "prop": "Delay", "attributes": {"time": 0.1}}, {"id": 24, "prop": "charslot", "attributes": {"duration": 0.3}}, {"id": 25, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.3, "block": "true"}}, {"id": 26, "prop": "charslot", "attributes": {}}, {"id": 27, "prop": "Blocker", "attributes": {"a": 1.0, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 0.01, "block": "true"}}, {"id": 28, "prop": "CameraShake", "attributes": {"duration": 0.2, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 50.0, "randomness": 90.0, "fadeout": "false", "block": "false"}}, {"id": 29, "prop": "PlaySound", "attributes": {"key": "$swordtsing4"}}, {"id": 30, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.3, "block": "false"}}, {"id": 31, "prop": "Background", "attributes": {"image": "49_g4_kazdelstreet_shabby", "screenadapt": "coverall"}}, {"id": 32, "prop": "PlaySound", "attributes": {"key": "$d_avg_swordy"}}, {"id": 33, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 34, "prop": "name", "attributes": {"content": "刺客從陰影中躍出，一柄斷劍幾乎是貼著特雷西斯的前胸掠過。他側身，出手，佩劍已經橫在了刺客的脖頸。"}}, {"id": 35, "prop": "Dialog", "attributes": {}}, {"id": 36, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1301_1#1$1", "duration": 1.0}}, {"id": 37, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1297_1#1$1", "duration": 1.0}}, {"id": 38, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 39, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1301_1#1$1", "focus": "l"}}, {"id": 40, "prop": "name", "attributes": {"content": "……", "name": "阿斯卡綸"}}, {"id": 41, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1297_1#1$1", "focus": "r"}}, {"id": 42, "prop": "name", "attributes": {"content": "日影剛好在此時完全傾斜過來，將街道遮住。", "name": "特雷西斯"}}, {"id": 43, "prop": "name", "attributes": {"content": "……你一直在等待這一刻。", "name": "特雷西斯"}}, {"id": 44, "prop": "name", "attributes": {"content": "這樣確實能最大化發揮你的優勢，隱藏身形，接近敵人。但在晝夜交替的特殊時刻，你的敵人對環境變化的感知也會更敏感。", "name": "特雷西斯"}}, {"id": 45, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1301_1#1$1", "focus": "l"}}, {"id": 46, "prop": "name", "attributes": {"content": "好，知道了。", "name": "阿斯卡綸"}}, {"id": 47, "prop": "name", "attributes": {"content": "整個下午，我一共出手了七次，但一次都沒能得手。", "name": "阿斯卡綸"}}, {"id": 48, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1297_1#1$1", "focus": "r"}}, {"id": 49, "prop": "name", "attributes": {"content": "換一個對手，你早就成功了。", "name": "特雷西斯"}}, {"id": 50, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1297_1#3$1", "focus": "r"}}, {"id": 51, "prop": "name", "attributes": {"content": "你割斷了我胸前的綁帶……用這柄曾經被我斬斷的長劍。", "name": "特雷西斯"}}, {"id": 52, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1297_1#1$1", "focus": "r"}}, {"id": 53, "prop": "name", "attributes": {"content": "今天就到這裡，明天再繼續。", "name": "特雷西斯"}}, {"id": 54, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1301_1#3$1", "focus": "l"}}, {"id": 55, "prop": "name", "attributes": {"content": "……", "name": "阿斯卡綸"}}, {"id": 56, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1301_1#1$1", "focus": "l"}}, {"id": 57, "prop": "name", "attributes": {"content": "昨天，兩個喝醉的傭兵闖進了我們的辦公地點，他們扔下了一個酒壺，裡面是活性化的源石粉塵。", "name": "阿斯卡綸"}}, {"id": 58, "prop": "name", "attributes": {"content": "當時，殿下正在大廳為兩個孩子包紮傷口。", "name": "阿斯卡綸"}}, {"id": 59, "prop": "name", "attributes": {"content": "那不是意外。", "name": "阿斯卡綸"}}, {"id": 60, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1297_1#1$1", "focus": "r"}}, {"id": 61, "prop": "name", "attributes": {"content": "我已經知道，我已經處理過。", "name": "特雷西斯"}}, {"id": 62, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1301_1#4$1", "focus": "l"}}, {"id": 63, "prop": "name", "attributes": {"content": "類似的事情，越來越多。", "name": "阿斯卡綸"}}, {"id": 64, "prop": "name", "attributes": {"content": "軍事委員會……你保護不了殿下和巴別塔？你是真的沒有辦法，還是在縱容他們？", "name": "阿斯卡綸"}}, {"id": 65, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1297_1#1$1", "focus": "r"}}, {"id": 66, "prop": "name", "attributes": {"content": "這件事，不需要你來質問我，阿斯卡綸。", "name": "特雷西斯"}}, {"id": 67, "prop": "name", "attributes": {"content": "什麼對薩卡茲更好，我比你更清楚。", "name": "特雷西斯"}}, {"id": 68, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1301_1#4$1", "focus": "l"}}, {"id": 69, "prop": "name", "attributes": {"content": "可是，老師……", "name": "阿斯卡綸"}}, {"id": 70, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1301_1#5$1", "focus": "l"}}, {"id": 71, "prop": "name", "attributes": {"content": "如果真有人對殿下動手，你會出手嗎！", "name": "阿斯卡綸"}}, {"id": 72, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1297_1#1$1", "focus": "r"}}, {"id": 73, "prop": "name", "attributes": {"content": "會。", "name": "特雷西斯"}}, {"id": 74, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1301_1#5$1", "focus": "l"}}, {"id": 75, "prop": "name", "attributes": {"content": "那如果其他人都架著你，逼你對她動手，你會出手嗎？", "name": "阿斯卡綸"}}, {"id": 76, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 77, "prop": "name", "attributes": {"content": "沉默。"}}, {"id": 78, "prop": "name", "attributes": {"content": "但兩人的心中各自都有了答案。"}}, {"id": 79, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1301_1#2$1", "focus": "l"}}, {"id": 80, "prop": "name", "attributes": {"content": "這是最後一堂課了，老師。", "name": "阿斯卡綸"}}, {"id": 81, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1301_1#3$1", "focus": "l"}}, {"id": 82, "prop": "name", "attributes": {"content": "我沒有想通……但從明天起，我會去殿下身邊，守護好她。", "name": "阿斯卡綸"}}, {"id": 83, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1301_1#1$1", "focus": "l"}}, {"id": 84, "prop": "name", "attributes": {"content": "連帶著你本應有的心意一起。", "name": "阿斯卡綸"}}, {"id": 85, "prop": "Dialog", "attributes": {}}, {"id": 86, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 87, "prop": "name", "attributes": {"content": "阿斯卡綸不再言語，她彎腰撿起剛被特雷西斯打落的斷劍，以及散落在一旁，被她視作戰利品的斷裂綁帶。"}}, {"id": 88, "prop": "name", "attributes": {"content": "她頭也不回地離開。"}}, {"id": 89, "prop": "Dialog", "attributes": {}}, {"id": 90, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 91, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "0,0", "posto": "-200,0", "duration": 1.0, "afrom": 1.0, "ato": 0.0}}, {"id": 92, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 93, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1297_1#1$1", "focus": "r"}}, {"id": 94, "prop": "name", "attributes": {"content": "……", "name": "特雷西斯"}}, {"id": 95, "prop": "name", "attributes": {"content": "你選擇的只是某個人，而不是那個人腳下的道路。", "name": "特雷西斯"}}, {"id": 96, "prop": "name", "attributes": {"content": "不知道為何而行，那麼你要如何承受失去同行人的痛苦，阿斯卡綸？", "name": "特雷西斯"}}, {"id": 97, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 98, "prop": "Dialog", "attributes": {}}, {"id": 99, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 100, "prop": "charslot", "attributes": {}}, {"id": 101, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 102, "prop": "Background", "attributes": {"image": "bg_coldforest", "screenadapt": "coverall"}}, {"id": 103, "prop": "playMusic", "attributes": {"intro": "$loading_intro", "key": "$loading_loop", "volume": 0.6}}, {"id": 104, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 105, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 106, "prop": "name", "attributes": {"content": "1094年秋"}}, {"id": 107, "prop": "name", "attributes": {"content": "卡茲戴爾北部地區"}}, {"id": 108, "prop": "Dialog", "attributes": {}}, {"id": 109, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1308_1#1$1", "duration": 1.0}}, {"id": 110, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 111, "prop": "playsound", "attributes": {"key": "$d_gen_transmissionget"}}, {"id": 112, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 113, "prop": "name", "attributes": {"content": "炸藥已經填放好。接下來我就守在這裡……", "name": "巴別塔成員"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 114, "prop": "name", "attributes": {"content": "土方子、早霜，船上還有好幾個跟我一樣熟悉航路的人，如果發現異樣，他們會在第一時間讓羅德島轉向。", "name": "巴別塔成員"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 115, "prop": "name", "attributes": {"content": "只剩下一個小時了，我得守在這裡，保證炸藥能在羅德島經過這片區域的時候被觸發——", "name": "巴別塔成員"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 116, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 117, "prop": "name", "attributes": {"content": "你放在外圍的人都已經死了，細鹽。", "name": "？？？"}}, {"id": 118, "prop": "Dialog", "attributes": {}}, {"id": 119, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1308_1#1$1"}}, {"id": 120, "prop": "playsound", "attributes": {"key": "$transmission"}}, {"id": 121, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 122, "prop": "name", "attributes": {"content": "阿斯卡綸……", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 123, "prop": "name", "attributes": {"content": "哈，還是被你找到了。", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 124, "prop": "Dialog", "attributes": {}}, {"id": 125, "prop": "charslot", "attributes": {}}, {"id": 126, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 127, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4132_ascln_1#1$1", "duration": 1.0}}, {"id": 128, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 129, "prop": "name", "attributes": {"content": "……", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#1$1"}, {"id": 130, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1308_1#1$1"}}, {"id": 131, "prop": "name", "attributes": {"content": "也是，我的武藝和潛行的技術都是你教的，期望躲過你，不切實際。", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 132, "prop": "name", "attributes": {"content": "說起來，以前我就好奇，不管藏得多好，都能被你找到，你到底是靠什麼精準定位到每個人的？", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 133, "prop": "name", "attributes": {"content": "味道？聲音？", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 134, "prop": "name", "attributes": {"content": "……總不能是靠哈出來的氣吧，這在你看來也是某種“煙”？", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 135, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4132_ascln_1#3$1"}}, {"id": 136, "prop": "name", "attributes": {"content": "……", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#3$1"}, {"id": 137, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1308_1#1$1"}}, {"id": 138, "prop": "name", "attributes": {"content": "*薩卡茲粗口*，還真是！", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 139, "prop": "name", "attributes": {"content": "那就沒辦法了，我總不能不呼吸。", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 140, "prop": "name", "attributes": {"content": "既然都被你發現了，介意我生堆火嗎？入秋了，這荒郊野嶺的，冷得很！", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 141, "prop": "Dialog", "attributes": {}}, {"id": 142, "prop": "charslot", "attributes": {}}, {"id": 143, "prop": "playsound", "attributes": {"key": "$d_avg_woodcracle"}}, {"id": 144, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 145, "prop": "name", "attributes": {"content": "薩卡茲生起了火，風有點大，他用劍撥了撥火堆，火勢才起來，嗶剝聲變大了，聲音遠遠地傳開去。"}}, {"id": 146, "prop": "name", "attributes": {"content": "阿斯卡綸沒有動。"}}, {"id": 147, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4132_ascln_1#1$1"}}, {"id": 148, "prop": "name", "attributes": {"content": "這些烈性源石炸藥，製作得很粗糙……", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#1$1"}, {"id": 149, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1308_1#1$1"}}, {"id": 150, "prop": "name", "attributes": {"content": "情報到手得有點遲，做得太倉促了。", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 151, "prop": "name", "attributes": {"content": "當年離開卡茲戴爾的時候，我萬萬沒想到，先是需要跟你學潛行和動刀子，後來又得學做炸藥，和這些我最討厭的石頭打交道。", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 152, "prop": "name", "attributes": {"content": "說真的，這比把野生鹽泉旁邊的那些粗鹽粒提煉成可以吃的細鹽可難多了。", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 153, "prop": "name", "attributes": {"content": "說起來，當時缺帽簷“細鹽”“細鹽”地叫我的時候，就應該直接給他一拳讓他閉嘴。", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 154, "prop": "name", "attributes": {"content": "這個代號太嬌貴了，一聽就是吃不了苦的……我好心讓大傢伙在荒野上執行任務的時候能吃得好點，結果還被取笑。", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 155, "prop": "name", "attributes": {"content": "……誰知道後來你也跟著這麼叫。", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 156, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4132_ascln_1#3$1"}}, {"id": 157, "prop": "name", "attributes": {"content": "順口。", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#3$1"}, {"id": 158, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4132_ascln_1#1$1"}}, {"id": 159, "prop": "name", "attributes": {"content": "……從這些炸藥的體積來看，爆炸範圍足以覆蓋好幾公里。", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#1$1"}, {"id": 160, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4132_ascln_1#8$1"}}, {"id": 161, "prop": "name", "attributes": {"content": "為了逼停羅德島，你不惜讓這整片區域都受到不可逆的污染？", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#8$1"}, {"id": 162, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1308_1#1$1"}}, {"id": 163, "prop": "name", "attributes": {"content": "……", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 164, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4132_ascln_1#8$1"}}, {"id": 165, "prop": "name", "attributes": {"content": "你不應該做這樣的事，也不應該是你。", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#8$1"}, {"id": 166, "prop": "name", "attributes": {"content": "細鹽，你的任務是清洗那些叛徒。", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#8$1"}, {"id": 167, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1308_1#1$1"}}, {"id": 168, "prop": "name", "attributes": {"content": "殿下遇刺的時候，我們在那個小鎮上阻擊那些傭兵，我們用最快的速度趕回來……還來得及做的也只有跟你一起清洗那些叛徒。", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 169, "prop": "name", "attributes": {"content": "參與了那場刺殺的巴別塔成員，早就被你、被我們殺光了。十幾，幾十，還是上百？我忘了……", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 170, "prop": "name", "attributes": {"content": "那些不屑於你們現在所做的事的人，已經不會再願意回到羅德島……包括我，我成了他們的一分子。", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 171, "prop": "name", "attributes": {"content": "“叛徒”？", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 172, "prop": "name", "attributes": {"content": "阿斯卡綸，到底誰才是叛徒？", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 173, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4132_ascln_1#3$1"}}, {"id": 174, "prop": "name", "attributes": {"content": "……", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#3$1"}, {"id": 175, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1308_1#1$1"}}, {"id": 176, "prop": "name", "attributes": {"content": "阿斯卡綸，你應該和那個叫凱爾希的菲林保持聯繫，對吧？", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 177, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 178, "prop": "name", "attributes": {"content": "難道你沒聽說嗎，他們不會再嘗試回到卡茲戴爾，更不會去為特蕾西婭殿下復仇！", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 179, "prop": "name", "attributes": {"content": "才三個月，殿下死後才短短三個月，他們甚至已經在打算徹底丟掉“巴別塔”這個名字……", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 180, "prop": "name", "attributes": {"content": "如今那艘船還剩下多少薩卡茲？上百？幾十？還是十幾？", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 181, "prop": "name", "attributes": {"content": "我不關心那艘船和那艘船上的人是不是將來不會再和我們有聯繫，但我們必須拿回屬於薩卡茲、屬於卡茲戴爾的東西！", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 182, "prop": "name", "attributes": {"content": "那個總待在特蕾西婭殿下身邊的小卡特斯，那個新的魔——", "name": "細鹽"}, "figure_art": "avg_npc_1308_1#1$1"}, {"id": 183, "prop": "Dialog", "attributes": {}}, {"id": 184, "prop": "charslot", "attributes": {}}, {"id": 185, "prop": "PlaySound", "attributes": {"key": "$knifegore"}}, {"id": 186, "prop": "Blocker", "attributes": {"a": 0.5, "r": 1.0, "g": 0.0, "b": 0.0, "fadetime": 0.02, "block": "true"}}, {"id": 187, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 188, "prop": "Blocker", "attributes": {"a": 0.0, "r": 1.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "false"}}, {"id": 189, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 190, "prop": "name", "attributes": {"content": "薩卡茲佣兵看着阿斯卡綸消失在原地，等他反應過來的時候，對方的袖刃已經深深刺進自己的身體，鮮血沁過胸前的布甲。"}}, {"id": 191, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown1"}}, {"id": 192, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 10.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 193, "prop": "name", "attributes": {"content": "下一個瞬間，銳利的疼痛才追上他。他跪倒在地，差點將火堆撲滅。"}}, {"id": 194, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4132_ascln_1#4$1"}}, {"id": 195, "prop": "name", "attributes": {"content": "你們的目標是阿米婭。", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#4$1"}, {"id": 196, "prop": "name", "attributes": {"content": "這件事，殿下自有她的安排。", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#4$1"}, {"id": 197, "prop": "name", "attributes": {"content": "這個詞，你不該想，也不該提。", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#4$1"}, {"id": 198, "prop": "charslot", "attributes": {}}, {"id": 199, "prop": "name", "attributes": {"content": "咕——咳，咳咳……", "name": "細鹽"}, "figure_art": "avg_4132_ascln_1#4$1"}, {"id": 200, "prop": "Dialog", "attributes": {}}, {"id": 201, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 202, "prop": "name", "attributes": {"content": "當年，咳，離開卡茲戴爾，我是在你們的隊伍……快消失的時候才，決定追上你們……我連行李都沒帶……", "name": "細鹽"}}, {"id": 203, "prop": "name", "attributes": {"content": "我想要的，和殿下在做的事情差不多……讓大家的日子能，過得更好一些……", "name": "細鹽"}}, {"id": 204, "prop": "name", "attributes": {"content": "咳，我知道殿下的目標，殿下要走的路肯定比我想的要複雜很多……但她走在隊伍的前面，我們就，不用去想。", "name": "細鹽"}}, {"id": 205, "prop": "name", "attributes": {"content": "但現在……", "name": "細鹽"}}, {"id": 206, "prop": "name", "attributes": {"content": "阿斯卡綸，咳，你是離殿下最近的人……你不應該阻止我們，你是最不應該阻止我們的人，應該是你帶領我們去這麼做……", "name": "細鹽"}}, {"id": 207, "prop": "charslot", "attributes": {}}, {"id": 208, "prop": "name", "attributes": {"content": "一口氣說了太多的話，薩卡茲劇烈地咳嗽起來，血從喉嚨深處湧上來，他的身體止不住地前傾，袖刃被更深地送進胸腔。"}}, {"id": 209, "prop": "name", "attributes": {"content": "但阿斯卡綸只是俯身看著他。"}}, {"id": 210, "prop": "name", "attributes": {"content": "或許是火堆快滅了，林子裡太暗了吧，他總覺得阿斯卡綸的眼睛裡有太多陰影，什麼都看不清楚。"}}, {"id": 211, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 212, "prop": "name", "attributes": {"content": "還是說，殿下死後，你真的跟其他人說的那樣，咳咳，已經沒有方向了，已經瘋了……", "name": "細鹽"}}, {"id": 213, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4132_ascln_1#1$1"}}, {"id": 214, "prop": "name", "attributes": {"content": "……", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#1$1"}, {"id": 215, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4132_ascln_1#2$1"}}, {"id": 216, "prop": "name", "attributes": {"content": "最後的時間，告訴我，阿米婭的事情，還有多少人知情？", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#2$1"}, {"id": 217, "prop": "charslot", "attributes": {}}, {"id": 218, "prop": "name", "attributes": {"content": "咳咳，已經遲了，阿斯卡綸。", "name": "細鹽"}, "figure_art": "avg_4132_ascln_1#2$1"}, {"id": 219, "prop": "name", "attributes": {"content": "我死了，你也阻止不了這場行動……", "name": "細鹽"}, "figure_art": "avg_4132_ascln_1#2$1"}, {"id": 220, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 221, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4132_ascln_1#6$1"}}, {"id": 222, "prop": "name", "attributes": {"content": "——！", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#6$1"}, {"id": 223, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4132_ascln_1#4$1"}}, {"id": 224, "prop": "name", "attributes": {"content": "你剛剛的通訊對象，不是外圍那些被我殺死的人。", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#4$1"}, {"id": 225, "prop": "name", "attributes": {"content": "有另一隊也在進行同樣的行動……", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#4$1"}, {"id": 226, "prop": "name", "attributes": {"content": "你在這裡，就是為了吸引我的注意力？", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#4$1"}, {"id": 227, "prop": "charslot", "attributes": {}}, {"id": 228, "prop": "name", "attributes": {"content": "你只有一個人，你沒有辦法——", "name": "細鹽"}, "figure_art": "avg_4132_ascln_1#4$1"}, {"id": 229, "prop": "Dialog", "attributes": {}}, {"id": 230, "prop": "Blocker", "attributes": {"a": 0.1, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 2.0, "block": "true"}}, {"id": 231, "prop": "name", "attributes": {"content": "翻湧的血塊和最後的話都被堵在了喉頭，薩卡茲看見薄幕般的煙霧像是不受控制一般從阿斯卡綸的身體逸出。"}}, {"id": 232, "prop": "name", "attributes": {"content": "那些煙霧像是活物，撲滅了火堆，很快就融進了幽深的夜色裡。"}}, {"id": 233, "prop": "name", "attributes": {"content": "透過胸口的袖刃，他感受到了阿斯卡綸的手在顫抖，她的身體像是忽然之間發生了某種“坍塌”，止不住地顫抖……"}}, {"id": 234, "prop": "charslot", "attributes": {}}, {"id": 235, "prop": "name", "attributes": {"content": "……", "name": "細鹽"}}, {"id": 236, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4132_ascln_1#7$1"}}, {"id": 237, "prop": "name", "attributes": {"content": "……", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#7$1"}, {"id": 238, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 239, "prop": "name", "attributes": {"content": "生命的最後，薩卡茲在這個他已經熟識多年的刺客臉上，看見了他從未見過的，痛苦。"}}, {"id": 240, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 241, "prop": "Dialog", "attributes": {}}, {"id": 242, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 243, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 244, "prop": "charslot", "attributes": {}}, {"id": 245, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 246, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_003_kalts_1#1$1", "focus": "r"}}, {"id": 247, "prop": "Background", "attributes": {"image": "49_g14_rhodesdeck_d", "screenadapt": "coverall"}}, {"id": 248, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 249, "prop": "playMusic", "attributes": {"intro": "$loneliness_intro", "key": "$loneliness_loop", "volume": 0.6}}, {"id": 250, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 251, "prop": "name", "attributes": {"content": "……你終於回來了，阿斯卡綸。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 252, "prop": "Dialog", "attributes": {}}, {"id": 253, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 254, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4132_ascln_1#1$1", "duration": 1.5}}, {"id": 255, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 256, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4132_ascln_1#1$1", "focus": "l"}}, {"id": 257, "prop": "name", "attributes": {"content": "嗯。", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#1$1"}, {"id": 258, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_003_kalts_1#1$1", "focus": "r"}}, {"id": 259, "prop": "name", "attributes": {"content": "離這裡三十公里的兩片雷區，Ace他們正在帶人清除，羅德島暫時會停泊在這裡。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 260, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_003_kalts_1#5$1", "focus": "r"}}, {"id": 261, "prop": "name", "attributes": {"content": "那兩夥人……", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#5$1"}, {"id": 262, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4132_ascln_1#1$1", "focus": "l"}}, {"id": 263, "prop": "name", "attributes": {"content": "一百三十四人。", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#1$1"}, {"id": 264, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 265, "prop": "name", "attributes": {"content": "凱爾希低頭，接過阿斯卡綸遞來的東西。"}}, {"id": 266, "prop": "name", "attributes": {"content": "那是一疊布條，無一例外地別著巴別塔的袖標，它們有的已不完整，有的被血染透，黏膩得根本看不出本來的顏色。"}}, {"id": 267, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4132_ascln_1#1$1", "focus": "l"}}, {"id": 268, "prop": "name", "attributes": {"content": "參與了那場刺殺的叛徒，還有那些不該知道阿米婭身分的人，已經全部清除。", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#1$1"}, {"id": 269, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_003_kalts_1#4$1", "focus": "r"}}, {"id": 270, "prop": "name", "attributes": {"content": "你受傷得很重，晚一些需要到醫療部接受全面的檢查。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#4$1"}, {"id": 271, "prop": "name", "attributes": {"content": "……你的源石技藝幾乎是在自傷，以你目前的情緒狀態，我不建議你接下來繼續深度使用它。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#4$1"}, {"id": 272, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4132_ascln_1#1$1", "focus": "l"}}, {"id": 273, "prop": "name", "attributes": {"content": "好。", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#1$1"}, {"id": 274, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_003_kalts_1#1$1", "focus": "r"}}, {"id": 275, "prop": "name", "attributes": {"content": "接下來你打算怎麼做？", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 276, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4132_ascln_1#1$1", "focus": "l"}}, {"id": 277, "prop": "name", "attributes": {"content": "你召回了我。這些問題，應該我問。", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#1$1"}, {"id": 278, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_003_kalts_1#1$1", "focus": "r"}}, {"id": 279, "prop": "name", "attributes": {"content": "好。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 280, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4132_ascln_1#1$1", "focus": "l"}}, {"id": 281, "prop": "name", "attributes": {"content": "特蕾西婭殿下的屍體？", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#1$1"}, {"id": 282, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_003_kalts_1#5$1", "focus": "r"}}, {"id": 283, "prop": "name", "attributes": {"content": "與暗殺發生幾乎同時，羅德島附近的荒原上出現了赦罪師的身影，這兩件事情必然存在關聯。羅德島不會放棄追查。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#5$1"}, {"id": 284, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4132_ascln_1#1$1", "focus": "l"}}, {"id": 285, "prop": "name", "attributes": {"content": "特雷西斯，羅德島以後怎麼看待他？", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#1$1"}, {"id": 286, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_003_kalts_1#5$1", "focus": "r"}}, {"id": 287, "prop": "name", "attributes": {"content": "羅德島已不再是薩卡茲流亡政府，我們也不具備和軍事委員會正面對抗的能力。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#5$1"}, {"id": 288, "prop": "name", "attributes": {"content": "礦石病將是今後羅德島需要處理的主要問題。至於特雷西斯……將是我，你，我們這些少數人需要面對的問題，或心結。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#5$1"}, {"id": 289, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4132_ascln_1#8$1", "focus": "l"}}, {"id": 290, "prop": "name", "attributes": {"content": "博士？", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#8$1"}, {"id": 291, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_003_kalts_1#14$1", "focus": "r"}}, {"id": 292, "prop": "name", "attributes": {"content": "我知道你對博士仍有懷疑。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#14$1"}, {"id": 293, "prop": "name", "attributes": {"content": "僅從結果來看，特蕾西婭確實選擇在最後關頭以她的方式保護了博士。現階段，將博士送往烏薩斯，是最合適的做法。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#14$1"}, {"id": 294, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4132_ascln_1#3$1", "focus": "l"}}, {"id": 295, "prop": "name", "attributes": {"content": "……嗯。", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#3$1"}, {"id": 296, "prop": "Dialog", "attributes": {}}, {"id": 297, "prop": "charslot", "attributes": {"slot": "m", "focus": "all"}}, {"id": 298, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 299, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_003_kalts_1#1$1", "focus": "r"}}, {"id": 300, "prop": "name", "attributes": {"content": "阿斯卡綸，看來你暫時沒有問題了。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 301, "prop": "name", "attributes": {"content": "選擇在此時將你召回，是因為羅德島需要組成一個完全獨立運作的機密組織，我叫它“S.W.E.E.P.”——“特別清除協議”。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 302, "prop": "name", "attributes": {"content": "這件事應該由你來負責。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 303, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4132_ascln_1#8$1", "focus": "l"}}, {"id": 304, "prop": "name", "attributes": {"content": "“S.W.E.E.P.”？", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#8$1"}, {"id": 305, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_003_kalts_1#1$1", "focus": "r"}}, {"id": 306, "prop": "name", "attributes": {"content": "S.W.E.E.P.要做兩件事：阻止針對羅德島的滲透、暗殺和破壞；執行隱秘行動，用上述方式解決問題，和以前一樣。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 307, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4132_ascln_1#8$1", "focus": "l"}}, {"id": 308, "prop": "name", "attributes": {"content": "和以前一樣……", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#8$1"}, {"id": 309, "prop": "name", "attributes": {"content": "我並沒有守護好殿下。", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#8$1"}, {"id": 310, "prop": "name", "attributes": {"content": "你希望我留下來，做我沒有做到的事情，你希望我為殿下的死贖罪。", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#8$1"}, {"id": 311, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_003_kalts_1#1$1", "focus": "r"}}, {"id": 312, "prop": "name", "attributes": {"content": "不，阿斯卡綸，這不是贖罪。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 313, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_003_kalts_1#2$1", "focus": "r"}}, {"id": 314, "prop": "name", "attributes": {"content": "巴別塔已經不復存在，但仍有無數雙眼睛盯著我們，這艘船仍然舉步維艱。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#2$1"}, {"id": 315, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_003_kalts_1#1$1", "focus": "r"}}, {"id": 316, "prop": "name", "attributes": {"content": "剛剛過去的事情，絕不能在羅德島再發生。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 317, "prop": "name", "attributes": {"content": "你曾經是特雷西斯的學徒，巴別塔的反情報專家，沒有人比你更適合這份工作，僅此而已。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 318, "prop": "name", "attributes": {"content": "而且，你不會是一個人，你也不能是一個人。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 319, "prop": "name", "attributes": {"content": "我希望由你擔任S.W.E.E.P.的主管。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 320, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4132_ascln_1#3$1", "focus": "l"}}, {"id": 321, "prop": "name", "attributes": {"content": "……", "name": "阿斯卡綸"}, "figure_art": "avg_4132_ascln_1#3$1"}, {"id": 322, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_003_kalts_1#1$1", "focus": "r"}}, {"id": 323, "prop": "name", "attributes": {"content": "你不必馬上回答，阿斯卡綸。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 324, "prop": "name", "attributes": {"content": "在給我任何回覆之前，我有一個請求：去見阿米婭。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 325, "prop": "Dialog", "attributes": {}}, {"id": 326, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 327, "prop": "charslot", "attributes": {}}, {"id": 328, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 329, "prop": "gridbg", "attributes": {"imagegroup": "44_g13_afterglow_L1/44_g13_afterglow_R1/44_g13_afterglow_L2/44_g13_afterglow_R2", "solidwidth": "1280/1280/1280/1280", "solidheight": "720/720/720/720", "y": 500.0}}, {"id": 330, "prop": "largebgtween", "attributes": {"duration": 60.0, "yFrom": 500.0, "yTo": 700.0, "block": "false"}}, {"id": 331, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 332, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 333, "prop": "name", "attributes": {"content": "殘陽如血。"}}, {"id": 334, "prop": "name", "attributes": {"content": "她們最後的對話在肆意揚起的風沙中被掩去。"}}, {"id": 335, "prop": "name", "attributes": {"content": "“這段時間我一直待在她身邊，阿米婭已經適應了身體的變化……也不再哭了。”"}}, {"id": 336, "prop": "name", "attributes": {"content": "“阿斯卡綸，去見見她。或許你能明白，為什麼特蕾西婭最後會選擇她……特蕾西婭的道路並未終結。”"}}, {"id": 337, "prop": "name", "attributes": {"content": "“或許到時候，你會重新找到歸屬感，你的袖刃會為了一個更明確的目標而存在。”"}}, {"id": 338, "prop": "name", "attributes": {"content": "“……”"}}, {"id": 339, "prop": "name", "attributes": {"content": "“好。”"}}, {"id": 340, "prop": "Dialog", "attributes": {}}, {"id": 341, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 342, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 343, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 344, "prop": "gridbg", "attributes": {}}, {"id": 345, "prop": "Image", "attributes": {}}, {"id": 346, "prop": "charslot", "attributes": {}}, {"id": 347, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}