dic"}, {"id": 287, "prop": "name", "attributes": {"content": "這孩子去哪了？！", "name": "醫療幹員"}, "figure_art": "char_016_medic"}, {"id": 288, "prop": "name", "attributes": {"content": "完了，都怪我，兩個小時果然還是太長了......！", "name": "醫療幹員"}, "figure_art": "char_016_medic"}, {"id": 289, "prop": "dialog", "attributes": {}}, {"id": 290, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 291, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 292, "prop": "character", "attributes": {}}, {"id": 293, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 294, "prop": "Background", "attributes": {"image": "bg_coldforest", "screenadapt": "coverall", "block": "true"}}, {"id": 295, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 296, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0}}, {"id": 297, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 298, "prop": "Character", "attributes": {"name": "char_016_medic"}}, {"id": 299, "prop": "name", "attributes": {"content": "快，救回來的那個小孩不見了，你們也在周圍找找——！", "name": "醫療幹員"}, "figure_art": "char_016_medic"}, {"id": 300, "prop": "dialog", "attributes": {}}, {"id": 301, "prop": "character", "attributes": {}}, {"id": 302, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 303, "prop": "Character", "attributes": {"name": "char_empty"}}, {"id": 304, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0}}, {"id": 305, "prop": "characteraction", "attributes": {"name": "middle", "type": "move", "fadetime": 0.3, "block": "true"}}, {"id": 306, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 307, "prop": "characteraction", "attributes": {"name": "middle", "type": "move", "xpos": 200.0, "fadetime": 0.8, "block": "false"}}, {"id": 308, "prop": "Character", "attributes": {"name": "avg_npc_012", "fadetime": 0.8}}, {"id": 30