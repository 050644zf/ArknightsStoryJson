3, "prop": "character", "attributes": {}}, {"id": 334, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 335, "prop": "Background", "attributes": {"image": "bg_ri_1", "screenadapt": "coverall", "block": "true"}}, {"id": 336, "prop": "PlayMusic", "attributes": {"intro": "$warm_intro", "key": "$warm_loop", "volume": 0.4}}, {"id": 337, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 338, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 339, "prop": "name", "attributes": {"content": "第二天早晨"}}, {"id": 340, "prop": "Character", "attributes": {"name": "avg_253_greyy_1#1$1", "fadetime": 0.5, "block": "true"}}, {"id": 341, "prop": "name", "attributes": {"content": "......", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#1$1"}, {"id": 342, "prop": "name", "attributes": {"content": "......唔、天亮了？", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#1$1"}, {"id": 343, "prop": "Character", "attributes": {"name": "char_016_medic"}}, {"id": 344, "prop": "name", "attributes": {"content": "呼——你醒啦。", "name": "醫療幹員"}, "figure_art": "char_016_medic"}, {"id": 345, "prop": "name", "attributes": {"content": "來，喝點水。", "name": "醫療幹員"}, "figure_art": "char_016_medic"}, {"id": 346, "prop": "Character", "attributes": {"name": "avg_npc_089"}}, {"id": 347, "prop": "name", "attributes": {"content": "我去給你熱一點粥。昨天晚上就煮上了，你現在都不用嚼，直接咽下去也不用擔心腸胃受不了。", "name": "辦事處幹員B"}, "figure_art": "avg_npc_089"}, {"id": 348, "prop": "Character", "attributes": {"name": "avg_253_greyy_1#10$1"}}, {"id": 349, "prop": "name", "attributes": {"content": "啊、您，謝、謝謝！", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#10$1"}, {"id": 350, "prop": "Character", "attributes": {"name": "avg_253_greyy_1#9$1"}}, {"id": 351, "prop": "name", "attributes": {"content": "我、我昨天不是——？", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#9$1"}, {"id": 352, "prop": "Character", "attributes": {"name": "char_016_medic"}}, {"id": 353, "prop": "name", "attributes": {"content": "......那個，很抱歉......沒能照顧好你......", "name": "醫療幹員"}, "figure_art": "char_016_medic"}, {"id": 354, "prop": "Character", "attributes": {"name": "avg_253_greyy_1#6$1"}}, {"id": 355, "prop": "name", "attributes": {"content": "並、並沒有！是我自己想跑出去，我覺得外面太黑了才——", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#6$1"}, {"id": 356, "prop": "Character", "attributes": {"name": "avg_npc_089"}}, {"id": 357, "prop": "name", "attributes": {"content": "——粥來啦！", "name": "辦事處幹員B"}, "figure_art": "avg_npc_089"}, {"id": 358, "prop": "name", "attributes": {"content": "說什麼呢？快別光顧著說話了，你一直都沒吃東西呢，先喝點墊墊肚子，莉塔說待會兒還要再做一次檢查呢。", "name": "辦事處幹員B"}, "figure_art": "avg_npc_089"}, {"id": 359, "prop": "Character", "attributes": {"name": "avg_npc_012"}}, {"id": 360, "prop": "name", "attributes": {"content": "我來了！這孩子醒了？來，我扶你坐起來，昨天大半夜的亂跑，現在肯定沒力氣了吧？莉塔先去忙你那邊的，這裡我倆先照顧著。", "name": "辦事處幹員A"}, "figure_art": "avg_npc_012"}, {"id": 361, "prop": "Character", "attributes": {"name": "char_016_medic"}}, {"id": 362, "prop": "name", "attributes": {"content": "好，辛苦你們了。", "name": "醫療幹員"}, "figure_art": "char_016_medic"}, {"id": 363, "prop": "Dialog", "attributes": {}}, {"id": 364, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 365, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 366, "prop": "character", "attributes": {}}, {"id": 367, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 368, "prop": "Background", "attributes": {"image": "bg_ri_1", "screenadapt": "coverall", "block": "true"}}, {"id": 369, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 370, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 371, "prop": "Character", "attributes": {"name": "char_016_medic"}}, {"id": 372, "prop": "name", "attributes": {"content": "檢查結束了，沒什麼問題，只是有些營養不良。礦石病目前也處於輕症狀態，具體的要去其他地方用更專業的設備再測一次。", "name": "醫療幹員"}, "figure_art": "char_016_medic"}, {"id": 373, "prop": "Character", "attributes": {"name": "avg_npc_012", "name2": "avg_npc_089", "focus": 1.0}}, {"id": 374, "prop": "name", "attributes": {"content": "孩子，別擔心！叔叔和阿姨把你救了，就不會中途再把你扔出去，你一定要安心地在這裡把身體給養好了。", "name": "辦事處幹員A"}, "figure_art": "avg_npc_012"}, {"id": 375, "prop": "name", "attributes": {"content": "我們有些事情要給你說。", "name": "辦事處幹員A"}, "figure_art": "avg_npc_012"}, {"id": 376, "prop": "Character", "attributes": {"name": "avg_npc_012", "name2": "avg_npc_089", "focus": 2.0}}, {"id": 377, "prop": "name", "attributes": {"content": "對，我們是一個叫羅德島的醫療公司的辦事處成員，現在這裡是一個臨時搭起來的醫療帳篷。", "name": "辦事處幹員B"}, "figure_art": "avg_npc_089"}, {"id": 378, "prop": "name", "attributes": {"content": "昨天我們討論了下，我們現在的條件......有些抱歉，沒辦法長時間保證你的安全。", "name": "辦事處幹員B"}, "figure_art": "avg_npc_089"}, {"id": 379, "prop": "name", "attributes": {"content": "你......你知道你住的地方發生了什麼事嗎？", "name": "辦事處幹員B"}, "figure_art": "avg_npc_089"}, {"id": 380, "prop": "Character", "attributes": {"name": "avg_253_greyy_1#7$1"}}, {"id": 381, "prop": "name", "attributes": {"content": "我、我不知道......", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#7$1"}, {"id": 382, "prop": "name", "attributes": {"content": "媽媽把我送了出來，讓我一定往遠處跑，然後她、她就又回去了......", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#7$1"}, {"id": 383, "prop": "name", "attributes": {"content": "爸爸前幾天說要去工廠找新的工作，然後，就沒回來......", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#7$1"}, {"id": 384, "prop": "Character", "attributes": {"name": "avg_253_greyy_1#6$1"}}, {"id": 385, "prop": "name", "attributes": {"content": "......剩下的，我就不太清楚了......", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#6$1"}, {"id": 386, "prop": "Character", "attributes": {"name": "avg_npc_012", "name2": "avg_npc_089", "focus": 2.0}}, {"id": 387, "prop": "name", "attributes": {"content": "那，你知道自己生病的事嗎？", "name": "辦事處幹員B"}, "figure_art": "avg_npc_089"}, {"id": 388, "prop": "Character", "attributes": {"name": "avg_253_greyy_1#7$1"}}, {"id": 389, "prop": "name", "attributes": {"content": "知道的......他們都說這種病得了身上就會長石頭，我們那裡很多人都得了這個病......", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#7$1"}, {"id": 390, "prop": "Character", "attributes": {"name": "avg_npc_012", "name2": "avg_npc_089", "focus": 2.0}}, {"id": 391, "prop": "name", "attributes": {"content": "那......你的父母，都是感染者嗎？", "name": "辦事處幹員B"}, "figure_art": "avg_npc_089"}, {"id": 392, "prop": "Character", "attributes": {"name": "avg_253_greyy_1#7$1"}}, {"id": 393, "prop": "name", "attributes": {"content": "嗯......工廠發生了事故......", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#7$1"}, {"id": 394, "prop": "Character", "attributes": {"name": "avg_npc_012", "name2": "avg_npc_089", "focus": 1.0}}, {"id": 395, "prop": "name", "attributes": {"content": "......", "name": "辦事處幹員A"}, "figure_art": "avg_npc_012"}, {"id": 396, "prop": "name", "attributes": {"content": "把人逼成感染者，再把感染者逼到絕路，這群*玻利瓦爾俚語*！", "name": "辦事處幹員A"}, "figure_art": "avg_npc_012"}, {"id": 397, "prop": "Character", "attributes": {"name": "char_016_medic"}}, {"id": 398, "prop": "name", "attributes": {"content": "哎，小孩子面前！", "name": "醫療幹員"}, "figure_art": "char_016_medic"}, {"id": 399, "prop": "Character", "attributes": {"name": "avg_npc_012", "name2": "avg_npc_089", "focus": 1.0}}, {"id": 400, "prop": "name", "attributes": {"content": "......是我激動了，但這事也太......", "name": "辦事處幹員A"}, "figure_art": "avg_npc_012"}, {"id": 401, "prop": "name", "attributes": {"content": "你你你快和他說，再聽下去真的要氣死了。", "name": "辦事處幹員A"}, "figure_art": "avg_npc_012"}, {"id": 402, "prop": "Character", "attributes": {"name": "avg_npc_012", "name2": "avg_npc_089", "focus": 2.0}}, {"id": 403, "prop": "name", "attributes": {"content": "我們昨天討論的東西就是，想給你講一下我們公司，看看你喜不喜歡那裡，或者，願不願意去？", "name": "辦事處幹員B"}, "figure_art": "avg_npc_089"}, {"id": 404, "prop": "name", "attributes": {"content": "我們這裡有器械，但羅德島的會比我們這裡的更好，而且，你不是會一些電能的法術嗎？", "name": "辦事處幹員B"}, "figure_art": "avg_npc_089"}, {"id": 405, "prop": "name", "attributes": {"content": "那裡有很多很厲害的哥哥姐姐、叔叔阿姨，他們會很多很厲害的法術，你能在那裡學到更多。", "name": "辦事處幹員B"}, "figure_art": "avg_npc_089"}, {"id": 406, "prop": "Character", "attributes": {"name": "avg_253_greyy_1#5$1"}}, {"id": 407, "prop": "name", "attributes": {"content": "會更厲害的法術嗎？", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#5$1"}, {"id": 408, "prop": "Character", "attributes": {"name": "avg_npc_012", "name2": "avg_npc_089", "focus": 2.0}}, {"id": 409, "prop": "name", "attributes": {"content": "嗯，對。你現在的法術是誰教你的？", "name": "辦事處幹員B"}, "figure_art": "avg_npc_089"}, {"id": 410, "prop": "Character", "attributes": {"name": "avg_253_greyy_1#10$1"}}, {"id": 411, "prop": "name", "attributes": {"content": "是我的媽媽......", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#10$1"}, {"id": 412, "prop": "Character", "attributes": {"name": "avg_npc_012", "name2": "avg_npc_089", "focus": 1.0}}, {"id": 413, "prop": "name", "attributes": {"content": "唉......", "name": "辦事處幹員A"}, "figure_art": "avg_npc_012"}, {"id": 414, "prop": "name", "attributes": {"content": "孩子，叔叔不是故意說髒話的，你、你父母的事情......我們很抱歉，但是我們會在這裡繼續幫你找他們的下落的。", "name": "辦事處幹員A"}, "figure_art": "avg_npc_012"}, {"id": 415, "prop": "Character", "attributes": {"name": "avg_253_greyy_1#10$1"}}, {"id": 416, "prop": "name", "attributes": {"content": "您、您不用和我道歉！", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#10$1"}, {"id": 417, "prop": "name", "attributes": {"content": "我......", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#10$1"}, {"id": 418, "prop": "Character", "attributes": {"name": "avg_253_greyy_1#12$1"}}, {"id": 419, "prop": "name", "attributes": {"content": "你們救了我，我很感謝......我也很想、很想在這裡做點什麼報答你們......", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#12$1"}, {"id": 420, "prop": "name", "attributes": {"content": "我、我會一點電能法術的，昨天我半夜醒來過一次，這裡很黑，一個燈都沒有......", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#12$1"}, {"id": 421, "prop": "name", "attributes": {"content": "你們這裡，也和我家那裡一樣，是沒有電的吧？我、我想給你們這裡發一些電......作為我現在、我的報答......", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#12$1"}, {"id": 422, "prop": "name", "attributes": {"content": "我昨天看到這裡這麼黑，你們是不是遇到事情了？可是，我、我走到一半就昏過去了，醒來又回到了床上......", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#12$1"}, {"id": 423, "prop": "Character", "attributes": {"name": "avg_253_greyy_1#6$1"}}, {"id": 424, "prop": "name", "attributes": {"content": "這是我的法杖，但是昨天我太累了，它沒有那麼亮......我平時能讓它照亮整個屋子的！", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#6$1"}, {"id": 425, "prop": "Character", "attributes": {"name": "char_016_medic"}}, {"id": 426, "prop": "name", "attributes": {"content": "你昨天是為了讓這裡亮起來才......？", "name": "醫療幹員"}, "figure_art": "char_016_medic"}, {"id": 427, "prop": "Character", "attributes": {"name": "avg_253_greyy_1#10$1"}}, {"id": 428, "prop": "name", "attributes": {"content": "嗯、嗯！", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#10$1"}, {"id": 429, "prop": "name", "attributes": {"content": "用了媽媽教我的那些法術後，我的法杖能亮很久！", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#10$1"}, {"id": 430, "prop": "name", "attributes": {"content": "我有幫到你們嗎......？", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#10$1"}, {"id": 431, "prop": "Character", "attributes": {"name": "char_016_medic"}}, {"id": 432, "prop": "name", "attributes": {"content": "......！", "name": "醫療幹員"}, "figure_art": "char_016_medic"}, {"id": 433, "prop": "name", "attributes": {"content": "（他原來......是為了這個才......！）", "name": "醫療幹員"}, "figure_art": "char_016_medic"}, {"id": 434, "prop": "name", "attributes": {"content": "對！你有幫到我們。", "name": "醫療幹員"}, "figure_art": "char_016_medic"}, {"id": 435, "prop": "name", "attributes": {"content": "昨天這兩個叔叔晚上迷路了，外面那麼黑，他們就是看到了你的法杖發出的光，才找到了回這裡的路。", "name": "醫療幹員"}, "figure_art": "char_016_medic"}, {"id": 436, "prop": "name", "attributes": {"content": "他們一直想和你說謝謝來著，早上一忙就給忘了，對吧？", "name": "醫療幹員"}, "figure_art": "char_016_medic"}, {"id": 437, "prop": "Character", "attributes": {"name": "avg_npc_012", "name2": "avg_npc_089", "focus": 2.0}}, {"id": 438, "prop": "name", "attributes": {"content": "......嗯！對！", "name": "辦事處幹員B"}, "figure_art": "avg_npc_089"}, {"id": 439, "prop": "name", "attributes": {"content": "我們都打算在外面過夜了，結果模模糊糊地看到一團光，一路走過來就看到你了。要是沒有你，我們都看不見路！", "name": "辦事處幹員B"}, "figure_art": "avg_npc_089"}, {"id": 440, "prop": "name", "attributes": {"content": "（使眼色）", "name": "辦事處幹員B"}, "figure_art": "avg_npc_089"}, {"id": 441, "prop": "Character", "attributes": {"name": "avg_npc_012", "name2": "avg_npc_089", "focus": 1.0}}, {"id": 442, "prop": "name", "attributes": {"content": "（恍然大悟）", "name": "辦事處幹員A"}, "figure_art": "avg_npc_012"}, {"id": 443, "prop": "name", "attributes": {"content": "對的！你的光在晚上真的很亮，真的很謝謝你！", "name": "辦事處幹員A"}, "figure_art": "avg_npc_012"}, {"id": 444, "prop": "Character", "attributes": {"name": "avg_253_greyy_1#3$1"}}, {"id": 445, "prop": "name", "attributes": {"content": "真、真的嗎！", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#3$1"}, {"id": 446, "prop": "name", "attributes": {"content": "嗚！那我......那我願意去！我一定會好好養好身體，再學更多更好的法術，回來再幫你們！", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#3$1"}, {"id": 447, "prop": "Character", "attributes": {"name": "char_016_medic"}}, {"id": 448, "prop": "name", "attributes": {"content": "嗯！", "name": "醫療幹員"}, "figure_art": "char_016_medic"}, {"id": 449, "prop": "Character", "attributes": {"name": "avg_253_greyy_1#1$1"}}, {"id": 450, "prop": "name", "attributes": {"content": "我知道我在這裡現在也幫不上你們的忙，我的爸爸媽媽......我也不知道他們在哪裡，還需要你們幫我找他們......", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#1$1"}, {"id": 451, "prop": "name", "attributes": {"content": "等我把病治好了！我一定會回來，回來讓這裡的晚上，亮起來......！", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#1$1"}, {"id": 452, "prop": "Character", "attributes": {"name": "char_016_medic"}}, {"id": 453, "prop": "name", "attributes": {"content": "那，我們會在這裡好好地等你回來的，說好了哦？一定要學很多很多法術，我們這裡很需要你的幫助哦。", "name": "醫療幹員"}, "figure_art": "char_016_medic"}, {"id": 454, "prop": "Character", "attributes": {"name": "avg_253_greyy_1#10$1"}}, {"id": 455, "prop": "name", "attributes": {"content": "好！", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#10$1"}, {"id": 456, "prop": "Character", "attributes": {"name": "char_016_medic"}}, {"id": 457, "prop": "name", "attributes": {"content": "對了，你叫什麼名字？我們到現在還不知道你叫什麼呢。", "name": "醫療幹員"}, "figure_art": "char_016_medic"}, {"id": 458, "prop": "Character", "attributes": {"name": "avg_npc_012", "name2": "avg_npc_089", "focus": 1.0}}, {"id": 459, "prop": "name", "attributes": {"content": "對呀，我們這裡每個人都有代號，但是我們幾個認識得早，所以互相叫的是本名。", "name": "辦事處幹員A"}, "figure_art": "avg_npc_012"}, {"id": 460, "prop": "name", "attributes": {"content": "我叫費托，他叫佩德羅，這個阿姨叫莉塔。", "name": "辦事處幹員A"}, "figure_art": "avg_npc_012"}, {"id": 461, "prop": "Character", "attributes": {"name": "avg_npc_012", "name2": "avg_npc_089", "focus": 2.0}}, {"id": 462, "prop": "name", "attributes": {"content": "你現在決定要去本艦了，給自己也取個代號吧，取個自己喜歡的。", "name": "辦事處幹員B"}, "figure_art": "avg_npc_089"}, {"id": 463, "prop": "Character", "attributes": {"name": "avg_253_greyy_1#9$1"}}, {"id": 464, "prop": "name", "attributes": {"content": "嗯......", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#9$1"}, {"id": 465, "prop": "dialog", "attributes": {}}, {"id": 466, "prop": "Character", "attributes": {"name": "avg_253_greyy_1#10$1", "fadetime": 0.6, "block": "true"}}, {"id": 467, "prop": "Delay", "attributes": {"time": 0.61}}, {"id": 468, "prop": "name", "attributes": {"content": "我、我叫，格雷伊！", "name": "虛弱的佩洛男孩"}, "figure_art": "avg_253_greyy_1#10$1"}, {"id": 469, "prop": "Dialog", "attributes": {}}, {"id": 470, "prop": "stopmusic", "attributes": {"fadetime": 3.0}}, {"id": 471, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 472, "prop": "Character", "attributes": {}}, {"id": 473, "prop": "Image", "attributes": {}}, {"id": 474, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}