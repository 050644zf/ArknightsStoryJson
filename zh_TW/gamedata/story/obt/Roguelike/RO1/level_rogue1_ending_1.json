{"lang": "zh_TW", "eventid": "", "eventName": "", "entryType": "EXTRA", "storyCode": "", "avgTag": "", "storyName": "落幕", "storyInfo": "歡慶吧，諸位，歡慶吧！\n這便是眾人企盼的美好結局！", "storyList": [{"id": 0, "prop": "HEADER", "attributes": {"key": "title_test", "is_skippable": "true", "fit_mode": "BLACK_MASK"}}, {"id": 1, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 2, "prop": "stopmusic", "attributes": {}}, {"id": 3, "prop": "Dialog", "attributes": {}}, {"id": 4, "prop": "name", "attributes": {"content": "由此，故事迎來終結。"}}, {"id": 5, "prop": "name", "attributes": {"content": "燈光關閉，演員離場，紅幕布緩緩拉上。"}}, {"id": 6, "prop": "name", "attributes": {"content": "曲終人散，一切又重歸寂靜。"}}, {"id": 7, "prop": "dialog", "attributes": {}}, {"id": 8, "prop": "Background", "attributes": {"image": "24_RL_castlehall", "screenadapt": "coverall"}}, {"id": 9, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 10, "prop": "PlayMusic", "attributes": {"intro": "$loneliness_intro", "key": "$loneliness_loop", "volume": 0.4}}, {"id": 11, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 12, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 13, "prop": "name", "attributes": {"content": "傀影恢復了自我。"}}, {"id": 14, "prop": "name", "attributes": {"content": "他仍記得自己的所作所為。"}}, {"id": 15, "prop": "name", "attributes": {"content": "他明白，身為主演的他僅是劇團準備的誘餌。"}}, {"id": 16, "prop": "name", "attributes": {"content": "引誘著這些熱誠而高尚的凡人一次次躍入這有來無回的陷坑。"}}, {"id": 17, "prop": "name", "attributes": {"content": "一路艱險，無需言語。"}}, {"id": 18, "prop": "name", "attributes": {"content": "如今他幸而獲救，可在這之前呢？"}}, {"id": 19, "prop": "name", "attributes": {"content": "可曾有人迷失在這高聳迷宮中？"}}, {"id": 20, "prop": "name", "attributes": {"content": "自己又可曾將施以援手的同伴推下舞台？"}}, {"id": 21, "prop": "name", "attributes": {"content": "他不敢想像。"}}, {"id": 22, "prop": "name", "attributes": {"content": "他感到羞愧。"}}, {"id": 23, "prop": "dialog", "attribut