 "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 96, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 97, "prop": "character", "attributes": {}}, {"id": 98, "prop": "character", "attributes": {"name": "avg_NPC_017_3"}}, {"id": 99, "prop": "largebg", "attributes": {"imagegroup": "bg_20_G04_1/bg_20_G04_2", "solidwidth": "920/920", "solidheight": 720.0}}, {"id": 100, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 101, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 102, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 103, "prop": "name", "attributes": {"content": "這、這是......", "name": "D.D.D."}, "figure_art": "avg_NPC_017_3"}, {"id": 104, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 105, "prop": "name", "attributes": {"content": "林女俠居然真的在海面上“走”了起來！", "name": "D.D.D."}, "figure_art": "avg_NPC_017_3"}, {"id": 106, "prop": "Character", "attributes": {"name": "avg_npc_198_1#5"}}, {"id": 107, "prop": "name", "attributes": {"content": "不，她並不是走，而是在跳躍。", "name": "坎黛拉"}, "figure_art": "avg_npc_198_1#5"}, {"id": 108, "prop": "name", "attributes": {"content": "在她的每一個落腳點，都有她用沙子生成的玻璃作為支撐，供她進行下一次的跳躍。", "name": "坎黛拉"}, "figure_art": "avg_npc_198_1#5"}, {"id": 109, "prop": "name", "attributes": {"content": "而且，她為了省沙子，如果就近有其他人，她就直接踩在那個人身上，用那個人的身體作為跳板。", "name": "坎黛拉"}, "figure_art": "avg_npc_198_1#5"}, {"id": 110, "prop": "character", "attributes": {"name": "avg_npc_198_1#3"}}, {"id": 111, "prop": "name", "attributes": {"content": "哈哈哈，有意思，太有意思了！", "name": "坎黛拉"}, "figure_art": "avg_npc_198_1#3"}, {"id": 112, "prop": "character", "attributes": {"name": "avg_NPC_017_3"}}, {"id": 113, "prop": "name", "attributes": {"content": "原來如此。這真是前所未有的渡海方式！", "name": "D.D.D."}, "figure_art": "avg_NPC_017_3"}, {"id": 114, "prop": "name", "attributes": {"content": "也就是說，兩人是商量好，因為近海缺少跳板，所以由陳女俠來充當她的第一塊跳板，為林女俠的前進鋪平道路。", "name": "D.D.D."}, "figure_art": "avg_NPC_017_3"}, {"id": 115, "prop": "name", "attributes": {"content": "兩人再一次向我們展現了她們令人感動的隊友情誼！", "name": "D.D.D."}, "figure_art": "avg_NPC_017_3"}, {"id": 116, "prop": "dialog", "attributes": {}}, {"id": 117, "prop": "character", "attributes": {}}, {"id": 118, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 119, "prop": "character", "attributes": {"name": "avg_npc_203_1#1", "name2": "avg_npc_197_1#1", "focus": 1.0}}, {"id": 120, "prop": "name", "attributes": {"content": "哈哈哈，林小姐這方法確實出乎意料，但我覺得吧，她們一定沒有商量好。", "name": "星熊"}, "figure_art": "avg_npc_203_1#1"}, {"id": 121, "prop": "character", "attributes": {"name": "avg_npc_203_1#1", "name2": "avg_npc_197_1#1", "focus": 2.0}}, {"id": 122, "prop": "name", "attributes": {"content": "確實，鏡頭裡一閃而過的老陳那張臭臉太有趣了。", "name": "詩懷雅"}, "figure_art": "avg_npc_197_1#1"}, {"id": 123, "prop": "character", "attributes": {"name": "avg_npc_203_1#1", "name2": "avg_npc_197_1#1", "focus": 1.0}}, {"id": 124, "prop": "name", "attributes": {"content": "嘖嘖，沒想到這兩個人合作起來這麼好玩。", "name": "星熊"}, "figure_art": "avg_npc_203_1#1"}, {"id": 125, "prop": "dialog", "attributes": {}}, {"id": 126, "prop": "character", "attributes": {}}, {"id": 127, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 128, "prop": "character", "attributes": {"name": "avg_NPC_017_3"}}, {"id": 129, "prop": "name", "attributes": {"content": "保持第一的依然是甜蜜夏日隊，嘉文選手以勢不可擋的勁頭向著終點進發。", "name": "D.D.D."}, "figure_art": "avg_NPC_017_3"}, {"id": 130, "prop": "name", "attributes": {"content": "其他隊伍也緊跟其後。", "name": "D.D.D."}, "figure_art": "avg_NPC_017_3"}, {"id": 131, "prop": "name", "attributes": {"content": "但是，他們都沒有想到，在他們的身後，還有一個林女俠！", "name": "D.D.D."}, "figure_art": "avg_NPC_017_3"}, {"id": 132, "prop": "name", "attributes": {"content": "她直接越過了第三名！", "name": "D.D.D."}, "figure_art": "avg_NPC_017_3"}, {"id": 133, "prop": "name", "attributes": {"content": "第二名的頭也只能成為她的跳板！", "name": "D.D.D."}, "figure_art": "avg_NPC_017_3"}, {"id": 134, "prop": "name", "attributes": {"content": "嘉文注意到她了，但是那又能怎麼樣呢！", "name": "D.D.D."}, "figure_art": "avg_NPC_017_3"}, {"id": 135, "prop": "name", "attributes": {"content": "嘉文，嘉文也被林女俠無情地越過頭頂！", "name": "D.D.D."}, "figure_art": "avg_NPC_017_3"}, {"id": 136, "prop": "name", "attributes": {"content": "第一，第一名是林小姐，第一名，依然是鼠膽龍威隊！！！！！", "name": "D.D.D."}, "figure_art": "avg_NPC_017_3"}, {"id": 137, "prop": "name", "attributes": {"content": "這真是一場讓人熱血沸騰的逆轉！", "name": "D.D.D."}, "figure_art": "avg_NPC_017_3"}, {"id": 138, "prop": "dialog", "attributes": {}}, {"id": 139, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 140, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 141, "prop": "Character", "attributes": {}}, {"id": 142, "prop": "largebg", "attributes": {}}, {"id": 143, "prop": "character", "attributes": {"name": "avg_486_espumo_1#3"}}, {"id": 144, "prop": "Background", "attributes": {"image": "bg_20_G02"}}, {"id": 145, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 146, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 147, "prop": "name", "attributes": {"content": "喂，不是吧，這都能贏，真的假的，這未免也太犯規了吧。", "name": "埃內斯托"}, "figure_art": "avg_486_espumo_1#3"}, {"id": 148, "prop": "character", "attributes": {"name": "avg_486_espumo_1#5"}}, {"id": 149, "prop": "name", "attributes": {"content": "哈哈，哈哈哈哈......", "name": "埃內斯托"}, "figure_art": "avg_486_espumo_1#5"}, {"id": 150, "prop": "character", "attributes": {"name": "avg_486_espumo_1#2"}}, {"id": 151, "prop": "name", "attributes": {"content": "這下，該怎麼辦好呢。", "name": "埃內斯托"}, "figure_art": "avg_486_espumo_1#2"}, {"id": 152, "prop": "Dialog", "attributes": {}}, {"id": 153, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 154, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 155, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 156, "prop": "Character", "attributes": {}}, {"id": 157, "prop": "Image", "attributes": {}}, {"id": 158, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}