0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 80, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#1", "focus": 1.0}}, {"id": 81, "prop": "name", "attributes": {"content": "你先走，我用跑的。", "name": "陳"}, "figure_art": "avg_1013_spchen_1#1"}, {"id": 82, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#1", "focus": 2.0}}, {"id": 83, "prop": "name", "attributes": {"content": "上車。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#1"}, {"id": 84, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#4", "name2": "avg_npc_196_1#1", "focus": 1.0}}, {"id": 85, "prop": "name", "attributes": {"content": "？", "name": "陳"}, "figure_art": "avg_1013_spchen_1#4"}, {"id": 86, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#4", "name2": "avg_npc_196_1#5", "focus": 2.0}}, {"id": 87, "prop": "name", "attributes": {"content": "別讓我再說一次，上車。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#5"}, {"id": 88, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#7", "name2": "avg_npc_196_1#5", "focus": 1.0}}, {"id": 89, "prop": "name", "attributes": {"content": "你確定？", "name": "陳"}, "figure_art": "avg_1013_spchen_1#7"}, {"id": 90, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#7", "name2": "avg_npc_196_1#5", "focus": 2.0}}, {"id": 91, "prop": "name", "attributes": {"content": "我來騎，你來解決礙事的傢伙。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#5"}, {"id": 92, "prop": "dialog", "attributes": {}}, {"id": 93, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 94, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 95, "prop": "Character", "attributes": {}}, {"id": 96, "prop": "character", "attributes": {"name": "avg_NPC_017_3"}}, {"id": 97, "prop": "largebg", "attributes": {"imagegroup": "bg_20_G04_1/bg_20_G04_2", "solidwidth": "920/920", "solidheight": 720.0}}, {"id": 98, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 99, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 100, "prop": "name", "attributes": {"content": "太令人感動了，雖然只剩下一輛車，但是林女俠並沒有拋棄陳女俠。", "name": "D.D.D."}, "figure_art": "avg_NPC_017_3"}, {"id": 101, "prop": "name", "attributes": {"content": "她讓陳女俠站上自己的車後座，由她來騎車，而陳女俠負責對付那些想要妨礙她們的人。", "name": "D.D.D."}, "figure_art": "avg_NPC_017_3"}, {"id": 102, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 103, "prop": "name", "attributes": {"content": "兩個人，一輛自行車，一次讓所有人都目瞪口呆的完美配合！", "name": "D.D.D."}, "figure_art": "avg_NPC_017_3"}, {"id": 104, "prop": "name", "attributes": {"content": "現在我敢說，她們兩個的組合，是這場大獎賽中最強大的！", "name": "D.D.D."}, "figure_art": "avg_NPC_017_3"}, {"id": 105, "prop": "dialog", "attributes": {}}, {"id": 106, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 107, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 108, "prop": "Character", "attributes": {}}, {"id": 109, "prop": "largebg", "attributes": {}}, {"id": 110, "prop": "Background", "attributes": {"image": "bg_20_G03"}}, {"id": 111, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 112, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 113, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#7", "name2": "avg_npc_196_1#1", "fadetime": 0.5, "block": "true"}}, {"id": 114, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 115, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#7", "name2": "avg_npc_196_1#5", "focus": 2.0}}, {"id": 116, "prop": "name", "attributes": {"content": "你壓到我頭髮了。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#5"}, {"id": 117, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#2", "name2": "avg_npc_196_1#5", "focus": 1.0}}, {"id": 118, "prop": "name", "attributes": {"content": "敵人在前面，我也沒辦法。", "name": "陳"}, "figure_art": "avg_1013_spchen_1#2"}, {"id": 119, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#5", "focus": 1.0}}, {"id": 120, "prop": "name", "attributes": {"content": "你能不能不要亂扭？", "name": "陳"}, "figure_art": "avg_1013_spchen_1#1"}, {"id": 121, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#6", "focus": 2.0}}, {"id": 122, "prop": "name", "attributes": {"content": "要不然你來騎？", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#6"}, {"id": 123, "prop": "dialog", "attributes": {}}, {"id": 124, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#7", "name2": "avg_npc_196_1#4"}}, {"id": 125, "prop": "characteraction", "attributes": {"name": "left", "type": "jump", "xpos": 100.0, "power": 10.0, "times": 1.0, "fadetime": 0.2, "block": "true"}}, {"id": 126, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "fadetime": 0.3, "block": "true"}}, {"id": 127, "prop": "name", "attributes": {"content": "陳忽地壓下林雨霞的頭，躲開了迎面而來的一個輪胎。"}}, {"id": 128, "prop": "delay", "attributes": {"time": 0.6}}, {"id": 129, "prop": "dialog", "attributes": {}}, {"id": 130, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#4", "name2": "avg_npc_196_1#5"}}, {"id": 131, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "ypos": 50.0, "fadetime": 0.2, "block": "true"}}, {"id": 132, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 133, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.03, "block": "true"}}, {"id": 134, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 40.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 135, "prop": "PlaySound", "attributes": {"key": "$fightgeneral", "volume": 1.0}}, {"id": 136, "prop": "characteraction", "attributes": {"name": "left", "type": "move", "ypos": 10.0, "fadetime": 1.0, "block": "true"}}, {"id": 137, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 138, "prop": "Dialog", "attributes": {}}, {"id": 139, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 140, "prop": "name", "attributes": {"content": "林雨霞卻猛地抬頭，狠狠撞在陳的臉上。"}}, {"id": 141, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#6", "name2": "avg_npc_196_1#5", "focus": 1.0}}, {"id": 142, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 143, "prop": "name", "attributes": {"content": "林雨霞，你！", "name": "陳"}, "figure_art": "avg_1013_spchen_1#6"}, {"id": 144, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#6", "name2": "avg_npc_196_1#7", "focus": 2.0}}, {"id": 145, "prop": "name", "attributes": {"content": "意外。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#7"}, {"id": 146, "prop": "dialog", "attributes": {}}, {"id": 147, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 148, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 149, "prop": "Character", "attributes": {}}, {"id": 150, "prop": "largebg", "attributes": {"imagegroup": "bg_20_G04_1/bg_20_G04_2", "solidwidth": "920/920", "solidheight": 720.0}}, {"id": 151, "prop": "character", "attributes": {"name": "avg_NPC_017_3"}}, {"id": 152, "prop": "delay", "attributes": {"time": 0.6}}, {"id": 153, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadet