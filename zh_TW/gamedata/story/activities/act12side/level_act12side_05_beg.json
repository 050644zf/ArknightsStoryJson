vg_1013_spchen_1#1"}}, {"id": 100, "prop": "name", "attributes": {"content": "埃內斯托說著將一把鑰匙丟給陳。"}}, {"id": 101, "prop": "character", "attributes": {"name": "avg_486_espumo_1#1", "name2": "avg_1013_spchen_1#1", "focus": 1.0}}, {"id": 102, "prop": "name", "attributes": {"content": "（小聲）這把鑰匙你們拿著。", "name": "埃內斯托"}, "figure_art": "avg_486_espumo_1#1"}, {"id": 103, "prop": "name", "attributes": {"content": "（小聲）那邊有一家我開的武器店，你們過去應該就能看到。", "name": "埃內斯托"}, "figure_art": "avg_486_espumo_1#1"}, {"id": 104, "prop": "name", "attributes": {"content": "（小聲）武器店的地下室有一扇後門，從後門出去有一個地下行道，走那邊會快很多。", "name": "埃內斯托"}, "figure_art": "avg_486_espumo_1#1"}, {"id": 105, "prop": "name", "attributes": {"content": "（小聲）我在這裡拖住他們，你們先走。", "name": "埃內斯托"}, "figure_art": "avg_486_espumo_1#1"}, {"id": 106, "prop": "character", "attributes": {"name": "avg_486_espumo_1#1", "name2": "avg_1013_spchen_1#1", "focus": 2.0}}, {"id": 107, "prop": "name", "attributes": {"content": "......你一個人沒問題？", "name": "陳"}, "figure_art": "avg_1013_spchen_1#1"}, {"id": 108, "prop": "character", "attributes": {"name": "avg_486_espumo_1#1", "name2": "avg_1013_spchen_1#1", "focus": 1.0}}, {"id": 109, "prop": "name", "attributes": {"content": "只要有一個人到達終點就算勝利，兩位，你們先走！", "name": "埃內斯托"}, "figure_art": "avg_486_espumo_1#1"}, {"id": 110, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#1", "focus": 2.0}}, {"id": 111, "prop": "name", "attributes": {"content": "好。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#1"}, {"id": 112, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#1", "focus": 1.0}}, {"id": 113, "prop": "name", "attributes": {"content": "先突破這裡。", "name": "陳"}, "figure_art": "avg_1013_spchen_1#1"}, {"id": 114, "prop": "Dialog", "attributes": {}}, {"id": 115, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 116, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 117, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 118, "prop": "Character", "attributes": {}}, {"id": 119, "prop": "Image", "attributes": {}}, {"id": 120, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}