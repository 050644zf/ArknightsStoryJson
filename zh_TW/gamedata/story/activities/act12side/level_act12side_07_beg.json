gure_art": "avg_npc_206_1#7"}, {"id": 234, "prop": "Character", "attributes": {"name": "avg_npc_203_1", "name2": "avg_npc_206_1#7", "focus": 1.0}}, {"id": 235, "prop": "name", "attributes": {"content": "哈，我就猜到你會這麼說，那就一起吧。", "name": "星熊"}, "figure_art": "avg_npc_203_1"}, {"id": 236, "prop": "Character", "attributes": {"name": "avg_npc_203_1", "name2": "avg_npc_206_1#1", "focus": 2.0}}, {"id": 237, "prop": "name", "attributes": {"content": "對了。", "name": "鑄鐵"}, "figure_art": "avg_npc_206_1#1"}, {"id": 238, "prop": "dialog", "attributes": {}}, {"id": 239, "prop": "character", "attributes": {}}, {"id": 240, "prop": "PlaySound", "attributes": {"key": "$d_gen_transmissionget", "volume": 0.6}}, {"id": 241, "prop": "CharacterCutin", "attributes": {"widgetID": "1", "name": "char_144_red_7", "style": "cutin", "fadestyle": "horiz_expand_center", "fadetime": 0.5, "width": 200.0, "block": "true"}}, {"id": 242, "prop": "Character", "attributes": {"name": "char_empty", "name2": "avg_npc_206_1#7", "focus": 2.0}}, {"id": 243, "prop": "name", "attributes": {"content": "紅，你在哪？", "name": "鑄鐵"}, "figure_art": "avg_npc_206_1#7"}, {"id": 244, "prop": "Character", "attributes": {"name": "char_empty", "name2": "avg_npc_206_1#7", "focus": 1.0}}, {"id": 245, "prop": "name", "attributes": {"content": "我不知道。鑄鐵，人很多，有血的味道。", "name": "紅"}, "figure_art": "char_empty"}, {"id": 246, "prop": "Character", "attributes": {"name": "char_empty", "name2": "avg_npc_206_1#7", "focus": 2.0}}, {"id": 247, "prop": "name", "attributes": {"content": "我知道。你現在來沙灘。", "name": "鑄鐵"}, "figure_art": "avg_npc_206_1#7"}, {"id": 248, "prop": "name", "attributes": {"content": "艾雅法拉和蘇蘇洛需要你來保護。", "name": "鑄鐵"}, "figure_art": "avg_npc_206_1#7"}, {"id": 249, "prop": "Character", "attributes": {"name": "char_empty", "name2": "avg_npc_206_1#7", "focus": 1.0}}, {"id": 250, "prop": "name", "attributes": {"content": "好。", "name": "紅"}, "figure_art": "char_empty"}, {"id": 251, "prop": "CharacterCutin", "attributes": {"widgetID": "1", 