rop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#1", "focus": 2.0}}, {"id": 97, "prop": "name", "attributes": {"content": "好好的。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#1"}, {"id": 98, "prop": "name", "attributes": {"content": "看來，對方也沒想要置我們於死地。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#1"}, {"id": 99, "prop": "name", "attributes": {"content": "只不過......", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#1"}, {"id": 100, "prop": "name", "attributes": {"content": "湊巧，出口被堵住了。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#1"}, {"id": 101, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#2", "name2": "avg_npc_196_1#1", "focus": 1.0}}, {"id": 102, "prop": "name", "attributes": {"content": "好一個湊巧。", "name": "陳"}, "figure_art": "avg_1013_spchen_1#2"}, {"id": 103, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#2", "name2": "avg_npc_196_1#1", "focus": 2.0}}, {"id": 104, "prop": "name", "attributes": {"content": "你怎麼看？", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#1"}, {"id": 105, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#1", "focus": 1.0}}, {"id": 106, "prop": "name", "attributes": {"content": "想辦法出去，還能怎麼看。", "name": "陳"}, "figure_art": "avg_1013_spchen_1#1"}, {"id": 107, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#5", "focus": 2.0}}, {"id": 108, "prop": "name", "attributes": {"content": "我是問，誰幹的。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#5"}, {"id": 109, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#2", "name2": "avg_npc_196_1#5", "focus": 1.0}}, {"id": 110, "prop": "name", "attributes": {"content": "......我們的直覺看來沒錯。", "name": "陳"}, "figure_art": "avg_1013_spchen_1#2"}, {"id": 111, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#2", "name2": "avg_npc_196_1#5", "focus": 2.0}}, {"id": 112, "prop": "name", "attributes": {"content": "嗯。埃內斯托看起來忍不住了。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#5"}, {"id": 113, "prop": "name", "attributes": {"content": "但是你不覺得有些奇怪嗎？如果我是他，我不會這麼做。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#5"}, {"id": 114, "prop": "name", "attributes": {"content": "只有走投無路的人會用這種自爆式的方法。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#5"}, {"id": 115, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#5", "focus": 1.0}}, {"id": 116, "prop": "name", "attributes": {"content": "要嘛，確實不是他。", "name": "陳"}, "figure_art": "avg_1013_spchen_1#1"}, {"id": 117, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#1", "focus": 2.0}}, {"id": 118, "prop": "name", "attributes": {"content": "不可能。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#1"}, {"id": 119, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#1", "focus": 1.0}}, {"id": 120, "prop": "name", "attributes": {"content": "要嘛，他想讓我們以為他走投無路。", "name": "陳"}, "figure_art": "avg_1013_spchen_1#1"}, {"id": 121, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#5", "focus": 2.0}}, {"id": 122, "prop": "name", "attributes": {"content": "......", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#5"}, {"id": 123, "prop": "name", "attributes": {"content": "林雨霞挑了挑眉毛，沒有接話。"}}, {"id": 124, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#1", "focus": 2.0}}, {"id": 125, "prop": "name", "attributes": {"content": "對了，你把這件事告訴坎黛拉女士了嗎？", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#1"}, {"id": 126, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#1", "focus": 1.0}}, {"id": 127, "prop": "name", "attributes": {"content": "當然。", "name": "陳"}, "figure_art": "avg_1013_spchen_1#1"}, {"id": 128, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#1", "focus": 2.0}}, {"id": 129, "prop": "name", "attributes": {"content": "她怎麼說？", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#1"}, {"id": 130, "prop": "Dialog", "attributes": {}}, {"id": 131, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 132, "prop": "Character", "attributes": {}}, {"id": 133, "prop": "musicvolume", "attributes": {"volume": 0.0, "fadetime": 1.0}}, {"id": 134, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 135, "prop": "largebg", "attributes": {"imagegroup": "bg_20_G04_1/bg_20_G04_2", "solidwidth": "920/920", "solidheight": 720.0}}, {"id": 136, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "amount": 0.8, "keep": "true"}}, {"id": 137, "prop": "character", "attributes": {}}, {"id": 138, "prop": "character", "attributes": {"name": "avg_npc_198_1#1", "name2": "avg_1013_spchen_1#1"}}, {"id": 139, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 140, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 141, "prop": "character", "attributes": {"name": "avg_npc_198_1#1", "name2": "avg_1013_spchen_1#4", "focus": 2.0}}, {"id": 142, "prop": "name", "attributes": {"content": "您不會做任何事......嗎。", "name": "陳"}, "figure_art": "avg_1013_spchen_1#4"}, {"id": 143, "prop": "character", "attributes": {"name": "avg_npc_198_1#2", "name2": "avg_1013_spchen_1#4", "focus": 1.0}}, {"id": 144, "prop": "name", "attributes": {"content": "沒錯，陳世侄，你是個聰明人，你應該想得到。", "name": "坎黛拉"}, "figure_art": "avg_npc_198_1#2"}, {"id": 145, "prop": "name", "attributes": {"content": "現在我派人去排查炸彈的話，不是等於在告訴幕後黑手我發現了他的陰謀嗎？", "name": "坎黛拉"}, "figure_art": "avg_npc_198_1#2"}, {"id": 146, "prop": "character", "attributes": {"name": "avg_npc_198_1#2", "name2": "avg_1013_spchen_1#2", "focus": 2.0}}, {"id": 147, "prop": "name", "attributes": {"content": "我明白。", "name": "陳"}, "figure_art": "avg_1013_spchen_1#2"}, {"id": 148, "prop": "character", "attributes": {"name": "avg_npc_198_1#1", "name2": "avg_1013_spchen_1#2", "focus": 1.0}}, {"id": 149, "prop": "name", "attributes": {"content": "沒關係，陳世侄，你和林世侄已經做得很好了。", "name": "坎黛拉"}, "figure_art": "avg_npc_198_1#1"}, {"id": 150, "prop": "character", "attributes": {"name": "avg_npc_198_1#3", "name2": "avg_1013_spchen_1#2", "focus": 1.0}}, {"id": 151, "prop": "name", "attributes": {"content": "老實說，我一開始根本沒有期待你們真的能查出什麼，哈哈哈。", "name": "坎黛拉"}, "figure_art": "avg_npc_198_1#3"}, {"id": 152, "prop": "character", "attributes": {"name": "avg_npc_198_1#1", "name2": "avg_1013_spchen_1#1", "focus": 2.0}}, {"id": 153, "prop": "name", "attributes": {"content": "您好像一點都不擔心？", "name": "陳"}, "figure_art": "avg_1013_spchen_1#1"}, {"id": 154, "prop": "character", "attributes": {"name": "avg_npc_198_1#4", "name2": "avg_1013_spchen_1#1", "focus": 1.0}}, {"id": 155, "prop": "name", "attributes": {"content": "當然，陳世侄。", "name": "坎黛拉"}, "figure_art": "avg_npc_198_1#4"}, {"id": 156, "prop": "name", "attributes": {"content": "你也不用太關心這件事。", "name": "坎黛拉"}, "figure_art": "avg_npc_198_1#4"}, {"id": 157, "prop": "name", "attributes": {"content": "我看你和林世侄在大獎賽裡也表現得很好，與其去想這些，不如努努力把第一拿下來，這樣魏彥吾臉上也有光嘛，哈哈哈。", "name": "坎黛拉"}, "figure_art": "avg_npc_198_1#4"}, {"id": 158, "prop": "character", "attributes": {"name": "avg_npc_198_1#4", "name2": "avg_1013_spchen_1#2", "focus": 2.0}}, {"id": 159, "prop": "name", "attributes": {"content": "我們會考慮的。", "name": "陳"}, "figure_art": "avg_1013_spchen_1#2"}, {"id": 160, "prop": "Dialog", "attributes": {}}, {"id": 161, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 162, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 163, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 0.0, "amount": 0.0, "block": "true"}}, {"id": 164, "prop": "Background", "attributes": {"image": "bg_20_G08", "screenadapt": "coverall"}}, {"id": 165, "prop": "largebg", "attributes": {}}, {"id": 166, "prop": "character", "attributes": {}}, {"id": 167, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#2", "name2": "avg_npc_196_1#1"}}, {"id": 168, "prop": "Blocker", "attributes": {"a": 0.3, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 169, "prop": "musicvolume", "attributes": {"volume": 0.4, "fadetime": 1.0}}, {"id": 170, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 171, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#2", "name2": "avg_npc_196_1#1", "focus": 1.0}}, {"id": 172, "prop": "name", "attributes": {"content": "你應該想像得到。", "name": "陳"}, "figure_art": "avg_1013_spchen_1#2"}, {"id": 173, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#2", "name2": "avg_npc_196_1#1", "focus": 2.0}}, {"id": 174, "prop": "name", "attributes": {"content": "確實。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#1"}, {"id": 175, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#5", "focus": 1.0}}, {"id": 176, "prop": "name", "attributes": {"content": "比起這個，怎麼出去？", "name": "陳"}, "figure_art": "avg_1013_spchen_1#1"}, {"id": 177, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#5", "focus": 2.0}}, {"id": 178, "prop": "name", "attributes": {"content": "聽說特別督察組組長在出任務的時候，一怒之下能把房子切成塊，讓我見識一下？", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#5"}, {"id": 179, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#1", "focus": 1.0}}, {"id": 180, "prop": "name", "attributes": {"content": "......不是所有的房子都能那麼切。這座房子明顯用了非常堅硬的材質。", "name": "陳"}, "figure_art": "avg_1013_spchen_1#1"}, {"id": 181, "prop": "name", "attributes": {"content": "你使沙子的能力能不能搬運一下？", "name": "陳"}, "figure_art": "avg_1013_spchen_1#1"}, {"id": 182, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#1", "focus": 2.0}}, {"id": 183, "prop": "name", "attributes": {"content": "我又不是我爸，這個堵塞程度，用我的能力也要花一些時間。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#1"}, {"id": 184, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#2", "name2": "avg_npc_196_1#1", "focus": 1.0}}, {"id": 185, "prop": "name", "attributes": {"content": "那還是我來試試。", "name": "陳"}, "figure_art": "avg_1013_spchen_1#2"}, {"id": 186, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#2", "name2": "avg_npc_196_1#1", "focus": 2.0}}, {"id": 187, "prop": "name", "attributes": {"content": "不用。我有別的方法。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#1"}, {"id": 188, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#4", "name2": "avg_npc_196_1#1", "focus": 1.0}}, {"id": 189, "prop": "name", "attributes": {"content": "什麼方法？", "name": "陳"}, "figure_art": "avg_1013_spchen_1#4"}, {"id": 190, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#4", "name2": "avg_npc_196_1#7", "focus": 2.0}}, {"id": 191, "prop": "name", "attributes": {"content": "你猜這是什麼？", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#7"}, {"id": 192, "prop": "dialog", "attributes": {}}, {"id": 193, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 194, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#4", "name2": "avg_npc_196_1#7", "focus": 1.0}}, {"id": 195, "prop": "name", "attributes": {"content": "......炸彈？", "name": "陳"}, "figure_art": "avg_1013_spchen_1#4"}, {"id": 196, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#4", "name2": "avg_npc_196_1#7", "focus": 2.0}}, {"id": 197, "prop": "name", "attributes": {"content": "還記得我在第一輪找到的炸彈嗎？", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#7"}, {"id": 198, "prop": "name", "attributes": {"content": "雖然沒有辦法讓坎黛拉女士大規模地去搜查，但是我讓我在這邊收下的小弟裝成小偷去居民區盡可能地偷了一些出來。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#7"}, {"id": 199, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#4", "name2": "avg_npc_196_1#7", "focus": 1.0}}, {"id": 200, "prop": "name", "attributes": {"content": "小偷？", "name": "陳"}, "figure_art": "avg_1013_spchen_1#4"}, {"id": 201, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#1", "name2": "avg_npc_196_1#7", "focus": 2.0}}, {"id": 202, "prop": "name", "attributes": {"content": "小偷。只要稍微賄賂一下守衛，進去不鬧太大動靜，沒人會管你。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#7"}, {"id": 203, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#7", "name2": "avg_npc_196_1#7", "focus": 1.0}}, {"id": 204, "prop": "name", "attributes": {"content": "......", "name": "陳"}, "figure_art": "avg_1013_spchen_1#7"}, {"id": 205, "prop": "name", "attributes": {"content": "林雨霞。", "name": "陳"}, "figure_art": "avg_1013_spchen_1#7"}, {"id": 206, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#7", "name2": "avg_npc_196_1#1", "focus": 2.0}}, {"id": 207, "prop": "name", "attributes": {"content": "幹什麼。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#1"}, {"id": 208, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#7", "name2": "avg_npc_196_1#1", "focus": 1.0}}, {"id": 209, "prop": "name", "attributes": {"content": "雖然道不同，但我過去一向敬重你與林先生。", "name": "陳"}, "figure_art": "avg_1013_spchen_1#7"}, {"id": 210, "prop": "name", "attributes": {"content": "貧民窟沒有你們撐不下去，這我還是知道的。", "name": "陳"}, "figure_art": "avg_1013_spchen_1#7"}, {"id": 211, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#7", "name2": "avg_npc_196_1#5", "focus": 2.0}}, {"id": 212, "prop": "name", "attributes": {"content": "所以呢？", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#5"}, {"id": 213, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#7", "name2": "avg_npc_196_1#5", "focus": 1.0}}, {"id": 214, "prop": "name", "attributes": {"content": "不要讓我看到你樂在其中。", "name": "陳"}, "figure_art": "avg_1013_spchen_1#7"}, {"id": 215, "prop": "character", "attributes": {"name": "avg_1013_spchen_1#7", "name2": "avg_npc_196_1#5", "focus": 2.0}}, {"id": 216, "prop": "name", "attributes": {"content": "......陳暉潔，沒有人會主動給自己找罪受。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#5"}, {"id": 217, "prop": "name", "attributes": {"content": "閃開，我要安裝炸彈了。", "name": "林雨霞"}, "figure_art": "avg_npc_196_1#5"}, {"id": 2