"}, {"id": 16, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#3$1", "name2": "avg_npc_352_1#9$1", "focus": 1.0}}, {"id": 17, "prop": "name", "attributes": {"content": "哎？", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#3$1"}, {"id": 18, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#3$1", "name2": "avg_npc_352_1#9$1", "focus": 2.0}}, {"id": 19, "prop": "name", "attributes": {"content": "對不起，艾澤爾哥哥，媽媽帶我出門都是晚上，街上不太一樣......", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#9$1"}, {"id": 20, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#3$1", "name2": "avg_npc_352_1#10$1", "focus": 2.0}}, {"id": 21, "prop": "name", "attributes": {"content": "不過平時，我會偷偷從窗戶看家外面的樣子......我能認出來的！我會努力的......", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#10$1"}, {"id": 22, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#10$1", "focus": 1.0}}, {"id": 23, "prop": "name", "attributes": {"content": "......", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 24, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#8$1", "name2": "avg_npc_352_1#10$1", "focus": 1.0}}, {"id": 25, "prop": "name", "attributes": {"content": "沒關係，塞茜莉亞，會找到的，還沒到遇見你的地方呢。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#8$1"}, {"id": 26, "prop": "dialog", "attributes": {}}, {"id": 27, "prop": "Character", "attributes": {"name": "avg_npc_352_1#10$1", "name2": "avg_npc_367_1#1$1"}}, {"id": 28, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 29, "prop": "characteraction", "attributes": {"name": "left", "type": "move", "xpos": 100.0, "fadetime": 0.3, "block": "false"}}, {"id": 30, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown1", "volume": 0.4}}, {"id": 31, "prop": "characteraction", "attributes": {"name": "left", "type": "move", "fadetime": 0.5, "block": "false"}}, {"id": 32, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "xpos": 50.0, "fadetime": 0.5, "block": "false"}}, {"id": 33, "prop": "CameraShake", "attributes": {"duration": 0.9, "ystrength": 20.0, "vibrato": 30.0, "randomness": 50.0, "fadeout": "true", "block": "false"}}, {"id": 34, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 35, "prop": "Character", "attributes": {"name": "avg_npc_352_1#5$1"}}, {"id": 36, "prop": "name", "attributes": {"content": "呀！", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#5$1"}, {"id": 37, "prop": "Character", "attributes": {"name": "avg_npc_352_1#1$1"}}, {"id": 38, "prop": "name", "attributes": {"content": "對不起......我在看兩邊的房子，沒有看到您。", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#1$1"}, {"id": 39, "prop": "Character", "attributes": {"name": "avg_npc_367_1#1$1"}}, {"id": 40, "prop": "name", "attributes": {"content": "嗯？你不是早上昏倒被送醫院的小姑娘嗎？沒事了嗎？", "name": "熱心的拉特蘭市民"}, "figure_art": "avg_npc_367_1#1$1"}, {"id": 41, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#3$1", "name2": "avg_npc_367_1#1$1", "focus": 1.0}}, {"id": 42, "prop": "name", "attributes": {"content": "是您啊！嗯，她......她沒事。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#3$1"}, {"id": 43, "prop": "name", "attributes": {"content": "對了，之後有大人來找她嗎？", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#3$1"}, {"id": 44, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#3$1", "name2": "avg_npc_367_1#1$1", "focus": 2.0}}, {"id": 45, "prop": "name", "attributes": {"content": "我一直盯到中午呢！就是沒人出現，真奇怪，父母在幹什麼呢......", "name": "熱心的拉特蘭市民"}, "figure_art": "avg_npc_367_1#1$1"}, {"id": 46, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#1$1", "name2": "avg_npc_367_1#1$1", "focus": 1.0}}, {"id": 47, "prop": "name", "attributes": {"content": "塞茜莉亞說，她就住在這附近，您真的沒見過她嗎？", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#1$1"}, {"id": 48, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#1$1", "name2": "avg_npc_367_1#1$1", "focus": 2.0}}, {"id": 49, "prop": "name", "attributes": {"content": "這麼可愛的小姑娘，要是見過，肯定會有印象啦！我也不用在旁邊乾著急了不是。", "name": "熱心的拉特蘭市民"}, "figure_art": "avg_npc_367_1#1$1"}, {"id": 50, "prop": "name", "attributes": {"content": "這樣吧，之前那個人說得有道理，我帶你們去找社區辦事處的人吧。如果是剛搬來的住戶，在辦事處肯定有登記的。", "name": "熱心的拉特蘭市民"}, "figure_art": "avg_npc_367_1#1$1"}, {"id": 51, "prop": "dialog", "attributes": {}}, {"id": 52, "prop": "character", "attributes": {}}, {"id": 53, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 54, "prop": "Character", "attributes": {"name": "avg_npc_367_1#1$1"}}, {"id": 55, "prop": "name", "attributes": {"content": "嚯，巧了，那不是葆菈姐嗎！", "name": "熱心的拉特蘭市民"}, "figure_art": "avg_npc_367_1#1$1"}, {"id": 56, "prop": "name", "attributes": {"content": "葆菈姐！這邊這邊！", "name": "熱心的拉特蘭市民"}, "figure_art": "avg_npc_367_1#1$1"}, {"id": 57, "prop": "Character", "attributes": {"name": "avg_npc_368_1#1$1"}}, {"id": 58, "prop": "name", "attributes": {"content": "嗯，怎麼了？我趕著回辦公室呢，邊走邊說吧。", "name": "知性的拉特蘭市民"}, "figure_art": "avg_npc_368_1#1$1"}, {"id": 59, "prop": "Character", "attributes": {"name": "avg_npc_367_1#1$1"}}, {"id": 60, "prop": "name", "attributes": {"content": "咱們這片最近有新搬來的住戶嗎？", "name": "熱心的拉特蘭市民"}, "figure_art": "avg_npc_367_1#1$1"}, {"id": 61, "prop": "Character", "attributes": {"name": "avg_npc_368_1#1$1"}}, {"id": 62, "prop": "name", "attributes": {"content": "有當然是有......不過你說的最近是多近啊？", "name": "知性的拉特蘭市民"}, "figure_art": "avg_npc_368_1#1$1"}, {"id": 63, "prop": "Character", "attributes": {"name": "avg_npc_367_1#1$1"}}, {"id": 64, "prop": "name", "attributes": {"content": "小姑娘，你大概什麼時候搬過來的？", "name": "熱心的拉特蘭市民"}, "figure_art": "avg_npc_367_1#1$1"}, {"id": 65, "prop": "Character", "attributes": {"name": "avg_npc_352_1#9$1"}}, {"id": 66, "prop": "name", "attributes": {"content": "......不是剛搬過來的......住在這裡很久了......", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#9$1"}, {"id": 67, "prop": "Character", "attributes": {"name": "avg_npc_368_1#1$1"}}, {"id": 68, "prop": "name", "attributes": {"content": "哎？小姑娘，你叫什麼名字？", "name": "知性的拉特蘭市民"}, "figure_art": "avg_npc_368_1#1$1"}, {"id": 69, "prop": "Character", "attributes": {"name": "avg_npc_352_1#1$1"}}, {"id": 70, "prop": "name", "attributes": {"content": "我是塞茜莉亞......", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#1$1"}, {"id": 71, "prop": "Character", "attributes": {"name": "avg_npc_368_1#1$1"}}, {"id": 72, "prop": "name", "attributes": {"content": "嗯......沒道理呀，我在這裡工作十多年了，你要是住了很久......", "name": "知性的拉特蘭市民"}, "figure_art": "avg_npc_368_1#1$1"}, {"id": 73, "prop": "name", "attributes": {"content": "塞茜莉亞，你知道你的爸爸媽媽叫什麼名字嗎？", "name": "知性的拉特蘭市民"}, "figure_art": "avg_npc_368_1#1$1"}, {"id": 74, "prop": "Character", "attributes": {"name": "avg_npc_352_1#1$1"}}, {"id": 75, "prop": "name", "attributes": {"content": "媽媽的名字是......費莉亞。", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#1$1"}, {"id": 76, "prop": "stopmusic", "attributes": {"fadetime": 3.0}}, {"id": 77, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#2$1"}}, {"id": 78, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 79, "prop": "name", "attributes": {"content": "！！！！！", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#2$1"}, {"id": 80, "prop": "Character", "attributes": {"name": "avg_npc_368_1#1$1"}}, {"id": 81, "prop": "name", "attributes": {"content": "什麼什麼什麼？！費莉亞，是瑟法斯街的費莉亞嗎？費莉亞不是單身嗎？怎麼突然冒出個這麼大的孩子？", "name": "知性的拉特蘭市民"}, "figure_art": "avg_npc_368_1#1$1"}, {"id": 82, "prop": "name", "attributes": {"content": "不過仔細看看......你確實和費莉亞長得很像呢。", "name": "知性的拉特蘭市民"}, "figure_art": "avg_npc_368_1#1$1"}, {"id": 83, "prop": "name", "attributes": {"content": "太奇怪了......難道是私生子？塞茜莉亞，你剛才說住了很久，是說你媽媽住在這裡很久的意思嗎？", "name": "知性的拉特蘭市民"}, "figure_art": "avg_npc_368_1#1$1"}, {"id": 84, "prop": "Character", "attributes": {"name": "avg_npc_352_1#9$1"}}, {"id": 85, "prop": "name", "attributes": {"content": "對......", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#9$1"}, {"id": 86, "prop": "Character", "attributes": {"name": "avg_npc_368_1#1$1"}}, {"id": 87, "prop": "name", "attributes": {"content": "你是來找媽媽的嗎？", "name": "知性的拉特蘭市民"}, "figure_art": "avg_npc_368_1#1$1"}, {"id": 88, "prop": "Character", "attributes": {"name": "avg_npc_352_1#4$1"}}, {"id": 89, "prop": "name", "attributes": {"content": "......是的，我想找媽媽......", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#4$1"}, {"id": 90, "prop": "Character", "attributes": {"name": "avg_npc_368_1#1$1"}}, {"id": 91, "prop": "name", "attributes": {"content": "哎呀，這位小哥，那你是，費莉亞的親戚之類的？這個孩子是寄養在鄉下嗎？你帶她來看媽媽？", "name": "知性的拉特蘭市民"}, "figure_art": "avg_npc_368_1#1$1"}, {"id": 92, "prop": "name", "attributes": {"content": "真沒想到，難怪之前我給費莉亞介紹對象她都推辭了......原來孩子都這麼大了。", "name": "知性的拉特蘭市民"}, "figure_art": "avg_npc_368_1#1$1"}, {"id": 93, "prop": "name", "attributes": {"content": "小哥，你怎麼不說話了？嗯？你還好嗎？", "name": "知性的拉特蘭市民"}, "figure_art": "avg_npc_368_1#1$1"}, {"id": 94, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1"}}, {"id": 95, "prop": "name", "attributes": {"content": "......", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 96, "prop": "Character", "attributes": {"name": "avg_npc_368_1#1$1"}}, {"id": 97, "prop": "name", "attributes": {"content": "說著說著快走到了，那邊就是費莉亞家了，我幫你們去敲個門？", "name": "知性的拉特蘭市民"}, "figure_art": "avg_npc_368_1#1$1"}, {"id": 98, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1"}}, {"id": 99, "prop": "name", "attributes": {"content": "......瑟法斯街7-265號。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 100, "prop": "Character", "attributes": {"name": "avg_npc_368_1#1$1"}}, {"id": 101, "prop": "name", "attributes": {"content": "哎？原來你知道地址啊。", "name": "知性的拉特蘭市民"}, "figure_art": "avg_npc_368_1#1$1"}, {"id": 102, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1"}}, {"id": 103, "prop": "name", "attributes": {"content": "......嗯，我知道。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 104, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#5$1", "focus": 2.0}