, {"id": 225, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "false"}}, {"id": 226, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 227, "prop": "character", "attributes": {"name": "avg_npc_357_1#4$1"}}, {"id": 228, "prop": "name", "attributes": {"content": "......你......", "name": "帕蒂亞"}, "figure_art": "avg_npc_357_1#4$1"}, {"id": 229, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#7$1"}}, {"id": 230, "prop": "name", "attributes": {"content": "......讓開。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#7$1"}, {"id": 231, "prop": "Character", "attributes": {"name": "avg_npc_357_1#5$1"}}, {"id": 232, "prop": "name", "attributes": {"content": "我說什麼都沒用，是嗎？", "name": "帕蒂亞"}, "figure_art": "avg_npc_357_1#5$1"}, {"id": 233, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#7$1"}}, {"id": 234, "prop": "name", "attributes": {"content": "......你有你的想法，帕蒂亞。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#7$1"}, {"id": 235, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#8$1"}}, {"id": 236, "prop": "name", "attributes": {"content": "我也有我的想法。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#8$1"}, {"id": 237, "prop": "Character", "attributes": {"name": "avg_npc_357_1#3$1"}}, {"id": 238, "prop": "name", "attributes": {"content": "那就告訴我啊......！", "name": "帕蒂亞"}, "figure_art": "avg_npc_357_1#3$1"}, {"id": 239, "prop": "Character", "attributes": {"name": "avg_npc_357_1#5$1"}}, {"id": 240, "prop": "name", "attributes": {"content": "為什麼什麼都不說？為什麼......寧願追著明明無法企及的背影，也不願意回頭......看一眼？", "name": "帕蒂亞"}, "figure_art": "avg_npc_357_1#5$1"}, {"id": 241, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#8$1"}}, {"id": 242, "prop": "name", "attributes": {"content": "不明白你在說什麼，帕蒂亞。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#8$1"}, {"id": 243, "prop": "name", "attributes": {"content": "何況，我和你說上三言兩語，就能改變你的想法嗎？", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#8$1"}, {"id": 244, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#3$1"}}, {"id": 245, "prop": "name", "attributes": {"content": "如果一個人的想法是這麼隨便就能改變的東西，那我看也不值什麼錢。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#3$1"}, {"id": 246, "prop": "Character", "attributes": {"name": "avg_npc_357_1#4$1"}}, {"id": 247, "prop": "name", "attributes": {"content": "......", "name": "帕蒂亞"}, "figure_art": "avg_npc_357_1#4$1"}, {"id": 248, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#7$1"}}, {"id": 249, "prop": "name", "attributes": {"content": "讓開。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#7$1"}, {"id": 250, "prop": "name", "attributes": {"content": "我知道你只是來拖延我的腳步。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#7$1"}, {"id": 251, "prop": "name", "attributes": {"content": "但你該知道你攔不住我。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#7$1"}, {"id": 252, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#8$1"}}, {"id": 253, "prop": "name", "attributes": {"content": "我們都有自己的工作要做。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#8$1"}, {"id": 254, "prop": "name", "attributes": {"content": "你想讓你身邊那些......和平民差不了多少的同伴，替你付代價嗎？", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#8$1"}, {"id": 255, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#7$1"}}, {"id": 256, "prop": "name", "attributes": {"content": "你不會的，帕蒂亞。所以讓開吧，給我們都省點事。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#7$1"}, {"id": 257, "prop": "Dialog", "attributes": {}}, {"id": 258, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 259, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 260, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 261, "prop": "Character", "attributes": {}}, {"id": 262, "prop": "Background", "attributes": {"image": "26_g11_laterano_alley", "screenadapt": "showall"}}, {"id": 263, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 264, "prop": "playMusic", "attributes": {"intro": "$distressed_intro", "key": "$distressed_loop", "volume": 0.4}}, {"id": 265, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 266, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 267, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#1$1", "focus": 1.0}}, {"id": 268, "prop": "name", "attributes": {"content": "......到家了，塞茜莉亞。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 269, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#1$1", "focus": 2.0}}, {"id": 270, "prop": "name", "attributes": {"content": "嗯......我沒有鑰匙，開不了門......艾澤爾哥哥，你能......", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#1$1"}, {"id": 271, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#9$1", "focus": 2.0}}, {"id": 272, "prop": "name", "attributes": {"content": "艾澤爾哥哥，你真的沒事嗎？是不是不舒服呀......從剛才開始，你的臉色就很差。", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#9$1"}, {"id": 273, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#7$1", "name2": "avg_npc_352_1#9$1", "focus": 1.0}}, {"id": 274, "prop": "name", "attributes": {"content": "我沒事，塞茜莉亞，我來開門......", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#7$1"}, {"id": 275, "prop": "Dialog", "attributes": {}}, {"id": 276, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 277, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 278, "prop": "playsound", "attributes": {"key": "$dooropenquite"}}, {"id": 279, "prop": "Character", "attributes": {}}, {"id": 280, "prop": "Background", "attributes": {"image": "26_g8_laterano_dwelling", "screenadapt": "showall"}}, {"id": 281, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 282, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 283, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 284, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#7$1", "name2": "avg_npc_352_1#5$1", "focus": 2.0}}, {"id": 285, "prop": "name", "attributes": {"content": "艾澤爾哥哥，為什麼剛才那個姐姐說，你其實知道我家的地址......", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#5$1"}, {"id": 286, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#5$1", "focus": 1.0}}, {"id": 287, "prop": "name", "attributes": {"content": "......", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 288, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#1$1", "focus": 1.0}}, {"id": 289, "prop": "name", "attributes": {"content": "塞茜莉亞，你認識這把銃嗎？", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 290, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#5$1", "focus": 2.0}}, {"id": 291, "prop": "name", "attributes": {"content": "......這是，媽媽的守護銃？", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#5$1"}, {"id": 292, "prop": "name", "attributes": {"content": "艾澤爾哥哥......媽媽的守護銃，為什麼會在你那裡......？", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#5$1"}, {"id": 293, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#5$1", "focus": 1.0}}, {"id": 294, "prop": "name", "attributes": {"content": "......對不起，塞茜莉亞......", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 295, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#5$1", "focus": 2.0}}, {"id": 296, "prop": "name", "attributes": {"content": "為什麼要道歉......", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#5$1"}, {"id": 297, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#9$1", "focus": 2.0}}, {"id": 298, "prop": "name", "attributes": {"content": "我有點不明白了......", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#9$1"}, {"id": 299, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#8$1", "focus": 2.0}}, {"id": 300, "prop": "name", "attributes": {"content": "你......是不是知道媽媽在哪裡？", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#8$1"}, {"id": 301, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#12$1", "focus": 1.0}}, {"id": 302, "prop": "name", "attributes": {"content": "......是的，我知道......對不起，塞茜莉亞......", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 303, "prop": "name", "attributes": {"content": "對不起......我也不知道我為什麼要道歉......對不起......", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 304, "prop": "name", "attributes": {"content": "塞茜莉亞，你的媽媽，已經去世了。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 305, "prop": "name", "attributes": {"content": "她不在這裡了。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 306, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#12$1", "focus": 2.0}}, {"id": 307, "prop": "name", "attributes": {"content": "不在這裡，那在哪裡？“去世了”......是什麼意思......？", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#12$1"}, {"id": 308, "prop": "name", "attributes": {"content": "......我想起來了，早上，媽媽說她要去一個地方，不能帶我一起去......是你陪她去的嗎，艾澤爾哥哥？", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#12$1"}, {"id": 309, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#9$1", "focus": 2.0}}, {"id": 310, "prop": "name", "attributes": {"content": "艾澤爾哥哥，你能不能......也帶我去？就去一下，就待一會......", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#9$1"}, {"id": 311, "prop": "name", "attributes": {"content": "我，我不會任性的，我會聽媽媽的話，不會賴著不走......但是......但是......", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#9$1"}, {"id": 312, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#7$1", "focus": 2.0}}, {"id": 313, "prop": "name", "attributes": {"content": "能不能讓我再見一見媽媽......", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#7$1"}, {"id": 314, "prop": "name", "attributes": {"content": "我還沒有和她說再見呀......", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#7$1"}, {"id": 315, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#7$1", "focus": 1.0}}, {"id": 316, "prop": "name", "attributes": {"content": "......", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 317, "prop": "dialog", "attributes": {}}, {"id": 318, "prop": "character", "attributes": {}}, {"id": 319, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 320, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 321, "prop": "character", "attributes": {"name": "avg_npc_355_1#1$1", "fadetime": 1.5}}, {"id": 322, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 323, "prop": "name", "attributes": {"content": "嗯，怎麼回事？她怎麼快哭了，艾澤爾，你在欺負小姑娘嗎？", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 324, "prop": "dialog", "attributes": {}}, {"id": 325, "prop": "playMusic", "attributes": {"intro": "$mist_intro", "key": "$mist_loop", "volume": 0.4}}, {"id": 326, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#6$1", "name2": "avg_npc_352_1#5$1", "focus": 1.0}}, {"id": 327, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 328, "prop": "characteraction", "attributes": {"name": "left", "type": "move", "xpos": 200.0, "power": 5.0, "times": 1.0, "fadetime": 1.0, "block": "false"}}, {"id": 329, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "power": 0.0, "times": 1.0, "fadetime": 1.5, "block": "true"}}, {"id": 330, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 331, "prop": "name", "attributes": {"content": "你是什麼人？等等，這個制服......你是萬國信使？", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#6$1"}, {"id": 332, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 333, "prop": "name", "attributes": {"content": "很有眼力嘛，艾澤爾小哥。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 334, "prop": "name", "attributes": {"content": "奉教宗閣下的諭令，我來接塞茜莉亞前往大教堂。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 335, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#2$1"}}, {"id": 336, "prop": "name", "attributes": {"content": "..................", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#2$1"}, {"id": 337, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 338, "prop": "name", "attributes": {"content": "不好意思，忘了自我介紹，我的名字是奧倫·亞吉奧拉斯。如果想確認我的身份，艾澤爾小哥不妨使用一下你的公證所標準終端。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 339, "prop": "Character", "attributes": {"name": "avg_npc_355_1#4$1"}}, {"id": 340, "prop": "name", "attributes": {"content": "噢，我忘了，你關機了對吧？", "name": "奧倫"}, "figure_art": "avg_npc_355_1#4$1"}, {"id": 341, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#9$1"}}, {"id": 342, "prop": "name", "attributes": {"content": "......所以，你是怎麼找到這裡的？", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#9$1"}, {"id": 343, "prop": "Character", "attributes": {"name": "avg_npc_355_1#4$1"}}, {"id": 344, "prop": "name", "attributes": {"content": "......艾澤爾小哥，你是不是太小看萬國信使了，你以為你的動向很難掌握嗎？或者你覺得你做事足夠周全，一路上沒有留下任何痕跡？", "name": "奧倫"}, "figure_art": "avg_npc_355_1#4$1"}, {"id": 345, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#9$1"}}, {"id": 346, "prop": "name", "attributes": {"content": "萬國信使閣下......如果你要帶走塞茜莉亞，在那之前，我能不能問你幾個問題？", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#9$1"}, {"id": 347, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 348, "prop": "name", "attributes": {"content": "哈哈，挺有意思的，艾澤爾小哥。你覺得我需要回答你的問題嗎？", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 349, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 350, "prop": "name", "attributes": {"content": "不過我也不是什麼壞人嘛......你問吧。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 351, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#9$1"}}, {"id": 352, "prop": "name", "attributes": {"content": "塞茜莉亞到底是什麼人......", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#9$1"}, {"id": 353, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#6$1"}}, {"id": 354, "prop": "name", "attributes": {"content": "她是什麼......天生的墮天使嗎？", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#6$1"}, {"id": 355, "prop": "Character", "attributes": {"name": "avg_npc_355_1#4$1"}}, {"id": 356, "prop": "name", "attributes": {"content": "......很有想像力，艾澤爾。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#4$1"}, {"id": 357, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 358, "prop": "name", "attributes": {"content": "不過沒有你想的那麼神秘。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 359, "prop": "name", "attributes": {"content": "塞茜莉亞是一個混血兒，僅此而已。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 360, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#2$1"}}, {"id": 361, "prop": "name", "attributes": {"content": "什麼？這不可能......薩科塔的混血兒，不可能是薩科塔啊！", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#2$1"}, {"id": 362, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#9$1"}}, {"id": 363, "prop": "name", "attributes": {"content": "我知道薩科塔與他族混血的例子很少......但也沒有稀罕到要驚動教皇廳啊......", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#9$1"}, {"id": 364, "prop": "Character", "attributes": {"name": "avg_npc_355_1#4$1"}}, {"id": 365, "prop": "name", "attributes": {"content": "你不是很清楚原因嗎。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#4$1"}, {"id": 366, "prop": "name", "attributes": {"content": "薩科塔與他族的混血後裔，不會成為薩科塔。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#4$1"}, {"id": 367, "prop": "name", "attributes": {"content": "薩科塔與菲林的孩子會是菲林，薩科塔與豐蹄的孩子會是豐蹄。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#4$1"}, {"id": 368, "prop": "Character", "attributes": {"name": "avg_npc_355_1#8$1"}}, {"id": 369, "prop": "name", "attributes": {"content": "薩科塔混血後裔，不會在開口能言時獲得光環與光翼，也無法與薩科塔共感。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#8$1"}, {"id": 370, "prop": "Character", "attributes": {"name": "avg_npc_355_1#8$1"}}, {"id": 371, "prop": "name", "attributes": {"content": "簡而言之，他們不會有薩科塔的特徵。無一例外......", "name": "奧倫"}, "figure_art": "avg_npc_355_1#8$1"}, {"id": 372, "prop": "Character", "attributes": {"name": "avg_npc_355_1#4$1"}}, {"id": 373, "prop": "name", "attributes": {"content": "至少大部分人這樣認為。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#4$1"}, {"id": 374, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#7$1"}}, {"id": 375, "prop": "name", "attributes": {"content": "......塞茜莉亞就是例外。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#7$1"}, {"id": 376, "prop": "Character", "attributes": {"name": "avg_npc_355_1#4$1"}}, {"id": 377, "prop": "name", "attributes": {"content": "她是不應該成為薩科塔的薩科塔。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#4$1"}, {"id": 378, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#9$1"}}, {"id": 379, "prop": "name", "attributes": {"content": "......第二個問題，如果塞茜莉亞被帶到大教堂，教皇廳會怎麼......對待她。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#9$1"}, {"id": 380, "prop": "Character", "attributes": {"name": "avg_npc_355_1#4$1"}}, {"id": 381, "prop": "name", "attributes": {"content": "我不知道。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#4$1"}, {"id": 382, "prop": "Character", "attributes": {"name": "avg_npc_355_1#9$1"}}, {"id": 383, "prop": "name", "attributes": {"content": "不要露出那種表情，艾澤爾。如果我要哄騙你，大可以給你編點溫柔的瞎話。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#9$1"}, {"id": 384, "prop": "Character", "attributes": {"name": "avg_npc_355_1#7$1"}}, {"id": 385, "prop": "name", "attributes": {"content": "但正如你所見，塞茜莉亞是個“例外”。本代教宗會如何處理這一事件，我無法在此斷言。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#7$1"}, {"id": 386, "prop": "Character", "attributes": {"name": "avg_npc_355_1#4$1"}}, {"id": 387, "prop": "name", "attributes": {"content": "但我們這代的教宗閣下嘛......我不知道你對他是個什麼印象。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#4$1"}, {"id": 388, "prop": "Character", "attributes": {"name": "avg_npc_355_1#9$1"}}, {"id": 389, "prop": "name", "attributes": {"content": "至少，就我個人的瞭解，他並不喜歡使用激烈的手段。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#9$1"}, {"id": 390, "prop": "Character", "attributes": {"name": "avg_npc_355_1#4$1"}}, {"id": 391, "prop": "name", "attributes": {"content": "而且塞茜莉亞這麼可愛，多麼鐵石心腸的人才會傷害她呢，是不是？", "name": "奧倫"}, "figure_art": "avg_npc_355_1#4$1"}, {"id": 392, "prop": "Character", "attributes": {"name": "avg_4036_forcer_1#6$1"}}, {"id": 393, "prop": "name", "attributes": {"content": "......第三個問題。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#6$1"}, {"id": 394, "prop": "name", "attributes": {"content": "我不能完全信任你的回答......我希望陪同塞茜莉亞前往大教堂。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#6$1"}, {"id": 395, "prop": "Character", "attributes": {"name": "avg_npc_355_1#4$1"}}, {"id": 396, "prop": "name", "attributes": {"content": "嗯，這是問題嗎？", "name": "奧倫"}, "figure_art": "avg_npc_355_1#4$1"}, {"id": 397, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 398, "prop": "name", "attributes": {"content": "很可惜，唯有這個“問題”，恕我......", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 399, "prop": "dialog", "attributes": {}}, {"id": 400, "prop": "character", "attributes": {}}, {"id": 401, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 402, "prop": "name", "attributes": {"content": "奧倫，你怎麼在這裡？", "name": "？？？"}}, {"id": 403, "prop": "dialog", "attributes": {}}, {"id": 404, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 405, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#3$1", "fadetime": 1.5}}, {"id": 406, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 407, "prop": "dialog", "attributes": {}}, {"id": 408, "prop": "character", "attributes": {}}, {"id": 409, "prop": "character", "attributes": {"name": "avg_npc_355_1#10$1"}}, {"id": 410, "prop": "name", "attributes": {"content": "......", "name": "奧倫"}, "figure_art": "avg_npc_355_1#10$1"}, {"id": 411, "prop": "Dialog", "attributes": {}}, {"id": 412, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 413, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 414, "prop": "Dialog", "attributes": {}}, {"id": 415, "prop": "Character", "attributes": {}}, {"id": 416, "prop": "Image", "attributes": {}}, {"id": 417, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}