e", "attributes": {"content": "只長在聖瑪律索中心花園、夕輝禮拜堂和司提望區安魂教堂這幾個地方。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#6$1"}, {"id": 315, "prop": "character", "attributes": {"name": "avg_213_mostma_1#10$1"}}, {"id": 316, "prop": "name", "attributes": {"content": "嗯。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#10$1"}, {"id": 317, "prop": "character", "attributes": {"name": "avg_213_mostma_1#10$1"}}, {"id": 318, "prop": "name", "attributes": {"content": "走吧，我們一起。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#10$1"}, {"id": 319, "prop": "character", "attributes": {"name": "avg_213_mostma_1#7$1"}}, {"id": 320, "prop": "name", "attributes": {"content": "......你可是我的監視者，可別讓我受傷了哦。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#7$1"}, {"id": 321, "prop": "character", "attributes": {"name": "avg_300_phenxi_1#3$1"}}, {"id": 322, "prop": "name", "attributes": {"content": "......", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#3$1"}, {"id": 323, "prop": "Dialog", "attributes": {}}, {"id": 324, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 325, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 326, "prop": "Dialog", "attributes": {}}, {"id": 327, "prop": "Character", "attributes": {}}, {"id": 328, "prop": "Image", "attributes": {}}, {"id": 329, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}