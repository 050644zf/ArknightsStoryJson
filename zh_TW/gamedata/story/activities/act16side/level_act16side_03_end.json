t": "true", "block": "false"}}, {"id": 150, "prop": "name", "attributes": {"content": "給我滾出來！！！！！", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#2$1"}, {"id": 151, "prop": "Dialog", "attributes": {}}, {"id": 152, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 153, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 154, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 155, "prop": "Character", "attributes": {}}, {"id": 156, "prop": "Background", "attributes": {"image": "26_g4_laterano_cathedralliving", "screenadapt": "showall"}}, {"id": 157, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 158, "prop": "playMusic", "attributes": {"intro": "$sjoyasorrow_intro", "key": "$sjoyasorrow_loop", "volume": 0.4}}, {"id": 159, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 160, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 161, "prop": "character", "attributes": {"name": "avg_npc_361_1#3$1", "name2": "avg_213_mostma_1#1$2", "focus": 1.0}}, {"id": 162, "prop": "name", "attributes": {"content": "我真不明白，教宗閣下為什麼對那幫“迷途者”如此......放任自流。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#3$1"}, {"id": 163, "prop": "character", "attributes": {"name": "avg_npc_361_1#5$1", "name2": "avg_213_mostma_1#1$2", "focus": 1.0}}, {"id": 164, "prop": "name", "attributes": {"content": "莫斯提馬，你能告訴我嗎，既然你們認識？", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#5$1"}, {"id": 165, "prop": "character", "attributes": {"name": "avg_npc_361_1#5$1", "name2": "avg_213_mostma_1#7$2", "focus": 2.0}}, {"id": 166, "prop": "name", "attributes": {"content": "我可不想和你談這個話題。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#7$2"}, {"id": 167, "prop": "character", "attributes": {"name": "avg_npc_361_1#5$1", "name2": "avg_213_mostma_1#7$2", "focus": 1.0}}, {"id": 168, "prop": "name", "attributes": {"content": "就這麼記仇？", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#5$1"}, {"id": 169, "prop": "character", "attributes": {"name": "avg_npc_361_1#5$1", "name2": "avg_213_mostma_1#7$2", "focus": 2.0}}, {"id": 170, "prop": "name", "attributes": {"content": "畢竟那時候我沒死在那傢伙手上，卻差點被你殺了呢。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#7$2"}, {"id": 171, "prop": "character", "attributes": {"name": "avg_npc_361_1#5$1", "name2": "avg_213_mostma_1#2$2", "focus": 2.0}}, {"id": 172, "prop": "name", "attributes": {"content": "很難忘的經歷。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#2$2"}, {"id": 173, "prop": "character", "attributes": {"name": "avg_npc_361_1#6$1", "name2": "avg_213_mostma_1#2$2", "focus": 1.0}}, {"id": 174, "prop": "name", "attributes": {"content": "這就是你在我面前一直戴著帽子的原因？不難受嗎？", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#6$1"}, {"id": 175, "prop": "character", "attributes": {"name": "avg_npc_361_1#6$1", "name2": "avg_213_mostma_1#7$2", "focus": 2.0}}, {"id": 176, "prop": "name", "attributes": {"content": "都做了這麼久萬國信使了。戴帽子而已。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#7$2"}, {"id": 177, "prop": "character", "attributes": {"name": "avg_npc_361_1#6$1", "name2": "avg_213_mostma_1#5$2", "focus": 2.0}}, {"id": 178, "prop": "name", "attributes": {"content": "和你，多一事不如少一事。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#5$2"}, {"id": 179, "prop": "character", "attributes": {"name": "avg_npc_361_1#5$1", "name2": "avg_213_mostma_1#5$2", "focus": 1.0}}, {"id": 180, "prop": "name", "attributes": {"content": "你在埋怨我嗎，莫斯提馬？", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#5$1"}, {"id": 181, "prop": "character", "attributes": {"name": "avg_npc_361_1#5$1", "name2": "avg_213_mostma_1#2$2", "focus": 2.0}}, {"id": 182, "prop": "name", "attributes": {"content": "拉特蘭始終有拉特蘭要維護的東西，也總有人要在乎這些事。我無所謂。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#2$2"}, {"id": 183, "prop": "character", "attributes": {"name": "avg_npc_361_1#6$1", "name2": "avg_213_mostma_1#2$2", "focus": 1.0}}, {"id": 184, "prop": "name", "attributes": {"content": "莫斯提馬，你可能稍微有些誤解。很少有墮天使留在教廷，並不是因為教廷如何，而是因為那些墮天的薩科塔本身。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#6$1"}, {"id": 185, "prop": "character", "attributes": {"name": "avg_npc_361_1#5$1", "name2": "avg_213_mostma_1#2$2", "focus": 1.0}}, {"id": 186, "prop": "name", "attributes": {"content": "我的態度也許是有一點特別......莫斯提馬，你以為自己就不是個怪胎嗎？", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#5$1"}, {"id": 187, "prop": "character", "attributes": {"name": "avg_npc_361_1#5$1", "name2": "avg_213_mostma_1#5$2", "focus": 2.0}}, {"id": 188, "prop": "name", "attributes": {"content": "你這麼和我說話，就不怕我變成你口中那種“正常的墮天使”？", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#5$2"}, {"id": 189, "prop": "character", "attributes": {"name": "avg_npc_361_1#5$1", "name2": "avg_213_mostma_1#5$2", "focus": 1.0}}, {"id": 190, "prop": "name", "attributes": {"content": "如果你會，就聽不到我和你“這麼說話”了。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#5$1"}, {"id": 191, "prop": "character", "attributes": {"name": "avg_npc_361_1#5$1", "name2": "avg_213_mostma_1#8$2", "focus": 2.0}}, {"id": 192, "prop": "name", "attributes": {"content": "行吧。說點實在的，什麼時候把菲亞梅塔調走？", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#8$2"}, {"id": 193, "prop": "character", "attributes": {"name": "avg_npc_361_1#5$1", "name2": "avg_213_mostma_1#9$2", "focus": 2.0}}, {"id": 194, "prop": "name", "attributes": {"content": "總是跟著我，對她沒好處。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#9$2"}, {"id": 195, "prop": "character", "attributes": {"name": "avg_npc_361_1#6$1", "name2": "avg_213_mostma_1#9$2", "focus": 1.0}}, {"id": 196, "prop": "name", "attributes": {"content": "這句話你不和她本人說嗎？", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#6$1"}, {"id": 197, "prop": "character", "attributes": {"name": "avg_npc_361_1#6$1", "name2": "avg_213_mostma_1#10$2", "focus": 2.0}}, {"id": 198, "prop": "name", "attributes": {"content": "說過了，沒用。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#10$2"}, {"id": 199, "prop": "character", "attributes": {"name": "avg_npc_361_1#6$1", "name2": "avg_213_mostma_1#10$2", "focus": 1.0}}, {"id": 200, "prop": "name", "attributes": {"content": "我說就有用嗎？", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#6$1"}, {"id": 201, "prop": "character", "attributes": {"name": "avg_npc_361_1#6$1", "name2": "avg_213_mostma_1#7$2", "focus": 2.0}}, {"id": 202, "prop": "name", "attributes": {"content": "根據我的觀察，權力的方便之處就是可以無視他人的意願。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#7$2"}, {"id": 203, "prop": "character", "attributes": {"name": "avg_npc_361_1#1$1", "name2": "avg_213_mostma_1#7$2", "focus": 1.0}}, {"id": 204, "prop": "name", "attributes": {"content": "無視他人的意願是要付出代價的......你為什麼想調走菲亞梅塔，說來聽聽。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#1$1"}, {"id": 205, "prop": "character", "attributes": {"name": "avg_npc_361_1#1$1", "name2": "avg_213_mostma_1#7$2", "focus": 2.0}}, {"id": 206, "prop": "name", "attributes": {"content": "菲亞梅塔說是我的護衛，你們就不好奇我有什麼需要她護衛的？", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#7$2"}, {"id": 207, "prop": "character", "attributes": {"name": "avg_npc_361_1#1$1", "name2": "avg_213_mostma_1#7$2", "focus": 2.0}}, {"id": 208, "prop": "name", "attributes": {"content": "當然，也有人覺得她是我這個墮天使的監視者。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#7$2"}, {"id": 209, "prop": "character", "attributes": {"name": "avg_npc_361_1#1$1", "name2": "avg_213_mostma_1#2$2", "focus": 2.0}}, {"id": 210, "prop": "name", "attributes": {"content": "這麼想的人恐怕對菲亞梅塔沒有絲毫瞭解。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#2$2"}, {"id": 211, "prop": "character", "attributes": {"name": "avg_npc_361_1#1$1", "name2": "avg_213_mostma_1#7$2", "focus": 2.0}}, {"id": 212, "prop": "name", "attributes": {"content": "我不過是菲亞梅塔的餌，用來釣安多恩的。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#7$2"}, {"id": 213, "prop": "character", "attributes": {"name": "avg_npc_361_1#6$1", "name2": "avg_213_mostma_1#7$2", "focus": 1.0}}, {"id": 214, "prop": "name", "attributes": {"content": "她要是聽見你這麼說，恐怕不會很開心。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#6$1"}, {"id": 215, "prop": "character", "attributes": {"name": "avg_npc_361_1#6$1", "name2": "avg_213_mostma_1#5$2", "focus": 2.0}}, {"id": 216, "prop": "name", "attributes": {"content": "好吧，那我換個說法......餌是我背上這對鎖與匙。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#5$2"}, {"id": 217, "prop": "character", "attributes": {"name": "avg_npc_361_1#5$1", "name2": "avg_213_mostma_1#5$2", "focus": 1.0}}, {"id": 218, "prop": "name", "attributes": {"content": "所以？讓菲亞梅塔遂願有什麼不好嗎？如果她能幹掉安多恩，或者把他緝拿回大教堂，我當然樂見其成。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#5$1"}, {"id": 219, "prop": "character", "attributes": {"name": "avg_npc_361_1#6$1", "name2": "avg_213_mostma_1#5$2", "focus": 1.0}}, {"id": 220, "prop": "name", "attributes": {"content": "還是說，你們倆加一塊也捉不到安多恩？", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#6$1"}, {"id": 221, "prop": "character", "attributes": {"name": "avg_npc_361_1#6$1", "name2": "avg_213_mostma_1#7$2", "focus": 2.0}}, {"id": 222, "prop": "name", "attributes": {"content": "那倒不至於。只要安多恩還惦記著鎖與匙，他就逃不掉。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#7$2"}, {"id": 223, "prop": "character", "attributes": {"name": "avg_npc_361_1#6$1", "name2": "avg_213_mostma_1#1$2", "focus": 2.0}}, {"id": 224, "prop": "name", "attributes": {"content": "只不過......我在想啊。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#1$2"}, {"id": 225, "prop": "character", "attributes": {"name": "avg_npc_361_1#6$1", "name2": "avg_213_mostma_1#9$2", "focus": 2.0}}, {"id": 226, "prop": "name", "attributes": {"content": "如果安多恩已經找到別的路了呢？", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#9$2"}, {"id": 227, "prop": "character", "attributes": {"name": "avg_npc_361_1#6$1", "name2": "avg_213_mostma_1#6$2", "focus": 2.0}}, {"id": 228, "prop": "name", "attributes": {"content": "我不想見到的是，我走出來了，蕾繆安走出來了，甚至安多恩都走出來了......菲亞梅塔卻還陷在八年前那個雨夜裡。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#6$2"}, {"id": 229, "prop": "name", "attributes": {"content": "沒法和菲亞梅塔說這些。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#6$2"}, {"id": 230, "prop": "name", "attributes": {"content": "也就是這種時候，我會稍微懷念一下共感的好處......", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#6$2"}, {"id": 231, "prop": "character", "attributes": {"name": "avg_npc_361_1#6$1", "name2": "avg_213_mostma_1#1$2", "focus": 2.0}}, {"id": 232, "prop": "name", "attributes": {"content": "啊，忘了菲亞梅塔是黎博利。那當我沒說。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#1$2"}, {"id": 233, "prop": "dialog", "attributes": {}}, {"id": 234, "prop": "character", "attributes": {}}, {"id": 235, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 236, "prop": "character", "attributes": {"name": "avg_npc_356_1#10$1", "fadetime": 1.5}}, {"id": 237, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 238, "prop": "name", "attributes": {"content": "真是年輕的話題。", "name": "教宗"}, "figure_art": "avg_npc_356_1#10$1"}, {"id": 239, "prop": "character", "attributes": {"name": "avg_213_mostma_1#7$2"}}, {"id": 240, "prop": "name", "attributes": {"content": "怎麼，您要給我一點“過來人的教誨”嗎？", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#7$2"}, {"id": 241, "prop": "character", "attributes": {"name": "avg_npc_356_1#9$1"}}, {"id": 242, "prop": "name", "attributes": {"content": "如果你允許我享受一下這種屬於長輩的小小特權。", "name": "教宗"}, "figure_art": "avg_npc_356_1#9$1"}, {"id": 243, "prop": "character", "attributes": {"name": "avg_213_mostma_1#5$2"}}, {"id": 244, "prop": "name", "attributes": {"content": "您請。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#5$2"}, {"id": 245, "prop": "character", "attributes": {"name": "avg_npc_356_1#1$1"}}, {"id": 246, "prop": "name", "attributes": {"content": "還記得八年前你對我說的話嗎？", "name": "教宗"}, "figure_art": "avg_npc_356_1#1$1"}, {"id": 247, "prop": "character", "attributes": {"name": "avg_213_mostma_1#2$2"}}, {"id": 248, "prop": "name", "attributes": {"content": "......雖然我很不想破壞這麼溫情脈脈的氣氛......", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#2$2"}, {"id": 249, "prop": "character", "attributes": {"name": "avg_213_mostma_1#9$2"}}, {"id": 250, "prop": "name", "attributes": {"content": "抱歉，閣下，真忘了。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#9$2"}, {"id": 251, "prop": "character", "attributes": {"name": "avg_npc_361_1#3$1", "name2": "avg_213_mostma_1#9$2", "focus": 1.0}}, {"id": 252, "prop": "name", "attributes": {"content": "你說的是，“不......我還有要做的事，要保護的人”。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#3$1"}, {"id": 253, "prop": "character", "attributes": {"name": "avg_npc_361_1#3$1", "name2": "avg_213_mostma_1#11$2", "focus": 2.0}}, {"id": 254, "prop": "name", "attributes": {"content": "......聽薇爾麗芙學我說話也太惡寒了。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#11$2"}, {"id": 255, "prop": "character", "attributes": {"name": "avg_npc_361_1#5$1", "name2": "avg_213_mostma_1#11$2", "focus": 1.0}}, {"id": 256, "prop": "name", "attributes": {"content": "......", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#5$1"}, {"id": 257, "prop": "character", "attributes": {"name": "avg_npc_356_1#6$1"}}, {"id": 258, "prop": "name", "attributes": {"content": "彼時彼刻，你不願讓我替你做選擇，此時此刻，你又何必要替菲亞梅塔做選擇呢？", "name": "教宗"}, "figure_art": "avg_npc_356_1#6$1"}, {"id": 259, "prop": "character", "attributes": {"name": "avg_npc_356_1#1$1"}}, {"id": 260, "prop": "name", "attributes": {"content": "人的路總要自己去找，自己去選，自己去走。", "name": "教宗"}, "figure_art": "avg_npc_356_1#1$1"}, {"id": 261, "prop": "name", "attributes": {"content": "薇爾，這也是給你的回答。", "name": "教宗"}, "figure_art": "avg_npc_356_1#1$1"}, {"id": 262, "prop": "Dialog", "attributes": {}}, {"id": 263, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 264, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 265, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 266, "prop": "Character", "attributes": {}}, {"id": 267, "prop": "Background", "attributes": {"image": "26_g5_laterano_chapelout", "screenadapt": "showall"}}, {"id": 268, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 269, "prop": "playMusic", "attributes": {"intro": "$drift_intro", "key": "$drift_loop", "volume": 0.4}}, {"id": 270, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 271, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 272, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#1$1", "name2": "avg_npc_352_1#9$1", "focus": 1.0}}, {"id": 273, "prop": "name", "attributes": {"content": "......快到了，塞茜莉亞。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#1$1"}, {"id": 274, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#1$1", "name2": "avg_npc_352_1#9$1", "focus": 2.0}}, {"id": 275, "prop": "name", "attributes": {"content": "對不起，艾澤爾哥哥，我走得太慢了......太陽都快要落山了。", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#9$1"}, {"id": 276, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#8$1", "name2": "avg_npc_352_1#9$1", "focus": 1.0}}, {"id": 277, "prop": "name", "attributes": {"content": "塞茜莉亞很了不起！畢竟沒辦法用公共交通......我們都走到移動地塊以外啦。要是我有菲亞梅塔小姐的身手和力氣，你也不用這麼辛苦。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#8$1"}, {"id": 278, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#8$1", "name2": "avg_npc_352_1#10$1", "focus": 2.0}}, {"id": 279, "prop": "name", "attributes": {"content": "沒關係的！其實媽媽也帶我出來過，我們會走到離家很遠的地方......和這裡也差不多。", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#10$1"}, {"id": 280, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#8$1", "name2": "avg_npc_352_1#12$1", "focus": 2.0}}, {"id": 281, "prop": "name", "attributes": {"content": "不過，菲亞梅塔姐姐不會發現我們偷偷來這裡嗎？", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#12$1"}, {"id": 282, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#7$1", "name2": "avg_npc_352_1#12$1", "focus": 1.0}}, {"id": 283, "prop": "name", "attributes": {"content": "如果她只是查看終端的定位信號......希望我的花招至少能爭取一點時間。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#7$1"}, {"id": 284, "prop": "name", "attributes": {"content": "好在還是抵達了。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#7$1"}, {"id": 285, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#7$1", "name2": "avg_npc_352_1#12$1", "focus": 2.0}}, {"id": 286, "prop": "name", "attributes": {"content": "媽媽就是來了這裡嗎？", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#12$1"}, {"id": 287, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#12$1", "focus": 1.0}}, {"id": 288, "prop": "name", "attributes": {"content": "......塞茜莉亞，我想了很久應該怎麼和你解釋這件事。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 289, "prop": "name", "attributes": {"content": "費莉亞......你的媽媽，確實來了這裡，但她也不在這裡。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 290, "prop": "name", "attributes": {"content": "我沒辦法讓你再見到媽媽。但在這裡，你至少可以和她告別。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 291, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#9$1", "focus": 2.0}}, {"id": 292, "prop": "name", "attributes": {"content": "艾澤爾哥哥......你說的......我不太明白......", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#9$1"}, {"id": 293, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#12$1", "focus": 2.0}}, {"id": 294, "prop": "name", "attributes": {"content": "如果媽媽來了這裡，又不在這裡，那她是......又去了別的地方嗎？", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#12$1"}, {"id": 295, "prop": "name", "attributes": {"content": "去了哪裡呢？", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#12$1"}, {"id": 296, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#1$1", "name2": "avg_npc_352_1#12$1", "focus": 1.0}}, {"id": 297, "prop": "name", "attributes": {"content": "......我們先進去吧。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#1$1"}, {"id": 298, "prop": "Dialog", "attributes": {}}, {"id": 299, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 300, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 301, "prop": "Character", "attributes": {}}, {"id": 302, "prop": "Background", "attributes": {"image": "26_g6_laterano_chapelin", "screenadapt": "showall"}}, {"id": 303, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 304, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 305, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 306, "prop": "character", "attributes": {"name": "avg_npc_368_1#1$1", "name2": "avg_npc_369_1#1$1", "focus": 1.0}}, {"id": 307, "prop": "name", "attributes": {"content": "......父親去世之前，一直希望他的葬禮上只有歡笑，不要有淚水，可我卻......", "name": "拉特蘭市民"}, "figure_art": "avg_npc_368_1#1$1"}, {"id": 308, "prop": "character", "attributes": {"name": "avg_npc_368_1#1$1", "name2": "avg_npc_369_1#1$1", "focus": 2.0}}, {"id": 309, "prop": "name", "attributes": {"content": "我想，令尊真正希望的是，您不因他的離去陷入無法自拔的悲傷。", "name": "溫和的修士"}, "figure_art": "avg_npc_369_1#1$1"}, {"id": 310, "prop": "name", "attributes": {"content": "哭泣也好，歡笑也好，如果那就是您的道別......想必他都會欣然接受的。", "name": "溫和的修士"}, "figure_art": "avg_npc_369_1#1$1"}, {"id": 311, "prop": "character", "attributes": {"name": "avg_npc_368_1#1$1", "name2": "avg_npc_369_1#1$1", "focus": 1.0}}, {"id": 312, "prop": "name", "attributes": {"content": "謝謝你......修士小姐......", "name": "拉特蘭市民"}, "figure_art": "avg_npc_368_1#1$1"}, {"id": 313, "prop": "character", "attributes": {"name": "avg_npc_368_1#1$1", "name2": "avg_npc_369_1#1$1", "focus": 2.0}}, {"id": 314, "prop": "name", "attributes": {"content": "我陪您去外面的花田走走吧。", "name": "溫和的修士"}, "figure_art": "avg_npc_369_1#1$1"}, {"id": 315, "prop": "dialog", "attributes": {}}, {"id": 316, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 317, "prop": "character", "attributes": {"fadetime": 1.5}}, {"id": 318, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 319, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#1$1", "name2": "avg_npc_352_1#9$1", "focus": 2.0}}, {"id": 320, "prop": "name", "attributes": {"content": "艾澤爾哥哥，那個姐姐說她的父親也“去世”了......", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#9$1"}, {"id": 321, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#1$1", "name2": "avg_npc_352_1#9$1", "focus": 1.0}}, {"id": 322, "prop": "name", "attributes": {"content": "嗯......去世的人，就會來到這裡。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#1$1"}, {"id": 323, "prop": "name", "attributes": {"content": "活著的人，在這裡與他們道別......然後，帶著對去世之人的思念，繼續自己的生活。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#1$1"}, {"id": 324, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#1$1", "name2": "avg_npc_352_1#12$1", "focus": 2.0}}, {"id": 325, "prop": "name", "attributes": {"content": "那去世的人呢，他們做什麼？", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#12$1"}, {"id": 326, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#7$1", "name2": "avg_npc_352_1#12$1", "focus": 1.0}}, {"id": 327, "prop": "name", "attributes": {"content": "......也許會在天上看著我們吧。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#7$1"}, {"id": 328, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#7$1", "name2": "avg_npc_352_1#9$1", "focus": 2.0}}, {"id": 329, "prop": "name", "attributes": {"content": "因為去了天上，所以再也見不到了嗎？", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#9$1"}, {"id": 330, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#9$1", "focus": 1.0}}, {"id": 331, "prop": "name", "attributes": {"content": "......", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 332, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#1$1", "name2": "avg_npc_352_1#9$1", "focus": 1.0}}, {"id": 333, "prop": "name", "attributes": {"content": "塞茜莉亞，給你。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#1$1"}, {"id": 334, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#1$1", "name2": "avg_npc_352_1#5$1", "focus": 2.0}}, {"id": 335, "prop": "name", "attributes": {"content": "這是......媽媽的守護銃？", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#5$1"}, {"id": 336, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#1$1", "name2": "avg_npc_352_1#5$1", "focus": 1.0}}, {"id": 337, "prop": "name", "attributes": {"content": "嗯。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#1$1"}, {"id": 338, "prop": "name", "attributes": {"content": "我的爸爸媽媽，都是公證所的執行者。小時候我很少能見到他們......是爺爺把我帶大的。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#1$1"}, {"id": 339, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#8$1", "name2": "avg_npc_352_1#5$1", "focus": 1.0}}, {"id": 340, "prop": "name", "attributes": {"content": "爺爺很喜歡他的銃，每次擦銃的時候，都會和我講起他年輕時的事......", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#8$1"}, {"id": 341, "prop": "name", "attributes": {"content": "他參加過的戰役，他的戰友，他怎麼遇到奶奶，還有我爸爸小時候的糗事......", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#8$1"}, {"id": 342, "prop": "name", "attributes": {"content": "看到爺爺的銃，我就會想起他講的那些故事。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#8$1"}, {"id": 343, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#5$1", "focus": 1.0}}, {"id": 344, "prop": "name", "attributes": {"content": "......後來，爺爺去世了。我那時也只比你現在大一點點。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 345, "prop": "name", "attributes": {"content": "公證所的執行者，帶走了他的守護銃。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 346, "prop": "name", "attributes": {"content": "就像你母親的守護銃，本應被我帶走。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 347, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 348, "prop": "dialog", "attributes": {}}, {"id": 349, "prop": "character", "attributes": {}}, {"id": 350, "prop": "delay", "attributes": {"time": 3.0}}, {"id": 351, "prop": "playMusic", "attributes": {"intro": "$distressed_intro", "key": "$distressed_loop", "volume": 0.4}}, {"id": 352, "prop": "name", "attributes": {"content": "艾澤爾緩緩蹲下，將費莉亞的銃放在塞茜莉亞手中。"}}, {"id": 353, "prop": "name", "attributes": {"content": "塞茜莉亞低下頭，看著手中母親的守護銃。"}}, {"id": 354, "prop": "name", "attributes": {"content": "艾澤爾輕輕握住塞茜莉亞的手。"}}, {"id": 355, "prop": "name", "attributes": {"content": "溫熱的水滴跌落在守護銃的浮雕花紋上，流到年幼女孩的掌心，堆積成一小片水漬。"}}, {"id": 356, "prop": "dialog", "attributes": {}}, {"id": 357, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 358, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#1$1", "name2": "avg_npc_352_1#5$1", "focus": 2.0}}, {"id": 359, "prop": "name", "attributes": {"content": "艾澤爾哥哥......我怎麼哭了......", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#5$1"}, {"id": 360, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#7$1", "name2": "avg_npc_352_1#5$1", "focus": 1.0}}, {"id": 361, "prop": "name", "attributes": {"content": "我按爺爺教我的，每周給後院的盆栽澆水，後來它們開花了，我很高興，喊爺爺來看。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#7$1"}, {"id": 362, "prop": "character", "attributes": {"name": "avg_4036_forcer_1#5$1", "name2": "avg_npc_352_1#5$1", "focus": 1.0}}, {"id": 363, "prop": "name", "attributes": {"content": "喊出聲才想起來，爺爺已經不在了。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 364, "prop": "name", "attributes": {"content": "我再也見不到爺爺，再也沒見過他的銃。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 365, "prop": "name", "attributes": {"content": "死亡就是永不再會的離別。", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#5$1"}, {"id": 366, "prop": "character", "attributes": {"name": "avg_npc_352_1#7$1"}}, {"id": 367, "prop": "name", "attributes": {"content": "......", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#7$1"}, {"id": 368, "prop": "dialog", "attributes": {}}, {"id": 369, "prop": "character", "attributes": {}}, {"id": 370, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 371, "prop": "character", "attributes": {"name": "avg_npc_351_1#1$1", "blackstart": 0.2, "blackend": 0.7, "fadetime": 2.0}}, {"id": 372, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 373, "prop": "name", "attributes": {"content": "然而離別本身即是對死亡的克服。", "name": "？？？"}, "figure_art": "avg_npc_351_1#1$1"}, {"id": 374, "prop": "name", "attributes": {"content": "存者在此，去者在彼，才有“離別”。", "name": "？？？"}, "figure_art": "avg_npc_351_1#1$1"}, {"id": 375, "prop": "name", "attributes": {"content": "“離別”是生者對逝者的惦念，也因此成為逝者存在的證明。", "name": "？？？"}, "figure_art": "avg_npc_351_1#1$1"}, {"id": 376, "prop": "dialog", "attributes": {}}, {"id": 377, "prop": "character", "attributes": {}}, {"id": 378, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 379, "prop": "character", "attributes": {"name": "avg_npc_351_1#1$1", "fadetime": 1.0}}, {"id": 380, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 381, "prop": "name", "attributes": {"content": "這就是為何我們需要道別。", "name": "修士"}, "figure_art": "avg_npc_351_1#1$1"}, {"id": 382, "prop": "Dialog", "attributes": {}}, {"id": 383, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 384, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 385, "prop": "Dialog", "attributes": {}}, {"id": 386, "prop": "Character", "attributes": {}}, {"id": 387, "prop": "Image", "attributes": {}}, {"id": 388, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}