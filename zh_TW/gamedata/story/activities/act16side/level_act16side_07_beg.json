, "prop": "name", "attributes": {"content": "那是......一個執行者，一個萬國信使？！", "name": "悠哉的拉特蘭市民"}, "figure_art": "avg_npc_368_1#1$1"}, {"id": 46, "prop": "Character", "attributes": {"name": "avg_npc_366_1#1$1"}}, {"id": 47, "prop": "name", "attributes": {"content": "這是在幹啥，跑酷比賽？", "name": "喜悅的拉特蘭市民"}, "figure_art": "avg_npc_366_1#1$1"}, {"id": 48, "prop": "Character", "attributes": {"name": "avg_npc_368_1#1$1"}}, {"id": 49, "prop": "name", "attributes": {"content": "這麼熱鬧？你玩不玩？", "name": "悠哉的拉特蘭市民"}, "figure_art": "avg_npc_368_1#1$1"}, {"id": 50, "prop": "Character", "attributes": {"name": "avg_npc_366_1#1$1"}}, {"id": 51, "prop": "name", "attributes": {"content": "走唄！看看追不追得上！", "name": "喜悅的拉特蘭市民"}, "figure_art": "avg_npc_366_1#1$1"}, {"id": 52, "prop": "dialog", "attributes": {}}, {"id": 53, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 54, "prop": "PlaySound", "attributes": {"key": "$d_gen_soldiersrun", "volume": 0.8}}, {"id": 55, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 56, "prop": "Character", "attributes": {}}, {"id": 57, "prop": "Background", "attributes": {"image": "26_g10_laterano_roof", "screenadapt": "showall"}}, {"id": 58, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 59, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 60, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 61, "prop": "name", "attributes": {"content": "到這裡應該......", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 62, "prop": "dialog", "attributes": {}}, {"id": 63, "prop": "character", "attributes": {}}, {"id": 64, "prop": "PlaySound", "attributes": {"key": "$grenade_launcher_shot", "volume": 1.0}}, {"id": 65, "prop": "CameraShake", "attributes": {"duration": 0.4, "xstrength": 0.0, "ystrength": 0.0, "vibrato": 0.0, "randomness": 0.0, "fadeout": "true", "block": "true"}}, {"id": 66, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 67, "prop": "Character", "attributes": {"name": "avg_npc_355_1#6$1"}}, {"id": 68, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 69, "prop": "PlaySound", "attributes": {"key": "$swordtsing1", "volume": 1.0}}, {"id": 70, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.05, "block": "true"}}, {"id": 71, "prop": "CameraShake", "attributes": {"duration": 0.4, "xstrength": 0.0, "ystrength": 0.0, "vibrato": 0.0, "randomness": 0.0, "fadeout": "true", "block": "true"}}, {"id": 72, "prop": "dialog", "attributes": {}}, {"id": 73, "prop": "CameraShake", "attributes": {"duration": 1.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 74, "prop": "PlaySound", "attributes": {"key": "$d_sp_ballista"}}, {"id": 75, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 76, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 77, "prop": "character", "attributes": {}}, {"id": 78, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 79, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 80, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 1.0, "block": "false"}}, {"id": 81, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 82, "prop": "Character", "attributes": {"name": "char_279_excu_4", "fadetime": 1.0}}, {"id": 83, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 84, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 85, "prop": "name", "attributes": {"content": "唉，真是難纏啊，費德里科。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 86, "prop": "Character", "attributes": {"name": "char_279_excu_4"}}, {"id": 87, "prop": "name", "attributes": {"content": "你也很難纏。", "name": "費德里科"}, "figure_art": "char_279_excu_4"}, {"id": 88, "prop": "Character", "attributes": {"name": "avg_npc_355_1#2$1"}}, {"id": 89, "prop": "name", "attributes": {"content": "我調查過，你現在應該沒有任務在身......你根本就休假了啊？！", "name": "奧倫"}, "figure_art": "avg_npc_355_1#2$1"}, {"id": 90, "prop": "Character", "attributes": {"name": "avg_npc_355_1#2$1"}}, {"id": 91, "prop": "name", "attributes": {"content": "我真是搞不懂了，你咬著我不放做什麼？我什麼時候得罪你了嗎？", "name": "奧倫"}, "figure_art": "avg_npc_355_1#2$1"}, {"id": 92, "prop": "Character", "attributes": {"name": "char_279_excu_4"}}, {"id": 93, "prop": "name", "attributes": {"content": "我的上一項任務，是前往敘拉古將一位當地薩科塔的遺物送回拉特蘭。", "name": "費德里科"}, "figure_art": "char_279_excu_4"}, {"id": 94, "prop": "Character", "attributes": {"name": "char_279_excu_4"}}, {"id": 95, "prop": "name", "attributes": {"content": "他的遺物中有一本筆記，記載了他曾經目睹一名女性薩科塔與薩卡茲接觸。", "name": "費德里科"}, "figure_art": "char_279_excu_4"}, {"id": 96, "prop": "Character", "attributes": {"name": "avg_npc_355_1#7$1"}}, {"id": 97, "prop": "name", "attributes": {"content": "行吧，那你要查也正常。但是關我什麼事？我是男的哦？", "name": "奧倫"}, "figure_art": "avg_npc_355_1#7$1"}, {"id": 98, "prop": "Character", "attributes": {"name": "char_279_excu_4"}}, {"id": 99, "prop": "name", "attributes": {"content": "我追溯各種線索，最終找到這名女性的住址是拉特蘭城司提望區瑟法斯街7-265號。", "name": "費德里科"}, "figure_art": "char_279_excu_4"}, {"id": 100, "prop": "Character", "attributes": {"name": "avg_npc_355_1#2$1"}}, {"id": 101, "prop": "name", "attributes": {"content": "......", "name": "奧倫"}, "figure_art": "avg_npc_355_1#2$1"}, {"id": 102, "prop": "Character", "attributes": {"name": "avg_npc_355_1#2$1"}}, {"id": 103, "prop": "name", "attributes": {"content": "你到達那裡時，發現她已經去世了。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#2$1"}, {"id": 104, "prop": "Character", "attributes": {"name": "char_279_excu_4"}}, {"id": 105, "prop": "name", "attributes": {"content": "不錯。", "name": "費德里科"}, "figure_art": "char_279_excu_4"}, {"id": 106, "prop": "Character", "attributes": {"name": "avg_npc_355_1#2$1"}}, {"id": 107, "prop": "name", "attributes": {"content": "......你只好繼續調查她的行蹤記錄，然後發現她有一些可疑的出行，而每一次這種可疑的出行之前，她都和我這個萬國信使有過聯絡......", "name": "奧倫"}, "figure_art": "avg_npc_355_1#2$1"}, {"id": 108, "prop": "Character", "attributes": {"name": "avg_npc_355_1#4$1"}}, {"id": 109, "prop": "name", "attributes": {"content": "哈哈哈哈哈！有意思，太有意思了！", "name": "奧倫"}, "figure_art": "avg_npc_355_1#4$1"}, {"id": 110, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 111, "prop": "name", "attributes": {"content": "我還想是我在維多利亞露了馬腳？或者哪一次和安多恩聯絡留了痕跡？沒想到竟然是因為好心幫費莉亞的這一點小忙......", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 112, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 113, "prop": "name", "attributes": {"content": "也可謂是命運的一種了。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 114, "prop": "Character", "attributes": {"name": "char_279_excu_4"}}, {"id": 115, "prop": "name", "attributes": {"content": "感慨完了嗎？", "name": "費德里科"}, "figure_art": "char_279_excu_4"}, {"id": 116, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 117, "prop": "name", "attributes": {"content": "唉，費德里科，如果我沒猜錯，你現在應該無法感知我的情緒吧？", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 118, "prop": "Character", "attributes": {"name": "char_279_excu_4"}}, {"id": 119, "prop": "name", "attributes": {"content": "不能，我也不在乎。", "name": "費德里科"}, "figure_art": "char_279_excu_4"}, {"id": 120, "prop": "Character", "attributes": {"name": "char_279_excu_4"}}, {"id": 121, "prop": "name", "attributes": {"content": "緝捕對象的情緒與我無關。", "name": "費德里科"}, "figure_art": "char_279_excu_4"}, {"id": 122, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 123, "prop": "name", "attributes": {"content": "不是你緝捕對象的人，他們的情緒你就在乎嗎？", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 124, "prop": "Character", "attributes": {"name": "char_279_excu_4"}}, {"id": 125, "prop": "name", "attributes": {"content": "......不。", "name": "費德里科"}, "figure_art": "char_279_excu_4"}, {"id": 126, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 127, "prop": "name", "attributes": {"content": "你和我一樣，我們都多少拒絕了共感......依我看，我們大可以交個朋友啊。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 128, "prop": "name", "attributes": {"content": "其實我覺得，拉特蘭是應該多一點你這樣的人。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 129, "prop": "name", "attributes": {"content": "不要那麼同情心氾濫，單純以法規為準則行動。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 130, "prop": "Character", "attributes": {"name": "char_279_excu_4"}}, {"id": 131, "prop": "name", "attributes": {"content": "我不反對這個觀點。或許等你的審判結束後，我可以到監獄裡和你交流。", "name": "費德里科"}, "figure_art": "char_279_excu_4"}, {"id": 132, "prop": "character", "attributes": {}}, {"id": 133, "prop": "name", "attributes": {"content": "所以，這就是你的理由，奧倫？", "name": "？？？"}}, {"id": 134, "prop": "Character", "attributes": {"name": "avg_npc_355_1#6$1"}}, {"id": 135, "prop": "name", "attributes": {"content": "......最麻煩的傢伙出現了。我這樣日行一善的人為什麼會倒楣成這樣......", "name": "奧倫"}, "figure_art": "avg_npc_355_1#6$1"}, {"id": 136, "prop": "Character", "attributes": {"name": "char_279_excu_4"}}, {"id": 137, "prop": "name", "attributes": {"content": "樞機薇爾麗芙，你好。", "name": "費德里科"}, "figure_art": "char_279_excu_4"}, {"id": 138, "prop": "dialog", "attributes": {}}, {"id": 139, "prop": "character", "attributes": {}}, {"id": 140, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 141, "prop": "Character", "attributes": {"name": "avg_npc_361_1#5$1", "fadetime": 1.0, "block": "true"}}, {"id": 142, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 143, "prop": "name", "attributes": {"content": "你好，執行者費德里科。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#5$1"}, {"id": 144, "prop": "Character", "attributes": {"name": "avg_npc_361_1#1$1"}}, {"id": 145, "prop": "name", "attributes": {"content": "叛徒奧倫的處置接下來移交第七廳，公證所方面可以轉項結案了，你關於此事的報告麻煩抄送第七廳、第一廳。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#1$1"}, {"id": 146, "prop": "Character", "attributes": {"name": "avg_npc_361_1#1$1"}}, {"id": 147, "prop": "name", "attributes": {"content": "這是我的認證碼。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#1$1"}, {"id": 148, "prop": "Character", "attributes": {"name": "char_279_excu_4"}}, {"id": 149, "prop": "name", "attributes": {"content": "確認完畢，程序合規。", "name": "費德里科"}, "figure_art": "char_279_excu_4"}, {"id": 150, "prop": "Character", "attributes": {"name": "avg_npc_361_1#1$1"}}, {"id": 151, "prop": "name", "attributes": {"content": "然後，你想繼續休假還是臨時參與迷途者緝捕行動？隨你高興。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#1$1"}, {"id": 152, "prop": "dialog", "attributes": {}}, {"id": 153, "prop": "Character", "attributes": {"name": "char_279_excu_4"}}, {"id": 154, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 155, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 156, "prop": "character", "attributes": {"fadetime": 1.0}}, {"id": 157, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 158, "prop": "Character", "attributes": {"name": "avg_npc_355_1#2$1"}}, {"id": 159, "prop": "name", "attributes": {"content": "薇爾，你說，有人聽過費德里科說再見嗎？", "name": "奧倫"}, "figure_art": "avg_npc_355_1#2$1"}, {"id": 160, "prop": "Character", "attributes": {"name": "avg_npc_361_1#3$1"}}, {"id": 161, "prop": "name", "attributes": {"content": "別套近乎。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#3$1"}, {"id": 162, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 163, "prop": "name", "attributes": {"content": "你不是來幫我的嗎？", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 164, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 165, "prop": "name", "attributes": {"content": "如果你想把我繩之以法，只要等費德里科幹完他的活兒就行了，不是嗎？", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 166, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 167, "prop": "name", "attributes": {"content": "當然啦，也有可能費德里科確實敵不過我......但你也沒必要把他打發走，對吧。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 168, "prop": "Character", "attributes": {"name": "avg_npc_361_1#1$1"}}, {"id": 169, "prop": "name", "attributes": {"content": "我只是發現你比我以為的有用一點。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#1$1"}, {"id": 170, "prop": "Character", "attributes": {"name": "avg_npc_361_1#1$1"}}, {"id": 171, "prop": "name", "attributes": {"content": "費德里科上報之後，我本以為你只是安多恩的幫手......但現在看來，你還不算太廢物。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#1$1"}, {"id": 172, "prop": "Character", "attributes": {"name": "avg_npc_355_1#4$1"}}, {"id": 173, "prop": "name", "attributes": {"content": "倍感榮幸。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#4$1"}, {"id": 174, "prop": "Character", "attributes": {"name": "avg_npc_361_1#1$1"}}, {"id": 175, "prop": "name", "attributes": {"content": "塞茜莉亞的存在對拉特蘭是天然的威脅，你不希望這個威脅被抹去......不是因為你想實踐這個威脅，而是你想用這個威脅做交易。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#1$1"}, {"id": 176, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 177, "prop": "name", "attributes": {"content": "天上掉下來的一筆錢，大家都不想用，讓我很痛心哪。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 178, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 179, "prop": "name", "attributes": {"content": "其實我對拉特蘭是第一等的忠心，薇爾麗芙你是知道我的。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 180, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 181, "prop": "name", "attributes": {"content": "我可是最支持教宗閣下理想的人。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 182, "prop": "Character", "attributes": {"name": "avg_npc_361_1#1$1"}}, {"id": 183, "prop": "name", "attributes": {"content": "但你不認同閣下的方式，對嗎？", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#1$1"}, {"id": 184, "prop": "Character", "attributes": {"name": "avg_npc_361_1#1$1"}}, {"id": 185, "prop": "name", "attributes": {"content": "就比如這場會議，你從心底裡覺得它不會有用。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#1$1"}, {"id": 186, "prop": "Character", "attributes": {"name": "avg_npc_355_1#2$1"}}, {"id": 187, "prop": "name", "attributes": {"content": "......", "name": "奧倫"}, "figure_art": "avg_npc_355_1#2$1"}, {"id": 188, "prop": "Character", "attributes": {"name": "avg_npc_355_1#2$1"}}, {"id": 189, "prop": "name", "attributes": {"content": "難道你覺得會有用？", "name": "奧倫"}, "figure_art": "avg_npc_355_1#2$1"}, {"id": 190, "prop": "Character", "attributes": {"name": "avg_npc_355_1#8$1"}}, {"id": 191, "prop": "name", "attributes": {"content": "薇爾麗芙，你對維多利亞的現狀瞭解多少？", "name": "奧倫"}, "figure_art": "avg_npc_355_1#8$1"}, {"id": 192, "prop": "Character", "attributes": {"name": "avg_npc_355_1#2$1"}}, {"id": 193, "prop": "name", "attributes": {"content": "你不會不明白，我們距離一場戰爭有多麼的近。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#2$1"}, {"id": 194, "prop": "Character", "attributes": {"name": "avg_npc_355_1#2$1"}}, {"id": 195, "prop": "name", "attributes": {"content": "閣下在這個時期，動用佈局數十年的力量，即使撬動了大部分國家，但來的人還是......分量太輕了。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#2$1"}, {"id": 196, "prop": "Character", "attributes": {"name": "avg_npc_355_1#2$1"}}, {"id": 197, "prop": "name", "attributes": {"content": "在更平和的年代，或許我們確實可以以此為基礎，慢慢佈局。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#2$1"}, {"id": 198, "prop": "name", "attributes": {"content": "但情況並非如此。如果要實現閣下的理想，沒有那麼多時間讓我們溫吞吞地做事了。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#2$1"}, {"id": 199, "prop": "name", "attributes": {"content": "我在維多利亞親眼見證了無數更骯髒的手段，我不會說那是正確的，但如果正確不能達成目的——", "name": "奧倫"}, "figure_art": "avg_npc_355_1#2$1"}, {"id": 200, "prop": "name", "attributes": {"content": "告訴我，薇爾麗芙，你寧願成為一個高尚的人嗎？", "name": "奧倫"}, "figure_art": "avg_npc_355_1#2$1"}, {"id": 201, "prop": "Character", "attributes": {"name": "avg_npc_361_1#1$1"}}, {"id": 202, "prop": "name", "attributes": {"content": "奧倫，在這種時候，你的話通常沒有這麼多。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#1$1"}, {"id": 203, "prop": "Character", "attributes": {"name": "avg_npc_361_1#7$1"}}, {"id": 204, "prop": "name", "attributes": {"content": "你在等什麼？", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#7$1"}, {"id": 205, "prop": "Character", "attributes": {"name": "avg_npc_355_1#2$1"}}, {"id": 206, "prop": "name", "attributes": {"content": "其實剛才我改變了主意。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#2$1"}, {"id": 207, "prop": "Character", "attributes": {"name": "avg_npc_361_1#7$1"}}, {"id": 208, "prop": "name", "attributes": {"content": "哦？", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#7$1"}, {"id": 209, "prop": "Character", "attributes": {"name": "avg_npc_355_1#2$1"}}, {"id": 210, "prop": "name", "attributes": {"content": "在外走動這麼多年，我越來越不相信薩科塔有多麼獨特。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#2$1"}, {"id": 211, "prop": "Character", "attributes": {"name": "avg_npc_355_1#2$1"}}, {"id": 212, "prop": "name", "attributes": {"content": "我們只是能夠互相分享情感，僅此而已。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#2$1"}, {"id": 213, "prop": "Character", "attributes": {"name": "avg_npc_355_1#2$1"}}, {"id": 214, "prop": "name", "attributes": {"content": "但就在剛才，即便是我，也不得不承認......我感受到了某種古老的、悠久的東西，它真正來自我的內心。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#2$1"}, {"id": 215, "prop": "Character", "attributes": {"name": "avg_npc_355_1#1$1"}}, {"id": 216, "prop": "name", "attributes": {"content": "並且，我們獲得了一張牌。", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 217, "prop": "name", "attributes": {"content": "各國使者聚首拉特蘭之日，拉特蘭降下神跡......", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 218, "prop": "name", "attributes": {"content": "這意味著什麼，這能夠意味著什麼，我們有很多事可以做，不是嗎？", "name": "奧倫"}, "figure_art": "avg_npc_355_1#1$1"}, {"id": 219, "prop": "Character", "attributes": {"name": "avg_npc_361_1#1$1"}}, {"id": 220, "prop": "name", "attributes": {"content": "有一點，你可能想錯了。你覺得萬國峰會不該誕生在多事之秋......我建議你，不如反過來考慮一下。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#1$1"}, {"id": 221, "prop": "Character", "attributes": {"name": "avg_npc_361_1#7$1"}}, {"id": 222, "prop": "name", "attributes": {"content": "不過呢，你也有想得不錯的地方。教宗閣下也許有不方便做的事。但於我而言，做兩手準備沒有壞處。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#7$1"}, {"id": 223, "prop": "Character", "attributes": {"name": "avg_npc_361_1#6$1"}}, {"id": 224, "prop": "name", "attributes": {"content": "你很好運，奧倫，因為我確實用得著你。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#6$1"}, {"id": 225, "prop": "dialog", "attributes": {}}, {"id": 226, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 227, "prop": "Character", "attributes": {}}, {"id": 228, "prop": "Background", "attributes": {"image": "26_g11_laterano_alley", "screenadapt": "showall"}}, {"id": 229, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 230, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 231, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#6$1"}}, {"id": 232, "prop": "name", "attributes": {"content": "出來吧，帕蒂亞。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#6$1"}, {"id": 233, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#6$1"}}, {"id": 234, "prop": "name", "attributes": {"content": "算你們還有點理智，沒有讓你們的薩卡茲同伴們參與到城內的騷亂活動中......", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#6$1"}, {"id": 235, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#6$1"}}, {"id": 236, "prop": "name", "attributes": {"content": "如果使節們真的在拉特蘭城裡親眼目睹了“前來破壞萬國峰會的薩卡茲”......這件事情可就沒那麼好收場了。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#6$1"}, {"id": 237, "prop": "dialog", "attributes": {}}, {"id": 238, "prop": "character", "attributes": {}}, {"id": 239, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 240, "prop": "Character", "attributes": {"name": "avg_npc_357_1#6$1", "fadetime": 1.0, "block": "true"}}, {"id": 241, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 242, "prop": "name", "attributes": {"content": "......你想說什麼，菲亞梅塔。", "name": "帕蒂亞"}, "figure_art": "avg_npc_357_1#6$1"}, {"id": 243, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#6$1"}}, {"id": 244, "prop": "name", "attributes": {"content": "安多恩已經在去往大教堂的路上了吧。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#6$1"}, {"id": 245, "prop": "Character", "attributes": {"name": "avg_npc_357_1#3$1"}}, {"id": 246, "prop": "name", "attributes": {"content": "你知道了什麼？！", "name": "帕蒂亞"}, "figure_art": "avg_npc_357_1#3$1"}, {"id": 247, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#6$1"}}, {"id": 248, "prop": "name", "attributes": {"content": "沒必要和你彙報，帕蒂亞。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#6$1"}, {"id": 249, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#6$1"}}, {"id": 250, "prop": "name", "attributes": {"content": "但在去找他算帳之前，我得讓你先停下來，別再繼續這些愚蠢又煩人的小動作。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#6$1"}, {"id": 251, "prop": "name", "attributes": {"content": "雖然你們可能是還有那麼一絲理智，並不真的要對萬國峰會動手......", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#6$1"}, {"id": 252, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#6$1"}}, {"id": 253, "prop": "name", "attributes": {"content": "但我勸你們不要冒險，事情未必總如我們所願。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#6$1"}, {"id": 254, "prop": "Character", "attributes": {"name": "avg_npc_357_1#3$1"}}, {"id": 255, "prop": "name", "attributes": {"content": "哦......？現在輪到你來“說服”我了？", "name": "帕蒂亞"}, "figure_art": "avg_npc_357_1#3$1"}, {"id": 256, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#1$1"}}, {"id": 257, "prop": "name", "attributes": {"content": "只是給你一個小小的忠告，如果你不高興聽，我當然不介意......", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#1$1"}, {"id": 258, "prop": "dialog", "attributes": {}}, {"id": 259, "prop": "playsound", "attributes": {"key": "$bullet_loading"}}, {"id": 260, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 261, "prop": "Character", "attributes": {"name": "avg_npc_357_1#6$1"}}, {"id": 262, "prop": "name", "attributes": {"content": "......", "name": "帕蒂亞"}, "figure_art": "avg_npc_357_1#6$1"}, {"id": 263, "prop": "Character", "attributes": {"name": "avg_npc_357_1#6$1"}}, {"id": 264, "prop": "name", "attributes": {"content": "菲亞梅塔，告訴我你是怎麼想的。", "name": "帕蒂亞"}, "figure_art": "avg_npc_357_1#6$1"}, {"id": 265, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#1$1"}}, {"id": 266, "prop": "name", "attributes": {"content": "什麼怎麼想的？我做我的工作......了結我要清算的帳，有什麼複雜的？", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#1$1"}, {"id": 267, "prop": "Character", "attributes": {"name": "avg_npc_357_1#6$1"}}, {"id": 268, "prop": "name", "attributes": {"content": "......八年前，你為什麼離開戍衛隊？", "name": "帕蒂亞"}, "figure_art": "avg_npc_357_1#6$1"}, {"id": 269, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#1$1"}}, {"id": 270, "prop": "name", "attributes": {"content": "......戍衛隊不能外派，要掛靠到公證所才行。這有什麼好問的？你關心這個？", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#1$1"}, {"id": 271, "prop": "Character", "attributes": {"name": "avg_npc_357_1#6$1"}}, {"id": 272, "prop": "name", "attributes": {"content": "............", "name": "帕蒂亞"}, "figure_art": "avg_npc_357_1#6$1"}, {"id": 273, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#1$1"}}, {"id": 274, "prop": "name", "attributes": {"content": "帕蒂亞，我不明白你在耿耿於懷些什麼。也許你在我身上寄託了些什麼，我不知道，關於你那些黎博利就應當如何如何的大道理。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#1$1"}, {"id": 275, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#7$1"}}, {"id": 276, "prop": "name", "attributes": {"content": "我一點都不在乎，帕蒂亞。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#7$1"}, {"id": 277, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#7$1"}}, {"id": 278, "prop": "name", "attributes": {"content": "我信任的隊友背叛了同伴，我的朋友因此受傷、因此被流放，甚至可能從此被叛徒盯上。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#7$1"}, {"id": 279, "prop": "name", "attributes": {"content": "我已經錯失了一次......我不能讓這件事再度發生。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#7$1"}, {"id": 280, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#7$1"}}, {"id": 281, "prop": "name", "attributes": {"content": "我要保護她們，就這麼簡單。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#7$1"}, {"id": 282, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#7$1"}}, {"id": 283, "prop": "name", "attributes": {"content": "如果這不符合你的什麼幻想，我也不會說抱歉。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#7$1"}, {"id": 284, "prop": "Character", "attributes": {"name": "avg_213_mostma_1#5$2"}}, {"id": 285, "prop": "name", "attributes": {"content": "......噗。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#5$2"}, {"id": 286, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#6$1"}}, {"id": 287, "prop": "name", "attributes": {"content": "......別得意，莫斯提馬。換了你，難道你不會這麼做？", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#6$1"}, {"id": 288, "prop": "Character", "attributes": {"name": "avg_213_mostma_1#7$2"}}, {"id": 289, "prop": "name", "attributes": {"content": "你說得對。", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#7$2"}, {"id": 290, "prop": "Character", "attributes": {"name": "avg_npc_357_1#6$1"}}, {"id": 291, "prop": "name", "attributes": {"content": "......你說得對，是我的幻想。", "name": "帕蒂亞"}, "figure_art": "avg_npc_357_1#6$1"}, {"id": 292, "prop": "Character", "attributes": {"name": "avg_npc_357_1#3$1"}}, {"id": 293, "prop": "name", "attributes": {"content": "幻想又怎樣？幻想也好，理想也罷，如果不是追尋曾經相信的東西，我又怎麼走到今天？", "name": "帕蒂亞"}, "figure_art": "avg_npc_357_1#3$1"}, {"id": 294, "prop": "Character", "attributes": {"name": "avg_npc_357_1#6$1"}}, {"id": 295, "prop": "name", "attributes": {"content": "也許把理想寄託在別人身上是我的天真，但我不後悔，菲亞梅塔。", "name": "帕蒂亞"}, "figure_art": "avg_npc_357_1#6$1"}, {"id": 296, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#8$1"}}, {"id": 297, "prop": "name", "attributes": {"content": "搞不懂你。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#8$1"}, {"id": 298, "prop": "Character", "attributes": {"name": "avg_npc_357_1#6$1"}}, {"id": 299, "prop": "name", "attributes": {"content": "所以現在，我也不會後退。就算我做的這些......在你看來只是“愚蠢又煩人”的把戲。這是我的任務，我就會完成到底。", "name": "帕蒂亞"}, "figure_art": "avg_npc_357_1#6$1"}, {"id": 300, "prop": "Character", "attributes": {"name": "avg_npc_357_1#3$1"}}, {"id": 301, "prop": "name", "attributes": {"content": "要我停下，就來打倒我。", "name": "帕蒂亞"}, "figure_art": "avg_npc_357_1#3$1"}, {"id": 302, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#8$1"}}, {"id": 303, "prop": "name", "attributes": {"content": "......", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#8$1"}, {"id": 304, "prop": "Character", "attributes": {"name": "avg_300_phenxi_1#7$1"}}, {"id": 305, "prop": "name", "attributes": {"content": "這樣很好，帕蒂亞。", "name": "菲亞梅塔"}, "figure_art": "avg_300_phenxi_1#7$1"}, {"id": 306, "prop": "Dialog", "attributes": {}}, {"id": 307, "prop": "playsound", "attributes": {"key": "$d_avg_gunload"}}, {"id": 308, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 309, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 310, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 311, "prop": "Dialog", "attributes": {}}, {"id": 312, "prop": "Character", "attributes": {}}, {"id": 313, "prop": "Image", "attributes": {}}, {"id": 314, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}