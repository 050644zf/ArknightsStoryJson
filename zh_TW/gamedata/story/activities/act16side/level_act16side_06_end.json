: 311, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 312, "prop": "name", "attributes": {"content": "銃......銃騎泰爾瓦多萊閣下，使節區受到襲擊！城內還有多處發生火災和爆炸！", "name": "戍衛隊"}}, {"id": 313, "prop": "character", "attributes": {"name": "avg_npc_358_1#1$1"}}, {"id": 314, "prop": "name", "attributes": {"content": "迷途者！聽到聖鐘長鳴，他們終於也坐不住了嗎！", "name": "教宗騎士"}, "figure_art": "avg_npc_358_1#1$1"}, {"id": 315, "prop": "character", "attributes": {}}, {"id": 316, "prop": "name", "attributes": {"content": "雖然之前已有銃騎閣下撥駐使節區，但......襲擊和爆炸開始之後，使節們情緒激化，強烈要求增派銃騎保護......", "name": "戍衛隊"}}, {"id": 317, "prop": "character", "attributes": {"name": "avg_npc_358_1#1$1"}}, {"id": 318, "prop": "name", "attributes": {"content": "我明白了。", "name": "教宗騎士"}, "figure_art": "avg_npc_358_1#1$1"}, {"id": 319, "prop": "dialog", "attributes": {}}, {"id": 320, "prop": "playsound", "attributes": {"key": "$d_gen_transmissionget"}}, {"id": 321, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 322, "prop": "character", "attributes": {"name": "avg_npc_358_1#1$1"}}, {"id": 323, "prop": "name", "attributes": {"content": "可惡，偏偏是這個時候！", "name": "教宗騎士"}, "figure_art": "avg_npc_358_1#1$1"}, {"id": 324, "prop": "dialog", "attributes": {}}, {"id": 325, "prop": "character", "attributes": {}}, {"id": 326, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 327, "prop": "character", "attributes": {"name": "avg_npc_361_1#1$1", "fadetime": 1.0, "block": "true"}}, {"id": 328, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 329, "prop": "character", "attributes": {"name": "avg_npc_358_1#1$1"}}, {"id": 330, "prop": "name", "attributes": {"content": "樞機薇爾麗芙！", "name": "教宗騎士"}, "figure_art": "avg_npc_358_1#1$1"}, {"id": 331, "prop": "character", "attributes": {"name": "avg_npc_361_1#1$1"}}, {"id": 332, "prop": "name", "attributes": {"content": "啟示石塔的聖鐘再度鳴響，這是屬於拉特蘭的至聖時刻，首屆“萬國峰會”與各國使節也同蒙恩典，我們都該為此喜悅。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#1$1"}, {"id": 333, "prop": "character", "attributes": {"name": "avg_npc_361_1#1$1"}}, {"id": 334, "prop": "name", "attributes": {"content": "然而異端殘黨卻趁機作亂，企圖擾亂會議，黯淡拉特蘭的榮光。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#1$1"}, {"id": 335, "prop": "name", "attributes": {"content": "銃騎泰爾瓦多萊閣下，奉教宗諭令，請您前往使節區，與諸銃騎一同保護各國使節，確保萬國峰會如期開幕。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#1$1"}, {"id": 336, "prop": "character", "attributes": {"name": "avg_npc_361_1#1$1"}}, {"id": 337, "prop": "name", "attributes": {"content": "我將與你同往。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#1$1"}, {"id": 338, "prop": "character", "attributes": {"name": "avg_npc_358_1#1$1"}}, {"id": 339, "prop": "name", "attributes": {"content": "好的。我說，樞機......", "name": "教宗騎士"}, "figure_art": "avg_npc_358_1#1$1"}, {"id": 340, "prop": "character", "attributes": {"name": "avg_npc_358_1#1$1"}}, {"id": 341, "prop": "name", "attributes": {"content": "你一定也感覺到了，從啟示石塔蔓延出的那股力量......", "name": "教宗騎士"}, "figure_art": "avg_npc_358_1#1$1"}, {"id": 342, "prop": "character", "attributes": {"name": "avg_npc_361_1#1$1"}}, {"id": 343, "prop": "name", "attributes": {"content": "請慎言，銃騎泰爾瓦多萊閣下。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#1$1"}, {"id": 344, "prop": "character", "attributes": {"name": "avg_npc_361_1#3$1"}}, {"id": 345, "prop": "name", "attributes": {"content": "那是榮光。", "name": "薇爾麗芙"}, "figure_art": "avg_npc_361_1#3$1"}, {"id": 346, "prop": "Dialog", "attributes": {}}, {"id": 347, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 348, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 349, "prop": "stopmusic", "attributes": {"fadetime": 3.0}}, {"id": 350, "prop": "Character", "attributes": {}}, {"id": 351, "prop": "Background", "attributes": {"image": "26_g7_laterano_ward", "screenadapt": "showall"}}, {"id": 352, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 353, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "