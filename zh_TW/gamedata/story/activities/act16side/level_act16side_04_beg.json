racter", "attributes": {"name": "avg_npc_351_1#8$1", "name2": "avg_4036_forcer_1#1$1", "focus": 1.0}}, {"id": 133, "prop": "name", "attributes": {"content": "啊，是你，你終於來了。", "name": "修士"}, "figure_art": "avg_npc_351_1#8$1"}, {"id": 134, "prop": "name", "attributes": {"content": "請進吧，不必客氣，她就在這裡。", "name": "修士"}, "figure_art": "avg_npc_351_1#8$1"}, {"id": 135, "prop": "dialog", "attributes": {}}, {"id": 136, "prop": "character", "attributes": {}}, {"id": 137, "prop": "playsound", "attributes": {"key": "$dooropenquite"}}, {"id": 138, "prop": "character", "attributes": {"name": "avg_npc_363_1#1$1", "fadetime": 1.5}}, {"id": 139, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 140, "prop": "musicvolume", "attributes": {"volume": 0.0, "fadetime": 1.0}}, {"id": 141, "prop": "character", "attributes": {"name": "avg_npc_351_1#8$1", "name2": "avg_4036_forcer_1#2$1", "focus": 2.0}}, {"id": 142, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 143, "prop": "name", "attributes": {"content": "？！", "name": "艾澤爾"}, "figure_art": "avg_4036_forcer_1#2$1"}, {"id": 144, "prop": "character", "attributes": {"name": "avg_npc_352_1#6$1"}}, {"id": 145, "prop": "name", "attributes": {"content": "是唱歌的棉花糖姐姐！", "name": "塞茜莉亞"}, "figure_art": "avg_npc_352_1#6$1"}, {"id": 146, "prop": "dialog", "attributes": {}}, {"id": 147, "prop": "character", "attributes": {}}, {"id": 148, "prop": "Character", "attributes": {"name": "avg_npc_351_1#1$1", "name2": "avg_4036_forcer_1#2$1", "focus": 1.0}}, {"id": 149, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 150, "prop": "playsound", "attributes": {"key": "$d_avg_cloakmovement"}}, {"id": 151, "prop": "characteraction", "attributes": {"name": "left", "type": "move", "xpos": 250.0, "power": 5.0, "times": 1.0, "fadetime": 1.5, "block": "false"}}, {"id": 152, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 153, "prop": 