me": "avg_npc_002", "focus": "r"}}, {"id": 274, "prop": "name", "attributes": {"content": "這裡沒有，那裡也沒有……", "name": "懶散的社區居民"}, "figure_art": "avg_npc_002"}, {"id": 275, "prop": "Dialog", "attributes": {}}, {"id": 276, "prop": "charslot", "attributes": {}}, {"id": 277, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 278, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4124_iana_1#1$1", "duration": 1.5}}, {"id": 279, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 280, "prop": "charslot", "attributes": {}}, {"id": 281, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_033", "focus": "l"}}, {"id": 282, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_002", "focus": "l"}}, {"id": 283, "prop": "name", "attributes": {"content": "見鬼了！她從哪冒出來的？", "name": "疑惑的社區居民"}, "figure_art": "avg_npc_033"}, {"id": 284, "prop": "name", "attributes": {"content": "這女人怎麼敢大搖大擺出現在路中間的？！", "name": "疑惑的社區居民"}, "figure_art": "avg_npc_033"}, {"id": 285, "prop": "Dialog", "attributes": {}}, {"id": 286, "prop": "charslot", "attributes": {}}, {"id": 287, "prop": "playsound", "attributes": {"key": "$d_avg_arrow_rain", "volume": 1.0, "channel": "1"}}, {"id": 288, "prop": "playsound", "attributes": {"key": "$bottlebroken", "volume": 1.0, "channel": "2"}}, {"id": 289, "prop": "playsound", "attributes": {"key": "$d_avg_magic_4", "volume": 1.0, "channel": "3"}}, {"id": 290, "prop": "CameraShake", "attributes": {"duration": 1.5, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 291, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 292, "prop": "CameraShake", "attributes": {"duration": 1.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 293, "prop": "PlaySound", "attributes": {"key": "$d_gen_explo_n"}}, {"id": 294, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 295, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 296, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 297, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 298, "prop": "bgeffect", "attributes": {"name": "$eb_signalInterference", "layer": 2.0}}, {"id": 299, "prop": "bgeffect", "attributes": {"name": "$eb_screen_disturb_01", "layer": 1.0}}, {"id": 300, "prop": "Background", "attributes": {"image": "bg_black", "screenadapt": "coverall"}}, {"id": 301, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 1.0, "block": "true"}}, {"id": 302, "prop": "name", "attributes": {"content": "弓、弩、發射器、施術單元……亂七八糟的武器齊齊對準路中間的雙子分身。"}}, {"id": 303, "prop": "name", "attributes": {"content": "就算是IANA本人，透過分身的雙眼看到如此熱烈的“歡迎”，也不免愣住了。"}}, {"id": 304, "prop": "name", "attributes": {"content": "各位，你們可真是……熱情得過頭啊。", "name": "IANA"}}, {"id": 305, "prop": "Dialog", "attributes": {}}, {"id": 306, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 307, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 308, "prop": "charslot", "attributes": {}}, {"id": 309, "prop": "bgeffect", "attributes": {}}, {"id": 310, "prop": "Background", "attributes": {"image": "bg_ltalley", "screenadapt": "coverall"}}, {"id": 311, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#1$1"}}, {"id": 312, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4125_rdoc_1#8$1"}}, {"id": 313, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 314, "prop": "PlayMusic", "attributes": {"intro": "$darkness01_intro", "key": "$darkness01_loop", "volume": 0.6}}, {"id": 315, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 316, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 317, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#7$1", "focus": "l"}}, {"id": 318, "prop": "name", "attributes": {"content": "弓、弩、炸彈、“魔法”……嘖嘖。", "name": "IANA"}, "figure_art": "avg_4124_iana_1#7$1"}, {"id": 319, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4125_rdoc_1#8$1", "focus": "r"}}, {"id": 320, "prop": "name", "attributes": {"content": "趁著他們的注意力都在投影被打後的去向上，趕快走吧，再等一下子，他們就該回過神了。", "name": "DOC"}, "figure_art": "avg_4125_rdoc_1#8$1"}, {"id": 321, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#5$1", "focus": "l"}}, {"id": 322, "prop": "name", "attributes": {"content": "或許之後我們應該聯絡ELA問問，到底發生了什麼事，我現在大腦一片混亂……", "name": "IANA"}, "figure_art": "avg_4124_iana_1#5$1"}, {"id": 323, "prop": "dialog", "attributes": {}}, {"id": 324, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 325, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 326, "prop": "charslot", "attributes": {}}, {"id": 327, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4124_iana_1#1$1"}}, {"id": 328, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 329, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 330, "prop": "playsound", "attributes": {"key": "$d_gen_transmissionget"}}, {"id": 331, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4124_iana_1#1$1", "focus": "none"}}, {"id": 332, "prop": "CharacterCutin", "attributes": {"widgetID": "2", "name": "avg_4123_ela_1#1$1", "style": "cutin", "fadestyle": "horiz_expand_center", "fadetime": 0.5, "width": 200.0, "block": "true"}}, {"id": 333, "prop": "name", "attributes": {"content": "不，我很確定不是雷內爾派的人，他的保全人員最近被舒瑞訓練得叫苦連天。", "name": "ELA"}}, {"id": 334, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4124_iana_1#1$1", "focus": "r"}}, {"id": 335, "prop": "name", "attributes": {"content": "你確定那傢伙的話可信嗎？", "name": "IANA"}, "figure_art": "avg_4124_iana_1#1$1"}, {"id": 336, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4124_iana_1#1$1", "focus": "none"}}, {"id": 337, "prop": "CharacterCutin", "attributes": {"widgetID": "2", "name": "avg_4123_ela_1#7$1", "style": "cutin", "fadestyle": "horiz_expand_center", "fadetime": 0.0, "width": 200.0, "block": "true"}}, {"id": 338, "prop": "name", "attributes": {"content": "確定。他今天一整天都沒機會發布這樣的命令。", "name": "ELA"}}, {"id": 339, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4124_iana_1#1$1", "focus": "r"}}, {"id": 340, "prop": "name", "attributes": {"content": "可這裡的人似乎真的篤定是我們搶走了他們的藥品？", "name": "IANA"}, "figure_art": "avg_4124_iana_1#1$1"}, {"id": 341, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4124_iana_1#1$1", "focus": "none"}}, {"id": 342, "prop": "CharacterCutin", "attributes": {"widgetID": "2", "name": "avg_4123_ela_1#1$1", "style": "cutin", "fadestyle": "horiz_expand_center", "fadetime": 0.0, "width": 200.0, "block": "true"}}, {"id": 343, "prop": "name", "attributes": {"content": "那些都是其次，當務之急是趕緊離開那片社區……", "name": "ELA"}}, {"id": 344, "prop": "CharacterCutin", "attributes": {"widgetID": "2", "name": "avg_4123_ela_1#7$1", "style": "cutin", "fadestyle": "horiz_expand_center", "fadetime": 0.0, "width": 200.0, "block": "true"}}, {"id": 345, "prop": "name", "attributes": {"content": "考慮到那些人的特殊能力，我不太推薦你們兩個人繼續行動，太危險了。你們需要我們的支援嗎？", "name": "ELA"}}, {"id": 346, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4124_iana_1#1$1", "focus": "r"}}, {"id": 347, "prop": "name", "attributes": {"content": "不用了，他們的源石技藝雖然厲害，但戰鬥起來全無章法。我知道該如何保全自身，更不用說還有卡提布在旁。", "name": "IANA"}, "figure_art": "avg_4124_iana_1#1$1"}, {"id": 348, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4124_iana_1#1$1", "focus": "none"}}, {"id": 349, "prop": "CharacterCutin", "attributes": {"widgetID": "2", "name": "avg_4123_ela_1#1$1", "style": "cutin", "fadestyle": "horiz_expand_center", "fadetime": 0.0, "width": 200.0, "block": "true"}}, {"id": 350, "prop": "name", "attributes": {"content": "……有事就聯絡我們。", "name": "ELA"}}, {"id": 351, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4124_iana_1#8$1", "focus": "r"}}, {"id": 352, "prop": "name", "attributes": {"content": "嗯，一定。", "name": "IANA"}, "figure_art": "avg_4124_iana_1#8$1"}, {"id": 353, "prop": "Dialog", "attributes": {}}, {"id": 354, "prop": "playsound", "attributes": {"key": "$transmission"}}, {"id": 355, "prop": "CharacterCutin", "attributes": {"widgetID": "2", "fadetime": 0.5, "block": "true"}}, {"id": 356, "prop": "Dialog", "attributes": {}}, {"id": 357, "prop": "charslot", "attributes": {}}, {"id": 358, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#8$1", "focus": "r"}}, {"id": 359, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4125_rdoc_1#1$1", "focus": "r"}}, {"id": 360, "prop": "name", "attributes": {"content": "邁耶，他們散得差不多了，我們該動身了。", "name": "DOC"}, "figure_art": "avg_4125_rdoc_1#1$1"}, {"id": 361, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#1$1", "focus": "l"}}, {"id": 362, "prop": "name", "attributes": {"content": "明白，走吧。", "name": "IANA"}, "figure_art": "avg_4124_iana_1#1$1"}, {"id": 363, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#7$1", "focus": "l"}}, {"id": 364, "prop": "name", "attributes": {"content": "我剛剛攀到高處觀察了一下子，對情況有了大致的瞭解。這裡似乎可以簡單地分為三個部分：外圍，居民區，以及最核心的那棟樓。", "name": "IANA"}, "figure_art": "avg_4124_iana_1#7$1"}, {"id": 365, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4125_rdoc_1#2$1", "focus": "r"}}, {"id": 366, "prop": "name", "attributes": {"content": "是啊，那棟樓周圍總有些帶“魔杖”的傢伙守著，想必是有些重要的人物或者東西在那裡。", "name": "DOC"}, "figure_art": "avg_4125_rdoc_1#2$1"}, {"id": 367, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#1$1", "focus": "l"}}, {"id": 368, "prop": "name", "attributes": {"content": "反正是要避開那裡的，是什麼不重要了。", "name": "IANA"}, "figure_art": "avg_4124_iana_1#1$1"}, {"id": 369, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4125_rdoc_1#9$1", "focus": "r"}}, {"id": 370, "prop": "name", "attributes": {"content": "那從居民區繞行？沒看到有人裝備武器，似乎是條安全的出路。", "name": "DOC"}, "figure_art": "avg_4125_rdoc_1#9$1"}, {"id": 371, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#7$1", "focus": "l"}}, {"id": 372, "prop": "name", "attributes": {"content": "或許更危險也說不定？", "name": "IANA"}, "figure_art": "avg_4124_iana_1#7$1"}, {"id": 373, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4125_rdoc_1#2$1", "focus": "r"}}, {"id": 374, "prop": "name", "attributes": {"content": "呃，有道理……這個世界已經不能用常理來推斷了。", "name": "DOC"}, "figure_art": "avg_4125_rdoc_1#2$1"}, {"id": 375, "prop": "Dialog", "attributes": {}}, {"id": 376, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 377, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 378, "prop": "charslot", "attributes": {}}, {"id": 379, "prop": "Background", "attributes": {"image": "bg_lmstreet_2", "screenadapt": "coverall"}}, {"id": 380, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 381, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 382, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 383, "prop": "name", "attributes": {"content": "嗚哇——嗚哇——", "name": "右邊窗內的聲音"}}, {"id": 384, "prop": "name", "attributes": {"content": "寶寶別哭了，爸爸唱歌給你聽喔。", "name": "右邊窗內的聲音"}}, {"id": 385, "prop": "name", "attributes": {"content": "疲憊的羽獸，你要飛向何方♪", "name": "右邊窗內的聲音"}}, {"id": 386, "prop": "name", "attributes": {"content": "才能觸摸到明天的風向♪", "name": "右邊窗內的聲音"}}, {"id": 387, "prop": "name", "attributes": {"content": "你不知道♪", "name": "右邊窗內的聲音"}}, {"id": 388, "prop": "name", "attributes": {"content": "你只能拼命揮動今日的翅膀♪", "name": "右邊窗內的聲音"}}, {"id": 389, "prop": "name", "attributes": {"content": "（小聲）終於睡著了，太好了……", "name": "右邊窗內的聲音"}}, {"id": 390, "prop": "Dialog", "attributes": {}}, {"id": 391, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 392, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#1$1", "duration": 1.5}}, {"id": 393, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4125_rdoc_1#1$1", "duration": 1.5}}, {"id": 394, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 395, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4125_rdoc_1#1$1", "focus": "r"}}, {"id": 396, "prop": "multiline", "attributes": {"name": "DOC", "content": "想不到在這裡能聽到這樣的歌。"}}, {"id": 397, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4125_rdoc_1#6$1", "focus": "r"}}, {"id": 398, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 50.0, "ystrength": 50.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 399, "prop": "multiline", "attributes": {"name": "DOC", "end": "true", "content": "嘶——！", "joined": "想不到在這裡能聽到這樣的歌。嘶——！"}}, {"id": 400, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#4$1", "focus": "l"}}, {"id": 401, "prop": "name", "attributes": {"content": "怎麼了？", "name": "IANA"}, "figure_art": "avg_4124_iana_1#4$1"}, {"id": 402, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4125_rdoc_1#13$1", "focus": "r"}}, {"id": 403, "prop": "name", "attributes": {"content": "剛剛有什麼從我腳邊跑過去了。好像是老鼠，不，更像是蝸牛……太黑了，看不清楚。", "name": "DOC"}, "figure_art": "avg_4125_rdoc_1#13$1"}, {"id": 404, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#1$1", "focus": "l"}}, {"id": 405, "prop": "name", "attributes": {"content": "這裡似乎是他們堆放垃圾的地方，怪不得沒什麼人來。", "name": "IANA"}, "figure_art": "avg_4124_iana_1#1$1"}, {"id": 406, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4125_rdoc_1#11$1", "focus": "r"}}, {"id": 407, "prop": "name", "attributes": {"content": "前面就是出去的路了，你該慶幸這個臭氣燻天的地方沒什麼人願意靠近。", "name": "DOC"}, "figure_art": "avg_4125_rdoc_1#11$1"}, {"id": 408, "prop": "Dialog", "attributes": {}}, {"id": 409, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 410, "prop": "Blocker", "attributes": {"a": 0.8, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 0.05, "block": "true"}}, {"id": 411, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 412, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#6$1", "focus": "l"}}, {"id": 413, "prop": "name", "attributes": {"content": "敵襲？！", "name": "IANA"}, "figure_art": "avg_4124_iana_1#6$1"}, {"id": 414, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4125_rdoc_1#13$1", "focus": "r"}}, {"id": 415, "prop": "name", "attributes": {"content": "不，只是從那邊的窗子裡透出來的光。", "name": "DOC"}, "figure_art": "avg_4125_rdoc_1#13$1"}, {"id": 416, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#10$1", "focus": "l"}}, {"id": 417, "prop": "name", "attributes": {"content": "他們為什麼要在自己家裡做這種事情？", "name": "IANA"}, "figure_art": "avg_4124_iana_1#10$1"}, {"id": 418, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#10$1", "focus": "none"}}, {"id": 419, "prop": "name", "attributes": {"content": "厲害，親愛的！我半天都搞不定這隻亂跑的羽獸。", "name": "左邊窗內的聲音"}}, {"id": 420, "prop": "name", "attributes": {"content": "現在它昏過去了，我們動手吧。", "name": "左邊窗內的聲音"}}, {"id": 421, "prop": "name", "attributes": {"content": "哦，不不不，它又要醒來了，早就說了這種源石技藝根本不適合！", "name": "左邊窗內的聲音"}}, {"id": 422, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 423, "prop": "name", "attributes": {"content": "（響亮的羽獸鳴叫）", "name": "左邊窗內的聲音"}}, {"id": 424, "prop": "name", "attributes": {"content": "哦，不不不，她又要醒來了！", "name": "右邊窗內的聲音"}}, {"id": 425, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 50.0, "ystrength": 50.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 426, "prop": "name", "attributes": {"content": "（非常響亮的嬰兒啼哭）", "name": "右邊窗內的聲音"}}, {"id": 427, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#8$1", "focus": "l"}}, {"id": 428, "prop": "name", "attributes": {"content": "噗……", "name": "IANA"}, "figure_art": "avg_4124_iana_1#8$1"}, {"id": 429, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4125_rdoc_1#10$1", "focus": "r"}}, {"id": 430, "prop": "name", "attributes": {"content": "……看來這裡的源石技藝也不是萬能的。", "name": "DOC"}, "figure_art": "avg_4125_rdoc_1#10$1"}, {"id": 431, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#8$1", "focus": "l"}}, {"id": 432, "prop": "name", "attributes": {"content": "看外牆上的彩色塑膠板，只有真把這裡當成家的人，才會有心情做這種沒有實用價值的裝飾。", "name": "IANA"}, "figure_art": "avg_4124_iana_1#8$1"}, {"id": 433, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4125_rdoc_1#10$1", "focus": "r"}}, {"id": 434, "prop": "name", "attributes": {"content": "這邊的塗鴉也一樣，有不少風景、人像和純裝飾性的東西，看得出來不是隨手塗的。", "name": "DOC"}, "figure_art": "avg_4125_rdoc_1#10$1"}, {"id": 435, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4125_rdoc_1#12$1", "focus": "r"}}, {"id": 436, "prop": "name", "attributes": {"content": "我覺得這水準可不低，每一幅裡面都有個故事……", "name": "DOC"}, "figure_art": "avg_4125_rdoc_1#12$1"}, {"id": 437, "prop": "Dialog", "attributes": {}}, {"id": 438, "prop": "charslot", "attributes": {}}, {"id": 439, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 440, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1212_1#1$1", "duration": 1.5}}, {"id": 441, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 442, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1212_1#4$1"}}, {"id": 443, "prop": "name", "attributes": {"content": "你們、你們怎麼在這裡？！", "name": "特克諾"}, "figure_art": "avg_npc_1212_1#4$1"}, {"id": 444, "prop": "Dialog", "attributes": {}}, {"id": 445, "prop": "charslot", "attributes": {}}, {"id": 446, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#8$1", "focus": "r"}}, {"id": 447, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4125_rdoc_1#13$1", "focus": "r"}}, {"id": 448, "prop": "name", "attributes": {"content": "呃，小朋友，我們……", "name": "DOC"}, "figure_art": "avg_4125_rdoc_1#13$1"}, {"id": 449, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#10$1", "focus": "l"}}, {"id": 450, "prop": "name", "attributes": {"content": "你先冷靜下，那位先生說的事情不是我們做的……這應該是場誤會。", "name": "IANA"}, "figure_art": "avg_4124_iana_1#10$1"}, {"id": 451, "prop": "Dialog", "attributes": {}}, {"id": 452, "prop": "charslot", "attributes": {}}, {"id": 453, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1212_1#6$1"}}, {"id": 454, "prop": "name", "attributes": {"content": "……我、我也不知道，你們救了我，但是……", "name": "特克諾"}, "figure_art": "avg_npc_1212_1#6$1"}, {"id": 455, "prop": "Dialog", "attributes": {}}, {"id": 456, "prop": "charslot", "attributes": {}}, {"id": 457, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#10$1", "focus": "r"}}, {"id": 458, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4125_rdoc_1#7$1", "focus": "r"}}, {"id": 459, "prop": "name", "attributes": {"content": "我們沒有任何惡意……你清楚的，小朋友。", "name": "DOC"}, "figure_art": "avg_4125_rdoc_1#7$1"}, {"id": 460, "prop": "Dialog", "attributes": {}}, {"id": 461, "prop": "charslot", "attributes": {}}, {"id": 462, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1212_1#6$1"}}, {"id": 463, "prop": "name", "attributes": {"content": "……", "name": "特克諾"}, "figure_art": "avg_npc_1212_1#6$1"}, {"id": 464, "prop": "name", "attributes": {"content": "離開這條巷子後向右轉。雖然左邊看起來沒什麼人，但是老爹心煩了會去那裡抽煙，你們有可能會碰上。", "name": "特克諾"}, "figure_art": "avg_npc_1212_1#6$1"}, {"id": 465, "prop": "name", "attributes": {"content": "我只是來丟垃圾，什麼都沒看見。", "name": "特克諾"}, "figure_art": "avg_npc_1212_1#6$1"}, {"id": 466, "prop": "Dialog", "attributes": {}}, {"id": 467, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 468, "prop": "playsound", "attributes": {"key": "$rungeneral"}}, {"id": 469, "prop": "charslot", "attributes": {"duration": 1.5}}, {"id": 470, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 471, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#10$1", "focus": "r"}}, {"id": 472, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4125_rdoc_1#6$1", "focus": "r"}}, {"id": 473, "prop": "name", "attributes": {"content": "你……", "name": "DOC"}, "figure_art": "avg_4125_rdoc_1#6$1"}, {"id": 474, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4124_iana_1#10$1", "focus": "l"}}, {"id": 475, "prop": "name", "attributes": {"content": "（小聲）卡提布，我們該走了。", "name": "IANA"}, "figure_art": "avg_4124_iana_1#10$1"}, {"id": 476, "prop": "Dialog", "attributes": {}}, {"id": 477, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 478, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 479, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 480, "prop": "charslot", "attributes": {}}, {"id": 481, "prop": "Image", "attributes": {}}, {"id": 482, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}