士"}, "figure_art": "avg_npc_225"}, {"id": 375, "prop": "Character", "attributes": {"name": "avg_npc_225", "name2": "avg_npc_120#2", "focus": 2.0}}, {"id": 376, "prop": "name", "attributes": {"content": "  就算是獨立騎士，一路打比賽到四強，應該也存了不少錢吧？你的錢都去哪了？", "name": "老騎士"}, "figure_art": "avg_npc_120#2"}, {"id": 377, "prop": "Character", "attributes": {"name": "avg_npc_225", "name2": "avg_npc_120#2", "focus": 1.0}}, {"id": 378, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 20.0, "randomness": 80.0, "fadeout": "true", "block": "false"}}, {"id": 379, "prop": "name", "attributes": {"content": "  ......", "name": "逐魘騎士"}, "figure_art": "avg_npc_225"}, {"id": 380, "prop": "Character", "attributes": {"name": "avg_npc_225", "name2": "avg_npc_120#2", "focus": 2.0}}, {"id": 381, "prop": "name", "attributes": {"content": "  別亂動，傷口很深。", "name": "老騎士"}, "figure_art": "avg_npc_120#2"}, {"id": 382, "prop": "Character", "attributes": {"name": "avg_npc_225", "name2": "avg_npc_120", "focus": 2.0}}, {"id": 383, "prop": "name", "attributes": {"content": "  ......你要去哪？", "name": "老騎士"}, "figure_art": "avg_npc_120"}, {"id": 384, "prop": "Character", "attributes": {"name": "avg_npc_225", "name2": "avg_npc_120", "focus": 1.0}}, {"id": 385, "prop": "name", "attributes": {"content": "  ......", "name": "逐魘騎士"}, "figure_art": "avg_npc_225"}, {"id": 386, "prop": "Character", "attributes": {"name": "avg_npc_225", "name2": "avg_npc_120#2", "focus": 2.0}}, {"id": 387, "prop": "name", "attributes": {"content": "  喂，慢著，你要去哪？", "name": "老騎士"}, "figure_art": "avg_npc_120#2"}, {"id": 388, "prop": "Character", "attributes": {"name": "avg_npc_225", "name2": "avg_npc_120#2", "focus": 1.0}}, {"id": 389, "prop": "name", "attributes": {"content": "  ......離開。", "name": "逐魘騎士"}, "figure_art": "avg_npc_225"}, {"id": 390, "prop": "name", "attributes": {"content": "  金色的天馬，血色的米諾斯人，我......收獲頗豐。", "name": "逐魘騎士"}, "figure_art": "avg_npc_225"}, {"id": 391, "prop": "Character", "attributes": {"name": "avg_npc_225", "name2": "avg_npc_120#3", "focus": 2.0}}, {"id": 392, "prop": "name", "attributes": {"content": "  ......你不甘心嗎？", "name": "老騎士"}, "figure_art": "avg_npc_120#3"}, {"id": 393, "prop": "Character", "attributes": {"name": "avg_npc_225", "name2": "avg_npc_120#3", "focus": 1.0}}, {"id": 394, "prop": "name", "attributes": {"content": "  ......不，我失敗了。", "name": "逐魘騎士"}, "figure_art": "avg_npc_225"}, {"id": 395, "prop": "name", "attributes": {"content": "  然後，我不再恐懼失敗。", "name": "逐魘騎士"}, "figure_art": "avg_npc_225"}, {"id": 396, "prop": "name", "attributes": {"content": "  不再畏懼退縮。", "name": "逐魘騎士"}, "figure_art": "avg_npc_225"}, {"id": 397, "prop": "name", "attributes": {"content": "  不再畏懼......讚美弱小。", "name": "逐魘騎士"}, "figure_art": "avg_npc_225"}, {"id": 398, "prop": "name", "attributes": {"content": "  ......但我仍有欠缺......我還是得，走完天途。", "name": "逐魘騎士"}, "figure_art": "avg_npc_225"}, {"id": 399, "prop": "Character", "attributes": {"name": "avg_npc_225", "name2": "avg_npc_120#3", "focus": 2.0}}, {"id": 400, "prop": "name", "attributes": {"content": "  天途天途的......你的目的地到底是哪？", "name": "老騎士"}, "figure_art": "avg_npc_120#3"}, {"id": 401, "prop": "name", "attributes": {"content": "  就算在古代，也沒有一條天途走幾年的習俗吧？", "name": "老騎士"}, "figure_art": "avg_npc_120#3"}, {"id": 402, "prop": "Character", "attributes": {"name": "avg_npc_225", "name2": "avg_npc_120#3", "focus": 1.0}}, {"id": 403, "prop": "name", "attributes": {"content": "  北方。", "name": "逐魘騎士"}, "figure_art": "avg_npc_225"}, {"id": 404, "prop": "name", "attributes": {"content": "  在遙遠的北方......與先祖消失之地呼應的北方。", "name": "逐魘騎士"}, "figure_art": "avg_npc_225"}, {"id": 405, "prop": "Character", "attributes": {"name": "avg_npc_225", "name2": "avg_npc_120#2", "focus": 2.0}}, {"id": 406, "prop": "name", "attributes": {"content": "  ......你走到那裡去，然後呢？", "name": "老騎士"}, "figure_art": "avg_npc_120#2"}, {"id": 407, "prop": "name", "attributes": {"content": "  你還打算回來嗎？", "name": "老騎士"}, "figure_art": "avg_npc_120#2"}, {"id": 408, "prop": "Character", "attributes": {"name": "avg_npc_225", "name2": "avg_npc_120#2", "focus": 1.0}}, {"id": 409, "prop": "name", "attributes": {"content": "  ......", "name": "逐魘騎士"}, "figure_art": "avg_npc_225"}, {"id": 410, "prop": "Character", "attributes": {"name": "avg_npc_225", "name2": "avg_npc_120#3", "focus": 2.0}}, {"id": 411, "prop": "name", "attributes": {"content": "  你......我以為你只是尋找一些自己缺失的東西。", "name": "老騎士"}, "figure_art": "avg_npc_120#3"}, {"id": 412, "prop": "name", "attributes": {"content": "  結果......你卻在尋死嗎？", "name": "老騎士"}, "figure_art": "avg_npc_120#3"}, {"id": 413, "prop": "Dialog", "attributes": {}}, {"id": 414, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 415, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 416, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 417, "prop": "Character", "attributes": {}}, {"id": 418, "prop": "Image", "attributes": {}}, {"id": 419, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}