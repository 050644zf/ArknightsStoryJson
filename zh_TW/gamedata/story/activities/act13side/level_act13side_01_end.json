 153, "prop": "Character", "attributes": {"name": "avg_npc_061#2", "name2": "avg_npc_101", "focus": 1.0}}, {"id": 154, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 155, "prop": "name", "attributes": {"content": "  欸......只是偶然，偶然而已，總是這麼說怪讓人不好意思的......", "name": "瑪莉婭"}, "figure_art": "avg_npc_061#2"}, {"id": 156, "prop": "Character", "attributes": {"name": "avg_npc_107#2"}}, {"id": 157, "prop": "name", "attributes": {"content": "  ......唔。今晚的比賽，似乎也有“鏽銅”奧爾默·英格拉參與......", "name": "光頭馬丁"}, "figure_art": "avg_npc_107#2"}, {"id": 158, "prop": "Character", "attributes": {"name": "avg_npc_120", "name2": "avg_npc_061#2", "focus": 1.0}}, {"id": 159, "prop": "name", "attributes": {"content": "  哈，都是熟人啊，瑪莉婭——", "name": "老騎士"}, "figure_art": "avg_npc_120"}, {"id": 160, "prop": "Character", "attributes": {"name": "avg_npc_120", "name2": "avg_npc_101", "focus": 2.0}}, {"id": 161, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 162, "prop": "name", "attributes": {"content": "  ——你少說兩句。", "name": "老工匠"}, "figure_art": "avg_npc_101"}, {"id": 163, "prop": "Character", "attributes": {"name": "avg_npc_061", "name2": "avg_npc_101", "focus": 1.0}}, {"id": 164, "prop": "name", "attributes": {"content": "  沒事的啦，科瓦爾師傅。", "name": "瑪莉婭"}, "figure_art": "avg_npc_061"}, {"id": 165, "prop": "Character", "attributes": {"name": "avg_npc_061#2", "name2": "avg_npc_101", "focus": 1.0}}, {"id": 166, "prop": "name", "attributes": {"content": "  我已經放棄成為競技騎士的想法了，那實在不適合我。", "name": "瑪莉婭"}, "figure_art": "avg_npc_061#2"}, {"id": 167, "prop": "Character", "attributes": {"name": "avg_npc_120", "name2": "avg_npc_061#2", "focus": 1.0}}, {"id": 168, "prop": "name", "attributes": {"content": "  就是！成為自己的方式有那麼多，沒必要被迫做什麼選擇！這是老年人的忠告！", "name": "老騎士"}, "figure_art": "avg_npc_120"}, {"id": 169, "prop": "name", "attributes": {"content": "  再說，你的表現已經很亮眼啦，敬你一杯！", "name": "老騎士"}, "figure_art": "avg_npc_120"}, {"id": 170, "prop": "Character", "attributes": {"name": "avg_npc_061#2", "name2": "avg_npc_101", "focus": 2.0}}, {"id": 171, "prop": "name", "attributes": {"content": "  說起來，瑪嘉烈的那身盔甲是不是還沒有做最終調試？", "name": "老工匠"}, "figure_art": "avg_npc_101"}, {"id": 172, "prop": "name", "attributes": {"content": "  她之前穿的那一身雖然做工是不錯，但怎麼看也不適合瑪嘉烈這樣勇猛的庫蘭塔啊。", "name": "老工匠"}, "figure_art": "avg_npc_101"}, {"id": 173, "prop": "Character", "attributes": {"name": "avg_npc_061#2", "name2": "avg_npc_101", "focus": 1.0}}, {"id": 174, "prop": "name", "attributes": {"content": "  啊......我已經在著手調整了，還需要點時間。", "name": "瑪莉婭"}, "figure_art": "avg_npc_061#2"}, {"id": 175, "prop": "name", "attributes": {"content": "  還有姐姐的武器......", "name": "瑪莉婭"}, "figure_art": "avg_npc_061#2"}, {"id": 176, "prop": "Character", "attributes": {"name": "avg_npc_107", "name2": "avg_npc_061#2", "focus": 1.0}}, {"id": 177, "prop": "name", "attributes": {"content": "  瑪嘉烈剛參加騎士競技時，用的是一把戰錘。再後來，她改用一把騎士長劍，光芒在她的劍刃上縈繞。", "name": "光頭馬丁"}, "figure_art": "avg_npc_107"}, {"id": 178, "prop": "name", "attributes": {"content": "  現在——是一柄劍槍。", "name": "光頭馬丁"}, "figure_art": "avg_npc_107"}, {"id": 179, "prop": "Character", "attributes": {"name": "avg_npc_101"}}, {"id": 180, "prop": "name", "attributes": {"content": "  哈！米諾斯的D32夾鋼鍛造工藝，極佳的源石技藝傳導性！", "name": "老工匠"}, "figure_art": "avg_npc_101"}, {"id": 181, "prop": "name", "attributes": {"content": "  真懷念啊，那時候瑪嘉烈來找我給她換一把趁手的劍——那可是臨光老爺的孫女第一次開口讓我幫忙——", "name": "老工匠"}, "figure_art": "avg_npc_101"}, {"id": 182, "prop": "Character", "attributes": {"name": "avg_npc_120#2", "name2": "avg_npc_101", "focus": 1.0}}, {"id": 183, "prop": "name", "attributes": {"content": "  別懷舊了，科瓦爾，耀騎士下周就要登場了，你們到底有沒有在幫她！？", "name": "老騎士"}, "figure_art": "avg_npc_120#2"}, {"id": 184, "prop": "Character", "attributes": {"name": "avg_npc_120", "name2": "avg_npc_101#3", "focus": 2.0}}, {"id": 185, "prop": "name", "attributes": {"content": "  啊啊？你以為我是你嗎？整天只知道喝酒，遊手好閒？", "name": "老工匠"}, "figure_art": "avg_npc_101#3"}, {"id": 186, "prop": "Character", "attributes": {"name": "avg_npc_120", "name2": "avg_npc_101", "focus": 0.0}}, {"id": 187, "prop": "dialog", "attributes": {}}, {"id": 188, "prop": "PlaySound", "attributes": {"key": "$fightgeneral"}}, {"id": 189, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 10.0, "ystrength": 12.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 190, "prop": "PlaySound", "attributes": {"key": "$fightgeneral"}}, {"id": 191, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 10.0, "ystrength": 12.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 192, "prop": "Character", "attributes": {"name": "avg_npc_107#2"}}, {"id": 193, "prop": "name", "attributes": {"content": "  （鏽銅騎士參加的是......奪旗賽......？為什麼沸血騎士團會浪費一個精英騎士參加這種吃力不討好的賽制......）", "name": "光頭馬丁"}, "figure_art": "avg_npc_107#2"}, {"id": 194, "prop": "name", "attributes": {"content": "  （鏽銅的對手是......唔，都是些小有名氣的騎士團......）", "name": "光頭馬丁"}, "figure_art": "avg_npc_107#2"}, {"id": 195, "prop": "Character", "attributes": {"name": "avg_npc_107#3"}}, {"id": 196, "prop": "name", "attributes": {"content": "  （......慢著，有感染者騎士......）", "name": "光頭馬丁"}, "figure_art": "avg_npc_107#3"}, {"id": 197, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 198, "prop": "Dialog", "attributes": {}}, {"id": 199, "prop": "Character", "attributes": {}}, {"id": 200, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 201, "prop": "Background", "attributes": {"image": "bg_23_G01", "screenadapt": "coverall"}}, {"id": 202, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 203, "prop": "playMusic", "attributes": {"intro": "$nervous_intro", "key": "$nervous_loop", "volume": 0.4}}, {"id": 204, "prop": "Character", "attributes": {"name": "avg_496_wdmane_1", "blackstart": 0.4, "blackend": 0.9, "fadetime": 1.0, "block": "true"}}, {"id": 205, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 206, "prop": "name", "attributes": {"content": "  特錦賽正賽，嗯哼。", "name": "？？？"}, "figure_art": "avg_496_wdmane_1"}, {"id": 207, "prop": "name", "attributes": {"content": "  在成為感染者的時候，你想過會有這麼一天嗎？", "name": "？？？"}, "figure_art": "avg_496_wdmane_1"}, {"id": 208, "prop": "name", "attributes": {"content": "  你想過能站在這個賽場上，為自己贏取那感覺幾輩子都賺不到的財富嗎？", "name": "？？？"}, "figure_art": "avg_496_wdmane_1"}, {"id": 209, "prop": "dialog", "attributes": {}}, {"id": 210, "prop": "Character", "attributes": {"name": "avg_npc_220"}}, {"id": 211, "prop": "name", "attributes": {"content": "  我知道......我知道。", "name": "感染者騎士"}, "figure_art": "avg_npc_220"}, {"id": 212, "prop": "name", "attributes": {"content": "  加入紅松騎士團是我的榮幸，野鬃。", "name": "感染者騎士"}, "figure_art": "avg_npc_220"}, {"id": 213, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_496_wdmane_1", "blackstart2": 0.4, "blackend2": 0.9, "focus": 2.0}}, {"id": 214, "prop": "name", "attributes": {"content": "  哈，喊我名字就好。", "name": "？？？"}, "figure_art": "avg_496_wdmane_1"}, {"id": 215, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_496_wdmane_1", "blackstart2": 0.4, "blackend2": 0.9, "focus": 1.0}}, {"id": 216, "prop": "name", "attributes": {"content": "  好！等我拿到獎金，請你喝酒，艾沃娜。", "name": "感染者騎士"}, "figure_art": "avg_npc_220"}, {"id": 217, "prop": "dialog", "attributes": {}}, {"id": 218, "prop": "character", "attributes": {}}, {"id": 219, "prop": "character", "attributes": {"name": "avg_496_wdmane_1", "fadetime": 1.0}}, {"id": 220, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 221, "prop": "name", "attributes": {"content": "  好啊，除了灰毫根本沒人陪我喝酒，我正無聊得很——", "name": "艾沃娜"}, "figure_art": "avg_496_wdmane_1"}, {"id": 222, "prop": "name", "attributes": {"content": "  ——奪旗戰的規則還記得嗎？", "name": "艾沃娜"}, "figure_art": "avg_496_wdmane_1"}, {"id": 223, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_496_wdmane_1", "focus": 1.0}}, {"id": 224, "prop": "name", "attributes": {"content": "  記得，儘量待在得分線裡，儘量避免直接衝突——", "name": "感染者騎士"}, "figure_art": "avg_npc_220"}, {"id": 225, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_496_wdmane_1", "focus": 2.0}}, {"id": 226, "prop": "name", "attributes": {"content": "  欸，那是索娜教你的那套——要我說，打爛那群貴族騎士的盔甲，你就是冠軍啦。", "name": "艾沃娜"}, "figure_art": "avg_496_wdmane_1"}, {"id": 227, "prop": "name", "attributes": {"content": "  有人搶分，你就先把人解決了，不是很簡單嗎？", "name": "艾沃娜"}, "figure_art": "avg_496_wdmane_1"}, {"id": 228, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_496_wdmane_1", "focus": 1.0}}, {"id": 229, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 230, "prop": "name", "attributes": {"content": "  哈、哈哈哈......如果我能做到的話。", "name": "感染者騎士"}, "figure_art": "avg_npc_220"}, {"id": 231, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_496_wdmane_1#10", "focus": 2.0}}, {"id": 232, "prop": "name", "attributes": {"content": "  自信點。不好好鬧上一場，他們是不會看得起你的。", "name": "艾沃娜"}, "figure_art": "avg_496_wdmane_1#10"}, {"id": 233, "prop": "name", "attributes": {"content": "  想讓別人仰視你，很簡單，把他們揍趴下，對吧？", "name": "艾沃娜"}, "figure_art": "avg_496_wdmane_1#10"}, {"id": 234, "prop": "name", "attributes": {"content": "  不過好像有人是衝你來的，哈，那傢伙還沒在灰毫那邊吃夠苦頭？", "name": "艾沃娜"}, "figure_art": "avg_496_wdmane_1#10"}, {"id": 235, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_496_wdmane_1#10", "focus": 1.0}}, {"id": 236, "prop": "name", "attributes": {"content": "  奧爾默·英格拉......他是為了報復感染者才來到這裡的嗎？", "name": "感染者騎士"}, "figure_art": "avg_npc_220"}, {"id": 237, "prop": "name", "attributes": {"content": "  真是心胸狹隘。", "name": "感染者騎士"}, "figure_art": "avg_npc_220"}, {"id": 238, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_496_wdmane_1#9", "focus": 2.0}}, {"id": 239, "prop": "name", "attributes": {"content": "  貴族子弟，啐。", "name": "艾沃娜"}, "figure_art": "avg_496_wdmane_1#9"}, {"id": 240, "prop": "name", "attributes": {"content": "  看來灰毫那一仗挫敗他的自尊心了，虛有其表的傢伙根本不該站在賽場上。", "name": "艾沃娜"}, "figure_art": "avg_496_wdmane_1#9"}, {"id": 241, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_496_wdmane_1#8", "focus": 2.0}}, {"id": 242, "prop": "name", "attributes": {"content": "  啊——手癢。不然找個機會私下把他揍一頓得了。", "name": "艾沃娜"}, "figure_art": "avg_496_wdmane_1#8"}, {"id": 243, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_496_wdmane_1#8", "focus": 1.0}}, {"id": 244, "prop": "name", "attributes": {"content": "  ......", "name": "感染者騎士"}, "figure_art": "avg_npc_220"}, {"id": 245, "prop": "Dialog", "attributes": {}}, {"id": 246, "prop": "Character", "attributes": {}}, {"id": 247, "prop": "Character", "attributes": {"name": "avg_npc_104", "fadetime": 1.0, "block": "true"}}, {"id": 248, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 249, "prop": "name", "attributes": {"content": "  ......", "name": "鏽銅騎士"}, "figure_art": "avg_npc_104"}, {"id": 250, "prop": "dialog", "attributes": {}}, {"id": 251, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_496_wdmane_1"}}, {"id": 252, "prop": "name", "attributes": {"content": "  現在——有請各騎士入場——", "name": "廣播裡的聲音"}}, {"id": 253, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_496_wdmane_1", "focus": 2.0}}, {"id": 254, "prop": "name", "attributes": {"content": "  上吧。", "name": "艾沃娜"}, "figure_art": "avg_496_wdmane_1"}, {"id": 255, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_496_wdmane_1", "focus": 1.0}}, {"id": 256, "prop": "name", "attributes": {"content": "  ......好！", "name": "感染者騎士"}, "figure_art": "avg_npc_220"}, {"id": 257, 