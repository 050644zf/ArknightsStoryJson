"name2": "avg_npc_122", "focus": 2.0}}, {"id": 290, "prop": "name", "attributes": {"content": "  啊哈哈，沒什麼，走吧。", "name": "索娜"}, "figure_art": "avg_npc_122"}, {"id": 291, "prop": "name", "attributes": {"content": "  去見見紅松騎士團的新成員們。", "name": "索娜"}, "figure_art": "avg_npc_122"}, {"id": 292, "prop": "dialog", "attributes": {}}, {"id": 293, "prop": "character", "attributes": {}}, {"id": 294, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 295, "prop": "Background", "attributes": {"image": "bg_23_G10", "screenadapt": "coverall"}}, {"id": 296, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 297, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_npc_221", "focus": 1.0}}, {"id": 298, "prop": "name", "attributes": {"content": "  ......這裡，幾乎都是感染者。", "name": "滄桑的騎士"}, "figure_art": "avg_npc_220"}, {"id": 299, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_npc_221", "focus": 2.0}}, {"id": 300, "prop": "name", "attributes": {"content": "  會被國民院盯上的吧？", "name": "沙啞的騎士"}, "figure_art": "avg_npc_221"}, {"id": 301, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_npc_221", "focus": 1.0}}, {"id": 302, "prop": "name", "attributes": {"content": "  ......被國民院盯上好歹光明正大，大不了多花點錢，解決法律問題的最好辦法就是花錢。", "name": "滄桑的騎士"}, "figure_art": "avg_npc_220"}, {"id": 303, "prop": "name", "attributes": {"content": "  可再這樣下去......無胄盟會袖手旁觀嗎？", "name": "滄桑的騎士"}, "figure_art": "avg_npc_220"}, {"id": 304, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_npc_221", "focus": 2.0}}, {"id": 305, "prop": "name", "attributes": {"content": "  無胄盟？那種東西真的存在嗎？", "name": "沙啞的騎士"}, "figure_art": "avg_npc_221"}, {"id": 306, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_npc_221", "focus": 1.0}}, {"id": 307, "prop": "name", "attributes": {"content": "  別把他們當都市傳說比較好。", "name": "滄桑的騎士"}, "figure_art": "avg_npc_220"}, {"id": 308, "prop": "name", "attributes": {"content": "  唔，那邊正走過來的，她們就是紅松的騎士們吧......", "name": "滄桑的騎士"}, "figure_art": "avg_npc_220"}, {"id": 309, "prop": "name", "attributes": {"content": "  唉，乍一眼看上去，還不過是一群孩子罷了。", "name": "滄桑的騎士"}, "figure_art": "avg_npc_220"}, {"id": 310, "prop": "name", "attributes": {"content": "  但......也許有些事情，也只有年輕人去做。", "name": "滄桑的騎士"}, "figure_art": "avg_npc_220"}, {"id": 311, "prop": "dialog", "attributes": {}}, {"id": 312, "prop": "character", "attributes": {}}, {"id": 313, "prop": "Character", "attributes": {"name": "avg_npc_122", "fadetime": 1.0, "block": "true"}}, {"id": 314, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 315, "prop": "name", "attributes": {"content": "  “焰尾”索娜。", "name": "沙啞的騎士"}, "figure_art": "avg_npc_122"}, {"id": 316, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 317, "prop": "dialog", "attributes": {}}, {"id": 318, "prop": "Character", "attributes": {"name": "avg_npc_123", "fadetime": 1.0, "block": "true"}}, {"id": 319, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 320, "prop": "name", "attributes": {"content": "  “灰毫”格蕾納蒂。", "name": "沙啞的騎士"}, "figure_art": "avg_npc_123"}, {"id": 321, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 322, "prop": "dialog", "attributes": {}}, {"id": 323, "prop": "Character", "attributes": {"name": "avg_430_fartth_1", "fadetime": 1.0, "block": "true"}}, {"id": 324, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 325, "prop": "name", "attributes": {"content": "  “遠牙”查絲汀娜。", "name": "沙啞的騎士"}, "figure_art": "avg_430_fartth_1"}, {"id": 326, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 327, "prop": "dialog", "attributes": {}}, {"id": 328, "prop": "Character", "attributes": {"name": "avg_4000_jnight_1", "fadetime": 1.0, "block": "true"}}, {"id": 329, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 330, "prop": "name", "attributes": {"content": "  （響亮的滴滴聲）", "name": "“正義騎士號”"}, "figure_art": "avg_4000_jnight_1"}, {"id": 331, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 332, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_npc_221", "focus": 2.0}}, {"id": 333, "prop": "name", "attributes": {"content": "  唔。還有一位庫蘭塔似乎不在這裡......", "name": "沙啞的騎士"}, "figure_art": "avg_npc_221"}, {"id": 334, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_npc_221", "focus": 1.0}}, {"id": 335, "prop": "name", "attributes": {"content": "  ......我們加入這些年輕人的計畫，就能活下去嗎？活下去之後呢？下個月？明年？", "name": "滄桑的騎士"}, "figure_art": "avg_npc_220"}, {"id": 336, "prop": "Character", "attributes": {"name": "avg_npc_220", "name2": "avg_npc_221", "focus": 2.0}}, {"id": 337, "prop": "name", "attributes": {"content": "  感染者常說一件事，老朋友，事在人為。", "name": "沙啞的騎士"}, "figure_art": "avg_npc_221"}, {"id": 338, "prop": "name", "attributes": {"content": "  我們得了礦石病，有不少人選擇聽天由命得了......我們的生命註定短暫，而且隨時是個危險。", "name": "沙啞的騎士"}, "figure_art": "avg_npc_221"}, {"id": 339, "prop": "name", "attributes": {"content": "  可我想......感染者又不是一定會在第二天死翹翹，既然我們有這麼多個第二天，就該狠狠幹上一票。", "name": "沙啞的騎士"}, "figure_art": "avg_npc_221"}, {"id": 340, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 341, "prop": "dialog", "attributes": {}}, {"id": 342, "prop": "character", "attributes": {}}, {"id": 343, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 344, "prop": "Background", "attributes": {"image": "bg_23_G10", "screenadapt": "coverall"}}, {"id": 345, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 346, "prop": "playMusic", "attributes": {"intro": "$darkness02_intro", "key": "$darkness02_loop", "volume": 0.4}}, {"id": 347, "prop": "Character", "attributes": {"name": "avg_430_fartth_1", "fadetime": 1.0, "block": "true"}}, {"id": 348, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 349, "prop": "name", "attributes": {"content": "  ......人數在變少。", "name": "查絲汀娜"}, "figure_art": "avg_430_fartth_1"}, {"id": 350, "prop": "name", "attributes": {"content": "  只靠這種小動作，終歸是救不了所有感染者的，索娜。", "name": "查絲汀娜"}, "figure_art": "avg_430_fartth_1"}, {"id": 351, "prop": "Character", "attributes": {"name": "avg_430_fartth_1", "name2": "avg_npc_122#2", "focus": 2.0}}, {"id": 352, "prop": "name", "attributes": {"content": "  ......我知道，所以我們必須儘快找到突破口。", "name": "索娜"}, "figure_art": "avg_npc_122#2"}, {"id": 353, "prop": "Character", "attributes": {"name": "avg_npc_103nc_1#2", "name2": "avg_npc_122#2", "focus": 1.0}}, {"id": 354, "prop": "name", "attributes": {"content": "  哼......只靠著幾個感染者成為騎士之後的特權和財富，能在這座城市做什麼呢。", "name": "瑟奇亞克"}, "figure_art": "avg_npc_103nc_1#2"}, {"id": 355, "prop": "Character", "attributes": {"name": "avg_npc_103nc_1", "name2": "avg_npc_122#2", "focus": 1.0}}, {"id": 356, "prop": "name", "attributes": {"content": "  你們用來為這些感染者搞慈善的錢，你們這些毫無意義的遮掩，在城市的下水溝裡苟且偷生的棚屋。", "name": "瑟奇亞克"}, "figure_art": "avg_npc_103nc_1"}, {"id": 357, "prop": "name", "attributes": {"content": "  這一切都是這座城市賦予你們的，你們沒有什麼突破口。", "name": "瑟奇亞克"}, "figure_art": "avg_npc_103nc_1"}, {"id": 358, "prop": "Character", "attributes": {"name": "avg_npc_103nc_1", "name2": "avg_npc_122#3", "focus": 2.0}}, {"id": 359, "prop": "name", "attributes": {"content": "  啊哈哈，話說得真難聽啊，塑膠騎士閣下。", "name": "索娜"}, "figure_art": "avg_npc_122#3"}, {"id": 360, "prop": "Character", "attributes": {"name": "avg_npc_123", "name2": "avg_npc_103nc_1", "focus": 1.0}}, {"id": 361, "prop": "name", "attributes": {"content": "  ......那你的家族呢，瑟奇亞克？騎士貴族們沒有為你費盡心思討好那些企業家們嗎？", "name": "格蕾納蒂"}, "figure_art": "avg_npc_123"}, {"id": 362, "prop": "name", "attributes": {"content": "  被商業聯合會針對的你，和我們沒有區別。認清自己。", "name": "格蕾納蒂"}, "figure_art": "avg_npc_123"}, {"id": 363, "prop": "Character", "attributes": {"name": "avg_npc_123", "name2": "avg_npc_103nc_1#6", "focus": 2.0}}, {"id": 364, "prop": "name", "attributes": {"content": "  ......呵......也是，我們都是被傾倒到這裡的垃圾，確實沒有什麼區別。", "name": "瑟奇亞克"}, "figure_art": "avg_npc_103nc_1#6"}, {"id": 365, "prop": "Character", "attributes": {"name": "avg_npc_123", "name2": "avg_npc_103nc_1", "focus": 2.0}}, {"id": 366, "prop": "name", "attributes": {"content": "  你是叫格蕾納蒂？騎士貴族，這種東西從扈從團建立的那一刻就已經完蛋了。", "name": "瑟奇亞克"}, "figure_art": "avg_npc_103nc_1"}, {"id": 367, "prop": "Character", "attributes": {"name": "avg_npc_123", "name2": "avg_npc_103nc_1#6", "focus": 2.0}}, {"id": 368, "prop": "name", "attributes": {"content": "  可別說你還對你過去的家族抱有幻想 ，小松鼠。", "name": "瑟奇亞克"}, "figure_art": "avg_npc_103nc_1#6"}, {"id": 369, "prop": "Character", "attributes": {"name": "avg_npc_123#3", "name2": "avg_npc_103nc_1", "focus": 1.0}}, {"id": 370, "prop": "name", "attributes": {"content": "  ......", "name": "格蕾納蒂"}, "figure_art": "avg_npc_123#3"}, {"id": 371, "prop": "Character", "attributes": {"name": "avg_npc_123#3", "name2": "avg_npc_122", "focus": 2.0}}, {"id": 372, "prop": "name", "attributes": {"content": "  （你是不是以為他會和你吵起來？）", "name": "索娜"}, "figure_art": "avg_npc_122"}, {"id": 373, "prop": "Character", "attributes": {"name": "avg_npc_123", "name2": "avg_npc_103nc_1#6", "focus": 1.0}}, {"id": 374, "prop": "name", "attributes": {"content": "  ......你比我想的冷靜些。", "name": "格蕾納蒂"}, "figure_art": "avg_npc_123"}, {"id": 375, "prop": "Character", "attributes": {"name": "avg_npc_123", "name2": "avg_npc_103nc_1", "focus": 2.0}}, {"id": 376, "prop": "name", "attributes": {"content": "  呵，你知道嗎，我巴不得現在就離開這裡，天曉得你們什麼時候會把礦石病帶給其他人——", "name": "瑟奇亞克"}, "figure_art": "avg_npc_103nc_1"}, {"id": 377, "prop": "name", "attributes": {"content": "  但看你們這樣一時半會似乎也死不了，那就讓我們把注意力放在別的事情上——", "name": "瑟奇亞克"}, "figure_art": "avg_npc_103nc_1"}, {"id": 378, "prop": "Character", "attributes": {"name": "avg_npc_103nc_1", "name2": "avg_npc_122#2", "focus": 2.0}}, {"id": 379, "prop": "name", "attributes": {"content": "  無胄盟。", "name": "索娜"}, "figure_art": "avg_npc_122#2"}, {"id": 380, "prop": "Character", "attributes": {"name": "avg_npc_103nc_1", "name2": "avg_npc_122#2", "focus": 1.0}}, {"id": 381, "prop": "name", "attributes": {"content": "  ......聯合會的下賤爪牙，我會讓他們後悔的。", "name": "瑟奇亞克"}, "figure_art": "avg_npc_103nc_1"}, {"id": 382, "prop": "Character", "attributes": {"name": "avg_npc_103nc_1"}}, {"id": 383, "prop": "name", "attributes": {"content": "  話說回來，既然你們敢這麼和無胄盟作對......總得有點底牌吧？", "name": "瑟奇亞克"}, "figure_art": "avg_npc_103nc_1"}, {"id": 384, "prop": "Character", "attributes": {"name": "avg_npc_103nc_1", "name2": "avg_430_fartth_1", "focus": 2.0}}, {"id": 385, "prop": "name", "attributes": {"content": "  ......零號地塊。", "name": "查絲汀娜"}, "figure_art": "avg_430_fartth_1"}, {"id": 386, "prop": "name", "attributes": {"content": "  或者說，大騎士領感染者集中醫療部門，由多家企業聯合負責的感染者收治區......", "name": "查絲汀娜"}, "figure_art": "avg_430_fartth_1"}, {"id": 387, "prop": "Character", "attributes": {"name": "avg_npc_103nc_1", "name2": "avg_430_fartth_1", "focus": 1.0}}, {"id": 388, "prop": "name", "attributes": {"content": "  你們這些感染者騎士不是那裡的常客嗎？所以呢？無胄盟在那裡有什麼秘密？", "name": "瑟奇亞克"}, "figure_art": "avg_npc_103nc_1"}, {"id": 389, "prop": "Character", "attributes": {"name": "avg_npc_123#5", "name2": "avg_npc_103nc_1", "focus": 1.0}}, {"id": 390, "prop": "name", "attributes": {"content": "  ——慢著，瑟奇亞克。", "name": "格蕾納蒂"}, "figure_art": "avg_npc_123#5"}, {"id": 391, "prop": "Character", "attributes": {"name": "avg_npc_123#6", "name2": "avg_npc_103nc_1", "focus": 1.0}}, {"id": 392, "prop": "name", "attributes": {"content": "  我們當然有一些手段......但不代表我們要把這些手段無保留地告訴你。", "name": "格蕾納蒂"}, "figure_art": "avg_npc_123#6"}, {"id": 393, "prop": "Character", "attributes": {"name": "avg_npc_123#6", "name2": "avg_npc_103nc_1", "focus": 2.0}}, {"id": 394, "prop": "name", "attributes": {"content": "  如果你真這麼想，感染者，你該把我留在那家該死的醫院裡，等著無胄盟來拷問我——而不是救我出來。", "name": "瑟奇亞克"}, "figure_art": "avg_npc_103nc_1"}, {"id": 395, "prop": "name", "attributes": {"content": "  別這麼和我講話，我們都是各取所需才會站在這裡的，只憑你的身價，你配和我對話嗎？灰毫？", "name": "瑟奇亞克"}, "figure_art": "avg_npc_103nc_1"}, {"id": 396, "prop": "Character", "attributes": {"name": "avg_npc_123#6", "name2": "avg_npc_103nc_1#5", "focus": 2.0}}, {"id": 397, "prop": "name", "attributes": {"content": "  還是說，你把我帶出來，我就要對你感激涕零了？", "name": "瑟奇亞克"}, "figure_art": "avg_npc_103nc_1#5"}, {"id": 398, "prop": "Character", "attributes": {"name": "avg_npc_123#6", "name2": "avg_npc_103nc_1", "focus": 1.0}}, {"id": 399, "prop": "name", "attributes": {"content": "  狂妄的貴族——", "name": "格蕾納蒂"}, "figure_art": "avg_npc_123#6"}, {"id": 400, "prop": "Character", "attributes": {"name": "avg_npc_122#3"}}, {"id": 401, "prop": "name", "attributes": {"content": "  啊——好了好了，我是不反對你們現在打一架，現在打一架總比在面對無胄盟的時候捅刀子要強——", "name": "索娜"}, "figure_art": "avg_npc_122#3"}, {"id": 402, "prop": "Character", "attributes": {"name": "avg_npc_122"}}, {"id": 403, "prop": "name", "attributes": {"content": "  ——我們好歹也做這件事有幾年了......我們有一些政府管道。", "name": "索娜"}, "figure_art": "avg_npc_122"}, {"id": 404, "prop": "name", "attributes": {"content": "  你知道卡西米爾最痛恨商業聯合會的，除了那些日子都過不下去的窮人和感染者......還有誰嗎？", "name": "索娜"}, "figure_art": "avg_npc_122"}, {"id": 405, "prop": "Character", "attributes": {"name": "avg_npc_103nc_1", "name2": "avg_npc_122", "focus": 1.0}}, {"id": 406, "prop": "name", "attributes": {"content": "  ......呵。", "name": "瑟奇亞克"}, "figure_art": "avg_npc_103nc_1"}, {"id": 407, "prop": "name", "attributes": {"content": "  要嘛是我瘋了，要嘛是卡西米爾瘋了......你們該不會要說，一群感染者，在和監正會做交易，為了打擊聯合會？", "name": "瑟奇亞克"}, "figure_art": "avg_npc_103nc_1"}, {"id": 408, "prop": "Character", "attributes": {"name": "avg_npc_103nc_1", "name2": "avg_npc_122", "focus": 2.0}}, {"id": 409, "prop": "name", "attributes": {"content": "  啊哈哈......", "name": "索娜"}, "figure_art": "avg_npc_122"}, {"id": 410, "prop": "Character", "attributes": {"name": "avg_npc_103nc_1", "name2": "avg_npc_122#2", "focus": 2.0}}, {"id": 411, "prop": "name", "attributes": {"content": "  看看你如今的處境，看看騎士們，瑟奇亞克。", "name": "索娜"}, "figure_art": "avg_npc_122#2"}, {"id": 412, "prop": "Character", "attributes": {"name": "avg_npc_103nc_1", "name2": "avg_npc_122#8", "focus": 2.0}}, {"id": 413, "prop": "name", "attributes": {"content": "  ——他們早瘋了。", "name": "索娜"}, "figure_art": "avg_npc_122#8"}, {"id": 414, "prop": "Dialog", "attributes": {}}, {"id": 415, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 416, "prop": "Dialog", "attributes": {}}, {"id": 417, "prop": "Character", "attributes": {}}, {"id": 418, "prop": "Image", "attributes": {}}, {"id": 419, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}