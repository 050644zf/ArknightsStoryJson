acter", "attributes": {"name": "avg_npc_061#2", "fadetime": 1.0, "block": "true"}}, {"id": 187, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 188, "prop": "name", "attributes": {"content": "  各位！啊，佐菲婭姐姐也在。", "name": "瑪莉婭"}, "figure_art": "avg_npc_061#2"}, {"id": 189, "prop": "Character", "attributes": {"name": "avg_npc_061#2", "name2": "avg_npc_064_weapon_1", "focus": 2.0}}, {"id": 190, "prop": "name", "attributes": {"content": "  瑪莉婭？你怎麼一個人來了？", "name": "佐菲婭"}, "figure_art": "avg_npc_064_weapon_1"}, {"id": 191, "prop": "Character", "attributes": {"name": "avg_npc_061#2", "name2": "avg_npc_064_weapon_1", "focus": 1.0}}, {"id": 192, "prop": "name", "attributes": {"content": "  剛才騎士協會的人來找姐姐，我就自己先過來了......", "name": "瑪莉婭"}, "figure_art": "avg_npc_061#2"}, {"id": 193, "prop": "name", "attributes": {"content": "  像姐姐這樣曾被流放過，又重新取回身份的例子似乎不多，有很多法律文件要審查......", "name": "瑪莉婭"}, "figure_art": "avg_npc_061#2"}, {"id": 194, "prop": "Character", "attributes": {"name": "avg_npc_120", "name2": "avg_npc_101", "focus": 1.0}}, {"id": 195, "prop": "name", "attributes": {"content": "  真奇怪，這群人當年拼了命地陷害瑪嘉烈，現在又這麼乾脆地承認她了？", "name": "老騎士"}, "figure_art": "avg_npc_120"}, {"id": 196, "prop": "Character", "attributes": {"name": "avg_npc_120", "name2": "avg_npc_101", "focus": 2.0}}, {"id": 197, "prop": "name", "attributes": {"content": "  有詐吧？", "name": "老工匠"}, "figure_art": "avg_npc_101"}, {"id": 198, "prop": "Character", "attributes": {"name": "avg_npc_064_weapon_1#2"}}, {"id": 199, "prop": "name", "attributes": {"content": "  之前我就在思考這件事，您二老能不能偶爾說點好話？", "name": "佐菲婭"}, "figure_art": "avg_npc_064_weapon_1#2"}, {"id": 200, "prop": "Character", "attributes": {"name": "avg_npc_120", "name2": "avg_npc_064_weapon_1#2", "focus": 1.0}}, {"id": 201, "prop": "name", "attributes": {"content": "  這不是擔心嘛......", "name": "老騎士"}, "figure_art": "avg_npc_120"}, {"id": 202, "prop": "Character", "attributes": {"name": "avg_npc_064_weapon_1#2", "name2": "avg_npc_101", "focus": 2.0}}, {"id": 203, "prop": "n