: {"key": "$dooropenquite"}}, {"id": 288, "prop": "Character", "attributes": {"fadetime": 0.3}}, {"id": 289, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 290, "prop": "Character", "attributes": {"name": "avg_103_angel_1#1$1", "fadetime": 0.5}}, {"id": 291, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 292, "prop": "name", "attributes": {"content": "啊，空，你果然在卡特琳娜小姐家。", "name": "能天使"}, "figure_art": "avg_103_angel_1#1$1"}, {"id": 293, "prop": "Character", "attributes": {"name": "char_101_sora_1#5"}}, {"id": 294, "prop": "name", "attributes": {"content": "這裡有好多資料，而且不少劇本中都能看到卡特琳娜小姐的筆記。", "name": "空"}, "figure_art": "char_101_sora_1#5"}, {"id": 295, "prop": "name", "attributes": {"content": "她真的很喜歡自己的職業呢。", "name": "空"}, "figure_art": "char_101_sora_1#5"}, {"id": 296, "prop": "Dialog", "attributes": {}}, {"id": 297, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 298, "prop": "Character", "attributes": {"name": "char_101_sora_1#4"}}, {"id": 299, "prop": "name", "attributes": {"content": "唉......", "name": "空"}, "figure_art": "char_101_sora_1#4"}, {"id": 300, "prop": "Character", "attributes": {"name": "avg_201_moeshd_1#13$1"}}, {"id": 301, "prop": "name", "attributes": {"content": "別歎氣啦。", "name": "可頌"}, "figure_art": "avg_201_moeshd_1#13$1"}, {"id": 302, "prop": "name", "attributes": {"content": "我們都知道，你也不想把演員事業只是當做尋找德克薩斯的手段。", "name": "可頌"}, "figure_art": "avg_201_moeshd_1#13$1"}, {"id": 303, "prop": "Character", "attributes": {"name": "char_101_sora_1#4"}}, {"id": 304, "prop": "name", "attributes": {"content": "嗯，但是，眼下的情況，還是要以見到德克薩斯為優先呢......", "name": "空"}, "figure_art": "char_101_sora_1#4"}, {"id": 305, "prop": "name", "attributes": {"content": "畢竟，連那個拉普蘭德也回到了敘拉古，而且還做了那麼出格的事。", "name": "空"}, "figure_art": "char_101_sora_1#4"}, {"id": 306, "prop": "Character", "attributes": {"name": "avg_103_angel_1#1$1"}}, {"id": 307, "prop": "name", "attributes": {"content": "其實想一想也是理所當然的事情。", "name": "能天使"}, "figure_art": "avg_103_angel_1#1$1"}, {"id": 308, "prop": "name", "attributes": {"content": "總覺得她會出現在一切德克薩斯會出現的地方。", "name": "能天使"}, "figure_art": "avg_103_angel_1#1$1"}, {"id": 309, "prop": "Character", "attributes": {"name": "char_101_sora_1#4"}}, {"id": 310, "prop": "name", "attributes": {"content": "你們覺得，她是想要幫德克薩斯才那麼做的嗎？", "name": "空"}, "figure_art": "char_101_sora_1#4"}, {"id": 311, "prop": "Character", "attributes": {"name": "avg_201_moeshd_1#9$1"}}, {"id": 312, "prop": "name", "attributes": {"content": "雖然結果上來說，德克薩斯的嫌疑確實被洗清了，但是怎麼想都很奇怪吧。", "name": "可頌"}, "figure_art": "avg_201_moeshd_1#9$1"}, {"id": 313, "prop": "Character", "attributes": {"name": "char_101_sora_1#4"}}, {"id": 314, "prop": "name", "attributes": {"content": "嗯，我也覺得，她應該是有自己的目的。", "name": "空"}, "figure_art": "char_101_sora_1#4"}, {"id": 315, "prop": "Character", "attributes": {"name": "avg_201_moeshd_1#9$1"}}, {"id": 316, "prop": "name", "attributes": {"content": "唉，我是真的不擅長應付這個人。", "name": "可頌"}, "figure_art": "avg_201_moeshd_1#9$1"}, {"id": 317, "prop": "name", "attributes": {"content": "說是德克薩斯的朋友肯定談不上，但是，如果是仇家，哪有態度這麼曖昧的仇家。", "name": "可頌"}, "figure_art": "avg_201_moeshd_1#9$1"}, {"id": 318, "prop": "Character", "attributes": {"name": "avg_201_moeshd_1#12$1"}}, {"id": 319, "prop": "name", "attributes": {"content": "搞不清楚她到底想在德克薩斯身上找到什麼。", "name": "可頌"}, "figure_art": "avg_201_moeshd_1#12$1"}, {"id": 320, "prop": "Character", "attributes": {"name": "avg_103_angel_1#10$1"}}, {"id": 321, "prop": "name", "attributes": {"content": "但她之前送我的千層酥還蠻好吃的欸。", "name": "能天使"}, "figure_art": "avg_103_angel_1#10$1"}, {"id": 322, "prop": "Character", "attributes": {"name": "avg_201_moeshd_1#5$1"}}, {"id": 323, "prop": "name", "attributes": {"content": "吃貨閉嘴啦。", "name": "可頌"}, "figure_art": "avg_201_moeshd_1#5$1"}, {"id": 324, "prop": "Character", "attributes": {"name": "avg_103_angel_1#9$1"}}, {"id": 325, "prop": "name", "attributes": {"content": "我以前也猜不透莫斯提馬在想什麼，但是等我逐漸不去想這件事後，我反而有點理解了。", "name": "能天使"}, "figure_art": "avg_103_angel_1#9$1"}, {"id": 326, "prop": "name", "attributes": {"content": "我覺得拉普蘭德也是一樣的。", "name": "能天使"}, "figure_art": "avg_103_angel_1#9$1"}, {"id": 327, "prop": "name", "attributes": {"content": "像她們這樣的人，與其去猜她們到底在想什麼，不如乾脆地接受她們的每一句話。", "name": "能天使"}, "figure_art": "avg_103_angel_1#9$1"}, {"id": 328, "prop": "name", "attributes": {"content": "只有相信她們的每一句話都是真的，才能看穿她們最後是不是在用真實編織一個謊言。", "name": "能天使"}, "figure_art": "avg_103_angel_1#9$1"}, {"id": 329, "prop": "Character", "attributes": {"name": "char_101_sora_1#4"}}, {"id": 330, "prop": "name", "attributes": {"content": "是嗎......", "name": "空"}, "figure_art": "char_101_sora_1#4"}, {"id": 331, "prop": "Character", "attributes": {"name": "avg_201_moeshd_1#1$1"}}, {"id": 332, "prop": "name", "attributes": {"content": "啊，我先去買點吃的，能天使，護衛就拜託你了。", "name": "可頌"}, "figure_art": "avg_201_moeshd_1#1$1"}, {"id": 333, "prop": "Character", "attributes": {"name": "avg_103_angel_1#6$1"}}, {"id": 334, "prop": "name", "attributes": {"content": "放心~", "name": "能天使"}, "figure_art": "avg_103_angel_1#6$1"}, {"id": 335, "prop": "Dialog", "attributes": {}}, {"id": 336, "prop": "Character", "attributes": {"name": "avg_201_moeshd_1#1$1"}}, {"id": 337, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 338, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.7}}, {"id": 339, "prop": "Character", "attributes": {"fadetime": 0.5}}, {"id": 340, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 341, "prop": "playsound", "attributes": {"key": "$dooropenquite"}}, {"id": 342, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 343, "prop": "Character", "attributes": {"name": "avg_npc_687_1#9$1", "fadetime": 0.5}}, {"id": 344, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 345, "prop": "name", "attributes": {"content": "空，又在練台詞呢？", "name": "卡特琳娜"}, "figure_art": "avg_npc_687_1#9$1"}, {"id": 346, "prop": "Character", "attributes": {"name": "char_101_sora_1#5"}}, {"id": 347, "prop": "name", "attributes": {"content": "啊，卡特琳娜小姐，你好呀。", "name": "空"}, "figure_art": "char_101_sora_1#5"}, {"id": 348, "prop": "name", "attributes": {"content": "因為《德克薩斯之死》的第二幕快要正式演出了，所以我最近打算努力一點。", "name": "空"}, "figure_art": "char_101_sora_1#5"}, {"id": 349, "prop": "Character", "attributes": {"name": "avg_npc_687_1#10$1"}}, {"id": 350, "prop": "name", "attributes": {"content": "啊，已經到了這個日子了嗎，我都忘了。", "name": "卡特琳娜"}, "figure_art": "avg_npc_687_1#10$1"}, {"id": 351, "prop": "Character", "attributes": {"name": "avg_npc_687_1#9$1"}}, {"id": 352, "prop": "name", "attributes": {"content": "能天使，吃披薩嗎？", "name": "卡特琳娜"}, "figure_art": "avg_npc_687_1#9$1"}, {"id": 353, "prop": "Character", "attributes": {"name": "avg_103_angel_1#10$1"}}, {"id": 354, "prop": "name", "attributes": {"content": "我要！", "name": "能天使"}, "figure_art": "avg_103_angel_1#10$1"}, {"id": 355, "prop": "Character", "attributes": {"name": "char_101_sora_1#1"}}, {"id": 356, "prop": "name", "attributes": {"content": "對了，卡特琳娜小姐既然是劇本作者，到時候一定會來看吧？", "name": "空"}, "figure_art": "char_101_sora_1#1"}, {"id": 357, "prop": "Character", "attributes": {"name": "avg_npc_687_1#8$1"}}, {"id": 358, "prop": "name", "attributes": {"content": "嗯——", "name": "卡特琳娜"}, "figure_art": "avg_npc_687_1#8$1"}, {"id": 359, "prop": "Character", "attributes": {"name": "avg_npc_687_1#9$1"}}, {"id": 360, "prop": "name", "attributes": {"content": "我其實就是想來告訴你，我會暫時離開一段時間。", "name": "卡特琳娜"}, "figure_art": "avg_npc_687_1#9$1"}, {"id": 361, "prop": "Character", "attributes": {"name": "char_101_sora_1#3"}}, {"id": 362, "prop": "name", "attributes": {"content": "欸？", "name": "空"}, "figure_art": "char_101_sora_1#3"}, {"id": 363, "prop": "Character", "attributes": {"name": "char_101_sora_1#1"}}, {"id": 364, "prop": "name", "attributes": {"content": "你要離開很久嗎？", "name": "空"}, "figure_art": "char_101_sora_1#1"}, {"id": 365, "prop": "Character", "attributes": {"name": "avg_npc_687_1#8$1"}}, {"id": 366, "prop": "name", "attributes": {"content": "嗯......如果順利的話，應該不會很久吧。", "name": "卡特琳娜"}, "figure_art": "avg_npc_687_1#8$1"}, {"id": 367, "prop": "Character", "attributes": {"name": "avg_npc_687_1#9$1"}}, {"id": 368, "prop": "name", "attributes": {"content": "放心，不是什麼大事，家裡出了點狀況，我這個做大姐的，要回去主持一下大局而已。", "name": "卡特琳娜"}, "figure_art": "avg_npc_687_1#9$1"}, {"id": 369, "prop": "Character", "attributes": {"name": "avg_103_angel_1#1$1"}}, {"id": 370, "prop": "name", "attributes": {"content": "當姐姐的還真是辛苦欸......", "name": "能天使"}, "figure_art": "avg_103_angel_1#1$1"}, {"id": 371, "prop": "Character", "attributes": {"name": "avg_npc_687_1#3$1"}}, {"id": 372, "prop": "name", "attributes": {"content": "哈哈，還好啦。", "name": "卡特琳娜"}, "figure_art": "avg_npc_687_1#3$1"}, {"id": 373, "prop": "Character", "attributes": {"name": "avg_npc_687_1#9$1"}}, {"id": 374, "prop": "name", "attributes": {"content": "只可惜，第三幕的高潮我還是沒有想好。", "name": "卡特琳娜"}, "figure_art": "avg_npc_687_1#9$1"}, {"id": 375, "prop": "name", "attributes": {"content": "唉，但願這次回老家能找到一些靈感吧。", "name": "卡特琳娜"}, "figure_art": "avg_npc_687_1#9$1"}, {"id": 376, "prop": "Character", "attributes": {"name": "char_101_sora_1#4"}}, {"id": 377, "prop": "name", "attributes": {"content": "好吧......", "name": "空"}, "figure_art": "char_101_sora_1#4"}, {"id": 378, "prop": "Character", "attributes": {"name": "avg_npc_687_1#11$1"}}, {"id": 379, "prop": "name", "attributes": {"content": "哎，別露出這副表情嘛，只是平時見不到了而已，第二幕的上演我應該會抽空去看的。", "name": "卡特琳娜"}, "figure_art": "avg_npc_687_1#11$1"}, {"id": 380, "prop": "Character", "attributes": {"name": "avg_npc_687_1#9$1"}}, {"id": 381, "prop": "name", "attributes": {"content": "說不定到時候去後台找你玩哦。", "name": "卡特琳娜"}, "figure_art": "avg_npc_687_1#9$1"}, {"id": 382, "prop": "Character", "attributes": {"name": "char_101_sora_1#1"}}, {"id": 383, "prop": "name", "attributes": {"content": "真的？", "name": "空"}, "figure_art": "char_101_sora_1#1"}, {"id": 384, "prop": "Character", "attributes": {"name": "avg_npc_687_1#9$1"}}, {"id": 385, "prop": "name", "attributes": {"content": "畢竟是好不容易交到的朋友，而且又是我自己寫的劇本，我也想在近距離觀賞呢。", "name": "卡特琳娜"}, "figure_art": "avg_npc_687_1#9$1"}, {"id": 386, "prop": "Character", "attributes": {"name": "char_101_sora_1#1"}}, {"id": 387, "prop": "name", "attributes": {"content": "嗯，那就這麼說定了，你過來的話一定要聯絡我哦！", "name": "空"}, "figure_art": "char_101_sora_1#1"}, {"id": 388, "prop": "Character", "attributes": {"name": "avg_npc_687_1#3$1"}}, {"id": 389, "prop": "name", "attributes": {"content": "沒問題！", "name": "卡特琳娜"}, "figure_art": "avg_npc_687_1#3$1"}, {"id": 390, "prop": "Character", "attributes": {"name": "avg_npc_687_1#9$1"}}, {"id": 391, "prop": "name", "attributes": {"content": "那我先走了，拜拜。", "name": "卡特琳娜"}, "figure_art": "avg_npc_687_1#9$1"}, {"id": 392, "prop": "Character", "attributes": {"name": "char_101_sora_1#1"}}, {"id": 393, "prop": "name", "attributes": {"content": "拜拜~", "name": "空"}, "figure_art": "char_101_sora_1#1"}, {"id": 394, "prop": "Character", "attributes": {"name": "avg_103_angel_1#1$1"}}, {"id": 395, "prop": "name", "attributes": {"content": "再見~", "name": "能天使"}, "figure_art": "avg_103_angel_1#1$1"}, {"id": 396, "prop": "dialog", "attributes": {}}, {"id": 397, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 398, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 399, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 400, "prop": "Background", "attributes": {"image": "33_g6_newtown_street", "screenadapt": "coverall"}}, {"id": 401, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 402, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 403, "prop": "Character", "attributes": {"name": "avg_npc_687_1#9$1", "name2": "avg_npc_695_1#1$1", "fadetime": 0.5}}, {"id": 404, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 405, "prop": "Character", "attributes": {"name": "avg_npc_687_1#9$1", "name2": "avg_npc_695_1#1$1", "focus": 2.0}}, {"id": 406, "prop": "name", "attributes": {"content": "首領，不用帶行李嗎？", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#1$1"}, {"id": 407, "prop": "Character", "attributes": {"name": "avg_npc_687_1#14$1", "name2": "avg_npc_695_1#1$1", "focus": 1.0}}, {"id": 408, "prop": "name", "attributes": {"content": "等事情處理完，我還要回這裡寫劇本呢，有什麼好帶的。", "name": "喬萬娜"}, "figure_art": "avg_npc_687_1#14$1"}, {"id": 409, "prop": "Character", "attributes": {"name": "avg_npc_687_1#14$1", "name2": "avg_npc_695_1#1$1", "focus": 2.0}}, {"id": 410, "prop": "name", "attributes": {"content": "......好吧。", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#1$1"}, {"id": 411, "prop": "Character", "attributes": {"name": "avg_npc_687_1#1$1", "name2": "avg_npc_695_1#1$1", "focus": 1.0}}, {"id": 412, "prop": "name", "attributes": {"content": "薩盧佐和貝洛內現在是什麼反應？", "name": "喬萬娜"}, "figure_art": "avg_npc_687_1#1$1"}, {"id": 413, "prop": "Character", "attributes": {"name": "avg_npc_687_1#1$1", "name2": "avg_npc_695_1#1$1", "focus": 2.0}}, {"id": 414, "prop": "name", "attributes": {"content": "薩盧佐邀請萊昂圖索少爺去赴宴，貝納爾多這頭老狼應了下來。", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#1$1"}, {"id": 415, "prop": "name", "attributes": {"content": "這場宴會可有意思了，現在所有人都在看著他們呢。", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#1$1"}, {"id": 416, "prop": "name", "attributes": {"content": "我們要做些什麼反應嗎？", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#1$1"}, {"id": 417, "prop": "Character", "attributes": {"name": "avg_npc_687_1#1$1", "name2": "avg_npc_695_1#1$1", "focus": 1.0}}, {"id": 418, "prop": "name", "attributes": {"content": "......", "name": "喬萬娜"}, "figure_art": "avg_npc_687_1#1$1"}, {"id": 419, "prop": "name", "attributes": {"content": "瓦拉赫，幫我安排一場行程。", "name": "喬萬娜"}, "figure_art": "avg_npc_687_1#1$1"}, {"id": 420, "prop": "name", "attributes": {"content": "我要去看《德克薩斯之死》第二幕的上演。", "name": "喬萬娜"}, "figure_art": "avg_npc_687_1#1$1"}, {"id": 421, "prop": "Character", "attributes": {"name": "avg_npc_687_1#1$1", "name2": "avg_npc_695_1#1$1", "focus": 2.0}}, {"id": 422, "prop": "name", "attributes": {"content": "你就這麼關心自己寫的劇本嗎？", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#1$1"}, {"id": 423, "prop": "Character", "attributes": {"name": "avg_npc_687_1#1$1", "name2": "avg_npc_695_1#1$1", "focus": 1.0}}, {"id": 424, "prop": "name", "attributes": {"content": "當然，這可是我的心血之作。", "name": "喬萬娜"}, "figure_art": "avg_npc_687_1#1$1"}, {"id": 425, "prop": "name", "attributes": {"content": "而且，你不是問我們要做什麼反應嗎？", "name": "喬萬娜"}, "figure_art": "avg_npc_687_1#1$1"}, {"id": 426, "prop": "name", "attributes": {"content": "這就是我的反應，既然貝納爾多·貝洛內都從他的劇院裡走出來了。", "name": "喬萬娜"}, "figure_art": "avg_npc_687_1#1$1"}, {"id": 427, "prop": "Character", "attributes": {"name": "avg_npc_687_1#13$1", "name2": "avg_npc_695_1#1$1", "focus": 1.0}}, {"id": 428, "prop": "name", "attributes": {"content": "那我，喬萬娜·羅塞蒂，也該回來了。", "name": "喬萬娜"}, "figure_art": "avg_npc_687_1#13$1"}, {"id": 429, "prop": "Dialog", "attributes": {}}, {"id": 430, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 431, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 432, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 433, "prop": "Character", "attributes": {}}, {"id": 434, "prop": "Image", "attributes": {}}, {"id": 435, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}