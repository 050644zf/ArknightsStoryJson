avg_npc_695_1#1$1"}, {"id": 138, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_npc_695_1#2$1", "focus": 2.0}}, {"id": 139, "prop": "name", "attributes": {"content": "我們從來都不知道，她原來還活著。", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#2$1"}, {"id": 140, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_npc_695_1#2$1", "focus": 1.0}}, {"id": 141, "prop": "name", "attributes": {"content": "......當年，是我父親保下了她。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 142, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_npc_695_1#3$1", "focus": 2.0}}, {"id": 143, "prop": "name", "attributes": {"content": "原來如此，原來如此，是他老人家的手筆。", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#3$1"}, {"id": 144, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_npc_695_1#3$1", "focus": 1.0}}, {"id": 145, "prop": "name", "attributes": {"content": "這座新城市的建造，本來也是因薩爾瓦多雷與敘拉古的緣分而起，家父也只是希望她能夠回到敘拉古看看這座城市。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 146, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_npc_695_1#5$1", "focus": 2.0}}, {"id": 147, "prop": "name", "attributes": {"content": "唉，不愧是貝洛內家。", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#5$1"}, {"id": 148, "prop": "name", "attributes": {"content": "明知德克薩斯這個姓氏對羅塞蒂家族來說意義重大，卻就這樣落落大方地請了回來。", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#5$1"}, {"id": 149, "prop": "name", "attributes": {"content": "大氣，真的大氣。", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#5$1"}, {"id": 150, "prop": "name", "attributes": {"content": "我瓦拉赫今天算是服了。", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#5$1"}, {"id": 151, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#8$1", "name2": "avg_npc_695_1#5$1", "focus": 1.0}}, {"id": 152, "prop": "name", "attributes": {"content": "你又在開玩笑了。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#8$1"}, {"id": 153, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#8$1", "name2": "avg_npc_695_1#5$1", "focus": 2.0}}, {"id": 154, "prop": "name", "attributes": {"content": "玩笑？這哪裡是玩笑？", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#5$1"}, {"id": 155, "prop": "name", "attributes": {"content": "切利尼娜小姐還活著的消息，對我們羅塞蒂來說意義非凡。", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#5$1"}, {"id": 156, "prop": "name", "attributes": {"content": "不管貝洛內怎麼想，羅塞蒂都欠你們一次。", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#5$1"}, {"id": 157, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#8$1", "name2": "avg_npc_695_1#5$1", "focus": 1.0}}, {"id": 158, "prop": "name", "attributes": {"content": "我們兩家是將來要共同建設新城市的關係，有什麼欠與不欠的？", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#8$1"}, {"id": 159, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#8$1", "name2": "avg_npc_695_1#5$1", "focus": 2.0}}, {"id": 160, "prop": "name", "attributes": {"content": "哈哈哈，好，說得好啊！", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#5$1"}, {"id": 161, "prop": "name", "attributes": {"content": "看來，老弟你早就在這等著我了。", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#5$1"}, {"id": 162, "prop": "name", "attributes": {"content": "說吧，你想要什麼？", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#5$1"}, {"id": 163, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#8$1", "name2": "avg_npc_695_1#5$1", "focus": 1.0}}, {"id": 164, "prop": "name", "attributes": {"content": "我要的東西很簡單——", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#8$1"}, {"id": 165, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_npc_695_1#5$1", "focus": 1.0}}, {"id": 166, "prop": "name", "attributes": {"content": "羅塞蒂不要插手這件事。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 167, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_npc_695_1#1$1", "focus": 2.0}}, {"id": 168, "prop": "name", "attributes": {"content": "哦？要我們眼睜睜地看著最後的德克薩斯被審判，我恐怕沒有辦法向首領交代。", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#1$1"}, {"id": 169, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#7$1", "name2": "avg_npc_695_1#1$1", "focus": 1.0}}, {"id": 170, "prop": "name", "attributes": {"content": "等到審判結束後，她會被收押，你們仍然可以見到她。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#7$1"}, {"id": 171, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#7$1", "name2": "avg_npc_695_1#1$1", "focus": 2.0}}, {"id": 172, "prop": "name", "attributes": {"content": "......只是見到她嗎？", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#1$1"}, {"id": 173, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#8$1", "name2": "avg_npc_695_1#1$1", "focus": 1.0}}, {"id": 174, "prop": "name", "attributes": {"content": "她是我們的客人，但她也可以是羅塞蒂的客人。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#8$1"}, {"id": 175, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#8$1", "name2": "avg_npc_695_1#5$1", "focus": 2.0}}, {"id": 176, "prop": "name", "attributes": {"content": "......好，成交！", "name": "瓦拉赫"}, "figure_art": "avg_npc_695_1#5$1"}, {"id": 177, "prop": "dialog", "attributes": {}}, {"id": 178, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 179, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 180, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 181, "prop": "Background", "attributes": {"image": "bg_bar_1", "screenadapt": "coverall"}}, {"id": 182, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 183, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 184, "prop": "Character", "attributes": {"name": "avg_npc_690_1#7$1", "fadetime": 1.0}}, {"id": 185, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 186, "prop": "name", "attributes": {"content": "......", "name": "德米特里"}, "figure_art": "avg_npc_690_1#7$1"}, {"id": 187, "prop": "name", "attributes": {"content": "沒想到，在這裡把切利尼娜搬了出來。", "name": "德米特里"}, "figure_art": "avg_npc_690_1#7$1"}, {"id": 188, "prop": "Character", "attributes": {"name": "avg_npc_690_1#8$1"}}, {"id": 189, "prop": "name", "attributes": {"content": "是拉維妮婭的想法嗎？不......她不會不知道，切利尼娜不是兇手。", "name": "德米特里"}, "figure_art": "avg_npc_690_1#8$1"}, {"id": 190, "prop": "name", "attributes": {"content": "以她的性格，她不會做出這個決定。", "name": "德米特里"}, "figure_art": "avg_npc_690_1#8$1"}, {"id": 191, "prop": "Character", "attributes": {"name": "avg_npc_690_1#7$1"}}, {"id": 192, "prop": "name", "attributes": {"content": "難道是萊昂說服了她？", "name": "德米特里"}, "figure_art": "avg_npc_690_1#7$1"}, {"id": 193, "prop": "Character", "attributes": {"name": "avg_npc_690_1#3$1"}}, {"id": 194, "prop": "name", "attributes": {"content": "......算了，無論如何，沒想到還有這一手。", "name": "德米特里"}, "figure_art": "avg_npc_690_1#3$1"}, {"id": 195, "prop": "Character", "attributes": {"name": "avg_npc_698_1#1$1"}}, {"id": 196, "prop": "name", "attributes": {"content": "......德米特里，現在，我們應該怎麼辦？", "name": "家族成員"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 197, "prop": "name", "attributes": {"content": "要去暗殺切利尼娜嗎？", "name": "家族成員"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 198, "prop": "Character", "attributes": {"name": "avg_npc_690_1#9$1"}}, {"id": 199, "prop": "name", "attributes": {"content": "......你知道在七年前那場亂子裡，有多少家族的精銳折在她手上嗎？", "name": "德米特里"}, "figure_art": "avg_npc_690_1#9$1"}, {"id": 200, "prop": "Character", "attributes": {"name": "avg_npc_698_1#1$1"}}, {"id": 201, "prop": "name", "attributes": {"content": "但——", "name": "家族成員"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 202, "prop": "Character", "attributes": {"name": "avg_npc_690_1#8$1"}}, {"id": 203, "prop": "name", "attributes": {"content": "偷襲、爆炸，或者乾脆下毒，或許我們總有些辦法......", "name": "德米特里"}, "figure_art": "avg_npc_690_1#8$1"}, {"id": 204, "prop": "name", "attributes": {"content": "可別忘了，她歸根結底是誰請回來的人。", "name": "德米特里"}, "figure_art": "avg_npc_690_1#8$1"}, {"id": 205, "prop": "Character", "attributes": {"name": "avg_npc_690_1#9$1"}}, {"id": 206, "prop": "name", "attributes": {"content": "無論是誰的主意，這確實很聰明。", "name": "德米特里"}, "figure_art": "avg_npc_690_1#9$1"}, {"id": 207, "prop": "name", "attributes": {"content": "事已至此，只能用一些粗暴的辦法讓審判中止了。", "name": "德米特里"}, "figure_art": "avg_npc_690_1#9$1"}, {"id": 208, "prop": "Character", "attributes": {"name": "avg_npc_698_1#1$1"}}, {"id": 209, "prop": "name", "attributes": {"content": "......", "name": "家族成員"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 210, "prop": "Character", "attributes": {"name": "avg_npc_690_1#3$1"}}, {"id": 211, "prop": "name", "attributes": {"content": "歸根結底，我們的目的是讓城裡亂起來。", "name": "德米特里"}, "figure_art": "avg_npc_690_1#3$1"}, {"id": 212, "prop": "Character", "attributes": {"name": "avg_npc_690_1#9$1"}}, {"id": 213, "prop": "name", "attributes": {"content": "從一開始，挑釁西西里夫人就在我們的計劃之中。", "name": "德米特里"}, "figure_art": "avg_npc_690_1#9$1"}, {"id": 214, "prop": "name", "attributes": {"content": "現在，也只不過是把這一步提前了而已。", "name": "德米特里"}, "figure_art": "avg_npc_690_1#9$1"}, {"id": 215, "prop": "Character", "attributes": {"name": "avg_npc_698_1#1$1"}}, {"id": 216, "prop": "name", "attributes": {"content": "......是。", "name": "家族成員"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 217, "prop": "Character", "attributes": {}}, {"id": 218, "prop": "name", "attributes": {"content": "我倒覺得，還有別的方法哦。", "name": "？？？"}}, {"id": 219, "prop": "Character", "attributes": {"name": "avg_npc_690_1#7$1"}}, {"id": 220, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 221, "prop": "name", "attributes": {"content": "誰？！", "name": "德米特里"}, "figure_art": "avg_npc_690_1#7$1"}, {"id": 222, "prop": "Dialog", "attributes": {}}, {"id": 223, "prop": "Character", "attributes": {}}, {"id": 224, "prop": "Character", "attributes": {"name": "avg_npc_683_1#3$1", "fadetime": 1.0}}, {"id": 225, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 226, "prop": "name", "attributes": {"content": "這麼有趣的事情，能讓我也參加一下嗎？", "name": "拉普蘭德"}, "figure_art": "avg_npc_683_1#3$1"}, {"id": 227, "prop": "StopMusic", "attributes": {"fadetime": 2.0}}, {"id": 228, "prop": "dialog", "attributes": {}}, {"id": 229, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 230, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 231, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 232, "prop": "Background", "attributes": {"image": "33_g11_mansionhall", "screenadapt": "coverall"}}, {"id": 233, "prop": "playMusic", "attributes": {"intro": "$distressed_intro", "key": "$distressed_loop", "volume": 0.6}}, {"id": 234, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 235, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 236, "prop": "Character", "attributes": {"name": "avg_npc_685_1#2$1", "fadetime": 0.5}}, {"id": 237, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 238, "prop": "name", "attributes": {"content": "......", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#2$1"}, {"id": 239, "prop": "Dialog", "attributes": {}}, {"id": 240, "prop": "Character", "attributes": {"name": "avg_npc_685_1#2$1"}}, {"id": 241, "prop": "PlaySound", "attributes": {"key": "$doorknockquite"}}, {"id": 242, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 243, "prop": "Character", "attributes": {"name": "avg_npc_685_1#1$1"}}, {"id": 244, "prop": "name", "attributes": {"content": "請進。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#1$1"}, {"id": 245, "prop": "Dialog", "attributes": {}}, {"id": 246, "prop": "PlaySound", "attributes": {"key": "$dooropenquite"}}, {"id": 247, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 248, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 249, "prop": "Character", "attributes": {"name": "avg_npc_685_1#1$1", "name2": "avg_npc_684_1#6$1", "focus": 2.0}}, {"id": 250, "prop": "name", "attributes": {"content": "總監，德克薩斯的事情您知道了嗎？！", "name": "空"}, "figure_art": "avg_npc_684_1#6$1"}, {"id": 251, "prop": "Character", "attributes": {"name": "avg_npc_685_1#1$1", "name2": "avg_npc_684_1#6$1", "focus": 1.0}}, {"id": 252, "prop": "name", "attributes": {"content": "我也是剛剛得知。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#1$1"}, {"id": 253, "prop": "Character", "attributes": {"name": "avg_npc_685_1#1$1", "name2": "avg_npc_684_1#6$1", "focus": 2.0}}, {"id": 254, "prop": "name", "attributes": {"content": "您知道什麼內幕嗎？", "name": "空"}, "figure_art": "avg_npc_684_1#6$1"}, {"id": 255, "prop": "Character", "attributes": {"name": "avg_npc_685_1#6$1", "name2": "avg_npc_684_1#6$1", "focus": 1.0}}, {"id": 256, "prop": "name", "attributes": {"content": "至少以我得到的消息來說，是拉維妮婭法官親口宣佈的。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#6$1"}, {"id": 257, "prop": "Character", "attributes": {"name": "avg_npc_685_1#6$1", "name2": "avg_npc_684_1#8$1", "focus": 2.0}}, {"id": 258, "prop": "name", "attributes": {"content": "拉維妮婭，是那位幫助過我的法官小姐......", "name": "空"}, "figure_art": "avg_npc_684_1#8$1"}, {"id": 259, "prop": "Character", "attributes": {"name": "avg_npc_685_1#6$1", "name2": "avg_npc_684_1#6$1", "focus": 2.0}}, {"id": 260, "prop": "name", "attributes": {"content": "她......不像是會說謊的人，但是......", "name": "空"}, "figure_art": "avg_npc_684_1#6$1"}, {"id": 261, "prop": "Character", "attributes": {"name": "avg_npc_685_1#1$1", "name2": "avg_npc_684_1#6$1", "focus": 1.0}}, {"id": 262, "prop": "name", "attributes": {"content": "你想要推掉你的首秀嗎？", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#1$1"}, {"id": 263, "prop": "Character", "attributes": {"name": "avg_npc_685_1#1$1", "name2": "avg_npc_684_1#6$1", "focus": 2.0}}, {"id": 264, "prop": "name", "attributes": {"content": "您......能幫我想一想辦法嗎？", "name": "空"}, "figure_art": "avg_npc_684_1#6$1"}, {"id": 265, "prop": "name", "attributes": {"content": "我想......至少先見一見她。", "name": "空"}, "figure_art": "avg_npc_684_1#6$1"}, {"id": 266, "prop": "Character", "attributes": {"name": "avg_npc_685_1#1$1", "name2": "avg_npc_684_1#6$1", "focus": 1.0}}, {"id": 267, "prop": "name", "attributes": {"content": "且不論你的首秀是否可以推遲......", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#1$1"}, {"id": 268, "prop": "name", "attributes": {"content": "我想知道的是，見到了又如何呢？", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#1$1"}, {"id": 269, "prop": "Character", "attributes": {"name": "avg_npc_685_1#1$1", "name2": "avg_npc_684_1#6$1", "focus": 2.0}}, {"id": 270, "prop": "name", "attributes": {"content": "......", "name": "空"}, "figure_art": "avg_npc_684_1#6$1"}, {"id": 271, "prop": "Character", "attributes": {"name": "avg_npc_685_1#1$1", "name2": "avg_npc_684_1#6$1", "focus": 1.0}}, {"id": 272, "prop": "name", "attributes": {"content": "空小姐，我還記得，你曾經說過，你是為了與她重逢才與另外兩個朋友一起來到敘拉古。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#1$1"}, {"id": 273, "prop": "name", "attributes": {"content": "你一直相信著，你所見到的她，就是真正的她。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#1$1"}, {"id": 274, "prop": "Character", "attributes": {"name": "avg_npc_685_1#5$1", "name2": "avg_npc_684_1#6$1", "focus": 1.0}}, {"id": 275, "prop": "name", "attributes": {"content": "但現在，你已經知道，她隱藏的過去究竟如何。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#5$1"}, {"id": 276, "prop": "name", "attributes": {"content": "你被迫發現，你所追逐的那個人，或許與你的想像相去甚遠。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#5$1"}, {"id": 277, "prop": "name", "attributes": {"content": "見到她，又能怎麼樣呢？", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#5$1"}, {"id": 278, "prop": "name", "attributes": {"content": "你能對她說些什麼，她又能對你說些什麼？", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#5$1"}, {"id": 279, "prop": "Character", "attributes": {"name": "avg_npc_685_1#5$1", "name2": "avg_npc_684_1#6$1", "focus": 2.0}}, {"id": 280, "prop": "name", "attributes": {"content": "......如果真的是這樣，那麼恐怕，擅自想像的我也有責任，或許是我對她還不夠瞭解。", "name": "空"}, "figure_art": "avg_npc_684_1#6$1"}, {"id": 281, "prop": "Character", "attributes": {"name": "avg_npc_685_1#6$1", "name2": "avg_npc_684_1#6$1", "focus": 1.0}}, {"id": 282, "prop": "name", "attributes": {"content": "明明是對方對你有所隱瞞？", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#6$1"}, {"id": 283, "prop": "Character", "attributes": {"name": "avg_npc_685_1#6$1", "name2": "avg_npc_684_1#8$1", "focus": 2.0}}, {"id": 284, "prop": "name", "attributes": {"content": "這也要看對方有沒有理由呀。", "name": "空"}, "figure_art": "avg_npc_684_1#8$1"}, {"id": 285, "prop": "Character", "attributes": {"name": "avg_npc_685_1#6$1", "name2": "avg_npc_684_1#7$1", "focus": 2.0}}, {"id": 286, "prop": "name", "attributes": {"content": "不管怎麼說，貝納爾多先生，在演藝圈這個大染缸裡，我也算是見識過許多人啦。", "name": "空"}, "figure_art": "avg_npc_684_1#7$1"}, {"id": 287, "prop": "name", "attributes": {"content": "要做到表裡如一實在是太難了，至少我認為我是做不到的。", "name": "空"}, "figure_art": "avg_npc_684_1#7$1"}, {"id": 288, "prop": "name", "attributes": {"content": "我總是在想，有一天我也會變得身不由己的。", "name": "空"}, "figure_art": "avg_npc_684_1#7$1"}, {"id": 289, "prop": "name", "attributes": {"content": "所以，我從來都不會去要求別人這麼做。", "name": "空"}, "figure_art": "avg_npc_684_1#7$1"}, {"id": 290, "prop": "name", "attributes": {"content": "每個人都會有秘密，我也有，她也有，想必，您也會有。", "name": "空"}, "figure_art": "avg_npc_684_1#7$1"}, {"id": 291, "prop": "name", "attributes": {"content": "如果對方將他想要展現給我的一面貫徹到底，這難道不也是一種真誠嗎？", "name": "空"}, "figure_art": "avg_npc_684_1#7$1"}, {"id": 292, "prop": "Character", "attributes": {"name": "avg_npc_685_1#4$1", "name2": "avg_npc_684_1#7$1", "focus": 1.0}}, {"id": 293, "prop": "name", "attributes": {"content": "......誠然。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#4$1"}, {"id": 294, "prop": "Character", "attributes": {"name": "avg_npc_685_1#4$1", "name2": "avg_npc_684_1#1$1", "focus": 2.0}}, {"id": 295, "prop": "name", "attributes": {"content": "而且，或許是我那時候沒有說清楚吧。", "name": "空"}, "figure_art": "avg_npc_684_1#1$1"}, {"id": 296, "prop": "name", "attributes": {"content": "我來找德克薩斯，不是想要責備她，不是的。", "name": "空"}, "figure_art": "avg_npc_684_1#1$1"}, {"id": 297, "prop": "Character", "attributes": {"name": "avg_npc_685_1#4$1", "name2": "avg_npc_684_1#8$1", "focus": 2.0}}, {"id": 298, "prop": "name", "attributes": {"content": "我們四個一起在龍門生活了快六年了。", "name": "空"}, "figure_art": "avg_npc_684_1#8$1"}, {"id": 299, "prop": "name", "attributes": {"content": "這六年的生活對我來說是彌足珍貴的。", "name": "空"}, "figure_art": "avg_npc_684_1#8$1"}, {"id": 300, "prop": "name", "attributes": {"content": "而我至少相信，對她來說，也是這樣。", "name": "空"}, "figure_art": "avg_npc_684_1#8$1"}, {"id": 301, "prop": "name", "attributes": {"content": "即使如此，她卻依然不告而別。", "name": "空"}, "figure_art": "avg_npc_684_1#8$1"}, {"id": 302, "prop": "Character", "attributes": {"name": "avg_npc_685_1#4$1", "name2": "avg_npc_684_1#7$1", "focus": 2.0}}, {"id": 303, "prop": "name", "attributes": {"content": "我應該為此憤怒嗎？", "name": "空"}, "figure_art": "avg_npc_684_1#7$1"}, {"id": 304, "prop": "Character", "attributes": {"name": "avg_npc_685_1#4$1", "name2": "avg_npc_684_1#6$1", "focus": 2.0}}, {"id": 305, "prop": "name", "attributes": {"content": "不，我很擔心她。", "name": "空"}, "figure_art": "avg_npc_684_1#6$1"}, {"id": 306, "prop": "Character", "attributes": {"name": "avg_npc_685_1#4$1", "name2": "avg_npc_684_1#1$1", "focus": 2.0}}, {"id": 307, "prop": "name", "attributes": {"content": "能天使和可頌也是這樣的。", "name": "空"}, "figure_art": "avg_npc_684_1#1$1"}, {"id": 308, "prop": "Character", "attributes": {"name": "avg_npc_685_1#4$1", "name2": "avg_npc_684_1#7$1", "focus": 2.0}}, {"id": 309, "prop": "name", "attributes": {"content": "所以，我們才會來到敘拉古。", "name": "空"}, "figure_art": "avg_npc_684_1#7$1"}, {"id": 310, "prop": "name", "attributes": {"content": "如果她被捲進了麻煩的事情裡，那我們就去幫助她脫身。", "name": "空"}, "figure_art": "avg_npc_684_1#7$1"}, {"id": 311, "prop": "name", "attributes": {"content": "如果她的過去沉重到能夠壓垮她，那我們就去和她一起承擔。", "name": "空"}, "figure_art": "avg_npc_684_1#7$1"}, {"id": 312, "prop": "Character", "attributes": {"name": "avg_npc_685_1#1$1", "name2": "avg_npc_684_1#7$1", "focus": 1.0}}, {"id": 313, "prop": "name", "attributes": {"content": "眾多劇作中，關於切利尼娜的末路雖然只是謠傳，但德克薩斯家族的末路卻是眾所周知。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#1$1"}, {"id": 314, "prop": "name", "attributes": {"content": "她的過去恐怕比你想像的要深重得多。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#1$1"}, {"id": 315, "prop": "Character", "attributes": {"name": "avg_npc_685_1#1$1", "name2": "avg_npc_684_1#7$1", "focus": 2.0}}, {"id": 316, "prop": "name", "attributes": {"content": "我知道。", "name": "空"}, "figure_art": "avg_npc_684_1#7$1"}, {"id": 317, "prop": "name", "attributes": {"content": "但我們沒有親口聽到她這麼告訴我們。", "name": "空"}, "figure_art": "avg_npc_684_1#7$1"}, {"id": 318, "prop": "name", "attributes": {"content": "她必須親口告訴我們，她的想法。", "name": "空"}, "figure_art": "avg_npc_684_1#7$1"}, {"id": 319, "prop": "name", "attributes": {"content": "只有這樣，當我們努力的最後結果依然是她要離開，那時，我才能心甘情願地和她告別呀。", "name": "空"}, "figure_art": "avg_npc_684_1#7$1"}, {"id": 320, "prop": "name", "attributes": {"content": "我努力過了，我不後悔的。", "name": "空"}, "figure_art": "avg_npc_684_1#7$1"}, {"id": 321, "prop": "Character", "attributes": {"name": "avg_npc_685_1#1$1", "name2": "avg_npc_684_1#1$1", "focus": 2.0}}, {"id": 322, "prop": "name", "attributes": {"content": "......啊，大概還是會後悔吧，但不會那麼後悔。", "name": "空"}, "figure_art": "avg_npc_684_1#1$1"}, {"id": 323, "prop": "Character", "attributes": {"name": "avg_npc_685_1#8$1", "name2": "avg_npc_684_1#1$1", "focus": 1.0}}, {"id": 324, "prop": "name", "attributes": {"content": "你很有智慧，空小姐。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#8$1"}, {"id": 325, "prop": "Character", "attributes": {"name": "avg_npc_685_1#8$1", "name2": "avg_npc_684_1#9$1", "focus": 2.0}}, {"id": 326, "prop": "name", "attributes": {"content": "我只是給自己的逞強找點藉口而已啦。", "name": "空"}, "figure_art": "avg_npc_684_1#9$1"}, {"id": 327, "prop": "name", "attributes": {"content": "不過，和您這麼說了之後，我也感覺好多了。", "name": "空"}, "figure_art": "avg_npc_684_1#9$1"}, {"id": 328, "prop": "name", "attributes": {"content": "確實，現在即使我真的能見她，恐怕什麼也幫不了她。", "name": "空"}, "figure_art": "avg_npc_684_1#9$1"}, {"id": 329, "prop": "Character", "attributes": {"name": "avg_npc_685_1#8$1", "name2": "avg_npc_684_1#9$1", "focus": 1.0}}, {"id": 330, "prop": "name", "attributes": {"content": "實際上，我都已經準備同意你的要求了。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#8$1"}, {"id": 331, "prop": "name", "attributes": {"content": "在審判之後，你會見到她的，我保證。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#8$1"}, {"id": 332, "prop": "Character", "attributes": {"name": "avg_npc_685_1#8$1", "name2": "avg_npc_684_1#5$1", "focus": 2.0}}, {"id": 333, "prop": "name", "attributes": {"content": "真的嗎！", "name": "空"}, "figure_art": "avg_npc_684_1#5$1"}, {"id": 334, "prop": "Character", "attributes": {"name": "avg_npc_685_1#1$1", "name2": "avg_npc_684_1#5$1", "focus": 1.0}}, {"id": 335, "prop": "name", "attributes": {"content": "不過現在，可能還要再等等。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#1$1"}, {"id": 336, "prop": "Character", "attributes": {"name": "avg_npc_685_1#1$1", "name2": "avg_npc_684_1#9$1", "focus": 2.0}}, {"id": 337, "prop": "name", "attributes": {"content": "謝謝您，在那之前，我會好好準備的。", "name": "空"}, "figure_art": "avg_npc_684_1#9$1"}, {"id": 338, "prop": "Character", "attributes": {"name": "avg_npc_685_1#8$1", "name2": "avg_npc_684_1#9$1", "focus": 1.0}}, {"id": 339, "prop": "name", "attributes": {"content": "呵呵。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#8$1"}, {"id": 340, "prop": "name", "attributes": {"content": "真遺憾，我不能親眼看到你的首秀了。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#8$1"}, {"id": 341, "prop": "Character", "attributes": {"name": "avg_npc_685_1#8$1", "name2": "avg_npc_684_1#1$1", "focus": 2.0}}, {"id": 342, "prop": "name", "attributes": {"content": "欸？您不看嗎？", "name": "空"}, "figure_art": "avg_npc_684_1#1$1"}, {"id": 343, "prop": "Character", "attributes": {"name": "avg_npc_685_1#8$1", "name2": "avg_npc_684_1#1$1", "focus": 1.0}}, {"id": 344, "prop": "name", "attributes": {"content": "是啊，那天，我恐怕會有一些重要的事情要處理。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#8$1"}, {"id": 345, "prop": "name", "attributes": {"content": "但是，你可以放心，我已經為你準備好了最好的舞台。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#8$1"}, {"id": 346, "prop": "Character", "attributes": {"name": "avg_npc_685_1#8$1", "name2": "avg_npc_684_1#9$1", "focus": 2.0}}, {"id": 347, "prop": "name", "attributes": {"content": "謝謝！", "name": "空"}, "figure_art": "avg_npc_684_1#9$1"}, {"id": 348, "prop": "name", "attributes": {"content": "那我就先回去了。", "name": "空"}, "figure_art": "avg_npc_684_1#9$1"}, {"id": 349, "prop": "Character", "attributes": {"name": "avg_npc_685_1#8$1", "name2": "avg_npc_684_1#9$1", "focus": 1.0}}, {"id": 350, "prop": "name", "attributes": {"content": "去吧。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#8$1"}, {"id": 351, "prop": "Dialog", "attributes": {}}, {"id": 352, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.7}}, {"id": 353, "prop": "Character", "attributes": {"name": "avg_npc_685_1#8$1", "name2": "char_empty", "fadetime": 1.0}}, {"id": 354, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 355, "prop": "PlaySound", "attributes": {"key": "$doorclosequite"}}, {"id": 356, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 357, "prop": "Character", "attributes": {"name": "avg_npc_685_1#6$1", "name2": "char_empty", "fadetime": 1.0}}, {"id": 358, "prop": "name", "attributes": {"content": "......", "name": "貝納爾多"}}, {"id": 359, "prop": "Character", "attributes": {}}, {"id": 360, "prop": "name", "attributes": {"content": "貝納爾多走到書架邊，從書架上抽出一本書。"}}, {"id": 361, "prop": "name", "attributes": {"content": "那是一本環繞著荊棘的法典。"}}, {"id": 362, "prop": "name", "attributes": {"content": "他沉默良久，最後，撥通一個電話。"}}, {"id": 363, "prop": "PlaySound", "attributes": {"key": "$d_avg_telephone"}}, {"id": 364, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 365, "prop": "Character", "attributes": {"name": "avg_npc_685_1#2$1"}}, {"id": 366, "prop": "name", "attributes": {"content": "......德米特，告訴她，就說，我答應了。", "name": "貝納爾多"}, "figure_art": "avg_npc_685_1#2$1"}, {"id": 367, "prop": "Character", "attributes": {}}, {"id": 368, "prop": "PlaySound", "attributes": {"key": "$d_gen_thunders_amb", "volume": 0.5}}, {"id": 369, "prop": "PlaySound", "attributes": {"key": "$d_gen_thunders_amb", "volume": 0.3, "Delay": 0.7, "channel": "a"}}, {"id": 370, "prop": "name", "attributes": {"content": "“轟”的一聲，窗外，雷聲翻湧。"}}, {"id": 371, "prop": "name", "attributes": {"content": "像是在預告著，大雨將至。"}}, {"id": 372, "prop": "Dialog", "attributes": {}}, {"id": 373, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 374, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 375, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 376, "prop": "Character", "attributes": {}}, {"id": 377, "prop": "Image", "attributes": {}}, {"id": 378, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}