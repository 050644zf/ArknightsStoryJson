_art": "avg_4065_judge_1#7$1"}, {"id": 78, "prop": "name", "attributes": {"content": "這條線索斷了，我還要去找別的線索。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#7$1"}, {"id": 79, "prop": "Character", "attributes": {"name": "avg_1028_texas2_1#1$1"}}, {"id": 80, "prop": "name", "attributes": {"content": "炎國有一句諺語，叫“欲速則不達”。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 81, "prop": "Character", "attributes": {"name": "avg_4065_judge_1#5$1"}}, {"id": 82, "prop": "name", "attributes": {"content": "......我當然知道這個道理。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#5$1"}, {"id": 83, "prop": "name", "attributes": {"content": "但是，我沒有那麼多時間了。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#5$1"}, {"id": 84, "prop": "Character", "attributes": {"name": "avg_1028_texas2_1#1$1"}}, {"id": 85, "prop": "name", "attributes": {"content": "卡拉奇對你來說，是個很重要的人嗎？", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 86, "prop": "Character", "attributes": {"name": "avg_4065_judge_1#8$1"}}, {"id": 87, "prop": "name", "attributes": {"content": "......不。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#8$1"}, {"id": 88, "prop": "name", "attributes": {"content": "我和卡拉奇部長並沒有見過幾次。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#8$1"}, {"id": 89, "prop": "name", "attributes": {"content": "畢竟我是法官，和他在職能上相差很遠。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#8$1"}, {"id": 90, "prop": "Character", "attributes": {"name": "avg_4065_judge_1#1$1"}}, {"id": 91, "prop": "name", "attributes": {"content": "但是，凡是沃爾西尼的居民都知道，他是一個非常具有活力的人，圓滑地處理著和家族的關係。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 92, "prop": "name", "attributes": {"content": "他花費了全部的精力在新城區的建設上，用盡各種手段來保證市民們能有一個比較安全的地方。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 93, "prop": "name", "attributes": {"content": "因為調查他的死，我開始真正瞭解這個人。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 94, "prop": "Character", "attributes": {"name": "avg_4065_judge_1#7$1"}}, {"id": 95, "prop": "name", "attributes": {"content": "戰戰兢兢，如履薄冰，絞盡腦汁用手頭上能交換的一切，來博得一點點能做事的空間。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#7$1"}, {"id": 96, "prop": "name", "attributes": {"content": "比如，在遠離家族利益紛爭的區塊多建幾所學校，多建幾所醫院......", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#7$1"}, {"id": 97, "prop": "Character", "attributes": {"name": "avg_4065_judge_1#6$1"}}, {"id": 98, "prop": "name", "attributes": {"content": "我不知道該怎麼評價他，或許，只是個有點良心的好人吧。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#6$1"}, {"id": 99, "prop": "name", "attributes": {"content": "但好人在敘拉古的結局是註定的。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#6$1"}, {"id": 100, "prop": "Character", "attributes": {"name": "avg_1028_texas2_1#5$1"}}, {"id": 101, "prop": "name", "attributes": {"content": "......和這個揣著法官證的殺手一樣。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#5$1"}, {"id": 102, "prop": "Character", "attributes": {"name": "avg_4065_judge_1#6$1"}}, {"id": 103, "prop": "name", "attributes": {"content": "敘拉古是有正規的法律學校的。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#6$1"}, {"id": 104, "prop": "name", "attributes": {"content": "使用的是哥倫比亞出版的教材，畢業後，不僅可以在敘拉古本地的法律機構任職。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#6$1"}, {"id": 105, "prop": "name", "attributes": {"content": "也擁有被哥倫比亞承認的資質。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#6$1"}, {"id": 106, "prop": "name", "attributes": {"content": "如今，我們和龍門的來往也越來越頻繁了，再過一段時間，炎國可能也會承認這方面的資質。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#6$1"}, {"id": 107, "prop": "Character", "attributes": {"name": "avg_1028_texas2_1#1$1"}}, {"id": 108, "prop": "name", "attributes": {"content": "聽起來是一件好事。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 109, "prop": "Character", "attributes": {"name": "avg_4065_judge_1#1$1"}}, {"id": 110, "prop": "name", "attributes": {"content": "是啊，當然是好事。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 111, "prop": "name", "attributes": {"content": "但是，這不會影響任何事情。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 112, "prop": "name", "attributes": {"content": "我的母校曾經邀請過我回去為學弟學妹們演講，給他們一些信心。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 113, "prop": "name", "attributes": {"content": "我去了。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 114, "prop": "name", "attributes": {"content": "但是，當我站上台的時候，我發現，我沒有辦法告訴他們，相信自己學到的東西。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 115, "prop": "Character", "attributes": {"name": "avg_4065_judge_1#8$1"}}, {"id": 116, "prop": "name", "attributes": {"content": "......", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#8$1"}, {"id": 117, "prop": "name", "attributes": {"content": "法律之所以生效，在敘拉古，竟然是因為一個人的存在，而不是它真的基於一種被認可的公平。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#8$1"}, {"id": 118, "prop": "name", "attributes": {"content": "某種意義上，這比無法之地還要荒唐。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#8$1"}, {"id": 119, "prop": "name", "attributes": {"content": "而敘拉古人居然真的在這種環境下生活了將近六十年，以至於當所有人都習慣之後，沒有人再敢質疑這一切。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#8$1"}, {"id": 120, "prop": "Character", "attributes": {"name": "avg_4065_judge_1#14$1"}}, {"id": 121, "prop": "name", "attributes": {"content": "我是公正的化身嗎？不，我是一個化身，但連我自己也不知道，我的背後是什麼。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#14$1"}, {"id": 122, "prop": "Character", "attributes": {"name": "avg_1028_texas2_1#1$1"}}, {"id": 123, "prop": "name", "attributes": {"content": "......要去吃點東西嗎？", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 124, "prop": "Character", "attributes": {"name": "avg_4065_judge_1#11$1"}}, {"id": 125, "prop": "name", "attributes": {"content": "......要的。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#11$1"}, {"id": 126, "prop": "name", "attributes": {"content": "謝謝。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#11$1"}, {"id": 127, "prop": "dialog", "attributes": {}}, {"id": 128, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 129, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 130, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 131, "prop": "Background", "attributes": {"image": "33_g10_smallrestaurant", "screenadapt": "coverall"}}, {"id": 132, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1"}}, {"id": 133, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 134, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 135, "prop": "Character", "attributes": {"name": "avg_4065_judge_1#1$1"}}, {"id": 136, "prop": "name", "attributes": {"content": "我沒想到你會在這，萊昂。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 137, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#1$1", "focus": 1.0}}, {"id": 138, "prop": "name", "attributes": {"content": "我聽說你遭到了襲擊，就趕來了。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 139, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#1$1", "focus": 2.0}}, {"id": 140, "prop": "name", "attributes": {"content": "沒出什麼大事，德克薩斯幫了我。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 141, "prop": "name", "attributes": {"content": "只是線索斷了。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 142, "prop": "Dialog", "attributes": {}}, {"id": 143, "prop": "StopMusic", "attributes": {"fadetime": 1.0}}, {"id": 144, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#1$1", "focus": 1.0}}, {"id": 145, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 146, "prop": "name", "attributes": {"content": "收手吧，拉維妮婭。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 147, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#2$1", "focus": 2.0}}, {"id": 148, "prop": "PlayMusic", "attributes": {"intro": "$m_bat_imprisonment_intro", "key": "$m_bat_imprisonment_loop", "volume": 0.6}}, {"id": 149, "prop": "name", "attributes": {"content": "......萊昂，我們應該有過約定，不在吃飯時聊會吵架的事。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#2$1"}, {"id": 150, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#2$1", "focus": 1.0}}, {"id": 151, "prop": "name", "attributes": {"content": "現在不是說這個的時候。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 152, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#1$1", "focus": 2.0}}, {"id": 153, "prop": "name", "attributes": {"content": "不，這是我們唯一能無視各自的立場坐在一起吃飯的方法。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 154, "prop": "name", "attributes": {"content": "如果你打算打破這個約定，那我就先告辭了，萊昂圖索閣下。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 155, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 156, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#4$1", "name2": "avg_4065_judge_1#1$1", "focus": 1.0}}, {"id": 157, "prop": "name", "attributes": {"content": "你這是在拿你自己的性命開玩笑！", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#4$1"}, {"id": 158, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#4$1", "name2": "avg_4065_judge_1#8$1", "focus": 2.0}}, {"id": 159, "prop": "name", "attributes": {"content": "......從當上這座城市的法官那一刻起，我就在拿自己的性命“開玩笑”了，閣下。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#8$1"}, {"id": 160, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#8$1", "focus": 1.0}}, {"id": 161, "prop": "name", "attributes": {"content": "我打算去和羅塞蒂談。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 162, "prop": "name", "attributes": {"content": "無論他們對切利尼娜的存在怎麼反應，他們都必須要和我們談。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 163, "prop": "name", "attributes": {"content": "主動權在我們手上，只要能牽制住他們，無論是內鬼也好，還是其他家族也好，都會被壓住。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 164, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#1$1", "focus": 2.0}}, {"id": 165, "prop": "name", "attributes": {"content": "問題並不出在這裡。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 166, "prop": "name", "attributes": {"content": "城裡現在局勢十分緊張，所有人都在猜是誰下的手，如果不穩住局勢，情況也會變得越來越糟糕。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 167, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#1$1", "focus": 1.0}}, {"id": 168, "prop": "name", "attributes": {"content": "說實話，如果你真的能找到兇手的話，我會不遺餘力地幫你推進下去。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 169, "prop": "name", "attributes": {"content": "但是現在，對方明顯有備而來，你今天遇到的事，毫無疑問是一次警告。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 170, "prop": "name", "attributes": {"content": "再繼續下去，你的調查也不會有任何進展，只會遇到更多危險。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 171, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#7$1", "focus": 2.0}}, {"id": 172, "prop": "name", "attributes": {"content": "所以我應該聽從你的安排，中止調查，讓這件事不了了之？", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#7$1"}, {"id": 173, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#7$1", "focus": 1.0}}, {"id": 174, "prop": "name", "attributes": {"content": "拉維妮婭，你不是一個會意氣用事的人。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 175, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#7$1", "focus": 2.0}}, {"id": 176, "prop": "name", "attributes": {"content": "萊昂，你跟卡拉奇部長共事過，你應當更加瞭解他。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#7$1"}, {"id": 177, "prop": "name", "attributes": {"content": "無論他是以什麼樣的原因坐到了那個位置上，他都是一個能讓城市變好的人。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#7$1"}, {"id": 178, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#7$1", "focus": 1.0}}, {"id": 179, "prop": "name", "attributes": {"content": "這樣的事，每天都在發生。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 180, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#6$1", "focus": 2.0}}, {"id": 181, "prop": "name", "attributes": {"content": "所以，在敘拉古，想做一個好人就一定會死嗎？", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#6$1"}, {"id": 182, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#6$1", "focus": 1.0}}, {"id": 183, "prop": "name", "attributes": {"content": "......", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 184, "prop": "name", "attributes": {"content": "對我來說，你比他要重要。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 185, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#8$1", "focus": 2.0}}, {"id": 186, "prop": "name", "attributes": {"content": "卡拉奇部長的死，對你來說，或許就像一場稍大的雨。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#8$1"}, {"id": 187, "prop": "name", "attributes": {"content": "雨淋不到站在室內的你，你只是會奇怪，雨為什麼會下這麼久。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#8$1"}, {"id": 188, "prop": "name", "attributes": {"content": "如果你足夠好心，還會想去給雨中的人送傘。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#8$1"}, {"id": 189, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#2$1", "focus": 2.0}}, {"id": 190, "prop": "name", "attributes": {"content": "但對我來說......我已經不想再問自己，我要站在屋簷下等到什麼時候了。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#2$1"}, {"id": 191, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#2$1", "focus": 1.0}}, {"id": 192, "prop": "name", "attributes": {"content": "......", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 193, "prop": "name", "attributes": {"content": "......但你只有一個人，要怎麼阻止一場雨？", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 194, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#1$1", "focus": 2.0}}, {"id": 195, "prop": "name", "attributes": {"content": "至少這一次，我不希望眼睜睜地看著卡拉奇部長那樣的人平白死去而沒有作為。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 196, "prop": "name", "attributes": {"content": "我已經做過太多違心的事情了。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 197, "prop": "name", "attributes": {"content": "如果，我是說如果，萊昂，我的生命能夠用來換些什麼。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 198, "prop": "name", "attributes": {"content": "我或許還會覺得好受一些。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 199, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#1$1", "focus": 1.0}}, {"id": 200, "prop": "name", "attributes": {"content": "......", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 201, "prop": "name", "attributes": {"content": "我從哥倫比亞人身上學到的事情是——", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 202, "prop": "name", "attributes": {"content": "想要別人聽我的話，有的時候，利益比暴力更有用。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 203, "prop": "name", "attributes": {"content": "但這並不意味著我不會行使暴力，拉維妮婭。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 204, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#1$1", "focus": 2.0}}, {"id": 205, "prop": "name", "attributes": {"content": "而這正是我說的，你我之間最大的差異。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 206, "prop": "name", "attributes": {"content": "你坐擁暴力，你以教養和自制讓自己不去使用，而我甚至要為你的仁慈而感謝你。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 207, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#1$1", "focus": 1.0}}, {"id": 208, "prop": "name", "attributes": {"content": "......我不是這個意思。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 209, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#1$1", "focus": 2.0}}, {"id": 210, "prop": "name", "attributes": {"content": "而我也不是在責怪你，萊昂。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 211, "prop": "name", "attributes": {"content": "你願意去想雨為什麼會下這麼久，已經非常難得了。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 212, "prop": "name", "attributes": {"content": "但是，你是貝洛內家族的下一任家主。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 213, "prop": "name", "attributes": {"content": "我只是一個身不由己的法官。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 214, "prop": "name", "attributes": {"content": "我們的立場始終是不同的。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 215, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#8$1", "focus": 2.0}}, {"id": 216, "prop": "name", "attributes": {"content": "就這樣吧，萊昂。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#8$1"}, {"id": 217, "prop": "name", "attributes": {"content": "如果你真的想幫我，那就繼續做你該做的事。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#8$1"}, {"id": 218, "prop": "name", "attributes": {"content": "你真的能和羅塞蒂談妥，對局勢也一定會有幫助。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#8$1"}, {"id": 219, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1", "name2": "avg_4065_judge_1#7$1", "focus": 2.0}}, {"id": 220, "prop": "name", "attributes": {"content": "只是，除非你現在將我關起來，否則，誰也不能阻止我，找到真正的兇手。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#7$1"}, {"id": 221, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#2$1", "name2": "avg_4065_judge_1#7$1", "focus": 1.0}}, {"id": 222, "prop": "name", "attributes": {"content": "......", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#2$1"}, {"id": 223, "prop": "name", "attributes": {"content": "餐廳裡寂靜無聲。"}}, {"id": 224, "prop": "name", "attributes": {"content": "萊昂圖索想要再說些什麼，但他發現自己能想到的一切語言都是蒼白的。"}}, {"id": 225, "prop": "name", "attributes": {"content": "喉結翻動了兩下，他沒有說出一句話。"}}, {"id": 226, "prop": "Character", "attributes": {"name": "avg_1028_texas2_1#1$1"}}, {"id": 227, "prop": "name", "attributes": {"content": "等等。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 228, "prop": "Character", "attributes": {"name": "avg_4065_judge_1#4$1"}}, {"id": 229, "prop": "name", "attributes": {"content": "德克薩斯？", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#4$1"}, {"id": 230, "prop": "Character", "attributes": {"name": "avg_4065_judge_1#1$1"}}, {"id": 231, "prop": "name", "attributes": {"content": "對了，你也回去萊昂身邊吧，他和羅塞蒂的談判會需要你。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 232, "prop": "Character", "attributes": {"name": "avg_1028_texas2_1#1$1"}}, {"id": 233, "prop": "name", "attributes": {"content": "不，我有一個更好的辦法。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 234, "prop": "Character", "attributes": {"name": "avg_1028_texas2_1#2$1"}}, {"id": 235, "prop": "name", "attributes": {"content": "你不是需要一個兇手嗎，我來做這個兇手。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#2$1"}, {"id": 236, "prop": "Character", "attributes": {"name": "avg_4065_judge_1#15$1"}}, {"id": 237, "prop": "name", "attributes": {"content": "......你知道自己在說什麼嗎？", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#15$1"}, {"id": 238, "prop": "Character", "attributes": {"name": "avg_1028_texas2_1#1$1"}}, {"id": 239, "prop": "name", "attributes": {"content": "這是能穩定局勢最快的方法。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 240, "prop": "Character", "attributes": {"name": "avg_4065_judge_1#7$1"}}, {"id": 241, "prop": "name", "attributes": {"content": "......我不用別人來憐憫我。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#7$1"}, {"id": 242, "prop": "Character", "attributes": {"name": "avg_1028_texas2_1#1$1"}}, {"id": 243, "prop": "name", "attributes": {"content": "不要誤會。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 244, "prop": "name", "attributes": {"content": "我是為了我自己。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 245, "prop": "Character", "attributes": {"name": "avg_1028_texas2_1#7$1"}}, {"id": 246, "prop": "name", "attributes": {"content": "你們都是對的，再這樣下去，局勢只會更加糟糕，幕後黑手也會更加難找到。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#7$1"}, {"id": 247, "prop": "name", "attributes": {"content": "在局勢進一步惡化之前找到兇手是最理想的辦法。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#7$1"}, {"id": 248, "prop": "name", "attributes": {"content": "而對方顯然也會千方百計地阻止。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#7$1"}, {"id": 249, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#5$1"}}, {"id": 250, "prop": "name", "attributes": {"content": "你是說，你來當誘餌？", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#5$1"}, {"id": 251, "prop": "Character", "attributes": {"name": "avg_1028_texas2_1#1$1"}}, {"id": 252, "prop": "name", "attributes": {"content": "嗯。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 253, "prop": "name", "attributes": {"content": "其他人份量不夠，我來正合適。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 254, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#7$1"}}, {"id": 255, "prop": "name", "attributes": {"content": "......", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#7$1"}, {"id": 256, "prop": "name", "attributes": {"content": "將德克薩斯真的推作犯人，透過犧牲一點名譽，將過錯都推到自己家族的識人不明上。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#7$1"}, {"id": 257, "prop": "Character", "attributes": {"name": "avg_1028_texas2_1#1$1"}}, {"id": 258, "prop": "name", "attributes": {"content": "然後，你們就可以放我離開。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 259, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1"}}, {"id": 260, "prop": "name", "attributes": {"content": "這能夠最快速度穩定局勢，並且，還能借此引出幕後黑手。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 261, "prop": "name", "attributes": {"content": "......很冒險，但或許有用。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 262, "prop": "name", "attributes": {"content": "不過......你是德克薩斯最後的血脈，而這裡是敘拉古。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 263, "prop": "Character", "attributes": {"name": "avg_1028_texas2_1#8$1"}}, {"id": 264, "prop": "name", "attributes": {"content": "......對我來說，最無所謂的東西，就是德克薩斯這個姓氏帶給我的名譽。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#8$1"}, {"id": 265, "prop": "Character", "attributes": {"name": "avg_1028_texas2_1#1$1"}}, {"id": 266, "prop": "name", "attributes": {"content": "我說過，我的目的只有一個，那就是完成和貝洛內的約定，離開敘拉古。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 267, "prop": "Character", "attributes": {"name": "avg_4065_judge_1#8$1"}}, {"id": 268, "prop": "name", "attributes": {"content": "你......為什麼要做到這一步？", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#8$1"}, {"id": 269, "prop": "Character", "attributes": {"name": "avg_1028_texas2_1#1$1"}}, {"id": 270, "prop": "name", "attributes": {"content": "我也有不少想要讓事情變好的朋友，在一個叫羅德島的地方。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 271, "prop": "name", "attributes": {"content": "我同樣不會接受她們輕易死去。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 272, "prop": "Character", "attributes": {"name": "avg_4065_judge_1#6$1"}}, {"id": 273, "prop": "name", "attributes": {"content": "......", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#6$1"}, {"id": 274, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#7$1"}}, {"id": 275, "prop": "name", "attributes": {"content": "這個方法如果順利的話——", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#7$1"}, {"id": 276, "prop": "name", "attributes": {"content": "甚至可能直接反將幕後黑手一軍。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#7$1"}, {"id": 277, "prop": "name", "attributes": {"content": "我現在開始慶幸，你願意站在我們這一邊了。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#7$1"}, {"id": 278, "prop": "Character", "attributes": {"name": "avg_1028_texas2_1#1$1"}}, {"id": 279, "prop": "name", "attributes": {"content": "不用。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 280, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#7$1"}}, {"id": 281, "prop": "name", "attributes": {"content": "既然這麼決定了，那這場審判，肯定動靜要鬧得大一些，最後才能鎮住其他家族。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#7$1"}, {"id": 282, "prop": "name", "attributes": {"content": "我會安排下去。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#7$1"}, {"id": 283, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1"}}, {"id": 284, "prop": "name", "attributes": {"content": "接下來，輪到我們反擊了。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 285, "prop": "Character", "attributes": {"name": "avg_1028_texas2_1#1$1"}}, {"id": 286, "prop": "name", "attributes": {"content": "那麼，你能給我一個讓我離開敘拉古的承諾嗎？", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 287, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#1$1"}}, {"id": 288, "prop": "name", "attributes": {"content": "我向你保證，等我們的計劃成功，沒有人會追究你的去向。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 289, "prop": "name", "attributes": {"content": "那些關注著你的人，羅塞蒂也好，其他家族也好，只會知道......", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 290, "prop": "name", "attributes": {"content": "“切利尼娜·德克薩斯越獄了，如今已經離開了敘拉古。”", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#1$1"}, {"id": 291, "prop": "Character", "attributes": {"name": "avg_427_vigil_1#7$1"}}, {"id": 292, "prop": "name", "attributes": {"content": "抱歉，拉維妮婭，這或許有損法律的尊嚴。", "name": "萊昂圖索"}, "figure_art": "avg_427_vigil_1#7$1"}, {"id": 293, "prop": "Character", "attributes": {"name": "avg_4065_judge_1#2$1"}}, {"id": 294, "prop": "name", "attributes": {"content": "......我沒那麼古板。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#2$1"}, {"id": 295, "prop": "Character", "attributes": {"name": "avg_4065_judge_1#15$1"}}, {"id": 296, "prop": "name", "attributes": {"content": "如今......只能做下去了。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#15$1"}, {"id": 297, "prop": "Dialog", "attributes": {}}, {"id": 298, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 299, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 300, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 301, "prop": "Character", "attributes": {}}, {"id": 302, "prop": "Image", "attributes": {}}, {"id": 303, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}