butes": {"content": "等等！", "name": "喬迪"}, "figure_art": "avg_npc_1380_1#7$1"}, {"id": 167, "prop": "dialog", "attributes": {}}, {"id": 168, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0}}, {"id": 169, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,0", "posto": "-200,0", "afrom": 1.0, "ato": 0.0, "duration": 0.8, "isblock": "true"}}, {"id": 170, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 171, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 172, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 173, "prop": "charslot", "attributes": {}}, {"id": 174, "prop": "Background", "attributes": {}}, {"id": 175, "prop": "PlaySound", "attributes": {"key": "$e_atk_saw_n_2", "volume": 1.0}}, {"id": 176, "prop": "delay", "attributes": {"time": 0.6}}, {"id": 177, "prop": "PlaySound", "attributes": {"key": "$e_atk_saw_n_1", "volume": 1.0}}, {"id": 178, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 179, "prop": "name", "attributes": {"content": "圓鋸的聲音太大，斯卡蒂，你來開路。", "name": "歌蕾蒂婭"}}, {"id": 180, "prop": "name", "attributes": {"content": "切開這叢珊瑚，盡量別鬧出太大的聲響。", "name": "歌蕾蒂婭"}}, {"id": 181, "prop": "name", "attributes": {"content": "好。", "name": "斯卡蒂"}}, {"id": 182, "prop": "dialog", "attributes": {}}, {"id": 183, "prop": "PlaySound", "attributes": {"key": "$e_skill_skulsrsword", "volume": 1.0}}, {"id": 184, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 185, "prop": "PlaySound", "attributes": {"key": "$d_avg_seawaterinflux", "volume": 0.4}}, {"id": 186, "prop": "PlaySound", "attributes": {"key": "$d_avg_rockfall", "volume": 1.0, "loop": "true", "channel": "r"}}, {"id": 187, "prop": "StopSound", "attributes": {"channel": "r", "fadetime": 2.0}}, {"id": 188, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 189, "prop": "PlaySound", "attributes": {"key": "$d_avg_underwtr", "volume": 1.0, "loop": "true", "channel": "u"}}, {"id": 190, "prop": "Background", "attributes": {"image": "51_g13_seabornnest", "x": 200.0, "xScale": 1.4, "yScale": 1.4, "screenadapt": "coverall", "fadetime": 6.0}}, {"id": 191, "prop": "focusout", "attributes": {"type": "bg", "id": "51_g13_seabornnest", "from": 0.0, "to": 1.0, "duration": 20.0, "block": "false"}}, {"id": 192, "prop": "backgroundTween", "attributes": {"xFrom": 200.0, "duration": 20.0, "block": "false"}}, {"id": 193, "prop": "curtain", "attributes": {"direction": 0.0, "fillfrom": 0.01, "fillto": 0.15, "fadetime": 0.1}}, {"id": 194, "prop": "curtain", "attributes": {"direction": 4.0, "fillfrom": 0.01, "fillto": 0.15, "fadetime": 0.1}}, {"id": 195, "prop": "PlayMusic", "attributes": {"intro": "$act18d3d0_intro", "key": "$act18d3d0_loop", "volume": 0.6}}, {"id": 196, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 197, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 198, "prop": "name", "attributes": {"content": "只一瞬間，幽艷的色彩與迷離的光影包圍了闖入的獵人們。"}}, {"id": 199, "prop": "name", "attributes": {"content": "被伊比利亞人稱作溟痕的生物在層疊的珊瑚間游曳，群卵在嶙峋的岩壁上搖擺。"}}, {"id": 200, "prop": "name", "attributes": {"content": "隨水流經過，不斷有卵從岩壁上脫落，它們飛旋著變換形態，舒展著不可名狀的褶皺，直至海嗣的模樣從中顯現。"}}, {"id": 201, "prop": "dialog", "attributes": {}}, {"id": 202, "prop": "SoundVolume", "attributes": {"volume": 0.5, "channel": "a", "fadetime": 2.0}}, {"id": 203, "prop": "Background", "attributes": {"image": "51_g13_seabornnest", "xScale": 1.4, "yScale": 1.4, "screenadapt": "coverall", "fadetime": 2.0}}, {"id": 204, "prop": "PlaySound", "attributes": {"key": "$d_avg_seabornactivity_1", "volume": 0.4}}, {"id": 205, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1388_1#1$1", "posfrom": "0,100", "posto": "0,50", "duration": 1.5, "isblock": "true"}}, {"id": 206, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 207, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1388_1#1$1", "posfrom": "100,50", "posto": "-100,50", "duration": 1.5}}, {"id": 208, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 209, "prop": "charslot", "attributes": {"slot": "l", "focus": "l"}}, {"id": 210, "prop": "name", "attributes": {"content": "（鼓動柔軟的膜）", "name": "新生的海嗣"}, "figure_art": "avg_npc_1388_1#1$1"}, {"id": 211, "prop": "dialog", "attributes": {}}, {"id": 212, "prop": "PlaySound", "attributes": {"key": "$d_avg_seabornactivity_intense", "volume": 1.0}}, {"id": 213, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1388_1#1$1", "posfrom": "-100,50", "posto": "100,50", "duration": 1.5}}, {"id": 214, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 215, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 216, "prop": "name", "attributes": {"content": "（扇動多褶的皮）", "name": "新生的海嗣"}, "figure_art": "avg_npc_1388_1#1$1"}, {"id": 217, "prop": "dialog", "attributes": {}}, {"id": 218, "prop": "charslot", "attributes": {"slot": "all", "focus": "all"}}, {"id": 219, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 220, "prop": "curtain", "attributes": {"direction": 0.0, "fillfrom": 0.15, "fillto": 0.0, "fadetime": 4.0}}, {"id": 221, "prop": "curtain", "attributes": {"direction": 4.0, "fillfrom": 0.15, "fillto": 0.0, "fadetime": 4.0}}, {"id": 222, "prop": "backgroundTween", "attributes": {"yFrom": 0.0, "duration": 4.0, "block": "false"}}, {"id": 223, "prop": "Background", "attributes": {"image": "51_g13_seabornnest", "screenadapt": "coverall", "fadetime": 4.0}}, {"id": 224, "prop": "focusout", "attributes": {"type": "bg", "id": "51_g13_seabornnest", "from": 1.0, "to": 0.0, "duration": 4.0, "block": "false"}}, {"id": 225, "prop": "PlaySound", "attributes": {"key": "$d_avg_seahumansurface", "volume": 1.0}}, {"id": 226, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "-100,50", "posto": "-50,200", "afrom": 1.0, "ato": 0.0, "duration": 2.0}}, {"id": 227, "prop": "charslot", "attributes": {"slot": "l", "action": "zoom", "poszoom": "0.5,0.5", "scale": 0.8, "duration": 2.0}}, {"id": 228, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,50", "posto": "0,200", "afrom": 1.0, "ato": 0.0, "duration": 2.0}}, {"id": 229, "prop": "charslot", "attributes": {"slot": "m", "action": "zoom", "poszoom": "0.5,0.5", "scale": 0.8, "duration": 2.0}}, {"id": 230, "prop": "charslot", "attributes": {"slot": "r", "posfrom": "100,50", "posto": "50,200", "afrom": 1.0, "ato": 0.0, "duration": 2.0}}, {"id": 231, "prop": "charslot", "attributes": {"slot": "r", "action": "zoom", "poszoom": "0.5,0.5", "scale": 0.8, "duration": 2.0}}, {"id": 232, "prop": "delay", "attributes": {"time": 4.0}}, {"id": 233, "prop": "name", "attributes": {"content": "新生的個體們無聲地聚集，它們身體的震顫在整個巢穴中迴盪。觸肢與須腕相互鈎連，海嗣彼此裹挾著向遠方湧去。"}}, {"id": 234, "prop": "dialog", "attributes": {}}, {"id": 235, "prop": "charslot", "attributes": {}}, {"id": 236, "prop": "charslot", "attributes": {"slot": "m", "name": "char_263_skadi#7"}}, {"id": 237, "prop": "name", "attributes": {"content": "它們還在源源不斷地離開巢穴，趕去……前線。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#7"}, {"id": 238, "prop": "charslot", "attributes": {"slot": "m", "name": "char_263_skadi#6"}}, {"id": 239, "prop": "name", "attributes": {"content": "等等，你們不覺得有什麼異常嗎？剛剛那隻就這麼憑空變成了好幾個？", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#6"}, {"id": 240, "prop": "name", "attributes": {"content": "它在幹什麼？增殖？分裂？", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#6"}, {"id": 241, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1023_ghost2_1#13$1"}}, {"id": 242, "prop": "name", "attributes": {"content": "上次救援艦隊時我就隱隱覺得不安，劍魚，這些傢伙是不是又進化了？", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#13$1"}, {"id": 243, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_474_gladiia_1#1"}}, {"id": 244, "prop": "name", "attributes": {"content": "海嗣永遠在進化。", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#1"}, {"id": 245, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1023_ghost2_1#13$1"}}, {"id": 246, "prop": "name", "attributes": {"content": "斯卡蒂，你還記得自己殺死的第一隻海嗣嗎？", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#13$1"}, {"id": 247, "prop": "charslot", "attributes": {"slot": "m", "name": "char_263_skadi#3"}}, {"id": 248, "prop": "name", "attributes": {"content": "記不清了，只記得那東西長了很多觸手。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#3"}, {"id": 249, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1023_ghost2_1#10$1"}}, {"id": 250, "prop": "name", "attributes": {"content": "是啊。觸手、尖刺、幾丁質外殼……至少還是可以辨認的器官，一眼就能看出功能。", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#10$1"}, {"id": 251, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_474_gladiia_1#1"}}, {"id": 252, "prop": "name", "attributes": {"content": "先前，海嗣還只是擅於攫取其他物種千萬年來積累下來的進化成果。", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#1"}, {"id": 253, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1023_ghost2_1#10$1"}}, {"id": 254, "prop": "name", "attributes": {"content": "可眼前這些東西……", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#10$1"}, {"id": 255, "prop": "dialog", "attributes": {}}, {"id": 256, "prop": "charslot", "attributes": {}}, {"id": 257, "prop": "PlaySound", "attributes": {"key": "$d_avg_swimdeepsea", "volume": 1.0}}, {"id": 258, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1388_1#1$1", "posfrom": "0,-50", "posto": "0,80", "duration": 1.5}}, {"id": 259, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 260, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1388_1#1$1", "posfrom": "0,-100", "posto": "0,-30", "duration": 1.5}}, {"id": 261, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 262, "prop": "PlaySound", "attributes": {"key": "$d_avg_divebubble", "volume": 1.0}}, {"id": 263, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1388_1#1$1", "posfrom": "0,80", "posto": "0,180", "afrom": 1.0, "ato": 0.0, "duration": 1.0}}, {"id": 264, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 265, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1388_1#1$1", "posfrom": "0,-30", "posto": "0,70", "afrom": 1.0, "ato": 0.0, "duration": 1.0, "isblock": "true"}}, {"id": 266, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 267, "prop": "charslot", "attributes": {}}, {"id": 268, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1023_ghost2_1#13$1"}}, {"id": 269, "prop": "name", "attributes": {"content": "我辨認不出它們長了什麼器官，我甚至不覺得這些傢伙和我們三個月前殺死的那些雜碎存在什麼聯繫。", "name": "幽靈鯊"}, "figure_art": "avg_npc_1388_1#1$1"}, {"id": 270, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_474_gladiia_1#1"}}, {"id": 271, "prop": "name", "attributes": {"content": "……現成的演化成果已經不能滿足海嗣的需求，它們開始尋找自己的答案。", "name": "歌蕾蒂婭"}, "figure_art": "avg_npc_1388_1#1$1"}, {"id": 272, "prop": "name", "attributes": {"content": "這也意味著，它們的演化方式正在超出我們的認知。", "name": "歌蕾蒂婭"}, "figure_art": "avg_npc_1388_1#1$1"}, {"id": 273, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_474_gladiia_1#5"}}, {"id": 274, "prop": "name", "attributes": {"content": "如果我們觀察不出它們的身體結構，分辨不清它們器官的功能和區別，預測不到它們的演化方向……", "name": "歌蕾蒂婭"}, "figure_art": "avg_npc_1388_1#1$1"}, {"id": 275, "prop": "charslot", "attributes": {"slot": "m", "name": "char_263_skadi#8"}}, {"id": 276, "prop": "name", "attributes": {"content": "就不知道該怎麼殺死它們。", "name": "斯卡蒂"}, "figure_art": "avg_npc_1388_1#1$1"}, {"id": 277, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1023_ghost2_1#1$1"}}, {"id": 278, "prop": "name", "attributes": {"content": "稍後撤離的時候，倒是可以給布蘭都斯顧問帶一隻樣本。", "name": "幽靈鯊"}, "figure_art": "avg_npc_1388_1#1$1"}, {"id": 279, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_474_gladiia_1#1"}}, {"id": 280, "prop": "name", "attributes": {"content": "不過現在，任務優先。", "name": "歌蕾蒂婭"}, "figure_art": "avg_npc_1388_1#1$1"}, {"id": 281, "prop": "name", "attributes": {"content": "斯卡蒂，我們去找一處還未被溟痕覆蓋的岩壁，把信標嵌進去，啟動它。", "name": "歌蕾蒂婭"}, "figure_art": "avg_npc_1388_1#1$1"}, {"id": 282, "prop": "name", "attributes": {"content": "勞倫緹娜，警戒四周。一旦信標安置完成，我們立刻撤離。", "name": "歌蕾蒂婭"}, "figure_art": "avg_npc_1388_1#1$1"}, {"id": 283, "prop": "dialog", "attributes": {}}, {"id": 284, "prop": "PlaySound", "attributes": {"key": "$d_avg_swimdeepsea", "volume": 1.0}}, {"id": 285, "prop": "StopSound", "attributes": {"channel": "u", "fadetime": 2.0}}, {"id": 286, "prop": "charslot", "attributes": {"duration": 1.5, "isblock": "true"}}, {"id": 287, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 288, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 289, "prop": "charslot", "attributes": {}}, {"id": 290, "prop": "Background", "attributes": {"image": "51_g7_consuloffice", "screenadapt": "coverall"}}, {"id": 291, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 292, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 293, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 294, "prop": "PlaySound", "attributes": {"key": "$d_avg_higheldshosfts", "volume": 1.0}}, {"id": 295, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#1$1", "duration": 1.5, "isblock": "true"}}, {"id": 296, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 297, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 298, "prop": "Decision", "attributes": {"options": "克萊門莎女士。;執政官閣下。", "values": "1;2"}, "targetLine": {"option1": "line299", "option2": "line299"}}, {"id": 299, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 300, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#1$1"}}, {"id": 301, "prop": "name", "attributes": {"content": "久仰，羅德島的博士。您來到彌利亞留姆後，我們終於有了第一次正式交流。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#1$1"}, {"id": 302, "prop": "dialog", "attributes": {}}, {"id": 303, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 304, "prop": "Decision", "attributes": {"options": "畢竟凱爾希才是伊比利亞的正式代表。", "values": "1"}, "targetLine": {"option1": "line305"}}, {"id": 305, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 306, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#1$1"}}, {"id": 307, "prop": "name", "attributes": {"content": "不必謙遜。凱爾希醫生的見聞跨越了空間與時間的邊界，令人折服。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#1$1"}, {"id": 308, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#15$1"}}, {"id": 309, "prop": "name", "attributes": {"content": "那被她藏在背後的您，想必只會更為深邃。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#15$1"}, {"id": 310, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#1$1"}}, {"id": 311, "prop": "name", "attributes": {"content": "不論您是產生了某種疑惑，還是得出了某種結論，我都願意傾聽。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#1$1"}, {"id": 312, "prop": "dialog", "attributes": {}}, {"id": 313, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 314, "prop": "Decision", "attributes": {"options": "您將深海獵人送入了危險的巢穴。;您將三位羅德島的幹員置於險境。", "values": "1;2"}, "targetLine": {"option1": "line315", "option2": "line315"}}, {"id": 315, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 316, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#2$1"}}, {"id": 317, "prop": "name", "attributes": {"content": "您同凱爾希醫生一樣，對這項決定抱有疑慮。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#2$1"}, {"id": 318, "prop": "name", "attributes": {"content": "但我不得不令她們又一次前去面對死亡，唯有她們能夠打破當下的僵局。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#2$1"}, {"id": 319, "prop": "dialog", "attributes": {}}, {"id": 320, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 321, "prop": "Decision", "attributes": {"options": "合理，但您不覺得過於合理了嗎？", "values": "1"}, "targetLine": {"option1": "line322"}}, {"id": 322, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 323, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#9$1"}}, {"id": 324, "prop": "name", "attributes": {"content": "軍團盡出，連剛剛回到阿戈爾的深海獵人也必須承擔作戰任務，您懷疑眼下的局勢是被人為設計出來的。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#9$1"}, {"id": 325, "prop": "name", "attributes": {"content": "看來您確實在城內有所發現。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#9$1"}, {"id": 326, "prop": "dialog", "attributes": {}}, {"id": 327, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 328, "prop": "Decision", "attributes": {"options": "信標與武器的聯動關係可能遭到了篡改。", "values": "1"}, "targetLine": {"option1": "line329"}}, {"id": 329, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 330, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#9$1"}}, {"id": 331, "prop": "name", "attributes": {"content": "小幫手，立刻幫我聯繫航道信標與第Ⅳ級武器的核心研發及管理人員。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#9$1"}, {"id": 332, "prop": "name", "attributes": {"content": "也通知全體軍團指揮官，留下部分艦隊牽制前線海嗣，接應深海獵人，剩餘編隊有序撤離，回防城市。海巡隊立刻控制信標塔。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#9$1"}, {"id": 333, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#1$1"}}, {"id": 334, "prop": "name", "attributes": {"content": "感謝您提供的消息，博士。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#1$1"}, {"id": 335, "prop": "dialog", "attributes": {}}, {"id": 336, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 337, "prop": "Decision", "attributes": {"options": "（沉默地點頭）", "values": "1"}, "targetLine": {"option1": "line338"}}, {"id": 338, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 339, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#2$1"}}, {"id": 340, "prop": "name", "attributes": {"content": "凱爾希醫生，還有博士，關於我對深海獵人的布置，我仍需要給你們一個交代。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#2$1"}, {"id": 341, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1"}}, {"id": 342, "prop": "name", "attributes": {"content": "我們所需的並非戰術上的解釋。深海獵人應對海嗣的行動能力，您比我們更加熟悉。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 343, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1"}}, {"id": 344, "prop": "name", "attributes": {"content": "只是，憑您的觀察力，不至於注意不到歌蕾蒂婭脖子上的鱗片。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 345, "prop": "name", "attributes": {"content": "我們可以假設深海獵人有能力順利地完成任務，但您又如何確保她們在海嗣巢穴中不會產生異變？", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 346, "prop": "name", "attributes": {"content": "僅憑那位布蘭都斯顧問的保證？", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 347, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#9$1"}}, {"id": 348, "prop": "name", "attributes": {"content": "布蘭都斯顧問在評議會上的發言鞏固了彌利亞留姆對深海獵人的信任。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#9$1"}, {"id": 349, "prop": "name", "attributes": {"content": "只是，於我而言，那甚至稱不上一種心理安慰。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#9$1"}, {"id": 350, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1"}}, {"id": 351, "prop": "name", "attributes": {"content": "聽起來，關於深海獵人，您有更多的考慮。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 352, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#9$1"}}, {"id": 353, "prop": "name", "attributes": {"content": "……斬殺“初生”之後，阿戈爾並未真正封停深海獵人計劃。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#9$1"}, {"id": 354, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#4$1"}}, {"id": 355, "prop": "name", "attributes": {"content": "我沒有涉足其中，但僅憑知情，我就應該接受所有同胞的質詢。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#4$1"}, {"id": 356, "prop": "dialog", "attributes": {}}, {"id": 357, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 358, "prop": "Decision", "attributes": {"options": "……", "values": "1"}, "targetLine": {"option1": "line359"}}, {"id": 359, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 360, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#9$1"}}, {"id": 361, "prop": "name", "attributes": {"content": "“初生”死後，深海獵人計劃在短時間內經歷了巨大的變故。相關的實驗異象頻發，深海教會的動向也越來越多地指向獵人。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#9$1"}, {"id": 362, "prop": "name", "attributes": {"content": "這意味著深海獵人背後仍埋藏著亟待發掘的未知，但同時也表明它不再適宜作為公開計劃運行。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#9$1"}, {"id": 363, "prop": "name", "attributes": {"content": "時至今日，深海獵人計劃仍在秘密運行。但截至目前，阿戈爾的深海獵人依然只有歌蕾蒂婭她們三人……四人。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#9$1"}, {"id": 364, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#6$1"}}, {"id": 365, "prop": "name", "attributes": {"content": "儘管技術在不斷更新，阿戈爾卻再也無法成功改造出一位深海獵人。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#6$1"}, {"id": 366, "prop": "name", "attributes": {"content": "哪怕受試者的體徵與心理數據再穩定，也一樣會在醒來的那一刻喪失神智，墮落成海嗣。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#6$1"}, {"id": 367, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#8$1"}}, {"id": 368, "prop": "name", "attributes": {"content": "他們甚至無法走出實驗室，他們甚至不需要真正接觸海洋……", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#8$1"}, {"id": 369, "prop": "dialog", "attributes": {}}, {"id": 370, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 371, "prop": "Decision", "attributes": {"options": "“深海獵人血脈相連。”我們通常迴避了……", "values": "1"}, "targetLine": {"option1": "line372"}}, {"id": 372, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 373, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 374, "prop": "Decision", "attributes": {"options": "相連的到底是哪種血脈？", "values": "1"}, "targetLine": {"option1": "line375"}}, {"id": 375, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 376, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#2$1"}}, {"id": 377, "prop": "name", "attributes": {"content": "不得而知。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#2$1"}, {"id": 378, "prop": "name", "attributes": {"content": "歌蕾蒂婭她們仍能保持清醒的原因，我們還未能確證。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#2$1"}, {"id": 379, "prop": "dialog", "attributes": {}}, {"id": 380, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 381, "prop": "Decision", "attributes": {"options": "聽起來，她們將是解開謎題的關鍵。", "values": "1"}, "targetLine": {"option1": "line382"}}, {"id": 382, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 383, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 384, "prop": "Decision", "attributes": {"options": "但你仍然選擇將她們送上了前線。", "values": "1"}, "targetLine": {"option1": "line385"}}, {"id": 385, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 386, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#2$1"}}, {"id": 387, "prop": "name", "attributes": {"content": "……嗯。對於歌蕾蒂婭、勞倫緹娜和斯卡蒂，乃至所有深海獵人計劃的參與者，這都是不負責任的行為。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#2$1"}, {"id": 388, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#9$1"}}, {"id": 389, "prop": "name", "attributes": {"content": "但彌利亞留姆已是前線。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#9$1"}, {"id": 390, "prop": "name", "attributes": {"content": "我們及時截斷了撲向陸地的海嗣浪潮，但彌利亞留姆並非堅不可摧。倘若這條航道無法開啟，這座城市失守只是時間問題。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#9$1"}, {"id": 391, "prop": "name", "attributes": {"content": "海嗣有組織地扼住了航道線路的咽喉，正面強攻必然引發大規模的反撲。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#9$1"}, {"id": 392, "prop": "name", "attributes": {"content": "屆時，恐怕無人能夠倖存。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#9$1"}, {"id": 393, "prop": "dialog", "attributes": {}}, {"id": 394, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 395, "prop": "Decision", "attributes": {"options": "獵人涉險出征是計劃必要的代價？", "values": "1"}, "targetLine": {"option1": "line396"}}, {"id": 396, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 397, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#9$1"}}, {"id": 398, "prop": "name", "attributes": {"content": "獵人們可能犧牲，也可能異變。但如今，她們是最大的希望。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#9$1"}, {"id": 399, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1"}}, {"id": 400, "prop": "name", "attributes": {"content": "歌蕾蒂婭始終對航道計劃的可行性抱有質疑。正因如此，她毫不猶豫地選擇成為其中的一環。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 401, "prop": "name", "attributes": {"content": "你們的疑慮與掙扎或許不同，最終卻殊途同歸。阿戈爾人似乎有某種內在的默契。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 402, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#4$1"}}, {"id": 403, "prop": "name", "attributes": {"content": "……一種不無悲哀的默契。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#4$1"}, {"id": 404, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#6$1"}}, {"id": 405, "prop": "name", "attributes": {"content": "鬥智場入口的石磚上，有設計者瑪利圖斯留下的箴言——“此處並無正義，唯有前路。”", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#6$1"}, {"id": 406, "prop": "name", "attributes": {"content": "那位先哲……後世有人評價他過於糾結事物的價值，在無窮無盡的價值比較中耗費了許多心神。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#6$1"}, {"id": 407, "prop": "name", "attributes": {"content": "但他最終在意的，其實只有阿戈爾的前路。諸如正義這樣的大眾情緒價值，他寧願不去考慮。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#6$1"}, {"id": 408, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#4$1"}}, {"id": 409, "prop": "name", "attributes": {"content": "恐怕我與歌蕾蒂婭，都在無意間踐行了他的理念。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#4$1"}, {"id": 410, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#2$1"}}, {"id": 411, "prop": "name", "attributes": {"content": "凱爾希醫生，您先前所言不假。不論如何，我身上終歸也承載著“阿戈爾的傲慢”。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#2$1"}, {"id": 412, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1"}}, {"id": 413, "prop": "name", "attributes": {"content": "我想要糾正這個說法，“傲慢”一詞似乎並不足以概括阿戈爾。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 414, "prop": "name", "attributes": {"content": "你們平等地尊重每一位同胞的人性，將人的價值實現作為整個社會的發展目標。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 415, "prop": "name", "attributes": {"content": "但同時你們也能夠為了阿戈爾整體的存續，做出最殘酷的決斷，然後平靜地接受它。", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 416, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#8$1"}}, {"id": 417, "prop": "name", "attributes": {"content": "平靜……嗎？", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#8$1"}, {"id": 418, "prop": "name", "attributes": {"content": "阿戈爾人並非冷血，當你們感到憤怒時，我的內心也並非毫無波瀾。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#8$1"}, {"id": 419, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#4$1"}}, {"id": 420, "prop": "name", "attributes": {"content": "我曾經想要向歌蕾蒂婭表達這些情緒，但我意識到自己沒有資格。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#4$1"}, {"id": 421, "prop": "name", "attributes": {"content": "我對她做出了純粹出自理性的決斷，自然沒有資格求得感性的原諒。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#4$1"}, {"id": 422, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#2$1"}}, {"id": 423, "prop": "name", "attributes": {"content": "此時此刻，也是如此。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#2$1"}, {"id": 424, "prop": "name", "attributes": {"content": "所以，我“平靜”地接受了自己的決斷。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#2$1"}, {"id": 425, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1"}}, {"id": 426, "prop": "name", "attributes": {"content": "……", "name": "凱爾希"}, "figure_art": "avg_003_kalts_1#1$1"}, {"id": 427, "prop": "dialog", "attributes": {}}, {"id": 428, "prop": "charslot", "attributes": {}}, {"id": 429, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 430, "prop": "Decision", "attributes": {"options": "……", "values": "1"}, "targetLine": {"option1": "line431"}}, {"id": 431, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 432, "prop": "PlaySound", "attributes": {"key": "$d_avg_telephonebusy", "volume": 1.0}}, {"id": 433, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 434, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1401_1#1$1", "duration": 0.5, "isblock": "true"}}, {"id": 435, "prop": "name", "attributes": {"content": "已經為您連線指定人員。布蘭都斯顧問沒有接聽。", "name": "“小幫手”"}, "figure_art": "avg_npc_1401_1#1$1"}, {"id": 436, "prop": "dialog", "attributes": {}}, {"id": 437, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1382_1#9$1"}}, {"id": 438, "prop": "name", "attributes": {"content": "……", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#9$1"}, {"id": 439, "prop": "name", "attributes": {"content": "凱爾希醫生，博士。很抱歉沒能給出得體的答覆。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#9$1"}, {"id": 440, "prop": "name", "attributes": {"content": "但現在，請允許我履行我的職責。", "name": "克萊門莎"}, "figure_art": "avg_npc_1382_1#9$1"}, {"id": 441, "prop": "dialog", "attributes": {}}, {"id": 442, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 443, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 444, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 445, "prop": "charslot", "attributes": {}}, {"id": 446, "prop": "Background", "attributes": {}}, {"id": 447, "prop": "Image", "attributes": {}}, {"id": 448, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}