{"lang": "zh_TW", "eventid": "act34side", "eventName": "生路", "entryType": "ACTIVITY", "storyCode": "BP-ST-1", "avgTag": "幕間", "storyName": "浪潮守望者", "storyInfo": "阿戈爾的城市“彌利亞留姆”主動與陸地取得聯繫，邀請伊比利亞派遣使節前往深海。為了解決海嗣問題，阿戈爾將開闢一條連通海洋與陸地的航道。與此同時，烏爾比安也出現在了附近的海域。\n", "storyList": [{"id": 0, "prop": "HEADER", "attributes": {"key": "title_test", "is_skippable": "true", "fit_mode": "BLACK_MASK"}}, {"id": 1, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 2, "prop": "stopmusic", "attributes": {}}, {"id": 3, "prop": "Dialog", "attributes": {}}, {"id": 4, "prop": "Background", "attributes": {"image": "27_g18_lighthouse_square", "screenadapt": "coverall"}}, {"id": 5, "prop": "playsound", "attributes": {"key": "$d_avg_sea", "loop": "true", "channel": "bgs", "volume": 0.0}}, {"id": 6, "prop": "SoundVolume", "attributes": {"volume": 0.7, "channel": "bgs", "fadetime": 3.0}}, {"id": 7, "prop": "Delay", "attributes": {"time": 3.0}}, {"id": 8, "prop": "Subtitle", "attributes": {"text": "一個獵人他走上海岸♪", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 9, "prop": "Subtitle", "attributes": {"text": "他的家鄉在後，他的路在身前♪", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 10, "prop": "Subtitle", "attributes": {"text": "父母與兒女都與他失散♪", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 11, "prop": "Subtitle", "attributes": {"text": "他的戀人已經葬身大海♪", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 12, "prop": "subtitle", "attributes": {}}, {"id": 13, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 14, "prop": "Subtitle", "attributes": {"text": "一個獵人他走上海岸♪", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 15, "prop": "Subtitle", "attributes": {"text": "他的家鄉在後，徒余哀嘆♪", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 16, "prop": "Subtitle", "attributes": {"text": "他的路沒有盡頭♪", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 17, "prop": "Subtitle", "attributes": {"text": "他的路濃霧瀰漫♪", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 18, "prop": "subtitle", "attributes": {}}, {"id": 19, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 20, "prop": "Dialog", "attributes": {}}, {"id": 21, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 22, "prop": "Subtitle", "attributes": {"text": "一個獵人他回到海岸♪", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 23, "prop": "Subtitle", "attributes": {"text": "他的旅程結束，他的家鄉近在眼前♪", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 24, "prop": "Subtitle", "attributes": {"text": "舊日的濤聲呢喃♪", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 25, "prop": "Subtitle", "attributes": {"text": "可他為什麼卻步♪", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 26, "prop": "Subtitle", "attributes": {"text": "又為什麼不安♪", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 27, "prop": "subtitle", "attributes": {}}, {"id": 28, "prop": "StopSound", "attributes": {"channel": "bgs", "fadetime": 2.0}}, {"id": 29, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 30, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.6}}, {"id": 31, "prop": "Delay", "attributes": {"time": 3.0}}, {"id": 32, "prop": "playMusic", "attributes": {"intro": "$tech_intro", "key": "$tech_loop", "volume": 0.6}}, {"id": 33, "prop": "Decision", "attributes": {"options": "好久不見，斯卡蒂。;你好啊，斯卡蒂。", "values": "1;2"}, "targetLine": {"option1": "line34", "option2": "line34"}}, {"id": 34, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 35, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 36, "prop": "charslot", "attributes": {"slot": "m", "name": "char_263_skadi#3", "duration": 1.5}}, {"id": 37, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 38, "prop": "name", "attributes": {"content": "好久不見，博士。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#3"}, {"id": 39, "prop": "name", "attributes": {"content": "按照約定，來接你的應該是那個臉皮很厚話又多的黎博利，但你好像並不驚訝。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#3"}, {"id": 40, "prop": "Dialog", "attributes": {}}, {"id": 41, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 42, "prop": "Decision", "attributes": {"options": "你和極境都是羅德島的幹員。;畢竟這裡更靠近你的故鄉。", "values": "1;2"}, "targetLine": {"option1": "line43", "option2": "line43"}}, {"id": 43, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 44, "prop": "charslot", "attributes": {"slot": "m", "name": "char_263_skadi#5"}}, {"id": 45, "prop": "name", "attributes": {"content": "嗯，也是。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#5"}, {"id": 46, "prop": "name", "attributes": {"content": "你比凱爾希估計的晚到了快一個小時。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#5"}, {"id": 47, "prop": "charslot", "attributes": {"slot": "m", "name": "char_263_skadi#3"}}, {"id": 48, "prop": "name", "attributes": {"content": "看來就算有聖徒開具的公函，審判庭該有的審查程序還是一樣沒落。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#3"}, {"id": 49, "prop": "name", "attributes": {"content": "才不到三個月，除了能派上用場的工人外，這裡的居民全都遷去了內陸城鎮，取而代之的是幾個大陣的懲戒軍。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#3"}, {"id": 50, "prop": "Dialog", "attributes": {}}, {"id": 51, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 52, "prop": "Decision", "attributes": {"options": "他們在緊鑼密鼓地籌備著什麼。;他們看起來非常緊張。", "values": "1;2"}, "targetLine": {"option1": "line53", "option2": "line53"}}, {"id": 53, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 54, "prop": "charslot", "attributes": {"slot": "m", "name": "char_263_skadi#9"}}, {"id": 55, "prop": "name", "attributes": {"content": "自從一週前，伊比利亞收到了來自阿戈爾的聯絡，這座被遺忘的小鎮就不再安靜了。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#9"}, {"id": 56, "prop": "name", "attributes": {"content": "遍地的海洋殘渣刺激著這些年輕戰士的神經，阿戈爾的聲音只會加重他們的焦慮。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#9"}, {"id": 57, "prop": "Dialog", "attributes": {}}, {"id": 58, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 59, "prop": "Decision", "attributes": {"options": "阿戈爾的行動確實值得關注甚至戒備。;遠海中的國家突然發聲，沒人能充耳不聞。", "values": "1;2"}, "targetLine": {"option1": "line60", "option2": "line60"}}, {"id": 60, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 61, "prop": "charslot", "attributes": {"slot": "m", "name": "char_263_skadi#3"}}, {"id": 62, "prop": "name", "attributes": {"content": "沿著雕塑左邊的這條街道過去，走得快一點，十分鐘就能看到大海。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#3"}, {"id": 63, "prop": "name", "attributes": {"content": "我們待會直接前往伊比利亞之眼。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#3"}, {"id": 64, "prop": "Dialog", "attributes": {}}, {"id": 65, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 66, "prop": "PlaySound", "attributes": {"key": "$d_avg_sea", "volume": 0.7, "loop": "true", "channel": "sea"}}, {"id": 67, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 68, "prop": "charslot", "attributes": {"slot": "m", "name": "char_263_skadi#3"}}, {"id": 69, "prop": "name", "attributes": {"content": "喂，博士，你聽見海浪了嗎？", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#3"}, {"id": 70, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 71, "prop": "name", "attributes": {"content": "斯卡蒂微微側過了頭，迎向海風吹來的方向，她的長髮在風中舞動，與眼中的陰翳同色。"}}, {"id": 72, "prop": "charslot", "attributes": {"slot": "m", "name": "char_263_skadi#4"}}, {"id": 73, "prop": "name", "attributes": {"content": "浪的層次變得很複雜，我還聽見了——星空流動的聲音，永不停歇的自然的歌，還有，不被理解的語言……", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#4"}, {"id": 74, "prop": "StopSound", "attributes": {"channel": "sea", "fadetime": 3.0}}, {"id": 75, "prop": "Dialog", "attributes": {}}, {"id": 76, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 77, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 78, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.5, "block": "true"}}, {"id": 79, "prop": "playMusic", "attributes": {"intro": "$loneliness_intro", "key": "$loneliness_loop", "volume": 0.6}}, {"id": 80, "prop": "Sticker", "attributes": {"id": "st1", "text": "Ishar-mla。", "x": 320.0, "y": 340.0, "alignment": "center", "size": 22.0, "delay": 0.001, "width": 700.0, "duration": 1.0}}, {"id": 81, "prop": "Sticker", "attributes": {"id": "st1", "duration": 1.0, "block": "false"}}, {"id": 82, "prop": "delay", "attributes": {"time": 1.1}}, {"id": 83, "prop": "Sticker", "attributes": {"id": "st1", "text": "我在。", "x": 320.0, "y": 340.0, "alignment": "center", "size": 22.0, "delay": 0.001, "width": 700.0, "duration": 1.0}}, {"id": 84, "prop": "Sticker", "attributes": {"id": "st1", "duration": 1.0, "block": "false"}}, {"id": 85, "prop": "delay", "attributes": {"time": 1.1}}, {"id": 86, "prop": "Sticker", "attributes": {"id": "st1", "text": "我們遭受的苦永在。", "x": 320.0, "y": 340.0, "alignment": "center", "size": 22.0, "delay": 0.001, "width": 700.0, "duration": 1.0}}, {"id": 87, "prop": "Sticker", "attributes": {"id": "st1", "duration": 1.0, "block": "false"}}, {"id": 88, "prop": "delay", "attributes": {"time": 1.1}}, {"id": 89, "prop": "Sticker", "attributes": {"id": "st1", "text": "我們渴望的生永在。", "x": 320.0, "y": 340.0, "alignment": "center", "size": 22.0, "delay": 0.001, "width": 700.0, "duration": 1.0}}, {"id": 90, "prop": "Sticker", "attributes": {"id": "st1", "duration": 1.0, "block": "false"}}, {"id": 91, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 92, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 93, "prop": "charslot", "attributes": {"slot": "m", "name": "char_263_skadi#7"}}, {"id": 94, "prop": "name", "attributes": {"content": "……", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#7"}, {"id": 95, "prop": "Dialog", "attributes": {}}, {"id": 96, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 97, "prop": "playMusic", "attributes": {"intro": "$tech_intro", "key": "$tech_loop", "volume": 0.6}}, {"id": 98, "prop": "Decision", "attributes": {"options": "斯卡蒂，你還好嗎？;和家鄉恢復聯繫，反而讓你心神不寧？", "values": "1;2"}, "targetLine": {"option1": "line99", "option2": "line99"}}, {"id": 99, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 100, "prop": "charslot", "attributes": {"slot": "m", "name": "char_263_skadi#3"}}, {"id": 101, "prop": "name", "attributes": {"content": "近鄉情怯吧……算了，這種感受很難總結。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#3"}, {"id": 102, "prop": "name", "attributes": {"content": "也可能只是沒睡好覺，上次回了一趟海裡，好像鯊魚把她的夢都轉移給我了一樣。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#3"}, {"id": 103, "prop": "name", "attributes": {"content": "說起來，凱爾希醫生為什麼這麼著急地叫你過來？", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#3"}, {"id": 104, "prop": "name", "attributes": {"content": "我不記得你接觸過海洋，博士。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#3"}, {"id": 105, "prop": "Dialog", "attributes": {}}, {"id": 106, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 107, "prop": "Decision", "attributes": {"options": "不一定，但我記不清了。;但似乎，並不陌生。", "values": "1;2"}, "targetLine": {"option1": "line108", "option2": "line108"}}, {"id": 108, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": false}, {"id": 109, "prop": "charslot", "attributes": {"slot": "m", "name": "char_263_skadi#3"}}, {"id": 110, "prop": "name", "attributes": {"content": "這個回答很模糊。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#3"}, {"id": 111, "prop": "name", "attributes": {"content": "好吧，我忘了你的情況。這個回答其實很正常。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#3"}, {"id": 112, "prop": "charslot", "attributes": {"slot": "m", "name": "char_263_skadi#5"}}, {"id": 113, "prop": "name", "attributes": {"content": "算了，凱爾希醫生把你叫過來，總有她的原因。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#5"}, {"id": 114, "prop": "name", "attributes": {"content": "走吧，天快要黑下來了。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#5"}, {"id": 115, "prop": "Dialog", "attributes": {}}, {"id": 116, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 117, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 118, "prop": "Dialog", "attributes": {}}, {"id": 119, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 120, "prop": "charslot", "attributes": {}}, {"id": 121, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 122, "prop": "Background", "attributes": {"image": "27_g24_cloudy_sea", "screenadapt": "coverall"}}, {"id": 123, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 124, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 125, "prop": "PlaySound", "attributes": {"key": "$d_avg_jump_water", "volume": 1.0}}, {"id": 126, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_474_gladiia_1#1", "posfrom": "0,-100", "posto": "0,0", "duration": 1.0}}, {"id": 127, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 128, "prop": "Effect", "attributes": {"name": "$e_shuihua", "layer": 1.0}}, {"id": 129, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 5.0, "ystrength": 10.0, "vibrato": 15.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 130, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1023_ghost2_1#1$1", "posfrom": "0,-100", "posto": "0,0", "duration": 1.0}}, {"id": 131, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 132, "prop": "charslot", "attributes": {}}, {"id": 133, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1", "duration": 1.5}}, {"id": 134, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 135, "prop": "charslot", "attributes": {}}, {"id": 136, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_474_gladiia_1#1", "focus": "l"}}, {"id": 137, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1023_ghost2_1#1$1", "focus": "l"}}, {"id": 138, "prop": "name", "attributes": {"content": "先別靠過來，等我把水甩乾。", "name": "歌蕾蒂婭"}}, {"id": 139, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1023_ghost2_1#1$1", "focus": "r"}}, {"id": 140, "prop": "name", "attributes": {"content": "啊，醫生。很少有人能鎖定深海獵人的行蹤。劍魚提前告訴你我們要從這裡上岸嗎？", "name": "幽靈鯊"}}, {"id": 141, "prop": "charslot", "attributes": {}}, {"id": 142, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1"}}, {"id": 143, "prop": "name", "attributes": {"content": "極境在這一片海域布置了訊息採集裝置，目前已經完成校準，與伊比利亞之眼的中控系統直接連通。", "name": "凱爾希"}}, {"id": 144, "prop": "charslot", "attributes": {}}, {"id": 145, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_474_gladiia_1#1", "focus": "r"}}, {"id": 146, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1023_ghost2_1#1$1", "focus": "r"}}, {"id": 147, "prop": "name", "attributes": {"content": "這麼短的時間，架設一套針對水下環境的定位系統，那個黎博利還蠻有辦法的。", "name": "幽靈鯊"}}, {"id": 148, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_474_gladiia_1#1", "focus": "l"}}, {"id": 149, "prop": "name", "attributes": {"content": "我應該理解為，羅德島與審判庭加深了合作？", "name": "歌蕾蒂婭"}}, {"id": 150, "prop": "charslot", "attributes": {}}, {"id": 151, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1"}}, {"id": 152, "prop": "name", "attributes": {"content": "一週前，水下的那座城市藉由特殊頻段告知伊比利亞，阿戈爾將開闢一條連通阿戈爾本境與陸地的“航道”。", "name": "凱爾希"}}, {"id": 153, "prop": "name", "attributes": {"content": "然而面對這項龐大的計劃，除了大燈塔的定位系統，伊比利亞幾乎沒有其他獲取情報的途徑。", "name": "凱爾希"}}, {"id": 154, "prop": "name", "attributes": {"content": "顯然，作為總戰爭設計師的您，對此也毫不知情。", "name": "凱爾希"}}, {"id": 155, "prop": "charslot", "attributes": {}}, {"id": 156, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_474_gladiia_1#1", "focus": "l"}}, {"id": 157, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1023_ghost2_1#1$1", "focus": "l"}}, {"id": 158, "prop": "name", "attributes": {"content": "鯊魚，告訴凱爾希我們的發現。", "name": "歌蕾蒂婭"}}, {"id": 159, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1023_ghost2_1#13$1", "focus": "r"}}, {"id": 160, "prop": "name", "attributes": {"content": "這是我和隊長第三次潛回斯圖提斐拉沉沒的地方，距離上一次，僅僅相隔了十天。", "name": "幽靈鯊"}}, {"id": 161, "prop": "name", "attributes": {"content": "第一次的時候，還能看見爆炸後殘存的船體插在海床上，藉著從海面透下的微光，艙體內部的金色像是暈開的顏料。", "name": "幽靈鯊"}}, {"id": 162, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1023_ghost2_1#10$1", "focus": "r"}}, {"id": 163, "prop": "name", "attributes": {"content": "而這一次，巨大的金屬船體結構已經完全消失，取而代之的是一片生機盎然的珊瑚叢。", "name": "幽靈鯊"}}, {"id": 164, "prop": "name", "attributes": {"content": "……我習慣了做夢，但依然覺得不真實。", "name": "幽靈鯊"}}, {"id": 165, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_474_gladiia_1#1", "focus": "l"}}, {"id": 166, "prop": "name", "attributes": {"content": "那塊悼亡文明與歷史的碑，只樹立了極短的時間。", "name": "歌蕾蒂婭"}}, {"id": 167, "prop": "name", "attributes": {"content": "“愚人號”已經徹底變成了海洋的一部分。", "name": "歌蕾蒂婭"}}, {"id": 168, "prop": "name", "attributes": {"content": "準確說，化作了海嗣巢穴的一部分。", "name": "歌蕾蒂婭"}}, {"id": 169, "prop": "charslot", "attributes": {}}, {"id": 170, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#14$1"}}, {"id": 171, "prop": "name", "attributes": {"content": "海嗣同化環境的速度加快了。", "name": "凱爾希"}}, {"id": 172, "prop": "charslot", "attributes": {}}, {"id": 173, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_474_gladiia_1#1", "focus": "l"}}, {"id": 174, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1023_ghost2_1#10$1", "focus": "l"}}, {"id": 175, "prop": "name", "attributes": {"content": "快了很多。", "name": "歌蕾蒂婭"}}, {"id": 176, "prop": "name", "attributes": {"content": "但還有更值得關注的事情。我們的確發現了戰爭的痕跡，而且就發生在不久前。", "name": "歌蕾蒂婭"}}, {"id": 177, "prop": "name", "attributes": {"content": "完全淨空，連海雪也不見一絲的海域；扭曲破碎，明顯被微型奇點撕扯過的海床……", "name": "歌蕾蒂婭"}}, {"id": 178, "prop": "charslot", "attributes": {}}, {"id": 179, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1"}}, {"id": 180, "prop": "name", "attributes": {"content": "能做到這些的，恐怕只有阿戈爾正規軍團的艦隊。", "name": "凱爾希"}}, {"id": 181, "prop": "charslot", "attributes": {}}, {"id": 182, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_474_gladiia_1#1", "focus": "l"}}, {"id": 183, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1023_ghost2_1#10$1", "focus": "l"}}, {"id": 184, "prop": "name", "attributes": {"content": "作為一個常在陸地上行走的人，凱爾希，你對阿戈爾的關注與了解超乎尋常。", "name": "歌蕾蒂婭"}}, {"id": 185, "prop": "charslot", "attributes": {}}, {"id": 186, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1"}}, {"id": 187, "prop": "name", "attributes": {"content": "雖然遠隔無垠的海水，但阿戈爾依然屬於泰拉。", "name": "凱爾希"}}, {"id": 188, "prop": "charslot", "attributes": {}}, {"id": 189, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_474_gladiia_1#1", "focus": "r"}}, {"id": 190, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1023_ghost2_1#12$1", "focus": "r"}}, {"id": 191, "prop": "name", "attributes": {"content": "我和歌蕾蒂婭已經決定，前往那座城市。", "name": "幽靈鯊"}}, {"id": 192, "prop": "charslot", "attributes": {}}, {"id": 193, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1"}}, {"id": 194, "prop": "name", "attributes": {"content": "這無疑是一個冒險的決定。", "name": "凱爾希"}}, {"id": 195, "prop": "charslot", "attributes": {}}, {"id": 196, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_474_gladiia_1#1", "focus": "r"}}, {"id": 197, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1023_ghost2_1#1$1", "focus": "r"}}, {"id": 198, "prop": "name", "attributes": {"content": "是有一點冒險啦。", "name": "幽靈鯊"}}, {"id": 199, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_474_gladiia_1#1", "focus": "l"}}, {"id": 200, "prop": "name", "attributes": {"content": "相當冒險。", "name": "歌蕾蒂婭"}}, {"id": 201, "prop": "name", "attributes": {"content": "所以，深海獵人已經觀察了很久。", "name": "歌蕾蒂婭"}}, {"id": 202, "prop": "name", "attributes": {"content": "在那次行動之前，我作為深海獵人總戰爭設計師參加了科學院與技術院的軍事會議。", "name": "歌蕾蒂婭"}}, {"id": 203, "prop": "name", "attributes": {"content": "在兩院當時制定的戰爭預案裡，並不存在一座靠近陸地的軍事要塞，也不存在涉及“航道”的計劃。", "name": "歌蕾蒂婭"}}, {"id": 204, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_474_gladiia_1#5", "focus": "l"}}, {"id": 205, "prop": "name", "attributes": {"content": "毫無疑問，阿戈爾經歷了重大變故。", "name": "歌蕾蒂婭"}}, {"id": 206, "prop": "name", "attributes": {"content": "斬殺伊莎瑪拉之後，我們和本境的聯繫徹底斷絕。根據已知的情報很難拼湊出真相。", "name": "歌蕾蒂婭"}}, {"id": 207, "prop": "charslot", "attributes": {}}, {"id": 208, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1"}}, {"id": 209, "prop": "name", "attributes": {"content": "這並不能構成你們重返阿戈爾的充足理由。最先勸阻你們的人甚至並不是我，而是你們舊日的同僚。", "name": "凱爾希"}}, {"id": 210, "prop": "charslot", "attributes": {}}, {"id": 211, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_474_gladiia_1#5", "focus": "l"}}, {"id": 212, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1023_ghost2_1#1$1", "focus": "l"}}, {"id": 213, "prop": "name", "attributes": {"content": "你是說……烏爾比安？", "name": "歌蕾蒂婭"}}, {"id": 214, "prop": "name", "attributes": {"content": "烏爾比安也一定明白，陸地上不會有答案。我們必須回到海洋之中。", "name": "歌蕾蒂婭"}}, {"id": 215, "prop": "name", "attributes": {"content": "如果刻意與阿戈爾保持距離是他的策略，那我們就更有必要以正式的姿態回歸阿戈爾。", "name": "歌蕾蒂婭"}}, {"id": 216, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1023_ghost2_1#3$1", "focus": "r"}}, {"id": 217, "prop": "name", "attributes": {"content": "……自我從睡夢中清醒以來，海浪時刻在訴說著，迷途的人該回家。", "name": "幽靈鯊"}}, {"id": 218, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1023_ghost2_1#13$1", "focus": "r"}}, {"id": 219, "prop": "name", "attributes": {"content": "深海獵人，必須返回故鄉。", "name": "幽靈鯊"}}, {"id": 220, "prop": "charslot", "attributes": {}}, {"id": 221, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1"}}, {"id": 222, "prop": "name", "attributes": {"content": "我能理解。", "name": "凱爾希"}}, {"id": 223, "prop": "name", "attributes": {"content": "歌蕾蒂婭，我會與你們同行。", "name": "凱爾希"}}, {"id": 224, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_474_gladiia_1#1"}}, {"id": 225, "prop": "name", "attributes": {"content": "對你而言，這的確是個不可多得的機會。", "name": "歌蕾蒂婭"}}, {"id": 226, "prop": "charslot", "attributes": {}}, {"id": 227, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1"}}, {"id": 228, "prop": "name", "attributes": {"content": "我此行並不僅僅代表我自己，甚至不僅僅代表羅德島。", "name": "凱爾希"}}, {"id": 229, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_474_gladiia_1#1"}}, {"id": 230, "prop": "name", "attributes": {"content": "伊比利亞？他們往你已經不堪重負的肩膀上多加了一副擔子？", "name": "歌蕾蒂婭"}}, {"id": 231, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_003_kalts_1#1$1"}}, {"id": 232, "prop": "name", "attributes": {"content": "這同樣是我自己的選擇。", "name": "凱爾希"}}, {"id": 233, "prop": "name", "attributes": {"content": "羅德島與伊比利亞審判庭的合作剛剛起步，正如我們之間的合作也依然只是開始。", "name": "凱爾希"}}, {"id": 234, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_474_gladiia_1#1", "focus": "n"}}, {"id": 235, "prop": "name", "attributes": {"content": "凱爾希凝視著歌蕾蒂婭，海風沒有吹皺對方那張毫無表情的臉。"}}, {"id": 236, "prop": "name", "attributes": {"content": "短暫的沉默後，歌蕾蒂婭點了點頭。"}}, {"id": 237, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 238, "prop": "Dialog", "attributes": {}}, {"id": 239, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 240, "prop": "charslot", "attributes": {}}, {"id": 241, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 242, "prop": "PlaySound", "attributes": {"key": "$d_avg_sea", "volume": 0.6, "loop": "true", "channel": "sea"}}, {"id": 243, "prop": "Background", "attributes": {"image": "27_g19_lighthouse_front", "screenadapt": "coverall"}}, {"id": 244, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 245, "prop": "playMusic", "attributes": {"intro": "$darkness01_intro", "key": "$darkness01_loop", "volume": 0.6}}, {"id": 246, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 247, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_447_1#1$1", "duration": 1.0}}, {"id": 248, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_4009_irene_1#1$1", "duration": 1.0}}, {"id": 249, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 250, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_447_1#1$1", "focus": "l"}}, {"id": 251, "prop": "name", "attributes": {"content": "艾麗妮，距離我們收到阿戈爾的聯絡已經有幾天了？", "name": "聖徒卡門"}}, {"id": 252, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_4009_irene_1#7$1", "focus": "r"}}, {"id": 253, "prop": "name", "attributes": {"content": "八天了，聖徒閣下。", "name": "艾麗妮"}}, {"id": 254, "prop": "name", "attributes": {"content": "這八天裡，除了必要的布置、會議和休息時間，您一直站在這裡觀察著海洋。", "name": "艾麗妮"}}, {"id": 255, "prop": "name", "attributes": {"content": "阿戈爾一方並未給出明確的接洽時間，我理解您擔心錯過他們的動向，但……", "name": "艾麗妮"}}, {"id": 256, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_447_1#7$1", "focus": "l"}}, {"id": 257, "prop": "name", "attributes": {"content": "艾麗妮，看看眼前的海。", "name": "聖徒卡門"}}, {"id": 258, "prop": "charslot", "attributes": {}}, {"id": 259, "prop": "name", "attributes": {"content": "難以辨明顏色的深沉海洋湧動著。或許是海面太過遼闊，天空便顯得低沉。"}}, {"id": 260, "prop": "name", "attributes": {"content": "海水撞擊礁石，激起幾公尺高的浪濤，在這狹小的天地間激盪出轟然聲響。"}}, {"id": 261, "prop": "StopSound", "attributes": {"channel": "sea", "fadetime": 3.0}}, {"id": 262, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_447_1#1$1", "focus": "l"}}, {"id": 263, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_4009_irene_1#7$1", "focus": "l"}}, {"id": 264, "prop": "name", "attributes": {"content": "對伊比利亞來說，沒有翻湧著恐魚血肉的海洋，哪怕再喧囂，也是仁慈的。", "name": "聖徒卡門"}}, {"id": 265, "prop": "name", "attributes": {"content": "我的一位故友，曾是港都最富才情的詩人。", "name": "聖徒卡門"}}, {"id": 266, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_447_1#2$1", "focus": "l"}}, {"id": 267, "prop": "name", "attributes": {"content": "宏偉的港都沉入靜謐之後，他掙扎著一路向北逃亡，踏著遍地餓殍來到了內陸深處，那座日後將會成為首都的小城。", "name": "聖徒卡門"}}, {"id": 268, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_447_1#5$1", "focus": "l"}}, {"id": 269, "prop": "name", "attributes": {"content": "我看到他在破落的城門前跪下，不住地哀哭。那座城市就從哭聲中得到了新的名字，佩爾多尼朵拉，“寬恕已去”。", "name": "聖徒卡門"}}, {"id": 270, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_447_1#1$1", "focus": "l"}}, {"id": 271, "prop": "name", "attributes": {"content": "不過，當時的人們需要的不是哀悼，而是撫慰。許多人更習慣將那個名字簡稱為佩爾多尼——“寬恕”。", "name": "聖徒卡門"}}, {"id": 272, "prop": "name", "attributes": {"content": "如今，黃金時代的遺產，最後的伊比利亞之眼重新亮起，艾麗妮，這意味著什麼？", "name": "聖徒卡門"}}, {"id": 273, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_4009_irene_1#7$1", "focus": "r"}}, {"id": 274, "prop": "name", "attributes": {"content": "希望和決心。", "name": "艾麗妮"}}, {"id": 275, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_447_1#1$1", "focus": "l"}}, {"id": 276, "prop": "name", "attributes": {"content": "“希望和決心”，當然。", "name": "聖徒卡門"}}, {"id": 277, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_447_1#8$1", "focus": "l"}}, {"id": 278, "prop": "name", "attributes": {"content": "年輕人，你回答我時的眼神要比達里奧年輕時更加堅毅，這很好。", "name": "聖徒卡門"}}, {"id": 279, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_447_1#1$1", "focus": "l"}}, {"id": 280, "prop": "name", "attributes": {"content": "但這種鼓舞人心的發言往往並不是最準確的答案。", "name": "聖徒卡門"}}, {"id": 281, "prop": "name", "attributes": {"content": "半個世紀後，我們一再後撤的防線終於重新向前推進至此。很快，這裡將會成為審判庭新的中樞。", "name": "聖徒卡門"}}, {"id": 282, "prop": "name", "attributes": {"content": "可與此同時，我們也將一切袒露在了海洋——海嗣，還有阿戈爾——面前。", "name": "聖徒卡門"}}, {"id": 283, "prop": "name", "attributes": {"content": "伊比利亞已捉襟見肘。這個國家無法再掩藏它長久以來的疲弱和困病，這是不爭的事實。", "name": "聖徒卡門"}}, {"id": 284, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_447_1#6$1", "focus": "l"}}, {"id": 285, "prop": "name", "attributes": {"content": "而另一個事實是，我們已不可能再次退卻。", "name": "聖徒卡門"}}, {"id": 286, "prop": "Dialog", "attributes": {}}, {"id": 287, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 288, "prop": "charslot", "attributes": {}}, {"id": 289, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0}}, {"id": 290, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 291, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1380_1#1$1", "duration": 1.0}}, {"id": 292, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 293, "prop": "name", "attributes": {"content": "老師——哎呀，艾麗妮閣下，好久不見。", "name": "喬迪"}, "figure_art": "avg_npc_1380_1#1$1"}, {"id": 294, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4009_irene_1#1$1"}}, {"id": 295, "prop": "name", "attributes": {"content": "好久不見。", "name": "艾麗妮"}, "figure_art": "avg_4009_irene_1#1$1"}, {"id": 296, "prop": "name", "attributes": {"content": "這套衣服還滿適合你的。", "name": "艾麗妮"}, "figure_art": "avg_4009_irene_1#1$1"}, {"id": 297, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1380_1#11$1"}}, {"id": 298, "prop": "multiline", "attributes": {"name": "喬迪", "content": "謝、謝謝。"}}, {"id": 299, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1380_1#2$1"}}, {"id": 300, "prop": "multiline", "attributes": {"name": "喬迪", "content": "啊對了，緊急情況——燈塔剛剛偵測到了一批來歷不明的訊號。"}}, {"id": 301, "prop": "name", "attributes": {"content": "訊號來源似乎不是海底，而是天空。", "name": "喬迪"}, "figure_art": "avg_npc_1380_1#2$1"}, {"id": 302, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4009_irene_1#7$1"}}, {"id": 303, "prop": "name", "attributes": {"content": "喬迪，我想它已經肉眼可見了……", "name": "艾麗妮"}, "figure_art": "avg_4009_irene_1#7$1"}, {"id": 304, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 305, "prop": "name", "attributes": {"content": "卡門和艾麗妮緊緊盯著遠處的天空。年輕的書記順著兩人的視線看過去。"}}, {"id": 306, "prop": "name", "attributes": {"content": "他愣在原地。"}}, {"id": 307, "prop": "Stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 308, "prop": "Dialog", "attributes": {}}, {"id": 309, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 310, "prop": "charslot", "attributes": {}}, {"id": 311, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 312, "prop": "image", "attributes": {"image": "51_i01_1", "screenadapt": "coverall", "xScale": 1.1, "yScale": 1.1, "y": 30.0}}, {"id": 313, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.1, "yScaleFrom": 1.1, "xScaleTo": 1.0, "yScaleTo": 1.0, "yTo": 0.0, "duration": 20.0, "block": "false"}}, {"id": 314, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 315, "prop": "playMusic", "attributes": {"key": "$faceoff_loop", "volume": 0.6}}, {"id": 316, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 317, "prop": "playsound", "attributes": {"key": "$d_avg_bionicuavs", "loop": "true", "channel": "bgs", "volume": 0.0}}, {"id": 318, "prop": "SoundVolume", "attributes": {"volume": 0.7, "channel": "bgs", "fadetime": 2.0}}, {"id": 319, "prop": "name", "attributes": {"content": "他們看見了飛翔的鱗群。"}}, {"id": 320, "prop": "name", "attributes": {"content": "那是？", "name": "喬迪"}}, {"id": 321, "prop": "name", "attributes": {"content": "仿生無人機。早年島民帶上岸的器物裡，曾有過類似的造物。", "name": "聖徒卡門"}}, {"id": 322, "prop": "StopSound", "attributes": {"channel": "bgs", "fadetime": 2.0}}, {"id": 323, "prop": "name", "attributes": {"content": "無人機矩陣眨眼間便已越過海面，與高聳的大燈塔遙相對應。其中一隻脫離編隊，緩緩懸停在三人的面前。"}}, {"id": 324, "prop": "name", "attributes": {"content": "機翼如鰭翕動，光的微粒在虛空中舞蹈，親切而富有磁性的女聲旋即響起。"}}, {"id": 325, "prop": "PlaySound", "attributes": {"key": "$d_avg_bionicuavs_tech"}}, {"id": 326, "prop": "Dialog", "attributes": {}}, {"id": 327, "prop": "image", "attributes": {"image": "51_i01_2", "screenadapt": "coverall", "fadetime": 2.0}}, {"id": 328, "prop": "Delay", "attributes": {"time": 3.0}}, {"id": 329, "prop": "name", "attributes": {"content": "（伊比利亞語）伊比利亞的諸位，請不必緊張。", "name": "？？？"}}, {"id": 330, "prop": "name", "attributes": {"content": "這是來自阿戈爾的致意。", "name": "？？？"}}, {"id": 331, "prop": "name", "attributes": {"content": "我是本國社會行政監察所的技術執政官之一，克萊門莎。", "name": "？？？"}}, {"id": 332, "prop": "name", "attributes": {"content": "卡門端舉提燈，平靜地直視著身前的無人機。"}}, {"id": 333, "prop": "name", "attributes": {"content": "兩種截然不同的光亮，彷彿兩個截然不同的文明的對話——或者對峙。"}}, {"id": 334, "prop": "name", "attributes": {"content": "伊比利亞審判庭，聖徒卡門·伊·伊比利亞。", "name": "聖徒卡門"}}, {"id": 335, "prop": "name", "attributes": {"content": "我想，這應當是我們兩國之間的首次正式交流。", "name": "聖徒卡門"}}, {"id": 336, "prop": "name", "attributes": {"content": "是這樣沒錯。", "name": "克萊門莎"}}, {"id": 337, "prop": "name", "attributes": {"content": "您的伊比利亞語很標準。", "name": "聖徒卡門"}}, {"id": 338, "prop": "name", "attributes": {"content": "離開本境前，我為自己錄入過伊比利亞的語言模組。如果我的表達有不得當的地方，還請您理解。", "name": "克萊門莎"}}, {"id": 339, "prop": "name", "attributes": {"content": "此外，也請原諒我暫時只能以這種形式與您溝通，伊比利亞……閣下。", "name": "克萊門莎"}}, {"id": 340, "prop": "name", "attributes": {"content": "我們對這種形式的交流沒有異議，但我對它發生得如此之遲感到遺憾，執政官閣下。", "name": "聖徒卡門"}}, {"id": 341, "prop": "name", "attributes": {"content": "被你們稱為“航道”的計劃據稱已經進行到後半，而近在咫尺的伊比利亞仍對種種細節一無所知。", "name": "聖徒卡門"}}, {"id": 342, "prop": "name", "attributes": {"content": "所以我們將迎接伊比利亞的使節前往我們的城市，阿戈爾尊重伊比利亞在被海嗣危機波及時所做出的努力。", "name": "克萊門莎"}}, {"id": 343, "prop": "name", "attributes": {"content": "“波及”——伊比利亞所面對的，只是危機的餘波？", "name": "聖徒卡門"}}, {"id": 344, "prop": "name", "attributes": {"content": "是的。", "name": "克萊門莎"}}, {"id": 345, "prop": "name", "attributes": {"content": "不必糾結外交辭令，閣下。", "name": "克萊門莎"}}, {"id": 346, "prop": "name", "attributes": {"content": "我們都認同語言的力量。而您的姓名，卡門·伊·伊比利亞，本身便已是一種象徵，勇氣與魄力的象徵。", "name": "克萊門莎"}}, {"id": 347, "prop": "name", "attributes": {"content": "所以阿戈爾才會來此。我們希望達成與伊比利亞、與陸上諸國的合作，開闢一條直抵陸地的航道。", "name": "克萊門莎"}}, {"id": 348, "prop": "name", "attributes": {"content": "我們將淨空從阿戈爾本境到陸地之間的大片海域，以便阿戈爾的主力抵達海岸。", "name": "克萊門莎"}}, {"id": 349, "prop": "name", "attributes": {"content": "……我想我不必提醒您，將大量軍隊派遣至其他國家的邊境，這種行為在陸上意味著什麼。", "name": "聖徒卡門"}}, {"id": 350, "prop": "name", "attributes": {"content": "意味著為了對抗即將到來的巨大威脅，我們將竭盡所能。", "name": "克萊門莎"}}, {"id": 351, "prop": "name", "attributes": {"content": "如有必要，我願意前往陸地與您會晤，向您詳細解釋一切。但來到深海，會方便諸位更好地理解我們當下的處境。", "name": "克萊門莎"}}, {"id": 352, "prop": "name", "attributes": {"content": "第八與第十軍團的艦隊正在有序清剿沿途海嗣。他們隨後將迎接諸位前往我們的城市，彌利亞留姆。", "name": "克萊門莎"}}, {"id": 353, "prop": "name", "attributes": {"content": "無人機編隊將持續向諸位同步戰鬥進展與環境變化，直到諸位安全抵達。", "name": "克萊門莎"}}, {"id": 354, "prop": "name", "attributes": {"content": "海洋或許正在醞釀一場前所未有的災難。", "name": "克萊門莎"}}, {"id": 355, "prop": "name", "attributes": {"content": "而審判官閣下，我憂心大地即使再浩瀚，也不過是另一座孤島。", "name": "克萊門莎"}}, {"id": 356, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 357, "prop": "Dialog", "attributes": {}}, {"id": 358, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 359, "prop": "charslot", "attributes": {}}, {"id": 360, "prop": "image", "attributes": {}}, {"id": 361, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 362, "prop": "Background", "attributes": {"image": "27_g19_lighthouse_front", "screenadapt": "coverall"}}, {"id": 363, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 364, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 365, "prop": "name", "attributes": {"content": "無人機矩陣收斂了輝光，這場突如其來的通訊已經結束。"}}, {"id": 366, "prop": "name", "attributes": {"content": "海風依舊在吹，老人緩緩放下了手中的提燈。"}}, {"id": 367, "prop": "Dialog", "attributes": {}}, {"id": 368, "prop": "playMusic", "attributes": {"intro": "$ponder_intro", "key": "$ponder_loop", "volume": 0.6}}, {"id": 369, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4009_irene_1#7$1", "duration": 0.5}}, {"id": 370, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 371, "prop": "name", "attributes": {"content": "“直抵陸地的航道”——她的表達很得體，但……", "name": "艾麗妮"}, "figure_art": "avg_4009_irene_1#7$1"}, {"id": 372, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_447_1#1$1"}}, {"id": 373, "prop": "name", "attributes": {"content": "阿戈爾無疑是傲慢的。", "name": "聖徒卡門"}, "figure_art": "avg_npc_447_1#1$1"}, {"id": 374, "prop": "name", "attributes": {"content": "一個手持利器的傲慢大人，不屑於對赤手空拳的孩子耍弄心機與手腕。", "name": "聖徒卡門"}, "figure_art": "avg_npc_447_1#1$1"}, {"id": 375, "prop": "name", "attributes": {"content": "艾麗妮，將剛剛的通訊內容同步給我們的合作夥伴。", "name": "聖徒卡門"}, "figure_art": "avg_npc_447_1#1$1"}, {"id": 376, "prop": "name", "attributes": {"content": "凱爾希已經同意作為伊比利亞的使節出訪阿戈爾，一直對航道計劃心存疑慮的深海獵人此時應該也已經做出了決定。", "name": "聖徒卡門"}, "figure_art": "avg_npc_447_1#1$1"}, {"id": 377, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4009_irene_1#7$1"}}, {"id": 378, "prop": "name", "attributes": {"content": "是！", "name": "艾麗妮"}, "figure_art": "avg_4009_irene_1#7$1"}, {"id": 379, "prop": "name", "attributes": {"content": "我也會盡快與格蘭法洛的其他審判官將事務交接清楚。", "name": "艾麗妮"}, "figure_art": "avg_4009_irene_1#7$1"}, {"id": 380, "prop": "Dialog", "attributes": {}}, {"id": 381, "prop": "playsound", "attributes": {"key": "$rungeneral"}}, {"id": 382, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 383, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 384, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_447_1#1$1", "duration": 1.0}}, {"id": 385, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1380_1#1$1", "duration": 1.0}}, {"id": 386, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 387, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1380_1#1$1", "focus": "r"}}, {"id": 388, "prop": "name", "attributes": {"content": "老師，剛才與阿戈爾通訊的全部內容，我都做了紀錄，請您過目。", "name": "喬迪"}}, {"id": 389, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1380_1#8$1", "focus": "r"}}, {"id": 390, "prop": "name", "attributes": {"content": "您、您是否批准我前往……", "name": "喬迪"}}, {"id": 391, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_447_1#1$1", "focus": "l"}}, {"id": 392, "prop": "name", "attributes": {"content": "書記，一週前你就已經提交了申請。", "name": "聖徒卡門"}}, {"id": 393, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1380_1#8$1", "focus": "r"}}, {"id": 394, "prop": "name", "attributes": {"content": "是的，既然現在阿戈爾的艦隊馬上就要來了，我想，是不是……", "name": "喬迪"}}, {"id": 395, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_447_1#1$1", "focus": "l"}}, {"id": 396, "prop": "name", "attributes": {"content": "如果已經做了決定，猶豫反而會讓你的表態沒有說服力。", "name": "聖徒卡門"}}, {"id": 397, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1380_1#10$1", "focus": "r"}}, {"id": 398, "prop": "name", "attributes": {"content": "我很小的時候，蒂亞戈叔叔就總是憂心忡忡的。他跟我說：“喬迪，你應該離開格蘭法洛，離開伊比利亞。”", "name": "喬迪"}}, {"id": 399, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1380_1#3$1", "focus": "r"}}, {"id": 400, "prop": "name", "attributes": {"content": "但他沒辦法告訴我，我該去哪裡。", "name": "喬迪"}}, {"id": 401, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1380_1#1$1", "focus": "r"}}, {"id": 402, "prop": "name", "attributes": {"content": "阿戈爾，那是我的家鄉，我的家鄉在大海裡，而大海無法靠近。我從沒聽過阿戈爾的聲音，也從沒看過阿戈爾的模樣。", "name": "喬迪"}}, {"id": 403, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1380_1#6$1", "focus": "r"}}, {"id": 404, "prop": "name", "attributes": {"content": "但現在，它很近。", "name": "喬迪"}}, {"id": 405, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_447_1#1$1", "focus": "l"}}, {"id": 406, "prop": "name", "attributes": {"content": "審判庭同意你的申請，喬迪·方塔納羅薩。你將作為伊比利亞的使節，與艾麗妮和凱爾希一同前往阿戈爾的城市。", "name": "聖徒卡門"}}, {"id": 407, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1380_1#8$1", "focus": "r"}}, {"id": 408, "prop": "name", "attributes": {"content": "謝謝您。", "name": "喬迪"}}, {"id": 409, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_447_1#1$1", "focus": "l"}}, {"id": 410, "prop": "name", "attributes": {"content": "不。這並不是一次獎勵，你在審判庭的工作做得算不上好。", "name": "聖徒卡門"}}, {"id": 411, "prop": "name", "attributes": {"content": "選擇艾麗妮，是因為她已經做好了準備，甚至為此拋棄了自己堅持許久的信念。", "name": "聖徒卡門"}}, {"id": 412, "prop": "name", "attributes": {"content": "而選擇你，恰恰是因為你仍然困惑和悵然，軟弱終究會腐蝕你。", "name": "聖徒卡門"}}, {"id": 413, "prop": "name", "attributes": {"content": "加入審判庭是一次考驗，回到自己的家鄉，同樣也是一次考驗。", "name": "聖徒卡門"}}, {"id": 414, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1380_1#6$1", "focus": "r"}}, {"id": 415, "prop": "name", "attributes": {"content": "我、我明白的，老師。", "name": "喬迪"}}, {"id": 416, "prop": "Dialog", "attributes": {}}, {"id": 417, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 418, "prop": "charslot", "attributes": {}}, {"id": 419, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 420, "prop": "Background", "attributes": {"image": "51_g12_seabed", "screenadapt": "coverall"}}, {"id": 421, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 422, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 423, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_463_1#1$1", "duration": 1.5}}, {"id": 424, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 425, "prop": "playsound", "attributes": {"key": "$d_avg_horse"}}, {"id": 426, "prop": "name", "attributes": {"content": "（興奮的嘶鳴）", "name": "羅辛南特"}, "figure_art": "avg_npc_463_1#1$1"}, {"id": 427, "prop": "Dialog", "attributes": {}}, {"id": 428, "prop": "charslot", "attributes": {}}, {"id": 429, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4145_Ulpia_1#1$1", "duration": 1.5}}, {"id": 430, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 431, "prop": "name", "attributes": {"content": "——", "name": "烏爾比安"}, "figure_art": "avg_4145_Ulpia_1#1$1"}, {"id": 432, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4145_Ulpia_1#3$1"}}, {"id": 433, "prop": "name", "attributes": {"content": "這裡已經是海溝的最深處。", "name": "烏爾比安"}, "figure_art": "avg_4145_Ulpia_1#3$1"}, {"id": 434, "prop": "name", "attributes": {"content": "它們掏空了海溝兩側的峭壁，向內築巢。所以我們繞了好幾圈，都沒有發現這裡。", "name": "烏爾比安"}, "figure_art": "avg_4145_Ulpia_1#3$1"}, {"id": 435, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_463_1#1$1"}}, {"id": 436, "prop": "playsound", "attributes": {"key": "$d_avg_horse"}}, {"id": 437, "prop": "name", "attributes": {"content": "（警惕的嘶鳴）", "name": "羅辛南特"}, "figure_art": "avg_npc_463_1#1$1"}, {"id": 438, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4145_Ulpia_1#1$1"}}, {"id": 439, "prop": "name", "attributes": {"content": "嗯。我也聞到了。", "name": "烏爾比安"}, "figure_art": "avg_4145_Ulpia_1#1$1"}, {"id": 440, "prop": "name", "attributes": {"content": "這種氣味……海嗣在摧毀了原有的海洋生態之後，又建立了一套完全只為它們自己服務的生態系統。", "name": "烏爾比安"}, "figure_art": "avg_4145_Ulpia_1#1$1"}, {"id": 441, "prop": "name", "attributes": {"content": "如此完善的海嗣生態系統，原本只存在於海洋的深處。", "name": "烏爾比安"}, "figure_art": "avg_4145_Ulpia_1#1$1"}, {"id": 442, "prop": "name", "attributes": {"content": "回去吧，羅辛南特。接下來我一個人進去。", "name": "烏爾比安"}, "figure_art": "avg_4145_Ulpia_1#1$1"}, {"id": 443, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_463_1#1$1"}}, {"id": 444, "prop": "name", "attributes": {"content": "（不悅地晃動脖頸）", "name": "羅辛南特"}, "figure_art": "avg_npc_463_1#1$1"}, {"id": 445, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4145_Ulpia_1#1$1"}}, {"id": 446, "prop": "name", "attributes": {"content": "整塊大陸架都在變化，我需要知道，究竟是誰在使海浪鼓噪。", "name": "烏爾比安"}, "figure_art": "avg_4145_Ulpia_1#1$1"}, {"id": 447, "prop": "name", "attributes": {"content": "告訴騎士，別停止狩獵。", "name": "烏爾比安"}, "figure_art": "avg_4145_Ulpia_1#1$1"}, {"id": 448, "prop": "name", "attributes": {"content": "我們只是暫時分別。", "name": "烏爾比安"}, "figure_art": "avg_4145_Ulpia_1#1$1"}, {"id": 449, "prop": "Dialog", "attributes": {}}, {"id": 450, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 451, "prop": "charslot", "attributes": {"duration": 1.5}}, {"id": 452, "prop": "playsound", "attributes": {"key": "$d_avg_swimdeepsea"}}, {"id": 453, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 454, "prop": "image", "attributes": {"image": "51_i03", "screenadapt": "coverall", "xScale": 1.1, "yScale": 1.1}}, {"id": 455, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.1, "yScaleFrom": 1.1, "xScaleTo": 1.0, "yScaleTo": 1.0, "xTo": 0.0, "duration": 45.0, "block": "false"}}, {"id": 456, "prop": "playsound", "attributes": {"key": "$d_avg_underwateramb", "loop": "true", "channel": "bgs", "volume": 0.0}}, {"id": 457, "prop": "SoundVolume", "attributes": {"volume": 0.4, "channel": "bgs", "fadetime": 3.0}}, {"id": 458, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 20.0, "block": "false"}}, {"id": 459, "prop": "Delay", "attributes": {"time": 3.0}}, {"id": 460, "prop": "playMusic", "attributes": {"intro": "$chenandwei_intro", "key": "$chenandwei_loop", "volume": 0.6}}, {"id": 461, "prop": "name", "attributes": {"content": "烏爾比安游進了巢穴。"}}, {"id": 462, "prop": "name", "attributes": {"content": "他沒有選擇潛行，因為發光的植物海嗣點亮了巢穴的每一個角落，他無處可藏。"}}, {"id": 463, "prop": "name", "attributes": {"content": "在盤旋而上的厚實葉片之間，造型奇特的微小生物在酣眠或游弋。"}}, {"id": 464, "prop": "name", "attributes": {"content": "海床原本的岩石已不可見。溟痕緩緩搖動著細小的觸肢，捕捉著有機物的碎屑，它們織成層層疊疊的菌毯，淹沒了烏爾比安游動的聲響。"}}, {"id": 465, "prop": "name", "attributes": {"content": "他清晰地感受到自己身體的變化。意識在舒展，軀殼在放鬆，體內的每一個細胞都在試圖回應著什麼。"}}, {"id": 466, "prop": "name", "attributes": {"content": "他分明是闖入這裡的異類，但整個巢穴都在向自己盛開。"}}, {"id": 467, "prop": "name", "attributes": {"content": "Ul……Ul-pian……咕……Ul-pianus，同胞。", "name": "海嗣"}}, {"id": 468, "prop": "name", "attributes": {"content": "烏爾比安幾乎能看穿海嗣接近透明的軀體，他在等待對方吐出捕食或者被他捕食之類的蠢話，但是並沒有。"}}, {"id": 469, "prop": "name", "attributes": {"content": "海嗣，在思考他的思考。"}}, {"id": 470, "prop": "name", "attributes": {"content": "終於。你走過長路。", "name": "海嗣"}}, {"id": 471, "prop": "name", "attributes": {"content": "這裡。營養足夠。褪去累贅的血肉。", "name": "海嗣"}}, {"id": 472, "prop": "name", "attributes": {"content": "回歸。滋長。遷徙。", "name": "海嗣"}}, {"id": 473, "prop": "name", "attributes": {"content": "哼。", "name": "烏爾比安"}}, {"id": 474, "prop": "name", "attributes": {"content": "我為你而生，Ul-pianus，只為你而生。", "name": "海嗣"}}, {"id": 475, "prop": "name", "attributes": {"content": "我解開你。疑惑。我引導你。回歸族群懷抱。", "name": "海嗣"}}, {"id": 476, "prop": "name", "attributes": {"content": "你們因何遷徙？你們要去向何方？", "name": "烏爾比安"}}, {"id": 477, "prop": "name", "attributes": {"content": "Ul-pianus，你仍動搖。", "name": "海嗣"}}, {"id": 478, "prop": "name", "attributes": {"content": "同胞，你需要知曉大群。你想要知曉大群。", "name": "海嗣"}}, {"id": 479, "prop": "name", "attributes": {"content": "生代即將甦醒。生代需要回歸。新的循環。建構海洋。離開海洋。", "name": "海嗣"}}, {"id": 480, "prop": "name", "attributes": {"content": "生代甦醒？離開海洋？", "name": "烏爾比安"}}, {"id": 481, "prop": "name", "attributes": {"content": "大群。看見。新的長路。我們盡快——", "name": "海嗣"}}, {"id": 482, "prop": "name", "attributes": {"content": "……那麼，那座城市在進行的事情，與你們有什麼關聯？", "name": "烏爾比安"}}, {"id": 483, "prop": "Dialog", "attributes": {}}, {"id": 484, "prop": "StopSound", "attributes": {"channel": "bgs", "fadetime": 2.0}}, {"id": 485, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 486, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 487, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 488, "prop": "Image", "attributes": {}}, {"id": 489, "prop": "charslot", "attributes": {}}, {"id": 490, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}