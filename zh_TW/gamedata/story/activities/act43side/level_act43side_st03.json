, {"id": 293, "prop": "Sticker", "attributes": {"id": "st2", "text": "導演/編劇   斯蒂芬·奎", "delay": 0.001, "width": 800.0, "x": 250.0, "y": 350.0, "duration": 1.0, "alignment": "center", "size": 24.0, "block": "false"}}, {"id": 294, "prop": "Sticker", "attributes": {"id": "st3", "text": "統籌   謝莉", "delay": 0.001, "width": 800.0, "x": 250.0, "y": 450.0, "duration": 1.0, "alignment": "center", "size": 24.0, "block": "true"}}, {"id": 295, "prop": "Sticker", "attributes": {"id": "st1", "duration": 1.0}}, {"id": 296, "prop": "Sticker", "attributes": {"id": "st2", "duration": 1.0}}, {"id": 297, "prop": "Sticker", "attributes": {"id": "st3", "duration": 1.0}}, {"id": 298, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 299, "prop": "Sticker", "attributes": {"id": "st4", "text": "美術部門   卡爾、鮑勃、蒂比、傑里科爾……", "delay": 0.001, "width": 800.0, "x": 250.0, "y": 200.0, "duration": 1.0, "alignment": "center", "size": 24.0, "block": "false"}}, {"id": 300, "prop": "Sticker", "attributes": {"id": "st5", "text": "攝製部門   阿布納、列爾……", "delay": 0.001, "width": 800.0, "x": 250.0, "y": 300.0, "duration": 1.0, "alignment": "center", "size": 24.0, "block": "false"}}, {"id": 301, "prop": "Sticker", "attributes": {"id": "st6", "text": "服裝部門   瑪麗昂……", "delay": 0.001, "width": 800.0, "x": 250.0, "y": 400.0, "duration": 1.0, "alignment": "center", "size": 24.0, "block": "false"}}, {"id": 302, "prop": "Sticker", "attributes": {"id": "st7", "text": "道具部門   莫伊拉……", "delay": 0.001, "width": 800.0, "x": 250.0, "y": 500.0, "duration": 1.0, "alignment": "center", "size": 24.0, "block": "true"}}, {"id": 303, "prop": "Sticker", "attributes": {"id": "st4", "duration": 1.0}}, {"id": 304, "prop": "Sticker", "attributes": {"id": "st5", "duration": 1.0}}, {"id": 305, "prop": "Sticker", "attributes": {"id": "st6", "duration": 1.0}}, {"id": 306, "prop": "Sticker", "attributes": {"id": "st7", "duration": 1.0}}, {"id": 307, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 308, "prop": "Sticker", "attributes": {"id": "st8", "text": "……", "delay": 0.001, "width": 800.0, "x": 250.0, "y": 250.0, "duration": 1.0, "alignment": "center", "size": 24.0, "block": "false"}}, {"id": 309, "prop": "Sticker", "attributes": {"id": "st9", "text": "場務部門   霍汀……", "delay": 0.001, "width": 800.0, "x": 250.0, "y": 350.0, "duration": 1.0, "alignment": "center", "size": 24.0, "block": "false"}}, {"id": 310, "prop": "Sticker", "attributes": {"id": "st10", "text": "……", "delay": 0.001, "width": 800.0, "x": 250.0, "y": 450.0, "duration": 1.0, "alignment": "center", "size": 24.0, "block": "true"}}, {"id": 311, "prop": "Sticker", "attributes": {"id": "st8", "duration": 1.0}}, {"id": 312, "prop": "Sticker", "attributes": {"id": "st9", "duration": 1.0}}, {"id": 313, "prop": "Sticker", "attributes": {"id": "st10", "duration": 1.0}}, {"id": 314, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 315, "prop": "PlaySound", "attributes": {"key": "$d_avg_filmprojection"}}, {"id": 316, "prop": "StopSound", "attributes": {"channel": "bgs", "fadetime": 0.5}}, {"id": 317, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 318, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.1, "block": "true"}}, {"id": 319, "prop": "bgeffect", "attributes": {}}, {"id": 320, "prop": "Image", "attributes": {"image": "62_i11_1", "screenadapt": "coverall"}}, {"id": 321, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.1, "yScaleFrom": 1.1, "xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 30.0, "block": "false"}}, {"id": 322, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 323, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 324, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 325, "prop": "PlayMusic", "attributes": {"key": "$m_sys_rglk1secretstage_loop", "volume": 0.6}}, {"id": 326, "prop": "name", "attributes": {"content": "……結束了？", "name": "觀眾A"}}, {"id": 327, "prop": "name", "attributes": {"content": "結束了。", "name": "觀眾B"}}, {"id": 328, "prop": "name", "attributes": {"content": "你覺得這部電影怎麼樣？", "name": "觀眾A"}}, {"id": 329, "prop": "name", "attributes": {"content": "我聽說了一些這個劇組經歷的事情，命案啊天災啊什麼的，整部電影的管理一塌糊塗……", "name": "觀眾B"}}, {"id": 330, "prop": "name", "attributes": {"content": "進場之前，我以為電影本身不可能會比這些八卦有趣，結果……", "name": "觀眾B"}}, {"id": 331, "prop": "name", "attributes": {"content": "一場荒唐的貴族婚變，最後以天災收尾——所有的反轉都在情理之中，但好多人物的行為都透露著幾分詭異……", "name": "觀眾B"}}, {"id": 332, "prop": "name", "attributes": {"content": "雖然不太好說是好還是不好，但我覺得蠻有趣的。", "name": "觀眾B"}}, {"id": 333, "prop": "name", "attributes": {"content": "老實說，我也是。", "name": "觀眾A"}}, {"id": 334, "prop": "name", "attributes": {"content": "拋開故事不談，它的製作也應該很有爭議，畢竟連拍攝風格都不統一……", "name": "觀眾A"}}, {"id": 335, "prop": "name", "attributes": {"content": "前面是精緻細膩的正劇拍法，越到後面反而越粗糙，尤其是天災那幾場高潮戲，完全變成了記錄片！", "name": "觀眾A"}}, {"id": 336, "prop": "name", "attributes": {"content": "喜歡的觀眾會給它滿分，討厭的觀眾應該也不會留情。", "name": "觀眾A"}}, {"id": 337, "prop": "name", "attributes": {"content": "話又說回來，很有趣，不是嗎？", "name": "觀眾B"}}, {"id": 338, "prop": "name", "attributes": {"content": "這幾年，藍卡塢越來越無聊了，就連在這個“另類電影節”上放的電影，也越來越不另類……", "name": "觀眾B"}}, {"id": 339, "prop": "name", "attributes": {"content": "起碼這部《杜邦夫人》，我願意為它買一張電影票。", "name": "觀眾B"}}, {"id": 340, "prop": "name", "attributes": {"content": "等一下映後座談開始時，再看創作團隊怎麼說吧。", "name": "觀眾A"}}, {"id": 341, "prop": "name", "attributes": {"content": "對了，聽說最前面那個一臉倒楣樣的傢伙就是劇組的成員……", "name": "觀眾A"}}, {"id": 342, "prop": "dialog", "attributes": {}}, {"id": 343, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 344, "prop": "name", "attributes": {"content": "呼……真倒楣。", "name": "霍汀"}}, {"id": 345, "prop": "name", "attributes": {"content": "申請了一個月，好不容易作為最後一個場務被招進劇組，結果一進去就發生了那麼多事，還撞見了屍體，失眠了好幾晚……", "name": "霍汀"}}, {"id": 346, "prop": "name", "attributes": {"content": "要不是失眠，也不會在靠近天災的時候，明明都跟著大家躲進了動力層，安全了，結果還是因為恍神踢到牆壁，腳骨折了……", "name": "霍汀"}}, {"id": 347, "prop": "name", "attributes": {"content": "要不是腳骨折了，也不會錯過公車，連這場電影的前半段都沒有趕上……", "name": "霍汀"}}, {"id": 348, "prop": "name", "attributes": {"content": "字幕在滾動著，倒楣的場務喃喃自語，她想起自己這段時間的經歷，不禁有些悲從中來。"}}, {"id": 349, "prop": "name", "attributes": {"content": "就連銀幕上那些畫面，她也覺得陌生，那些熟悉的面孔、熟悉的場景以一種她無法理解的方式被組合在了一起……"}}, {"id": 350, "prop": "name", "attributes": {"content": "就像她“跌宕起伏”的人生。"}}, {"id": 351, "prop": "name", "attributes": {"content": "然後，她在演職員表的最後看到了自己的名字。"}}, {"id": 352, "prop": "name", "attributes": {"content": "“場務部門：霍汀”……", "name": "霍汀"}}, {"id": 353, "prop": "name", "attributes": {"content": "命運的手再怎麼翻覆，也終歸要落下一行，你所確信的，真實。"}}, {"id": 354, "prop": "dialog", "attributes": {}}, {"id": 355, "prop": "PlaySound", "attributes": {"key": "$d_avg_footsteps_flock", "volume": 1.0}}, {"id": 356, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 357, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 358, "prop": "Image", "attributes": {"image": "62_i11_2", "screenadapt": "coverall"}}, {"id": 359, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 360, "prop": "PlaySound", "attributes": {"key": "$d_avg_spotlight", "volume": 1.0}}, {"id": 361, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 362, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 363, "prop": "name", "attributes": {"content": "放映結束了，你不去參加映後座談嗎？", "name": "劇作家"}}, {"id": 364, "prop": "name", "attributes": {"content": "我不屬於他們。更何況……你們來了。", "name": "盧西恩"}}, {"id": 365, "prop": "name", "attributes": {"content": "哈哈，也是。", "name": "劇作家"}}, {"id": 366, "prop": "name", "attributes": {"content": "對了，很精彩……無論是戲裡，還是戲外。", "name": "劇作家"}}, {"id": 367, "prop": "name", "attributes": {"content": "盧西恩……", "name": "暮落"}}, {"id": 368, "prop": "name", "attributes": {"content": "嗯？", "name": "盧西恩"}}, {"id": 369, "prop": "name", "attributes": {"content": "他這次是真的死了？", "name": "暮落"}}, {"id": 370, "prop": "name", "attributes": {"content": "還是說，他依舊以某種方式活著？", "name": "暮落"}}, {"id": 371, "prop": "name", "attributes": {"content": "這是我需要思考的問題。", "name": "盧西恩"}}, {"id": 372, "prop": "name", "attributes": {"content": "暮落，你只要知道，就算你躲藏於羅德島上，也不必再憂心會被過往的陰影侵入夢境……", "name": "盧西恩"}}, {"id": 373, "prop": "name", "attributes": {"content": "劇作家，你可以盡情創作自己的劇本，任何題材、任何風格……", "name": "盧西恩"}}, {"id": 374, "prop": "name", "attributes": {"content": "猩紅劇團不復存在，你們自由了。", "name": "盧西恩"}}, {"id": 375, "prop": "name", "attributes": {"content": "……", "name": "暮落"}}, {"id": 376, "prop": "name", "attributes": {"content": "……", "name": "劇作家"}}, {"id": 377, "prop": "name", "attributes": {"content": "那你呢？", "name": "劇作家"}}, {"id": 378, "prop": "name", "attributes": {"content": "你剛剛說，你還需要思考有關他的結局——也就是說，你無法從這條路上離開，對吧？", "name": "劇作家"}}, {"id": 379, "prop": "name", "attributes": {"content": "“戲劇不死”……坐在我旁邊的，不再是“血鑽”，而是，“酒神”？", "name": "劇作家"}}, {"id": 380, "prop": "name", "attributes": {"content": "盧西恩，聽起來，你付出了很多代價……", "name": "暮落"}}, {"id": 381, "prop": "name", "attributes": {"content": "談不上。", "name": "盧西恩"}}, {"id": 382, "prop": "Image", "attributes": {"image": "62_i11_3", "screenadapt": "coverall", "fadetime": 0.5}}, {"id": 383, "prop": "name", "attributes": {"content": "如果說，此前我們連復仇或逃遁都是被寫就的劇本，那麼此刻，我們終於得以走進未來。", "name": "盧西恩"}}, {"id": 384, "prop": "name", "attributes": {"content": "我會重新開始遊歷、歌唱、演出，直到我確信我所形塑的事物，足以與自己的喜悅和痛苦相符……", "name": "盧西恩"}}, {"id": 385, "prop": "Image", "attributes": {"image": "62_i11_2", "screenadapt": "coverall", "fadetime": 0.5}}, {"id": 386, "prop": "name", "attributes": {"content": "它可能是一個新的劇團或主張，一些新的奇遇與故事，或者，更刺眼的明天，更慘烈的真相……", "name": "盧西恩"}}, {"id": 387, "prop": "name", "attributes": {"content": "……", "name": "暮落"}}, {"id": 388, "prop": "name", "attributes": {"content": "……", "name": "劇作家"}}, {"id": 389, "prop": "name", "attributes": {"content": "喂，暮落，怎麼說也算認識很久了……要幫他嗎？", "name": "劇作家"}}, {"id": 390, "prop": "name", "attributes": {"content": "盧西恩，你、你有信心嗎？", "name": "暮落"}}, {"id": 391, "prop": "name", "attributes": {"content": "當然。", "name": "盧西恩"}}, {"id": 392, "prop": "name", "attributes": {"content": "奔突於迷途者，閉塞了感識與內心的苦行人，在偉大與低微中跋涉的凡俗，咀嚼著痛苦的生靈……", "name": "盧西恩"}}, {"id": 393, "prop": "name", "attributes": {"content": "這片大地從來都不缺演員。", "name": "盧西恩"}}, {"id": 394, "prop": "dialog", "attributes": {}}, {"id": 395, "prop": "PlaySound", "attributes": {"key": "$d_avg_spotlightc", "volume": 1.0}}, {"id": 396, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 397, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 398, "prop": "image", "attributes": {}}, {"id": 399, "prop": "Image", "attributes": {"image": "62_i11_4", "screenadapt": "coverall"}}, {"id": 400, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.0, "yScaleFrom": 1.0, "xScaleTo": 1.05, "yScaleTo": 1.05, "duration": 10.0, "block": "false"}}, {"id": 401, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 402, "prop": "PlaySound", "attributes": {"key": "$d_avg_spotlight", "volume": 1.0}}, {"id": 403, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 404, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 405, "prop": "name", "attributes": {"content": "……歡迎你們，加入“劇團”。", "name": "盧西恩"}}, {"id": 406, "prop": "dialog", "attributes": {}}, {"id": 407, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 408, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 409, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 410, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 411, "prop": "charslot", "attributes": {}}, {"id": 412, "prop": "Background", "attributes": {}}, {"id": 413, "prop": "Image", "attributes": {}}, {"id": 414, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}