s": {"time": 1.5}}, {"id": 161, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 162, "prop": "name", "attributes": {"content": "早知道白天就離開這個鬼地方了……嗚……到底發生什麼事了……", "name": "害怕的工作人員"}, "figure_art": "avg_npc_1847_1#1$1"}, {"id": 163, "prop": "dialog", "attributes": {}}, {"id": 164, "prop": "charslot", "attributes": {}}, {"id": 165, "prop": "PlaySound", "attributes": {"key": "$d_avg_crowdrun", "volume": 1.0}}, {"id": 166, "prop": "CameraShake", "attributes": {"duration": 2.0, "xstrength": 10.0, "ystrength": 10.0, "vibrato": 30.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 167, "prop": "name", "attributes": {"content": "從房間湧出的劇組成員擠滿了走廊，每個人都對現在的狀況毫無頭緒。"}}, {"id": 168, "prop": "name", "attributes": {"content": "盧西恩的影子穿過咒罵、抱怨、哀嘆、祈禱的人群，來到走廊盡頭，向窗戶外看去。"}}, {"id": 169, "prop": "dialog", "attributes": {}}, {"id": 170, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1828_1#7$1", "duration": 1.0}}, {"id": 171, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 172, "prop": "name", "attributes": {"content": "……", "name": "盧西恩"}, "figure_art": "avg_npc_1828_1#7$1"}, {"id": 173, "prop": "dialog", "attributes": {}}, {"id": 174, "prop": "charslot", "attributes": {"slot": "l", "focus": "n"}}, {"id": 175, "prop": "name", "attributes": {"content": "你們有沒有覺得……地塊越開越快了？！", "name": "害怕的工作人員"}}, {"id": 176, "prop": "dialog", "attributes": {}}, {"id": 177, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 178, "prop": "StopSound", "attributes": {"channel": "e", "fadetime": 2.0}}, {"id": 179, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 180, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 181, "prop": "charslot", "attributes": {}}, {"id": 182, "prop": "Background", "attributes": {"image": "62_g6_proproom", "screenadapt": "coverall"}}, {"id": 183, "prop": "Delay", "attributes": {"time