k": "true"}}, {"id": 207, "prop": "charslot", "attributes": {}}, {"id": 208, "prop": "PlayMusic", "attributes": {"key": "$monastery_sad_loop", "volume": 0.6}}, {"id": 209, "prop": "Background", "attributes": {"image": "62_g10_dormitory", "screenadapt": "coverall"}}, {"id": 210, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1828_1#1$1"}}, {"id": 211, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "amount": 0.8, "keep": "true"}}, {"id": 212, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 213, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 214, "prop": "name", "attributes": {"content": "勞拉，並沒有妹妹。", "name": "盧西恩"}, "figure_art": "avg_npc_1828_1#1$1"}, {"id": 215, "prop": "name", "attributes": {"content": "……她從不存在於你的人生。", "name": "盧西恩"}, "figure_art": "avg_npc_1828_1#1$1"}, {"id": 216, "prop": "dialog", "attributes": {}}, {"id": 217, "prop": "PlaySound", "attributes": {"key": "$flashback", "volume": 0.8}}, {"id": 218, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 219, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 220, "prop": "charslot", "attributes": {}}, {"id": 221, "prop": "Background", "attributes": {"image": "62_g6_proproom", "screenadapt": "coverall"}}, {"id": 222, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "amount": 0.0, "keep": "true"}}, {"id": 223, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1831_1#5$2"}}, {"id": 224, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 225, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 226, "prop": "name", "attributes": {"content": "……", "name": "莫伊拉"}, "figure_art": "avg_npc_1831_1#5$2"}, {"id": 227, "prop": "name", "attributes": {"content": "怎、怎麼會……", "name": "莫伊拉"}, "figure_art": "avg_npc_1831_1#5$2"}, {"id": 228, "prop": "dialog", "attributes": {}}, {"id": 229, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 230, "prop": "charslot", "attributes": {"duration": 1.5, "isblock": "true"}}, {"id": 231, "prop": "PlaySound", "attributes": {"key": "$d_avg_weapons_drop", "volume": 1.0}}, {"id": 232, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 233, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 234, "prop": "charslot", "attributes": {}}, {"id": 235, "prop": "Background", "attributes": {}}, {"id": 236, "prop": "name", "attributes": {"content": "莫伊拉喃喃不停，她在道具間的雜物堆裡翻找著，終於，她將那個復古攝影機擺好，從貼身的口袋掏出了一卷錄影帶……"}}, {"id": 237, "prop": "name", "attributes": {"content": "一卷她看過無數遍的錄影帶。"}}, {"id": 238, "prop": "name", "attributes": {"content": "她按下了放映鍵。"}}, {"id": 239, "prop": "dialog", "attributes": {}}, {"id": 240, "prop": "bgeffect", "attributes": {"name": "$eb_062cg_tvnoise", "layer": 1.0}}, {"id": 241, "prop": "Image", "attributes": {"image": "62_i04_1", "screenadapt": "coverall"}}, {"id": 242, "prop": "PlaySound", "attributes": {"key": "$d_avg_filmprojection"}}, {"id": 243, "prop": "playsound", "attributes": {"key": "$d_avg_oldtvelectricity", "loop": "true", "channel": "fi"}}, {"id": 244, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 4.0, "block": "true"}}, {"id": 245, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 246, "prop": "name", "attributes": {"content": "一張女孩的笑臉出現在了螢幕上。"}}, {"id": 247, "prop": "name", "attributes": {"content": "……勞拉。", "name": "莫伊拉"}}, {"id": 248, "prop": "name", "attributes": {"content": "……我的姐姐。你明明，這麼、這麼真實……", "name": "莫伊拉"}}, {"id": 249, "prop": "name", "attributes": {"content": "你大笑的時候只有左邊的臉頰有梨渦，你的瞳孔是淺綠色的，你的眼睛很大，你看著我的時候，總是那麼溫柔。", "name": "莫伊拉"}}, {"id": 250, "prop": "name", "attributes": {"content": "你可以半分鐘削完一個蘋果而皮一點都不斷，你會在開心的時候吹清亮的口哨，你會用源石技藝結出小雪花當作髮夾……", "name": "莫伊拉"}}, {"id": 251, "prop": "name", "attributes": {"content": "你告訴我自己在藍卡塢的經歷，出演的第一個角色在最後的正式版本裡被剪輯得只剩下三秒的鏡頭……", "name": "莫伊拉"}}, {"id": 252, "prop": "name", "attributes": {"content": "你告訴我自己又多爭取到了幾場戲份，雖然有幾個傢伙感到不滿，但劇組裡的人們還是很照顧你的……", "name": "莫伊拉"}}, {"id": 253, "prop": "name", "attributes": {"content": "你告訴我哪怕是從連錄影機都買不到的小鎮來到藍卡塢，很多東西都要從零開始學，很多別人容易得到的機遇對我們來說都很遙遠……", "name": "莫伊拉"}}, {"id": 254, "prop": "name", "attributes": {"content": "也不應該灰心喪氣。", "name": "莫伊拉"}}, {"id": 255, "prop": "name", "attributes": {"content": "你從來都不會提及自己被怎麼欺負，受了多少委屈，你總是繪聲繪色地講起藍卡塢的朝陽，滿懷自信地憧憬著未來……", "name": "莫伊拉"}}, {"id": 256, "prop": "name", "attributes": {"content": "你也有情緒低落的時候，即便那時你也只是說，夜深人靜，看著天邊的雙月，會很想回家……", "name": "莫伊拉"}}, {"id": 257, "prop": "name", "attributes": {"content": "你告訴我，我們很像，你會永遠鼓勵我支持我……", "name": "莫伊拉"}}, {"id": 258, "prop": "name", "attributes": {"content": "我們從小——", "name": "莫伊拉"}}, {"id": 259, "prop": "name", "attributes": {"content": "莫伊拉突然停了下來。"}}, {"id": 260, "prop": "name", "attributes": {"content": "她發瘋似的搖著自己的腦袋，試圖從記憶深處逼出更多的細節。"}}, {"id": 261, "prop": "name", "attributes": {"content": "然而她卻無法再繼續說下去了，她發現自己有關勞拉的記憶，停留在了一個異常清晰的斷點——"}}, {"id": 262, "prop": "name", "attributes": {"content": "她們不曾小時候手牽著手在草地上奔跑，她們不曾在父母的歌聲中相依著睡著……"}}, {"id": 263, "prop": "name", "attributes": {"content": "更早之前，有關這個姐姐的畫面，一片空白。"}}, {"id": 264, "prop": "name", "attributes": {"content": "……", "name": "莫伊拉"}}, {"id": 265, "prop": "dialog", "attributes": {}}, {"id": 266, "prop": "bgeffect", "attributes": {"fade": "true", "fadetime": 0.2}}, {"id": 267, "prop": "StopSound", "attributes": {"channel": "fi", "fadetime": 0.2}}, {"id": 268, "prop": "PlaySound", "attributes": {"key": "$d_avg_filmprojection"}}, {"id": 269, "prop": "Image", "attributes": {"image": "62_i04_2", "screenadapt": "coverall", "fadetime": 0.2}}, {"id": 270, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 271, "prop": "name", "attributes": {"content": "錄影帶在此刻播放完畢，電視機的螢幕漆黑一片。"}}, {"id": 272, "prop": "name", "attributes": {"content": "莫伊拉看見了自己的臉。"}}, {"id": 273, "prop": "name", "attributes": {"content": "眼淚在無聲地流淌著。"}}, {"id": 274, "prop": "name", "attributes": {"content": "你從不曾存在於勞拉的人生……", "name": "莫伊拉"}}, {"id": 275, "prop": "name", "attributes": {"content": "勞拉也從不曾存在於你的人生……", "name": "莫伊拉"}}, {"id": 276, "prop": "name", "attributes": {"content": "可是、可是如果真的是這樣……", "name": "莫伊拉"}}, {"id": 277, "prop": "name", "attributes": {"content": "莫伊拉，你還剩下什麼？", "name": "莫伊拉"}}, {"id": 278, "prop": "name", "attributes": {"content": "……你是誰？", "name": "莫伊拉"}}, {"id": 279, "prop": "dialog", "attributes": {}}, {"id": 280, "prop": "stopmusic", "attributes": {"fadetime": 3.0}}, {"id": 281, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 282, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 283, "prop": "image", "attributes": {}}, {"id": 284, "prop": "Background", "attributes": {"image": "62_g7_mobileplotstreet_d", "screenadapt": "coverall"}}, {"id": 285, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 286, "prop": "name", "attributes": {"content": "唉……兇案接連不斷，凌晨又發生了原因不明的爆炸，到底怎麼了……", "name": "倒楣的場務"}}, {"id": 287, "prop": "dialog", "attributes": {}}, {"id": 288, "prop": "PlaySound", "attributes": {"key": "$d_avg_snowstormflp", "volume": 0.0, "loop": "true", "channel": "sn"}}, {"id": 289, "prop": "SoundVolume", "attributes": {"volume": 1.0, "channel": "sn", "fadetime": 2.0}}, {"id": 290, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 291, "prop": "PlayMusic", "attributes": {"intro": "$nervous_intro", "key": "$nervous_loop", "volume": 0.6}}, {"id": 292, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 293, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 294, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 295, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1846_1#3$1", "posfrom": "200,0", "posto": "-0,0", "duration": 1.5, "isblock": "true"}}, {"id": 296, "prop": "name", "attributes": {"content": "風怎麼這麼大？", "name": "倒楣的場務"}, "figure_art": "avg_npc_1846_1#3$1"}, {"id": 297, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1846_1#1$1"}}, {"id": 298, "prop": "name", "attributes": {"content": "哦對……按照計劃，今天就是拍攝天災的日子。", "name": "倒楣的場務"}, "figure_art": "avg_npc_1846_1#1$1"}, {"id": 299, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 300, "prop": "name", "attributes": {"content": "霍汀站在外景大街上，由於靠近風暴，原本色彩鮮豔的背景牆上蒙上了一層灰。"}}, {"id": 301, "prop": "name", "attributes": {"content": "她從未想過自己進入這個劇組後會有如此跌宕起伏的經歷，她只想拍電影，至於成為電影中的人……她才不想變成那樣。"}}, {"id": 302, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1846_1#6$1"}}, {"id": 303, "prop": "name", "attributes": {"content": "這就是……格蕾塔女士要拍的天災……", "name": "倒楣的場務"}, "figure_art": "avg_npc_1846_1#6$1"}, {"id": 304, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 305, "prop": "name", "attributes": {"content": "之前，被當作談資的災難還是荒原上若隱若現的一個灰點。"}}, {"id": 306, "prop": "name", "attributes": {"content": "現在，它已經凝聚成一大片天幕似的風暴，讓人移不開目光。"}}, {"id": 307, "prop": "name", "attributes": {"content": "源石粉塵形成的小型風柱在靠近地塊的區域迴旋……肉眼可見。"}}, {"id": 308, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1846_1#6$1"}}, {"id": 309, "prop": "name", "attributes": {"content": "……不得不說，實在是，太、太壯觀了……要是能在電影院裡看到這樣的場景……", "name": "倒楣的場務"}, "figure_art": "avg_npc_1846_1#6$1"}, {"id": 310, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1846_1#4$1"}}, {"id": 311, "prop": "name", "attributes": {"content": "大地保佑，我之前的運氣已經夠差了，拜託拜託，讓我們的電影順利拍完……", "name": "倒楣的場務"}, "figure_art": "avg_npc_1846_1#4$1"}, {"id": 312, "prop": "name", "attributes": {"content": "不……讓我們順利返回藍卡塢主城區就好了！拜託！", "name": "倒楣的場務"}, "figure_art": "avg_npc_1846_1#4$1"}, {"id": 313, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 314, "prop": "name", "attributes": {"content": "地塊以更加異常的聲響和晃動回應了霍汀的祈禱。"}}, {"id": 315, "prop": "dialog", "attributes": {}}, {"id": 316, "prop": "PlaySound", "attributes": {"key": "$d_avg_erthshkng", "volume": 0.4, "loop": "true", "channel": "e"}}, {"id": 317, "prop": "StopSound", "attributes": {"channel": "e", "fadetime": 3.0}}, {"id": 318, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 319, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1846_1#6$1"}}, {"id": 320, "prop": "name", "attributes": {"content": "等等……這是怎麼回事！", "name": "倒楣的場務"}, "figure_art": "avg_npc_1846_1#6$1"}, {"id": 321, "prop": "dialog", "attributes": {}}, {"id": 322, "prop": "PlaySound", "attributes": {"key": "$d_avg_erthshkng", "volume": 1.0, "loop": "true", "channel": "e"}}, {"id": 323, "prop": "CameraShake", "attributes": {"duration": 4.0, "xstrength": 10.0, "ystrength": 10.0, "vibrato": 90.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 324, "prop": "StopSound", "attributes": {"channel": "e", "fadetime": 6.0}}, {"id": 325, "prop": "PlaySound", "attributes": {"key": "$d_avg_bodyfallvalley", "volume": 1.0}}, {"id": 326, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 327, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1846_1#5$1"}}, {"id": 328, "prop": "name", "attributes": {"content": "啊——！", "name": "倒楣的場務"}, "figure_art": "avg_npc_1846_1#5$1"}, {"id": 329, "prop": "dialog", "attributes": {}}, {"id": 330, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,0", "posto": "0,-100", "afrom": 1.0, "ato": 0.0, "duration": 0.5}}, {"id": 331, "prop": "playsound", "attributes": {"key": "$bodyfalldown2"}}, {"id": 332, "prop": "StopSound", "attributes": {"channel": "sn", "fadetime": 2.0}}, {"id": 333, "prop": "musicvolume", "attributes": {"volume": 0.2, "fadetime": 2.0}}, {"id": 334, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 335, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 336, "prop": "PlaySound", "attributes": {"key": "$d_avg_tinnitus", "volume": 1.0}}, {"id": 337, "prop": "name", "attributes": {"content": "霍汀曾不只一次想像，若自己真的身處天災之下會聽到什麼？"}}, {"id": 338, "prop": "name", "attributes": {"content": "風聲？爆炸聲？受災群眾的嘶吼聲？都不是。"}}, {"id": 339, "prop": "name", "attributes": {"content": "是建築牆面和金屬結構像一個易開罐一樣，一點一點被踩扁、擠壓的聲音——"}}, {"id": 340, "prop": "name", "attributes": {"content": "它將毫無還手之力的人類輕易推入極端的惶恐之中，讓他們開始害怕自己的內臟、骨骼、血管也遭受同樣的折磨。"}}, {"id": 341, "prop": "dialog", "attributes": {}}, {"id": 342, "prop": "bgeffect", "attributes": {"name": "$eb_wind", "layer": 1.0}}, {"id": 343, "prop": "PlaySound", "attributes": {"key": "$d_avg_wind_howling", "volume": 0.0, "loop": "true", "channel": "wi"}}, {"id": 344, "prop": "Background", "attributes": {"image": "62_g7_mobileplotstreet_d", "screenadapt": "coverall", "xScale": 1.2, "yScale": 1.2}}, {"id": 345, "prop": "backgroundTween", "attributes": {"yFrom": 80.0, "duration": 8.0, "block": "false"}}, {"id": 346, "prop": "musicvolume", "attributes": {"volume": 0.6, "fadetime": 3.0}}, {"id": 347, "prop": "bgeffect", "attributes": {"name": "$eb_dim_openeye", "layer": 2.0}}, {"id": 348, "prop": "SoundVolume", "attributes": {"volume": 1.0, "channel": "wi", "fadetime": 2.0}}, {"id": 349, "prop": "Blocker", "attributes": {"a": 0.4, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 350, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 351, "prop": "PlaySound", "attributes": {"key": "$d_avg_equipment_collapse", "volume": 1.0}}, {"id": 352, "prop": "PlaySound", "attributes": {"key": "$d_avg_erthshkng", "volume": 0.6, "loop": "true", "channel": "e"}}, {"id": 353, "prop": "StopSound", "attributes": {"channel": "e", "fadetime": 6.0}}, {"id": 354, "prop": "CameraShake", "attributes": {"duration": 6.0, "xstrength": 10.0, "ystrength": 10.0, "vibrato": 90.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 355, "prop": "SoundVolume", "attributes": {"volume": 1.0, "channel": "sn", "fadetime": 2.0}}, {"id": 356, "prop": "Background", "attributes": {"image": "62_g8_mobileplotstreet_ruined", "screenadapt": "coverall", "xScale": 1.2, "yScale": 1.2, "fadetime": 2.0}}, {"id": 357, "prop": "backgroundTween", "attributes": {"yFrom": 0.0, "duration": 4.0, "block": "false"}}, {"id": 358, "prop": "Delay", "attributes": {"time": 4.0}}, {"id": 359, "prop": "name", "attributes": {"content": "渾濁的天幕不斷擠壓地塊邊緣，曾經出現在經典影片中的布景被狂風撕碎，消失於荒原。"}}, {"id": 360, "prop": "name", "attributes": {"content": "霍汀移開倒在自己身上的支撐架，卻發現自己的腿已經軟得完全使不上力。"}}, {"id": 361, "prop": "name", "attributes": {"content": "她呆呆地看著地塊上發生的劇變，懷疑自己的眼睛。"}}, {"id": 362, "prop": "dialog", "attributes": {}}, {"id": 363, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothtrailground", "volume": 1.0}}, {"id": 364, "prop": "Background", "attributes": {"image": "62_g8_mobileplotstreet_ruined", "screenadapt": "coverall", "fadetime": 1.5}}, {"id": 365, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 366, "prop": "name", "attributes": {"content": "天……我們怎麼離天災這麼近了！", "name": "倒楣的場務"}}, {"id": 367, "prop": "dialog", "attributes": {}}, {"id": 368, "prop": "StopSound", "attributes": {"channel": "wi", "fadetime": 2.0}}, {"id": 369, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 370, "prop": "bgeffect", "attributes": {}}, {"id": 371, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 372, "prop": "charslot", "attributes": {}}, {"id": 373, "prop": "Background", "attributes": {}}, {"id": 374, "prop": "Image", "attributes": {}}, {"id": 375, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}