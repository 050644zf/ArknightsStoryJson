name": "阿米婭", "end": "true", "content": "開了！", "joined": "可露希爾小姐教過我，這樣也可以開門……開了！"}}, {"id": 122, "prop": "dialog", "attributes": {}}, {"id": 123, "prop": "PlaySound", "attributes": {"key": "$dooropenquite", "volume": 1.0}}, {"id": 124, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 125, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 126, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1295_1#1$1", "posfrom": "200,0", "posto": "0,0", "duration": 2.0, "isblock": "true"}}, {"id": 127, "prop": "name", "attributes": {"content": "特蕾西婭小姐——", "name": "阿米婭"}, "figure_art": "avg_npc_1295_1#1$1"}, {"id": 128, "prop": "dialog", "attributes": {}}, {"id": 129, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0, "loop": "true", "channel": "w"}}, {"id": 130, "prop": "StopSound", "attributes": {"channel": "w", "fadetime": 1.0}}, {"id": 131, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1296_1#1$1", "duration": 1.0, "isblock": "true"}}, {"id": 132, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1296_1#10$1", "focus": "l"}}, {"id": 133, "prop": "name", "attributes": {"content": "阿米婭，為什麼你會在這裡？", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#10$1"}, {"id": 134, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1295_1#7$1", "focus": "r"}}, {"id": 135, "prop": "name", "attributes": {"content": "我聽到了討厭的聲音，離我很近……我有點害怕。", "name": "阿米婭"}, "figure_art": "avg_npc_1295_1#7$1"}, {"id": 136, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1296_1#1$1", "focus": "l"}}, {"id": 137, "prop": "name", "attributes": {"content": "……", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#1$1"}, {"id": 138, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1296_1#8$1", "focus": "l"}}, {"id": 139, "prop": "name", "attributes": {"content": "我們馬上就能回家了。", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#8$1"}, {"id": 140, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1295_1#7$1", "focus": "r"}}, {"id": 141, "prop": "name", "attributes": {"content": "您看起來很累……", "name": "阿米婭"}, "figure_art": "avg_npc_1295_1#7$1"}, {"id": 142, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1296_1#8$1", "focus": "l"}}, {"id": 143, "prop": "name", "attributes": {"content": "那阿米婭想陪著我一起工作嗎？", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#8$1"}, {"id": 144, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1296_1#8$1", "focus": "l"}}, {"id": 145, "prop": "name", "attributes": {"content": "這是……故事書？", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#8$1"}, {"id": 146, "prop": "name", "attributes": {"content": "原來如此。如果是陪阿米婭，我稍微偷偷懶，博士和凱爾希醫生一定不會說什麼。", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#8$1"}, {"id": 147, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1295_1#8$1", "focus": "r"}}, {"id": 148, "prop": "name", "attributes": {"content": "謝謝特蕾西婭小姐！", "name": "阿米婭"}, "figure_art": "avg_npc_1295_1#8$1"}, {"id": 149, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1296_1#8$1", "focus": "l"}}, {"id": 150, "prop": "name", "attributes": {"content": "來，坐在這裡。等我們講完這個故事，就能帶阿米婭一起去我的家裡玩。", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#8$1"}, {"id": 151, "prop": "dialog", "attributes": {}}, {"id": 152, "prop": "playsound", "attributes": {"key": "$d_avg_paper1", "volume": 1.0}}, {"id": 153, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 154, "prop": "playsound", "attributes": {"key": "$d_avg_paper2", "volume": 1.0}}, {"id": 155, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 156, "prop": "name", "attributes": {"content": "那麼，上次我們的故事講到哪裡了？", "name": "特蕾西婭"}}, {"id": 157, "prop": "dialog", "attributes": {}}, {"id": 158, "prop": "musicvolume", "attributes": {"volume": 0.6, "fadetime": 2.0}}, {"id": 159, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 160, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "style": "slider", "inverse": "true", "fadetime": 2.0, "block": "true"}}, {"id": 161, "prop": "charslot", "attributes": {}}, {"id": 162, "prop": "Background", "attributes": {"image": "bg_laccolith", "screenadapt": "coverall"}}, {"id": 163, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 164, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "style": "slider", "inverse": "true", "fadetime": 2.0, "block": "true"}}, {"id": 165, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_420_1#1$1"}}, {"id": 166, "prop": "name", "attributes": {"content": "……", "name": "孽茨雷"}, "figure_art": "avg_npc_420_1#1$1"}, {"id": 167, "prop": "name", "attributes": {"content": "杜卡雷，你該離遠點。", "name": "孽茨雷"}, "figure_art": "avg_npc_420_1#1$1"}, {"id": 168, "prop": "name", "attributes": {"content": "你的身上全是庸人的血。", "name": "孽茨雷"}, "figure_art": "avg_npc_420_1#1$1"}, {"id": 169, "prop": "dialog", "attributes": {}}, {"id": 170, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 171, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_410_1#6$1", "duration": 1.5, "isblock": "true"}}, {"id": 172, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_410_1#6$1", "focus": "l"}}, {"id": 173, "prop": "name", "attributes": {"content": "只是順手淨化了些妄議此事的子裔罷了。無人該在此刻輕言那對兄妹的生死。", "name": "杜卡雷"}, "figure_art": "avg_npc_410_1#6$1"}, {"id": 174, "prop": "name", "attributes": {"content": "大不敬。", "name": "杜卡雷"}, "figure_art": "avg_npc_410_1#6$1"}, {"id": 175, "prop": "dialog", "attributes": {}}, {"id": 176, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 177, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_410_1#7$1", "focus": "l"}}, {"id": 178, "prop": "name", "attributes": {"content": "孽茨雷，你此刻不應該退守城內嗎？", "name": "杜卡雷"}, "figure_art": "avg_npc_410_1#7$1"}, {"id": 179, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_420_1#1$1", "focus": "r"}}, {"id": 180, "prop": "name", "attributes": {"content": "那與我所等待的戰爭無關。", "name": "孽茨雷"}, "figure_art": "avg_npc_420_1#1$1"}, {"id": 181, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_410_1#7$1", "focus": "l"}}, {"id": 182, "prop": "name", "attributes": {"content": "特雷西斯讓你來確保她的死亡？", "name": "杜卡雷"}, "figure_art": "avg_npc_410_1#7$1"}, {"id": 183, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_420_1#1$1", "focus": "r"}}, {"id": 184, "prop": "name", "attributes": {"content": "那你何嘗不是在輕蔑那對兄妹？攝政王不會做這種安排。", "name": "孽茨雷"}, "figure_art": "avg_npc_420_1#1$1"}, {"id": 185, "prop": "name", "attributes": {"content": "我只是來此見證一場戰爭的結束，以及另一場戰爭的開始。", "name": "孽茨雷"}, "figure_art": "avg_npc_420_1#1$1"}, {"id": 186, "prop": "name", "attributes": {"content": "若魔王敗亡，我將背負這片刻的死亡氣息……代王見證，我於深淵中握住的勝利。", "name": "孽茨雷"}, "figure_art": "avg_npc_420_1#1$1"}, {"id": 187, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_410_1#1$1", "focus": "l"}}, {"id": 188, "prop": "name", "attributes": {"content": "……原來你還會感受到悲傷。", "name": "杜卡雷"}, "figure_art": "avg_npc_410_1#1$1"}, {"id": 189, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_420_1#1$1", "focus": "r"}}, {"id": 190, "prop": "name", "attributes": {"content": "彼此。", "name": "孽茨雷"}, "figure_art": "avg_npc_420_1#1$1"}, {"id": 191, "prop": "dialog", "attributes": {}}, {"id": 192, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 193, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "style": "slider", "inverse": "false", "fadetime": 2.0, "block": "true"}}, {"id": 194, "prop": "charslot", "attributes": {}}, {"id": 195, "prop": "Background", "attributes": {"image": "34_g2_reedmarshes", "screenadapt": "coverall"}}, {"id": 196, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 197, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "style": "slider", "inverse": "false", "fadetime": 2.0, "block": "true"}}, {"id": 198, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 199, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1071_1#5$1", "duration": 1.5, "isblock": "true"}}, {"id": 200, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 201, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 202, "prop": "name", "attributes": {"content": "蘆葦編織的草環沉入了河底，陰鬱的霧氣已經連續多日未散。"}}, {"id": 203, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1071_1#5$1"}}, {"id": 204, "prop": "name", "attributes": {"content": "……哀琺尼爾……你是否還在她的身邊？", "name": "菈瑪蓮"}, "figure_art": "avg_npc_1071_1#5$1"}, {"id": 205, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1071_1#2$1"}}, {"id": 206, "prop": "name", "attributes": {"content": "輓歌又要為誰而鳴？", "name": "菈瑪蓮"}, "figure_art": "avg_npc_1071_1#2$1"}, {"id": 207, "prop": "dialog", "attributes": {}}, {"id": 208, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 209, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 210, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 211, "prop": "charslot", "attributes": {}}, {"id": 212, "prop": "Background", "attributes": {"image": "49_g10_theresaoffice", "screenadapt": "coverall"}}, {"id": 213, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 214, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1295_1#9$1", "focus": "r"}}, {"id": 215, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1296_1#8$1", "focus": "l"}}, {"id": 216, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 217, "prop": "PlaySound", "attributes": {"key": "$book_close", "volume": 1.0}}, {"id": 218, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 219, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1296_1#1$1", "focus": "l"}}, {"id": 220, "prop": "name", "attributes": {"content": "……", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#1$1"}, {"id": 221, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1295_1#1$1", "focus": "r"}}, {"id": 222, "prop": "name", "attributes": {"content": "特蕾西婭小姐，您為什麼停下了，故事才剛剛到要緊的地方啊？", "name": "阿米婭"}, "figure_art": "avg_npc_1295_1#1$1"}, {"id": 223, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1296_1#8$1", "focus": "l"}}, {"id": 224, "prop": "name", "attributes": {"content": "阿米婭，我想為你留下一點小小的懸念。讓我換一種更舒服的方式給你講故事好嗎？", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#8$1"}, {"id": 225, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1295_1#2$1", "focus": "r"}}, {"id": 226, "prop": "name", "attributes": {"content": "可……嗯，好吧，聽您的。", "name": "阿米婭"}, "figure_art": "avg_npc_1295_1#2$1"}, {"id": 227, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1296_1#8$1", "focus": "l"}}, {"id": 228, "prop": "name", "attributes": {"content": "阿米婭，小心點。", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#8$1"}, {"id": 229, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1295_1#1$1", "focus": "r"}}, {"id": 230, "prop": "name", "attributes": {"content": "泡泡！欸，這是——", "name": "阿米婭"}, "figure_art": "avg_npc_1295_1#1$1"}, {"id": 231, "prop": "dialog", "attributes": {}}, {"id": 232, "prop": "PlayMusic", "attributes": {"intro": "$distressed_intro", "key": "$distressed_loop", "volume": 0.6}}, {"id": 233, "prop": "charslot", "attributes": {"slot": "r", "afrom": 1.0, "ato": 0.0, "duration": 3.0}}, {"id": 234, "prop": "Blocker", "attributes": {"a": 0.4, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 235, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 236, "prop": "name", "attributes": {"content": "融合的黑色波紋不斷在純白的房間中蕩漾，阿米婭好像一頭紮進了黑色的泳池中。"}}, {"id": 237, "prop": "dialog", "attributes": {}}, {"id": 238, "prop": "PlaySound", "attributes": {"key": "$d_avg_underwtr", "volume": 0.0, "loop": "true", "channel": "un"}}, {"id": 239, "prop": "SoundVolume", "attributes": {"volume": 1.0, "channel": "un", "fadetime": 3.0}}, {"id": 240, "prop": "bgeffect", "attributes": {"name": "$eb_dim_closeeye", "layer": 1.0}}, {"id": 241, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 242, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 243, "prop": "name", "attributes": {"content": "黑色的泡泡隔絕了聲音，也隔絕了阿米婭的視線。"}}, {"id": 244, "prop": "name", "attributes": {"content": "透過泡泡看去，特蕾西婭的身形越來越模糊……"}}, {"id": 245, "prop": "name", "attributes": {"content": "越來越遙遠……"}}, {"id": 246, "prop": "name", "attributes": {"content": "特蕾西婭……小姐……", "name": "阿米婭"}}, {"id": 247, "prop": "dialog", "attributes": {}}, {"id": 248, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 249, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1296_1#8$1", "focus": "l"}}, {"id": 250, "prop": "name", "attributes": {"content": "先留在裡面安穩地睡一覺吧，阿米婭。", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#8$1"}, {"id": 251, "prop": "name", "attributes": {"content": "……待在我身邊，是安全的。", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#8$1"}, {"id": 252, "prop": "dialog", "attributes": {}}, {"id": 253, "prop": "StopSound", "attributes": {"channel": "un", "fadetime": 2.0}}, {"id": 254, "prop": "charslot", "attributes": {}}, {"id": 255, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1296_1#6$1"}}, {"id": 256, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 257, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 258, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 259, "prop": "name", "attributes": {"content": "唉……", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#6$1"}, {"id": 260, "prop": "dialog", "attributes": {}}, {"id": 261, "prop": "charslot", "attributes": {}}, {"id": 262, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 263, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1307_1#1$1", "duration": 1.5, "isblock": "true"}}, {"id": 264, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 265, "prop": "name", "attributes": {"content": "特蕾西婭殿下……", "name": "決然的刺客"}, "figure_art": "avg_npc_1307_1#1$1"}, {"id": 266, "prop": "name", "attributes": {"content": "我們會用性命向您證明將軍所追求的未來。", "name": "決然的刺客"}, "figure_art": "avg_npc_1307_1#1$1"}, {"id": 267, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1296_1#6$1"}}, {"id": 268, "prop": "name", "attributes": {"content": "不，我只是在嘆息另一件事。", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#6$1"}, {"id": 269, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1296_1#3$1"}}, {"id": 270, "prop": "name", "attributes": {"content": "其實，您的遮掩在我的面前並沒有意義。", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#3$1"}, {"id": 271, "prop": "name", "attributes": {"content": "我依然記得您當年在以勒什車輦前領命的樣子，您在那一戰中的英勇令我動容。", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#3$1"}, {"id": 272, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1296_1#1$1"}}, {"id": 273, "prop": "name", "attributes": {"content": "還有與您一起的人，他們中的大多數我都記得。", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#1$1"}, {"id": 274, "prop": "name", "attributes": {"content": "都是配得上被稱為勇士的人。與此刻在卡茲戴爾城內奮戰的英雄相比，也毫不遜色。", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#1$1"}, {"id": 275, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1307_1#1$1"}}, {"id": 276, "prop": "name", "attributes": {"content": "……並非為了掩飾身分，我們知道這在您面前毫無意義。", "name": "決然的刺客"}, "figure_art": "avg_npc_1307_1#1$1"}, {"id": 277, "prop": "name", "attributes": {"content": "割去雙角，捨棄名姓，甚至毀掉身上每一寸可被當作特徵的肌膚，只是因為當我們決定用如此低劣的手段屠戮魔王後——", "name": "決然的刺客"}, "figure_art": "avg_npc_1307_1#1$1"}, {"id": 278, "prop": "name", "attributes": {"content": "我們不配被薩卡茲記住。不能被記住。", "name": "決然的刺客"}, "figure_art": "avg_npc_1307_1#1$1"}, {"id": 279, "prop": "name", "attributes": {"content": "動手。", "name": "決然的刺客"}, "figure_art": "avg_npc_1307_1#1$1"}, {"id": 280, "prop": "dialog", "attributes": {}}, {"id": 281, "prop": "charslot", "attributes": {}}, {"id": 282, "prop": "PlaySound", "attributes": {"key": "$d_gen_soldiersrun", "volume": 1.0, "loop": "true", "channel": "s"}}, {"id": 283, "prop": "StopSound", "attributes": {"channel": "s", "fadetime": 1.0}}, {"id": 284, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1307_1#1$1", "duration": 0.5}}, {"id": 285, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1307_1#1$1", "duration": 0.5, "isblock": "true"}}, {"id": 286, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 287, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovement", "volume": 1.0}}, {"id": 288, "prop": "charslot", "attributes": {"slot": "r", "action": "zoom", "poszoom": "0.5,0.5", "scale": 1.05, "duration": 0.2}}, {"id": 289, "prop": "charslot", "attributes": {"slot": "l", "action": "zoom", "poszoom": "0.5,0.5", "scale": 1.05, "duration": 0.2}}, {"id": 290, "prop": "charslot", "attributes": {"duration": 0.2}}, {"id": 291, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.3, "block": "true"}}, {"id": 292, "prop": "PlaySound", "attributes": {"key": "$d_avg_windmagic", "volume": 1.0}}, {"id": 293, "prop": "bgeffect", "attributes": {"name": "$eb_windburst", "layer": 1.0}}, {"id": 294, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 295, "prop": "PlaySound", "attributes": {"key": "$e_skill_skulsrsword", "volume": 0.8}}, {"id": 296, "prop": "PlaySound", "attributes": {"key": "$d_avg_swordy", "volume": 1.0}}, {"id": 297, "prop": "CameraShake", "attributes": {"duration": 0.8, "xstrength": 25.0, "ystrength": 25.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 298, "prop": "Effect", "attributes": {"name": "$e_slash_cross", "layer": 1.0}}, {"id": 299, "prop": "Effect", "attributes": {"name": "$e_spark_02_large", "layer": 2.0}}, {"id": 300, "prop": "Effect", "attributes": {"name": "$e_spark_01_mid", "layer": 3.0}}, {"id": 301, "prop": "name", "attributes": {"content": "湧動的氣流如同泥沼般包裹住了不斷向前突刺的數道刀鋒。"}}, {"id": 302, "prop": "name", "attributes": {"content": "嗡——"}}, {"id": 303, "prop": "name", "attributes": {"content": "刀刃的震顫牽動著周遭空間的共鳴。不停逼近，不斷刺破。"}}, {"id": 304, "prop": "name", "attributes": {"content": "隨即利刃的主人們彷彿被無法抗拒的浪潮推向後方，被淹沒。"}}, {"id": 305, "prop": "dialog", "attributes": {}}, {"id": 306, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1296_1#10$1"}}, {"id": 307, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 308, "prop": "name", "attributes": {"content": "我記得你們的名字。", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#10$1"}, {"id": 309, "prop": "name", "attributes": {"content": "盧卡……我記得你。", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#10$1"}, {"id": 310, "prop": "name", "attributes": {"content": "當年你獨自拖住蒸汽騎士，在蒸汽的掩蓋下扯出了那位騎士，並當眾將其斬首……", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#10$1"}, {"id": 311, "prop": "dialog", "attributes": {}}, {"id": 312, "prop": "charslot", "attributes": {}}, {"id": 313, "prop": "PlaySound", "attributes": {"key": "$d_avg_spellattack_1", "volume": 1.0}}, {"id": 314, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 315, "prop": "Blocker", "attributes": {"a": 0.5, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.1, "block": "true"}}, {"id": 316, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 317, "prop": "PlaySound", "attributes": {"key": "$d_avg_tear", "volume": 1.0}}, {"id": 318, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 319, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 320, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown2", "volume": 1.0}}, {"id": 321, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 322, "prop": "name", "attributes": {"content": "刺客的生命在消逝。"}}, {"id": 323, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1296_1#1$1"}}, {"id": 324, "prop": "name", "attributes": {"content": "……我也記得你。鐮須。", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#1$1"}, {"id": 325, "prop": "name", "attributes": {"content": "千萬同名薩卡茲中最特殊的一位，被俘虜後從高塔術師的營地中救下了三位同胞，還摧毀了他們的法陣……", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#1$1"}, {"id": 326, "prop": "dialog", "attributes": {}}, {"id": 327, "prop": "charslot", "attributes": {}}, {"id": 328, "prop": "PlaySound", "attributes": {"key": "$d_avg_spelldfns_1", "volume": 1.0}}, {"id": 329, "prop": "Delay", "attributes": {"time": 0.1}}, {"id": 330, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.2, "block": "true"}}, {"id": 331, "prop": "charslot", "attributes": {}}, {"id": 332, "prop": "background", "attributes": {}}, {"id": 333, "prop": "PlaySound", "attributes": {"key": "$swordtsing6", "volume": 1.0}}, {"id": 334, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 1.0, "block": "true"}}, {"id": 335, "prop": "Delay", "attributes": {"time": 0.3}}, {"id": 336, "prop": "PlaySound", "attributes": {"key": "$d_avg_spellattack_2", "volume": 1.0}}, {"id": 337, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 338, "prop": "PlaySound", "attributes": {"key": "$d_avg_broadswordblood", "volume": 1.0}}, {"id": 339, "prop": "delay", "attributes": {"time": 0.4}}, {"id": 340, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 341, "prop": "Blocker", "attributes": {"a": 0.4, "r": 255.0, "g": 0.0, "b": 0.0, "fadetime": 0.03, "block": "true"}}, {"id": 342, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 343, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 344, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.1, "block": "true"}}, {"id": 345, "prop": "Background", "attributes": {"image": "49_g10_theresaoffice", "screenadapt": "coverall"}}, {"id": 346, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0}}, {"id": 347, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 348, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown1", "volume": 1.0}}, {"id": 349, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 350, "prop": "name", "attributes": {"content": "死亡，也無法阻止他們靠近特蕾西婭。"}}, {"id": 351, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1296_1#1$1"}}, {"id": 352, "prop": "name", "attributes": {"content": "還有你……萊文。", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#1$1"}, {"id": 353, "prop": "name", "attributes": {"content": "你為特雷西斯阻擋弓弩，失去了一臂，但在地獄裡活下來並一直堅持到撤退……", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#1$1"}, {"id": 354, "prop": "name", "attributes": {"content": "我並不希望你們作為無名之徒死去。", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#1$1"}, {"id": 355, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1296_1#6$1"}}, {"id": 356, "prop": "name", "attributes": {"content": "至少……我記得。", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#6$1"}, {"id": 357, "prop": "dialog", "attributes": {}}, {"id": 358, "prop": "PlaySound", "attributes": {"key": "$d_sp_amiyakilling", "volume": 1.0}}, {"id": 359, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 360, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 361, "prop": "charslot", "attributes": {}}, {"id": 362, "prop": "background", "attributes": {}}, {"id": 363, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 364, "prop": "PlaySound", "attributes": {"key": "$d_avg_explosion_stone"}}, {"id": 365, "prop": "delay", "attributes": {"time": 0.4}}, {"id": 366, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 40.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 367, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 368, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 369, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 370, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 371, "prop": "Background", "attributes": {"image": "49_g10_theresaoffice", "screenadapt": "coverall"}}, {"id": 372, "prop": "Delay", "attributes": {"time": 0.1}}, {"id": 373, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 2.0, "block": "true"}}, {"id": 374, "prop": "CameraShake", "attributes": {"duration": 0.8, "xstrength": 40.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 375, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown2", "volume": 1.0}}, {"id": 376, "prop": "Delay", "attributes": {"time": 0.3}}, {"id": 377, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown1", "volume": 1.0}}, {"id": 378, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 379, "prop": "name", "attributes": {"content": "身邊堆積的屍體越來越多，她所能立足的位置也越來越少。"}}, {"id": 380, "prop": "name", "attributes": {"content": "一聲嘆息。她拭去了脖頸處滲出的鮮血，不小心在白衣上蹭上一抹殷紅。"}}, {"id": 381, "prop": "dialog", "attributes": {}}, {"id": 382, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1307_1#1$1", "duration": 1.0, "isblock": "true"}}, {"id": 383, "prop": "name", "attributes": {"content": "我們想在死前為薩卡茲再做些什麼，才走到您的面前……", "name": "決然的刺客"}, "figure_art": "avg_npc_1307_1#1$1"}, {"id": 384, "prop": "name", "attributes": {"content": "來殺死您——我們曾宣誓效忠的魔王。", "name": "決然的刺客"}, "figure_art": "avg_npc_1307_1#1$1"}, {"id": 385, "prop": "name", "attributes": {"content": "您的強大我們比誰都清楚。那麼，就讓我們這些該死的叛徒，與您共赴地獄吧。", "name": "決然的刺客"}, "figure_art": "avg_npc_1307_1#1$1"}, {"id": 386, "prop": "dialog", "attributes": {}}, {"id": 387, "prop": "charslot", "attributes": {}}, {"id": 388, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1296_1#6$1", "duration": 1.0}}, {"id": 389, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 390, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1296_1#1$1"}}, {"id": 391, "prop": "name", "attributes": {"content": "……", "name": "特蕾西婭"}, "figure_art": "avg_npc_1296_1#1$1"}, {"id": 392, "prop": "dialog", "attributes": {}}, {"id": 393, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 394, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 4.0, "block": "true"}}, {"id": 395, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 396, "prop": "charslot", "attributes": {}}, {"id": 397, "prop": "Background", "attributes": {}}, {"id": 398, "prop": "Image", "attributes": {}}, {"id": 399, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}