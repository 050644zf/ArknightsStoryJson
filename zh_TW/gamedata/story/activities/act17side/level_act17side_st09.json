7$1"}}, {"id": 115, "prop": "name", "attributes": {"content": "最後，就看這座燈塔，還能堅持多久了。", "name": "喬迪"}, "figure_art": "avg_4042_lumen_1#7$1"}, {"id": 116, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#9$1"}}, {"id": 117, "prop": "name", "attributes": {"content": "（溟痕，已經，爬到這一層了？）", "name": "喬迪"}, "figure_art": "avg_4042_lumen_1#9$1"}, {"id": 118, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#9$1"}}, {"id": 119, "prop": "name", "attributes": {"content": "我得再往上走......", "name": "喬迪"}, "figure_art": "avg_4042_lumen_1#9$1"}, {"id": 120, "prop": "name", "attributes": {"content": "大審判官閣下......", "name": "喬迪"}, "figure_art": "avg_4042_lumen_1#9$1"}, {"id": 121, "prop": "Dialog", "attributes": {}}, {"id": 122, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 123, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 124, "prop": "Background", "attributes": {"image": "27_g19_lighthouse_front", "screenadapt": "coverall"}}, {"id": 125, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 126, "prop": "Character", "attributes": {"name": "avg_npc_183#3"}}, {"id": 127, "prop": "name", "attributes": {"content": "......", "name": "大審判官達里奧"}, "figure_art": "avg_npc_183#3"}, {"id": 128, "prop": "name", "attributes": {"content": "手臂發麻。"}}, {"id": 129, "prop": "name", "attributes": {"content": "礁石的形狀與排布已經發生了極大的變化。審判官不留餘力，盡可能殲滅進入視野的敵人。"}}, {"id": 130, "prop": "name", "attributes": {"content": "但敵人如字面意義上無窮無盡。"}}, {"id": 131, "prop": "name", "attributes": {"content": "劍已銹蝕，卷匣中的炸藥也已消耗殆盡。"}}, {"id": 132, "prop": "name", "attributes": {"content": "只有提燈中的火焰，比先前還要旺盛。"}}, {"id": 133, "prop": "name", "attributes": {"content": "達里奧沒有一次看向身後，看向他始終捍衛的高塔。"}}, {"id": 134, "prop": "name", "attributes": {"content": "他看著海平面的彼方。"}}, {"id": 135, "prop": "Character", "attributes": {"name": "avg_npc_183#3"}}, {"id": 136, "prop": "name", "attributes": {"content": "......海洋的生物，伊比利亞不會被你們毀滅。", "name": "大審判官達里奧"}, "figure_art": "avg_npc_183#3"}, {"id": 137, "prop": "Character", "attributes": {"name": "avg_npc_183#3"}}, {"id": 138, "prop": "name", "attributes": {"content": "人類不會被你們毀滅。", "name": "大審判官達里奧"}, "figure_art": "avg_npc_183#3"}, {"id": 139, "prop": "name", "attributes": {"content": "他咳出了卡在喉嚨裡的鮮血。血腥味充滿鼻腔。"}}, {"id": 140, "prop": "Character", "attributes": {"name": "avg_npc_457_1#1$1"}}, {"id": 141, "prop": "PlaySound", "attributes": {"key": "$d_avg_fish_howl"}}, {"id": 142, "prop": "name", "attributes": {"content": "（緩慢的窸窣聲）", "name": "恐魚"}, "figure_art": "avg_npc_457_1#1$1"}, {"id": 143, "prop": "Character", "attributes": {"name": "avg_npc_183#3"}}, {"id": 144, "prop": "name", "attributes": {"content": "我，也不會，被毀滅。只是死亡而已。", "name": "大審判官達里奧"}, "figure_art": "avg_npc_183#3"}, {"id": 145, "prop": "dialog", "attributes": {}}, {"id": 146, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 147, "prop": "Blocker", "attributes": {"a": 0.5, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 0.1, "block": "true"}}, {"id": 148, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "false"}}, {"id": 149, "prop": "PlaySound", "attributes": {"key": "$e_skill_skulsrsword", "volume": 0.9}}, {"id": 150, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 8.0, "ystrength": 6.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 151, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 152, "prop": "Dialog", "attributes": {}}, {"id": 153, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 154, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 155, "prop": "Background", "attributes": {"image": "27_g22_goldenboat_hall", "screenadapt": "coverall"}}, {"id": 156, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 157, "prop": "Character", "attributes": {"name": "avg_npc_446_1#2$1"}}, {"id": 158, "prop": "name", "attributes": {"content": "......耐心等待。加西亞。", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#2$1"}, {"id": 159, "prop": "Character", "attributes": {"name": "avg_npc_452_1#1$1"}}, {"id": 160, "prop": "name", "attributes": {"content": "（乖巧地蹲在船長身邊）", "name": "大副"}, "figure_art": "avg_npc_452_1#1$1"}, {"id": 161, "prop": "Character", "attributes": {"name": "avg_npc_446_1#2$1"}}, {"id": 162, "prop": "name", "attributes": {"content": "等著獵物上鉤的時間，總是無聊的。", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#2$1"}, {"id": 163, "prop": "Character", "attributes": {"name": "avg_npc_446_1#2$1"}}, {"id": 164, "prop": "name", "attributes": {"content": "還記得我們第二次捕獵怪物的時候嗎？那時候我們還有上百名倖存者......", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#2$1"}, {"id": 165, "prop": "Character", "attributes": {"name": "avg_npc_446_1#2$1"}}, {"id": 166, "prop": "name", "attributes": {"content": "離開海岸的時候，歡呼和禮炮的聲響，現在彷彿還迴蕩在我們耳邊。我們告別偉大的海岸，滿載阿戈爾的傳說，奔向海的深處。", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#2$1"}, {"id": 167, "prop": "Character", "attributes": {"name": "avg_npc_446_1#1$1"}}, {"id": 168, "prop": "name", "attributes": {"content": "只過了幾天，我們只在海洋上待了幾天而已——災難就來了。", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#1$1"}, {"id": 169, "prop": "Character", "attributes": {"name": "avg_npc_446_1#6$1"}}, {"id": 170, "prop": "name", "attributes": {"content": "啊啊......為什麼這愚蠢的細胞還要剝奪你的語言？", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#6$1"}, {"id": 171, "prop": "Character", "attributes": {"name": "avg_npc_446_1#6$1"}}, {"id": 172, "prop": "name", "attributes": {"content": "我多想再和你說說話，而不是和那些，腐臭的，愚蠢的，花了六十多年才抵達這裡的白癡們交談。", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#6$1"}, {"id": 173, "prop": "Character", "attributes": {"name": "avg_npc_452_1#1$1"}}, {"id": 174, "prop": "name", "attributes": {"content": "（傷心地蹭著阿方索的手）", "name": "大副"}, "figure_art": "avg_npc_452_1#1$1"}, {"id": 175, "prop": "dialog", "attributes": {}}, {"id": 176, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 177, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 178, "prop": "Character", "attributes": {"name": "avg_1023_ghost2_1#1$1", "fadetime": 1.0}}, {"id": 179, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 180, "prop": "name", "attributes": {"content": "您好，船長先生。", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#1$1"}, {"id": 181, "prop": "Character", "attributes": {"name": "avg_npc_446_1#1$1"}}, {"id": 182, "prop": "name", "attributes": {"content": "我正缺合適的餌把它釣上來，你下去如何？反正你是阿戈爾人。", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#1$1"}, {"id": 183, "prop": "Character", "attributes": {"name": "char_263_skadi#2"}}, {"id": 184, "prop": "name", "attributes": {"content": "......", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#2"}, {"id": 185, "prop": "Character", "attributes": {"name": "avg_npc_446_1#1$1"}}, {"id": 186, "prop": "name", "attributes": {"content": "......怎麼？忘了我說的話嗎？", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#1$1"}, {"id": 187, "prop": "Character", "attributes": {"name": "avg_npc_446_1#1$1"}}, {"id": 188, "prop": "name", "attributes": {"content": "要嘛你跳下去，要嘛我把你丟下去。", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#1$1"}, {"id": 189, "prop": "Character", "attributes": {"name": "char_263_skadi#2"}}, {"id": 190, "prop": "name", "attributes": {"content": "你能活下來是個奇跡。我從沒想過真的有伊比利亞人能活到今天。", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#2"}, {"id": 191, "prop": "Character", "attributes": {"name": "avg_npc_446_1#1$1"}}, {"id": 192, "prop": "name", "attributes": {"content": "這與你無關，我也與伊比利亞無關。六十年時間，我已經屬於這艘船。", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#1$1"}, {"id": 193, "prop": "Character", "attributes": {"name": "char_263_skadi#2"}}, {"id": 194, "prop": "name", "attributes": {"content": "可是我們——", "name": "斯卡蒂"}, "figure_art": "char_263_skadi#2"}, {"id": 195, "prop": "Character", "attributes": {"name": "avg_1023_ghost2_1#1$1"}}, {"id": 196, "prop": "name", "attributes": {"content": "——讓我來吧，斯卡蒂。", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#1$1"}, {"id": 197, "prop": "Character", "attributes": {"name": "avg_1023_ghost2_1#1$1"}}, {"id": 198, "prop": "name", "attributes": {"content": "狩獵愉快嗎？", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#1$1"}, {"id": 199, "prop": "Character", "attributes": {"name": "avg_npc_446_1#1$1"}}, {"id": 200, "prop": "name", "attributes": {"content": "也許我溫和的態度讓你們誤會了許多事情。但我能感覺到你們身上流著怪物的血，我們是一樣的。", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#1$1"}, {"id": 201, "prop": "Character", "attributes": {"name": "avg_1023_ghost2_1#1$1"}}, {"id": 202, "prop": "name", "attributes": {"content": "我們......一樣嗎？", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#1$1"}, {"id": 203, "prop": "Character", "attributes": {"name": "avg_1023_ghost2_1#1$1"}}, {"id": 204, "prop": "name", "attributes": {"content": "與您，和您的大副？", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#1$1"}, {"id": 205, "prop": "Character", "attributes": {"name": "avg_npc_446_1#7$1"}}, {"id": 206, "prop": "name", "attributes": {"content": "......誰允許你談論加西亞的？誰允許你，用這種眼神，看待我的加西亞？阿戈爾雜種？", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#7$1"}, {"id": 207, "prop": "Character", "attributes": {"name": "avg_npc_452_1#1$1"}}, {"id": 208, "prop": "name", "attributes": {"content": "......", "name": "大副"}, "figure_art": "avg_npc_452_1#1$1"}, {"id": 209, "prop": "Character", "attributes": {"name": "avg_npc_446_1#7$1"}}, {"id": 210, "prop": "name", "attributes": {"content": "我從未和你們提起過加西亞曾經是個什麼樣的人。你們不知道他是男是女，是高是矮，是胖是瘦，是佩洛還是魔族佬。", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#7$1"}, {"id": 211, "prop": "Character", "attributes": {"name": "avg_npc_446_1#7$1"}}, {"id": 212, "prop": "name", "attributes": {"content": "但你們只要知道，它是我的大副也是我的愛人，而我永遠不會和外人透露半點它過去的形象。", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#7$1"}, {"id": 213, "prop": "Character", "attributes": {"name": "avg_npc_446_1#7$1"}}, {"id": 214, "prop": "name", "attributes": {"content": "它不需要你們的憐憫，更不需要你們用想像的過去來與它的如今比較，我們都不需要。", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#7$1"}, {"id": 215, "prop": "Character", "attributes": {"name": "avg_npc_446_1#7$1"}}, {"id": 216, "prop": "name", "attributes": {"content": "可笑。與獵物混血的獵人，你們的骯髒連海浪都洗刷不掉，還膽敢對我們表露敵意？", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#7$1"}, {"id": 217, "prop": "dialog", "attributes": {}}, {"id": 218, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 219, "prop": "name", "attributes": {"content": "斯卡蒂皺了皺眉頭。她極少在意別人的言辭，特別是陸上人的。但眼前這個特例的話語還是讓她感到不舒服。"}}, {"id": 220, "prop": "name", "attributes": {"content": "大副敏銳地將目光投向斯卡蒂。它在警告。"}}, {"id": 221, "prop": "Character", "attributes": {"name": "avg_1023_ghost2_1#1$1"}}, {"id": 222, "prop": "name", "attributes": {"content": "但是我們需要您的幫助。", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#1$1"}, {"id": 223, "prop": "Character", "attributes": {"name": "avg_npc_446_1#1$1"}}, {"id": 224, "prop": "name", "attributes": {"content": "......你們怎麼稱呼這些怪物？海什麼？", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#1$1"}, {"id": 225, "prop": "Character", "attributes": {"name": "avg_1023_ghost2_1#5$1"}}, {"id": 226, "prop": "name", "attributes": {"content": "唔，“海嗣”。", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#5$1"}, {"id": 227, "prop": "Character", "attributes": {"name": "avg_npc_446_1#1$1"}}, {"id": 228, "prop": "name", "attributes": {"content": "我為什麼要幫助海嗣？那場災難之後，有多少好小夥子喪命於海洋？", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#1$1"}, {"id": 229, "prop": "Character", "attributes": {"name": "avg_1023_ghost2_1#1$1"}}, {"id": 230, "prop": "name", "attributes": {"content": "您就漂泊在海洋之上，不肯回到陸地，也堅持與海洋為敵？", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#1$1"}, {"id": 231, "prop": "Character", "attributes": {"name": "avg_npc_446_1#1$1"}}, {"id": 232, "prop": "name", "attributes": {"content": "這就是我的生活。", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#1$1"}, {"id": 233, "prop": "Character", "attributes": {"name": "avg_1023_ghost2_1#1$1"}}, {"id": 234, "prop": "name", "attributes": {"content": "我們是......深海獵人。我們來自阿戈爾，雖然不瞭解您存活下來的詳細情況，只憑猜測，我們也對您感到敬重。", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#1$1"}, {"id": 235, "prop": "Character", "attributes": {"name": "avg_1023_ghost2_1#1$1"}}, {"id": 236, "prop": "name", "attributes": {"content": "也希望您理解，我們所做的一切，都是為了對抗它們。", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#1$1"}, {"id": 237, "prop": "Character", "attributes": {"name": "avg_npc_446_1#1$1"}}, {"id": 238, "prop": "name", "attributes": {"content": "阿戈爾怎麼做，和我有什麼關係？", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#1$1"}, {"id": 239, "prop": "Character", "attributes": {"name": "avg_1023_ghost2_1#1$1"}}, {"id": 240, "prop": "name", "attributes": {"content": "哦，不，您誤會了。", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#1$1"}, {"id": 241, "prop": "dialog", "attributes": {}}, {"id": 242, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 243, "prop": "name", "attributes": {"content": "斯卡蒂微微瞥了一眼身邊的幽靈鯊。她本以為幽靈鯊的那句“讓她來”，是指她更擅交涉。"}}, {"id": 244, "prop": "name", "attributes": {"content": "但“交涉”應該是沒必要拿出那柄武器的。"}}, {"id": 245, "prop": "Character", "attributes": {"name": "avg_1023_ghost2_1#7$1"}}, {"id": 246, "prop": "name", "attributes": {"content": "我是說，殺死它們是我們的工作，而我本人則享受這個過程。", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#7$1"}, {"id": 247, "prop": "name", "attributes": {"content": "既然您只是為了果腹而狩獵，殺死目標後，我給您留些血肉就是。反正這種令人作嘔的玩意，我一向是不愛處理的。", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#7$1"}, {"id": 248, "prop": "Character", "attributes": {"name": "avg_npc_446_1#5$1"}}, {"id": 249, "prop": "name", "attributes": {"content": "......", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#5$1"}, {"id": 250, "prop": "Character", "attributes": {"name": "avg_npc_446_1#1$1"}}, {"id": 251, "prop": "name", "attributes": {"content": "你們......很有本事？比起維多利亞人，比起萊塔尼亞人？我見過你們獵殺海嗣的樣子，你們沒什麼值得一提的。", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#1$1"}, {"id": 252, "prop": "Character", "attributes": {"name": "avg_1023_ghost2_1#1$1"}}, {"id": 253, "prop": "name", "attributes": {"content": "哦，您誤會了。那些被稱為“恐魚”的低等生物，一般是不值得被二隊當做戰功記住的，歌蕾蒂婭也沒那麼小家子氣。", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#1$1"}, {"id": 254, "prop": "Character", "attributes": {"name": "avg_1023_ghost2_1#1$1"}}, {"id": 255, "prop": "name", "attributes": {"content": "我比您強，這是不爭的事實。", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#1$1"}, {"id": 256, "prop": "dialog", "attributes": {}}, {"id": 257, "prop": "PlaySound", "attributes": {"key": "$e_skill_skulsrsword", "volume": 0.3}}, {"id": 258, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 259, "prop": "Character", "attributes": {"name": "avg_npc_452_1#1$1"}}, {"id": 260, "prop": "name", "attributes": {"content": "嘎......！", "name": "大副"}, "figure_art": "avg_npc_452_1#1$1"}, {"id": 261, "prop": "Character", "attributes": {"name": "avg_1023_ghost2_1#7$1"}}, {"id": 262, "prop": "name", "attributes": {"content": "唔，別這麼著急，大副先生或是大副小姐，還沒輪到你。", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#7$1"}, {"id": 263, "prop": "Character", "attributes": {"name": "avg_npc_446_1#7$1"}}, {"id": 264, "prop": "name", "attributes": {"content": "......你敢動它，你就死。", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#7$1"}, {"id": 265, "prop": "Character", "attributes": {"name": "avg_1023_ghost2_1#1$1"}}, {"id": 266, "prop": "name", "attributes": {"content": "我會嗎？", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#1$1"}, {"id": 267, "prop": "Character", "attributes": {"name": "avg_1023_ghost2_1#1$1"}}, {"id": 268, "prop": "name", "attributes": {"content": "既然隊長的任務是奪回這艘船，回到阿戈爾，那我們也沒悠哉到可以慢慢說服您。", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#1$1"}, {"id": 269, "prop": "Character", "attributes": {"name": "avg_1023_ghost2_1#1$1"}}, {"id": 270, "prop": "name", "attributes": {"content": "這本來就是更簡單的交流方式——獵人的方式。", "name": "幽靈鯊"}, "figure_art": "avg_1023_ghost2_1#1$1"}, {"id": 271, "prop": "Character", "attributes": {"name": "avg_npc_446_1#9$1"}}, {"id": 272, "prop": "name", "attributes": {"content": "——哈，你在找死！", "name": "船長阿方索"}, "figure_art": "avg_npc_446_1#9$1"}, {"id": 273, "prop": "dialog", "attributes": {}}, {"id": 274, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 275, "prop": "Blocker", "attributes": {"a": 0.5, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 0.1, "block": "true"}}, {"id": 276, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "false"}}, {"id": 277, "prop": "PlaySound", "attributes": {"key": "$e_skill_skulsrsword", "volume": 0.9}}, {"id": 278, "prop": "PlaySound", "attributes": {"key": "$d_avg_attack_heavy"}}, {"id": 279, "prop": "PlaySound", "attributes": {"key": "$d_sp_ballista", "volume": 0.4}}, {"id": 280, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 8.0, "ystrength": 6.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 281, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 282, "prop": "character", "attributes": {}}, {"id": 283, "prop": "Character", "attributes": {"name": "avg_npc_456_1#1$1", "fadetime": 2.0}}, {"id": 284, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 285, "prop": "PlayMusic", "attributes": {"intro": "$tense_intro", "key": "$tense_loop", "volume": 0.8}}, {"id": 286, "prop": "name", "attributes": {"content": "同類，我來找你。", "name": "海嗣"}, "figure_art": "avg_npc_456_1#1$1"}, {"id": 287, "prop": "Character", "attributes": {"name": "avg_npc_456_1#1$1"}}, {"id": 288, "prop": "name", "attributes": {"content": "捕食，重要事項。", "name": "海嗣"}, "figure_art": "avg_npc_456_1#1$1"}, {"id": 289, "prop": "Character", "attributes": {"name": "avg_npc_456_1#1$1"}}, {"id": 290, "prop": "name", "attributes": {"content": "你們，並非同胞。我已認識，但你們仍可回歸族群。", "name": "海嗣"}, "figure_art": "avg_npc_456_1#1$1"}, {"id": 291, "prop": "Character", "attributes": {"name": "avg_npc_456_1#1$1"}}, {"id": 292, "prop": "name", "attributes": {"content": "我想問，你們作何打算？", "name": "海嗣"}, "figure_art": "avg_npc_456_1#1$1"}, {"id": 293, "prop": "Character", "attributes": {"name2": "avg_npc_446_1#3$1", "name": "avg_1023_ghost2_1#1$1"}}, {"id": 294, "prop": "name", "attributes": {"content": "滾開！", "name": "船長阿方索&幽靈鯊"}, "figure_art": "avg_npc_456_1#1$1"}, {"id": 295, "prop": "dialog", "attributes": {}}, {"id": 296, "prop": "Character", "attributes": {"name": "avg_npc_446_1#9$1"}}, {"id": 297, "prop": "Blocker", "attributes": {"a": 0.5, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 0.1, "block": "true"}}, {"id": 298, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "false"}}, {"id": 299, "prop": "PlaySound", "attributes": {"key": "$e_skill_skulsrsword", "volume": 0.9}}, {"id": 300, "prop": "PlaySound", "attributes": {"key": "$d_avg_attack_heavy"}}, {"id": 301, "prop": "PlaySound", "attributes": {"key": "$d_sp_ballista", "volume": 0.4}}, {"id": 302, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 8.0, "ystrength": 6.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 303, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 304, "prop": "Character", "attributes": {"name": "avg_1023_ghost2_1#1$1"}}, {"id": 305, "prop": "Blocker", "attributes": {"a": 0.5, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 0.1, "block": "true"}}, {"id": 306, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "false"}}, {"id": 307, "prop": "PlaySound", "attributes": {"key": "$e_atk_saw_n_1", "volume": 1.0}}, {"id": 308, "prop": "PlaySound", "attributes": {"key": "$e_atk_saw_n_1", "volume": 1.0}}, {"id": 309, "prop": "PlaySound", "attributes": {"key": "$e_atk_saw_n_2", "volume": 1.0}}, {"id": 310, "prop": "PlaySound", "attributes": {"key": "$d_avg_attack_heavy"}}, {"id": 311, "prop": "PlaySound", "attributes": {"key": "$d_sp_ballista", "volume": 0.4}}, {"id": 312, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 8.0, "ystrength": 6.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 313, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 314, "prop": "Character", "attributes": {"name": "avg_npc_456_1#1$1"}}, {"id": 315, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 8.0, "ystrength": 6.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 316, "prop": "name", "attributes": {"content": "......！", "name": "海嗣"}, "figure_art": "avg_npc_456_1#1$1"}, {"id": 317, "prop": "Dialog", "attributes": {}}, {"id": 318, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 319, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 320, "prop": "Image", "attributes": {"image": "27_i39", "fadetime": 0.0, "xScale": 1.2, "yScale": 1.2, "x": 20.0}}, {"id": 321, "prop": "ImageTween", "attributes": {"xScaleTo": 0.8, "yScaleTo": 0.8, "duration": 50.0, "xTo": 0.0, "yTo": 0.0, "block": "false"}}, {"id": 322, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 323, "prop": "name", "attributes": {"content": "哈，證明你不是海嗣的方法很簡單。殺了它。除非你不願意對你的“同胞”下手。", "name": "船長阿方索"}}, {"id": 324, "prop": "name", "attributes": {"content": "我由衷希望您不要拖我的後腿。", "name": "幽靈鯊"}}, {"id": 325, "prop": "name", "attributes": {"content": "我更擔心你會對你扭曲的“同胞”手下留情，阿戈爾人。", "name": "船長阿方索"}}, {"id": 326, "prop": "name", "attributes": {"content": "那您確實多慮了。畢竟，如果我真的淪落到它們一邊，您也許根本打不贏我。", "name": "幽靈鯊"}}, {"id": 327, "prop": "name", "attributes": {"content": "證明我不是海嗣之後，您願意把船借給我們嗎？", "name": "幽靈鯊"}}, {"id": 328, "prop": "name", "attributes": {"content": "沒門。這艘船是我的東西。", "name": "船長阿方索"}}, {"id": 329, "prop": "name", "attributes": {"content": "真遺憾。也許我可以在這場戰鬥中讓你失去那隻手，你人類的部分就會更清醒些？", "name": "幽靈鯊"}}, {"id": 330, "prop": "name", "attributes": {"content": "大副！別出手，讓我看看這個自稱人的怪物，和我們有多大差別。", "name": "船長阿方索"}}, {"id": 331, "prop": "name", "attributes": {"content": "斯卡蒂，可別和我搶獵物喔，這場狩獵屬於我，讓我稍微......稍微發洩一下吧。", "name": "幽靈鯊"}}, {"id": 332, "prop": "Dialog", "attributes": {}}, {"id": 333, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 334, "prop": "dialog", "attributes": {}}, {"id": 335, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 336, "prop": "Image", "attributes": {}}, {"id": 337, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 338, "prop": "Character", "attributes": {"name": "avg_npc_456_1#1$1"}}, {"id": 339, "prop": "name", "attributes": {"content": "......", "name": "海嗣"}, "figure_art": "avg_npc_456_1#1$1"}, {"id": 340, "prop": "Character", "attributes": {"name": "avg_npc_456_1#1$1"}}, {"id": 341, "prop": "name", "attributes": {"content": "捕食，必須去做。", "name": "海嗣"}, "figure_art": "avg_npc_456_1#1$1"}, {"id": 342, "prop": "Character", "attributes": {"name": "avg_npc_456_1#1$1"}}, {"id": 343, "prop": "name", "attributes": {"content": "使命，塑造環境。", "name": "海嗣"}, "figure_art": "avg_npc_456_1#1$1"}, {"id": 344, "prop": "Character", "attributes": {"name": "avg_npc_456_1#1$1"}}, {"id": 345, "prop": "name", "attributes": {"content": "你們，富含養分。", "name": "海嗣"}, "figure_art": "avg_npc_456_1#1$1"}, {"id": 346, "prop": "Dialog", "attributes": {}}, {"id": 347, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 348, "prop": "stopmusic", "attributes": {"fadetime": 3.0}}, {"id": 349, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 350, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}