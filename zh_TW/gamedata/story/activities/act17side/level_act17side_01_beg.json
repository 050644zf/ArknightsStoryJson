Delay", "attributes": {"time": 1.3}}, {"id": 339, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#13$1", "name2": "avg_npc_453_1#1$1", "focus": 1.0}}, {"id": 340, "prop": "name", "attributes": {"content": "你......", "name": "喬迪"}, "figure_art": "avg_4042_lumen_1#13$1"}, {"id": 341, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#13$1", "name2": "avg_npc_453_1#1$1", "focus": 2.0}}, {"id": 342, "prop": "name", "attributes": {"content": "......喬迪？", "name": "詭異的教徒"}, "figure_art": "avg_npc_453_1#1$1"}, {"id": 343, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#8$1", "name2": "avg_npc_453_1#1$1", "focus": 1.0}}, {"id": 344, "prop": "name", "attributes": {"content": "你認識我？你是誰？", "name": "喬迪"}, "figure_art": "avg_4042_lumen_1#8$1"}, {"id": 345, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#8$1", "name2": "avg_npc_453_1#1$1", "focus": 2.0}}, {"id": 346, "prop": "name", "attributes": {"content": "我......你不需要知道我是誰，你並不認識我。而我認識你，僅僅因為你是個阿戈爾人而已。", "name": "詭異的教徒"}, "figure_art": "avg_npc_453_1#1$1"}, {"id": 347, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#1$1", "name2": "avg_npc_453_1#1$1", "focus": 1.0}}, {"id": 348, "prop": "name", "attributes": {"content": "你、你受傷了？", "name": "喬迪"}, "figure_art": "avg_4042_lumen_1#1$1"}, {"id": 349, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#1$1", "name2": "avg_npc_453_1#1$1", "focus": 2.0}}, {"id": 350, "prop": "name", "attributes": {"content": "......是的，那你會為我包紮嗎？你不是禮拜堂的護工嗎？", "name": "詭異的教徒"}, "figure_art": "avg_npc_453_1#1$1"}, {"id": 351, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#8$1", "name2": "avg_npc_453_1#1$1", "focus": 1.0}}, {"id": 352, "prop": "name", "attributes": {"content": "我......", "name": "喬迪"}, "figure_art": "avg_4042_lumen_1#8$1"}, {"id": 353, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#13$1", "name2": "avg_npc_453_1#1$1", "focus": 1.0}}, {"id": 354, "prop": "name", "attributes": {"content": "我可以幫你，但你得告訴我，你是怎麼受傷的。", "name": "喬迪"}, "figure_art": "avg_4042_lumen_1#13$1"}, {"id": 355, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#13$1", "name2": "avg_npc_453_1#1$1", "focus": 2.0}}, {"id": 356, "prop": "name", "attributes": {"content": "......好。", "name": "詭異的教徒"}, "figure_art": "avg_npc_453_1#1$1"}, {"id": 357, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#1$1", "name2": "avg_npc_453_1#1$1", "focus": 1.0}}, {"id": 358, "prop": "name", "attributes": {"content": "你找個地方坐下。", "name": "喬迪"}, "figure_art": "avg_4042_lumen_1#1$1"}, {"id": 359, "prop": "Dialog", "attributes": {}}, {"id": 360, "prop": "Character", "attributes": {"fadetime": 0.5}}, {"id": 361, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 362, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovement", "volume": 0.5}}, {"id": 363, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 364, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown2", "volume": 0.5}}, {"id": 365, "prop": "PlaySound", "attributes": {"key": "$dooropenquite", "volume": 0.5}}, {"id": 366, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 367, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#1$1", "name2": "avg_npc_453_1#1$1", "focus": 1.0}}, {"id": 368, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "fadetime": 0.0, "block": "true"}}, {"id": 369, "prop": "name", "attributes": {"content": "忍著點。", "name": "喬迪"}, "figure_art": "avg_4042_lumen_1#1$1"}, {"id": 370, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#1$1", "name2": "avg_npc_453_1#1$1", "focus": 2.0}}, {"id": 371, "prop": "name", "attributes": {"content": "......唔......", "name": "詭異的教徒"}, "figure_art": "avg_npc_453_1#1$1"}, {"id": 372, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#13$1", "name2": "avg_npc_453_1#1$1", "focus": 1.0}}, {"id": 373, "prop": "name", "attributes": {"content": "別動！萬幸沒傷到骨頭和內臟......這是割傷？還有木屑扎在皮膚裡，怎麼回事？", "name": "喬迪"}, "figure_art": "avg_4042_lumen_1#13$1"}, {"id": 374, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#13$1", "name2": "avg_npc_453_1#1$1", "focus": 2.0}}, {"id": 375, "prop": "name", "attributes": {"content": "有個阿戈爾人，殺了我的兄弟。我受了波及，逃了出來。", "name": "詭異的教徒"}, "figure_art": "avg_npc_453_1#1$1"}, {"id": 376, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#7$1", "name2": "avg_npc_453_1#1$1", "focus": 1.0}}, {"id": 377, "prop": "name", "attributes": {"content": "謀、謀殺？！在這裡嗎？那可得趕緊找蒂亞戈叔叔——", "name": "喬迪"}, "figure_art": "avg_4042_lumen_1#7$1"}, {"id": 378, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#7$1", "name2": "avg_npc_453_1#1$1", "focus": 2.0}}, {"id": 379, "prop": "name", "attributes": {"content": "呵，呵呵，蒂亞戈鎮長管不了那個阿戈爾人，多諷刺，如今只有審判庭能制裁他。", "name": "詭異的教徒"}, "figure_art": "avg_npc_453_1#1$1"}, {"id": 380, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#1$1", "name2": "avg_npc_453_1#1$1", "focus": 1.0}}, {"id": 381, "prop": "name", "attributes": {"content": "但、但是他傷害了你的家人......", "name": "喬迪"}, "figure_art": "avg_4042_lumen_1#1$1"}, {"id": 382, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#1$1", "name2": "avg_npc_453_1#1$1", "focus": 2.0}}, {"id": 383, "prop": "name", "attributes": {"content": "我們總是在被傷害，因為無知，恐懼，和從那場災難起彌留至今的憤怒......謝謝，我好多了。", "name": "詭異的教徒"}, "figure_art": "avg_npc_453_1#1$1"}, {"id": 384, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#8$1", "name2": "avg_npc_453_1#1$1", "focus": 1.0}}, {"id": 385, "prop": "name", "attributes": {"content": "......你是，胡安先生？", "name": "喬迪"}, "figure_art": "avg_4042_lumen_1#8$1"}, {"id": 386, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#8$1", "name2": "avg_npc_453_1#1$1", "focus": 2.0}}, {"id": 387, "prop": "name", "attributes": {"content": "你記得我的長相，喬迪。你沒想過......去看看那片大海嗎？", "name": "詭異的教徒"}, "figure_art": "avg_npc_453_1#1$1"}, {"id": 388, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#11$1", "name2": "avg_npc_453_1#1$1", "focus": 1.0}}, {"id": 389, "prop": "name", "attributes": {"content": "看......海嗎？蒂亞戈叔叔帶我去過海岸邊......", "name": "喬迪"}, "figure_art": "avg_4042_lumen_1#11$1"}, {"id": 390, "prop": "Dialog", "attributes": {}}, {"id": 391, "prop": "Blocker", "attributes": {"a": 0.8, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 392, "prop": "Subtitle", "attributes": {"text": "那是一片漆黑的海。風掠起髮絲，浪在咆哮。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 393, "prop": "Subtitle", "attributes": {"text": "“故鄉”的定義因人而異，也許是小麥的香氣，巷角陰影的角度，泥雪被傾軋的聲響。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 394, "prop": "Subtitle", "attributes": {"text": "但那一刻，喬迪知道，在格蘭法洛的生活裡，自己早已預支了故鄉。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 395, "prop": "Subtitle", "attributes": {}}, {"id": 396, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 397, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#11$1", "name2": "avg_npc_453_1#1$1", "focus": 2.0}}, {"id": 398, "prop": "name", "attributes": {"content": "這片大地已經忘記了真正的海洋，但是我們遲早......遲早都要回到海裡。", "name": "詭異的教徒"}, "figure_art": "avg_npc_453_1#1$1"}, {"id": 399, "prop": "name", "attributes": {"content": "（生澀的阿戈爾語）謝謝，喬迪。謝謝你的善良，也許終有一日，無限的利他性會填滿生存的窟窿。", "name": "詭異的教徒"}, "figure_art": "avg_npc_453_1#1$1"}, {"id": 400, "prop": "name", "attributes": {"content": "（生澀的阿戈爾語）如果你還是一個阿戈爾人，喬迪，別管我們的事情。回到你的生活，這樣更好。", "name": "詭異的教徒"}, "figure_art": "avg_npc_453_1#1$1"}, {"id": 401, "prop": "name", "attributes": {"content": "（生澀的阿戈爾語）也許，你也會像你的父母那樣，去尋找那座燈塔。", "name": "詭異的教徒"}, "figure_art": "avg_npc_453_1#1$1"}, {"id": 402, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#13$1", "name2": "avg_npc_453_1#1$1", "focus": 1.0}}, {"id": 403, "prop": "name", "attributes": {"content": "你、你在說什麼？我聽不清！", "name": "喬迪"}, "figure_art": "avg_4042_lumen_1#13$1"}, {"id": 404, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#13$1", "name2": "avg_npc_453_1#1$1", "focus": 2.0}}, {"id": 405, "prop": "name", "attributes": {"content": "（生澀的阿戈爾語）逃走的家人們來接我了。但是沒關係，格蘭法洛本來就只是一處踏板，我們將飛向深海。", "name": "詭異的教徒"}, "figure_art": "avg_npc_453_1#1$1"}, {"id": 406, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 407, "prop": "Character", "attributes": {}}, {"id": 408, "prop": "Dialog", "attributes": {}}, {"id": 409, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 410, "prop": "playMusic", "attributes": {"intro": "$frontline_intro", "key": "$frontline_loop", "fadetime": 3.0, "volume": 0.4}}, {"id": 411, "prop": "Character", "attributes": {"name": "avg_npc_457_1#1$1", "fadetime": 1.0}}, {"id": 412, "prop": "characteraction", "attributes": {"name": "middle", "type": "move", "ypos": 100.0, "fadetime": 0.0, "block": "true"}}, {"id": 413, "prop": "characteraction", "attributes": {"name": "middle", "type": "zoom", "scale": 0.8, "fadetime": 0.0, "block": "true"}}, {"id": 414, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 415, "prop": "Character", "attributes": {"fadetime": 0.5}}, {"id": 416, "prop": "characteraction", "attributes": {"name": "middle", "type": "zoom", "scale": 0.8, "fadetime": 0.0, "block": "true"}}, {"id": 417, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 418, "prop": "Character", "attributes": {}}, {"id": 419, "prop": "Character", "attributes": {"name": "avg_4042_lumen_1#6$1"}}, {"id": 420, "prop": "name", "attributes": {"content": "——！", "name": "喬迪"}, "figure_art": "avg_4042_lumen_1#6$1"}, {"id": 421, "prop": "Dialog", "attributes": {}}, {"id": 422, "prop": "Character", "attributes": {}}, {"id": 423, "prop": "Character", "attributes": {"name": "char_empty", "name2": "avg_npc_453_1#1$1"}}, {"id": 424, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "fadetime": 0.0, "block": "true"}}, {"id": 425, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 426, "prop": "Character", "attributes": {"name": "avg_npc_457_1#1$1", "name2": "avg_npc_453_1#1$1", "fadetime": 1.0}}, {"id": 427, "prop": "characteraction", "attributes": {"name": "left", "type": "move", "ypos": 100.0, "fadetime": 0.0, "block": "true"}}, {"id": 428, "prop": "characteraction", "attributes": {"name": "left", "type": "zoom", "scale": 0.8, "fadetime": 0.0, "block": "true"}}, {"id": 429, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 430, "prop": "PlaySound", "attributes": {"key": "$d_avg_fish_howl", "volume": 0.3}}, {"id": 431, "prop": "Characteraction", "attributes": {"name": "left", "type": "move", "xpos": 70.0, "fadetime": 2.0, "block": "false"}}, {"id": 432, "prop": "characteraction", "attributes": {"name": "left", "type": "zoom", "scale": 0.9, "fadetime": 3.0, "block": "true"}}, {"id": 433, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 434, "prop": "PlaySound", "attributes": {"key": "$d_avg_fish_howl", "volume": 0.3}}, {"id": 435, "prop": "Characteraction", "attributes": {"name": "left", "type": "move", "fadetime": 2.0, "block": "false"}}, {"id": 436, "prop": "characteraction", "attributes": {"name": "left", "type": "zoom", "scale": 1.0, "fadetime": 3.0, "block": "true"}}, {"id": 437, "prop": "StopSound", "attributes": {"channel": "bgs", "fadetime": 1.0}}, {"id": 438, "prop": "Character", "attributes": {"name": "avg_npc_457_1#1$1", "name2": "avg_npc_453_1#1$1", "focus": 1.0}}, {"id": 439, "prop": "name", "attributes": {"content": "（輕巧的窸窣聲）", "name": "蠕行的恐魚"}, "figure_art": "avg_npc_457_1#1$1"}, {"id": 440, "prop": "Character", "attributes": {"name": "avg_npc_457_1#1$1", "name2": "avg_npc_453_1#1$1", "focus": 2.0}}, {"id": 441, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "ypos": 60.0, "fadetime": 1.0, "block": "true"}}, {"id": 442, "prop": "name", "attributes": {"content": "喬迪，喬迪。阿戈爾人。", "name": "詭異的教徒"}, "figure_art": "avg_npc_453_1#1$1"}, {"id": 443, "prop": "name", "attributes": {"content": "再會吧。", "name": "詭異的教徒"}, "figure_art": "avg_npc_453_1#1$1"}, {"id": 444, "prop": "Dialog", "attributes": {}}, {"id": 445, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 446, "prop": "stopmusic", "attributes": {"fadetime": 3.0}}, {"id": 447, "prop": "Character", "attributes": {}}, {"id": 448, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}