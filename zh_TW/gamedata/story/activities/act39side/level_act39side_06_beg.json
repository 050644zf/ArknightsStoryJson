me", "attributes": {"content": "那是船隊的方向。"}}, {"id": 394, "prop": "Dialog", "attributes": {}}, {"id": 395, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1577_1#5$1", "focus": "m"}}, {"id": 396, "prop": "name", "attributes": {"content": "怎麼會這樣？", "name": "伊西多"}, "figure_art": "avg_npc_1577_1#5$1"}, {"id": 397, "prop": "name", "attributes": {"content": "我……", "name": "伊西多"}, "figure_art": "avg_npc_1577_1#5$1"}, {"id": 398, "prop": "Dialog", "attributes": {}}, {"id": 399, "prop": "PlaySound", "attributes": {"key": "$runsand", "volume": 1.0}}, {"id": 400, "prop": "charslot", "attributes": {"duration": 0.5}}, {"id": 401, "prop": "delay", "attributes": {"time": 0.7}}, {"id": 402, "prop": "image", "attributes": {"image": "57_i05", "screenadapt": "coverall", "xScale": 1.1, "yScale": 1.1, "fadetime": 2.0}}, {"id": 403, "prop": "ImageTween", "attributes": {"xTo": 0.0, "yTo": 0.0, "xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 9.0, "block": "false"}}, {"id": 404, "prop": "Delay", "attributes": {"time": 3.0}}, {"id": 405, "prop": "name", "attributes": {"content": "伊西多毫不猶豫地邁出了步伐。"}}, {"id": 406, "prop": "name", "attributes": {"content": "不靠理性，只憑衝動，他做出了決定。"}}, {"id": 407, "prop": "name", "attributes": {"content": "沿著原路踩出的腳印，伊西多拚命地往回奔去。"}}, {"id": 408, "prop": "name", "attributes": {"content": "那串腳印於是不再孤獨。"}}, {"id": 409, "prop": "Dialog", "attributes": {}}, {"id": 410, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 411, "prop": "StopSound", "attributes": {"channel": "bgs", "fadetime": 2.0}}, {"id": 412, "prop": "StopSound", "attributes": {"channel": "bse", "fadetime": 2.0}}, {"id": 413, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 414, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 415, "prop": "charslot", "attributes": {}}, {"id": 416, "prop": "image", "attributes": {}}, {"id": 417, "prop": "Background", "attributes": {"image": "57_g11_meetingroom", "screenadapt": "showall"}}, {"id": 418, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 419, "prop": "playMusic", "attributes": {"key": "$darkness_03_loop", "volume": 0.6}}, {"id": 420, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 421, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 422, "prop": "PlaySound", "attributes": {"key": "$d_avg_chairbump", "volume": 0.7}}, {"id": 423, "prop": "PlaySound", "attributes": {"key": "$d_avg_cardboard", "volume": 1.0, "delay": 0.2}}, {"id": 424, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 425, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1579_1#1$2", "focus": "m"}}, {"id": 426, "prop": "name", "attributes": {"content": "別再找了，你找不到的。", "name": "哈維爾"}, "figure_art": "avg_npc_1579_1#1$2"}, {"id": 427, "prop": "Dialog", "attributes": {}}, {"id": 428, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1579_1#1$2", "focus": "n"}}, {"id": 429, "prop": "PlaySound", "attributes": {"key": "$d_avg_planeshake", "volume": 0.6}}, {"id": 430, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 431, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1579_1#1$2", "focus": "m"}}, {"id": 432, "prop": "name", "attributes": {"content": "船員們告訴我，那個小子的實驗搞砸了，羅盤毀在他的手裡，你就算找到也沒用。", "name": "哈維爾"}, "figure_art": "avg_npc_1579_1#1$2"}, {"id": 433, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1582_1#7$1", "focus": "m"}}, {"id": 434, "prop": "name", "attributes": {"content": "羅盤對我有沒有用，不是你說的算，強盜。", "name": "安納斯塔西奧"}, "figure_art": "avg_npc_1582_1#7$1"}, {"id": 435, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1579_1#9$2", "focus": "m"}}, {"id": 436, "prop": "name", "attributes": {"content": "是是……對不起。", "name": "哈維爾"}, "figure_art": "avg_npc_1579_1#9$2"}, {"id": 437, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1582_1#7$1", "focus": "m"}}, {"id": 438, "prop": "name", "attributes": {"content": "我守了那個羅盤將近十年，我殺了每一個試圖染指它的人……", "name": "安納斯塔西奧"}, "figure_art": "avg_npc_1582_1#7$1"}, {"id": 439, "prop": "name", "attributes": {"content": "就算它真的化為粉塵，我也要親眼見證。", "name": "安納斯塔西奧"}, "figure_art": "avg_npc_1582_1#7$1"}, {"id": 440, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1582_1#9$1", "focus": "m"}}, {"id": 441, "prop": "name", "attributes": {"content": "你們的首領在哪裡？", "name": "安納斯塔西奧"}, "figure_art": "avg_npc_1582_1#9$1"}, {"id": 442, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1579_1#10$2", "focus": "m"}}, {"id": 443, "prop": "name", "attributes": {"content": "我們有過協議，你們答應會放過胡安娜。", "name": "哈維爾"}, "figure_art": "avg_npc_1579_1#10$2"}, {"id": 444, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1582_1#7$1", "focus": "m"}}, {"id": 445, "prop": "name", "attributes": {"content": "你和西爾弗的協議，與我無關。", "name": "安納斯塔西奧"}, "figure_art": "avg_npc_1582_1#7$1"}, {"id": 446, "prop": "name", "attributes": {"content": "那個女人帶著羅盤逃走了，是不是？那套煉金失敗的說法只是藉口，是不是？", "name": "安納斯塔西奧"}, "figure_art": "avg_npc_1582_1#7$1"}, {"id": 447, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1582_1#3$1", "focus": "m"}}, {"id": 448, "prop": "name", "attributes": {"content": "謊言……為了保護那個女人，為了你自己的慾望，是不是？你也該被——", "name": "安納斯塔西奧"}, "figure_art": "avg_npc_1582_1#3$1"}, {"id": 449, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1579_1#6$2", "focus": "m"}}, {"id": 450, "prop": "name", "attributes": {"content": "我沒騙你。羅盤早就不在胡安娜手上了，她完全沒有必要死死握著一個已經毀掉的羅盤。", "name": "哈維爾"}, "figure_art": "avg_npc_1579_1#6$2"}, {"id": 451, "prop": "name", "attributes": {"content": "你該找的只有那個煉金小子和他的工坊。", "name": "哈維爾"}, "figure_art": "avg_npc_1579_1#6$2"}, {"id": 452, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1582_1#7$1", "focus": "m"}}, {"id": 453, "prop": "name", "attributes": {"content": "在哪裡？", "name": "安納斯塔西奧"}, "figure_art": "avg_npc_1582_1#7$1"}, {"id": 454, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1579_1#1$2", "focus": "m"}}, {"id": 455, "prop": "name", "attributes": {"content": "那邊後面的第二個帳篷，地上有暗門，煉金工坊就在底下。", "name": "哈維爾"}, "figure_art": "avg_npc_1579_1#1$2"}, {"id": 456, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1582_1#8$1", "focus": "m"}}, {"id": 457, "prop": "name", "attributes": {"content": "……謊言。", "name": "安納斯塔西奧"}, "figure_art": "avg_npc_1582_1#8$1"}, {"id": 458, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1582_1#9$1", "focus": "m"}}, {"id": 459, "prop": "name", "attributes": {"content": "別逼我現在殺了你。", "name": "安納斯塔西奧"}, "figure_art": "avg_npc_1582_1#9$1"}, {"id": 460, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1579_1#9$2", "focus": "m"}}, {"id": 461, "prop": "name", "attributes": {"content": "……", "name": "哈維爾"}, "figure_art": "avg_npc_1579_1#9$2"}, {"id": 462, "prop": "Dialog", "attributes": {}}, {"id": 463, "prop": "musicvolume", "attributes": {"volume": 0.3, "fadetime": 1.5}}, {"id": 464, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 465, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 466, "prop": "charslot", "attributes": {}}, {"id": 467, "prop": "image", "attributes": {}}, {"id": 468, "prop": "Background", "attributes": {"image": "57_g9_community_d", "screenadapt": "showall"}}, {"id": 469, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1591_1#1$1"}}, {"id": 470, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1587_1#1$1"}}, {"id": 471, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 472, "prop": "musicvolume", "attributes": {"volume": 0.6, "fadetime": 2.0}}, {"id": 473, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 474, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 475, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1587_1#1$1", "focus": "r"}}, {"id": 476, "prop": "name", "attributes": {"content": "老實點！別亂動！", "name": "習武教士"}, "figure_art": "avg_npc_1587_1#1$1"}, {"id": 477, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1591_1#1$1", "focus": "l"}}, {"id": 478, "prop": "name", "attributes": {"content": "那個……你們說的是真的嗎？只要找到那個羅盤，我們都能獲得赦免？", "name": "窘迫的船員"}, "figure_art": "avg_npc_1591_1#1$1"}, {"id": 479, "prop": "name", "attributes": {"content": "我們都這麼快就投降了……那赦免我們的部分，是不是也應該稍微放寬條件？", "name": "窘迫的船員"}, "figure_art": "avg_npc_1591_1#1$1"}, {"id": 480, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1587_1#1$1", "focus": "r"}}, {"id": 481, "prop": "name", "attributes": {"content": "……", "name": "習武教士"}, "figure_art": "avg_npc_1587_1#1$1"}, {"id": 482, "prop": "name", "attributes": {"content": "蠢貨。", "name": "習武教士"}, "figure_art": "avg_npc_1587_1#1$1"}, {"id": 483, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1591_1#1$1", "focus": "l"}}, {"id": 484, "prop": "name", "attributes": {"content": "好吧……", "name": "窘迫的船員"}, "figure_art": "avg_npc_1591_1#1$1"}, {"id": 485, "prop": "Dialog", "attributes": {}}, {"id": 486, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 487, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 488, "prop": "charslot", "attributes": {}}, {"id": 489, "prop": "Image", "attributes": {}}, {"id": 490, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}