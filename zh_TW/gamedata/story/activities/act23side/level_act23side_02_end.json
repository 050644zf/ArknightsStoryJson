$1", "focus": "l"}}, {"id": 332, "prop": "name", "attributes": {"content": "先去和雨霞姐會合吧。", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#1$1"}, {"id": 333, "prop": "Dialog", "attributes": {}}, {"id": 334, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 335, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 336, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 337, "prop": "charslot", "attributes": {}}, {"id": 338, "prop": "Background", "attributes": {"image": "35_g9_yumensuburb", "screenadapt": "coverall"}}, {"id": 339, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 340, "prop": "PlayMusic", "attributes": {"intro": "$darkalley_intro", "key": "$darkalley_loop", "volume": 0.4}}, {"id": 341, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 342, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 343, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 344, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 345, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_033", "duration": 0.7}}, {"id": 346, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4080_lin_1#1$1", "duration": 0.7}}, {"id": 347, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 348, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_033", "focus": "l"}}, {"id": 349, "prop": "name", "attributes": {"content": "大小姐，前面就是那個走私犯說的倉庫了。", "name": "龍門暗樁"}, "figure_art": "avg_npc_033"}, {"id": 350, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_033", "focus": "l"}}, {"id": 351, "prop": "name", "attributes": {"content": "奇怪......", "name": "龍門暗樁"}, "figure_art": "avg_npc_033"}, {"id": 352, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4080_lin_1#1$1", "focus": "r"}}, {"id": 353, "prop": "name", "attributes": {"content": "你知道這個地方？", "name": "林雨霞"}, "figure_art": "avg_4080_lin_1#1$1"}, {"id": 354, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_033", "focus": "l"}}, {"id": 355, "prop": "name", "attributes": {"content": "我之前暗訪的時候，排查過城裡的貨運點，這個倉庫，應該是城南鑄劍坊用來囤放鐵器和源石燃料的。", "name": "龍門暗樁"}, "figure_art": "avg_npc_033"}, {"id": 356, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_033", "focus": "l"}}, {"id": 357, "prop": "name", "attributes": {"content": "從我查到的資料看，鑄劍坊是城裡有年頭的招牌，不應該和這件事有關聯......", "name": "龍門暗樁"}, "figure_art": "avg_npc_033"}, {"id": 358, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_033", "focus": "l"}}, {"id": 359, "prop": "name", "attributes": {"content": "個*龍門粗口*的，那傢伙敢耍我們！", "name": "龍門暗樁"}, "figure_art": "avg_npc_033"}, {"id": 360, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4080_lin_1#8$1", "focus": "r"}}, {"id": 361, "prop": "name", "attributes": {"content": "慢著。", "name": "林雨霞"}, "figure_art": "avg_4080_lin_1#8$1"}, {"id": 362, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4080_lin_1#1$1", "focus": "r"}}, {"id": 363, "prop": "name", "attributes": {"content": "你急什麼。", "name": "林雨霞"}, "figure_art": "avg_4080_lin_1#1$1"}, {"id": 364, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4080_lin_1#1$1", "focus": "r"}}, {"id": 365, "prop": "name", "attributes": {"content": "都逼到了那個份上，他沒有撒謊的膽子。既然來了，有沒有問題，看一看不就知道了。", "name": "林雨霞"}, "figure_art": "avg_4080_lin_1#1$1"}, {"id": 366, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4080_lin_1#1$1", "focus": "r"}}, {"id": 367, "prop": "name", "attributes": {"content": "你守在這裡，我去看看。", "name": "林雨霞"}, "figure_art": "avg_4080_lin_1#1$1"}, {"id": 368, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_033", "focus": "l"}}, {"id": 369, "prop": "name", "attributes": {"content": "大小姐當心。", "name": "龍門暗樁"}, "figure_art": "avg_npc_033"}, {"id": 370, "prop": "musicvolume", "attributes": {"volume": 0.2, "fadetime": 1.0}}, {"id": 371, "prop": "Dialog", "attributes": {}}, {"id": 372, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 373, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 374, "prop": "Character", "attributes": {}}, {"id": 375, "prop": "charslot", "attributes": {}}, {"id": 376, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 377, "prop": "Background", "attributes": {"image": "bg_warehouse", "screenadapt": "coverall"}}, {"id": 378, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 379, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 380, "prop": "musicvolume", "attributes": {"volume": 0.4, "fadetime": 1.0}}, {"id": 381, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4080_lin_1#1$1", "focus": "m"}}, {"id": 382, "prop": "name", "attributes": {"content": "......", "name": "林雨霞"}, "figure_art": "avg_4080_lin_1#1$1"}, {"id": 383, "prop": "dialog", "attributes": {}}, {"id": 384, "prop": "charslot", "attributes": {}}, {"id": 385, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 386, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_797_1#1$1", "bstart": 0.2, "bend": 0.7, "duration": 1.5}}, {"id": 387, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 388, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_797_1#1$1", "focus": "m"}}, {"id": 389, "prop": "name", "attributes": {"content": "這位小姐，您大概走錯地方了。", "name": "倉庫看守"}, "figure_art": "avg_npc_797_1#1$1"}, {"id": 390, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4080_lin_1#1$1", "focus": "m"}}, {"id": 391, "prop": "name", "attributes": {"content": "這裡不是石刻店的倉庫嗎？", "name": "林雨霞"}, "figure_art": "avg_4080_lin_1#1$1"}, {"id": 392, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_797_1#1$1", "focus": "m"}}, {"id": 393, "prop": "name", "attributes": {"content": "......", "name": "倉庫看守"}, "figure_art": "avg_npc_797_1#1$1"}, {"id": 394, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4080_lin_1#1$1", "focus": "m"}}, {"id": 395, "prop": "name", "attributes": {"content": "我是來買石料的。", "name": "林雨霞"}, "figure_art": "avg_4080_lin_1#1$1"}, {"id": 396, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4080_lin_1#1$1", "focus": "m"}}, {"id": 397, "prop": "name", "attributes": {"content": "你們老闆擺在集市賣的那些石刻做工太粗糙了，但用料本身不錯，我想直接進一批帶回去。", "name": "林雨霞"}, "figure_art": "avg_4080_lin_1#1$1"}, {"id": 398, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4080_lin_1#10$1", "focus": "m"}}, {"id": 399, "prop": "name", "attributes": {"content": "你們老闆同意了，讓我來倉庫，找你直接帶我看看。", "name": "林雨霞"}, "figure_art": "avg_4080_lin_1#10$1"}, {"id": 400, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_797_1#1$1", "focus": "m"}}, {"id": 401, "prop": "name", "attributes": {"content": "鐘記石刻嗎？", "name": "倉庫看守"}, "figure_art": "avg_npc_797_1#1$1"}, {"id": 402, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4080_lin_1#10$1", "focus": "m"}}, {"id": 403, "prop": "name", "attributes": {"content": "是叫這個名吧，集市最東頭那家。", "name": "林雨霞"}, "figure_art": "avg_4080_lin_1#10$1"}, {"id": 404, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_797_1#1$1", "focus": "m"}}, {"id": 405, "prop": "name", "attributes": {"content": "鐘記石刻的倉庫在城西，這裡是城南。", "name": "倉庫看守"}, "figure_art": "avg_npc_797_1#1$1"}, {"id": 406, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_797_1#1$1", "focus": "m"}}, {"id": 407, "prop": "name", "attributes": {"content": "您不用再往裡走了。", "name": "倉庫看守"}, "figure_art": "avg_npc_797_1#1$1"}, {"id": 408, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_797_1#1$1", "focus": "m"}}, {"id": 409, "prop": "name", "attributes": {"content": "您看看周圍，都是些生鐵料子，還有打廢的鐵坯，上哪找石料去。", "name": "倉庫看守"}, "figure_art": "avg_npc_797_1#1$1"}, {"id"