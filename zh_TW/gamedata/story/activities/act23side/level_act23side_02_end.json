": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 75, "prop": "stickerclear", "attributes": {}}, {"id": 76, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 77, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 78, "prop": "curtain", "attributes": {"direction": 0.0, "fillfrom": 0.3, "fillto": 0.0, "grad": "true", "fadetime": 0.01}}, {"id": 79, "prop": "curtain", "attributes": {"direction": 4.0, "fillfrom": 0.4, "fillto": 0.0, "grad": "true", "fadetime": 0.01, "block": "true"}}, {"id": 80, "prop": "curtain", "attributes": {}}, {"id": 81, "prop": "delay", "attributes": {"time": 0.1}}, {"id": 82, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 83, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 84, "prop": "PlaySound", "attributes": {"key": "$swordtsing5", "delay": 0.2, "channel": "R", "volume": 1.0, "block": "true"}}, {"id": 85, "prop": "PlaySound", "attributes": {"key": "$swordtsing5", "delay": 0.6, "channel": "h", "volume": 1.0, "block": "true"}}, {"id": 86, "prop": "PlaySound", "attributes": {"key": "$swordtsing5", "channel": "o", "volume": 1.0, "block": "true"}}, {"id": 87, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 88, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 89, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.3, "block": "true"}}, {"id": 90, "prop": "PlayMusic", "attributes": {"intro": "$suspenseful_intro", "key": "$suspenseful_loop", "volume": 0.4}}, {"id": 91, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_787_1#1$1", "focus": "none"}}, {"id": 92, "prop": "name", "attributes": {"content": "（悶哼聲）", "name": "山海眾成員"}}, {"id": 93, "prop": "name", "attributes": {"content": "這樣的反應，絕不僅僅是高超的“武技”，那是從生死場裡賺來的經驗。"}}, {"id": 94, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_787_1#7$1", "focus": "m"}}, {"id": 95, "prop": "name", "attributes": {"content": "還不退？", "name": "仇白"}, "figure_art": "avg_npc_787_1#7$1"}, {"id": 96, "prop": "dialog", "attributes": {}}, {"id": 97, "prop": "charslot", "attributes": {}}, {"id": 98, "prop": "name", "attributes": {"content": "......", "name": "山海眾成員"}}, {"id": 99, "prop": "playsound", "attributes": {"key": "$d_avg_crowdrun", "channel": "run"}}, {"id": 100, "prop": "soundvolume", "attributes": {"channel": "run", "volume": 0.0, "fadetime": 1.0}}, {"id": 101, "prop": "Dialog", "attributes": {}}, {"id": 102, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_787_1#7$1"}}, {"id": 103, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 0.9}}, {"id": 104, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_297_1#1$1", "posfrom": "200,0", "posto": "0,0", "duration": 1.0, "isblock": "false"}}, {"id": 105, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 106, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_787_1#1$1", "focus": "r"}}, {"id": 107, "prop": "name", "attributes": {"content": "別追。", "name": "仇白"}}, {"id": 108, "prop": "name", "attributes": {"content": "集市人太多，這些凶徒下手殘忍，容易傷及無辜。", "name": "仇白"}}, {"id": 109, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_297_1#6$1", "focus": "l"}}, {"id": 110, "prop": "name", "attributes": {"content": "（粗重的喘息）", "name": "左樂"}, "figure_art": "avg_npc_297_1#6$1"}, {"id": 111, "prop": "charslot", "attributes": {}}, {"id": 112, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_297_1#5$1", "focus": "m"}}, {"id": 113, "prop": "name", "attributes": {"content": "仇、仇姐姐......好久不見。", "name": "左樂"}, "figure_art": "avg_npc_297_1#5$1"}, {"id": 114, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_787_1#11$1", "focus": "m"}}, {"id": 115, "prop": "name", "attributes": {"content": "是好久不見。你的武功怎麼沒什麼長進？", "name": "仇白"}, "figure_art": "avg_npc_787_1#11$1"}, {"id": 116, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_297_1#5$1", "focus": "m"}}, {"id": 117, "prop": "name", "attributes": {"content": "......", "name": "左樂"}, "figure_art": "avg_npc_297_1#5$1"}, {"id": 118, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_297_1#1$1", "focus": "m"}}, {"id": 119, "prop": "name", "attributes": {"content": "仇姐姐為何來此？", "name": "左樂"}, "figure_art": "avg_npc_297_1#1$1"}, {"id": 120, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_787_1#1$1", "focus": "m"}}, {"id": 121, "prop": "name", "attributes": {"content": "宗師讓我來幫一幫你。", "name": "仇白"}, "figure_art": "avg_npc_787_1#1$1"}, {"id": 122, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_787_1#11$1", "focus": "m"}}, {"id": 123, "prop": "name", "attributes": {"content": "旁邊這位是？", "name": "仇白"}, "figure_art": "avg_npc_787_1#11$1"}, {"id": 124, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_297_1#1$1", "focus": "m"}}, {"id": 125, "prop": "name", "attributes": {"content": "是在先前的任務中，認識的一位朋友......也是梁大人的故交。", "name": "左樂"}, "figure_art": "avg_npc_297_1#1$1"}, {"id": 126, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_787_1#11$1", "focus": "m"}}, {"id": 127, "prop": "name", "attributes": {"content": "哪怕是梁大人的朋友，不是官差之身，也不該隨意插手眼下的事。", "name": "仇白"}, "figure_art": "avg_npc_787_1#11$1"}, {"id": 128, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_322_lmlee_1#9$1", "focus": "m"}}, {"id": 129, "prop": "name", "attributes": {"content": "誤會，誤會。我只是碰巧路過。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#9$1"}, {"id": 130, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_322_lmlee_1#1$1", "focus": "m"}}, {"id": 131, "prop": "name", "attributes": {"content": "說起來，有人托我辦事的時候，都另外有人勸我不要多管閒事。這大概也算私家偵探工作固定的套路？", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 132, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_297_1#7$1", "focus": "m"}}, {"id": 133, "prop": "name", "attributes": {"content": "若不是鯉先生出手，在下恐怕已經性命有恙。只是，鯉先生真的是碰巧出現在這裡？", "name": "左樂"}, "figure_art": "avg_npc_297_1#7$1"}, {"id": 134, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_322_lmlee_1#10$1", "focus": "m"}}, {"id": 135, "prop": "name", "attributes": {"content": "我要說真是碰巧，司歲台願意相信嗎......", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#10$1"}, {"id": 136, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_297_1#6$1", "focus": "m"}}, {"id": 137, "prop": "name", "attributes": {"content": "事關重大，勿要戲言。", "name": "左樂"}, "figure_art": "avg_npc_297_1#6$1"}, {"id": 138, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_322_lmlee_1#6$1", "focus": "m"}}, {"id": 139, "prop": "name", "attributes": {"content": "哎，平生最怕麻煩，但麻煩偏偏總是主動找上我。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#6$1"}, {"id": 140, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_322_lmlee_1#1$1", "focus": "m"}}, {"id": 141, "prop": "name", "attributes": {"content": "非要說的話，托我辦事的那位，也是龍門魏長官的熟人。昨晚在軍營，各位可能已經打過照面了。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 142, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_322_lmlee_1#8$1", "focus": "m"}}, {"id": 143, "prop": "name", "attributes": {"content": "他托我找的，大概就是剛才襲擊公子的那夥人吧。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#8$1"}, {"id": 144, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_297_1#1$1", "focus": "m"}}, {"id": 145, "prop": "name", "attributes": {"content": "關於玉門昨夜的事情，鯉先生還知道些什麼？", "name": "左樂"}, "figure_art": "avg_npc_297_1#1$1"}, {"id": 146, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_322_lmlee_1#1$1", "focus": "m"}}, {"id": 147, "prop": "name", "attributes": {"content": "不多。托私家偵探辦事的人，大部分都有講不出的隱情，我也習慣了。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 148, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_322_lmlee_1#1$1", "focus": "m"}}, {"id": 149, "prop": "name", "attributes": {"content": "如果左公子願意多告訴我一點消息，或許我還能多幫上些忙。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 150, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_297_1#7$1", "focus": "m"}}, {"id": 151, "prop": "name", "attributes": {"content": "......", "name": "左樂"}, "figure_art": "avg_npc_297_1#7$1"}, {"id": 152, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_297_1#1$1", "focus": "m"}}, {"id": 153, "prop": "name", "attributes": {"content": "昨夜亂戰中，我傷到了那刺客一刀，我本想以此為線索從醫館開始調查。", "name": "左樂"}, "figure_art": "avg_npc_297_1#1$1"}, {"id": 154, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_297_1#1$1", "focus": "m"}}, {"id": 155, "prop": "name", "attributes": {"content": "我幾乎查遍了城裡的醫館，都沒有發現異樣。唯獨剛才的那家，一個自稱醫館夥計的男人對我百般阻撓，堅決不放我進去。", "name": "左樂"}, "figure_art": "avg_npc_297_1#1$1"}, {"id": 156, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_297_1#1$1", "focus": "m"}}, {"id": 157, "prop": "name", "attributes": {"content": "我闖入之後，在屋內發現了紗布和血跡。那個男人神色慌張，匆匆跑走了。", "name": "左樂"}, "figure_art": "avg_npc_297_1#1$1"}, {"id": 158, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_322_lmlee_1#4$1", "focus": "m"}}, {"id": 159, "prop": "name", "attributes": {"content": "在這玉門城中，還有人敢阻撓司歲台查案......？", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#4$1"}, {"id": 160, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_297_1#7$1", "focus": "m"}}, {"id": 161, "prop": "name", "attributes": {"content": "我也十分懷疑。雖然故意妨礙調查就足以構成罪名，但那人說話做事顛三倒四，也不像有預謀的樣子。", "name": "左樂"}, "figure_art": "avg_npc_297_1#7$1"}, {"id": 162, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_322_lmlee_1#4$1", "focus": "m"}}, {"id": 163, "prop": "name", "attributes": {"content": "左公子，是否方便把那人外貌說得再詳細些？", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#4$1"}, {"id": 164, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_297_1#7$1", "focus": "m"}}, {"id": 165, "prop": "name", "attributes": {"content": "那怪人樣貌......", "name": "左樂"}, "figure_art": "avg_npc_297_1#7$1"}, {"id": 166, "prop": "dialog", "attributes": {}}, {"id": 167, "prop": "PlaySound", "attributes": {"key": "$flashback", "volume": 0.4}}, {"id": 168, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 169, "prop": "Blocker", "attributes": {"a": 0.7, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 170, "prop": "cameraEffect", "attributes": {"effect": "Grayscale", "keep": "true", "amount": 0.7, "fadetime": 0.0}}, {"id": 171, "prop": "Background", "attributes": {"image": "35_g13_yanlivingroom", "screenadapt": "coverall"}}, {"id": 172, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_785_1#1$1", "focus": "m"}}, {"id": 173, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 174, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 175, "prop": "Dialog", "attributes": {}}, {"id": 176, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 177, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 178, "prop": "cameraEffect", "attributes": {"effect": "Grayscale", "keep": "true", "amount": 0.0, "fadetime": 0.0}}, {"id": 179, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 180, "prop": "Background", "attributes": {"image": "35_g10_yumenfair", "screenadapt": "coverall"}}, {"id": 181, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_297_1#1$1", "focus": "m"}}, {"id": 182, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 183, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 184, "prop": "name", "attributes": {"content": "是位菲林男性，年紀大概在四五十歲左右，身形健壯，而且......武功奇高。", "name": "左樂"}, "figure_art": "avg_npc_297_1#1$1"}, {"id": 185, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_322_lmlee_1#4$1", "focus": "m"}}, {"id": 186, "prop": "name", "attributes": {"content": "......", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#4$1"}, {"id": 187, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_322_lmlee_1#4$1", "focus": "m"}}, {"id": 188, "prop": "name", "attributes": {"content": "當真是他......？", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#4$1"}, {"id": 189, "prop": "Dialog", "attributes": {}}, {"id": 190, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 191, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 192, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 193, "prop": "charslot", "attributes": {}}, {"id": 194, "prop": "Background", "attributes": {"image": "35_g1_yumenstreet_d", "screenadapt": "coverall"}}, {"id": 195, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 196, "prop": "PlayMusic", "attributes": {"intro": "$m_dia_street_intro", "key": "$m_dia_street_loop", "volume": 0.4}}, {"id": 197, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 198, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 199, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#1$1", "duration": 0.7}}, {"id": 200, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#1$1", "duration": 0.7}}, {"id": 201, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 202, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#1$1", "focus": "l"}}, {"id": 203, "prop": "name", "attributes": {"content": "雨霞姐讓我們探訪死去鏢客的家屬，得抓緊點才行。", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#1$1"}, {"id": 204, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#1$1", "focus": "r"}}, {"id": 205, "prop": "name", "attributes": {"content": "在走了，不是就差最後一家了嘛。", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 206, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#1$1", "focus": "l"}}, {"id": 207, "prop": "name", "attributes": {"content": "杜小姐，還沒有來得及問你，你為什麼會來到玉門？", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#1$1"}, {"id": 208, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#1$1", "focus": "r"}}, {"id": 209, "prop": "name", "attributes": {"content": "之前不是跟你說過了，來玉門，創立自己的物流公司。", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 210, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#1$1", "focus": "l"}}, {"id": 211, "prop": "name", "attributes": {"content": "鄭前輩和我說起他的女兒也來了玉門，但我沒想到真會碰見你。", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#1$1"}, {"id": 212, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#2$1", "focus": "r"}}, {"id": 213, "prop": "name", "attributes": {"content": "緣分嘛。", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#2$1"}, {"id": 214, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#2$1", "focus": "r"}}, {"id": 215, "prop": "name", "attributes": {"content": "說起來，既然我們已經開始合作查案了，那你之後加入行裕物流，是不是就順理成章了？", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#2$1"}, {"id": 216, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#7$1", "focus": "l"}}, {"id": 217, "prop": "name", "attributes": {"content": "你還在惦記這件事啊......", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#7$1"}, {"id": 218, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#5$1", "focus": "l"}}, {"id": 219, "prop": "name", "attributes": {"content": "還有雨霞姐......這次的事，還真是牽扯了不少熟人進來。", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#5$1"}, {"id": 220, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#1$1", "focus": "r"}}, {"id": 221, "prop": "name", "attributes": {"content": "那位官差大小姐，原來就是鼠王的女兒。", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 222, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#7$1", "focus": "l"}}, {"id": 223, "prop": "name", "attributes": {"content": "你也認識林先生？", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#7$1"}, {"id": 224, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#1$1", "focus": "r"}}, {"id": 225, "prop": "name", "attributes": {"content": "不算認識。爹早年走南闖北，聽說過鼠王的名聲。", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 226, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#1$1", "focus": "r"}}, {"id": 227, "prop": "name", "attributes": {"content": "我還以為你們都是龍門人，應該很熟來著。", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 228, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#1$1", "focus": "l"}}, {"id": 229, "prop": "name", "attributes": {"content": "龍門可不是什麼小城鎮啊......", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#1$1"}, {"id": 230, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#4$1", "focus": "l"}}, {"id": 231, "prop": "name", "attributes": {"content": "因為事務所的工作，我偶爾會見到林先生，但對雨霞姐，更多只是聽說吧。", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#4$1"}, {"id": 232, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#1$1", "focus": "r"}}, {"id": 233, "prop": "name", "attributes": {"content": "我還是很好奇，對於龍門人來說，鼠王到底是什麼樣的人？", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 234, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#1$1", "focus": "l"}}, {"id": 235, "prop": "name", "attributes": {"content": "“龍門人”這個說法也太廣泛了點。", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#1$1"}, {"id": 236, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#9$1", "focus": "l"}}, {"id": 237, "prop": "name", "attributes": {"content": "有些人眼裡他是保護傘，有些人眼裡他是招惹不起的大人物，還有人只是把他當作一個和藹的老人家。", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#9$1"}, {"id": 238, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#4$1", "focus": "l"}}, {"id": 239, "prop": "name", "attributes": {"content": "但可以確認的一點是，龍門的安定離不開他。", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#4$1"}, {"id": 240, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#7$1", "focus": "r"}}, {"id": 241, "prop": "name", "attributes": {"content": "聽起來還真是位厲害角色......有這麼一個爹，估計林小姐的生活也很麻煩吧。", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#7$1"}, {"id": 242, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#7$1", "focus": "l"}}, {"id": 243, "prop": "name", "attributes": {"content": "為什麼這麼說？", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#7$1"}, {"id": 244, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#6$1", "focus": "r"}}, {"id": 245, "prop": "name", "attributes": {"content": "這世上當爹的全都一個樣，都想讓孩子老老實實按自己鋪好的路走。", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#6$1"}, {"id": 246, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#1$1", "focus": "r"}}, {"id": 247, "prop": "name", "attributes": {"content": "越是有點成就的人，就越會這麼做。", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 248, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#7$1", "focus": "l"}}, {"id": 249, "prop": "name", "attributes": {"content": "難道說杜小姐和鄭前輩關係不好？", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#7$1"}, {"id": 250, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#1$1", "focus": "r"}}, {"id": 251, "prop": "name", "attributes": {"content": "不能說關係不好，應該說，我希望關係別這麼緊密才好。", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 252, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#1$1", "focus": "l"}}, {"id": 253, "prop": "name", "attributes": {"content": "那你能不能想像，還有一種父親，根本不把他的孩子放在心上。", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#1$1"}, {"id": 254, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#10$1", "focus": "l"}}, {"id": 255, "prop": "name", "attributes": {"content": "他永遠按照自己的心情喜好做事，想一齣是一齣，親生的孩子托給別人照顧，不聞不問，一消失就是十幾年。", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#10$1"}, {"id": 256, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#9$1", "focus": "r"}}, {"id": 257, "prop": "name", "attributes": {"content": "你是說......", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#9$1"}, {"id": 258, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#6$1", "focus": "l"}}, {"id": 259, "prop": "name", "attributes": {"content": "算了，我現在也不想提他。", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#6$1"}, {"id": 260, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#1$1", "focus": "r"}}, {"id": 261, "prop": "name", "attributes": {"content": "要是鄭老頭消失十幾年，那我正好接手鏢局的一切，按我自己的想法從頭打理。", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 262, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#1$1", "focus": "r"}}, {"id": 263, "prop": "name", "attributes": {"content": "讓他看看，我能做得遠比他要好。", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 264, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#2$1", "focus": "l"}}, {"id": 265, "prop": "name", "attributes": {"content": "可是，如果他根本不願意回來看看你做得有多好呢？", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#2$1"}, {"id": 266, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#1$1", "focus": "r"}}, {"id": 267, "prop": "name", "attributes": {"content": "......", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 268, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#1$1", "focus": "r"}}, {"id": 269, "prop": "name", "attributes": {"content": "唔，就是這裡了。", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 270, "prop": "dialog", "attributes": {}}, {"id": 271, "prop": "PlaySound", "attributes": {"key": "$doorknockquite"}}, {"id": 272, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 273, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#1$1", "focus": "l"}}, {"id": 274, "prop": "name", "attributes": {"content": "請問，有人在嗎？", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#1$1"}, {"id": 275, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#1$1", "focus": "l"}}, {"id": 276, "prop": "name", "attributes": {"content": "打擾了，我們是——", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#1$1"}, {"id": 277, "prop": "dialog", "attributes": {}}, {"id": 278, "prop": "PlaySound", "attributes": {"key": "$dooropenquite"}}, {"id": 279, "prop": "musicvolume", "attributes": {"volume": 0.2, "fadetime": 1.0}}, {"id": 280, "prop": "Dialog", "attributes": {}}, {"id": 281, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 282, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 283, "prop": "Character", "attributes": {}}, {"id": 284, "prop": "charslot", "attributes": {}}, {"id": 285, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 286, "prop": "Background", "attributes": {"image": "35_g13_yanlivingroom", "screenadapt": "coverall"}}, {"id": 287, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 288, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 289, "prop": "musicvolume", "attributes": {"volume": 0.4, "fadetime": 1.0}}, {"id": 290, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#1$1", "focus": "l"}}, {"id": 291, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#7$1", "focus": "l"}}, {"id": 292, "prop": "name", "attributes": {"content": "咦，門沒有鎖，醫館裡也沒有人？", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#7$1"}, {"id": 293, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#1$1", "focus": "r"}}, {"id": 294, "prop": "name", "attributes": {"content": "這就是第四戶人家。", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 295, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#1$1", "focus": "r"}}, {"id": 296, "prop": "name", "attributes": {"content": "犧牲的鏢客是這家醫館醫生的兒子，醫生是本地人，經營這家醫館幾十年了，父子兩人相依為命。", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 297, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#1$1", "focus": "r"}}, {"id": 298, "prop": "name", "attributes": {"content": "信使隊伍犧牲的消息昨天下午就傳回了城裡，醫生應該已經知道了才對......", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 299, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#1$1", "focus": "l"}}, {"id": 300, "prop": "name", "attributes": {"content": "但房間看起來沒有任何異常，物品擺放工整，桌椅也擦得乾乾淨淨，角落的那兩個袋子，應該是剛剛趕集買回來的日用品。", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#1$1"}, {"id": 301, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#1$1", "focus": "l"}}, {"id": 302, "prop": "name", "attributes": {"content": "雖然不知道玉門的風俗什麼樣，但這屋子......看起來就像什麼事都沒有發生一樣。", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#1$1"}, {"id": 303, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_243_waaifu_1#5$1", "focus": "l"}}, {"id": 304, "prop": "name", "attributes": {"content": "作為父親，知道自己的孩子永遠離世，會是什麼反應呢......", "name": "槐琥"}, "figure_art": "avg_243_waaifu_1#5$1"}, {"id": 305, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_296_1#3$1", "focus": "r"}}, {"id": 306, "prop": "name", "attributes": {"content": "......", "name": "杜遙夜"}, "figure_art": "avg_npc_296_1#3$1"}, {"id": 307, "prop": "dialog", "attributes": {}}, {"id": 308, "prop": "PlaySound", "attributes": {"key": "$flashback", "volume": 0.4}}, {"id": 309, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 310, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 31