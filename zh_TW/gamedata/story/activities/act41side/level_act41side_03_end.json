utes": {"time": 1.0}}, {"id": 40, "prop": "name", "attributes": {"content": "小心！馱獸受驚了！快躲開！", "name": "車夫的聲音"}}, {"id": 41, "prop": "Dialog", "attributes": {}}, {"id": 42, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_240", "focus": "m"}}, {"id": 43, "prop": "delay", "attributes": {"time": 0.2}}, {"id": 44, "prop": "PlaySound", "attributes": {"key": "$d_avg_pcknmrn", "volume": 0.6}}, {"id": 45, "prop": "PlaySound", "attributes": {"key": "$d_avg_carriage_loop", "volume": 1.0, "loop": "true", "channel": "ca"}}, {"id": 46, "prop": "StopSound", "attributes": {"channel": "ca", "fadetime": 4.0}}, {"id": 47, "prop": "CameraShake", "attributes": {"duration": 3.5, "xstrength": 40.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 48, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 49, "prop": "PlaySound", "attributes": {"key": "$d_avg_doorbreak", "volume": 0.8}}, {"id": 50, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown1", "volume": 1.0, "delay": 0.3}}, {"id": 51, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 52, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 53, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 54, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 55, "prop": "charslot", "attributes": {"duration": 0.5}}, {"id": 56, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.7, "block": "true"}}, {"id": 57, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 58, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1686_1#1$1", "focus": "m"}}, {"id": 59, "prop": "name", "attributes": {"content": "趕車的，你瘋了嗎？差點撞死我！給我停下來！", "name": "陰沉的居民"}, "figure_art": "avg_npc_1686_1#1$1"}, {"id": 60, "prop": "Dialog", "attributes": {}}, {"id": 61, "prop": "charslot", "attributes": {}}, {"id": 62, "prop": "PlaySound", "attributes": {"key": "$d_avg_pcknmrn", "channel": "step1", "loop": "false", "volume": 0.4}}, {"id": 63, "prop": "PlaySound", "attributes": {"key": "$d_avg_carriagegoaway", "channel": "step2", "loop": "false", "volume": 1.0, "delay": 0.2}}, {"id": 64, "prop": "stopsound", "attributes": {"channel": "step1", "fadetime": 4.0}}, {"id": 65, "prop": "stopsound", "attributes": {"channel": "step2", "fadetime": 4.0}}, {"id": 66, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 67, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1686_1#1$1", "focus": "m"}}, {"id": 68, "prop": "name", "attributes": {"content": "竟然就這樣跑了？！", "name": "陰沉的居民"}, "figure_art": "avg_npc_1686_1#1$1"}, {"id": 69, "prop": "Dialog", "attributes": {}}, {"id": 70, "prop": "charslot", "attributes": {}}, {"id": 71, "prop": "name", "attributes": {"content": "羅里先生，我……", "name": "提奧"}}, {"id": 72, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1686_1#1$1", "focus": "m"}}, {"id": 73, "prop": "name", "attributes": {"content": "哈，哈哈，真是惡有惡報，被撞的竟然是你？", "name": "陰沉的居民"}, "figure_art": "avg_npc_1686_1#1$1"}, {"id": 74, "prop": "name", "attributes": {"content": "走，小子，現在你哪裡也去不了了，跟我去見深池的人，我要把你這個叛徒交給他們，這樣我就有馬鈴薯可以——", "name": "陰沉的居民"}, "figure_art": "avg_npc_1686_1#1$1"}, {"id": 75, "prop": "name", "attributes": {"content": "不對，不能走大路！萬一這個間諜被其他人搶走……", "name": "陰沉的居民"}, "figure_art": "avg_npc_1686_1#1$1"}, {"id": 76, "prop": "Dialog", "attributes": {}}, {"id": 77, "prop": "charslot", "attributes": {}}, {"id": 78, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovement", "volume": 0.7}}, {"id": 79, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 25.0, "ystrength": 25.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 80, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 81, "prop": "name", "attributes": {"content": "男人一把提起男孩的領子，不顧男孩痛苦的呻吟，拖著他走向平日無人經過的小巷深處。"}}, {"id": 82, "prop": "Dialog", "attributes": {}}, {"id": 83, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 84, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 85, "prop": "charslot", "attributes": {}}, {"id": 86, "prop": "Background", "attributes": {"image": "59_g1_citystreets_d", "screenadapt": "coverall", "block": "true"}}, {"id": 87, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1686_1#1$1", "focus": "m"}}, {"id": 88, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 89, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 90, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 91, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1686_1#1$1", "focus": "m"}}, {"id": 92, "prop": "name", "attributes": {"content": "真是奇怪，為什麼還是走不出去？難道我記錯路了？", "name": "陰沉的居民"}, "figure_art": "avg_npc_1686_1#1$1"}, {"id": 93, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1686_1#1$1", "focus": "n"}}, {"id": 94, "prop": "name", "attributes": {"content": "別搶！把馬鈴薯還給我！你自己去糧店買，你看那裡還有剩下的……", "name": "遙遠的爭吵聲"}}, {"id": 95, "prop": "name", "attributes": {"content": "還給我！！", "name": "遙遠的爭吵聲"}}, {"id": 96, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1686_1#1$1", "focus": "m"}}, {"id": 97, "prop": "name", "attributes": {"content": "還有剩下的？！", "name": "陰沉的居民"}, "figure_art": "avg_npc_1686_1#1$1"}, {"id": 98, "prop": "Dialog", "attributes": {}}, {"id": 99, "prop": "charslot", "attributes": {}}, {"id": 100, "prop": "name", "attributes": {"content": "男人看向聲音傳來的方向，又看了看一條手臂握在自己手裡，幾乎已經不成人形的男孩。"}}, {"id": 101, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1686_1#1$1", "focus": "m"}}, {"id": 102, "prop": "name", "attributes": {"content": "快死了……快死了還能從他嘴裡撬出情報嗎？深池的老爺們還願意給我一口吃的嗎？", "name": "陰沉的居民"}, "figure_art": "avg_npc_1686_1#1$1"}, {"id": 103, "prop": "name", "attributes": {"content": "……叛徒，算你運氣好。", "name": "陰沉的居民"}, "figure_art": "avg_npc_1686_1#1$1"}, {"id": 104, "prop": "Dialog", "attributes": {}}, {"id": 105, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 106, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovementsp", "volume": 1.0}}, {"id": 107, "prop": "CameraShake", "attributes": {"duration": 0.7, "xstrength": 25.0, "ystrength": 25.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 108, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 109, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 0.9}}, {"id": 110, "prop": "charslot", "attributes": {"duration": 1.5}}, {"id": 111, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 112, "prop": "name", "attributes": {"content": "男人甩開孩子那反而抓緊了自己袖口的手，快步跑向聲音傳來的方向。"}}, {"id": 113, "prop": "Dialog", "attributes": {}}, {"id": 114, "prop": "charslot", "attributes": {}}, {"id": 115, "prop": "name", "attributes": {"content": "好痛……我的腿……", "name": "提奧"}}, {"id": 116, "prop": "Dialog", "attributes": {}}, {"id": 117, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothtrailground", "volume": 1.0}}, {"id": 118, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 119, "prop": "name", "attributes": {"content": "不行，站不起來……", "name": "提奧"}}, {"id": 120, "prop": "Dialog", "attributes": {}}, {"id": 121, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1696_1#1$1", "duration": 1.0}}, {"id": 122, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 123, "prop": "Dialog", "attributes": {}}, {"id": 124, "prop": "charslot", "attributes": {}}, {"id": 125, "prop": "playMusic", "attributes": {"intro": "$drift_intro", "key": "$drift_loop", "volume": 0.6}}, {"id": 126, "prop": "name", "attributes": {"content": "艾瑪阿姨……", "name": "提奧"}}, {"id": 127, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1696_1#1$1", "focus": "m"}}, {"id": 128, "prop": "name", "attributes": {"content": "……誰叫我？誰？！", "name": "擔憂的居民"}, "figure_art": "avg_npc_1696_1#1$1"}, {"id": 129, "prop": "name", "attributes": {"content": "我已經照你說的做了，我已經做了！不要再來纏著我了——", "name": "擔憂的居民"}, "figure_art": "avg_npc_1696_1#1$1"}, {"id": 130, "prop": "Dialog", "attributes": {}}, {"id": 131, "prop": "charslot", "attributes": {}}, {"id": 132, "prop": "name", "attributes": {"content": "艾瑪……阿姨！", "name": "提奧"}}, {"id": 133, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1696_1#1$1", "focus": "m"}}, {"id": 134, "prop": "name", "attributes": {"content": "提奧？你怎麼了？", "name": "擔憂的居民"}, "figure_art": "avg_npc_1696_1#1$1"}, {"id": 135, "prop": "Dialog", "attributes": {}}, {"id": 136, "prop": "charslot", "attributes": {}}, {"id": 137, "prop": "name", "attributes": {"content": "我被馱獸車撞到了，然後又被人丟到了這裡。", "name": "提奧"}}, {"id": 138, "prop": "name", "attributes": {"content": "我不是維多利亞人的間諜，艾瑪阿姨。求你救救我，帶我去找庫林先生，好嗎？", "name": "提奧"}}, {"id": 139, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1696_1#1$1", "focus": "m"}}, {"id": 140, "prop": "name", "attributes": {"content": "維多利亞人……間諜？", "name": "擔憂的居民"}, "figure_art": "avg_npc_1696_1#1$1"}, {"id": 141, "prop": "name", "attributes": {"content": "原來這麼快啊……", "name": "擔憂的居民"}, "figure_art": "avg_npc_1696_1#1$1"}, {"id": 142, "prop": "Dialog", "attributes": {}}, {"id": 143, "prop": "charslot", "attributes": {}}, {"id": 144, "prop": "name", "attributes": {"content": "艾瑪阿姨，我好痛，真的好痛。", "name": "提奧"}}, {"id": 145, "prop": "name", "attributes": {"content": "我知道維多利亞人害了大家，大家都不喜歡我，沒人願意聽我說話，更沒人願意碰我。", "name": "提奧"}}, {"id": 146, "prop": "name", "attributes": {"content": "可是能不能……至少把庫林先生叫過來，我好痛，而且好冷……", "name": "提奧"}}, {"id": 147, "prop": "name", "attributes": {"content": "艾瑪阿姨，等我長大了，我會去找維多利亞人報仇的，我會去幫尼亞爾叔叔……報仇的。", "name": "提奧"}}, {"id": 148, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1696_1#1$1", "focus": "m"}}, {"id": 149, "prop": "name", "attributes": {"content": "（深呼吸）", "name": "擔憂的居民"}, "figure_art": "avg_npc_1696_1#1$1"}, {"id": 150, "prop": "name", "attributes": {"content": "提奧，如果死的只有尼亞爾，也許我會幫你。", "name": "擔憂的居民"}, "figure_art": "avg_npc_1696_1#1$1"}, {"id": 151, "prop": "Dialog", "attributes": {}}, {"id": 152, "prop": "charslot", "attributes": {}}, {"id": 153, "prop": "name", "attributes": {"content": "艾瑪……阿姨？", "name": "提奧"}}, {"id": 154, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1696_1#1$1", "focus": "m"}}, {"id": 155, "prop": "name", "attributes": {"content": "你只知道尼亞爾死在戰爭裡，可是還有更多人，他們沒上戰場，也死掉了。", "name": "擔憂的居民"}, "figure_art": "avg_npc_1696_1#1$1"}, {"id": 156, "prop": "name", "attributes": {"content": "因為你們維多利亞人封鎖了商路，直到現在還在封鎖，所有人都在挨餓，包括我，包括……", "name": "擔憂的居民"}, "figure_art": "avg_npc_1696_1#1$1"}, {"id": 157, "prop": "name", "attributes": {"content": "尼亞爾留給我的……我肚子裡的孩子。", "name": "擔憂的居民"}, "figure_art": "avg_npc_1696_1#1$1"}, {"id": 158, "prop": "name", "attributes": {"content": "他也餓死了，被你們維多利亞人活活餓死了。", "name": "擔憂的居民"}, "figure_art": "avg_npc_1696_1#1$1"}, {"id": 159, "prop": "name", "attributes": {"content": "所以，找其他人去幫你叫庫林吧。他們不像我，他們都是好人……", "name": "擔憂的居民"}, "figure_art": "avg_npc_1696_1#1$1"}, {"id": 160, "prop": "name", "attributes": {"content": "……很好很好的好人。", "name": "擔憂的居民"}, "figure_art": "avg_npc_1696_1#1$1"}, {"id": 161, "prop": "Dialog", "attributes": {}}, {"id": 162, "prop": "musicvolume", "attributes": {"volume": 0.2, "fadetime": 1.5}}, {"id": 163, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 164, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 165, "prop": "charslot", "attributes": {}}, {"id": 166, "prop": "Background", "attributes": {"image": "bg_oldwarehouse_d", "screenadapt": "coverall", "block": "true"}}, {"id": 167, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "amount": 0.0, "keep": "true"}}, {"id": 168, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#2$1", "focus": "m"}}, {"id": 169, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 170, "prop": "PlaySound", "attributes": {"key": "$d_avg_woodcracle", "volume": 0.8, "loop": "true", "channel": "a"}}, {"id": 171, "prop": "musicvolume", "attributes": {"volume": 0.6, "fadetime": 2.0}}, {"id": 172, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 173, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 174, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#2$1", "focus": "m"}}, {"id": 175, "prop": "name", "attributes": {"content": "艾瑪，竟然是艾瑪……", "name": "庫林"}, "figure_art": "avg_npc_1697_1#2$1"}, {"id": 176, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#7$1", "focus": "m"}}, {"id": 177, "prop": "name", "attributes": {"content": "為什麼她會變成這樣？", "name": "庫林"}, "figure_art": "avg_npc_1697_1#7$1"}, {"id": 178, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4177_brigid_1#6$1", "focus": "m"}}, {"id": 179, "prop": "name", "attributes": {"content": "庫林，我不是想幫她辯解，但那天經過那裡的人，肯定不只她一個。", "name": "布莉吉"}, "figure_art": "avg_4177_brigid_1#6$1"}, {"id": 180, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#8$1", "focus": "m"}}, {"id": 181, "prop": "name", "attributes": {"content": "是啊，不只她一個……", "name": "庫林"}, "figure_art": "avg_npc_1697_1#8$1"}, {"id": 182, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4177_brigid_1#11$1", "focus": "m"}}, {"id": 183, "prop": "name", "attributes": {"content": "……我是不是說錯話了？", "name": "布莉吉"}, "figure_art": "avg_4177_brigid_1#11$1"}, {"id": 184, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#8$1", "focus": "m"}}, {"id": 185, "prop": "name", "attributes": {"content": "不，你沒說錯。", "name": "庫林"}, "figure_art": "avg_npc_1697_1#8$1"}, {"id": 186, "prop": "name", "attributes": {"content": "你之前還想帶提奧離開，是嗎？你看見什麼了？", "name": "庫林"}, "figure_art": "avg_npc_1697_1#8$1"}, {"id": 187, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4177_brigid_1#11$1", "focus": "m"}}, {"id": 188, "prop": "name", "attributes": {"content": "別人欺負他。不是小孩子之間的打打鬧鬧，是大人。", "name": "布莉吉"}, "figure_art": "avg_4177_brigid_1#11$1"}, {"id": 189, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#2$1", "focus": "m"}}, {"id": 190, "prop": "name", "attributes": {"content": "我在第一次看見提奧被欺負的時候就衝上去了，我以為這樣的事情……不會再發生。", "name": "庫林"}, "figure_art": "avg_npc_1697_1#2$1"}, {"id": 191, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4177_brigid_1#6$1", "focus": "m"}}, {"id": 192, "prop": "name", "attributes": {"content": "實際上……發生過很多次。", "name": "布莉吉"}, "figure_art": "avg_4177_brigid_1#6$1"}, {"id": 193, "prop": "name", "attributes": {"content": "之前我只是一直有種很不好的預感，我覺得提奧不屬於這座城市，納斯爾紗可能容不下他，誰知道……", "name": "布莉吉"}, "figure_art": "avg_4177_brigid_1#6$1"}, {"id": 194, "prop": "name", "attributes": {"content": "……", "name": "布莉吉"}, "figure_art": "avg_4177_brigid_1#6$1"}, {"id": 195, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#8$1", "focus": "m"}}, {"id": 196, "prop": "name", "attributes": {"content": "我知道了，你走吧。", "name": "庫林"}, "figure_art": "avg_npc_1697_1#8$1"}, {"id": 197, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4177_brigid_1#11$1", "focus": "m"}}, {"id": 198, "prop": "name", "attributes": {"content": "庫林？", "name": "布莉吉"}, "figure_art": "avg_4177_brigid_1#11$1"}, {"id": 199, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#8$1", "focus": "m"}}, {"id": 200, "prop": "name", "attributes": {"content": "我說我知道了。", "name": "庫林"}, "figure_art": "avg_npc_1697_1#8$1"}, {"id": 201, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4177_brigid_1#11$1", "focus": "m"}}, {"id": 202, "prop": "name", "attributes": {"content": "你……", "name": "布莉吉"}, "figure_art": "avg_4177_brigid_1#11$1"}, {"id": 203, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#4$1", "focus": "m"}}, {"id": 204, "prop": "name", "attributes": {"content": "我說我知道了！走！現在就走！讓我——", "name": "庫林"}, "figure_art": "avg_npc_1697_1#4$1"}, {"id": 205, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#7$1", "focus": "m"}}, {"id": 206, "prop": "name", "attributes": {"content": "……一個人待著，好嗎？", "name": "庫林"}, "figure_art": "avg_npc_1697_1#7$1"}, {"id": 207, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4177_brigid_1#6$1", "focus": "m"}}, {"id": 208, "prop": "name", "attributes": {"content": "……抱歉。", "name": "布莉吉"}, "figure_art": "avg_4177_brigid_1#6$1"}, {"id": 209, "prop": "Dialog", "attributes": {}}, {"id": 210, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 211, "prop": "PlaySound", "attributes": {"key": "$d_avg_walk_stage", "volume": 1.0, "loop": "false", "channel": "bw"}}, {"id": 212, "prop": "stopsound", "attributes": {"fadetime": 2.0, "channel": "bw"}}, {"id": 213, "prop": "charslot", "attributes": {"duration": 0.7}}, {"id": 214, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 215, "prop": "name", "attributes": {"content": "鐵匠呆呆地站著，靜謐的四周只剩下火焰的劈啪聲。"}}, {"id": 216, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#7$1", "focus": "m"}}, {"id": 217, "prop": "name", "attributes": {"content": "提奧，我……", "name": "庫林"}, "figure_art": "avg_npc_1697_1#7$1"}, {"id": 218, "prop": "Dialog", "attributes": {}}, {"id": 219, "prop": "charslot", "attributes": {}}, {"id": 220, "prop": "name", "attributes": {"content": "他錯過的事情太多，無法理解的事也太多，已經無力去釐清其中的因果與來龍去脈。"}}, {"id": 221, "prop": "name", "attributes": {"content": "他只意識到一件事——自己什麼都沒做到。"}}, {"id": 222, "prop": "Dialog", "attributes": {}}, {"id": 223, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#7$1", "focus": "m"}}, {"id": 224, "prop": "name", "attributes": {"content": "我算什麼英雄？！", "name": "庫林"}, "figure_art": "avg_npc_1697_1#7$1"}, {"id": 225, "prop": "Dialog", "attributes": {}}, {"id": 226, "prop": "charslot", "attributes": {}}, {"id": 227, "prop": "StopSound", "attributes": {"channel": "a", "fadetime": 1.5}}, {"id": 228, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 229, "prop": "name", "attributes": {"content": "是啊，你算什麼英雄？", "name": "？？？"}}, {"id": 230, "prop": "name", "attributes": {"content": "鐵匠環顧四周，工坊內空無一人，唯有巨龍的雕像正用空空如也的眼眶斜睨著他，宛如質疑。"}}, {"id": 231, "prop": "Dialog", "attributes": {}}, {"id": 232, "prop": "playMusic", "attributes": {"intro": "$loneliness_intro", "key": "$loneliness_loop", "volume": 0.6}}, {"id": 233, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 234, "prop": "name", "attributes": {"content": "你算什麼英雄？", "name": "巨龍"}}, {"id": 235, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#11$1", "focus": "m"}}, {"id": 236, "prop": "name", "attributes": {"content": "我算……什麼英雄？", "name": "庫林"}, "figure_art": "avg_npc_1697_1#11$1"}, {"id": 237, "prop": "Dialog", "attributes": {}}, {"id": 238, "prop": "charslot", "attributes": {}}, {"id": 239, "prop": "name", "attributes": {"content": "英雄會放任一個每天面對無數敵意的孩子，在時不時對他口吐惡言的人群中東遊西逛？", "name": "巨龍"}}, {"id": 240, "prop": "name", "attributes": {"content": "英雄會讓糧食在自己鼻子底下運出城，直到城內無糧可吃，還只能向鄰居分發幾顆可憐的馬鈴薯？", "name": "巨龍"}}, {"id": 241, "prop": "name", "attributes": {"content": "英雄會在城內亂成一團時窩在家裡埋頭打鐵，就為了把自己的名字刻在雕像的基座上，滿足那點可憐的虛榮心？", "name": "巨龍"}}, {"id": 242, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#5$1", "focus": "m"}}, {"id": 243, "prop": "name", "attributes": {"content": "什麼？！", "name": "庫林"}, "figure_art": "avg_npc_1697_1#5$1"}, {"id": 244, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#11$1", "focus": "m"}}, {"id": 245, "prop": "name", "attributes": {"content": "我……我絕不是為了什麼虛榮，我是為了……為了能用英雄的名號，去……", "name": "庫林"}, "figure_art": "avg_npc_1697_1#11$1"}, {"id": 246, "prop": "Dialog", "attributes": {}}, {"id": 247, "prop": "charslot", "attributes": {}}, {"id": 248, "prop": "name", "attributes": {"content": "去像你當時對涅梅絲說的那樣，“為那些在戰爭中失去了一切的同胞謀取幸福”？", "name": "巨龍"}}, {"id": 249, "prop": "name", "attributes": {"content": "就像現在？", "name": "巨龍"}}, {"id": 250, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#11$1", "focus": "m"}}, {"id": 251, "prop": "name", "attributes": {"content": "……就像……現在？", "name": "庫林"}, "figure_art": "avg_npc_1697_1#11$1"}, {"id": 252, "prop": "Dialog", "attributes": {}}, {"id": 253, "prop": "charslot", "attributes": {}}, {"id": 254, "prop": "name", "attributes": {"content": "你要保護的弱小已經不在人世。", "name": "巨龍"}}, {"id": 255, "prop": "name", "attributes": {"content": "你要伸張的正義，已經沒入黑暗。", "name": "巨龍"}}, {"id": 256, "prop": "name", "attributes": {"content": "你要為之謀取福利的同胞……艾瑪、羅里，他們真的還是你的同胞嗎？", "name": "巨龍"}}, {"id": 257, "prop": "name", "attributes": {"content": "他們難道不是活在過去的死人嗎？", "name": "巨龍"}}, {"id": 258, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#5$1", "focus": "m"}}, {"id": 259, "prop": "name", "attributes": {"content": "活在過去的……死人？！", "name": "庫林"}, "figure_art": "avg_npc_1697_1#5$1"}, {"id": 260, "prop": "Dialog", "attributes": {}}, {"id": 261, "prop": "charslot", "attributes": {}}, {"id": 262, "prop": "name", "attributes": {"content": "他們甚至不像你，你那顆虛榮的心還夢想著未來，而他們？他們不過是一群活在過去的行屍走肉罷了。", "name": "巨龍"}}, {"id": 263, "prop": "name", "attributes": {"content": "你的同胞是個拿著從火裡搶出來的古董刀四處比劃的可憐人嗎？", "name": "巨龍"}}, {"id": 264, "prop": "name", "attributes": {"content": "或者，為了一個流產的胎兒，就對一個無辜的孩子見死不救的走私犯？", "name": "巨龍"}}, {"id": 265, "prop": "name", "attributes": {"content": "又或者，面對變故，已經只能理解仇恨這一種邏輯的“城裡人”？", "name": "巨龍"}}, {"id": 266, "prop": "name", "attributes": {"content": "現在就抓一個人過來，問問他以後的打算，猜猜看你能聽見什麼？", "name": "巨龍"}}, {"id": 267, "prop": "Dialog", "attributes": {}}, {"id": 268, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#8$1", "focus": "m"}}, {"id": 269, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 270, "prop": "PlaySound", "attributes": {"key": "$d_avg_speardrop", "volume": 1.0}}, {"id": 271, "prop": "CameraShake", "attributes": {"duration": 0.7, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 272, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 273, "prop": "name", "attributes": {"content": "鐵匠從不離手的大錘噹啷一聲落在地上。"}}, {"id": 274, "prop": "name", "attributes": {"content": "他死死盯著巨龍的頭顱。"}}, {"id": 275, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#8$1", "focus": "m"}}, {"id": 276, "prop": "name", "attributes": {"content": "不，不……", "name": "庫林"}, "figure_art": "avg_npc_1697_1#8$1"}, {"id": 277, "prop": "name", "attributes": {"content": "真正把人們困在過去的……難道不是你嗎？", "name": "庫林"}, "figure_art": "avg_npc_1697_1#8$1"}, {"id": 278, "prop": "name", "attributes": {"content": "我收集同胞們生活用的碗盆，點燃同胞們取暖照明用的燃料……就只為了哺育你這個……", "name": "庫林"}, "figure_art": "avg_npc_1697_1#8$1"}, {"id": 279, "prop": "name", "attributes": {"content": "怪物。", "name": "庫林"}, "figure_art": "avg_npc_1697_1#8$1"}, {"id": 280, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#8$1", "focus": "m"}}, {"id": 281, "prop": "multiline", "attributes": {"name": "庫林", "content": "糧食我不知道，但金屬、燃料……"}}, {"id": 282, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#7$1", "focus": "m"}}, {"id": 283, "prop": "multiline", "attributes": {"name": "庫林", "content": "對，是我，我親手把鍋，把碗，把人們的生活餵到你的嘴裡，把你餵成如此巨大……"}}, {"id": 284, "prop": "name", "attributes": {"content": "連我自己的生活也被你吞吃下去，緊接著，就是提奧的生命……", "name": "庫林"}, "figure_art": "avg_npc_1697_1#7$1"}, {"id": 285, "prop": "multiline", "attributes": {"name": "庫林", "content": "提奧，提奧……"}}, {"id": 286, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#8$1", "focus": "m"}}, {"id": 287, "prop": "multiline", "attributes": {"name": "庫林", "content": "對，是我養大了這個怪物，這個怪物又把你的命吞掉！"}}, {"id": 288, "prop": "name", "attributes": {"content": "現在，它又要在夏末節那天站上廣場，張開雙翼，它說整座城的居民都會被它變成只能活在過去的死人……", "name": "庫林"}, "figure_art": "avg_npc_1697_1#8$1"}, {"id": 289, "prop": "Dialog", "attributes": {}}, {"id": 290, "prop": "charslot", "attributes": {}}, {"id": 291, "prop": "name", "attributes": {"content": "……", "name": "巨龍"}}, {"id": 292, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#8$1", "focus": "m"}}, {"id": 293, "prop": "name", "attributes": {"content": "怪物，你說得對。我的確不是英雄。", "name": "庫林"}, "figure_art": "avg_npc_1697_1#8$1"}, {"id": 294, "prop": "name", "attributes": {"content": "我只是個可憐的、虛榮的騙子。過去我騙其他人，現在，我騙的是自己。", "name": "庫林"}, "figure_art": "avg_npc_1697_1#8$1"}, {"id": 295, "prop": "name", "attributes": {"content": "但人們需要我。", "name": "庫林"}, "figure_art": "avg_npc_1697_1#8$1"}, {"id": 296, "prop": "Dialog", "attributes": {}}, {"id": 297, "prop": "charslot", "attributes": {}}, {"id": 298, "prop": "name", "attributes": {"content": "需要你？", "name": "巨龍"}}, {"id": 299, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#8$1", "focus": "m"}}, {"id": 300, "prop": "name", "attributes": {"content": "他們需要一個英雄，去叫醒他們，告訴他們，戰爭已經結束了，現在重要的是明天，是未來，是即將開始的生活。", "name": "庫林"}, "figure_art": "avg_npc_1697_1#8$1"}, {"id": 301, "prop": "Dialog", "attributes": {}}, {"id": 302, "prop": "charslot", "attributes": {}}, {"id": 303, "prop": "name", "attributes": {"content": "就憑你？", "name": "巨龍"}}, {"id": 304, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#2$1", "focus": "m"}}, {"id": 305, "prop": "name", "attributes": {"content": "就憑我。", "name": "庫林"}, "figure_art": "avg_npc_1697_1#2$1"}, {"id": 306, "prop": "Dialog", "attributes": {}}, {"id": 307, "prop": "charslot", "attributes": {"duration": 0.7}}, {"id": 308, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 309, "prop": "name", "attributes": {"content": "鐵匠決絕地自爐膛邊離開。他拿了一條最粗大、最堅固的鐵索，又拖著鐵索，回到巨龍那仍然斜睨著他的頭顱下方。"}}, {"id": 310, "prop": "Dialog", "attributes": {}}, {"id": 311, "prop": "PlaySound", "attributes": {"key": "$d_avg_ironchaindrop", "volume": 1.0}}, {"id": 312, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#8$1", "focus": "m"}}, {"id": 313, "prop": "name", "attributes": {"content": "跟我走。", "name": "庫林"}, "figure_art": "avg_npc_1697_1#8$1"}, {"id": 314, "prop": "Dialog", "attributes": {}}, {"id": 315, "prop": "charslot", "attributes": {}}, {"id": 316, "prop": "name", "attributes": {"content": "去哪裡？", "name": "巨龍"}}, {"id": 317, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#8$1", "focus": "m"}}, {"id": 318, "prop": "name", "attributes": {"content": "廣場。", "name": "庫林"}, "figure_art": "avg_npc_1697_1#8$1"}, {"id": 319, "prop": "Dialog", "attributes": {}}, {"id": 320, "prop": "charslot", "attributes": {}}, {"id": 321, "prop": "name", "attributes": {"content": "今天並不是夏末節。", "name": "巨龍"}}, {"id": 322, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#8$1", "focus": "m"}}, {"id": 323, "prop": "name", "attributes": {"content": "我不能再等了，再等下去，你那些不祥的預言只會成真。", "name": "庫林"}, "figure_art": "avg_npc_1697_1#8$1"}, {"id": 324, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#2$1", "focus": "m"}}, {"id": 325, "prop": "name", "attributes": {"content": "跟我走……", "name": "庫林"}, "figure_art": "avg_npc_1697_1#2$1"}, {"id": 326, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1697_1#8$1", "focus": "m"}}, {"id": 327, "prop": "name", "attributes": {"content": "然後，我會將你拆掉……", "name": "庫林"}, "figure_art": "avg_npc_1697_1#8$1"}, {"id": 328, "prop": "name", "attributes": {"content": "我會讓你把生活還給所有人。", "name": "庫林"}, "figure_art": "avg_npc_1697_1#8$1"}, {"id": 329, "prop": "Dialog", "attributes": {}}, {"id": 330, "prop": "charslot", "attributes": {}}, {"id": 331, "prop": "name", "attributes": {"content": "巨龍紋絲不動，但鐵匠分明看到，那頭顱向著他低了低，既像輕蔑，又像邀請。"}}, {"id": 332, "prop": "Dialog", "attributes": {}}, {"id": 333, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 334, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 335, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 336, "prop": "charslot", "attributes": {}}, {"id": 337, "prop": "Background", "attributes": {"image": "59_g10_indoor", "screenadapt": "coverall", "block": "true"}}, {"id": 338, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 339, "prop": "PlayMusic", "attributes": {"intro": "$loading_intro", "key": "$loading_loop", "volume": 0.6}}, {"id": 340, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 341, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 342, "prop": "PlaySound", "attributes": {"key": "$doorknockquite", "volume": 1.0}}, {"id": 343, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 344, "prop": "PlaySound", "attributes": {"key": "$dooropenquite", "volume": 1.0}}, {"id": 345, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 346, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4177_brigid_1#6$1", "duration": 0.7}}, {"id": 347, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 348, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4177_brigid_1#6$1", "focus": "m"}}, {"id": 349, "prop": "name", "attributes": {"content": "葦草、涅梅絲，我回來了。庫林的狀態很不好，也許你們應該過去看看他。", "name": "布莉吉"}, "figure_art": "avg_4177_brigid_1#6$1"}, {"id": 350, "prop": "name", "attributes": {"content": "你們那邊的情況呢？城裡人怎麼樣了？", "name": "布莉吉"}, "figure_art": "avg_4177_brigid_1#6$1"}, {"id": 351, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1694_1#1$1", "focus": "m"}}, {"id": 352, "prop": "name", "attributes": {"content": "人們仍然在抓間諜……維多利亞間諜。", "name": "拉芙希妮"}, "figure_art": "avg_npc_1694_1#1$1"}, {"id": 353, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4177_brigid_1#4$1", "focus": "m"}}, {"id": 354, "prop": "name", "attributes": {"content": "他們瘋了！說到底，塔拉人、維多利亞人，不都是人嗎？戰爭已經結束了，我們難道還要這樣繼續拚個你死我活嗎？", "name": "布莉吉"}, "figure_art": "avg_4177_brigid_1#4$1"}, {"id": 355, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4177_brigid_1#7$1", "focus": "m"}}, {"id": 356, "prop": "name", "attributes": {"content": "涅梅絲，去解釋給人們聽，讓他們吃不到飯的深池已經被紅龍懲治了，糧食也——", "name": "布莉吉"}, "figure_art": "avg_4177_brigid_1#7$1"}, {"id": 357, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1692_1#7$1", "focus": "m"}}, {"id": 358, "prop": "name", "attributes": {"content": "布莉吉，別再說深池這個詞，一次也別說。這是領袖的命令。", "name": "涅梅絲"}, "figure_art": "avg_npc_1692_1#7$1"}, {"id": 359, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1692_1#6$1", "focus": "m"}}, {"id": 360, "prop": "name", "attributes": {"content": "而且……說到底，糧食的事，我也只是在慶功會上聽見他們竊竊私語罷了，沒有證明，沒有審判。", "name": "涅梅絲"}, "figure_art": "avg_npc_1692_1#6$1"}, {"id": 361, "prop": "name", "attributes": {"content": "甚至連糧食到底是怎麼回來的，我都一無所知。", "name": "涅梅絲"}, "figure_art": "avg_npc_1692_1#6$1"}, {"id": 362, "prop": "name", "attributes": {"content": "更別說深——那些人不在了的消息，現在根本就沒傳到人們的耳裡……我到底該怎麼解釋？", "name": "涅梅絲"}, "figure_art": "avg_npc_1692_1#6$1"}, {"id": 363, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4177_brigid_1#6$1", "focus": "m"}}, {"id": 364, "prop": "name", "attributes": {"content": "……", "name": "布莉吉"}, "figure_art": "avg_4177_brigid_1#6$1"}, {"id": 365, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1694_1#1$1", "focus": "m"}}, {"id": 366, "prop": "name", "attributes": {"content": "如果道理講不通，就只能硬來了。", "name": "拉芙希妮"}, "figure_art": "avg_npc_1694_1#1$1"}, {"id": 367, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1692_1#10$1", "focus": "m"}}, {"id": 368, "prop": "name", "attributes": {"content": "您是說？", "name": "涅梅絲"}, "figure_art": "avg_npc_1692_1#10$1"}, {"id": 369, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1694_1#1$1", "focus": "m"}}, {"id": 370, "prop": "name", "attributes": {"content": "我回到這裡，原本抱著再也不當影子的打算。", "name": "拉芙希妮"}, "figure_art": "avg_npc_1694_1#1$1"}, {"id": 371, "prop": "name", "attributes": {"content": "但到了現在這個地步，如果真正的領袖始終不願露面承擔責任，我就必須出面，至少暫時安撫混亂的人心。", "name": "拉芙希妮"}, "figure_art": "avg_npc_1694_1#1$1"}, {"id": 372, "prop": "name", "attributes": {"content": "對了，那位庫林先生呢？他畢竟是公認的英雄，如果他能幫我們一把，事情就能順利許多。", "name": "拉芙希妮"}, "figure_art": "avg_npc_1694_1#1$1"}, {"id": 373, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1692_1#8$1", "focus": "m"}}, {"id": 374, "prop": "name", "attributes": {"content": "他應該就在自己的工坊，我來帶路。", "name": "涅梅絲"}, "figure_art": "avg_npc_1692_1#8$1"}, {"id": 375, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1692_1#7$1", "focus": "m"}}, {"id": 376, "prop": "name", "attributes": {"content": "布莉吉，你趁現在快點出城。", "name": "涅梅絲"}, "figure_art": "avg_npc_1692_1#7$1"}, {"id": 377, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4177_brigid_1#11$1", "focus": "m"}}, {"id": 378, "prop": "name", "attributes": {"content": "為什麼？", "name": "布莉吉"}, "figure_art": "avg_4177_brigid_1#11$1"}, {"id": 379, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1692_1#6$1", "focus": "m"}}, {"id": 380, "prop": "name", "attributes": {"content": "你……如果我們和庫林都無法成功，你和人群之間……", "name": "涅梅絲"}, "figure_art": "avg_npc_1692_1#6$1"}, {"id": 381, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4177_brigid_1#10$1", "focus": "m"}}, {"id": 382, "prop": "name", "attributes": {"content": "我懂了，因為城裡的人不喜歡我，我可能會礙事，對吧？", "name": "布莉吉"}, "figure_art": "avg_4177_brigid_1#10$1"}, {"id": 383, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1692_1#6$1", "focus": "m"}}, {"id": 384, "prop": "name", "attributes": {"content": "抱歉，布莉吉，我不是說你礙事的意思——", "name": "涅梅絲"}, "figure_art": "avg_npc_1692_1#6$1"}, {"id": 385, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4177_brigid_1#10$1", "focus": "m"}}, {"id": 386, "prop": "name", "attributes": {"content": "但你說得對，我就是會礙事啊。", "name": "布莉吉"}, "figure_art": "avg_4177_brigid_1#10$1"}, {"id": 387, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4177_brigid_1#9$1", "focus": "m"}}, {"id": 388, "prop": "name", "attributes": {"content": "別擔心，我現在就走，去黑林碰碰運氣。也許它現在就願意放行了呢。", "name": "布莉吉"}, "figure_art": "avg_4177_brigid_1#9$1"}, {"id": 389, "prop": "Dialog", "attributes": {}}, {"id": 390, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 391, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 392, "prop": "charslot", "attributes": {}}, {"id": 393, "prop": "Background", "attributes": {"image": "59_g1_citystreets_d", "screenadapt": "coverall", "block": "true"}}, {"id": 394, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 395, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 396, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 397, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 0.9}}, {"id": 398, "prop": "name", "attributes": {"content": "庫林！", "name": "涅梅絲"}}, {"id": 399, "prop": "name", "attributes": {"content": "庫林……", "name": "涅梅絲"}}, {"id": 400, "prop": "name", "attributes": {"content": "他不在嗎？", "name": "拉芙希妮"}}, {"id": 401, "prop": "name", "attributes": {"content": "他……", "name": "涅梅絲"}}, {"id": 402, "prop": "Dialog", "attributes": {}}, {"id": 403, "prop": "PlaySound", "attributes": {"key": "$d_avg_runstop", "volume": 1.0}}, {"id": 404, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1694_1#6$1", "duration": 0.5}}, {"id": 405, "prop": "delay", "attributes": {"time": 0.7}}, {"id": 406, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1694_1#6$1", "focus": "m"}}, {"id": 407, "prop": "name", "attributes": {"content": "這是？！", "name": "拉芙希妮"}, "figure_art": "avg_npc_1694_1#6$1"}, {"id": 408, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1692_1#5$1", "focus": "m"}}, {"id": 409, "prop": "name", "attributes": {"content": "……", "name": "涅梅絲"}, "figure_art": "avg_npc_1692_1#5$1"}, {"id": 410, "prop": "Dialog", "attributes": {}}, {"id": 411, "prop": "charslot", "attributes": {}}, {"id": 412, "prop": "name", "attributes": {"content": "兩人瞠目結舌。"}}, {"id": 413, "prop": "name", "attributes": {"content": "工坊的門……"}}, {"id": 414, "prop": "name", "attributes": {"content": "不，工坊正對著她們的那面牆，已經不在了。"}}, {"id": 415, "prop": "name", "attributes": {"content": "那面本該在雕像完工時才拆掉的牆此時已經化為一堆瓦礫，而那些瓦礫掩蓋不住的，是一道通向廣場方向的拖痕。"}}, {"id": 416, "prop": "name", "attributes": {"content": "一道寬如道路的，長長的拖痕。"}}, {"id": 417, "prop": "Dialog", "attributes": {}}, {"id": 418, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 419, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 420, "prop": "charslot", "attributes": {}}, {"id": 421, "prop": "Image", "attributes": {}}, {"id": 422, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}