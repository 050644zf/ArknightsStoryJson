e": "涅梅絲"}, "figure_art": "avg_npc_1692_1#10$1"}, {"id": 330, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1687_1#1$1", "focus": "m"}}, {"id": 331, "prop": "name", "attributes": {"content": "……我？我還好，就是太餓了。怎麼了？你剛才說什麼？", "name": "沉默的居民"}, "figure_art": "avg_npc_1687_1#1$1"}, {"id": 332, "prop": "Dialog", "attributes": {}}, {"id": 333, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 334, "prop": "charslot", "attributes": {}}, {"id": 335, "prop": "Background", "attributes": {"image": "59_g1_citystreets_d", "screenadapt": "showall"}}, {"id": 336, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 337, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "style": "slider", "inverse": "true", "fadetime": 1.0, "block": "true"}}, {"id": 338, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 339, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1689_1#1$1", "focus": "m"}}, {"id": 340, "prop": "name", "attributes": {"content": "你來得剛好！涅梅絲，提奧那個小子最近沒有什麼可疑的舉動吧？", "name": "憤怒的居民"}, "figure_art": "avg_npc_1689_1#1$1"}, {"id": 341, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1692_1#6$1", "focus": "m"}}, {"id": 342, "prop": "name", "attributes": {"content": "……沒有，他還忙不過來呢。", "name": "涅梅絲"}, "figure_art": "avg_npc_1692_1#6$1"}, {"id": 343, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1689_1#1$1", "focus": "m"}}, {"id": 344, "prop": "name", "attributes": {"content": "哼，他最好是。", "name": "憤怒的居民"}, "figure_art": "avg_npc_1689_1#1$1"}, {"id": 345, "prop": "Dialog", "attributes": {}}, {"id": 346, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 347, "prop": "charslot", "attributes": {}}, {"id": 348, "prop": "Background", "attributes": {"image": "59_g1_citystreets_d", "screenadapt": "showall"}}, {"id": 349, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1692_1#10$1", "focus": "m"}}, {"id": 350, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 351, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "style": "slider", "inverse": "true", "fadetime": 1.0, "block": "true"}}, {"id": 352, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 353, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1692_1#10$1", "focus": "m"}}, {"id": 354, "prop": "name", "attributes": {"content": "提奧！", "name": "涅梅絲"}, "figure_art": "avg_npc_1692_1#10$1"}, {"id": 355, "prop": "Dialog", "attributes": {}}, {"id": 356, "prop": "charslot", "attributes": {}}, {"id": 357, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 358, "prop": "name", "attributes": {"content": "“守靈人”小姐？你怎麼還在這裡？", "name": "？？？"}}, {"id": 359, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1692_1#1$1", "focus": "m"}}, {"id": 360, "prop": "name", "attributes": {"content": "你是——哦，“歌唱家”先生，請問您在這裡做什麼？", "name": "涅梅絲"}, "figure_art": "avg_npc_1692_1#1$1"}, {"id": 361, "prop": "Dialog", "attributes": {}}, {"id": 362, "prop": "charslot", "attributes": {}}, {"id": 363, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_247", "duration": 0.7}}, {"id": 364, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 365, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_247", "focus": "m"}}, {"id": 366, "prop": "name", "attributes": {"content": "聽聞城中發生了一些混亂，我想看看有沒有什麼自己能做的，結果，唉，無能為力，只聽說糧食短缺是維多利亞人破壞導致。", "name": "“歌唱家”"}, "figure_art": "avg_npc_247"}, {"id": 367, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_247", "focus": "m"}}, {"id": 368, "prop": "name", "attributes": {"content": "但我唯一一次碰到維多利亞人的軍隊純屬意外，那次還是承蒙您和庫林先生救我出來的。", "name": "“歌唱家”"}, "figure_art": "avg_npc_247"}, {"id": 369, "prop": "name", "attributes": {"content": "還有您為我提供的關於守靈人的消息，真的令我受益良多——", "name": "“歌唱家”"}, "figure_art": "avg_npc_247"}, {"id": 370, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1692_1#6$1", "focus": "m"}}, {"id": 371, "prop": "name", "attributes": {"content": "抱歉，“歌唱家”先生，我實在沒有時間和您敘舊——對了，能請您幫我一個忙嗎？庫林的學徒提奧失蹤了，可以請您幫我找他嗎？", "name": "涅梅絲"}, "figure_art": "avg_npc_1692_1#6$1"}, {"id": 372, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_247", "focus": "m"}}, {"id": 373, "prop": "name", "attributes": {"content": "這……我愛莫能助。", "name": "“歌唱家”"}, "figure_art": "avg_npc_247"}, {"id": 374, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_247", "focus": "m"}}, {"id": 375, "prop": "name", "attributes": {"content": "城裡人現在提到維多利亞人恨不得扒了他們的皮，你又何苦為了一個維多利亞小孩四處奔波呢？", "name": "“歌唱家”"}, "figure_art": "avg_npc_247"}, {"id": 376, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1692_1#6$1", "focus": "m"}}, {"id": 377, "prop": "name", "attributes": {"content": "算了，我自己找。", "name": "涅梅絲"}, "figure_art": "avg_npc_1692_1#6$1"}, {"id": 378, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_247", "focus": "m"}}, {"id": 379, "prop": "name", "attributes": {"content": "我也得提醒您一下，慶功會還有一個多小時就開始了，您不是還要把象徵守靈人祝福的祭器送去會場嗎？", "name": "“歌唱家”"}, "figure_art": "avg_npc_247"}, {"id": 380, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1692_1#5$1", "focus": "m"}}, {"id": 381, "prop": "name", "attributes": {"content": "嘖！", "name": "涅梅絲"}, "figure_art": "avg_npc_1692_1#5$1"}, {"id": 382, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_247", "focus": "m"}}, {"id": 383, "prop": "name", "attributes": {"content": "唉，您也真是……抱歉，我先失陪了。", "name": "“歌唱家”"}, "figure_art": "avg_npc_247"}, {"id": 384, "prop": "Dialog", "attributes": {}}, {"id": 385, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.6}}, {"id": 386, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 387, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 388, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1692_1#6$1", "focus": "m"}}, {"id": 389, "prop": "name", "attributes": {"content": "……", "name": "涅梅絲"}, "figure_art": "avg_npc_1692_1#6$1"}, {"id": 390, "prop": "name", "attributes": {"content": "那現在……", "name": "涅梅絲"}, "figure_art": "avg_npc_1692_1#6$1"}, {"id": 391, "prop": "Dialog", "attributes": {}}, {"id": 392, "prop": "charslot", "attributes": {}}, {"id": 393, "prop": "PlaySound", "attributes": {"key": "$d_avg_runstop", "volume": 1.0}}, {"id": 394, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1694_1#11$1", "duration": 0.5}}, {"id": 395, "prop": "Delay", "attributes": {"time": 0.7}}, {"id": 396, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1694_1#11$1", "focus": "m"}}, {"id": 397, "prop": "name", "attributes": {"content": "涅梅絲，是你嗎？", "name": "拉芙希妮"}, "figure_art": "avg_npc_1694_1#11$1"}, {"id": 398, "prop": "name", "attributes": {"content": "終於找到你了……城裡到底出了什麼事？", "name": "拉芙希妮"}, "figure_art": "avg_npc_1694_1#11$1"}, {"id": 399, "prop": "Dialog", "attributes": {}}, {"id": 400, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 401, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 402, "prop": "charslot", "attributes": {}}, {"id": 403, "prop": "Image", "attributes": {}}, {"id": 404, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}