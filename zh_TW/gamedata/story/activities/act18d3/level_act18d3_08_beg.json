{"lang": "zh_TW", "eventid": "act18d3", "eventName": "覆潮之下", "entryType": "ACTIVITY", "storyCode": "SV-8", "avgTag": "行動前", "storyName": "親族", "storyInfo": "縱使再相近，人類與海嗣，依舊是不同的。\n", "storyList": [{"id": 0, "prop": "HEADER", "attributes": {"key": "title_test", "is_skippable": "true", "fit_mode": "BLACK_MASK"}}, {"id": 1, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 2, "prop": "stopmusic", "attributes": {}}, {"id": 3, "prop": "Dialog", "attributes": {}}, {"id": 4, "prop": "Background", "attributes": {"image": "bg_ibcave"}}, {"id": 5, "prop": "character", "attributes": {"name": "avg_npc_184"}}, {"id": 6, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 7, "prop": "PlayMusic", "attributes": {"intro": "$warchaos_intro", "key": "$warchaos_loop", "volume": 0.4}}, {"id": 8, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 9, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 10, "prop": "name", "attributes": {"content": "雜種......你們兩個雜種——", "name": "主教"}, "figure_art": "avg_npc_184"}, {"id": 11, "prop": "name", "attributes": {"content": "使者！你在做什麼？！你為什麼留住她們？她們怎麼值得你這麼做？！", "name": "主教"}, "figure_art": "avg_npc_184"}, {"id": 12, "prop": "name", "attributes": {"content": "在她們對我們同胞大肆殺戮的時候，你們就該意識到她們和你絕對不是一種東西！", "name": "主教"}, "figure_art": "avg_npc_184"}, {"id": 13, "prop": "name", "attributes": {"content": "你是神聖的生命！她們只是污濁的殘渣！", "name": "主教"}, "figure_art": "avg_npc_184"}, {"id": 14, "prop": "character", "attributes": {"name": "avg_474_gladiia_1#5"}}, {"id": 15, "prop": "name", "attributes": {"content": "（啐）", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#5"}, {"id": 16, "prop": "name", "attributes": {"content": "很會適應，是不是？", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#5"}, {"id": 17, "prop": "name", "attributes": {"content": "我們用冷兵器去砍殺你們，讓你們對技術不那麼敏感，不讓你們進化成其他手段也解決不了的樣子。", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#5"}, {"id": 18, "prop": "name", "attributes": {"content": "現在我卻高估你了。你太不敏感了......這都適應不了？", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#5"}, {"id": 19, "prop": "name", "attributes": {"content": "看起來你習慣不了阿戈爾材料學造出來的刀刃。是不是？", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#5"}, {"id": 20, "prop": "dialog", "attributes": {}}, {"id": 21, "prop": "character", "attributes": {}}, {"id": 22, "prop": "Character", "attributes": {"name": "avg_npc_186"}}, {"id": 23, "prop": "name", "attributes": {"content": "——", "name": "海嗣"}, "figure_art": "avg_npc_186"}, {"id": 24, "prop": "character", "attributes": {"name": "avg_npc_184"}}, {"id": 25, "prop": "name", "attributes": {"content": "使者，她在污衊你！", "name": "主教"}, "figure_art": "avg_npc_184"}, {"id": 26, "prop": "character", "attributes": {"name": "avg_474_gladiia_1#4"}}, {"id": 27, "prop": "name", "attributes": {"content": "主教，主教......你還看不出嗎？呵呵，是的，我就是有自信殺了你。我從最開始就能殺掉你。", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#4"}, {"id": 28, "prop": "character", "attributes": {"name": "avg_npc_186"}}, {"id": 29, "prop": "CameraShake", "attributes": {"duration": 0.8, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 30, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 31, "prop": "name", "attributes": {"content": "（低鳴）", "name": "海嗣"}, "figure_art": "avg_npc_186"}, {"id": 32, "prop": "name", "attributes": {"content": "嗚......（咳嗽）", "name": "海嗣"}, "figure_art": "avg_npc_186"}, {"id": 33, "prop": "name", "attributes": {"content": "兄弟，你為什麼不接受？", "name": "海嗣"}, "figure_art": "avg_npc_186"}, {"id": 34, "prop": "name", "attributes": {"content": "她們都是我姐妹。所以她們也是你姐妹。", "name": "海嗣"}, "figure_art": "avg_npc_186"}, {"id": 35, "prop": "name", "attributes": {"content": "我能喚起你，喚起Ishar-mla，當然......也喚起Gla-dia。", "name": "海嗣"}, "figure_art": "avg_npc_186"}, {"id": 36, "prop": "name", "attributes": {"content": "你因為你兄弟，游向淺海，就不認他，那樣只是......不在乎。", "name": "海嗣"}, "figure_art": "avg_npc_186"}, {"id": 37, "prop": "name", "attributes": {"content": "我們，族群，都在乎。", "name": "海嗣"}, "figure_art": "avg_npc_186"}, {"id": 38, "prop": "character", "attributes": {"name": "avg_npc_184"}}, {"id": 39, "prop": "name", "attributes": {"content": "不......妄言......", "name": "主教"}, "figure_art": "avg_npc_184"}, {"id": 40, "prop": "character", "attributes": {"name": "avg_474_gladiia_1#5"}}, {"id": 41, "prop": "name", "attributes": {"content": "你難道相信過你手中經書的任何字句？允我提醒，你也是在伊比利亞的眼皮底下宣傳邪說，主教。", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#5"}, {"id": 42, "prop": "name", "attributes": {"content": "它說什麼我都無所謂，可你，深海教會的人，是不是把他的話都用本子記下來會比較好？", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#5"}, {"id": 43, "prop": "character", "attributes": {"name": "avg_npc_184"}}, {"id": 44, "prop": "name", "attributes": {"content": "殺了他們......殺了她們！使者！動手！她們犯下了大罪！他們褻瀆了你，褻瀆了海洋？", "name": "主教"}, "figure_art": "avg_npc_184"}, {"id": 45, "prop": "character", "attributes": {"name": "avg_npc_186"}}, {"id": 46, "prop": "name", "attributes": {"content": "你這樣要求......我真會這麼做。", "name": "海嗣"}, "figure_art": "avg_npc_186"}, {"id": 47, "prop": "character", "attributes": {"name": "avg_npc_184"}}, {"id": 48, "prop": "name", "attributes": {"content": "你也無所謂，對嗎？就像你和我說的一樣，我這麼要求也沒問題！你會殺了她們！", "name": "主教"}, "figure_art": "avg_npc_184"}, {"id": 49, "prop": "character", "attributes": {"name": "avg_npc_186"}}, {"id": 50, "prop": "name", "attributes": {"content": "是的。我依然無所謂。", "name": "海嗣"}, "figure_art": "avg_npc_186"}, {"id": 51, "prop": "character", "attributes": {"name": "avg_npc_184"}}, {"id": 52, "prop": "name", "attributes": {"content": "先去殺了那個......吟遊歌手。把那個紅衣服的先殺掉！", "name": "主教"}, "figure_art": "avg_npc_184"}, {"id": 53, "prop": "character", "attributes": {"name": "avg_474_gladiia_1#5"}}, {"id": 54, "prop": "name", "attributes": {"content": "垃圾。是不是我讓你去殺掉你身後的人，殺了你身後穿得像條海帶的主教，你也會這麼做？", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#5"}, {"id": 55, "prop": "character", "attributes": {"name": "avg_npc_186"}}, {"id": 56, "prop": "name", "attributes": {"content": "是的。", "name": "海嗣"}, "figure_art": "avg_npc_186"}, {"id": 57, "prop": "character", "attributes": {"name": "avg_npc_184"}}, {"id": 58, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 59, "prop": "name", "attributes": {"content": "......！！！", "name": "主教"}, "figure_art": "avg_npc_184"}, {"id": 60, "prop": "character", "attributes": {"name": "avg_npc_186"}}, {"id": 61, "prop": "name", "attributes": {"content": "因為他是我同胞，你也是我同胞。他在呼喚我，你也在呼喚我。", "name": "海嗣"}, "figure_art": "avg_npc_186"}, {"id": 62, "prop": "character", "attributes": {"name": "avg_474_gladiia_1#3"}}, {"id": 63, "prop": "name", "attributes": {"content": "人類啊。", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#3"}, {"id": 64, "prop": "name", "attributes": {"content": "阿戈爾人可真是又卑劣又醜陋。承認吧，主教。", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#3"}, {"id": 65, "prop": "name", "attributes": {"content": "我們都是些愚蠢的阿戈爾人，喜歡把自己的想法去套在畜生身上。你根本不懂它。", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#3"}, {"id": 66, "prop": "character", "attributes": {"name": "avg_npc_184"}}, {"id": 67, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 68, "prop": "name", "attributes": {"content": "雜種！！", "name": "主教"}, "figure_art": "avg_npc_184"}, {"id": 69, "prop": "character", "attributes": {"name": "avg_474_gladiia_1#5"}}, {"id": 70, "prop": "name", "attributes": {"content": "只不過，如果你想保護我們的生命——為什麼不拒絕？", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#5"}, {"id": 71, "prop": "character", "attributes": {"name": "avg_npc_186"}}, {"id": 72, "prop": "name", "attributes": {"content": "拒絕？", "name": "海嗣"}, "figure_art": "avg_npc_186"}, {"id": 73, "prop": "name", "attributes": {"content": "怎麼樣......拒絕？", "name": "海嗣"}, "figure_art": "avg_npc_186"}, {"id": 74, "prop": "character", "attributes": {"name": "avg_474_gladiia_1#5"}}, {"id": 75, "prop": "name", "attributes": {"content": "行了，的確是劣等生物。你只游到這個深度。", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#5"}, {"id": 76, "prop": "character", "attributes": {"name": "avg_474_gladiia_1#3"}}, {"id": 77, "prop": "name", "attributes": {"content": "但是，垃圾，聽好，我不會開口請你去殺你背後那個軟蛋。", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#3"}, {"id": 78, "prop": "name", "attributes": {"content": "你只是獵物。誰會懇求自己的獵物？", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#3"}, {"id": 79, "prop": "name", "attributes": {"content": "你想動她？你聽從他的建議，想殺斯卡蒂，我的獵人？你不想再要那個答案了？", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#3"}, {"id": 80, "prop": "character", "attributes": {"name": "avg_npc_186"}}, {"id": 81, "prop": "name", "attributes": {"content": "殺了她也有其他辦法。只要還有辦法，我就無所謂。", "name": "海嗣"}, "figure_art": "avg_npc_186"}, {"id": 82, "prop": "name", "attributes": {"content": "但你說的，拒絕......", "name": "海嗣"}, "figure_art": "avg_npc_186"}, {"id": 83, "prop": "character", "attributes": {"name": "avg_474_gladiia_1#5"}}, {"id": 84, "prop": "name", "attributes": {"content": "太早了。咳......", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#5"}, {"id": 85, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 86, "prop": "name", "attributes": {"content": "（咳血）", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#5"}, {"id": 87, "prop": "name", "attributes": {"content": "呸。我不管你。你想殺她——你得先過我這關。", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#5"}, {"id": 88, "prop": "character", "attributes": {"name": "avg_npc_186"}}, {"id": 89, "prop": "name", "attributes": {"content": "那麼，Gla-dia。", "name": "海嗣"}, "figure_art": "avg_npc_186"}, {"id": 90, "prop": "name", "attributes": {"content": "你的生命能不能延續，你肉體以後還能不能活動，你來選能還是不能。", "name": "海嗣"}, "figure_art": "avg_npc_186"}, {"id": 91, "prop": "character", "attributes": {"name": "avg_474_gladiia_1#5"}}, {"id": 92, "prop": "name", "attributes": {"content": "用相互獵殺來選。", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#5"}, {"id": 93, "prop": "character", "attributes": {"name": "avg_npc_186"}}, {"id": 94, "prop": "name", "attributes": {"content": "相互......相互。是的。用相互捕食來選。你捕食我。我捕食你。", "name": "海嗣"}, "figure_art": "avg_npc_186"}, {"id": 95, "prop": "Dialog", "attributes": {}}, {"id": 96, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 97, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 98, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 99, "prop": "Character", "attributes": {}}, {"id": 100, "prop": "Image", "attributes": {}}, {"id": 101, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}