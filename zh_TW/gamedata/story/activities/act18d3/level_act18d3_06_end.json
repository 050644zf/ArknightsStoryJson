nd", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 109, "prop": "character", "attributes": {"name": "avg_1012_skadiSP_1#1", "fadetime": 1.5}}, {"id": 110, "prop": "delay", "attributes": {"time": 3.0}}, {"id": 111, "prop": "Character", "attributes": {"name": "avg_npc_180#3"}}, {"id": 112, "prop": "name", "attributes": {"content": "歌手，歡迎再次來到我們家！", "name": "安妮塔"}, "figure_art": "avg_npc_180#3"}, {"id": 113, "prop": "character", "attributes": {"name": "avg_npc_179#1"}}, {"id": 114, "prop": "name", "attributes": {"content": "呃......啊......", "name": "老年居民"}, "figure_art": "avg_npc_179#1"}, {"id": 115, "prop": "character", "attributes": {"name": "avg_1012_skadiSP_1#1"}}, {"id": 116, "prop": "name", "attributes": {"content": "你奶奶......", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 117, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#1", "focus": 2.0}}, {"id": 118, "prop": "name", "attributes": {"content": "佩特拉奶奶還在休息呢。昨天我們一起回到這裡，她就一直躺著。", "name": "安妮塔"}, "figure_art": "avg_npc_180#1"}, {"id": 119, "prop": "name", "attributes": {"content": "我想，她也消耗了很大體力，肯定很累了。我沒想到她會衝出來，對審判官那樣說話。她變得和平時都不一樣。", "name": "安妮塔"}, "figure_art": "avg_npc_180#1"}, {"id": 120, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#1", "focus": 1.0}}, {"id": 121, "prop": "name", "attributes": {"content": "你說的對。她很......厲害。她打退了審判官。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 122, "prop": "character", "attributes": {"name": "avg_npc_179#1"}}, {"id": 123, "prop": "name", "attributes": {"content": "呵......哈......", "name": "老年居民"}, "figure_art": "avg_npc_179#1"}, {"id": 124, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 2.0}}, {"id": 125, "prop": "name", "attributes": {"content": "打退了......審判官？！歌手，你這麼說，要是讓審判官聽見，她一定又要生氣了。", "name": "安妮塔"}, "figure_art": "avg_npc_180#2"}, {"id": 126, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 1.0}}, {"id": 127, "prop": "name", "attributes": {"content": "隨便她。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 128, "prop": "name", "attributes": {"content": "要是她想再動手......", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 129, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#1", "focus": 2.0}}, {"id": 130, "prop": "name", "attributes": {"content": "她不會再來找你麻煩了吧？", "name": "安妮塔"}, "figure_art": "avg_npc_180#1"}, {"id": 131, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#1", "focus": 1.0}}, {"id": 132, "prop": "name", "attributes": {"content": "......找誰的麻煩都一樣。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 133, "prop": "name", "attributes": {"content": "（摸箱子）", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 134, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 2.0}}, {"id": 135, "prop": "name", "attributes": {"content": "對了，我們出去找琴吧！", "name": "安妮塔"}, "figure_art": "avg_npc_180#2"}, {"id": 136, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 1.0}}, {"id": 137, "prop": "name", "attributes": {"content": "等一下。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 138, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 2.0}}, {"id": 139, "prop": "name", "attributes": {"content": "哎？", "name": "安妮塔"}, "figure_art": "avg_npc_180#2"}, {"id": 140, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 1.0}}, {"id": 141, "prop": "name", "attributes": {"content": "你頭上。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 142, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 2.0}}, {"id": 143, "prop": "name", "attributes": {"content": "哇！好多綠色的黏黏的東西......這、這是什麼東西呀？", "name": "安妮塔"}, "figure_art": "avg_npc_180#2"}, {"id": 144, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 1.0}}, {"id": 145, "prop": "name", "attributes": {"content": "是海藻。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 146, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#1", "focus": 2.0}}, {"id": 147, "prop": "name", "attributes": {"content": "是剛才摔跤時候蹭到的嗎？", "name": "安妮塔"}, "figure_art": "avg_npc_180#1"}, {"id": 148, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#1", "focus": 1.0}}, {"id": 149, "prop": "name", "attributes": {"content": "大概。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 150, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#1", "focus": 2.0}}, {"id": 151, "prop": "name", "attributes": {"content": "這些......有用嗎？看起來和海草長得差不多。能不能等風吹乾了拿來鋪床？佩特拉奶奶腰不舒服，正好用得上。", "name": "安妮塔"}, "figure_art": "avg_npc_180#1"}, {"id": 152, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#1", "focus": 1.0}}, {"id": 153, "prop": "name", "attributes": {"content": "......給我。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 154, "prop": "name", "attributes": {"content": "你用貝殼將這些海藻磨碎。不要洗掉這些粘液。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 155, "prop": "name", "attributes": {"content": "加上一點海水，記得沒過海藻。裝進這個小罐子裡，封好口。放半年。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 156, "prop": "name", "attributes": {"content": "等罐子裡的液體的綠色淡了，說明發酵好了，就可以喝啦。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 157, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 2.0}}, {"id": 158, "prop": "name", "attributes": {"content": "......歌手。", "name": "安妮塔"}, "figure_art": "avg_npc_180#2"}, {"id": 159, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 1.0}}, {"id": 160, "prop": "name", "attributes": {"content": "怎麼了？是不是沒聽明白？", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 161, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 2.0}}, {"id": 162, "prop": "name", "attributes": {"content": "你......你好像從來沒一口氣對我說過這麼多話！", "name": "安妮塔"}, "figure_art": "avg_npc_180#2"}, {"id": 163, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 1.0}}, {"id": 164, "prop": "name", "attributes": {"content": "嗯。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 165, "prop": "name", "attributes": {"content": "貝殼也不用扔，洗淨曬乾，當喝酒的容器用。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 166, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 2.0}}, {"id": 167, "prop": "name", "attributes": {"content": "酒？那是什麼東西？", "name": "安妮塔"}, "figure_art": "avg_npc_180#2"}, {"id": 168, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 1.0}}, {"id": 169, "prop": "name", "attributes": {"content": "那裡寫著。這裡原先是所酒吧。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 170, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 2.0}}, {"id": 171, "prop": "name", "attributes": {"content": "原來這個字是酒的意思！", "name": "安妮塔"}, "figure_art": "avg_npc_180#2"}, {"id": 172, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 1.0}}, {"id": 173, "prop": "name", "attributes": {"content": "他們說喝酒能帶來快樂，忘記煩惱。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 174, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 2.0}}, {"id": 175, "prop": "name", "attributes": {"content": "真的嗎？", "name": "安妮塔"}, "figure_art": "avg_npc_180#2"}, {"id": 176, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 1.0}}, {"id": 177, "prop": "name", "attributes": {"content": "......沒用。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 178, "prop": "name", "attributes": {"content": "不過，味道還不錯。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 179, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 2.0}}, {"id": 180, "prop": "name", "attributes": {"content": "你以前經常喝這個嗎？在你的家鄉......阿戈爾？", "name": "安妮塔"}, "figure_art": "avg_npc_180#2"}, {"id": 181, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#2", "focus": 1.0}}, {"id": 182, "prop": "name", "attributes": {"content": "不大一樣。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 183, "prop": "name", "attributes": {"content": "......有時候會一起喝類似的，在跳舞之前。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 184, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#3", "focus": 2.0}}, {"id": 185, "prop": "name", "attributes": {"content": "你們那時候一定很快樂。噢，我明白啦！不是酒能帶來快樂，是快樂的時候，我們喝酒。", "name": "安妮塔"}, "figure_art": "avg_npc_180#3"}, {"id": 186, "prop": "name", "attributes": {"content": "生活在外面的人，呃，是不是都會喝酒？大家是不是都很快樂？", "name": "安妮塔"}, "figure_art": "avg_npc_180#3"}, {"id": 187, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#3", "focus": 1.0}}, {"id": 188, "prop": "name", "attributes": {"content": "未必。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 189, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#3", "focus": 2.0}}, {"id": 190, "prop": "name", "attributes": {"content": "我懂了。那他們一定沒有我現在這麼快樂。歌手，謝謝你教我做這個酒。我真想馬上就和你一起喝。", "name": "安妮塔"}, "figure_art": "avg_npc_180#3"}, {"id": 191, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#1", "name2": "avg_npc_180#3", "focus": 1.0}}, {"id": 192, "prop": "name", "attributes": {"content": "你的手勢錯了。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 193, "prop": "name", "attributes": {"content": "這麼碾的話，很難碾碎。你可以換個角度，用最尖的部分對準海藻的紋理。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 194, "prop": "name", "attributes": {"content": "掌握韻律，調整呼吸......令你的手，你的身體，與觸到你肌膚的海風融為一體。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 195, "prop": "name", "attributes": {"content": "像這樣——一擊，即碎。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 196, "prop": "dialog", "attributes": {}}, {"id": 197, "prop": "character", "attributes": {}}, {"id": 198, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 199, "prop": "character", "attributes": {"name": "avg_npc_187", "name2": "avg_1012_skadiSP_1#1", "focus": 1.0}}, {"id": 200, "prop": "name", "attributes": {"content": "......", "name": "男性居民B"}, "figure_art": "avg_npc_187"}, {"id": 201, "prop": "character", "attributes": {"name": "avg_npc_187", "name2": "avg_1012_skadiSP_1#1", "focus": 2.0}}, {"id": 202, "prop": "name", "attributes": {"content": "你盯著我，是還想動手嗎？只有你一個人的話，結束得很快。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#1"}, {"id": 203, "prop": "character", "attributes": {"name": "avg_npc_187", "name2": "avg_1012_skadiSP_1#1", "focus": 1.0}}, {"id": 204, "prop": "name", "attributes": {"content": "不......沒有。", "name": "男性居民B"}, "figure_art": "avg_npc_187"}, {"id": 205, "prop": "name", "attributes": {"content": "這個，還給你。", "name": "男性居民B"}, "figure_art": "avg_npc_187"}, {"id": 206, "prop": "character", "attributes": {"name": "avg_npc_187", "name2": "avg_1012_skadiSP_1#4", "focus": 2.0}}, {"id": 207, "prop": "name", "attributes": {"content": "嗯？", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#4"}, {"id": 208, "prop": "name", "attributes": {"content": "這是我的琴。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#4"}, {"id": 209, "prop": "character", "attributes": {"name": "avg_npc_187", "name2": "avg_1012_skadiSP_1#4", "focus": 1.0}}, {"id": 210, "prop": "name", "attributes": {"content": "是鐵皮撿到的。", "name": "男性居民B"}, "figure_art": "avg_npc_187"}, {"id": 211, "prop": "name", "attributes": {"content": "他昨天夜裡看到你把這東西掉在了外面。", "name": "男性居民B"}, "figure_art": "avg_npc_187"}, {"id": 212, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#4", "name2": "avg_npc_180#3", "focus": 1.0}}, {"id": 213, "prop": "name", "attributes": {"content": "......", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#4"}, {"id": 214, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#4", "name2": "avg_npc_180#3", "focus": 2.0}}, {"id": 215, "prop": "name", "attributes": {"content": "哎呀，太好了！歌手，我們不用去找琴了！", "name": "安妮塔"}, "figure_art": "avg_npc_180#3"}, {"id": 216, "prop": "character", "attributes": {"name": "avg_npc_187", "name2": "avg_1012_skadiSP_1#4", "focus": 1.0}}, {"id": 217, "prop": "name", "attributes": {"content": "鐵皮他，他把這東西偷偷拿回了我們住的房子，讓我......讓我把它給你。", "name": "男性居民B"}, "figure_art": "avg_npc_187"}, {"id": 218, "prop": "name", "attributes": {"content": "說完這個他就走了......", "name": "男性居民B"}, "figure_art": "avg_npc_187"}, {"id": 219, "prop": "character", "attributes": {"name": "avg_npc_187", "name2": "avg_1012_skadiSP_1#4", "focus": 2.0}}, {"id": 220, "prop": "name", "attributes": {"content": "謝謝。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#4"}, {"id": 221, "prop": "character", "attributes": {"name": "avg_npc_187", "name2": "avg_1012_skadiSP_1#4", "focus": 1.0}}, {"id": 222, "prop": "name", "attributes": {"content": "啊？啊......", "name": "男性居民B"}, "figure_art": "avg_npc_187"}, {"id": 223, "prop": "dialog", "attributes": {}}, {"id": 224, "prop": "character", "attributes": {"name": "avg_1012_skadiSP_1#4"}}, {"id": 225, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 226, "prop": "character", "attributes": {"name": "avg_1012_skadiSP_1#5"}}, {"id": 227, "prop": "name", "attributes": {"content": "（撥琴）", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#5"}, {"id": 228, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#5", "name2": "avg_npc_180#2", "focus": 2.0}}, {"id": 229, "prop": "name", "attributes": {"content": "這個調子......咦，是你晚上睡著時候哼著的。", "name": "安妮塔"}, "figure_art": "avg_npc_180#2"}, {"id": 230, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#4", "name2": "avg_npc_180#2", "focus": 1.0}}, {"id": 231, "prop": "name", "attributes": {"content": "它經常在我腦子裡。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#4"}, {"id": 232, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#4", "name2": "avg_npc_180#2", "focus": 2.0}}, {"id": 233, "prop": "name", "attributes": {"content": "這是你和你的同伴，你們以前會唱的歌嗎？", "name": "安妮塔"}, "figure_art": "avg_npc_180#2"}, {"id": 234, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#4", "name2": "avg_npc_180#2", "focus": 1.0}}, {"id": 235, "prop": "name", "attributes": {"content": "在家的時候，這樣的歌還有很多。我們用歌聲......對彼此說話。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#4"}, {"id": 236, "prop": "name", "attributes": {"content": "離開以後，其他歌聲都消失了。我一個人，只剩下這個。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#4"}, {"id": 237, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#4", "name2": "avg_npc_180#1", "focus": 2.0}}, {"id": 238, "prop": "name", "attributes": {"content": "難怪，這首歌聽起來很讓人難過。", "name": "安妮塔"}, "figure_art": "avg_npc_180#1"}, {"id": 239, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#5", "name2": "avg_npc_180#1", "focus": 1.0}}, {"id": 240, "prop": "name", "attributes": {"content": "（撥琴）", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#5"}, {"id": 241, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#5", "name2": "avg_npc_180#3", "focus": 2.0}}, {"id": 242, "prop": "name", "attributes": {"content": "歌手，我們的約定！你拿回了琴，是不是可以為我們唱歌了？", "name": "安妮塔"}, "figure_art": "avg_npc_180#3"}, {"id": 243, "prop": "name", "attributes": {"content": "我們可都等著哩，是吧，佩特拉奶奶？", "name": "安妮塔"}, "figure_art": "avg_npc_180#3"}, {"id": 244, "prop": "character", "attributes": {"name": "avg_npc_179#2"}}, {"id": 245, "prop": "name", "attributes": {"content": "唔......呃啊......", "name": "老年居民"}, "figure_art": "avg_npc_179#2"}, {"id": 246, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#4", "name2": "avg_npc_180#3", "focus": 2.0}}, {"id": 247, "prop": "name", "attributes": {"content": "奶奶今天說不出話了。不然她一定也想跟著唱哩。", "name": "安妮塔"}, "figure_art": "avg_npc_180#3"}, {"id": 248, "prop": "character", "attributes": {"name": "avg_npc_179#2"}}, {"id": 249, "prop": "name", "attributes": {"content": "啊......啊......", "name": "老年居民"}, "figure_art": "avg_npc_179#2"}, {"id": 250, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#4", "name2": "avg_npc_180#3", "focus": 2.0}}, {"id": 251, "prop": "name", "attributes": {"content": "歌手，佩特拉奶奶想聽呢。", "name": "安妮塔"}, "figure_art": "avg_npc_180#3"}, {"id": 252, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#4", "name2": "avg_npc_180#3", "focus": 1.0}}, {"id": 253, "prop": "name", "attributes": {"content": "......", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#4"}, {"id": 254, "prop": "name", "attributes": {"content": "好。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#4"}, {"id": 255, "prop": "dialog", "attributes": {}}, {"id": 256, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 257, "prop": "dialog", "attributes": {}}, {"id": 258, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 259, "prop": "Character", "attributes": {}}, {"id": 260, "prop": "Image", "attributes": {"image": "ac18_05", "xScale": 1.2, "yScale": 1.2, "fadetime": 0.0}}, {"id": 261, "prop": "ImageTween", "attributes": {"xFrom": 30.0, "duration": 25.0, "block": "false"}}, {"id": 262, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 263, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 264, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 265, "prop": "PlayMusic", "attributes": {"intro": "$newhope01_intro", "key": "$newhope01_loop", "volume": 0.4}}, {"id": 266, "prop": "Subtitle", "attributes": {"text": "紅裙的流浪歌手坐在人群中間。她閉上了眼睛，手指撫上琴弦。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 267, "prop": "Subtitle", "attributes": {"text": "琴聲和歌聲一起自她身上湧出來，彌漫在這間殘破的酒吧裡，旋轉，伸展，就像它們本來就該在這裡一樣。", "x": 300.0, "y": 370.0, "alignment": "left", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 268, "prop": "subtitle", "attributes": {}}, {"id": 269, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 270, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 271, "prop": "name", "attributes": {"content": "一個獵人他走上海岸♪"}}, {"id": 272, "prop": "name", "attributes": {"content": "他的家鄉在後，他的路在身前♪"}}, {"id": 273, "prop": "name", "attributes": {"content": "父母與兒女都與他失散♪"}}, {"id": 274, "prop": "name", "attributes": {"content": "他的戀人已經葬身大海♪"}}, {"id": 275, "prop": "dialog", "attributes": {}}, {"id": 276, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 277, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 278, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 279, "prop": "image", "attributes": {}}, {"id": 280, "prop": "background", "attributes": {"image": "bg_black"}}, {"id": 281, "prop": "character", "attributes": {"name": "avg_474_gladiia_1#1"}}, {"id": 282, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 283, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 284, "prop": "character", "attributes": {"name": "avg_474_gladiia_1#5"}}, {"id": 285, "prop": "name", "attributes": {"content": "......", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#5"}, {"id": 286, "prop": "character", "attributes": {"name": "avg_474_gladiia_1#5", "name2": "avg_npc_184", "focus": 2.0}}, {"id": 287, "prop": "name", "attributes": {"content": "你的表情有一絲變化。你是否感受到了什麼？", "name": "主教"}, "figure_art": "avg_npc_184"}, {"id": 288, "prop": "character", "attributes": {"name": "avg_474_gladiia_1#5", "name2": "avg_npc_184", "focus": 1.0}}, {"id": 289, "prop": "name", "attributes": {"content": "沒什麼。", "name": "歌蕾蒂婭"}, "figure_art": "avg_474_gladiia_1#5"}, {"id": 290, "prop": "character", "attributes": {"name": "avg_474_gladiia_1#5", "name2": "avg_npc_184", "focus": 2.0}}, {"id": 291, "prop": "name", "attributes": {"content": "並不意外，你的神經依舊遲鈍。看看你面前的這些水。水位的起伏，波紋的頻率，光澤的躍動。這些都是訊息。", "name": "主教"}, "figure_art": "avg_npc_184"}, {"id": 292, "prop": "name", "attributes": {"content": "快要漲潮了。我們該上去。", "name": "主教"}, "figure_art": "avg_npc_184"}, {"id": 293, "prop": "dialog", "attributes": {}}, {"id": 294, "prop": "character", "attributes": {"fadetime": 1.0}}, {"id": 295, "prop": "dialog", "attributes": {}}, {"id": 296, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 297, "prop": "Character", "attributes": {}}, {"id": 298, "prop": "Image", "attributes": {"image": "ac18_05", "xScale": 1.2, "yScale": 1.2, "fadetime": 0.0}}, {"id": 299, "prop": "ImageTween", "attributes": {"xTo": 30.0, "duration": 25.0, "block": "false"}}, {"id": 300, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 301, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 302, "prop": "name", "attributes": {"content": "一個獵人他走上海岸♪"}}, {"id": 303, "prop": "name", "attributes": {"content": "他的家鄉在後，徒餘哀歎♪"}}, {"id": 304, "prop": "name", "attributes": {"content": "他的路沒有盡頭♪"}}, {"id": 305, "prop": "name", "attributes": {"content": "他的路濃霧彌漫♪"}}, {"id": 306, "prop": "dialog", "attributes": {}}, {"id": 307, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 308, "prop": "dialog", "attributes": {}}, {"id": 309, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 310, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 311, "prop": "Character", "attributes": {}}, {"id": 312, "prop": "Background", "attributes": {"image": "bg_ibtownn", "fadetime": 1.0}}, {"id": 313, "prop": "Image", "attributes": {}}, {"id": 314, "prop": "delay", "attributes": {"time": 0.6}}, {"id": 315, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 316, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 317, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 318, "prop": "character", "attributes": {"name": "avg_npc_182#5", "fadetime": 1.5}}, {"id": 319, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 320, "prop": "name", "attributes": {"content": "她在唱歌。", "name": "審判官"}, "figure_art": "avg_npc_182#5"}, {"id": 321, "prop": "name", "attributes": {"content": "她竟然，在這個破房子裡，在這些人面前唱歌。", "name": "審判官"}, "figure_art": "avg_npc_182#5"}, {"id": 322, "prop": "name", "attributes": {"content": "這些人......他們也竟然在聽。", "name": "審判官"}, "figure_art": "avg_npc_182#5"}, {"id": 323, "prop": "name", "attributes": {"content": "低著頭的人依然低著頭。不會說話的人依然凍著舌頭。歌聲明明沒法進到他們僵硬的軀殼裡。可他們的眼睛......", "name": "審判官"}, "figure_art": "avg_npc_182#5"}, {"id": 324, "prop": "name", "attributes": {"content": "他們，聽懂了嗎？", "name": "審判官"}, "figure_art": "avg_npc_182#5"}, {"id": 325, "prop": "dialog", "attributes": {}}, {"id": 326, "prop": "dialog", "attributes": {}}, {"id": 327, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 328, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 329, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#5", "fadetime": 0.5}}, {"id": 330, "prop": "Background", "attributes": {"image": "bg_ibbar"}}, {"id": 331, "prop": "Image", "attributes": {}}, {"id": 332, "prop": "delay", "attributes": {"time": 0.6}}, {"id": 333, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 334, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 335, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 336, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 337, "prop": "Subtitle", "attributes": {"text": "一個獵人他走上海岸♪", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 338, "prop": "Subtitle", "attributes": {"text": "......", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 339, "prop": "subtitle", "attributes": {}}, {"id": 340, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 341, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 342, "prop": "Subtitle", "attributes": {"text": "歌手停下了撥琴的手指，琴聲和歌聲並沒有立刻消失。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 343, "prop": "Subtitle", "attributes": {"text": "它們依然存在於流浪者身上，在厚厚的塵土間鑽出一道縫。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 344, "prop": "Subtitle", "attributes": {"text": "一些枝芽擠了進去，另一些本來就在的淌了出來。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 345, "prop": "subtitle", "attributes": {}}, {"id": 346, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 347, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 348, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 349, "prop": "name", "attributes": {"content": "......", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#5"}, {"id": 350, "prop": "Character", "attributes": {"name": "avg_npc_188", "name2": "avg_npc_189"}}, {"id": 351, "prop": "name", "attributes": {"content": "......", "name": "居民"}, "figure_art": "avg_1012_skadiSP_1#5"}, {"id": 352, "prop": "Dialog", "attributes": {}}, {"id": 353, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 354, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 355, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#5", "name2": "avg_npc_180#1"}}, {"id": 356, "prop": "Background", "attributes": {"image": "bg_ibbar"}}, {"id": 357, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 358, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 359, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 360, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#5", "name2": "avg_npc_180#2", "focus": 2.0}}, {"id": 361, "prop": "name", "attributes": {"content": "佩特拉奶奶？", "name": "安妮塔"}, "figure_art": "avg_npc_180#2"}, {"id": 362, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#4", "name2": "avg_npc_180#2", "focus": 1.0}}, {"id": 363, "prop": "name", "attributes": {"content": "她怎麼了？", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#4"}, {"id": 364, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#4", "name2": "avg_npc_180#3", "focus": 2.0}}, {"id": 365, "prop": "name", "attributes": {"content": "她......睡著了。", "name": "安妮塔"}, "figure_art": "avg_npc_180#3"}, {"id": 366, "prop": "name", "attributes": {"content": "我很少見她睡得這麼安穩。以前她一閉眼就會大叫，在空氣裡亂抓。", "name": "安妮塔"}, "figure_art": "avg_npc_180#3"}, {"id": 367, "prop": "name", "attributes": {"content": "我還以為聽見你唱歌，她會想要跳舞。她總是嚷嚷著想跳舞哩。", "name": "安妮塔"}, "figure_art": "avg_npc_180#3"}, {"id": 368, "prop": "Character", "attributes": {"name": "avg_npc_187"}}, {"id": 369, "prop": "name", "attributes": {"content": "......", "name": "男性居民B"}, "figure_art": "avg_npc_187"}, {"id": 370, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#4", "name2": "avg_npc_180#2", "focus": 2.0}}, {"id": 371, "prop": "name", "attributes": {"content": "牆灰？", "name": "安妮塔"}, "figure_art": "avg_npc_180#2"}, {"id": 372, "prop": "Character", "attributes": {"name": "avg_npc_187"}}, {"id": 373, "prop": "name", "attributes": {"content": "我要死了。我的眼睛......進了海水。好鹹，一點都不好喝。", "name": "男性居民B"}, "figure_art": "avg_npc_187"}, {"id": 374, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#4", "name2": "avg_npc_180#2", "focus": 2.0}}, {"id": 375, "prop": "name", "attributes": {"content": "哇，你這是......你是不是哭了？", "name": "安妮塔"}, "figure_art": "avg_npc_180#2"}, {"id": 376, "prop": "Character", "attributes": {"name": "avg_npc_187"}}, {"id": 377, "prop": "name", "attributes": {"content": "哭？什麼是哭？", "name": "男性居民B"}, "figure_art": "avg_npc_187"}, {"id": 378, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#4", "name2": "avg_npc_180#2", "focus": 1.0}}, {"id": 379, "prop": "name", "attributes": {"content": "......是從你身體深處流淌出來的情緒。", "name": "斯卡蒂"}, "figure_art": "avg_1012_skadiSP_1#4"}, {"id": 380, "prop": "Character", "attributes": {"name": "avg_npc_187"}}, {"id": 381, "prop": "name", "attributes": {"content": "這樣......嗎？我還是不大明白。", "name": "男性居民B"}, "figure_art": "avg_npc_187"}, {"id": 382, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#4", "name2": "avg_npc_180#3", "focus": 2.0}}, {"id": 383, "prop": "name", "attributes": {"content": "歌手，我喜歡你的歌。你不愛說話，可是你的歌裡有許多話。", "name": "安妮塔"}, "figure_art": "avg_npc_180#3"}, {"id": 384, "prop": "name", "attributes": {"content": "你願意再唱一遍嗎？我想聽你說更多。", "name": "安妮塔"}, "figure_art": "avg_npc_180#3"}, {"id": 385, "prop": "Character", "attributes": {"name": "avg_1012_skadiSP_1#4", "name2": "avg_npc_180#3", "focus": 1.0}}, {