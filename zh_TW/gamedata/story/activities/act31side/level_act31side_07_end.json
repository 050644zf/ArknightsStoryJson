s": {"time": 2.0}}, {"id": 387, "prop": "Background", "attributes": {"image": "bg_black", "screenadapt": "coverall"}}, {"id": 388, "prop": "PlaySound", "attributes": {"key": "$dooropenquite"}}, {"id": 389, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 390, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 391, "prop": "name", "attributes": {"content": "桑麻日已長，我土日已廣……", "name": "績"}}, {"id": 392, "prop": "name", "attributes": {"content": "敢教邪祟詭魔拓易，天地煥新光……", "name": "績"}}, {"id": 393, "prop": "name", "attributes": {"content": "啦……啦……", "name": "績"}}, {"id": 394, "prop": "dialog", "attributes": {}}, {"id": 395, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 396, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1236_1#1$1", "duration": 1.5}}, {"id": 397, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 398, "prop": "name", "attributes": {"content": "繭已經結好了……", "name": "績"}, "figure_art": "avg_npc_1236_1#1$1"}, {"id": 399, "prop": "name", "attributes": {"content": "該抽絲了。", "name": "績"}, "figure_art": "avg_npc_1236_1#1$1"}, {"id": 400, "prop": "Dialog", "attributes": {}}, {"id": 401, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 402, "prop": "charslot", "attributes": {}}, {"id": 403, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 404, "prop": "Background", "attributes": {"image": "47_g10_fairyfarmland_ex", "screenadapt": "coverall"}}, {"id": 405, "prop": "PlaySound", "attributes": {"key": "$d_avg_reedmarshes", "volume": 0.0, "loop": "true", "channel": "reed"}}, {"id": 406, "prop": "SoundVolume", "attributes": {"volume": 0.5, "fadetime": 1.0, "channel": "reed"}}, {"id": 407, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 408, "prop": "playMusic", "attributes": {"key": "$saferoom_loop", "volume": 0.6}}, {"id": 409, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 410, "prop": "PlaySound", "attributes": {"key": "$d_avg_wing"}}, {"id": 411, "prop": "name", "attributes": {"content": "一隻羽獸飛過。"}}, {"id": 412, "prop": "name", "attributes": {"content": "這地方原本不該有羽獸，日月星辰，風霜雨雪，山川河流，這地方原本都不該有。"}}, {"id": 413, "prop": "name", "attributes": {"content": "但這隻羽獸銜來一株稻穗，揮揮翅膀，停在一座小山的山峰上。"}}, {"id": 414, "prop": "dialog", "attributes": {}}, {"id": 415, "prop": "PlaySound", "attributes": {"key": "$d_gen_heartbeat", "volume": 1.0, "loop": "true", "channel": "c"}}, {"id": 416, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 417, "prop": "StopSound", "attributes": {"channel": "c", "fadetime": 1.0}}, {"id": 418, "prop": "name", "attributes": {"content": "這顆心臟跳動、跳動，有什麼即將破土而出——"}}, {"id": 419, "prop": "name", "attributes": {"content": "一陣風吹過，禾苗搖搖晃晃。"}}, {"id": 420, "prop": "name", "attributes": {"content": "河流不斷，水奔騰著。"}}, {"id": 421, "prop": "name", "attributes": {"content": "山川隆起，土石轟鳴著。"}}, {"id": 422, "prop": "name", "attributes": {"content": "樹木扎根，蔭翳搖晃著。"}}, {"id": 423, "prop": "name", "attributes": {"content": "羽獸似有所感，銜著稻穗再度飛起，掉下兩粒稻種，落入無邊的水田中。"}}, {"id": 424, "prop": "name", "attributes": {"content": "刷——拉——，刷——拉——"}}, {"id": 425, "prop": "name", "attributes": {"content": "一雙眼睜開。"}}, {"id": 426, "prop": "dialog", "attributes": {}}, {"id": 427, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 428, "prop": "name", "attributes": {"content": "……你？", "name": "混沌的聲音"}}, {"id": 429, "prop": "name", "attributes": {"content": "你回來了？", "name": "混沌的聲音"}}, {"id": 430, "prop": "Dialog", "attributes": {}}, {"id": 431, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 432, "prop": "stopsound", "attributes": {"channel": "reed", "fadetime": 2.0}}, {"id": 433, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 434, "prop": "stopmusic", "attributes": {"fadetime": 2.0}},