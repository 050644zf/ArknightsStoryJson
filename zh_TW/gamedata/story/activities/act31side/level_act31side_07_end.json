, {"id": 19, "prop": "PlaySound", "attributes": {"key": "$d_avg_hgmlgscrm"}}, {"id": 20, "prop": "name", "attributes": {"content": "（淒厲的長鳴）", "name": "詭異的織物"}, "figure_art": "avg_npc_1244_1#3$1"}, {"id": 21, "prop": "dialog", "attributes": {}}, {"id": 22, "prop": "PlaySound", "attributes": {"key": "$d_avg_hammer", "volume": 0.8}}, {"id": 23, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 24, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 25, "prop": "PlaySound", "attributes": {"key": "$d_avg_hgmdspr"}}, {"id": 26, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 27, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 28, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1243_1#3$1", "duration": 1.0}}, {"id": 29, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 30, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 31, "prop": "name", "attributes": {"content": "他沉浸在自己的戰場裡。"}}, {"id": 32, "prop": "name", "attributes": {"content": "他所對戰的敵人不可說，他的舌頭僵死在口中。"}}, {"id": 33, "prop": "name", "attributes": {"content": "他所愛的人已經離去，看不到下一次春天的到來。"}}, {"id": 34, "prop": "name", "attributes": {"content": "他高高舉起自己的武器，他只知道自己好像要保護什麼。"}}, {"id": 35, "prop": "name", "attributes": {"content": "保護……什麼？"}}, {"id": 36, "prop": "name", "attributes": {"content": "一陣笛聲悠悠地傳來。"}}, {"id": 37, "prop": "Dialog", "attributes": {}}, {"id": 38, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 39, "prop": "charslot", "attributes": {}}, {"id": 40, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4122_grabds_1#5$1"}}, {"id": 41, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 42, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4122_grabds_1#5$1"}}, {"id": 43, "prop": "name", "attributes": {"content": "（努力地吹著笛子）", "name": "小滿"}, "figure_art": "avg_4122_grabds_1#5$1"}, {"id": 44, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4122_grabds_1#6$1"}}, {"id": 45, "prop": "name", "attributes": {"content": "大叔！大叔！我在這裡！快過來，別在樹林裡待著了！", "name": "小滿"}, "figure_art": "avg_4122_grabds_1#6$1"}, {"id": 46, "prop": "name", "attributes": {"content": "跟我一起走吧！我們回家去！", "name": "小滿"}, "figure_art": "avg_4122_grabds_1#6$1"}, {"id": 47, "prop": "PlaySound", "attributes": {"key": "$d_avg_hgmlgscrm"}}, {"id": 48, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1244_1#3$1"}}, {"id": 49, "prop": "name", "attributes": {"content": "（尖嘯）", "name": "詭異的織物"}, "figure_art": "avg_npc_1244_1#3$1"}, {"id": 50, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 51, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4122_grabds_1#7$1"}}, {"id": 52, "prop": "name", "attributes": {"content": "——！", "name": "小滿"}, "figure_art": "avg_4122_grabds_1#7$1"}, {"id": 53, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4122_grabds_1#6$1"}}, {"id": 54, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 55, "prop": "name", "attributes": {"content": "別以為我怕你！醜東西，滾開——！！", "name": "小滿"}, "figure_art": "avg_4122_grabds_1#6$1"}, {"id": 56, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4122_grabds_1#7$1"}}, {"id": 57, "prop": "name", "attributes": {"content": "……啊！", "name": "小滿"}, "figure_art": "avg_4122_grabds_1#7$1"}, {"id": 58, "prop": "dialog", "attributes": {}}, {"id": 59, "prop": "PlaySound", "attributes": {"key": "$d_avg_hammer", "volume": 0.8}}, {"id": 60, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 61, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1244_1#3$1"}}, {"id": 62, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 63, "prop": "PlaySound", "attributes": {"key": "$d_avg_hgmdspr"}}, {"id": 64, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 65, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 66, "prop": "name", "attributes": {"content": "一柄長斧釘在詭異怪物的正胸口，怪物奮力地鼓起身軀，最後絲線脫力地四散，鋪在地上。"}}, {"id": 67, "prop": "name", "attributes": {"content": "長斧脫手後，樵夫的手還維持著擲出武器的動作，雙眼看不清，他低頭側耳，細細分辨著四周的聲音。"}}, {"id": 68, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4122_grabds_1#7$1"}}, {"id": 69, "prop": "name", "attributes": {"content": "大叔！終於找到你了！", "name": "小滿"}, "figure_art": "avg_4122_grabds_1#7$1"}, {"id": 70, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4122_grabds_1#5$1"}}, {"id": 71, "prop": "name", "attributes": {"content": "我在這裡！你快過來！我帶你去安全的地方！", "name": "小滿"}, "figure_art": "avg_4122_grabds_1#5$1"}, {"id": 72, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 73, "prop": "name", "attributes": {"content": "樵夫側耳聽了聽，朝小滿的方向望去。"}}, {"id": 74, "prop": "PlaySound", "attributes": {"key": "$d_avg_grass"}}, {"id": 75, "prop": "name", "attributes": {"content": "隨即他再度提起斧子，轉身準備走向樹林。"}}, {"id": 76, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4122_grabds_1#7$1"}}, {"id": 77, "prop": "name", "attributes": {"content": "大叔？大叔！前面很危險，你不能回去了！", "name": "小滿"}, "figure_art": "avg_4122_grabds_1#7$1"}, {"id": 78, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4122_grabds_1#5$1"}}, {"id": 79, "prop": "name", "attributes": {"content": "小滿橫起笛子，努力平了平氣息，吹起了曲子。"}}, {"id": 80, "prop": "PlaySound", "attributes": {"key": "$d_avg_relaxflutem", "volume": 0.6}}, {"id": 81, "prop": "charslot", "attributes": {"duration": 0.5}}, {"id": 82, "prop": "name", "attributes": {"content": "花開了，快回家吧♪"}}, {"id": 83, "prop": "name", "attributes": {"content": "你聽，你聽，是我在呼喚你回來♪"}}, {"id": 84, "prop": "name", "attributes": {"content": "樵夫並沒有停下腳步。幾頭怪物在草叢中俯身，橫在小滿的身前。"}}, {"id": 85, "prop": "name", "attributes": {"content": "他渾濁的眼睛看不清眼前的事物，天地彷彿在眼前無盡地旋轉。他渾身的血液都在轟鳴，他再聽不見任何聲音。"}}, {"id": 86, "prop": "name", "attributes": {"content": "直到那一聲清脆的驚呼像一根針刺入他的耳朵。"}}, {"id": 87, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 88, "prop": "name", "attributes": {"content": "啊！！", "name": "小滿"}, "figure_art": "avg_4122_grabds_1#5$1"}, {"id": 89, "prop": "charslot", "attributes": {}}, {"id": 90, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1243_1#4$1"}}, {"id": 91, "prop": "name", "attributes": {"content": "——？！", "name": "沉默的樵夫"}, "figure_art": "avg_npc_1243_1#4$1"}, {"id": 92, "prop": "charslot", "attributes": {}}, {"id": 93, "prop": "name", "attributes": {"content": "小滿轉身想跑，但她隨即又橫起笛子，更尖銳的笛聲傳入他的耳朵。"}}, {"id": 94, "prop": "PlaySound", "attributes": {"key": "$d_avg_relaxflutem"}}, {"id": 95, "prop": "name", "attributes": {"content": "花開了，快回家吧♪"}}, {"id": 96, "prop": "name", "attributes": {"content": "你聽，你聽，是我在呼喚你回來♪"}}, {"id": 97, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1243_1#2$1"}}, {"id": 98, "prop": "name", "attributes": {"content": "（……花開了，該回家了……）", "name": "沉默的樵夫"}, "figure_art": "avg_npc_1243_1#2$1"}, {"id": 99, "prop": "dialog", "attributes": {}}, {"id": 100, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,0", "posto": "100,0", "duration": 1.0}}, {"id": 101, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 102, "prop": "name", "attributes": {"content": "他往前邁了一步。"}}, {"id": 103, "prop": "name", "attributes": {"content": "一隻白生生的小手牽住了他的手指。"}}, {"id": 104, "prop": "dialog", "attributes": {}}, {"id": 105, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4122_grabds_1#2$1", "duration": 1.0}}, {"id": 106, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 107, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1243_1#1$1", "focus": "m"}}, {"id": 108, "prop": "name", "attributes": {"content": "……", "name": "沉默的樵夫"}, "figure_art": "avg_npc_1243_1#1$1"}, {"id": 109, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4122_grabds_1#8$1", "focus": "l"}}, {"id": 110, "prop": "name", "attributes": {"content": "大叔，我們走吧……你不認識回家的路了嗎？", "name": "小滿"}, "figure_art": "avg_4122_grabds_1#8$1"}, {"id": 111, "prop": "name", "attributes": {"content": "你為什麼不想回去？你怕嚇到別人是不是？", "name": "小滿"}, "figure_art": "avg_4122_grabds_1#8$1"}, {"id": 112, "prop": "name", "attributes": {"content": "我保證，大家不會再怕你了，也不會再把你當怪人了……誰再敢說你的壞話，我一個個用笛子敲他們的頭！", "name": "小滿"}, "figure_art": "avg_4122_grabds_1#8$1"}, {"id": 113, "prop": "name", "attributes": {"content": "我們一起回去，好嗎……", "name": "小滿"}, "figure_art": "avg_4122_grabds_1#8$1"}, {"id": 114, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 115, "prop": "name", "attributes": {"content": "他臂膀上繫著的紅綢突然鬆開，被風吹著一卷，悠悠飛向天空。"}}, {"id": 116, "prop": "name", "attributes": {"content": "樵夫渾濁的眼滾出大滴大滴的淚水，但小滿渾然未覺。"}}, {"id": 117, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1243_1#2$1", "focus": "m"}}, {"id": 118, "prop": "name", "attributes": {"content": "……", "name": "沉默的樵夫"}, "figure_art": "avg_npc_1243_1#2$1"}, {"id": 119, "prop": "dialog", "attributes": {}}, {"id": 120, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1244_1#3$1", "posfrom": "500,0", "posto": "400,0", "duration": 1.0}}, {"id": 121, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 122, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1243_1#7$1", "focus": "m"}}, {"id": 123, "prop": "name", "attributes": {"content": "——？", "name": "沉默的樵夫"}, "figure_art": "avg_npc_1243_1#7$1"}, {"id": 124, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomn