ibutes": {"key": "$d_avg_punch", "volume": 0.7}}, {"id": 148, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 149, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 150, "prop": "PlaySound", "attributes": {"key": "$d_avg_hgmdspr"}}, {"id": 151, "prop": "charslot", "attributes": {"duration": 0.5}}, {"id": 152, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 153, "prop": "charslot", "attributes": {}}, {"id": 154, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4119_wanqin_1#5$1", "posfrom": "150,0", "posto": "0,0", "duration": 0.5}}, {"id": 155, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4121_zuole_1#4$1", "posfrom": "-150,0", "posto": "0,0", "duration": 0.5}}, {"id": 156, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 157, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4119_wanqin_1#5$1", "focus": "r"}}, {"id": 158, "prop": "name", "attributes": {"content": "到底還有多少……這些怪物真的殺不完嗎？", "name": "禾生"}, "figure_art": "avg_4119_wanqin_1#5$1"}, {"id": 159, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4121_zuole_1#4$1", "focus": "l"}}, {"id": 160, "prop": "name", "attributes": {"content": "只能盡量把它們擋在這裡……", "name": "左樂"}, "figure_art": "avg_4121_zuole_1#4$1"}, {"id": 161, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4119_wanqin_1#8$1", "focus": "r"}}, {"id": 162, "prop": "name", "attributes": {"content": "說是讓大家不要害怕……怎麼可能……", "name": "禾生"}, "figure_art": "avg_4119_wanqin_1#8$1"}, {"id": 163, "prop": "name", "attributes": {"content": "誰見過這種陣仗……", "name": "禾生"}, "figure_art": "avg_4119_wanqin_1#8$1"}, {"id": 164, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 165, "prop": "name", "attributes": {"content": "眼前是廣闊的田野，長相可怕的怪物仍在源源不絕地從地裡長出，難以計數。"}}, {"id": 166, "prop": "name", "attributes": {"content": "在二人身後，人們排起漫長的隊伍，向中央城區緩緩行進。"}}, {"id": 167, "prop": "name", "attributes": {"content": "隊伍中不斷有哭聲傳來。精通源石技藝的土木天師勉強構築起防線，擋在人群和怪物之間。"}}, {"id": 168, "prop": "dialog", "attributes": {}}, {"id": 169, "prop": "PlaySound", "attributes": {"key": "$smallearthquake"}}, {"id": 170, "prop": "CameraShake", "attributes": {"duration": 2.5, "xstrength": 10.0, "ystrength": 5.0, "vibrato": 50.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 171, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 172, "prop": "name", "attributes": {"content": "腳下的土地一陣震動，緊接著，人群中又傳來幾聲哭泣。"}}, {"id": 173, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4121_zuole_1#1$1", "focus": "l"}}, {"id": 174, "prop": "name", "attributes": {"content": "怎麼回事？", "name": "左樂"}, "figure_art": "avg_4121_zuole_1#1$1"}, {"id": 175, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4119_wanqin_1#9$1", "focus": "r"}}, {"id": 176, "prop": "name", "attributes": {"content": "那一塊移動地塊已經和核心城脫節了。", "name": "禾生"}, "figure_art": "avg_4119_wanqin_1#9$1"}, {"id": 177, "prop": "name", "attributes": {"content": "試驗田土壤各種參數的控制，都依賴核心城的能源供給……現在切斷能源，那片田也廢了。", "name": "禾生"}, "figure_art": "avg_4119_wanqin_1#9$1"}, {"id": 178, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4121_zuole_1#10$1", "focus": "l"}}, {"id": 179, "prop": "name", "attributes": {"content": "……", "name": "左樂"}, "figure_art": "avg_4121_zuole_1#10$1"}, {"id": 180, "prop": "Dialog", "attributes": {}}, {"id": 181, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 182, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1249_1#1$1", "focus": "l"}}, {"id": 183, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1250_1#1$1", "focus": "r"}}, {"id": 184, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 185, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1250_1#1$1", "focus": "r"}}, {"id": 186, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 187, "prop": "name", "attributes": {"content": "*炎國粗口*，哪裡來的畜生。我們多少年的心血，都被你們害的，全沒了！", "name": "怨恨的職農"}, "figure_art": "avg_npc_1250_1#1$1"}, {"id": 188, "prop": "name", "attributes": {"content": "在這種了這麼多年地，什麼時候受過這種委屈。", "name": "怨恨的職農"}, "figure_art": "avg_npc_1250_1#1$1"}, {"id": 189, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1249_1#1$1", "focus": "l"}}, {"id": 190, "prop": "name", "attributes": {"content": "*炎國粗口*，對啊！憑什麼要我們跑？", "name": "憤怒的職農"}, "figure_art": "avg_npc_1249_1#1$1"}, {"id": 191, "prop": "name", "attributes": {"content": "這些畜生要毀我們的地，啃我們的莊稼，我們就和它們拚到底！", "name": "憤怒的職農"}, "figure_art": "avg_npc_1249_1#1$1"}, {"id": 192, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 193, "prop": "name", "attributes": {"content": "大家一起上，和這些畜生拼了！", "name": "憤怒的職農"}, "figure_art": "avg_npc_1249_1#1$1"}, {"id": 194, "prop": "charslot", "attributes": {}}, {"id": 195, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4121_zuole_1#6$1"}}, {"id": 196, "prop": "name", "attributes": {"content": "大家——當心……", "name": "左樂"}, "figure_art": "avg_npc_1249_1#1$1"}, {"id": 197, "prop": "charslot", "attributes": {}}, {"id": 198, "prop": "name", "attributes": {"content": "有人撿起遺落在田間的鋤頭，回過頭衝向了未知的怪物。鋤頭狠狠落在怪物的頭上，居然讓怪物退了一步。"}}, {"id": 199, "prop": "name", "attributes": {"content": "職農不顧一切地撿起手邊的物件向怪物們丟去，石頭、農具。"}}, {"id": 200, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 201, "prop": "playsound", "attributes": {"key": "$bottlebroken"}}, {"id": 202, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 203, "prop": "name", "attributes": {"content": "被隨手擲出的一瓶對付害獸的農藥砸在怪物身上，瓶子碎裂，怪物發出哀鳴。"}}, {"id": 204, "prop": "playsound", "attributes": {"key": "$d_avg_hgmscrmh"}}, {"id": 205, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1244_1#3$1"}}, {"id": 206, "prop": "name", "attributes": {"content": "（痛苦的鳴叫）", "name": "詭異的織物"}, "figure_art": "avg_npc_1249_1#1$1"}, {"id": 207, "prop": "dialog", "attributes": {}}, {"id": 208, "prop": "PlaySound", "attributes": {"key": "$d_avg_hgmdspr"}}, {"id": 209, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 210, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 211, "prop": "playMusic", "attributes": {"intro": "$m_bat_bitw1_intro", "key": "$m_bat_bitw1_loop", "volume": 0.6}}, {"id": 212, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4121_zuole_1#10$1"}}, {"id": 213, "prop": "name", "attributes": {"content": "這也……可以？", "name": "左樂"}, "figure_art": "avg_4121_zuole_1#10$1"}, {"id": 214, "prop": "charslot", "attributes": {}}, {"id": 215, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1249_1#1$1", "focus": "r"}}, {"id": 216, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1250_1#1$1", "focus": "r"}}, {"id": 217, "prop": "name", "attributes": {"content": "……打……打死了……？", "name": "慌張的職農"}, "figure_art": "avg_npc_1250_1#1$1"}, {"id": 218, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1249_1#1$1", "focus": "l"}}, {"id": 219, "prop": "name", "attributes": {"content": "有用！這個有用！", "name": "激動的職農"}, "figure_art": "avg_npc_1249_1#1$1"}, {"id": 220, "prop": "name", "attributes": {"content": "我明白了！這些東西都是那些田裡的害獸變的！", "name": "激動的職農"}, "figure_art": "avg_npc_1249_1#1$1"}, {"id": 221, "prop": "name", "attributes": {"content": "*炎國粗口*，什麼妖魔鬼怪，說到底不還是一回事。", "name": "激動的職農"}, "figure_art": "avg_npc_1249_1#1$1"}, {"id": 222, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 223, "prop": "name", "attributes": {"content": "都別害怕！大家抄傢伙，把這些糟蹋莊稼的畜生收拾了！", "name": "激動的職農"}, "figure_art": "avg_npc_1249_1#1$1"}, {"id": 224, "prop": "charslot", "attributes": {"duration": 0.5}}, {"id": 225, "prop": "PlaySound", "attributes": {"key": "$d_avg_riot", "volume": 0.0, "channel": "a", "loop": "true"}}, {"id": 226, "prop": "SoundVolume", "attributes": {"volume": 0.5, "fadetime": 3.0, "channel": "a"}}, {"id": 227, "prop": "name", "attributes": {"content": "緊接著，越來越多的人拿起手邊的工具加入了防線。有人卯足力氣唱起了戲。"}}, {"id": 228, "prop": "dialog", "attributes": {}}, {"id": 229, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 230, "prop": "Subtitle", "attributes": {"text": "平莽原定溝壑氣沖霄漢，憑壯志戰凌雲直面河山！\\n東風烈，照霜月，天時難定，驚雷聲咽♪", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 231, "prop": "Subtitle", "attributes": {"text": "願稻香天南地北齊招展，哪怕是酷旱洪水也撲上前！\\n我恨不能以身做雲化春雨，迎接春色人間♪", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 232, "prop": "subtitle", "attributes": {}}, {"id": 233, "prop": "Dialog", "attributes": {}}, {"id": 234, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 235, "prop": "stopsound", "attributes": {"channel": "a", "fadetime": 3.0}}, {"id": 236, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 237, "prop": "charslot", "attributes": {}}, {"id": 238, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 239, "prop": "Background", "attributes": {"image": "47_g13_pollutedfield", "screenadapt": "coverall"}}, {"id": 240, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 241, "prop": "playMusic", "attributes": {"intro": "$storyendjp_intro", "key": "$storyendjp_loop", "volume": 0.6}}, {"id": 242, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 243, "prop":