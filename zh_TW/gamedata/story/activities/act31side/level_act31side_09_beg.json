lay", "attributes": {"time": 1.0}}, {"id": 277, "prop": "name", "attributes": {"content": "你們從那顆“心臟”裡逃出來，動作比我預想的要快一點。我的妹妹們心態也成熟了不少啊。", "name": "績"}, "figure_art": "avg_npc_1236_1#9$1"}, {"id": 278, "prop": "charslot", "attributes": {}}, {"id": 279, "prop": "charslot", "attributes": {"slot": "l", "name": "avgnew_2014_nian_1#3$1", "focus": "r"}}, {"id": 280, "prop": "charslot", "attributes": {"slot": "r", "name": "avgnew_2015_dusk_1#5$1", "focus": "r"}}, {"id": 281, "prop": "name", "attributes": {"content": "別說得好像大家關係很好一樣。", "name": "夕"}, "figure_art": "avgnew_2015_dusk_1#5$1"}, {"id": 282, "prop": "charslot", "attributes": {"slot": "l", "name": "avgnew_2014_nian_1#3$1", "focus": "l"}}, {"id": 283, "prop": "name", "attributes": {"content": "你當這是考驗？我還以為你是存心想幹掉我們來著。", "name": "年"}, "figure_art": "avgnew_2014_nian_1#3$1"}, {"id": 284, "prop": "charslot", "attributes": {}}, {"id": 285, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1236_1#7$1"}}, {"id": 286, "prop": "name", "attributes": {"content": "怎會……", "name": "績"}, "figure_art": "avgnew_2014_nian_1#3$1"}, {"id": 287, "prop": "charslot", "attributes": {}}, {"id": 288, "prop": "charslot", "attributes": {"slot": "l", "name": "avgnew_2014_nian_1#3$1", "focus": "l"}}, {"id": 289, "prop": "charslot", "attributes": {"slot": "r", "name": "avgnew_2015_dusk_1#5$1", "focus": "l"}}, {"id": 290, "prop": "name", "attributes": {"content": "原來你銷聲匿跡這麼多年，就是為了織這匹布。", "name": "年"}, "figure_art": "avgnew_2014_nian_1#3$1"}, {"id": 291, "prop": "name", "attributes": {"content": "拿大炎“國祚”織衣服，真有你的。", "name": "年"}, "figure_art": "avgnew_2014_nian_1#3$1"}, {"id": 292, "prop": "charslot", "attributes": {}}, {"id": 293, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1236_1#9$1"}}, {"id": 294, "prop": "name", "attributes": {"content": "他去見祂之前，需要這個東西。", "name": "績"}, "figure_art": "avgnew_2014_nian_1#3$1"}, {"id": 295, "prop": "name", "attributes": {"content": "走遍了炎國各地，最後決定要把大荒城織進去的時候，還是有些捨不得。", "name": "績"}, "figure_art": "avgnew_2014_nian_1#3$1"}, {"id": 296, "prop": "charslot", "attributes": {}}, {"id": 297, "prop": "charslot", "attributes": {"slot": "l", "name": "avgnew_2014_nian_1#3$1", "focus": "r"}}, {"id": 298, "prop": "charslot", "attributes": {"slot": "r", "name": "avgnew_2015_dusk_1#5$1", "focus": "r"}}, {"id": 299, "prop": "name", "attributes": {"content": "你們果然是串通好的——", "name": "夕"}, "figure_art": "avgnew_2015_dusk_1#5$1"}, {"id": 300, "prop": "name", "attributes": {"content": "他難道都已經準備好了……？", "name": "夕"}, "figure_art": "avgnew_2015_dusk_1#5$1"}, {"id": 301, "prop": "charslot", "attributes": {"slot": "l", "name": "avgnew_2014_nian_1#3$1", "focus": "l"}}, {"id": 302, "prop": "name", "attributes": {"content": "我早該想到，你才是最容易和那個臭棋簍子聊得來的。", "name": "年"}, "figure_art": "avgnew_2014_nian_1#3$1"}, {"id": 303, "prop": "name", "attributes": {"content": "別說你不知道，你把這匹布從這裡帶出去，意味著什麼。", "name": "年"}, "figure_art": "avgnew_2014_nian_1#3$1"}, {"id": 304, "prop": "name", "attributes": {"content": "這是對炎國明晃晃的宣戰。", "name": "年"}, "figure_art": "avgnew_2014_nian_1#3$1"}, {"id": 305, "prop": "charslot", "attributes": {}}, {"id": 306, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1236_1#9$1"}}, {"id": 307, "prop": "name", "attributes": {"content": "那又如何？", "name": "績"}, "figure_art": "avgnew_2014_nian_1#3$1"}, {"id": 308, "prop": "charslot", "attributes": {}}, {"id": 309, "prop": "charslot", "attributes": {"slot": "l", "name": "avgnew_2014_nian_1#7$1", "focus": "l"}}, {"id": 310, "prop": "charslot", "attributes": {"slot": "r", "name": "avgnew_2015_dusk_1#5$1", "focus": "l"}}, {"id": 311, "prop": "name", "attributes": {"content": "三哥，說實話，在幾個哥哥姐姐裡我還挺喜歡你的。總覺得很多時候我們能碰撞出挺不錯的主意來著。", "name": "年"}, "figure_art": "avgnew_2014_nian_1#7$1"}, {"id": 312, "prop": "charslot", "attributes": {"slot": "l", "name": "avgnew_2014_nian_1#4$1", "focus": "l"}}, {"id": 313, "prop": "name", "attributes": {"content": "早些時候，你拉著我到處賣夕的贗品畫，我也幫了你不是？", "name": "年"}, "figure_art": "avgnew_2014_nian_1#4$1"}, {"id": 314, "prop": "charslot", "attributes": {"slot": "r", "name": "avgnew_2015_dusk_1#6$1", "focus": "r"}}, {"id": 315, "prop": "name", "attributes": {"content": "還有這種事？！", "name": "夕"}, "figure_art": "avgnew_2015_dusk_1#6$1"}, {"id": 316, "prop": "charslot", "attributes": {"slot": "l", "name": "avgnew_2014_nian_1#3$1", "focus": "l"}}, {"id": 317, "prop": "name", "attributes": {"content": "但抱歉啦，這一次，連我都覺得你還是太激進了點。", "name": "年"}, "figure_art": "avgnew_2014_nian_1#3$1"}, {"id": 318, "prop": "charslot", "attributes": {}}, {"id": 319, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1236_1#9$1"}}, {"id": 320, "prop": "name", "attributes": {"content": "可惜。", "name": "績"}, "figure_art": "avgnew_2014_nian_1#3$1"}, {"id": 321, "prop": "name", "attributes": {"content": "看起來，夕妹也不願意站在我這邊了？", "name": "績"}, "figure_art": "avgnew_2014_nian_1#3$1"}, {"id": 322, "prop": "charslot", "attributes": {}}, {"id": 323, "prop": "charslot", "attributes": {"slot": "l", "name": "avgnew_2014_nian_1#3$1", "focus": "r"}}, {"id": 324, "prop": "charslot", "attributes": {"slot": "r", "name": "avgnew_2015_dusk_1#5$1", "focus": "r"}}, {"id": 325, "prop": "name", "attributes": {"content": "做夢。", "name": "夕"}, "figure_art": "avgnew_2015_dusk_1#5$1"}, {"id": 326, "prop": "charslot", "attributes": {"slot": "l", "name": "avgnew_2014_nian_1#4$1", "focus": "l"}}, {"id": 327, "prop": "name", "attributes": {"content": "幾百年沒有搞過三人以上的家庭派對了，要做的第一件事居然是回到打打殺殺的時候。", "name": "年"}, "figure_art": "avgnew_2014_nian_1#4$1"}, {"id": 328, "prop": "name", "attributes": {"content": "這算什麼，憶苦飯？", "name": "年"}, "figure_art": "avgnew_2014_nian_1#4$1"}, {"id": 329, "prop": "charslot", "attributes": {}}, {"id": 330, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1236_1#9$1"}}, {"id": 331, "prop": "name", "attributes": {"content": "能和和氣氣談判解決的事，我也希望可以不用動手。", "name": "績"}, "figure_art": "avgnew_2014_nian_1#4$1"}, {"id": 332, "prop": "name", "attributes": {"content": "對妹妹，我怎麼下得了手呢？", "name": "績"}, "figure_art": "avgnew_2014_nian_1#4$1"}, {"id": 333, "prop": "charslot", "attributes": {}}, {"id": 334, "prop": "charslot", "attributes": {"slot": "l", "name": "avgnew_2014_nian_1#4$1", "focus": "l"}}, {"id": 335, "prop": "charslot", "attributes": {"slot": "r", "name": "avgnew_2015_dusk_1#5$1", "focus": "l"}}, {"id": 336, "prop": "name", "attributes": {"content": "先別說大話，二對一，你贏面沒那麼大。", "name": "年"}, "figure_art": "avgnew_2014_nian_1#4$1"}, {"id": 337, "prop": "charslot", "attributes": {}}, {"id": 338, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1236_1#1$1"}}, {"id": 339, "prop": "name", "attributes": {"content": "那就只能試試看了。", "name": "績"}, "figure_art": "avgnew_2014_nian_1#4$1"}, {"id": 340, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1236_1#4$1"}}, {"id": 341, "prop": "name", "attributes": {"content": "這一次，就算當年大狩獵的那支軍隊站在這裡，也攔不住我。", "name": "績"}, "figure_art": "avgnew_2014_nian_1#4$1"}, {"id": 342, "prop": "Dialog", "attributes": {}}, {"id": 343, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 344, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 345, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 346, "prop": "Image", "attributes": {}}, {"id": 347, "prop": "charslot", "attributes": {}}, {"id": 348, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}