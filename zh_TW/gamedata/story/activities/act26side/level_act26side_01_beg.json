es": {"slot": "m", "name": "avg_npc_490_1#1$1"}}, {"id": 283, "prop": "name", "attributes": {"content": "看來今天會是客人很多的一天。", "name": "阿爾圖羅"}, "figure_art": "avg_npc_490_1#1$1"}, {"id": 284, "prop": "name", "attributes": {"content": "您好，杰拉爾德先生。", "name": "阿爾圖羅"}, "figure_art": "avg_npc_490_1#1$1"}, {"id": 285, "prop": "dialog", "attributes": {}}, {"id": 286, "prop": "charslot", "attributes": {}}, {"id": 287, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 288, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_926_1#1$2", "duration": 1.5}}, {"id": 289, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 290, "prop": "name", "attributes": {"content": "我本以為能在這裡見到斯特凡諾。", "name": "杰拉爾德"}, "figure_art": "avg_npc_926_1#1$2"}, {"id": 291, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_490_1#1$1"}}, {"id": 292, "prop": "name", "attributes": {"content": "主教閣下還有不少事務要處理，剛剛才離開。", "name": "阿爾圖羅"}, "figure_art": "avg_npc_490_1#1$1"}, {"id": 293, "prop": "name", "attributes": {"content": "我想他應該還沒走多遠，以您的腳力，現在追上去應該還來得及。", "name": "阿爾圖羅"}, "figure_art": "avg_npc_490_1#1$1"}, {"id": 294, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_926_1#1$2"}}, {"id": 295, "prop": "name", "attributes": {"content": "多謝。", "name": "杰拉爾德"}, "figure_art": "avg_npc_926_1#1$2"}, {"id": 296, "prop": "name", "attributes": {"content": "......", "name": "杰拉爾德"}, "figure_art": "avg_npc_926_1#1$2"}, {"id": 297, "prop": "name", "attributes": {"content": "......你今天還沒有拉響琴弦。", "name": "杰拉爾德"}, "figure_art": "avg_npc_926_1#1$2"}, {"id": 298, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_490_1#8$1"}}, {"id": 299, "prop": "name", "attributes": {"content": "如果您喜歡我的琴聲的話，我可以現在就為您演奏一曲。", "name": "阿爾圖羅"}, "figure_art": "avg_npc_490_1#8$1"}, {"id": 300, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_926_1#1$2"}}, {"id": 301, "prop": "name", "attributes": {"content": "不用了。", "name": "杰拉爾德"}, "figure_art": "avg_npc_926_1#1$2"}, {"id": 302, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_926_1#6$2"}}, {"id": 303, "prop": "name", "attributes": {"content": "你給一些......我們的人帶來了快樂，對此我很感激。", "name": "杰拉爾德"}, "figure_art": "avg_npc_926_1#6$2"}, {"id": 304, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_926_1#1$2"}}, {"id": 305, "prop": "name", "attributes": {"content": "但並不是所有人都可以從你的音樂中得到安慰的，至少我不行。", "name": "杰拉爾德"}, "figure_art": "avg_npc_926_1#1$2"}, {"id": 306, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_926_1#10$2"}}, {"id": 307, "prop": "name", "attributes": {"content": "我不知道像你這樣的音樂家為何會在這個地方逗留......我只希望你不會為這裡帶來災難。", "name": "杰拉爾德"}, "figure_art": "avg_npc_926_1#10$2"}, {"id": 308, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_490_1#1$1"}}, {"id": 309, "prop": "name", "attributes": {"content": "您太高看我了。", "name": "阿爾圖羅"}, "figure_art": "avg_npc_490_1#1$1"}, {"id": 310, "prop": "name", "attributes": {"content": "據我所知，災難總是在最初就被埋藏在土壤裡，而後生根發芽，開花結果。", "name": "阿爾圖羅"}, "figure_art": "avg_npc_490_1#1$1"}, {"id": 311, "prop": "name", "attributes": {"content": "如果這片花圃裡真有這麼一粒種子，那麼它遲早會破土而出。", "name": "阿爾圖羅"}, "figure_art": "avg_npc_490_1#1$1"}, {"id": 312, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_490_1#2$1"}}, {"id": 313, "prop": "name", "attributes": {"content": "而我......充其量只是一個將這一切納入眼簾的過客。", "name": "阿爾圖羅"}, "figure_art": "avg_npc_490_1#2$1"}, {"id": 314, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_926_1#1$2"}}, {"id": 315, "prop": "name", "attributes": {"content": "......不會有什麼不該發芽的種子。", "name": "杰拉爾德"}, "figure_art": "avg_npc_926_1#1$2"}, {"id": 316, "prop": "name", "attributes": {"content": "要不了多久，一切都會回歸正軌，不會有意外，更不會有災難。", "name": "杰拉爾德"}, "figure_art": "avg_npc_926_1#1$2"}, {"id": 317, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_926_1#9$2"}}, {"id": 318, "prop": "name", "attributes": {"content": "小姐，請不要做多餘的事。", "name": "杰拉爾德"}, "figure_art": "avg_npc_926_1#9$2"}, {"id": 319, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_490_1#1$1"}}, {"id": 320, "prop": "name", "attributes": {"content": "這是您給我的忠告？", "name": "阿爾圖羅"}, "figure_art": "avg_npc_490_1#1$1"}, {"id": 321, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_926_1#1$2"}}, {"id": 322, "prop": "name", "attributes": {"content": "不。", "name": "杰拉爾德"}, "figure_art": "avg_npc_926_1#1$2"}, {"id": 323, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_926_1#5$2"}}, {"id": 324, "prop": "name", "attributes": {"content": "這是我的警告。", "name": "杰拉爾德"}, "figure_art": "avg_npc_926_1#5$2"}, {"id": 325, "prop": "dialog", "attributes": {}}, {"id": 326, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 327, "prop": "charslot", "attributes": {"duration": 0.5}}, {"id": 328, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 329, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_490_1#7$1"}}, {"id": 330, "prop": "name", "attributes": {"content": "真是有夠不講情面，不過沒有直接動手，應該已經算是很手下留情了吧。", "name": "阿爾圖羅"}, "figure_art": "avg_npc_490_1#7$1"}, {"id": 331, "prop": "name", "attributes": {"content": "該說不愧是老前輩嗎？", "name": "阿爾圖羅"}, "figure_art": "avg_npc_490_1#7$1"}, {"id": 332, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_490_1#4$1"}}, {"id": 333, "prop": "name", "attributes": {"content": "......嗯？", "name": "阿爾圖羅"}, "figure_art": "avg_npc_490_1#4$1"}, {"id": 334, "prop": "dialog", "attributes": {}}, {"id": 335, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 336, "prop": "PlaySound", "attributes": {"key": "$dooropenquite", "volume": 0.5}}, {"id": 337, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 338, "prop": "name", "attributes": {"content": "......", "name": "？？？"}}, {"id": 339, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_490_1#8$1"}}, {"id": 340, "prop": "name", "attributes": {"content": "哎呀。", "name": "阿爾圖羅"}, "figure_art": "avg_npc_490_1#8$