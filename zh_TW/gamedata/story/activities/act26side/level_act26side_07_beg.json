_931_1#1$1"}, {"id": 393, "prop": "name", "attributes": {"content": "推門的響動太大，那些拉特蘭人很可能會注意到。我們出門就往右跑，右邊是雜草叢生的亂石堆，應該能藏住我們的行跡。", "name": "萊蒙德"}, "figure_art": "avg_npc_931_1#1$1"}, {"id": 394, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_931_1#11$1", "focus": "l"}}, {"id": 395, "prop": "name", "attributes": {"content": "準備好了嗎？我拉開門閂了。", "name": "萊蒙德"}, "figure_art": "avg_npc_931_1#11$1"}, {"id": 396, "prop": "Dialog", "attributes": {}}, {"id": 397, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_931_1#11$1", "focus": "all"}}, {"id": 398, "prop": "delay", "attributes": {"time": 0.2}}, {"id": 399, "prop": "PlaySound", "attributes": {"key": "$d_avg_woodgear", "volume": 1.0}}, {"id": 400, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 401, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 0.5}}, {"id": 402, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "channel": "escape3", "volume": 0.9, "loop": "false", "delay": 0.3}}, {"id": 403, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_927_1#1$2", "afrom": 1.0, "ato": 0.0, "duration": 0.7}}, {"id": 404, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_931_1#11$1", "afrom": 1.0, "ato": 0.0, "duration": 1.0}}, {"id": 405, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 406, "prop": "Dialog", "attributes": {}}, {"id": 407, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 408, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 409, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 410, "prop": "charslot", "attributes": {}}, {"id": 411, "prop": "Background", "attributes": {"image": "39_g4_gatheringplace_d", "screenadapt": "coverall", "block": "true"}}, {"id": 412, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 413, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 