: {"content": "站到我後面，福爾圖娜。", "name": "萊蒙德"}, "figure_art": "avg_npc_931_1#7$1"}, {"id": 436, "prop": "Dialog", "attributes": {}}, {"id": 437, "prop": "charslot", "attributes": {}}, {"id": 438, "prop": "PlaySound", "attributes": {"key": "$d_gen_transmissionget", "volume": 0.6}}, {"id": 439, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_366_1#1$1 ", "focus": "l"}}, {"id": 440, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_371_1#1$1", "focus": "l"}}, {"id": 441, "prop": "name", "attributes": {"content": "......第一小隊，正門發現薩卡茲。", "name": "老練的拉特蘭特勤隊成員"}, "figure_art": "avg_npc_366_1#1$1 "}, {"id": 442, "prop": "Dialog", "attributes": {}}, {"id": 443, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 444, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 445, "prop": "charslot", "attributes": {}}, {"id": 446, "prop": "Image", "attributes": {}}, {"id": 447, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}