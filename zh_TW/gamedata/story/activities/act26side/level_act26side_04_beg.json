ot", "attributes": {"slot": "r", "name": "avg_4015_spuria_1#1$1", "focus": "r"}}, {"id": 113, "prop": "name", "attributes": {"content": "當然可以。", "name": "斯普莉雅"}, "figure_art": "avg_4015_spuria_1#1$1"}, {"id": 114, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_927_1#4$2", "focus": "l"}}, {"id": 115, "prop": "name", "attributes": {"content": "......菲娜她，是不是已經......", "name": "福爾圖娜"}, "figure_art": "avg_npc_927_1#4$2"}, {"id": 116, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_927_1#1$2", "focus": "l"}}, {"id": 117, "prop": "name", "attributes": {"content": "已經不在了？", "name": "福爾圖娜"}, "figure_art": "avg_npc_927_1#1$2"}, {"id": 118, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4015_spuria_1#2$1", "focus": "r"}}, {"id": 119, "prop": "name", "attributes": {"content": "......如果可以的話，我比較希望你能換一個問題。", "name": "斯普莉雅"}, "figure_art": "avg_4015_spuria_1#2$1"}, {"id": 120, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4015_spuria_1#2$1", "focus": "r"}}, {"id": 121, "prop": "name", "attributes": {"content": "我不太想騙你。", "name": "斯普莉雅"}, "figure_art": "avg_4015_spuria_1#2$1"}, {"id": 122, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_927_1#4$2", "focus": "l"}}, {"id": 123, "prop": "name", "attributes": {"content": "......", "name": "福爾圖娜"}, "figure_art": "avg_npc_927_1#4$2"}, {"id": 124, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_927_1#5$2", "focus": "l"}}, {"id": 125, "prop": "name", "attributes": {"content": "我知道了。", "name": "福爾圖娜"}, "figure_art": "avg_npc_927_1#5$2"}, {"id": 126, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_927_1#5$2", "focus": "l"}}, {"id": 127, "prop": "name", "attributes": {"content": "其實我最開始就有這樣的感覺......", "name": "福爾圖娜"}, "figure_art": "avg_npc_927_1#5$2"}, {"id": 128, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_927_1#5$2", "focus": "l"}}, {"id": 129, "prop": "name", "attributes": {"content": "那個時候，我忽然就、就感受不到菲娜......明明她那時那麼生氣，又那麼難過......", "name": "福爾圖娜"}, "figure_art": "avg_npc_927_1#5$2"}, {"id": 130, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_927_1#5$2", "focus": "l"}}, {"id": 131, "prop": "name", "attributes": {"content": "她就在我面前啊......？我卻哪裡都找不到她......", "name": "福爾圖娜"}, "figure_art": "avg_npc_927_1#5$2"}, {"id": 132, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4015_spuria_1#2$1", "focus": "r"}}, {"id": 133, "prop": "name", "attributes": {"content": "......", "name": "斯普莉雅"}, "figure_art": "avg_4015_spuria_1#2$1"}, {"id": 134, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4015_spuria_1#2$1", "focus": "r"}}, {"id": 135, "prop": "name", "attributes": {"content": "如果當時，我沒幫你修那把銃......", "name": "斯普莉雅"}, "figure_art": "avg_4015_spuria_1#2$1"}, {"id": 136, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_927_1#6$2", "focus": "l"}}, {"id": 137, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 138, "prop": "name", "attributes": {"content": "別說了！", "name": "福爾圖娜"}, "figure_art": "avg_npc_927_1#6$2"}, {"id": 139, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4015_spuria_1#6$1", "focus": "r"}}, {"id": 140, "prop": "name", "attributes": {"content": "——！", "name": "斯普莉雅"}, "figure_art": "avg_4015_spuria_1#6$1"}, {"id": 141, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_927_1#5$2", "focus": "l"}}, {"id": 142, "prop": "name", "attributes": {"content": "......別說了，求你......", "name": "福爾圖娜"}, "figure_art": "avg_npc_927_1#5$2"}, {"id": 143, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4015_spuria_1#2$1", "focus": "r"}}, {"id": 144, "prop": "name", "attributes": {"content": "......好。", "name": "斯普莉雅"}, "figure_art": "avg_4015_spuria_1#2$1"}, {"id": 145, "prop": "charslot", "attributes": {}}, {"id": 146, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_927_1#10$2", "focus": "m"}}, {"id": 147, "prop": "name", "attributes": {"content": "......我頭頂的角，我摸到了。和萊蒙德他們一樣的角。", "name": "福爾圖娜"}, "figure_art": "avg_npc_927_1#10$2"}, {"id": 148, "prop": "name", "attributes": {"content": "雖然再也沒法握著銃祈禱，但至少現在......", "name": "福爾圖娜"}, "figure_art": "avg_npc_927_1#10$2"}, {"id": 149, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_927_1#1$2", "focus": "m"}}, {"id": 150, "prop": "name", "attributes": {"content": "我終於，和萊蒙德，和卡洛琳姐......", "name": "福爾圖娜"}, "figure_art": "avg_npc_927_1#1$2"}, {"id": 151, "prop": "name", "attributes": {"content": "我終於和大家都一樣了。", "name": "福爾圖娜"}, "figure_art": "avg_npc_927_1#1$2"}, {"id": 152, "prop": "Dialog", "attributes": {}}, {"id": 153, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 154, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 155, "prop": "charslot", "attributes": {}}, {"id": 156, "prop": "Background", "attributes": {"image": "39_g2_abandonsancturay", "screenadapt": "coverall"}}, {"id": 157, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 158, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 159, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_931_1#1$2", "focus": "m", "bstart": 0.2, "bend": 0.7, "afrom": 0.0, "ato": 1.0, "duration": 1.0}}, {"id": 160, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 161, "prop": "name", "attributes": {"content": "......", "name": "？？？"}, "figure_art": "avg_npc_931_1#1$2"}, {"id": 162, "prop": "name", "attributes": {"content": "哈，去年還沒這麼早開花，今年怎麼就這麼巧？", "name": "？？？"}, "figure_art": "avg_npc_931_1#1$2"}, {"id": 163, "prop": "dialog", "attributes": {}}, {"id": 164, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_931_1#1$2", "bstart": 0.0, "bend": 0.0, "duration": 0.5, "focus": "m"}}, {"id": 165, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 166, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_931_1#1$2", "focus": "m"}}, {"id": 167, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 168, "prop": "name", "attributes": {"content": "也好，好歹算是最後開了一回。", "name": "萊蒙德"}, "figure_art": "avg_npc_931_1#1$2"}, {"id": 169, "prop": "dialog", "attributes": {}}, {"id": 170, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 171, "prop": "playsound", "attributes": {"key": "$d_avg_cloakmovement"}}, {"id": 172, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_931_1#1$2", "posfrom": "0,0", "posto": "0,-50", "duration": 1.0, "isblock": "false"}}, {"id": 173, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_931_1#1$2", "afrom": 1.0, "ato": 0.0, "duration": 0.5}}, {"id": 174, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 175, "prop": "PlaySound", "attributes": {"key": "$d_avg_grass", "volume": 0.4}}, {"id": 176, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 177, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_931_1#8$1", "posfrom": "0,-50", "posto": "0,0", "afrom": 0.0, "ato": 1.0, "duration": 0.5}}, {"id": 178, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 179, "prop": "name", "attributes": {"content": "這樣一來......", "name": "萊蒙德"}, "figure_art": "avg_npc_931_1#8$1"}, {"id": 180, "prop": "dialog", "attributes": {}}, {"id": 181, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_931_1#8$1", "focus": "m"}}, {"id": 182, "prop": "name", "attributes": {"content": "......", "name": "萊蒙德"}, "figure_art": "avg_npc_931_1#8$1"}, {"id": 183, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_931_1#1$1", "focus": "m"}}, {"id": 184, "prop": "name", "attributes": {"content": "這樣就沒問題了......", "name": "萊蒙德"}, "figure_art": "avg_npc_931_1#1$1"}, {"id": 185, "prop": "Dialog", "attributes": {}}, {"id": 186, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 187, "prop": "charslot", "attributes": {}}, {"id": 188, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 189, "prop": "Background", "attributes": {"image": "39_g8_outsidepath", "screenadapt": "coverall"}}, {"id": 190, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 191, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 192, "prop": "playMusic", "attributes": {"intro": "$escape_intro", "key": "$escape_loop", "volume": 0.6}}, {"id": 193, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#3$1", "focus": "m"}}, {"id": 194, "prop": "name", "attributes": {"content": "你剛剛說......有薩科塔墮天？那個女孩叫福爾圖娜？", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#3$1"}, {"id": 195, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#1$1", "focus": "m"}}, {"id": 196, "prop": "name", "attributes": {"content": "是。", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#1$1"}, {"id": 197, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#7$1", "focus": "m"}}, {"id": 198, "prop": "name", "attributes": {"content": "竟然出了這樣的事......", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#7$1"}, {"id": 199, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#7$1", "focus": "m"}}, {"id": 200, "prop": "name", "attributes": {"content": "墮天......只能回去後由教宗閣下定奪，不是現在我們能夠處理的問題。", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#7$1"}, {"id": 201, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_924_1#5$1", "focus": "m"}}, {"id": 202, "prop": "name", "attributes": {"content": "......", "name": "克萊芒"}, "figure_art": "avg_npc_924_1#5$1"}, {"id": 203, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#7$1", "focus": "m"}}, {"id": 204, "prop": "name", "attributes": {"content": "但闖入我房間的那位不速之客不同。費德里科，有些事我之後再和你解釋......現在必須要儘快把那傢伙找出來才行。", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#7$1"}, {"id": 205, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#7$1", "focus": "m"}}, {"id": 206, "prop": "name", "attributes": {"content": "我需要你的協助，執行者費德里科。", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#7$1"}, {"id": 207, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#7$1", "focus": "m"}}, {"id": 208, "prop": "name", "attributes": {"content": "它的機動性不弱，我雖然勉強追到這裡，但還是追丟了......", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#7$1"}, {"id": 209, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#1$1", "focus": "m"}}, {"id": 210, "prop": "name", "attributes": {"content": "......", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#1$1"}, {"id": 211, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#4$1", "focus": "m"}}, {"id": 212, "prop": "name", "attributes": {"content": "咦，你居然沒有立刻回覆？", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#4$1"}, {"id": 213, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#4$1", "focus": "m"}}, {"id": 214, "prop": "name", "attributes": {"content": "很少見哦，你這樣子我會覺得是出了什麼大事......欸，你皺眉了，所以真的出了什麼大事嗎？", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#4$1"}, {"id": 215, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#4$1", "focus": "m"}}, {"id": 216, "prop": "name", "attributes": {"content": "......有琴聲。", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#4$1"}, {"id": 217, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#8$1", "focus": "m"}}, {"id": 218, "prop": "name", "attributes": {"content": "琴聲？有......嗎？我好像沒有聽到......", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#8$1"}, {"id": 219, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#4$1", "focus": "m"}}, {"id": 220, "prop": "name", "attributes": {"content": "據我推斷，琴聲是從頂層聖堂的方向傳來。", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#4$1"}, {"id": 221, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#8$1", "focus": "m"}}, {"id": 222, "prop": "name", "attributes": {"content": "這樣嗎......", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#8$1"}, {"id": 223, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#6$1", "focus": "m"}}, {"id": 224, "prop": "name", "attributes": {"content": "老實說呢，這段時間以來我對你在公證所的工作多少有所瞭解，因此我會比較信任你的判斷。", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#6$1"}, {"id": 225, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#6$1", "focus": "m"}}, {"id": 226, "prop": "name", "attributes": {"content": "現在我正式地詢問你——", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#6$1"}, {"id": 227, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#7$1", "focus": "m"}}, {"id": 228, "prop": "name", "attributes": {"content": "中庭公證所執行者費德里科，你真的認為這段來源不明，不確定影響，甚至有可能全然無害的琴聲——", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#7$1"}, {"id": 229, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#7$1", "focus": "m"}}, {"id": 230, "prop": "name", "attributes": {"content": "會比我向你提出的協助請求更加重要嗎？", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#7$1"}, {"id": 231, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#6$1", "focus": "m"}}, {"id": 232, "prop": "name", "attributes": {"content": "......", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#6$1"}, {"id": 233, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#6$1", "focus": "m"}}, {"id": 234, "prop": "name", "attributes": {"content": "不會。", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#6$1"}, {"id": 235, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#7$1", "focus": "m"}}, {"id": 236, "prop": "name", "attributes": {"content": "顯而易見。", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#7$1"}, {"id": 237, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#5$1", "focus": "m"}}, {"id": 238, "prop": "name", "attributes": {"content": "琴聲的出現是偶然事件，我對此有所懷疑，但不可否認的是，暫時找不到其與目前發生的所有事件之間的直接關聯。", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#5$1"}, {"id": 239, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#5$1", "focus": "m"}}, {"id": 240, "prop": "name", "attributes": {"content": "根據目前的形勢判斷，應優先執行協助任務，與你共同行動。", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#5$1"}, {"id": 241, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#5$1", "focus": "m"}}, {"id": 242, "prop": "name", "attributes": {"content": "......", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#5$1"}, {"id": 243, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#1$1", "focus": "m"}}, {"id": 244, "prop": "name", "attributes": {"content": "呵呵，不繼續說下去了嗎？", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#1$1"}, {"id": 245, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#1$1", "focus": "m"}}, {"id": 246, "prop": "name", "attributes": {"content": "好啦，我可沒有要欺負人的意思。只不過，我也確實需要確認一下你的態度......", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#1$1"}, {"id": 247, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#1$1", "focus": "m"}}, {"id": 248, "prop": "name", "attributes": {"content": "現在我明白了。", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#1$1"}, {"id": 249, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#7$1", "focus": "m"}}, {"id": 250, "prop": "name", "attributes": {"content": "給我指一個方向，我繼續追蹤目標，琴聲的事就交給你來解決。", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#7$1"}, {"id": 251, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#1$1", "focus": "m"}}, {"id": 252, "prop": "name", "attributes": {"content": "......本次任務需要優先確保你和奧倫的安全。", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#1$1"}, {"id": 253, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#6$1", "focus": "m"}}, {"id": 254, "prop": "name", "attributes": {"content": "盡職盡責是好事，但是我覺得優先度這種東西，是要自己判斷的哦。", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#6$1"}, {"id": 255, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#6$1", "focus": "m"}}, {"id": 256, "prop": "name", "attributes": {"content": "我感受不到你的情緒，費德里科。不過，我有一個黎博利朋友，因為無法和她共感，所以我早早學會了如何猜測他人的想法。", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#6$1"}, {"id": 257, "prop": "name", "attributes": {"content": "雖然她比你好懂很多，但有些東西是共通的。", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#6$1"}, {"id": 258, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#1$1", "focus": "m"}}, {"id": 259, "prop": "name", "attributes": {"content": "一個小小的忠告——或許有的時候，你得學會相信你的直覺。", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#1$1"}, {"id": 260, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#5$1", "focus": "m"}}, {"id": 261, "prop": "name", "attributes": {"content": "......", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#5$1"}, {"id": 262, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#1$1", "focus": "m"}}, {"id": 263, "prop": "name", "attributes": {"content": "就這麼定了，我們沒有多少時間可以浪費......我也得強迫自己活動一下。", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#1$1"}, {"id": 264, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_925_1#1$1", "focus": "m"}}, {"id": 265, "prop": "name", "attributes": {"content": "出發，大家行動起來~", "name": "蕾繆安"}, "figure_art": "avg_npc_925_1#1$1"}, {"id": 266, "prop": "Dialog", "attributes": {}}, {"id": 267, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 268, "prop": "charslot", "attributes": {}}, {"id": 269, "prop": "Background", "attributes": {"image": "39_g8_outsidepath", "screenadapt": "coverall"}}, {"id": 270, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 271, "prop": "PlaySound", "attributes": {"key": "$d_avg_crowdrun", "volume": 1.0}}, {"id": 272, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 273, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#1$1", "focus": "m"}}, {"id": 274, "prop": "name", "attributes": {"content": "加快速度。", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#1$1"}, {"id": 275, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_924_1#3$1", "focus": "m"}}, {"id": 276, "prop": "name", "attributes": {"content": "費德里科先生！請、請等一下！", "name": "克萊芒"}, "figure_art": "avg_npc_924_1#3$1"}, {"id": 277, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_924_1#3$1", "focus": "m"}}, {"id": 278, "prop": "name", "attributes": {"content": "上面到底......到底有什麼？只是琴聲而已，而且現在已經聽不到了啊！", "name": "克萊芒"}, "figure_art": "avg_npc_924_1#3$1"}, {"id": 279, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_924_1#3$1", "focus": "m"}}, {"id": 280, "prop": "name", "attributes": {"content": "我們、我們真的就讓那位小姐一個人去冒險嗎？她還坐著輪椅......", "name": "克萊芒"}, "figure_art": "avg_npc_924_1#3$1"}, {"id": 281, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#1$1", "focus": "m"}}, {"id": 282, "prop": "name", "attributes": {"content": "不用擔心。", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#1$1"}, {"id": 283, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_924_1#10$1", "focus": "m"}}, {"id": 284, "prop": "name", "attributes": {"content": "怎麼可能不擔心？我剛剛看到了......那是個怪物！", "name": "克萊芒"}, "figure_art": "avg_npc_924_1#10$1"}, {"id": 285, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#1$1", "focus": "m"}}, {"id": 286, "prop": "name", "attributes": {"content": "蕾繆安由第七廳樞機親自邀請加入教皇廳，實力不容小覷。", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#1$1"}, {"id": 287, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#1$1", "focus": "m"}}, {"id": 288, "prop": "name", "attributes": {"content": "不要小看她。", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#1$1"}, {"id": 289, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_924_1#3$1", "focus": "m"}}, {"id": 290, "prop": "name", "attributes": {"content": "我不太明白這些，也就是說，那位小姐也是很厲害的人？", "name": "克萊芒"}, "figure_art": "avg_npc_924_1#3$1"}, {"id": 291, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_924_1#3$1", "focus": "m"}}, {"id": 292, "prop": "name", "attributes": {"content": "可是......萬一呢？", "name": "克萊芒"}, "figure_art": "avg_npc_924_1#3$1"}, {"id": 293, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#6$1", "focus": "m"}}, {"id": 294, "prop": "name", "attributes": {"content": "......", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#6$1"}, {"id": 295, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#4$1", "focus": "m"}}, {"id": 296, "prop": "name", "attributes": {"content": "加快速度。或者留在原地等待。", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#4$1"}, {"id": 297, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#4$1", "focus": "m"}}, {"id": 298, "prop": "name", "attributes": {"content": "建議你選擇後者。這是更安全的選擇。", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#4$1"}, {"id": 299, "prop": "Dialog", "attributes": {}}, {"id": 300, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 301, "prop": "charslot", "attributes": {}}, {"id": 302, "prop": "Background", "attributes": {"image": "39_g2_abandonsancturay", "screenadapt": "coverall"}}, {"id": 303, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 304, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 305, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#6$1", "focus": "m"}}, {"id": 306, "prop": "name", "attributes": {"content": "......", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#6$1"}, {"id": 307, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#6$1", "focus": "m"}}, {"id": 308, "prop": "name", "attributes": {"content": "（沒有人？）", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#6$1"}, {"id": 309, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#6$1", "focus": "m"}}, {"id": 310, "prop": "name", "attributes": {"content": "（不對。）", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#6$1"}, {"id": 311, "prop": "Dialog", "attributes": {}}, {"id": 312, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 313, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#6$1", "focus": "none"}}, {"id": 314, "prop": "PlaySound", "attributes": {"key": "$d_avg_cloakmovement", "volume": 1.0}}, {"id": 315, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 316, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#6$1", "focus": "m"}}, {"id": 317, "prop": "Delay", "attributes": {"time": 0.2}}, {"id": 318, "prop": "playsound", "attributes": {"key": "$d_avg_gunload"}}, {"id": 319, "prop": "name", "attributes": {"content": "......", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#6$1"}, {"id": 320, "prop": "dialog", "attributes": {}}, {"id": 321, "prop": "charslot", "attributes": {}}, {"id": 322, "prop": "name", "attributes": {"content": "細微的聲響在空曠的聖堂內盪開，銃上膛的聲音與其同步響起。"}}, {"id": 323, "prop": "name", "attributes": {"content": "執行者猛然舉起銃。"}}, {"id": 324, "prop": "Dialog", "attributes": {}}, {"id": 325, "prop": "playsound", "attributes": {"key": "$d_avg_gunequip", "volume": 0.9}}, {"id": 326, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#4$1", "focus": "m"}}, {"id": 327, "prop": "name", "attributes": {"content": "出來。", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#4$1"}, {"id": 328, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1032_excu2_1#4$1", "focus": "m"}}, {"id": 329, "prop": "name", "attributes": {"content": "我只會再警告一次。從那裡出來。", "name": "費德里科"}, "figure_art": "avg_1032_excu2_1#4$1"}, {"id": 330, "prop": "dialog", "attributes": {}}, {"id": 331, "prop": "charslot", "attributes": {}}, {"id": 332, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_928_1#1$1", "focus": "m", "afrom": 0.0, "ato": 1.0, "duration": 1.0}}, {"id": 333, "pro