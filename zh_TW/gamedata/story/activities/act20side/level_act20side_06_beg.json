racteraction", "attributes": {"name": "middle", "type": "move", "ypos": 30.0, "fadetime": 0.2, "block": "true"}}, {"id": 61, "prop": "PlaySound", "attributes": {"key": "$d_avg_vallyrck"}}, {"id": 62, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 63, "prop": "Character", "attributes": {"fadetime": 0.0}}, {"id": 64, "prop": "Character", "attributes": {"name": "avg_4054_malist_1#7$1"}}, {"id": 65, "prop": "name", "attributes": {"content": "嘉維爾，你在幹什麼啊......", "name": "斯第奇·畫布"}, "figure_art": "avg_4054_malist_1#7$1"}, {"id": 66, "prop": "Dialog", "attributes": {}}, {"id": 67, "prop": "Character", "attributes": {"fadetime": 0.0}}, {"id": 68, "prop": "PlaySound", "attributes": {"key": "$e_atk_saw_n_1"}}, {"id": 69, "prop": "Character", "attributes": {"name": "avg_1026_gvial2_1#8$1"}}, {"id": 70, "prop": "characteraction", "attributes": {"name": "middle", "type": "move", "xpos": 300.0, "fadetime": 0.0, "block": "true"}}, {"id": 71, "prop": "PlaySound", "attributes": {"key": "$d_avg_walk_stage"}}, {"id": 72, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 73, "prop": "characteraction", "attributes": {"name": "middle", "type": "move", "fadetime": 1.5, "block": "true"}}, {"id": 74, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 75, "prop": "Character", "attributes": {"name": "avg_1026_gvial2_1#10$1"}}, {"id": 76, "prop": "name", "attributes": {"content": "看不就知道了，我在清理岩壁啊。", "name": "嘉維爾"}, "figure_art": "avg_1026_gvial2_1#10$1"}, {"id": 77, "prop": "Character", "attributes": {"name": "avg_4055_bgsnow_1#4$1"}}, {"id": 78, "prop": "name", "attributes": {"content": "雖然船把坍塌的地方砸出了不小的裂口，但是，依然沒有那麼簡單能夠通行。", "name": "阿芙朵嘉"}, "figure_art": "avg_4055_bgsnow_1#4$1"}, {"id": 79, "prop": "name", "attributes": {"content": "而開鑿的裝備也壞了，原本還以為要等一會，結果——", "name": "阿芙朵嘉"}, "figure_art": "avg_4055_bgsnow_1#4$1"}, {"id": 80, "prop": "Character", "attributes": {"name": "avg_4055_bgsnow_1#6$1"}}, {"id": 81, "prop": "name", "attributes": {"content": "如你所見。", "name": "阿芙朵嘉"}, "figure_art": "avg_4055_bgsnow_1#6$1"}, {"id": 82, "prop": "Character", "attributes": {"name": "avg_1026_gvial2_1#3$1"}}, {"id": 83, "prop": "name", "attributes": {"content": "哈哈，比起修鐵路和勘測，很顯然，這個才是我的強項嘛！", "name": "嘉維爾"}, "figure_art": "avg_1026_gvial2_1#3$1"}, {"id": 84, "prop": "Dialog", "attributes": {}}, {"id": 85, "prop": "Character", "attributes": {}}, {"id": 86, "prop": "name", "attributes": {"content": "環視四周，斯第奇看到了許多切面非常規整的岩石碎塊，以及一個足夠兩人並肩通行的洞口。"}}, {"id": 87, "prop": "name", "attributes": {"content": "這無疑是嘉維爾的傑作。"}}, {"id": 88, "prop": "name", "attributes": {"content": "也就是說，在開鑿設備全部損失的情況下，嘉維爾僅憑自己一個人，就打開了通往隧道內的路。"}}, {"id": 89, "prop": "name", "attributes": {"content": "斯第奇忍不住開始懷疑，他在阿卡胡拉部族裡聽到的那些有關無敵的嘉維爾的離奇傳言，是不是有一部分其實是真的。"}}, {"id": 90, "prop": "Dialog", "attributes": {}}, {"id": 91, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.7}}, {"id": 92, "prop": "Character", "attributes": {"name": "avg_npc_571_1#11$1", "name2": "char_empty", "fadetime": 0.5}}, {"id": 93, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 94, "prop": "Character", "attributes": {"name": "avg_npc_571_1#11$1", "name2": "avg_1026_gvial2_1#1$1", "fadetime": 0.5}}, {"id": 95, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "xpos": 200.0, "fadetime": 0.0, "block": "false"}}, {"id": 96, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "fadetime": 1.0, "block": "false"}}, {"id": 97, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 98, "prop": "Character", "attributes": {"name": "avg_npc_571_1#11$1", "name2": "avg_1026_gvial2_1#5$1", "focus": 2.0}}, {"id": 99, "prop": "name", "attributes": {"content": "哦，極境，你怎麼回來得這麼快？", "name": "嘉維爾"}, "figure_art": "avg_1026_gvial2_1#5$1"}, {"id": 100, "prop": "stopmusic", "attributes": {"fadetime": 3.0}}, {"id": 101, "prop": "Character", "attributes": {"name": "avg_npc_571_1#11$1", "name2": "avg_1026_gvial2_1#5$1", "focus": 1.0}}, {"id": 102, "prop": "name", "attributes": {"content": "......", "name": "極境"}, "figure_art": "avg_npc_571_1#11$1"}, {"id": 103, "prop": "Character", "attributes": {"name": "avg_npc_571_1#11$1", "name2": "avg_1026_gvial2_1#9$1", "focus": 2.0}}, {"id": 104, "prop": "name", "attributes": {"content": "發生了什麼，耶奇大師呢？", "name": "嘉維爾"}, "figure_art": "avg_1026_gvial2_1#9$1"}, {"id": 105, "prop": "Character", "attributes": {"name": "avg_npc_571_1#12$1", "name2": "avg_1026_gvial2_1#9$1", "focus": 1.0}}, {"id": 106, "prop": "name", "attributes": {"content": "情況有點不妙，嘉維爾。", "name": "極境"}, "figure_art": "avg_npc_571_1#12$1"}, {"id": 107, "prop": "Character", "attributes": {"name": "avg_npc_571_1#12$1", "name2": "avg_1026_gvial2_1#6$1", "focus": 2.0}}, {"id": 108, "prop": "name", "attributes": {"content": "怎麼了？難道有什麼巨大源石蟲之類的東西？我聽普羅旺斯說過她在汐斯塔見過那種玩意。", "name": "嘉維爾"}, "figure_art": "avg_1026_gvial2_1#6$1"}, {"id": 109, "prop": "Character", "attributes": {"name": "avg_npc_571_1#11$1", "name2": "avg_1026_gvial2_1#6$1", "focus": 1.0}}, {"id": 110, "prop": "name", "attributes": {"content": "如果是某種生物，我現在一定還有心情跟你開玩笑。", "name": "極境"}, "figure_art": "avg_npc_571_1#11$1"}, {"id": 111, "prop": "Character", "attributes": {"name": "avg_npc_571_1#9$1"}}, {"id": 112, "prop": "name", "attributes": {"content": "跟我來。", "name": "極境"}, "figure_art": "avg_npc_571_1#9$1"}, {"id": 113, "prop": "Dialog", "attributes": {}}, {"id": 114, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.7}}, {"id": 115, "prop": "Character", "attributes": {"fadetime": 0.5}}, {"id": 116, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 117, "prop": "dialog", "attributes": {}}, {"id": 118, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 119, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 120, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 121, "prop": "Background", "attributes": {"image": "bg_caveentrance", "screenadapt": "coverall"}}, {"id": 122, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 123, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 124, "prop": "playMusic", "attributes": {"intro": "$ponder_intro", "key": "$ponder_loop", "volume": 0.4}}, {"id": 125, "prop": "name", "attributes": {"content": "在鑽過隧道的坍塌處後，眾人走入了隧道之中。"}}, {"id": 126, "prop": "name", "attributes": {"content": "隧道之中的空間，實際上與其說是隧道，不如說是洞窟，寬廣又幽深。"}}, {"id": 127, "prop": "name", "attributes": {"content": "不過，極境的引導十分高效，在他的指引下，眾人在洞穴中的穿行十分順利。"}}, {"id": 128, "prop": "name", "attributes": {"content": "順利到讓人忍不住好奇，他是怎麼在這麼短的時間內就摸清了隧道的構造，甚至懷疑他是否來過這條隧道。"}}, {"id": 129, "prop": "name", "attributes": {"content": "然而，和這點近乎玩笑的懷疑相比，當極境停下腳步時，眾人所看到的東西，更令他們感到懷疑。"}}, {"id": 130, "prop": "name", "attributes": {"content": "那是一條裸露在岩層外的源石礦脈。"}}, {"id": 131, "prop": "name", "attributes": {"content": "並且，任何對源石有些瞭解的人都能夠輕易發現，這條源石礦脈已經活性化了很久。"}}, {"id": 132, "prop": "name", "attributes": {"content": "而活性化，意味著——"}}, {"id": 133, "prop": "name", "attributes": {"content": "爆炸。"}}, {"id": 134, "prop": "name", "attributes": {"content": "或者說——"}}, {"id": 135, "prop": "name", "attributes": {"content": "災難。"}}, {"id": 136, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 137, "prop": "Character", "attributes": {"name": "avg_4054_malist_1#3$1"}}, {"id": 138, "prop": "name", "attributes": {"content": "這怎麼可能？！", "name": "斯第奇·畫布"}, "figure_art": "avg_4054_malist_1#3$1"}, {"id": 139, "prop": "Character", "attributes": {"name": "avg_npc_564_1#6$1"}}, {"id": 140, "prop": "name", "attributes": {"content": "這個方向上確實在建城時曾勘測到有源石礦脈的存在，但是它距離隧道應該很遠——", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#6$1"}, {"id": 141, "prop": "Character", "attributes": {"name": "avg_npc_571_1#7$1"}}, {"id": 142, "prop": "name", "attributes": {"content": "有沒有可能是之前的大地震導致它被扯到了這裡？聽說之後也發生過幾次小的餘震。", "name": "極境"}, "figure_art": "avg_npc_571_1#7$1"}, {"id": 143, "prop": "name", "attributes": {"content": "畢竟這礦脈看起來確實夠突兀的。", "name": "極境"}, "figure_art": "avg_npc_571_1#7$1"}, {"id": 144, "prop": "Character", "attributes": {"name": "avg_npc_564_1#6$1"}}, {"id": 145, "prop": "name", "attributes": {"content": "不是沒有可能......", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#6$1"}, {"id": 146, "prop": "Character", "attributes": {"name": "avg_npc_564_1#4$1"}}, {"id": 147, "prop": "name", "attributes": {"content": "對，沒錯！它很有可能是被之前的那場地震牽扯到這裡來的！", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#4$1"}, {"id": 148, "prop": "Character", "attributes": {"name": "avg_npc_564_1#8$1"}}, {"id": 149, "prop": "name", "attributes": {"content": "並且，那場地震也激發了它的活性，讓它緩慢地開始了活性化。", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#8$1"}, {"id": 150, "prop": "Character", "attributes": {"name": "avg_npc_564_1#7$1"}}, {"id": 151, "prop": "name", "attributes": {"content": "而我們卻因為穹頂的源石檢測設施一直壞著，直到現在才發現這個問題嗎——", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#7$1"}, {"id": 152, "prop": "Character", "attributes": {"name": "avg_4054_malist_1#5$1"}}, {"id": 153, "prop": "name", "attributes": {"content": "我......", "name": "斯第奇·畫布"}, "figure_art": "avg_4054_malist_1#5$1"}, {"id": 154, "prop": "Character", "attributes": {"name": "avg_npc_564_1#8$1"}}, {"id": 155, "prop": "name", "attributes": {"content": "斯第奇，別慌，這不怪你。", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#8$1"}, {"id": 156, "prop": "name", "attributes": {"content": "這是我們全際崖城居民的決定。", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#8$1"}, {"id": 157, "prop": "Character", "attributes": {"name": "avg_npc_564_1#9$1"}}, {"id": 158, "prop": "name", "attributes": {"content": "只是......", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#9$1"}, {"id": 159, "prop": "name", "attributes": {"content": "我們剛才走過的距離連半公里都不一定有，在這個距離下，一條完整的活性源石礦脈爆發的話......", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#9$1"}, {"id": 160, "prop": "Character", "attributes": {"name": "avg_npc_564_1#8$1"}}, {"id": 161, "prop": "name", "attributes": {"content": "際崖城絕無倖免可能。", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#8$1"}, {"id": 162, "prop": "dialog", "attributes": {}}, {"id": 163, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 164, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 165, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 166, "prop": "Background", "attributes": {"image": "30_g1_durinstreet", "screenadapt": "coverall"}}, {"id": 167, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 168, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 169, "prop": "playsound", "attributes": {"key": "$radio"}}, {"id": 170, "prop": "name", "attributes": {"content": "各位際崖城的居民，臨時插播一條緊急通知。", "name": "廣播"}}, {"id": 171, "prop": "name", "attributes": {"content": "在剛才的游泳比賽結束後，耶奇大師已經率先帶領其他幾位參賽選手進入坍塌的隧道勘測。", "name": "廣播"}}, {"id": 172, "prop": "name", "attributes": {"content": "而勘測的結果並不樂觀。", "name": "廣播"}}, {"id": 173, "prop": "name", "attributes": {"content": "在隧道中距離城市直線距離約一公里的地方，耶奇大師發現了一條源石礦脈。", "name": "廣播"}}, {"id": 174, "prop": "name", "attributes": {"content": "初步推測這條源石礦脈來自在際崖城建立之初就已經被確認的，位於距離際崖城大約三公里左右的一處礦層。", "name": "廣播"}}, {"id": 175, "prop": "name", "attributes": {"content": "而由於半年前地震的原因，地層發生了變動，使這條礦脈彎曲並蔓延到了我們城市的附近並開始了活性化。", "name": "廣播"}}, {"id": 176, "prop": "name", "attributes": {"content": "現在，耶奇大師正在帶領其他專家緊急測定這條源石礦脈的活性化程度，以此來判斷它將在多久之後爆發。", "name": "廣播"}}, {"id": 177, "prop": "name", "attributes": {"content": "我們將在獲得確切結果後再行通知。", "name": "廣播"}}, {"id": 178, "prop": "name", "attributes": {"content": "現在，請各位居民做好撤離的準備。", "name": "廣播"}}, {"id": 179, "prop": "Dialog", "attributes": {}}, {"id": 180, "prop": "PlaySound", "attributes": {"key": "$d_avg_crwddiscuss_outside", "volume": 1.0, "loop": "false", "channel": "people"}}, {"id": 181, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 182, "prop": "stopsound", "attributes": {"channel": "people", "fadetime": 1.0}}, {"id": 183, "prop": "Character", "attributes": {"name": "avg_npc_573_1#1$1", "name2": "avg_npc_575_1#1$1", "fadetime": 0.5}}, {"id": 184, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 185, "prop": "Character", "attributes": {"name": "avg_npc_573_1#1$1", "name2": "avg_npc_575_1#1$1", "focus": 1.0}}, {"id": 186, "prop": "name", "attributes": {"content": "嗯？活性源石礦脈要爆炸了？怎麼這麼突然？", "name": "懶散的杜林人"}, "figure_art": "avg_npc_573_1#1$1"}, {"id": 187, "prop": "Character", "attributes": {"name": "avg_npc_573_1#1$1", "name2": "avg_npc_575_1#1$1", "focus": 2.0}}, {"id": 188, "prop": "name", "attributes": {"content": "從廣播內容來判斷，是因為之前地震導致了穹頂被破壞後，我們一直沒有修理穹頂的源石探測功能，所以沒有發現吧。", "name": "冷靜的杜林人"}, "figure_art": "avg_npc_575_1#1$1"}, {"id": 189, "prop": "Character", "attributes": {"name": "avg_npc_573_1#1$1", "name2": "avg_npc_575_1#1$1", "focus": 1.0}}, {"id": 190, "prop": "name", "attributes": {"content": "這麼一說，好像確實聽耶奇大師說過這樣的事情。", "name": "懶散的杜林人"}, "figure_art": "avg_npc_573_1#1$1"}, {"id": 191, "prop": "name", "attributes": {"content": "既然如此，那也沒辦法了。", "name": "懶散的杜林人"}, "figure_art": "avg_npc_573_1#1$1"}, {"id": 192, "prop": "Character", "attributes": {"name": "avg_npc_075"}}, {"id": 193, "prop": "name", "attributes": {"content": "你們......不會覺得建造“大水坑”是一個錯誤的決定嗎？", "name": "依娜姆"}, "figure_art": "avg_npc_075"}, {"id": 194, "prop": "Character", "attributes": {"name": "avg_npc_573_1#1$1", "name2": "avg_npc_575_1#1$1", "focus": 1.0}}, {"id": 195, "prop": "name", "attributes": {"content": "為什麼？我們願意接受這個結果。", "name": "懶散的杜林人"}, "figure_art": "avg_npc_573_1#1$1"}, {"id": 196, "prop": "Character", "attributes": {"name": "avg_npc_573_1#1$1", "name2": "avg_npc_575_1#1$1", "focus": 2.0}}, {"id": 197, "prop": "name", "attributes": {"content": "沒錯，我們從來沒有否定耶奇大師的警告。", "name": "冷靜的杜林人"}, "figure_art": "avg_npc_575_1#1$1"}, {"id": 198, "prop": "name", "attributes": {"content": "在決定不修補我們頭頂的這個缺口以及建造這個“大水坑”時，耶奇大師就已經做過預警。", "name": "冷靜的杜林人"}, "figure_art": "avg_npc_575_1#1$1"}, {"id": 199, "prop": "name", "attributes": {"content": "我們是在理解並接受了這個潛在危機之後，才決定建造“大水坑”的。", "name": "冷靜的杜林人"}, "figure_art": "avg_npc_575_1#1$1"}, {"id": 200, "prop": "name", "attributes": {"content": "現在，我們只是在承擔我們選擇的後果而已。", "name": "冷靜的杜林人"}, "figure_art": "avg_npc_575_1#1$1"}, {"id": 201, "prop": "Character", "attributes": {"name": "avg_npc_075"}}, {"id": 202, "prop": "name", "attributes": {"content": "......", "name": "依娜姆"}, "figure_art": "avg_npc_075"}, {"id": 203, "prop": "Character", "attributes": {"name": "avg_npc_573_1#1$1", "name2": "avg_npc_575_1#1$1", "focus": 1.0}}, {"id": 204, "prop": "name", "attributes": {"content": "對，地上人，你沒有任何為我們感到可惜的必要。", "name": "懶散的杜林人"}, "figure_art": "avg_npc_573_1#1$1"}, {"id": 205, "prop": "name", "attributes": {"content": "換個方式想，我們至少度過了一個漫長的夏天，不是嗎？", "name": "懶散的杜林人"}, "figure_art": "avg_npc_573_1#1$1"}, {"id": 206, "prop": "Character", "attributes": {"name": "avg_npc_573_1#1$1", "name2": "avg_npc_575_1#1$1", "focus": 2.0}}, {"id": 207, "prop": "name", "attributes": {"content": "我完全同意。", "name": "冷靜的杜林人"}, "figure_art": "avg_npc_575_1#1$1"}, {"id": 208, "prop": "Character", "attributes": {"name": "avg_npc_573_1#1$1", "name2": "avg_npc_575_1#1$1", "focus": 1.0}}, {"id": 209, "prop": "name", "attributes": {"content": "不過，撤離啊......我還沒想好我要留下什麼呢，你想好了嗎？", "name": "懶散的杜林人"}, "figure_art": "avg_npc_573_1#1$1"}, {"id": 210, "prop": "Character", "attributes": {"name": "avg_npc_573_1#1$1", "name2": "avg_npc_575_1#1$1", "focus": 2.0}}, {"id": 211, "prop": "name", "attributes": {"content": "我可不像你，我如今的房屋就是我當下最想要也是最滿意的設計。", "name": "冷靜的杜林人"}, "figure_art": "avg_npc_575_1#1$1"}, {"id": 212, "prop": "Character", "attributes": {"name": "avg_npc_573_1#1$1", "name2": "avg_npc_575_1#1$1", "focus": 1.0}}, {"id": 213, "prop": "name", "attributes": {"content": "好吧，但願那條源石礦脈不要那麼輕易地爆炸，我還得想一想呢。", "name": "懶散的杜林人"}, "figure_art": "avg_npc_573_1#1$1"}, {"id": 214, "prop": "Character", "attributes": {"name": "avg_npc_573_1#1$1", "name2": "avg_npc_575_1#1$1", "focus": 2.0}}, {"id": 215, "prop": "name", "attributes": {"content": "不如先去喝一杯吧？老卡爾蜜釀？", "name": "冷靜的杜林人"}, "figure_art": "avg_npc_575_1#1$1"}, {"id": 216, "prop": "Character", "attributes": {"name": "avg_npc_573_1#1$1", "name2": "avg_npc_575_1#1$1", "focus": 1.0}}, {"id": 217, "prop": "name", "attributes": {"content": "沒興趣，我還是選七號烈酒。", "name": "懶散的杜林人"}, "figure_art": "avg_npc_573_1#1$1"}, {"id": 218, "prop": "Character", "attributes": {"name": "avg_npc_075"}}, {"id": 219, "prop": "name", "attributes": {"content": "原以為杜林人只是一群不比頭頂上的阿達克利斯聰明多少的傻瓜......看來好像並不是這樣。", "name": "依娜姆"}, "figure_art": "avg_npc_075"}, {"id": 220, "prop": "dialog", "attributes": {}}, {"id": 221, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 222, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 223, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 224, "prop": "Background", "attributes": {"image": "bg_caveentrance", "screenadapt": "coverall"}}, {"id": 225, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 226, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 227, "prop": "Character", "attributes": {"name": "avg_npc_564_1#7$1", "name2": "char_empty"}}, {"id": 228, "prop": "name", "attributes": {"content": "唉......", "name": "耶奇·地心"}}, {"id": 229, "prop": "Dialog", "attributes": {}}, {"id": 230, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.7}}, {"id": 231, "prop": "Character", "attributes": {"name": "avg_npc_564_1#7$1", "name2": "avg_4055_bgsnow_1#1$1"}}, {"id": 232, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "xpos": 200.0, "fadetime": 0.0, "block": "false"}}, {"id": 233, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "fadetime": 1.0, "block": "false"}}, {"id": 234, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 235, "prop": "Character", "attributes": {"name": "avg_npc_564_1#7$1", "name2": "avg_4055_bgsnow_1#1$1", "focus": 2.0}}, {"id": 236, "prop": "name", "attributes": {"content": "耶奇大師，怎麼樣？", "name": "阿芙朵嘉"}, "figure_art": "avg_4055_bgsnow_1#1$1"}, {"id": 237, "prop": "Character", "attributes": {"name": "avg_npc_564_1#2$1", "name2": "avg_4055_bgsnow_1#1$1", "focus": 1.0}}, {"id": 238, "prop": "name", "attributes": {"content": "還要一點時間才能完全確認，不過，以我的經驗判斷——", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#2$1"}, {"id": 239, "prop": "Character", "attributes": {"name": "avg_npc_564_1#6$1", "name2": "avg_4055_bgsnow_1#1$1", "focus": 1.0}}, {"id": 240, "prop": "name", "attributes": {"content": "不出一個月，它就要爆發了。", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#6$1"}, {"id": 241, "prop": "Character", "attributes": {"name": "avg_npc_564_1#6$1", "name2": "avg_4055_bgsnow_1#4$1", "focus": 2.0}}, {"id": 242, "prop": "name", "attributes": {"content": "一個月？", "name": "阿芙朵嘉"}, "figure_art": "avg_4055_bgsnow_1#4$1"}, {"id": 243, "prop": "Character", "attributes": {"name": "avg_npc_564_1#6$1", "name2": "avg_4055_bgsnow_1#8$1", "focus": 2.0}}, {"id": 244, "prop": "name", "attributes": {"content": "那我們應該趁現在立刻鋪設鐵路，安排市民從隧道撤離。", "name": "阿芙朵嘉"}, "figure_art": "avg_4055_bgsnow_1#8$1"}, {"id": 245, "prop": "Character", "attributes": {"name": "avg_npc_564_1#8$1", "name2": "avg_4055_bgsnow_1#8$1", "focus": 1.0}}, {"id": 246, "prop": "name", "attributes": {"content": "不可能，來不及的。", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#8$1"}, {"id": 247, "prop": "name", "attributes": {"content": "往更深的方向挖一個臨時避難所的可行性更高。", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#8$1"}, {"id": 248, "prop": "Character", "attributes": {"name": "avg_npc_564_1#8$1", "name2": "avg_4055_bgsnow_1#8$1", "focus": 2.0}}, {"id": 249, "prop": "name", "attributes": {"content": "我們都知道，在這個距離的源石礦脈一旦爆發，穹頂或許能夠減輕爆炸的威力。", "name": "阿芙朵嘉"}, "figure_art": "avg_4055_bgsnow_1#8$1"}, {"id": 250, "prop": "name", "attributes": {"content": "但真正的問題是爆發後的源石粉塵散佈！", "name": "阿芙朵嘉"}, "figure_art": "avg_4055_bgsnow_1#8$1"}, {"id": 251, "prop": "Character", "attributes": {"name": "avg_npc_564_1#8$1", "name2": "avg_4055_bgsnow_1#3$1", "focus": 2.0}}, {"id": 252, "prop": "name", "attributes": {"content": "到時候，源石粉塵將會充斥著這個空間，我們所有人都會出事的！", "name": "阿芙朵嘉"}, "figure_art": "avg_4055_bgsnow_1#3$1"}, {"id": 253, "prop": "name", "attributes": {"content": "事到如今，即使是危險，也必須重新修建鐵路，然後掃清障礙，讓所有人前往天際城避難！", "name": "阿芙朵嘉"}, "figure_art": "avg_4055_bgsnow_1#3$1"}, {"id": 254, "prop": "Character", "attributes": {"name": "avg_npc_564_1#4$1", "name2": "avg_4055_bgsnow_1#3$1", "focus": 1.0}}, {"id": 255, "prop": "name", "attributes": {"content": "但是，現在隧道裡已經遍佈了源石，要順利地通過隧道是非常困難的！", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#4$1"}, {"id": 256, "prop": "name", "attributes": {"content": "際崖城現在有幾十萬的居民，要小心翼翼地通過那條寬度頂多也只能容納二十個人並肩前進的隧道，要花多少時間你難道不明白嗎？！", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#4$1"}, {"id": 257, "prop": "Character", "attributes": {"name": "avg_1026_gvial2_1#5$1"}}, {"id": 258, "prop": "name", "attributes": {"content": "喂......你們怎麼吵起來了。", "name": "嘉維爾"}, "figure_art": "avg_1026_gvial2_1#5$1"}, {"id": 259, "prop": "Character", "attributes": {"name": "avg_4055_bgsnow_1#8$1"}}, {"id": 260, "prop": "name", "attributes": {"content": "嘉維爾，我等一下再和你說。耶奇大師，難道您有更好的辦法嗎？", "name": "阿芙朵嘉"}, "figure_art": "avg_4055_bgsnow_1#8$1"}, {"id": 261, "prop": "Character", "attributes": {"name": "avg_npc_564_1#8$1", "name2": "avg_4055_bgsnow_1#8$1", "focus": 1.0}}, {"id": 262, "prop": "name", "attributes": {"content": "我認為我們現在應該立刻往源石礦脈的反方向進行挖掘。", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#8$1"}, {"id": 263, "prop": "name", "attributes": {"content": "在挖出一個足夠容納所有人的小型避難所後，再往回封閉道路，只要我們挖得夠深......", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#8$1"}, {"id": 264, "prop": "Character", "attributes": {"name": "avg_npc_564_1#8$1", "name2": "avg_4055_bgsnow_1#8$1", "focus": 2.0}}, {"id": 265, "prop": "name", "attributes": {"content": "建造容納這座城市裡的幾十萬人的避難所，即使是依靠際崖城的科技，要在短時間內完成也是非常困難的事。", "name": "阿芙朵嘉"}, "figure_art": "avg_4055_bgsnow_1#8$1"}, {"id": 266, "prop": "name", "attributes": {"content": "而且，幾十萬人接下來一段時間的生活起居又要如何解決？！", "name": "阿芙朵嘉"}, "figure_art": "avg_4055_bgsnow_1#8$1"}, {"id": 267, "prop": "Character", "attributes": {"name": "avg_npc_564_1#8$1", "name2": "avg_4055_bgsnow_1#8$1", "focus": 1.0}}, {"id": 268, "prop": "name", "attributes": {"content": "難道走隧道就可以解決嗎！", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#8$1"}, {"id": 269, "prop": "Character", "attributes": {"name": "avg_npc_564_1#8$1", "name2": "avg_4055_bgsnow_1#8$1", "focus": 2.0}}, {"id": 270, "prop": "name", "attributes": {"content": "至少走隧道只要穿過最危險的源石礦脈區，問題就還有迴旋的餘地！", "name": "阿芙朵嘉"}, "figure_art": "avg_4055_bgsnow_1#8$1"}, {"id": 271, "prop": "name", "attributes": {"content": "但是如果我們留在一座臨時建成的避難所，那麼一旦源石礦脈封住了唯一一條通往其他城市的隧道。", "name": "阿芙朵嘉"}, "figure_art": "avg_4055_bgsnow_1#8$1"}, {"id": 272, "prop": "Character", "attributes": {"name": "avg_npc_564_1#8$1", "name2": "avg_4055_bgsnow_1#3$1", "focus": 2.0}}, {"id": 273, "prop": "name", "attributes": {"content": "我們接下來就要面臨慢性死亡的局面了！", "name": "阿芙朵嘉"}, "figure_art": "avg_4055_bgsnow_1#3$1"}, {"id": 274, "prop": "Character", "attributes": {"name": "avg_npc_564_1#7$1", "name2": "avg_4055_bgsnow_1#3$1", "focus": 1.0}}, {"id": 275, "prop": "name", "attributes": {"content": "唔，你說的確實有道理，但我還是認為......", "name": "耶奇·地心"}, "figure_art": "avg_npc_564_1#7$1"}, {"id": 276, "prop": "Character", "attributes": {"name": "avg_npc_564_1#7$1", "name2": "avg_4055_bgsnow_1#3$1", "focus": 2.0}}, {"id": 277, "prop": "name", "attributes": {"content": "我當然明白這麼做的危險性，但是這已經是眼下最好的辦法了！", "name": "阿芙朵嘉"}, "figure_art": "avg_4055_bgsnow_1#3$1"}, {"id": 278, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 279, "prop": "Character", "attributes": {"name": "avg_1026_gvial2_1#9$1"}}, {"id": 280, "prop": "name", "attributes": {"content": "......我說，阿芙朵嘉。", "name": "嘉維爾"}, "figure_art": "avg_1026_gvial2_1#9$1"}, {"id": 281, "prop": "Character", "attributes": {"name": "avg_4055_bgsnow_1#3$1"}}, {"id": 282, "prop": "name", "attributes": {"content": "如果不是什麼重要的事，可以等一下再說嗎，嘉維爾？", "name": "阿芙朵嘉"}, "figure_art": "avg_4055_bgsnow_1#3$1"}, {"id": 283, "prop": "Character", "attributes": {"name": "avg_1026_gvial2_1#6$1"}}, {"id": 284, "prop": "name", "attributes": {"content": "雖然我也不想打擾你們，但是——", "name": "嘉維爾"}, "figure_art": "avg_1026_gvial2_1#6$1"}, {"id": 285, "prop": "playMusic", "attributes": {"intro": "$newhope02_intro", "key": "$newhope02_loop", "volume": 0.4}}, {"id": 286, "prop": "name", "attributes": {"content": "既然那條隧道走不通了......", "name": "嘉維爾"}, "figure_art": "avg_1026_gvial2_1#6$1"}, {"id": 287, "prop": "name", "attributes": {"content": "那剩下的辦法應該只有修一修特米米提過的那台超方便大升降梯一號，所有杜林人上地面來我們部族生活一段時間了吧？", "name": "嘉維爾"}, "figure_art": "avg_1026_gvial2_1#6$1"}, {"id": 288, "prop": "name", "attributes": {"content": "這個法子有什麼問題嗎，值得你們吵這麼久？", "name": "嘉維爾"}, "figure_art": "avg_1026_gvial2_1#6$1"}, {"id": 289, "prop": "Character", "attributes": {"name": "avg_4055_bgsnow_1#4$1"}}, {"id": 290, "prop": "name", "attributes": {"content": "前往......地面？", "name": "阿芙朵嘉"}, "figure_art": "avg_4055_bgsnow_1#4$1"}, {"id": 291, "prop": "Character", "attributes": {"name": "avg_1026_gvial2_1#2$1"}}, {"id": 292, "prop": "name", "attributes": {"content": "對啊。", "name": "嘉維爾"}, "figure_art": "avg_1026_gvial2_1#2$1"}, {"id": 293, "prop": "Character", "attributes": {"name": "avg_1026_gvial2_1#6$1"}}, {"id": 294, "prop": "name", "attributes": {"content": "呃，你們......難道就沒有考慮過前往地面嗎？", "name": "嘉維爾"}, "figure_art": "avg_1026_gvial2_1#6$1"}, {"id": 295, "prop": "Dialog", "attributes": {}}, {"id": 296, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 297, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 298, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 299, "prop": "Character", "attributes": {}}, {"id": 300, "prop": "Image", "attributes": {}}, {"id": 301, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}