 {"id": 212, "prop": "dialog", "attributes": {}}, {"id": 213, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 214, "prop": "Characteraction", "attributes": {"name": "left", "type": "move", "power": 16.0, "times": 2.0, "fadetime": 0.8, "block": "true"}}, {"id": 215, "prop": "Characteraction", "attributes": {"name": "right", "type": "move", "power": 15.0, "times": 2.0, "fadetime": 0.8, "block": "true"}}, {"id": 216, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1", "name2": "avg_npc_490_1#1$1", "focus": 1.0}}, {"id": 217, "prop": "name", "attributes": {"content": " 抱歉！", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#4$1"}, {"id": 218, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1", "name2": "avg_npc_490_1#1$1", "focus": 2.0}}, {"id": 219, "prop": "name", "attributes": {"content": " 沒關係。我才應該道歉，只顧著欣賞這座壯麗的建築，卻打擾了您的樂思。", "name": "？？？"}, "figure_art": "avg_npc_490_1#1$1"}, {"id": 220, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#3$1", "name2": "avg_npc_490_1#1$1", "focus": 1.0}}, {"id": 221, "prop": "name", "attributes": {"content": "......樂思？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#3$1"}, {"id": 222, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#3$1", "name2": "avg_npc_490_1#1$1", "focus": 2.0}}, {"id": 223, "prop": "name", "attributes": {"content": " 再見了。", "name": "？？？"}, "figure_art": "avg_npc_490_1#1$1"}, {"id": 224, "prop": "dialog", "attributes": {}}, {"id": 225, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 226, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "xpos": 300.0, "fadetime": 2.0, "block": "false"}}, {"id": 227, "prop": "character", "attributes": {"name": "avg_1024_hbisc2_1#3$1", "name2": "char_empty", "fadetime": 0.5}}, {"id": 228, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 229, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#3$1", "name2": "char_empty", "focus": 1.0}}, {"id": 230, "prop": "multiline", "attributes": {"name": "芙蓉", "content": " 再——"}}, {"id": 231, "prop": "multiline", "attributes": {"name": "芙蓉", "content": "見......"}}, {"id": 232, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#7$1", "name2": "char_empty", "focus": 1.0}}, {"id": 233, "prop": "name", "attributes": {"content": "（走得好快......）", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#7$1"}, {"id": 234, "prop": "name", "attributes": {"content": "（不過也是時候回頭了，廣場上又沒有住戶......）", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#7$1"}, {"id": 235, "prop": "Dialog", "attributes": {}}, {"id": 236, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 237, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 238, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 239, "prop": "Character", "attributes": {}}, {"id": 240, "prop": "Background", "attributes": {"image": "28_g2_slumstreets", "screenadapt": "coverall"}}, {"id": 241, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 242, "prop": "PlayMusic", "attributes": {"intro": "$nervous_intro", "key": "$nervous_loop", "volume": 0.4}}, {"id": 243, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 244, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 245, "prop": "Character", "attributes": {"name": "avg_npc_498_1#1$1"}}, {"id": 246, "prop": "name", "attributes": {"content": " 喂，那個女的！", "name": "醉酒的感染者"}, "figure_art": "avg_npc_498_1#1$1"}, {"id": 247, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#9$1"}}, {"id": 248, "prop": "name", "attributes": {"content": "嗯？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#9$1"}, {"id": 249, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1"}}, {"id": 250, "prop": "name", "attributes": {"content": "（好重的酒味......）", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#4$1"}, {"id": 251, "prop": "Character", "attributes": {"name": "avg_npc_498_1#1$1"}}, {"id": 252, "prop": "name", "attributes": {"content": " 對，就是你，魔族佬！", "name": "醉酒的感染者"}, "figure_art": "avg_npc_498_1#1$1"}, {"id": 253, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1"}}, {"id": 254, "prop": "name", "attributes": {"content": "......", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#4$1"}, {"id": 255, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#1$1"}}, {"id": 256, "prop": "name", "attributes": {"content": "您是？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#1$1"}, {"id": 257, "prop": "Character", "attributes": {"name": "avg_npc_498_1#1$1"}}, {"id": 258, "prop": "name", "attributes": {"content": " 你剛剛從我家出來，不記得了？", "name": "醉酒的感染者"}, "figure_art": "avg_npc_498_1#1$1"}, {"id": 259, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#9$1"}}, {"id": 260, "prop": "name", "attributes": {"content": "這麼說，您是施耐德先生的親屬？剛剛我登門的時候，您好像不在家。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#9$1"}, {"id": 261, "prop": "Character", "attributes": {"name": "avg_npc_498_1#1$1"}}, {"id": 262, "prop": "name", "attributes": {"content": " 我是他兒子！你敢抽我父親的血！", "name": "醉酒的感染者"}, "figure_art": "avg_npc_498_1#1$1"}, {"id": 263, "prop": "dialog", "attributes": {}}, {"id": 264, "prop": "character", "attributes": {}}, {"id": 265, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 0.9}}, {"id": 266, "prop": "character", "attributes": {"name": "avg_npc_501_1#1$1", "fadetime": 1.5}}, {"id": 267, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 268, "prop": "name", "attributes": {"content": "芙蓉，芙蓉！", "name": "行板"}, "figure_art": "avg_npc_501_1#1$1"}, {"id": 269, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#1$1"}}, {"id": 270, "prop": "name", "attributes": {"content": "行板，你來得正好，這位先生情緒實在太激動，我不知道他想表達什麼......", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#1$1"}, {"id": 271, "prop": "Character", "attributes": {"name": "avg_npc_498_1#1$1"}}, {"id": 272, "prop": "name", "attributes": {"content": " 行板？是羅德島的行板吧！趕緊告訴你們上司，把這個魔族佬送回去，不要再讓她接近夕照區了！", "name": "醉酒的感染者"}, "figure_art": "avg_npc_498_1#1$1"}, {"id": 273, "prop": "Character", "attributes": {"name": "avg_npc_501_1#1$1"}}, {"id": 274, "prop": "name", "attributes": {"content": "這......您先別激動，說說她做什麼了，我也好在報告裡寫啊。", "name": "行板"}, "figure_art": "avg_npc_501_1#1$1"}, {"id": 275, "prop": "Character", "attributes": {"name": "avg_npc_501_1#1$1"}}, {"id": 276, "prop": "name", "attributes": {"content": "（小聲）就說你怎麼這麼久都不回來......你先回辦事處！", "name": "行板"}, "figure_art": "avg_npc_501_1#1$1"}, {"id": 277, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#7$1"}}, {"id": 278, "prop": "name", "attributes": {"content": "（小聲）我再看看情況。這次的事件多少有些蹊蹺，他說的話沒准能提供一些幫助。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#7$1"}, {"id": 279, "prop": "Character", "attributes": {"name": "avg_npc_498_1#1$1"}}, {"id": 280, "prop": "name", "attributes": {"content": " 她抽我父親的血！魔族佬！抽血！你知道這意味著什麼嗎？", "name": "醉酒的感染者"}, "figure_art": "avg_npc_498_1#1$1"}, {"id": 281, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1"}}, {"id": 282, "prop": "name", "attributes": {"content": "呃，施耐德先生，您可能聽說了一些關於血魔的傳說，但我只是一個普通的薩卡茲，鮮血對我沒有任何吸引力......", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#4$1"}, {"id": 283, "prop": "Character", "attributes": {"name": "avg_npc_498_1#1$1"}}, {"id": 284, "prop": "name", "attributes": {"content": " 誰說什麼血魔了？", "name": "醉酒的感染者"}, "figure_art": "avg_npc_498_1#1$1"}, {"id": 285, "prop": "Character", "attributes": {"name": "avg_npc_498_1#1$1"}}, {"id": 286, "prop": "name", "attributes": {"content": " 這位朋友，你來評評理，收集感染者的血液，這人......到底是在幹什麼？", "name": "醉酒的感染者"}, "figure_art": "avg_npc_498_1#1$1"}, {"id": 287, "prop": "Character", "attributes": {"name": "avg_npc_499_1#1$1"}}, {"id": 288, "prop": "name", "attributes": {"content": "我？", "name": "路過的感染者"}, "figure_art": "avg_npc_499_1#1$1"}, {"id": 289, "prop": "Character", "attributes": {"name": "avg_npc_498_1#1$1"}}, {"id": 290, "prop": "name", "attributes": {"content": " 對，就是你！你——說說！", "name": "醉酒的感染者"}, "figure_art": "avg_npc_498_1#1$1"}, {"id": 291, "prop": "Character", "attributes": {"name": "avg_npc_499_1#1$1"}}, {"id": 292, "prop": "name", "attributes": {"content": "這個......我還有事，先走了......", "name": "路過的感染者"}, "figure_art": "avg_npc_499_1#1$1"}, {"id": 293, "prop": "dialog", "attributes": {}}, {"id": 294, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 295, "prop": "character", "attributes": {"fadetime": 1.5}}, {"id": 296, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 297, "prop": "Character", "attributes": {"name": "avg_npc_498_1#1$1"}}, {"id": 298, "prop": "name", "attributes": {"content": " 嘁，沒骨氣的東西......", "name": "醉酒的感染者"}, "figure_art": "avg_npc_498_1#1$1"}, {"id": 299, "prop": "Character", "attributes": {"name": "avg_npc_498_1#1$1"}}, {"id": 300, "prop": "name", "attributes": {"content": " 老哥，你——你來說說！", "name": "醉酒的感染者"}, "figure_art": "avg_npc_498_1#1$1"}, {"id": 301, "prop": "Character", "attributes": {"name": "avg_npc_488_1#1$1"}}, {"id": 302, "prop": "name", "attributes": {"content": " 這個嘛......具體的我也不太清楚，不過，有術師用感染者的血液施術，這我是聽說過的。", "name": "可疑的感染者"}, "figure_art": "avg_npc_488_1#1$1"}, {"id": 303, "prop": "Character", "attributes": {"name": "avg_npc_488_1#1$1"}}, {"id": 304, "prop": "name", "attributes": {"content": " 最近還有高塔術師偷偷抓感染者，也是為了差不多的事......", "name": "可疑的感染者"}, "figure_art": "avg_npc_488_1#1$1"}, {"id": 305, "prop": "Character", "attributes": {"name": "avg_npc_498_1#1$1"}}, {"id": 306, "prop": "name", "attributes": {"content": " 這才是公道話！這個魔族佬到處收集我們感染者的血液，怕不就是在做這種事情！", "name": "醉酒的感染者"}, "figure_art": "avg_npc_498_1#1$1"}, {"id": 307, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#5$1"}}, {"id": 308, "prop": "name", "attributes": {"content": "收集感染者的血液施術......據我所知，除了所謂的“巫王殘黨”......", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#5$1"}, {"id": 309, "prop": "Character", "attributes": {"name": "avg_npc_496_1#1$1", "name2": "avg_npc_497_1#1$1"}}, {"id": 310, "prop": "name", "attributes": {"content": "？！", "name": "感染者們"}, "figure_art": "avg_1024_hbisc2_1#5$1"}, {"id": 311, "prop": "dialog", "attributes": {}}, {"id": 312, "prop": "character", "attributes": {}}, {"id": 313, "prop": "name", "attributes": {"content": "芙蓉的無心之言一出，不光是那兩個感染者，連周圍看熱鬧的人群都在一瞬間變得寂靜無聲。"}}, {"id": 314, "prop": "Character", "attributes": {"name": "avg_npc_488_1#1$1"}}, {"id": 315, "prop": "name", "attributes": {"content": " 你......竟敢這麼隨便地直呼那位陛下的名號......果然是......關係不淺吧。", "name": "可疑的感染者"}, "figure_art": "avg_npc_488_1#1$1"}, {"id": 316, "prop": "Character", "attributes": {"name": "avg_npc_498_1#1$1"}}, {"id": 317, "prop": "name", "attributes": {"content": " 肯定是這麼回事！預言裡都說了，這個魔族佬肯定是想用感染者的血液施術害人！", "name": "醉酒的感染者"}, "figure_art": "avg_npc_498_1#1$1"}, {"id": 318, "prop": "Character", "attributes": {"name": "avg_npc_488_1#1$1"}}, {"id": 319, "prop": "name", "attributes": {"content": " 預言？難道你說的是那位陛下的......", "name": "可疑的感染者"}, "figure_art": "avg_npc_488_1#1$1"}, {"id": 320, "prop": "Character", "attributes": {"name": "avg_npc_498_1#1$1"}}, {"id": 321, "prop": "name", "attributes": {"content": " 沒錯！就是那個預言！絕對不能讓那個預言成真！！", "name": "醉酒的感染者"}, "figure_art": "avg_npc_498_1#1$1"}, {"id": 322, "prop": "Character", "attributes": {"name": "avg_npc_496_1#1$1"}}, {"id": 323, "prop": "name", "attributes": {"content": "你們說預言？", "name": "好事的感染者"}, "figure_art": "avg_npc_496_1#1$1"}, {"id": 324, "prop": "Character", "attributes": {"name": "avg_npc_496_1#1$1"}}, {"id": 325, "prop": "name", "attributes": {"content": "這幾天我也聽說有個預言，可總是模模糊糊的......具體說的是什麼呀？", "name": "好事的感染者"}, "figure_art": "avg_npc_496_1#1$1"}, {"id": 326, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#5$1"}}, {"id": 327, "prop": "name", "attributes": {"content": "我也好奇得很，你們因為一個預言就要把我趕走，可我連這個預言是什麼都不知道，怎麼可能就這麼走了呢？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#5$1"}, {"id": 328, "prop": "Character", "attributes": {"name": "avg_npc_488_1#1$1"}}, {"id": 329, "prop": "name", "attributes": {"content": " 這些事可不敢大聲講，誰能保證那位陛下沒留下什麼法術，我們的一舉一動，也許都還......", "name": "可疑的感染者"}, "figure_art": "avg_npc_488_1#1$1"}, {"id": 330, "prop": "Character", "attributes": {"name": "avg_npc_496_1#1$1"}}, {"id": 331, "prop": "name", "attributes": {"content": "噫！", "name": "好事的感染者"}, "figure_art": "avg_npc_496_1#1$1"}, {"id": 332, "prop": "Character", "attributes": {"name": "avg_npc_496_1#1$1"}}, {"id": 333, "prop": "name", "attributes": {"content": "那、那、那......那你小聲告訴我，預言說的到底是什麼呀？", "name": "好事的感染者"}, "figure_art": "avg_npc_496_1#1$1"}, {"id": 334, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#5$1"}}, {"id": 335, "prop": "name", "attributes": {"content": "嘖。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#5$1"}, {"id": 336, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#5$1"}}, {"id": 337, "prop": "name", "attributes": {"content": "（小聲）行板，類似的謠言你最近聽過嗎？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#5$1"}, {"id": 338, "prop": "Character", "attributes": {"name": "avg_npc_501_1#1$1"}}, {"id": 339, "prop": "name", "attributes": {"content": "（小聲）說實話，不是完全沒印象，但我完全沒往心裡去......", "name": "行板"}, "figure_art": "avg_npc_501_1#1$1"}, {"id": 340, "prop": "Character", "attributes": {"name": "avg_npc_501_1#1$1"}}, {"id": 341, "prop": "name", "attributes": {"content": "（小聲）且不說那位陛下早就已經不在了，就算他還健在，也沒必要特地為夕照區留下什麼預言啊。", "name": "行板"}, "figure_art": "avg_npc_501_1#1$1"}, {"id": 342, "prop": "Character", "attributes": {"name": "avg_npc_501_1#1$1"}}, {"id": 343, "prop": "name", "attributes": {"content": "（小聲）人可越聚越多了......", "name": "行板"}, "figure_art": "avg_npc_501_1#1$1"}, {"id": 344, "prop": "Character", "attributes": {"name": "avg_npc_496_1#1$1"}}, {"id": 345, "prop": "name", "attributes": {"content": "小姑娘，你還是避一避吧，這東西寧可信其有，不可信其無......", "name": "好事的感染者"}, "figure_art": "avg_npc_496_1#1$1"}, {"id": 346, "prop": "Character", "attributes": {"name": "avg_npc_498_1#1$1"}}, {"id": 347, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 348, "prop": "name", "attributes": {"content": " 滾出夕照區！", "name": "醉酒的感染者"}, "figure_art": "avg_npc_498_1#1$1"}, {"id": 349, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#6$1"}}, {"id": 350, "prop": "name", "attributes": {"content": "請大家不要相信這種沒有真憑實據的謠言！", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#6$1"}, {"id": 351, "prop": "Character", "attributes": {"name": "avg_npc_488_1#1$1"}}, {"id": 352, "prop": "name", "attributes": {"content": " 謠言？！你竟敢把預言說成是謠言，你......", "name": "可疑的感染者"}, "figure_art": "avg_npc_488_1#1$1"}, {"id": 353, "prop": "dialog", "attributes": {}}, {"id": 354, "prop": "Character", "attributes": {"name": "avg_npc_496_1#1$1", "name2": "avg_npc_497_1#1$1"}}, {"id": 355, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 356, "prop": "Character", "attributes": {"name": "avg_npc_499_1#1$1", "name2": "avg_npc_498_1#1$1"}}, {"id": 357, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 358, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#5$1"}}, {"id": 359, "prop": "name", "attributes": {"content": "這位先生，你一會兒說我和巫......和那些殘黨關係不淺，一會兒又暗示我對他不敬，如此自相矛盾，你到底想表達什麼，煽動什麼？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#5$1"}, {"id": 360, "prop": "Character", "attributes": {"name": "avg_npc_488_1#1$1"}}, {"id": 361, "prop": "name", "attributes": {"content": " 你們這種人的行事本來就不能以常理揣度。", "name": "可疑的感染者"}, "figure_art": "avg_npc_488_1#1$1"}, {"id": 362, "prop": "Character", "attributes": {"name": "avg_npc_488_1#1$1"}}, {"id": 363, "prop": "name", "attributes": {"content": " 再說，你一個魔族佬跑到夕照區來，還打著做調查的旗號收集大家的血液，誰知道你想幹什麼。", "name": "可疑的感染者"}, "figure_art": "avg_npc_488_1#1$1"}, {"id": 364, "prop": "Character", "attributes": {"name": "avg_npc_488_1#1$1"}}, {"id": 365, "prop": "name", "attributes": {"content": " 就算你沒有惡意，我們也不能放著預言不管，讓你在這逗留，大夥說是不是？", "name": "可疑的感染者"}, "figure_art": "avg_npc_488_1#1$1"}, {"id": 366, "prop": "dialog", "attributes": {}}, {"id": 367, "prop": "character", "attributes": {}}, {"id": 368, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 369, "prop": "name", "attributes": {"content": " 是！是啊！", "name": "圍觀的感染者們"}}, {"id": 370, "prop": "dialog", "attributes": {}}, {"id": 371, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 372, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#7$1"}}, {"id": 373, "prop": "name", "attributes": {"content": "不知道為什麼，可能是因為冠上了“那位陛下”的名號吧，各位似乎很害怕這場子虛烏有的災難。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#7$1"}, {"id": 374, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#5$1"}}, {"id": 375, "prop": "name", "attributes": {"content": "但我有更害怕的事情。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#5$1"}, {"id": 376, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#5$1"}}, {"id": 377, "prop": "name", "attributes": {"content": "我害怕我找不到這次事件的答案。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#5$1"}, {"id": 378, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#6$1"}}, {"id": 379, "prop": "name", "attributes": {"content": "一旦我退縮了，要嘛，我會錯失拯救生命的良機；要嘛，我會因為自己的膽怯，放任你們陷入危險。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#6$1"}, {"id": 380, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1"}}, {"id": 381, "prop": "name", "attributes": {"content": "你們視我為用感染者血液施術的殘忍術師，把我當成散佈災難的“魔族佬”......我都不介意。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#4$1"}, {"id": 382, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#5$1"}}, {"id": 383, "prop": "name", "attributes": {"content": "我只想拯救更多的生命，除此以外，對夕照區別無所求。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#5$1"}, {"id": 384, "prop": "Character", "attributes": {"name": "avg_npc_498_1#1$1"}}, {"id": 385, "prop": "name", "attributes": {"content": " 別扯謊了，不走，你就是故意在夕照區搞破壞！", "name": "醉酒的感染者"}, "figure_art": "avg_npc_498_1#1$1"}, {"id": 386, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#5$1"}}, {"id": 387, "prop": "name", "attributes": {"content": "......", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#5$1"}, {"id": 388, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1"}}, {"id": 389, "prop": "name", "attributes": {"content": "各位，我無意在這裡和你們起什麼衝突。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#4$1"}, {"id": 390, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1"}}, {"id": 391, "prop": "name", "attributes": {"content": "如果你們實在不想見到我，我可以暫時回到羅德島辦事處，各位也冷靜一下，好不好？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#4$1"}, {"id": 392, "prop": "Character", "attributes": {"name": "avg_npc_498_1#1$1"}}, {"id": 393, "prop": "name", "attributes": {"content": " 嘁，這還像句人話——", "name": "醉酒的感染者"}, "figure_art": "avg_npc_498_1#1$1"}, {"id": 394, "prop": "Character", "attributes": {"name": "avg_npc_488_1#1$1"}}, {"id": 395, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 396, "prop": "name", "attributes": {"content": " 不行！", "name": "可疑的感染者"}, "figure_art": "avg_npc_488_1#1$1"}, {"id": 397, "prop": "Character", "attributes": {"name": "avg_npc_488_1#1$1"}}, {"id": 398, "prop": "name", "attributes": {"content": " 你以為羅德島辦事處在哪裡？辦事處也是夕照區的一部分！", "name": "可疑的感染者"}, "figure_art": "avg_npc_488_1#1$1"}, {"id": 399, "prop": "Character", "attributes": {"name": "avg_npc_488_1#1$1"}}, {"id": 400, "prop": "name", "attributes": {"content": " 還是說，你覺得羅德島有什麼特權，羅德島辦事處可以不歸夕照區管了？", "name": "可疑的感染者"}, "figure_art": "avg_npc_488_1#1$1"}, {"id": 401, "prop": "Character", "attributes": {"name": "avg_npc_488_1#1$1"}}, {"id": 402, "prop": "name", "attributes": {"content": " 我們絕對不答應！", "name": "可疑的感染者"}, "figure_art": "avg_npc_488_1#1$1"}, {"id": 403, "prop": "Character", "attributes": {"name": "avg_npc_488_1#1$1"}}, {"id": 404, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 405, "prop": "name", "attributes": {"content": " 大夥跟我上，把魔族佬趕出去！", "name": "可疑的感染者"}, "figure_art": "avg_npc_488_1#1$1"}, {"id": 406, "prop": "PlaySound", "attributes": {"key": "$d_avg_crowdrun", "volume": 1.0}}, {"id": 407, "prop": "dialog", "attributes": {}}, {"id": 408, "prop": "Character", "attributes": {}}, {"id": 409, "prop": "name", "attributes": {"content": "一些人衝了上去，一些人原地不動，還有一些人選擇背向芙蓉，離開是非之地。"}}, {"id": 410, "prop": "name", "attributes": {"content": "無論他們做何選擇，芙蓉只是站在那裡，既不選擇戰鬥，也不選擇逃跑。"}}, {"id": 411, "prop": "Dialog", "attributes": {}}, {"id": 412, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 413, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 414, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 415, "prop": "Character", "attributes": {}}, {"id": 416, "prop": "Image", "attributes": {}}, {"id": 417, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}