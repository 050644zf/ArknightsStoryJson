"prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 20, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "xpos": 200.0, "fadetime": 0.3, "block": "true"}}, {"id": 21, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 22, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "fadetime": 1.0, "block": "false"}}, {"id": 23, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#1$1", "name2": "avg_npc_494_1#1$1", "fadetime": 0.7}}, {"id": 24, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 25, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#1$1", "name2": "avg_npc_494_1#1$1", "focus": 2.0}}, {"id": 26, "prop": "name", "attributes": {"content": "姑娘，我看你這一整天都沒閒著，在周圍到處跑，也該餓了吧？", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 27, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#1$1", "name2": "avg_npc_494_1#6$1", "focus": 2.0}}, {"id": 28, "prop": "name", "attributes": {"content": "嘗嘗夕照區特產怎麼樣？", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#6$1"}, {"id": 29, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#3$1", "name2": "avg_npc_494_1#6$1", "focus": 1.0}}, {"id": 30, "prop": "name", "attributes": {"content": "特產？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#3$1"}, {"id": 31, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#3$1", "name2": "avg_npc_494_1#6$1", "focus": 2.0}}, {"id": 32, "prop": "name", "attributes": {"content": "瞧瞧，油煎酸漬捲心菜，這香氣，這色澤！", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#6$1"}, {"id": 33, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#7$1", "name2": "avg_npc_494_1#6$1", "focus": 1.0}}, {"id": 34, "prop": "name", "attributes": {"content": "（高溫油煎的醃漬食品，這和健康完全背道而馳啊......）", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#7$1"}, {"id": 35, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#7$1", "name2": "avg_npc_494_1#1$1", "focus": 2.0}}, {"id": 36, "prop": "name", "attributes": {"content": "怎麼，怕我宰客？來，這一份是送你的，不要錢！", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 37, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#7$1", "name2": "avg_npc_494_1#1$1", "focus": 2.0}}, {"id": 38, "prop": "name", "attributes": {"content": "別不好意思，你在我們這裡走街串巷替大家看病，這是感謝你的。", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 39, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 40, "prop": "name", "attributes": {"content": "（唉，盛情難卻......）", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#4$1"}, {"id": 41, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#8$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 42, "prop": "name", "attributes": {"content": "那就多謝您了。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#8$1"}, {"id": 43, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#8$1", "name2": "avg_npc_494_1#6$1", "focus": 2.0}}, {"id": 44, "prop": "name", "attributes": {"content": "客氣！", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#6$1"}, {"id": 45, "prop": "Dialog", "attributes": {}}, {"id": 46, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 47, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 48, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 49, "prop": "Character", "attributes": {}}, {"id": 50, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 51, "prop": "PlayMusic", "attributes": {"intro": "$farce_intro", "key": "$farce_loop", "volume": 0.4}}, {"id": 52, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 53, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 54, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#1$1", "name2": "avg_npc_494_1#1$1", "focus": 2.0}}, {"id": 55, "prop": "name", "attributes": {"content": "怎麼吃了一口就放下了，說了是送你的嘛。", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 56, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#1$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 57, "prop": "name", "attributes": {"content": "我還不餓，一會兒再吃。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#1$1"}, {"id": 58, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#10$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 59, "prop": "name", "attributes": {"content": "不過，您有沒有考慮過稍微調整一下配方？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#10$1"}, {"id": 60, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#10$1", "name2": "avg_npc_494_1#4$1", "focus": 2.0}}, {"id": 61, "prop": "name", "attributes": {"content": "調整配方？", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#4$1"}, {"id": 62, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#1$1", "name2": "avg_npc_494_1#4$1", "focus": 1.0}}, {"id": 63, "prop": "name", "attributes": {"content": "您看，這一份餐食大約是一個成年人一餐的量，但其中含有的鹽和油至少是推薦攝入量的三倍和五倍，這對健康可有害無利啊。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#1$1"}, {"id": 64, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#1$1", "name2": "avg_npc_494_1#1$1", "focus": 2.0}}, {"id": 65, "prop": "name", "attributes": {"content": "姑娘，這道菜我可做了幾十年了，來吃的人就沒有不說好的。", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 66, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#1$1", "name2": "avg_npc_494_1#1$1", "focus": 2.0}}, {"id": 67, "prop": "name", "attributes": {"content": "突然改了配方，我那些老主顧可是要罵人的！", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 68, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#2$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 69, "prop": "name", "attributes": {"content": "這也是為了大家的健康著想。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#2$1"}, {"id": 70, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#5$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 71, "prop": "name", "attributes": {"content": "來這裡消費的，包括我自己在內，都是感染者，這種高油高鹽的飲食對感染者的傷害只會比對健康人更大......", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#5$1"}, {"id": 72, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#5$1", "name2": "avg_npc_494_1#1$1", "focus": 2.0}}, {"id": 73, "prop": "name", "attributes": {"content": "我就問你一件事，我做的這道菜到底好不好吃？", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 74, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#8$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 75, "prop": "name", "attributes": {"content": "......非常美味。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#8$1"}, {"id": 76, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#8$1", "name2": "avg_npc_494_1#6$1", "focus": 2.0}}, {"id": 77, "prop": "name", "attributes": {"content": "這不就結了！", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#6$1"}, {"id": 78, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1", "name2": "avg_npc_494_1#6$1", "focus": 1.0}}, {"id": 79, "prop": "name", "attributes": {"content": "可我還是覺得——", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#4$1"}, {"id": 80, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1", "name2": "avg_npc_494_1#1$1", "focus": 2.0}}, {"id": 81, "prop": "name", "attributes": {"content": "好啦好啦，知道你無福消受我的手藝了。", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 82, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 83, "prop": "name", "attributes": {"content": "哈哈......", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#4$1"}, {"id": 84, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#1$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 85, "prop": "name", "attributes": {"content": "對了，我問您一些問題，可以嗎？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#1$1"}, {"id": 86, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#1$1", "name2": "avg_npc_494_1#1$1", "focus": 2.0}}, {"id": 87, "prop": "name", "attributes": {"content": "反正現在又沒生意上門，你問就是了。", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 88, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#1$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 89, "prop": "name", "attributes": {"content": "您最近生意怎麼樣？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#1$1"}, {"id": 90, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#1$1", "name2": "avg_npc_494_1#1$1", "focus": 2.0}}, {"id": 91, "prop": "name", "attributes": {"content": "忙得很！可能是因為天氣暖和，這幾天來吃飯的人越來越多了。", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 92, "prop": "dialog", "attributes": {}}, {"id": 93, "prop": "PlaySound", "attributes": {"key": "$d_avg_penrustle"}}, {"id": 94, "prop": "delay", "attributes": {"time": 0.7}}, {"id": 95, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#1$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 96, "prop": "name", "attributes": {"content": "來吃飯的人您都認識嗎？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#1$1"}, {"id": 97, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#1$1", "name2": "avg_npc_494_1#1$1", "focus": 2.0}}, {"id": 98, "prop": "name", "attributes": {"content": "認識啊。來照顧我生意的都是夕照區的人，我基本上都認識。", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 99, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#9$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 100, "prop": "name", "attributes": {"content": "大家都是感染者？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#9$1"}, {"id": 101, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#9$1", "name2": "avg_npc_494_1#1$1", "focus": 2.0}}, {"id": 102, "prop": "name", "attributes": {"content": "沒錯。", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 103, "prop": "dialog", "attributes": {}}, {"id": 104, "prop": "PlaySound", "attributes": {"key": "$d_avg_penrustle"}}, {"id": 105, "prop": "delay", "attributes": {"time": 0.7}}, {"id": 106, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#7$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 107, "prop": "name", "attributes": {"content": "有沒有已經一段時間不露面，但這幾天又來光顧的客人？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#7$1"}, {"id": 108, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#7$1", "name2": "avg_npc_494_1#1$1", "focus": 2.0}}, {"id": 109, "prop": "name", "attributes": {"content": "有，好像還不少呢。", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 110, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#8$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 111, "prop": "name", "attributes": {"content": "能不能麻煩您告訴我，都有哪幾位客人是這種情況？他們都住哪裡？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#8$1"}, {"id": 112, "prop": "musicvolume", "attributes": {"volume": 0.2, "fadetime": 1.0}}, {"id": 113, "prop": "Dialog", "attributes": {}}, {"id": 114, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 115, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 116, "prop": "Character", "attributes": {}}, {"id": 117, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 118, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 119, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 120, "prop": "musicvolume", "attributes": {"volume": 0.4, "fadetime": 1.0}}, {"id": 121, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#10$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 122, "prop": "name", "attributes": {"content": "謝謝您！", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#10$1"}, {"id": 123, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#10$1", "name2": "avg_npc_494_1#1$1", "focus": 2.0}}, {"id": 124, "prop": "name", "attributes": {"content": "客氣！", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 125, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#8$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 126, "prop": "name", "attributes": {"content": "最後......您最近感覺怎麼樣？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#8$1"}, {"id": 127, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#8$1", "name2": "avg_npc_494_1#1$1", "focus": 2.0}}, {"id": 128, "prop": "name", "attributes": {"content": "你說礦石病？挺正常的，不好不壞。不過最近生意好，我每天進貨都特別有勁。", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 129, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#9$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 130, "prop": "name", "attributes": {"content": "您好像不是很熱衷音樂？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#9$1"}, {"id": 131, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#9$1", "name2": "avg_npc_494_1#1$1", "focus": 2.0}}, {"id": 132, "prop": "name", "attributes": {"content": "哎，我本來也不是搞藝術的，沒他們那麼高的追求，能養活一家子人就知足啦。", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 133, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#1$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 134, "prop": "name", "attributes": {"content": "我的問題問完了。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#1$1"}, {"id": 135, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#10$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 136, "prop": "name", "attributes": {"content": "感謝您的配合，祝您生意興隆！", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#10$1"}, {"id": 137, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#10$1", "name2": "avg_npc_494_1#1$1", "focus": 2.0}}, {"id": 138, "prop": "name", "attributes": {"content": "多謝，多謝。", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 139, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#10$1", "name2": "avg_npc_494_1#6$1", "focus": 2.0}}, {"id": 140, "prop": "name", "attributes": {"content": "不過姑娘，菜你只吃了一口，不再多吃點嗎？", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#6$1"}, {"id": 141, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1", "name2": "avg_npc_494_1#6$1", "focus": 1.0}}, {"id": 142, "prop": "name", "attributes": {"content": "這——剛剛不是——", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#4$1"}, {"id": 143, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1", "name2": "avg_npc_494_1#1$1", "focus": 2.0}}, {"id": 144, "prop": "name", "attributes": {"content": "開個玩笑，開個玩笑。", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 145, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1", "name2": "avg_npc_494_1#1$1", "focus": 2.0}}, {"id": 146, "prop": "name", "attributes": {"content": "你們醫生把健康放在第一位，我理解！不過我們廚子自然是以口味優先，當醫生的多少也理解一下我們，你覺得呢？", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 147, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1", "name2": "avg_npc_494_1#1$1", "focus": 1.0}}, {"id": 148, "prop": "name", "attributes": {"content": "呃......我能理解，但是不能認同。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#4$1"}, {"id": 149, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1", "name2": "avg_npc_494_1#6$1", "focus": 2.0}}, {"id": 150, "prop": "name", "attributes": {"content": "光是理解也挺好，求同存異嘛。下次想吃的時候記得來啊！", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#6$1"}, {"id": 151, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#8$1", "name2": "avg_npc_494_1#6$1", "focus": 1.0}}, {"id": 152, "prop": "name", "attributes": {"content": "嗯，嗯。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#8$1"}, {"id": 153, "prop": "dialog", "attributes": {}}, {"id": 154, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 155, "prop": "characteraction", "attributes": {"name": "left", "type": "move", "fadetime": 2.0, "block": "false"}}, {"id": 156, "prop": "character", "attributes": {"name": "char_empty", "name2": "avg_npc_494_1#1$1", "fadetime": 0.5}}, {"id": 157, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 158, "prop": "Character", "attributes": {"name": "avg_npc_494_1#2$1"}}, {"id": 159, "prop": "name", "attributes": {"content": "我還奇怪，這姑娘怎麼吃了一口就像要哭了似的......", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#2$1"}, {"id": 160, "prop": "name", "attributes": {"content": "唉，這麼好的小姑娘，怎麼偏偏是個薩卡茲呢。", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#2$1"}, {"id": 161, "prop": "Dialog", "attributes": {}}, {"id": 162, "prop": "Character", "attributes": {"name": "avg_npc_494_1#1$1", "name2": "char_empty"}}, {"id": 163, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 164, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "xpos": 200.0, "fadetime": 0.3, "block": "true"}}, {"id": 165, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 166, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "fadetime": 1.0, "block": "false"}}, {"id": 167, "prop": "Character", "attributes": {"name": "avg_npc_494_1#1$1", "name2": "avg_npc_485_1#1$1", "fadetime": 0.7}}, {"id": 168, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 169, "prop": "Character", "attributes": {"name": "avg_npc_494_1#1$1", "name2": "avg_npc_485_1#1$1", "focus": 2.0}}, {"id": 170, "prop": "name", "attributes": {"content": "老闆，來一份酸漬捲心菜。", "name": "咖啡店主"}, "figure_art": "avg_npc_485_1#1$1"}, {"id": 171, "prop": "Character", "attributes": {"name": "avg_npc_494_1#1$1", "name2": "avg_npc_485_1#1$1", "focus": 1.0}}, {"id": 172, "prop": "name", "attributes": {"content": "好的——喲，是你啊。", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 173, "prop": "Character", "attributes": {"name": "avg_npc_494_1#1$1", "name2": "avg_npc_485_1#1$1", "focus": 1.0}}, {"id": 174, "prop": "name", "attributes": {"content": "肉醬要雙份，菜煎到微焦，沒錯吧？", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 175, "prop": "Character", "attributes": {"name": "avg_npc_494_1#1$1", "name2": "avg_npc_485_1#8$1", "focus": 2.0}}, {"id": 176, "prop": "name", "attributes": {"content": "多謝啦！", "name": "咖啡店主"}, "figure_art": "avg_npc_485_1#8$1"}, {"id": 177, "prop": "Character", "attributes": {"name": "avg_npc_494_1#1$1", "name2": "avg_npc_485_1#1$1", "focus": 2.0}}, {"id": 178, "prop": "name", "attributes": {"content": "剛才那小姑娘有點面生，你認識她？", "name": "咖啡店主"}, "figure_art": "avg_npc_485_1#1$1"}, {"id": 179, "prop": "Character", "attributes": {"name": "avg_npc_494_1#1$1", "name2": "avg_npc_485_1#1$1", "focus": 1.0}}, {"id": 180, "prop": "name", "attributes": {"content": "她最近一直在街上轉，不認識也認識了。怎麼，難道你想請她去你們那裡喝一杯？", "name": "小吃攤主"}, "figure_art": "avg_npc_494_1#1$1"}, {"id": 181, "prop": "Character", "attributes": {"name": "avg_npc_494_1#1$1", "name2": "avg_npc_485_1#8$1", "focus": 2.0}}, {"id": 182, "prop": "name", "attributes": {"content": "不至於，不至於。", "name": "咖啡店主"}, "figure_art": "avg_npc_485_1#8$1"}, {"id": 183, "prop": "Character", "attributes": {"name": "avg_npc_494_1#1$1", "name2": "avg_npc_485_1#8$1", "focus": 2.0}}, {"id": 184, "prop": "name", "attributes": {"content": "看她那副忙忙碌碌的樣子，大概是在做什麼正經事吧，沒機會去喝咖啡的。", "name": "咖啡店主"}, "figure_art": "avg_npc_485_1#8$1"}, {"id": 185, "prop": "Dialog", "attributes": {}}, {"id": 186, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 187, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 188, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 189, "prop": "Character", "attributes": {}}, {"id": 190, "prop": "Background", "attributes": {"image": "28_g7_concerthall_outside", "screenadapt": "coverall"}}, {"id": 191, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 192, "prop": "PlayMusic", "attributes": {"intro": "$m_dia_street_intro", "key": "$m_dia_street_loop", "volume": 0.4}},