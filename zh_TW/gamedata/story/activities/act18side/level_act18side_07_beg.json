1"}}, {"id": 186, "prop": "name", "attributes": {"content": "看到那個音箱了嗎？很明顯有被拆過的痕跡。那邊的唱機也是，她甚至連螺絲都沒擰緊——嘖，連螺絲刀都忘記收起來了。", "name": "車爾尼"}, "figure_art": "avg_4047_pianst_1#7$1"}, {"id": 187, "prop": "name", "attributes": {"content": "不愧是貴族，這水準粗糙得我都想笑了。", "name": "車爾尼"}, "figure_art": "avg_4047_pianst_1#7$1"}, {"id": 188, "prop": "character", "attributes": {"name": "avg_4047_pianst_1#1$1"}}, {"id": 189, "prop": "name", "attributes": {"content": "芙蓉，你把那個唱機拿過來，我看看她除了唱臂還改了什麼。", "name": "車爾尼"}, "figure_art": "avg_4047_pianst_1#1$1"}, {"id": 190, "prop": "Dialog", "attributes": {}}, {"id": 191, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 192, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 193, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 194, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 195, "prop": "Delay", "attributes": {"time": 0.51}}, {"id": 196, "prop": "character", "attributes": {"name": "avg_4047_pianst_1#1$1"}}, {"id": 197, "prop": "name", "attributes": {"content": "......", "name": "車爾尼"}, "figure_art": "avg_4047_pianst_1#1$1"}, {"id": 198, "prop": "character", "attributes": {"name": "avg_4047_pianst_1#2$1"}}, {"id": 199, "prop": "name", "attributes": {"content": "你自己看。", "name": "車爾尼"}, "figure_art": "avg_4047_pianst_1#2$1"}, {"id": 200, "prop": "character", "attributes": {"name": "avg_4046_ebnhlz_1#3$2"}}, {"id": 201, "prop": "name", "attributes": {"content": "她在唱機裡面加裝拾音器？這只會引發回路間的干擾......", "name": "黑鍵"}, "figure_art": "avg_4046_ebnhlz_1#3$2"}, {"id": 202, "prop": "character", "attributes": {"name": "avg_4047_pianst_1#1$1"}}, {"id": 203, "prop": "name", "attributes": {"content": "她已經把唱針拆掉了，這東西現在只是個擴音器而已。", "name": "車爾尼"}, "figure_art": "avg_4047_pianst_1#1$1"}, {"id": 204, "prop": "character", "attributes": {"name": "avg_4047_pianst_1#10$1"}}, {