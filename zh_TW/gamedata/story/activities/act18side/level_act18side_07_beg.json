art": "avg_4047_pianst_1#10$1"}, {"id": 244, "prop": "Dialog", "attributes": {}}, {"id": 245, "prop": "Character", "attributes": {}}, {"id": 246, "prop": "Delay", "attributes": {"time": 0.51}}, {"id": 247, "prop": "playsound", "attributes": {"key": "$d_avg_open_door"}}, {"id": 248, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 249, "prop": "character", "attributes": {"name": "avg_4046_ebnhlz_1#3$2", "fadetime": 0.7}}, {"id": 250, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 251, "prop": "name", "attributes": {"content": "車爾尼！", "name": "黑鍵"}, "figure_art": "avg_4046_ebnhlz_1#3$2"}, {"id": 252, "prop": "character", "attributes": {"name": "avg_4047_pianst_1#5$1"}}, {"id": 253, "prop": "name", "attributes": {"content": "咳、咳......", "name": "車爾尼"}, "figure_art": "avg_4047_pianst_1#5$1"}, {"id": 254, "prop": "name", "attributes": {"content": "不用擔心我......我只是，心跳得有點快......", "name": "車爾尼"}, "figure_art": "avg_4047_pianst_1#5$1"}, {"id": 255, "prop": "character", "attributes": {"name": "avg_4047_pianst_1#1$1"}}, {"id": 256, "prop": "name", "attributes": {"content": "黑鍵，你在這，再用一下剛才的法術，記得注意音量。", "name": "車爾尼"}, "figure_art": "avg_4047_pianst_1#1$1"}, {"id": 257, "prop": "Dialog", "attributes": {}}, {"id": 258, "prop": "Character", "attributes": {}}, {"id": 259, "prop": "Delay", "attributes": {"time": 0.51}}, {"id": 260, "prop": "playsound", "attributes": {"key": "$d_avg_flute_attack", "volume": 1.0}}, {"id": 261, "prop": "Delay", "attributes": {"time": 0.51}}, {"id": 262, "prop": "PlaySound", "attributes": {"key": "$d_avg_flute_attack", "channel": "bgs", "delay": 0.2, "volume": 0.4, "block": "true"}}, {"id": 263, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 264, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#3$1", "name2": "avg_4047_pianst_1#1$1", "focus": 1.0}}, {"id": 265, "prop": "name", "attributes": {"content": "回音？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#3$1"}, {"id": 266, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#3$1", "name2": "avg_4047_pianst_1#1$1", "focus": 2.0}}, {"id": 267, "prop": "name", "attributes": {"content": "是外面傳來的聲音。", "name": "車爾尼"}, "figure_art": "avg_4047_pianst_1#1$1"}, {"id": 268, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1", "name2": "avg_4047_pianst_1#1$1", "focus": 1.0}}, {"id": 269, "prop": "name", "attributes": {"content": "可這不是黑鍵吹出來的笛聲嗎？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#4$1"}, {"id": 270, "prop": "Dialog", "attributes": {}}, {"id": 271, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1", "name2": "avg_4047_pianst_1#10$1", "focus": 2.0}}, {"id": 272, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 273, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1", "name2": "avg_4047_pianst_1#7$1", "focus": 2.0}}, {"id": 274, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 275, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1", "name2": "avg_4047_pianst_1#7$1"}}, {"id": 276, "prop": "name", "attributes": {"content": "車爾尼張了張嘴，沒發出聲音。"}}, {"id": 277, "prop": "name", "attributes": {"content": "他好像已經知道答案了。"}}, {"id": 278, "prop": "name", "attributes": {"content": "然而，芙蓉從他臉上看見的，不是興奮，也不是憤怒，而是恐懼。"}}, {"id": 279, "prop": "name", "attributes": {"content": "純粹的恐懼。"}}, {"id": 280, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1", "name2": "avg_4047_pianst_1#1$1", "focus": 2.0}}, {"id": 281, "prop": "name", "attributes": {"content": "......", "name": "車爾尼"}, "figure_art": "avg_4047_pianst_1#1$1"}, {"id": 282, "prop": "name", "attributes": {"content": "格特魯德把這間休息室，不，把整個夕照廳，改裝成了一個巨大的擴音器，兼法術放大裝置。", "name": "車爾尼"}, "figure_art": "avg_4047_pianst_1#1$1"}, {"id": 283, "prop": "name", "attributes": {"content": "如果沒有探測到音樂法術，擴音器會一直保持在關閉的狀態。", "name": "車爾尼"}, "figure_art": "avg_4047_pianst_1#1$1"}, {"id": 284, "prop": "name", "attributes": {"content": "可一旦有人在台上用音樂施術，放大裝置就會被啟動......法術就會被指數級地擴大，隨著音樂擴散到夕照廳外......", "name": "車爾尼"}, "figure_art": "avg_4047_pianst_1#1$1"}, {"id": 285, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#4$1", "name2": "avg_4047_pianst_1#5$1", "focus": 2.0}}, {"id": 286, "prop": "name", "attributes": {"content": "塵世之音的洩漏和共振......也不例外。", "name": "車爾尼"}, "figure_art": "avg_4047_pianst_1#5$1"}, {"id": 287, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#3$1", "name2": "avg_4047_pianst_1#5$1", "focus": 1.0}}, {"id": 288, "prop": "name", "attributes": {"content": "？！", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#3$1"}, {"id": 289, "prop": "dialog", "attributes": {}}, {"id": 290, "prop": "character", "attributes": {}}, {"id": 291, "prop": "character", "attributes": {"name": "avg_4046_ebnhlz_1#9$2"}}, {"id": 292, "prop": "name", "attributes": {"content": "（呆滯的眼神）", "name": "黑鍵"}, "figure_art": "avg_4046_ebnhlz_1#9$2"}, {"id": 293, "prop": "character", "attributes": {"name": "avg_1024_hbisc2_1#11$1"}}, {"id": 294, "prop": "name", "attributes": {"content": "也就是說，所有受到影響的區域，其中的源石活性都會急劇提升，維謝海姆的所有人，幾乎無一例外，全部會受到感染......", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#11$1"}, {"id": 295, "prop": "name", "attributes": {"content": "而那些已經感染了礦石病的人更不可能倖免，他們死後，遺體快速崩解，又會產生大量活性源石微粒......", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#11$1"}, {"id": 296, "prop": "name", "attributes": {"content": "這周圍會變成徹頭徹尾的疫區，維謝海姆將徹底與外界斷絕聯繫——", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#11$1"}, {"id": 297, "prop": "Dialog", "attributes": {}}, {"id": 298, "prop": "Character", "attributes": {}}, {"id": 299, "prop": "Delay", "attributes": {"time": 0.51}}, {"id": 300, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 301, "prop": "character", "attributes": {"name": "avg_npc_484_1#1$1", "blackstart": 0.2, "blackend": 0.7, "fadetime": 1.5}}, {"id": 302, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 303, "prop": "name", "attributes": {"content": "很抱歉打擾你們聊天，不過，我是來向你們提意見的。", "name": "？？？"}, "figure_art": "avg_npc_484_1#1$1"}, {"id": 304, "prop": "name", "attributes": {"content": "如此美妙的夜晚，為什麼要向整個維謝海姆施放令人清醒的法術呢？我可是經常失眠的。", "name": "？？？"}, "figure_art": "avg_npc_484_1#1$1"}, {"id": 305, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#11$1"}}, {"id": 306, "prop": "name", "attributes": {"content": "不好意思，我們現在正在處理很重要的......", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#11$1"}, {"id": 307, "prop": "Character", "attributes": {"name": "avg_4047_pianst_1#3$1"}}, {"id": 308, "prop": "name", "attributes": {"content": "格特魯德？！", "name": "車爾尼"}, "figure_art": "avg_4047_pianst_1#3$1"}, {"id": 309, "prop": "Dialog", "attributes": {}}, {"id": 310, "prop": "Character", "attributes": {}}, {"id": 311, "prop": "Delay", "attributes": {"time": 0.51}}, {"id": 312, "prop": "character", "attributes": {"name": "avg_npc_484_1#1$1", "blackstart": 0.7, "blackend": 0.0, "fadetime": 1.5}}, {"id": 313, "prop": "Delay", "attributes": {"time": 1.6}}, {"id": 314, "prop": "PlayMusic", "attributes": {"intro": "$calamity_intro", "key": "$calamity_loop", "volume": 0.4}}, {"id": 315, "prop": "character", "attributes": {"name": "avg_npc_484_1#1$1"}}, {"id": 316, "prop": "name", "attributes": {"content": "晚上好，車爾尼。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#1$1"}, {"id": 317, "prop": "character", "attributes": {"name": "avg_npc_484_1#7$1"}}, {"id": 318, "prop": "name", "attributes": {"content": "這位就是羅德島的芙蓉幹員吧？幸會。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#7$1"}, {"id": 319, "prop": "name", "attributes": {"content": "至於那邊那個看起來受了什麼打擊的年輕人，要不要去我家喝點什麼，美美地睡上一覺，明天再接著努力一把呢？", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#7$1"}, {"id": 320, "prop": "character", "attributes": {"name": "avg_4046_ebnhlz_1#8$2"}}, {"id": 321, "prop": "name", "attributes": {"content": "格——格特魯德，你竟然——", "name": "黑鍵"}, "figure_art": "avg_4046_ebnhlz_1#8$2"}, {"id": 322, "prop": "character", "attributes": {"name": "avg_npc_484_1#7$1"}}, {"id": 323, "prop": "name", "attributes": {"content": "我竟然？難道你是想說，我竟然騙了你，差點讓你成為害死半城人的兇手？", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#7$1"}, {"id": 324, "prop": "name", "attributes": {"content": "不對吧。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#7$1"}, {"id": 325, "prop": "character", "attributes": {"name": "avg_npc_484_1#13$1"}}, {"id": 326, "prop": "name", "attributes": {"content": "你真正生氣的，是我竟然把你耍得團團轉，甚至差點要了你的命，而你卻毫無察覺，對不對？", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#13$1"}, {"id": 327, "prop": "name", "attributes": {"content": "拿出點貴族的氣魄啊，烏提卡伯爵。來，說點什麼。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#13$1"}, {"id": 328, "prop": "character", "attributes": {"name": "avg_4046_ebnhlz_1#10$2"}}, {"id": 329, "prop": "name", "attributes": {"content": "......", "name": "黑鍵"}, "figure_art": "avg_4046_ebnhlz_1#10$2"}, {"id": 330, "prop": "character", "attributes": {"name": "avg_1024_hbisc2_1#5$1"}}, {"id": 331, "prop": "name", "attributes": {"content": "黑鍵，你別被她挑釁了。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#5$1"}, {"id": 332, "prop": "character", "attributes": {"name": "avg_1024_hbisc2_1#6$1"}}, {"id": 333, "prop": "name", "attributes": {"content": "我現在只有一個疑問：你來到底是想幹什麼？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#6$1"}, {"id": 334, "prop": "Character", "attributes": {"name": "avg_npc_484_1#6$1"}}, {"id": 335, "prop": "name", "attributes": {"content": "當然是因為你們吵醒了我，還能是什麼？", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#6$1"}, {"id": 336, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#5$1"}}, {"id": 337, "prop": "name", "attributes": {"content": "那我就當成是你聽見了剛剛擴散出去的音樂法術的聲音，意識到自己的佈置已經敗露了。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#5$1"}, {"id": 338, "prop": "Character", "attributes": {"name": "avg_npc_484_1#7$1"}}, {"id": 339, "prop": "name", "attributes": {"content": "回答正確。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#7$1"}, {"id": 340, "prop": "Character", "attributes": {"name": "avg_npc_484_1#1$1"}}, {"id": 341, "prop": "name", "attributes": {"content": "真可惜啊，明明只要再拖一天，我的計畫就圓滿成功了。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#1$1"}, {"id": 342, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#5$1"}}, {"id": 343, "prop": "name", "attributes": {"content": "這種時候，你最應該做的難道不是趕緊逃走嗎？難道你覺得，把我們幾個打倒，你的計畫就能進行下去？", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#5$1"}, {"id": 344, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#6$1"}}, {"id": 345, "prop": "name", "attributes": {"content": "黑鍵已經不會幫你了，不管你要用合奏引發什麼陰謀，都不可能再實現了！", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#6$1"}, {"id": 346, "prop": "Character", "attributes": {"name": "avg_npc_484_1#7$1"}}, {"id": 347, "prop": "name", "attributes": {"content": "是嗎？我不這麼覺得。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#7$1"}, {"id": 348, "prop": "Character", "attributes": {"name": "avg_npc_484_1#1$1"}}, {"id": 349, "prop": "name", "attributes": {"content": "只要黑鍵和白堊還在，我的計畫就沒失敗。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#1$1"}, {"id": 350, "prop": "name", "attributes": {"content": "把你們解決掉，我可以繼續和烏提卡伯爵談條件。他很熟悉這種貴族之間討價還價的邏輯，回心轉意也不是不可能。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#1$1"}, {"id": 351, "prop": "Character", "attributes": {"name": "avg_npc_484_1#6$1"}}, {"id": 352, "prop": "name", "attributes": {"content": "最重要的是，我不覺得你們能贏得過我。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#6$1"}, {"id": 353, "prop": "Character", "attributes": {"name": "avg_npc_484_1#7$1"}}, {"id": 354, "prop": "name", "attributes": {"content": "如果你們三個都有烏提卡伯爵這種程度的實力，那我確實不能硬拼，可你們三個，呵呵......失禮。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#7$1"}, {"id": 355, "prop": "Character", "attributes": {"name": "avg_1024_hbisc2_1#5$1"}}, {"id": 356, "prop": "name", "attributes": {"content": "......你休想。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#5$1"}, {"id": 357, "prop": "Character", "attributes": {"name": "avg_npc_484_1#1$1"}}, {"id": 358, "prop": "name", "attributes": {"content": "烏提卡伯爵，要不然，我們倆各退一步吧。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#1$1"}, {"id": 359, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#8$2"}}, {"id": 360, "prop": "name", "attributes": {"content": "各退一步？", "name": "黑鍵"}, "figure_art": "avg_4046_ebnhlz_1#8$2"}, {"id": 361, "prop": "Character", "attributes": {"name": "avg_npc_484_1#7$1"}}, {"id": 362, "prop": "name", "attributes": {"content": "我把這些放大器拆掉，你繼續配合我就好。這樣一來，只要死一個白堊，反正他也沒幾天好活了。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#7$1"}, {"id": 363, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#8$2"}}, {"id": 364, "prop": "name", "attributes": {"content": "做夢。", "name": "黑鍵"}, "figure_art": "avg_4046_ebnhlz_1#8$2"}, {"id": 365, "prop": "Character", "attributes": {"name": "avg_npc_484_1#13$1"}}, {"id": 366, "prop": "name", "attributes": {"content": "那真是遺憾啊，烏提卡伯爵，你迫於形勢，選擇了一條最不適合自己的路。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#13$1"}, {"id": 367, "prop": "Character", "attributes": {"name": "avg_npc_484_1#10$1"}}, {"id": 368, "prop": "name", "attributes": {"content": "如果你是真心的也就算了，可惜——", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#10$1"}, {"id": 369, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#8$2"}}, {"id": 370, "prop": "name", "attributes": {"content": "閉嘴——", "name": "黑鍵"}, "figure_art": "avg_4046_ebnhlz_1#8$2"}, {"id": 371, "prop": "Character", "attributes": {"name": "avg_npc_484_1#1$1"}}, {"id": 372, "prop": "name", "attributes": {"content": "你會後悔一輩子的。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#1$1"}, {"id": 373, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#10$2"}}, {"id": 374, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 375, "prop": "name", "attributes": {"content": "閉嘴！！", "name": "黑鍵"}, "figure_art": "avg_4046_ebnhlz_1#10$2"}, {"id": 376, "prop": "Character", "attributes": {"name": "avg_npc_484_1#10$1"}}, {"id": 377, "prop": "name", "attributes": {"content": "事已至此，看來我們只能打一架了。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#10$1"}, {"id": 378, "prop": "name", "attributes": {"content": "如果我贏了，自封的夕照區守衛者們就只好乖乖閉嘴，我可以繼續和烏提卡伯爵談條件。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#10$1"}, {"id": 379, "prop": "name", "attributes": {"content": "如果你們贏了，我也沒什麼好說的，輸了就是輸了。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#10$1"}, {"id": 380, "prop": "Character", "attributes": {"name": "avg_npc_484_1#13$1"}}, {"id": 381, "prop": "name", "attributes": {"content": "拔杖吧，烏提卡伯爵，難道你想讓兩個感染者替你打頭陣？", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#13$1"}, {"id": 382, "prop": "character", "attributes": {"name": "avg_1024_hbisc2_1#5$1"}}, {"id": 383, "prop": "name", "attributes": {"content": "我說過了，這樣的挑釁是沒用的。", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#5$1"}, {"id": 384, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#8$2"}}, {"id": 385, "prop": "name", "attributes": {"content": "芙蓉，別礙事，我今天一定要——", "name": "黑鍵"}, "figure_art": "avg_4046_ebnhlz_1#8$2"}, {"id": 386, "prop": "character", "attributes": {"name": "avg_1024_hbisc2_1#6$1"}}, {"id": 387, "prop": "name", "attributes": {"content": "你好好想想，這是哪裡，這裡佈置了什麼！", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#6$1"}, {"id": 388, "prop": "name", "attributes": {"content": "除非你能做到一點音樂法術都不用，否則搞不好瘟疫還沒來，你先把維謝海姆的居民都變成了瘋子！", "name": "芙蓉"}, "figure_art": "avg_1024_hbisc2_1#6$1"}, {"id": 389, "prop": "Character", "attributes": {"name": "avg_npc_484_1#13$1"}}, {"id": 390, "prop": "name", "attributes": {"content": "嘖嘖嘖，腦子很快啊，芙蓉小姐。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#13$1"}, {"id": 391, "prop": "Character", "attributes": {"name": "avg_npc_484_1#13$1"}}, {"id": 392, "prop": "name", "attributes": {"content": "沒辦法，既然被你識破了，那我們去外面決一勝負吧。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#13$1"}, {"id": 393, "prop": "name", "attributes": {"content": "事先提醒一下，可不要以為逃走就算是勝利了。我個人是不想對無關人士動粗的，但我的手下可未必。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#13$1"}, {"id": 394, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#1$2"}}, {"id": 395, "prop": "name", "attributes": {"content": "帶這麼多人過來，看來你對自己沒什麼信心。", "name": "黑鍵"}, "figure_art": "avg_4046_ebnhlz_1#1$2"}, {"id": 396, "prop": "Character", "attributes": {"name": "avg_npc_484_1#7$1"}}, {"id": 397, "prop": "name", "attributes": {"content": "終於聽見了熟悉的冷嘲熱諷，我都要感動哭了。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#7$1"}, {"id": 398, "prop": "name", "attributes": {"content": "看來你好些了，烏提卡伯爵？", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#7$1"}, {"id": 399, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#1$2"}}, {"id": 400, "prop": "name", "attributes": {"content": "當然，斯特羅洛女士。", "name": "黑鍵"}, "figure_art": "avg_4046_ebnhlz_1#1$2"}, {"id": 401, "prop": "Character", "attributes": {"name": "avg_npc_484_1#7$1"}}, {"id": 402, "prop": "name", "attributes": {"content": "出去吧，讓我們痛痛快快地打一場。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#7$1"}, {"id": 403, "prop": "name", "attributes": {"content": "在烏提卡沒人陪你玩打架遊戲，一定很寂寞吧？", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#7$1"}, {"id": 404, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#1$2"}}, {"id": 405, "prop": "name", "attributes": {"content": "要是有其他對手，我也不想和你這樣的阿姨玩啊。", "name": "黑鍵"}, "figure_art": "avg_4046_ebnhlz_1#1$2"}, {"id": 406, "prop": "name", "attributes": {"content": "畢竟你連爵位都沒爭過自己的親哥哥，還要等他死掉再上位，我猜你和他打架一定沒贏過。", "name": "黑鍵"}, "figure_art": "avg_4046_ebnhlz_1#1$2"}, {"id": 407, "prop": "Character", "attributes": {"name": "avg_npc_484_1#6$1"}}, {"id": 408, "prop": "name", "attributes": {"content": "很好，很好，我越來越討厭你了。", "name": "格特魯德"}, "figure_art": "avg_npc_484_1#6$1"}, {"id": 409, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#8$2"}}, {"id": 410, "prop": "name", "attributes": {"content": "彼此彼此。", "name": "黑鍵"}, "figure_art": "avg_4046_ebnhlz_1#8$2"}, {"id": 411, "prop": "Dialog", "attributes": {}}, {"id": 412, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 413, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 414, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 415, "prop": "Character", "attributes": {}}, {"id": 416, "prop": "Image", "attributes": {}}, {"id": 417, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}