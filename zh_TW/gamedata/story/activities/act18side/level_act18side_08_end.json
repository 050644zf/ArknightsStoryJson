1#1$1", "focus": 2.0}}, {"id": 160, "prop": "name", "attributes": {"content": "（深呼吸）", "name": "白堊"}, "figure_art": "avg_npc_483_1#1$1"}, {"id": 161, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#6$2", "name2": "avg_npc_483_1#2$1", "focus": 2.0}}, {"id": 162, "prop": "name", "attributes": {"content": "我覺得......身體好輕......", "name": "白堊"}, "figure_art": "avg_npc_483_1#2$1"}, {"id": 163, "prop": "name", "attributes": {"content": "剛剛一直很痛，但現在好多了......", "name": "白堊"}, "figure_art": "avg_npc_483_1#2$1"}, {"id": 164, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#6$2", "name2": "avg_npc_483_1#2$1", "focus": 1.0}}, {"id": 165, "prop": "name", "attributes": {"content": "嗯，會好的，肯定會好的......", "name": "黑鍵"}, "figure_art": "avg_4046_ebnhlz_1#6$2"}, {"id": 166, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#6$2", "name2": "avg_npc_483_1#3$1", "focus": 2.0}}, {"id": 167, "prop": "name", "attributes": {"content": "聽好了，黑鍵，這是我最後一次跟你說話了。", "name": "白堊"}, "figure_art": "avg_npc_483_1#3$1"}, {"id": 168, "prop": "name", "attributes": {"content": "記著我的話。", "name": "白堊"}, "figure_art": "avg_npc_483_1#3$1"}, {"id": 169, "prop": "name", "attributes": {"content": "黑鍵，你要活下去，你要走過漫長的夜晚。", "name": "白堊"}, "figure_art": "avg_npc_483_1#3$1"}, {"id": 170, "prop": "name", "attributes": {"content": "你要去反抗那些不公的命運，並且孜孜不倦地為他人付出。", "name": "白堊"}, "figure_art": "avg_npc_483_1#3$1"}, {"id": 171, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#6$2", "name2": "avg_npc_483_1#2$1", "focus": 2.0}}, {"id": 172, "prop": "name", "attributes": {"content": "只有這樣，當你坐下來的時候，才會想到我。", "name": "白堊"}, "figure_art": "avg_npc_483_1#2$1"}, {"id": 173, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#6$2", "name2": "avg_npc_483_1#1$1", "focus": 2.0}}, {"id": 174, "prop": "name", "attributes": {"content": "我會問你，黑鍵，你今天過得如何？", "name": "白堊"}, "figure_art": "avg_npc_483_1#1$1"}, {"id": 175, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#6$2", "name2": "avg_npc_483_1#2$1", "focus": 2.0}}, {"id": 176, "prop": "name", "attributes": {"content": "然後，你會挺起胸膛告訴我，你又度過了充實的一天。", "name": "白堊"}, "figure_art": "avg_npc_483_1#2$1"}, {"id": 177, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#6$2", "name2": "avg_npc_483_1#1$1", "focus": 2.0}}, {"id": 178, "prop": "name", "attributes": {"content": "你會向我傾訴你在行善過程中遭遇的障礙，以及抱怨命運始終不願青睞於你。", "name": "白堊"}, "figure_art": "avg_npc_483_1#1$1"}, {"id": 179, "prop": "name", "attributes": {"content": "但是沒有關係，我會傾聽你的一切。", "name": "白堊"}, "figure_art": "avg_npc_483_1#1$1"}, {"id": 180, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#6$2", "name2": "avg_npc_483_1#2$1", "focus": 2.0}}, {"id": 181, "prop": "name", "attributes": {"content": "因為你是那麼努力，你當然可以去抱怨一下。", "name": "白堊"}, "figure_art": "avg_npc_483_1#2$1"}, {"id": 182, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#6$2", "name2": "avg_npc_483_1#1$1", "focus": 2.0}}, {"id": 183, "prop": "name", "attributes": {"content": "只有這樣，你才不會被這片大地上的苦痛所淹沒，你才能在你的生活中獲得安寧。", "name": "白堊"}, "figure_art": "avg_npc_483_1#1$1"}, {"id": 184, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#6$2", "name2": "avg_npc_483_1#3$1", "focus": 2.0}}, {"id": 185, "prop": "name", "attributes": {"content": "記著，黑鍵，我們曾經一同反抗了不公平的命，而我們得了勝！", "name": "白堊"}, "figure_art": "avg_npc_483_1#3$1"}, {"id": 186, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#6$2", "name2": "avg_npc_483_1#2$1", "focus": 2.0}}, {"id": 187, "prop": "name", "attributes": {"content": "所以，想到我的時候，你應當笑，而不是哭。", "name": "白堊"}, "figure_art": "avg_npc_483_1#2$1"}, {"id": 188, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#10$2", "name2": "avg_npc_483_1#2$1", "focus": 1.0}}, {"id": 189, "prop": "name", "attributes": {"content": "嗯，嗯！", "name": "黑鍵"}, "figure_art": "avg_4046_ebnhlz_1#10$2"}, {"id": 190, "prop": "Character", "attributes": {"name": "avg_4046_ebnhlz_1#10$2", "name2": "avg_npc_483_1#1$1", "focus": 2.0}}, {"i