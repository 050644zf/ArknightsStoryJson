{"lang": "zh_TW", "eventid": "act3d0", "eventName": "火藍之心", "entryType": "ACTIVITY", "storyCode": "OF-ST3", "avgTag": "幕間", "storyName": "壓力之下", "storyInfo": "博士和錫蘭一邊散步一邊談心，最終，錫蘭堅定了自己的想法，並制定了一個計畫。\n", "storyList": [{"id": 0, "prop": "HEADER", "attributes": {"key": "title_test", "is_skippable": "true", "fit_mode": "BLACK_MASK"}}, {"id": 1, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 2, "prop": "Dialog", "attributes": {}}, {"id": 3, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 4, "prop": "Character", "attributes": {}}, {"id": 5, "prop": "largebg", "attributes": {"imagegroup": "bg_beach_1/bg_beach_2", "solidwidth": "920/920", "solidheight": 720.0}}, {"id": 6, "prop": "playsound", "attributes": {"key": "$beach", "volume": 0.7, "channel": "B", "loop": "true"}}, {"id": 7, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 8, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#9"}}, {"id": 9, "prop": "name", "attributes": {"content": "   ......可以陪我逛逛嗎，博士。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#9"}, {"id": 10, "prop": "Decision", "attributes": {"options": "我有些擔心你。", "values": "1"}, "targetLine": {"option1": "line11"}}, {"id": 11, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 12, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#9"}}, {"id": 13, "prop": "name", "attributes": {"content": "   博士，你知道嗎，我小的時候，這片沙灘沒有這麼多人的。我很喜歡一個人在那裡堆沙子城堡。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#9"}, {"id": 14, "prop": "name", "attributes": {"content": "   ......這座城市在我父親的治理下，每一年都在變得更好。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#9"}, {"id": 15, "prop": "name", "attributes": {"content": "   我和我的父親，該怎麼說呢，話並不多。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#9"}, {"id": 16, "prop": "name", "attributes": {"content": "   我一直在想，是不是比起跟我多說說話，城市和賺錢對他才更重要。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#9"}, {"id": 17, "prop": "name", "attributes": {"content": "   母親在生我的時候就去世了，我有時候也會想是不是因為這樣，他才不喜歡我。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#9"}, {"id": 18, "prop": "name", "attributes": {"content": "   仿佛也不在乎我喜不喜歡他，自我記事起，他就經常不在家裡。與其說是父女，更像是住在同一座房子裡的陌生人。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#9"}, {"id": 19, "prop": "PlayMusic", "attributes": {"intro": "$path_intro", "key": "$path_loop", "volume": 0.8, "crossfade": 1.5}}, {"id": 20, "prop": "Dialog", "attributes": {}}, {"id": 21, "prop": "Blocker", "attributes": {"a": 1.0, "initr": 2.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 22, "prop": "largebg", "attributes": {}}, {"id": 23, "prop": "Background", "attributes": {"image": "bg_hotel", "screenadapt": "coverall", "block": "true"}}, {"id": 24, "prop": "Character", "attributes": {"fadetime": 0.0}}, {"id": 25, "prop": "cameraEffect", "attributes": {"effect": "Grayscale", "keep": "true", "amount": 1.0, "fadetime": 0.0}}, {"id": 26, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 27, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#6", "name2": "char_340_shwaz_2#1", "focus": 1.0}}, {"id": 28, "prop": "name", "attributes": {"content": "   黑，我要出門去觀察海邊的生態！", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#6"}, {"id": 29, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#6", "name2": "char_340_shwaz_2#1", "focus": 2.0}}, {"id": 30, "prop": "name", "attributes": {"content": "   不行，小姐，老爺吩咐過，不能隨便出門的。", "name": "黑"}, "figure_art": "char_340_shwaz_2#1"}, {"id": 31, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#1", "name2": "char_340_shwaz_2#1", "focus": 1.0}}, {"id": 32, "prop": "name", "attributes": {"content": "   可家裡的書我已經看膩了！黑你又一點也不好玩。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#1"}, {"id": 33, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#1", "name2": "char_340_shwaz_2#3", "focus": 2.0}}, {"id": 34, "prop": "name", "attributes": {"content": "   對不起，小姐。這也是為了您的安全著想，外面是很危險的。", "name": "黑"}, "figure_art": "char_340_shwaz_2#3"}, {"id": 35, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#4", "name2": "char_340_shwaz_2#3", "focus": 1.0}}, {"id": 36, "prop": "name", "attributes": {"content": "   不是有你在嗎，難道你會讓我身處危險嗎？", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#4"}, {"id": 37, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#4", "name2": "char_340_shwaz_2#3", "focus": 2.0}}, {"id": 38, "prop": "name", "attributes": {"content": "   ......那自然是肯定不會的。", "name": "黑"}, "figure_art": "char_340_shwaz_2#3"}, {"id": 39, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#6", "name2": "char_340_shwaz_2#3", "focus": 1.0}}, {"id": 40, "prop": "name", "attributes": {"content": "   那還有什麼問題？我們走！", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#6"}, {"id": 41, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#6", "name2": "char_340_shwaz_2#3", "focus": 2.0}}, {"id": 42, "prop": "name", "attributes": {"content": "   ......那麼，請您絕對不要離開我的視線。", "name": "黑"}, "figure_art": "char_340_shwaz_2#3"}, {"id": 43, "prop": "Dialog", "attributes": {}}, {"id": 44, "prop": "Blocker", "attributes": {"a": 1.0, "initr": 2.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 45, "prop": "Background", "attributes": {"image": "bg_sunnytown_1", "screenadapt": "coverall", "block": "true"}}, {"id": 46, "prop": "Character", "attributes": {"fadetime": 0.0}}, {"id": 47, "prop": "cameraEffect", "attributes": {"effect": "Grayscale", "keep": "true", "amount": 0.0, "fadetime": 0.0}}, {"id": 48, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 49, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#5"}}, {"id": 50, "prop": "name", "attributes": {"content": "   可以說，黑在我的身邊這件事，對我來說，是我的生活中最理所當然不過的一部分了。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#5"}, {"id": 51, "prop": "Dialog", "attributes": {}}, {"id": 52, "prop": "Blocker", "attributes": {"a": 1.0, "initr": 2.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 53, "prop": "stopsound", "attributes": {"channel": "B", "fadetime": 1.0}}, {"id": 54, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 55, "prop": "Background", "attributes": {"image": "bg_sunnytown_1", "screenadapt": "coverall", "block": "true"}}, {"id": 56, "prop": "Character", "attributes": {"fadetime": 0.0}}, {"id": 57, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 58, "prop": "name", "attributes": {"content": "   快點，這批裝飾是今晚的LIVE要用到的。", "name": "男市民"}}, {"id": 59, "prop": "name", "attributes": {"content": "   要是趕不上了可就麻煩了！", "name": "男市民"}}, {"id": 60, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#5"}}, {"id": 61, "prop": "name", "attributes": {"content": "   啊，那個人......", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#5"}, {"id": 62, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#4"}}, {"id": 63, "prop": "name", "attributes": {"content": "   沒記錯的話，是第二大道那家“知更鳥咖啡店”的店主爺爺的孫子。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#4"}, {"id": 64, "prop": "name", "attributes": {"content": "   那裡是我以前常去的地方，店主爺爺很和藹。店裡裝飾著他去世的妻子奇幻的花和盆栽，放著他們以前一起喜歡的音樂。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#4"}, {"id": 65, "prop": "name", "attributes": {"content": "   這麼說來，他確實說過，身體不行了，要把店傳給孫子了呢。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#4"}, {"id": 66, "prop": "name", "attributes": {"content": "   時間過得真快。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#4"}, {"id": 67, "prop": "Dialog", "attributes": {}}, {"id": 68, "prop": "Blocker", "attributes": {"a": 1.0, "initr": 2.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 69, "prop": "Background", "attributes": {"image": "bg_hotel", "screenadapt": "coverall", "block": "true"}}, {"id": 70, "prop": "Character", "attributes": {"fadetime": 0.0}}, {"id": 71, "prop": "cameraEffect", "attributes": {"effect": "Grayscale", "keep": "true", "amount": 1.0, "fadetime": 0.0}}, {"id": 72, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 73, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#7", "name2": "char_340_shwaz_2#3", "focus": 1.0}}, {"id": 74, "prop": "name", "attributes": {"content": "   為什麼？", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#7"}, {"id": 75, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#7", "name2": "char_340_shwaz_2#3", "focus": 2.0}}, {"id": 76, "prop": "name", "attributes": {"content": "   因為我得了礦石病，小姐。", "name": "黑"}, "figure_art": "char_340_shwaz_2#3"}, {"id": 77, "prop": "name", "attributes": {"content": "   靠近我對您的身體不好，您只要在需要的時候叫我就好。", "name": "黑"}, "figure_art": "char_340_shwaz_2#3"}, {"id": 78, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#8", "name2": "char_340_shwaz_2#3", "focus": 1.0}}, {"id": 79, "prop": "name", "attributes": {"content": "   那是什麼，很痛嗎？", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#8"}, {"id": 80, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#8", "name2": "char_340_shwaz_2#3", "focus": 2.0}}, {"id": 81, "prop": "name", "attributes": {"content": "   ......不會很痛，但是，會死。", "name": "黑"}, "figure_art": "char_340_shwaz_2#3"}, {"id": 82, "prop": "name", "attributes": {"content": "   這種病是治不了的，小姐。", "name": "黑"}, "figure_art": "char_340_shwaz_2#3"}, {"id": 83, "prop": "name", "attributes": {"content": "   而且......", "name": "黑"}, "figure_art": "char_340_shwaz_2#3"}, {"id": 84, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#3", "name2": "char_340_shwaz_2#3", "focus": 1.0}}, {"id": 85, "prop": "name", "attributes": {"content": "   我偏要把它治好！", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#3"}, {"id": 86, "prop": "name", "attributes": {"content": "   哼，你等著吧！將來有一天，我會把它給打敗，然後把黑從它手裡搶回來。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#3"}, {"id": 87, "prop": "Dialog", "attributes": {}}, {"id": 88, "prop": "Blocker", "attributes": {"a": 1.0, "initr": 2.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 89, "prop": "largebg", "attributes": {}}, {"id": 90, "prop": "Background", "attributes": {"image": "bg_sunnytown_1", "screenadapt": "coverall", "block": "true"}}, {"id": 91, "prop": "Character", "attributes": {"fadetime": 0.0}}, {"id": 92, "prop": "cameraEffect", "attributes": {"effect": "Grayscale", "keep": "true", "amount": 0.0, "fadetime": 0.0}}, {"id": 93, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 94, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#9"}}, {"id": 95, "prop": "name", "attributes": {"content": "   我會想要研究源石，也是因為她是感染者，我想要把她治好。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#9"}, {"id": 96, "prop": "name", "attributes": {"content": "   這是一直以來支持我的動力啊，為了這個夢想，我可是去了維多利亞讀書欸。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#9"}, {"id": 97, "prop": "name", "attributes": {"content": "   晦澀難懂的源石研究，我一開始完全搞不懂，好幾次都想放棄了，最後還是堅持了下來。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#9"}, {"id": 98, "prop": "name", "attributes": {"content": "   維多利亞也好遠啊，本來我一開始還完全不習慣那裡的。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#9"}, {"id": 99, "prop": "Dialog", "attributes": {}}, {"id": 100, "prop": "Blocker", "attributes": {"a": 1.0, "initr": 2.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 101, "prop": "largebg", "attributes": {"imagegroup": "bg_beach_1/bg_beach_2", "solidwidth": "920/920", "solidheight": 720.0}}, {"id": 102, "prop": "Character", "attributes": {"fadetime": 0.0}}, {"id": 103, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 104, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#9"}}, {"id": 105, "prop": "name", "attributes": {"content": "   結果到了現在，我與其說是一個汐斯塔人，不如說是一個維多利亞人了。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#9"}, {"id": 106, "prop": "name", "attributes": {"content": "   博士，難道說，我所擁有的一切，都是假的嗎？", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#9"}, {"id": 107, "prop": "Dialog", "attributes": {}}, {"id": 108, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 109, "prop": "largebg", "attributes": {"imagegroup": "bg_beach_1/bg_beach_2", "solidwidth": "920/920", "solidheight": 720.0}}, {"id": 110, "prop": "Character", "attributes": {}}, {"id": 111, "prop": "cameraEffect", "attributes": {"effect": "Grayscale", "keep": "true", "amount": 1.0, "fadetime": 0.0}}, {"id": 112, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 2.0, "block": "false"}}, {"id": 113, "prop": "Character", "attributes": {"name": "char_340_shwaz_2#1"}}, {"id": 114, "prop": "name", "attributes": {"content": "   為了守護這裡，我可以付出很多東西。", "name": "黑"}, "figure_art": "char_340_shwaz_2#1"}, {"id": 115, "prop": "Dialog", "attributes": {}}, {"id": 116, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 117, "prop": "Character", "attributes": {}}, {"id": 118, "prop": "cameraEffect", "attributes": {"effect": "Grayscale", "keep": "true", "amount": 0.0, "fadetime": 0.0}}, {"id": 119, "prop": "largebg", "attributes": {"imagegroup": "bg_beach_1/bg_beach_2", "solidwidth": "920/920", "solidheight": 720.0}}, {"id": 120, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 2.0, "block": "false"}}, {"id": 121, "prop": "Decision", "attributes": {"options": "我也不知道。;她說不定也有苦衷。", "values": "1;2"}, "targetLine": {"option1": "line122", "option2": "line125"}}, {"id": 122, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false, "targetLine": "line129"}, {"id": 123, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#5"}}, {"id": 124, "prop": "name", "attributes": {"content": "   ......呼。是啊，博士又怎麼會知道呢。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#5"}, {"id": 125, "prop": "Predicate", "attributes": {"references": "2"}, "endOfOpt": false, "targetLine": "line129"}, {"id": 126, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#9"}}, {"id": 127, "prop": "name", "attributes": {"content": "   有什麼苦衷，連我也不能告訴嗎？", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#9"}, {"id": 128, "prop": "name", "attributes": {"content": "   而且，無論有什麼樣的苦衷，做了壞事就是做了壞事，這是無法回避的。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#9"}, {"id": 129, "prop": "Predicate", "attributes": {"references": "1;2"}, "endOfOpt": true}, {"id": 130, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#9"}}, {"id": 131, "prop": "name", "attributes": {"content": "   博士，你說，我應該放棄嗎？", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#9"}, {"id": 132, "prop": "Dialog", "attributes": {}}, {"id": 133, "prop": "Decision", "attributes": {"options": "我很難就這件事給你答案......", "values": "3"}, "targetLine": {"option3": "line134"}}, {"id": 134, "prop": "Predicate", "attributes": {"references": "3"}, "endOfOpt": false}, {"id": 135, "prop": "Decision", "attributes": {"options": "但是我知道的是，你也是研究源石的學者。", "values": "4"}, "targetLine": {"option4": "line136"}}, {"id": 136, "prop": "Predicate", "attributes": {"references": "4"}, "endOfOpt": false}, {"id": 137, "prop": "Character", "attributes": {}}, {"id": 138, "prop": "Dialog", "attributes": {}}, {"id": 139, "prop": "Blocker", "attributes": {"a": 1.0, "initr": 2.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 140, "prop": "largebg", "attributes": {}}, {"id": 141, "prop": "Background", "attributes": {}}, {"id": 142, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 143, "prop": "name", "attributes": {"content": "我們能戰勝礦石病嗎？"}}, {"id": 144, "prop": "name", "attributes": {"content": "我們能拯救礦石病人嗎？"}}, {"id": 145, "prop": "name", "attributes": {"content": "這災難會有盡頭嗎？"}}, {"id": 146, "prop": "name", "attributes": {"content": "我看不到盡頭。我沒有把握。我不知道答案。"}}, {"id": 147, "prop": "name", "attributes": {"content": "我可以放棄嗎？可以。"}}, {"id": 148, "prop": "name", "attributes": {"content": "但我不願意。"}}, {"id": 149, "prop": "Dialog", "attributes": {}}, {"id": 150, "prop": "Blocker", "attributes": {"a": 1.0, "initr": 2.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 151, "prop": "largebg", "attributes": {"imagegroup": "bg_beach_1/bg_beach_2", "solidwidth": "920/920", "solidheight": 720.0}}, {"id": 152, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 153, "prop": "Decision", "attributes": {"options": "這片大地也許很糟......", "values": "5"}, "targetLine": {"option5": "line154"}}, {"id": 154, "prop": "Predicate", "attributes": {"references": "5"}, "endOfOpt": false}, {"id": 155, "prop": "Decision", "attributes": {"options": "但你做的一切，並不是徒勞的。", "values": "6"}, "targetLine": {"option6": "line156"}}, {"id": 156, "prop": "Predicate", "attributes": {"references": "6"}, "endOfOpt": false}, {"id": 157, "prop": "Decision", "attributes": {"options": "相信你自己的選擇。", "values": "7"}, "targetLine": {"option7": "line158"}}, {"id": 158, "prop": "Predicate", "attributes": {"references": "7"}, "endOfOpt": false}, {"id": 159, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#2"}}, {"id": 160, "prop": "name", "attributes": {"content": "   ......呼。你說得對，博士。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#2"}, {"id": 161, "prop": "name", "attributes": {"content": "   不愧是前輩，我在這方面看來要學習的還有許多呢。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#2"}, {"id": 162, "prop": "Character", "attributes": {"name": "char_348_ceylon_4#4"}}, {"id": 163, "prop": "name", "attributes": {"content": "   看來我要做的，不是坐在這裡胡思亂想，而是取證。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#4"}, {"id": 164, "prop": "name", "attributes": {"content": "   如果他們真的是會放任市民們陷入危機的話，我一定會盡我的全力去阻止他們！", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#4"}, {"id": 165, "prop": "name", "attributes": {"content": "   而且既然我相信自己絕對是正確的，即使是只有我一個人，我也會為了拯救這個城市而努力的！", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#4"}, {"id": 166, "prop": "Character", "attributes": {"name": "char_188_helage_1#2", "name2": "char_348_ceylon_4#4", "focus": 1.0}}, {"id": 167, "prop": "name", "attributes": {"content": "   說的不錯。", "name": "赫拉格"}, "figure_art": "char_188_helage_1#2"}, {"id": 168, "prop": "Character", "attributes": {"name": "char_188_helage_1#2", "name2": "char_348_ceylon_4#8", "focus": 2.0}}, {"id": 169, "prop": "name", "attributes": {"content": "   啊，赫拉格爺爺。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#8"}, {"id": 170, "prop": "Character", "attributes": {"name": "char_188_helage_1#2", "name2": "char_348_ceylon_4#8", "focus": 1.0}}, {"id": 171, "prop": "name", "attributes": {"content": "   看來，心情收拾得還不錯。", "name": "赫拉格"}, "figure_art": "char_188_helage_1#2"}, {"id": 172, "prop": "Character", "attributes": {"name": "char_188_helage_1#2", "name2": "char_348_ceylon_4#2", "focus": 2.0}}, {"id": 173, "prop": "name", "attributes": {"content": "   嗯。赫拉格爺爺，博士，你們能聽我說嗎。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#2"}, {"id": 174, "prop": "name", "attributes": {"content": "   不管怎麼樣，我也不希望讓汐斯塔市的人們陷入危險。對我來說這個才是最為優先的。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#2"}, {"id": 175, "prop": "name", "attributes": {"content": "   在加里森遊樂場的旁邊有著全市最大的廣播塔，全城市的廣播系統都是在那裡運行。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#2"}, {"id": 176, "prop": "Character", "attributes": {"name": "char_188_helage_1#3", "name2": "char_348_ceylon_4#2", "focus": 1.0}}, {"id": 177, "prop": "name", "attributes": {"content": "   廣播塔？", "name": "赫拉格"}, "figure_art": "char_188_helage_1#3"}, {"id": 178, "prop": "Character", "attributes": {"name": "char_188_helage_1#3", "name2": "char_348_ceylon_4#2", "focus": 2.0}}, {"id": 179, "prop": "name", "attributes": {"content": "   但是，那裡也是克洛寧管轄的區域。他也常常在面向全市的廣播中露面。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#2"}, {"id": 180, "prop": "name", "attributes": {"content": "   趁著LIVE開始的時候，人群集中起來，克洛寧的人也難免應接不暇。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#2"}, {"id": 181, "prop": "name", "attributes": {"content": "   只要我們能在那個時候控制電台，就能向全城的人傳遞火山的情報。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#2"}, {"id": 182, "prop": "name", "attributes": {"content": "   所以拜託你們了，請助我一臂之力吧。", "name": "錫蘭"}, "figure_art": "char_348_ceylon_4#2"}, {"id": 183, "prop": "Dialog", "attributes": {}}, {"id": 184, "prop": "Blocker", "attributes": {"block": "true"}}, {"id": 185, "prop": "Image", "attributes": {}}, {"id": 186, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}