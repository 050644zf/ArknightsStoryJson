"charslot", "attributes": {"slot": "l", "name": "avg_1028_texas2_1#1$1", "duration": 1.0}}, {"id": 21, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 22, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1564_1#9$1", "posfrom": "-200,0", "posto": "0,0", "duration": 0.8}}, {"id": 23, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 24, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1564_1#9$1", "focus": "r"}}, {"id": 25, "prop": "multiline", "attributes": {"name": "拉普蘭德", "content": "還有我……"}}, {"id": 26, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1564_1#3$1", "focus": "r"}}, {"id": 27, "prop": "multiline", "attributes": {"name": "拉普蘭德", "content": "怎麼，不歡迎？"}}, {"id": 28, "prop": "dialog", "attributes": {}}, {"id": 29, "prop": "charslot", "attributes": {}}, {"id": 30, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4065_judge_1#5$1"}}, {"id": 31, "prop": "name", "attributes": {"content": "……拉普蘭德？", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#5$1"}, {"id": 32, "prop": "dialog", "attributes": {}}, {"id": 33, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 34, "prop": "charslot", "attributes": {}}, {"id": 35, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1564_1#3$1"}}, {"id": 36, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 37, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4065_judge_1#7$1", "posfrom": "-150,0", "posto": "0,0", "duration": 1.0}}, {"id": 38, "prop": "delay", "attributes": {"time": 1.6}}, {"id": 39, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1564_1#3$1", "focus": "r"}}, {"id": 40, "prop": "name", "attributes": {"content": "別這麼如臨大敵，要是驚擾到病人怎麼辦？", "name": "拉普蘭德"}, "figure_art": "avg_npc_1564_1#3$1"}, {"id": 41, "prop": "name", "attributes": {"content": "德克薩斯，快告訴法官小姐，我真的只是過來送文件的。", "name": "拉普蘭德"}, "figure_art": "avg_npc_1564_1#3$1"}, {"id": 42, "prop": "dialog", "attributes": {}}, {"id": 43, "prop": "charslot", "attributes": {}}, {"id": 44, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1028_texas2_1#1$1"}}, {"id": 45, "prop": "name", "attributes": {"content": "（點頭）", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 46, "prop": "dialog", "attributes": {}}, {"id": 47, "prop": "charslot", "attributes": {}}, {"id": 48, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4065_judge_1#7$1", "focus": "r"}}, {"id": 49, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1564_1#9$1", "focus": "r"}}, {"id": 50, "prop": "name", "attributes": {"content": "接著，大法官小姐。", "name": "拉普蘭德"}, "figure_art": "avg_npc_1564_1#9$1"}, {"id": 51, "prop": "name", "attributes": {"content": "剛剛在門口碰見個小法官送卷宗來給你。市長大人的病房不能有太多人打擾，我和德克薩斯就順便幫你帶了進來。", "name": "拉普蘭德"}, "figure_art": "avg_npc_1564_1#9$1"}, {"id": 52, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4065_judge_1#5$1", "focus": "l"}}, {"id": 53, "prop": "name", "attributes": {"content": "……", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#5$1"}, {"id": 54, "prop": "dialog", "attributes": {}}, {"id": 55, "prop": "playsound", "attributes": {"key": "$d_avg_paper1"}}, {"id": 56, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 57, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4065_judge_1#4$1", "focus": "l"}}, {"id": 58, "prop": "name", "attributes": {"content": "新沃爾西尼港失火，緊急庭審流程——被告伊雷妮？", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#4$1"}, {"id": 59, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1564_1#9$1", "focus": "r"}}, {"id": 60, "prop": "name", "attributes": {"content": "……", "name": "拉普蘭德"}, "figure_art": "avg_npc_1564_1#9$1"}, {"id": 61, "prop": "name", "attributes": {"content": "那個司機小姐是你的朋友吧？別緊張，往後翻，直接看審判結果，她當庭就被無罪釋放了。", "name": "拉普蘭德"}, "figure_art": "avg_npc_1564_1#9$1"}, {"id": 62, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1564_1#3$1", "focus": "r"}}, {"id": 63, "prop": "name", "attributes": {"content": "我和德克薩斯碰巧去聽了那場庭審，很精彩，威尼斯家族——", "name": "拉普蘭德"}, "figure_art": "avg_npc_1564_1#3$1"}, {"id": 64, "prop": "name", "attributes": {"content": "哈哈，抱歉抱歉，是威尼斯載具公司和薩盧佐酒業的老闆同時為她作證，還在庭審結束後爭著搶著送她回家……", "name": "拉普蘭德"}, "figure_art": "avg_npc_1564_1#3$1"}, {"id": 65, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1564_1#9$1", "focus": "r"}}, {"id": 66, "prop": "name", "attributes": {"content": "嘖嘖，司機小姐的人緣可真好！", "name": "拉普蘭德"}, "figure_art": "avg_npc_1564_1#9$1"}, {"id": 67, "prop": "name", "attributes": {"content": "就是她走出法院的樣子，讓我想起了家族成員們進法院逛一圈出來的成人禮。", "name": "拉普蘭德"}, "figure_art": "avg_npc_1564_1#9$1"}, {"id": 68, "prop": "Dialog", "attributes": {}}, {"id": 69, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 70, "prop": "charslot", "attributes": {}}, {"id": 71, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 72, "prop": "Background", "attributes": {"image": "56_g5_courtsquare_d", "screenadapt": "coverall"}}, {"id": 73, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 74, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 75, "prop": "animtext", "attributes": {"content": "<p=2>1100年11月8日    11:35 A.M.</>", "id": "at1", "name": "group_location_stamp", "style": "avg_only_medium", "pos": "-400,-200", "block": "false", "p": 2.0}}, {"id": 76, "prop": "delay", "attributes": {"time": 3.0}}, {"id": 77, "prop": "animtextclean", "attributes": {}}, {"id": 78, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 79, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 80, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1542_1#2$1", "duration": 1.0}}, {"id": 81, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 82, "prop": "name", "attributes": {"content": "……", "name": "伊雷妮"}, "figure_art": "avg_npc_1542_1#2$1"}, {"id": 83, "prop": "charslot", "attributes": {}}, {"id": 84, "prop": "name", "attributes": {"content": "簽名確認，領走判決書，離開法院。流程並不麻煩，但伊雷妮還是覺得有點頭暈。陽光很刺眼，亮得她低下了頭——"}}, {"id": 85, "prop": "name", "attributes": {"content": "偌大的法院廣場，兩輛車停在她的必經之路上，它們的引擎蓋上各自綴著特製的車標——在敘拉古隨處可見的圖案。"}}, {"id": 86, "prop": "name", "attributes": {"content": "就算她不認得薩盧佐的酒標和威尼斯的家徽，她也不會不認得車前那兩個剛剛還在法庭上為自己辯護的人。"}}, {"id": 87, "prop": "name", "attributes": {"content": "伊雷妮知道，他們在等她——薩盧佐家族與威尼斯家族在等她。"}}, {"id": 88, "prop": "dialog", "attributes": {}}, {"id": 89, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_686_1#9$1", "duration": 0.5}}, {"id": 90, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 91, "prop": "name", "attributes": {"content": "恭喜你，伊雷妮小姐。", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#9$1"}, {"id": 92, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1542_1#2$1"}}, {"id": 93, "prop": "name", "attributes": {"content": "……沒什麼好恭喜的。", "name": "伊雷妮"}, "figure_art": "avg_npc_1542_1#2$1"}, {"id": 94, "prop": "name", "attributes": {"content": "阿爾貝托先生，雖然昨天那場火是個意外，但我擔心的事情，確實也因此被糊里糊塗地解決了。", "name": "伊雷妮"}, "figure_art": "avg_npc_1542_1#2$1"}, {"id": 95, "prop": "name", "attributes": {"content": "我想，已經辛苦您白跑了一趟，就更不應該繼續給您添麻煩了。", "name": "伊雷妮"}, "figure_art": "avg_npc_1542_1#2$1"}, {"id": 96, "prop": "name", "attributes": {"content": "但您今天過來，就等於告訴所有人——", "name": "伊雷妮"}, "figure_art": "avg_npc_1542_1#2$1"}, {"id": 97, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_686_1#9$1"}}, {"id": 98, "prop": "name", "attributes": {"content": "薩盧佐當然要幫卡車工會。", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#9$1"}, {"id": 99, "prop": "name", "attributes": {"content": "從目前的狀況來看，有些交易確實已經不再算數，但你我都清楚，在敘拉古，搭建一段友誼有多麼難能可貴。", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#9$1"}, {"id": 100, "prop": "name", "attributes": {"content": "約定依然存在，伊雷妮小姐。", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#9$1"}, {"id": 101, "prop": "dialog", "attributes": {}}, {"id": 102, "prop": "charslot", "attributes": {}}, {"id": 103, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1544_1#1$1", "duration": 0.5}}, {"id": 104, "prop": "delay", "attributes": {"time": 0.8}}, {"id": 105, "prop": "name", "attributes": {"content": "咳——阿爾貝托叔叔，我應該沒有打擾你吧？", "name": "安東尼奧"}, "figure_art": "avg_npc_1544_1#1$1"}, {"id": 106, "prop": "name", "attributes": {"content": "伊雷妮小姐是為我們運的輪胎，現在貨在她手裡出了事，我還得找她談談該怎麼賠償。", "name": "安東尼奧"}, "figure_art": "avg_npc_1544_1#1$1"}, {"id": 107, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1542_1#2$1"}}, {"id": 108, "prop": "name", "attributes": {"content": "安東尼奧先生……", "name": "伊雷妮"}, "figure_art": "avg_npc_1542_1#2$1"}, {"id": 109, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1544_1#1$1"}}, {"id": 110, "prop": "name", "attributes": {"content": "別緊張，雖然我們今天才正式認識，但已經相當有默契了。", "name": "安東尼奧"}, "figure_art": "avg_npc_1544_1#1$1"}, {"id": 111, "prop": "name", "attributes": {"content": "你在法庭上什麼都沒有說，這很好。", "name": "安東尼奧"}, "figure_art": "avg_npc_1544_1#1$1"}, {"id": 112, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1542_1#2$1"}}, {"id": 113, "prop": "name", "attributes": {"content": "……", "name": "伊雷妮"}, "figure_art": "avg_npc_1542_1#2$1"}, {"id": 114, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1544_1#1$1"}}, {"id": 115, "prop": "name", "attributes": {"content": "關於卡車工會，以及許多事情，我想我們已經有很多東西可以交流。", "name": "安東尼奧"}, "figure_art": "avg_npc_1544_1#1$1"}, {"id": 116, "prop": "name", "attributes": {"content": "上車吧，我送你回營地。", "name": "安東尼奧"}, "figure_art": "avg_npc_1544_1#1$1"}, {"id": 117, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_686_1#7$1"}}, {"id": 118, "prop": "name", "attributes": {"content": "小威尼斯——", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#7$1"}, {"id": 119, "prop": "dialog", "attributes": {}}, {"id": 120, "prop": "charslot", "attributes": {}}, {"id": 121, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 122, "prop": "playsound", "attributes": {"key": "$d_avg_carhorn"}}, {"id": 123, "prop": "playsound", "attributes": {"key": "$d_avg_truckengine", "loop": "true", "channel": "1", "volume": 0.0}}, {"id": 124, "prop": "SoundVolume", "attributes": {"volume": 0.6, "channel": "1", "fadetime": 1.0}}, {"id": 125, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 126, "prop": "StopSound", "attributes": {"channel": "1", "fadetime": 2.0}}, {"id": 127, "prop": "name", "attributes": {"content": "嘹亮的鳴笛聲打斷了三人的對話，一輛卡車從兩輛私家車之間穿過，穩穩地停在了伊雷妮面前。"}}, {"id": 128, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_686_1#1$1"}}, {"id": 129, "prop": "name", "attributes": {"content": "……", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#1$1"}, {"id": 130, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1544_1#4$1"}}, {"id": 131, "prop": "name", "attributes": {"content": "……", "name": "安東尼奧"}, "figure_art": "avg_npc_1544_1#4$1"}, {"id": 132, "prop": "charslot", "attributes": {}}, {"id": 133, "prop": "playsound", "attributes": {"key": "$d_avg_cardoorc"}}, {"id": 134, "prop": "name", "attributes": {"content": "車門打開，伊雷妮看到了下車的柳德米拉。"}}, {"id": 135, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1542_1#5$1"}}, {"id": 136, "prop": "name", "attributes": {"content": "柳德米拉！", "name": "伊雷妮"}, "figure_art": "avg_npc_1542_1#5$1"}, {"id": 137, "prop": "playMusic", "attributes": {"intro": "$storyendjp_intro", "key": "$storyendjp_loop", "volume": 0.6}}, {"id": 138, "prop": "dialog", "attributes": {}}, {"id": 139, "prop": "charslot", "attributes": {}}, {"id": 140, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1502_crosly_1#6$1", "duration": 1.0}}, {"id": 141, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 142, "prop": "name", "attributes": {"content": "……", "name": "柳德米拉"}, "figure_art": "avg_1502_crosly_1#6$1"}, {"id": 143, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1542_1#7$1"}}, {"id": 144, "prop": "name", "attributes": {"content": "……你怎麼了？", "name": "伊雷妮"}, "figure_art": "avg_npc_1542_1#7$1"}, {"id": 145, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1502_crosly_1#1$1"}}, {"id": 146, "prop": "name", "attributes": {"content": "走吧，我來接你回家。營地裡還有很多事情等著你處理呢。", "name": "柳德米拉"}, "figure_art": "avg_1502_crosly_1#1$1"}, {"id": 147, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1542_1#2$1"}}, {"id": 148, "prop": "name", "attributes": {"content": "好，我們走。", "name": "伊雷妮"}, "figure_art": "avg_npc_1542_1#2$1"}, {"id": 149, "prop": "Dialog", "attributes": {}}, {"id": 150, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 151, "prop": "charslot", "attributes": {}}, {"id": 152, "prop": "playsound", "attributes": {"key": "$d_avg_cardoorc"}}, {"id": 153, "prop": "curtain", "attributes": {"direction": 0.0, "fillfrom": 0.1, "fillto": 0.1, "fadetime": 0.1}}, {"id": 154, "prop": "curtain", "attributes": {"direction": 4.0, "fillfrom": 0.1, "fillto": 0.1, "fadetime": 0.1}}, {"id": 155, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_1502_crosly_1#1$1"}}, {"id": 156, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1542_1#2$1"}}, {"id": 157, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 158, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1542_1#2$1", "focus": "r"}}, {"id": 159, "prop": "name", "attributes": {"content": "回去之後，我們得趕快想辦法送索默爾暫時離開，現在城裡對他來說不安全。", "name": "伊雷妮"}}, {"id": 160, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1542_1#6$1", "focus": "r"}}, {"id": 161, "prop": "name", "attributes": {"content": "……柳德米拉，你有心事？", "name": "伊雷妮"}}, {"id": 162, "prop": "charslot", "attributes": {"slot": "right", "focus": "n"}}, {"id": 163, "prop": "name", "attributes": {"content": "柳德米拉沒有說話，只是將懷中的那枚打火機交給了伊雷妮。"}}, {"id": 164, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1542_1#5$1", "focus": "r"}}, {"id": 165, "prop": "name", "attributes": {"content": "咦……這不是索默爾的？！", "name": "伊雷妮"}}, {"id": 166, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_1502_crosly_1#6$1", "focus": "l"}}, {"id": 167, "prop": "name", "attributes": {"content": "他做了他能做的所有。", "name": "柳德米拉"}}, {"id": 168, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_1502_crosly_1#7$1", "focus": "l"}}, {"id": 169, "prop": "name", "attributes": {"content": "我早該明白，家族絕對不會允許任何可能對他們造成威脅的人存在。", "name": "柳德米拉"}}, {"id": 170, "prop": "Dialog", "attributes": {}}, {"id": 171, "prop": "charslot", "attributes": {}}, {"id": 172, "prop": "PlaySound", "attributes": {"key": "$d_avg_driveincar", "volume": 0.0, "loop": "true", "channel": "car"}}, {"id": 173, "prop": "SoundVolume", "attributes": {"volume": 0.5, "channel": "car", "fadetime": 2.0}}, {"id": 174, "prop": "CameraShake", "attributes": {"duration": 5.0, "xstrength": 3.0, "ystrength": 2.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 175, "prop": "playsound", "attributes": {"key": "$sportscarstart"}}, {"id": 176, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 177, "prop": "name", "attributes": {"content": "透過後視鏡，伊雷妮再次對上了小威尼斯與阿爾貝托的眼睛。"}}, {"id": 178, "prop": "name", "attributes": {"content": "她突然明白這兩人為什麼信心滿滿地站出來替自己作證，又為什麼同時在廣場等自己。"}}, {"id": 179, "prop": "name", "attributes": {"content": "小威尼斯說得沒錯，她的沉默，以及他們的發聲，意味著三方在法庭上達成了默契。"}}, {"id": 180, "prop": "dialog", "attributes": {}}, {"id": 181, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_1502_crosly_1#7$1", "focus": "r"}}, {"id": 182, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1542_1#6$1", "focus": "r"}}, {"id": 183, "prop": "name", "attributes": {"content": "……索默爾在哪裡？", "name": "伊雷妮"}}, {"id": 184, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_1502_crosly_1#6$1", "focus": "l"}}, {"id": 185, "prop": "name", "attributes": {"content": "……", "name": "柳德米拉"}}, {"id": 186, "prop": "name", "attributes": {"content": "……對不起，我找不到……", "name": "柳德米拉"}}, {"id": 187, "prop": "charslot", "attributes": {"slot": "right", "focus": "n"}}, {"id": 188, "prop": "name", "attributes": {"content": "伊雷妮握緊了手中的打火機。"}}, {"id": 189, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1542_1#8$1", "focus": "r"}}, {"id": 190, "prop": "name", "attributes": {"content": "所以事情的發展的確超出了所有人的預料，他們不得不下場保住我。", "name": "伊雷妮"}}, {"id": 191, "prop": "name", "attributes": {"content": "但代價……", "name": "伊雷妮"}}, {"id": 192, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_1502_crosly_1#7$1", "focus": "l"}}, {"id": 193, "prop": "name", "attributes": {"content": "他們想讓市政廳和法院的人看到，我們已經和家族綁在同一條船上。", "name": "柳德米拉"}}, {"id": 194, "prop": "name", "attributes": {"content": "剛剛那兩個傢伙對你的態度……簡直就像在爭搶地盤。", "name": "柳德米拉"}}, {"id": 195, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 196, "prop": "name", "attributes": {"content": "這場庭審不是事情的結束，它只是開始。"}}, {"id": 197, "prop": "name", "attributes": {"content": "未來漫長的時間裡，家族將成為卡車互助會的附骨之疽，她不得不和那些人糾纏，繼續保持這種默契，可恥的默契。"}}, {"id": 198, "prop": "name", "attributes": {"content": "卡車已經離法院廣場越來越遠，她看著手中的打火機，突然沒那麼恐懼了。"}}, {"id": 199, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1542_1#8$1", "focus": "r"}}, {"id": 200, "prop": "name", "attributes": {"content": "這件事沒完，阿爾貝托、安東尼奧……", "name": "伊雷妮"}}, {"id": 201, "prop": "name", "attributes": {"content": "我和索默爾剛搬來新沃爾西尼的時候，真的相信我們已經遠離了家族。", "name": "伊雷妮"}}, {"id": 202, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1542_1#3$1", "focus": "r"}}, {"id": 203, "prop": "name", "attributes": {"content": "……呵，真可笑啊。", "name": "伊雷妮"}}, {"id": 204, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1542_1#9$1", "focus": "r"}}, {"id": 205, "prop": "name", "attributes": {"content": "索默爾，對不起，我不會再相信他們中的任何人了。", "name": "伊雷妮"}}, {"id": 206, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 207, "prop": "Dialog", "attributes": {}}, {"id": 208, "prop": "StopSound", "attributes": {"channel": "car", "fadetime": 2.0}}, {"id": 209, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 210, "prop": "charslot", "attributes": {}}, {"id": 211, "prop": "curtain", "attributes": {}}, {"id": 212, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 213, "prop": "Background", "attributes": {"image": "bg_vipward", "screenadapt": "coverall"}}, {"id": 214, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 215, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 216, "prop": "playMusic", "attributes": {"intro": "$ponder_intro", "key": "$ponder_loop", "volume": 0.6}}, {"id": 217, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4065_judge_1#1$1", "duration": 0.5}}, {"id": 218, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 219, "prop": "name", "attributes": {"content": "……", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 220, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1564_1#3$1"}}, {"id": 221, "prop": "name", "attributes": {"content": "多有趣的場面，像是拍電影。薩盧佐的員工、威尼斯的員工，還有卡車司機，圍在那位司機小姐身邊的人，佔了快要半個廣場……", "name": "拉普蘭德"}, "figure_art": "avg_npc_1564_1#3$1"}, {"id": 222, "prop": "name", "attributes": {"content": "我第一次進法院，說是成年禮，出來的時候都沒有那麼多人迎接。", "name": "拉普蘭德"}, "figure_art": "avg_npc_1564_1#3$1"}, {"id": 223, "prop": "name", "attributes": {"content": "德克薩斯就更慘了，哈哈，來敘拉古做客，不小心惹上了官司，當時只有我等她。", "name": "拉普蘭德"}, "figure_art": "avg_npc_1564_1#3$1"}, {"id": 224, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1028_texas2_1#1$1"}}, {"id": 225, "prop": "name", "attributes": {"content": "……不要再提你那無聊的惡作劇了，拉普蘭德。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 226, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4065_judge_1#1$1"}}, {"id": 227, "prop": "name", "attributes": {"content": "拉普蘭德小姐，感謝你專程過來提醒。如果沒什麼其他的事，還請離開吧。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#1$1"}, {"id": 228, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1564_1#9$1"}}, {"id": 229, "prop": "name", "attributes": {"content": "不客氣，都是我應該做的。", "name": "拉普蘭德"}, "figure_art": "avg_npc_1564_1#9$1"}, {"id": 230, "prop": "name", "attributes": {"content": "明天就是狂歡節了，法官小姐，你們還有的忙呢。", "name": "拉普蘭德"}, "figure_art": "avg_npc_1564_1#9$1"}, {"id": 231, "prop": "dialog", "attributes": {}}, {"id": 232, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 233, "prop": "Dialog", "attributes": {}}, {"id": 234, "prop": "PlaySound", "attributes": {"key": "$doorclosequite"}}, {"id": 235, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 236, "prop": "charslot", "attributes": {}}, {"id": 237, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 238, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 239, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 240, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4065_judge_1#1$1", "duration": 1.0}}, {"id": 241, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1028_texas2_1#1$1", "duration": 1.0}}, {"id": 242, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 243, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1028_texas2_1#1$1", "focus": "r"}}, {"id": 244, "prop": "name", "attributes": {"content": "從昨天中午開始，我一直跟著拉普蘭德。", "name": "德克薩斯"}}, {"id": 245, "prop": "name", "attributes": {"content": "我們趕到港口的時候，那場火已經燒得差不多了，和她沒有直接的關係。", "name": "德克薩斯"}}, {"id": 246, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1028_texas2_1#8$1", "focus": "r"}}, {"id": 247, "prop": "name", "attributes": {"content": "接下來的整個晚上，她真的都在到處跑計程車。今天又去了法院，再然後來到了醫院……", "name": "德克薩斯"}}, {"id": 248, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1028_texas2_1#1$1", "focus": "r"}}, {"id": 249, "prop": "name", "attributes": {"content": "我暫時還不清楚她到底要做什麼。", "name": "德克薩斯"}}, {"id": 250, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4065_judge_1#8$1", "focus": "l"}}, {"id": 251, "prop": "name", "attributes": {"content": "——", "name": "拉維妮婭"}}, {"id": 252, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1028_texas2_1#5$1", "focus": "r"}}, {"id": 253, "prop": "name", "attributes": {"content": "拉維妮婭，你還在看這份卷宗？", "name": "德克薩斯"}}, {"id": 254, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4065_judge_1#5$1", "focus": "l"}}, {"id": 255, "prop": "name", "attributes": {"content": "單從卷宗內容來看，這場審判沒有任何問題。但這種感覺太過熟悉……", "name": "拉維妮婭"}}, {"id": 256, "prop": "name", "attributes": {"content": "整場庭審流程完整、證據詳實，但除了幫助某個人脫罪，它實際上沒有查明任何真相，也沒有解決任何問題。", "name": "拉維妮婭"}}, {"id": 257, "prop": "name", "attributes": {"content": "在沃爾西尼，在敘拉古的其他地方，絕大多數的案子都只能以這樣的一份卷宗收尾。", "name": "拉維妮婭"}}, {"id": 258, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4065_judge_1#2$1", "focus": "l"}}, {"id": 259, "prop": "name", "attributes": {"content": "而我一度認為，這樣的審判已經不會存在於新沃爾西尼。", "name": "拉維妮婭"}}, {"id": 260, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_1028_texas2_1#5$1", "focus": "r"}}, {"id": 261, "prop": "name", "attributes": {"content": "拉維妮婭……", "name": "德克薩斯"}}, {"id": 262, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_4065_judge_1#1$1", "focus": "l"}}, {"id": 263, "prop": "name", "attributes": {"content": "不用安慰我，德克薩斯。", "name": "拉維妮婭"}}, {"id": 264, "prop": "name", "attributes": {"content": "我更在意的是，這些人從什麼時候開始居然會在意一個家族之外的普通人無辜或者有罪？", "name": "拉維妮婭"}}, {"id": 265, "prop": "name", "attributes": {"content": "更何況在此之前，整個威尼斯家族在新沃爾西尼的表現幾乎沒有任何可以指摘的地方，小威尼斯卻在此時出了這個頭。", "name": "拉維妮婭"}}, {"id": 266, "prop": "name", "attributes": {"content": "從德米特里到英格麗——這兩天，我可能一直都追錯了方向。", "name": "拉維妮婭"}}, {"id": 267, "prop": "name", "attributes": {"content": "但可以肯定的是，在這場庭審之前——或者就是這場庭審，讓他們站在了一起。", "name": "拉維妮婭"}}, {"id": 268, "prop": "name", "attributes": {"content": "萊昂遭遇的那場車禍、肇事逃逸的車輛，還有港口的火災，這些事情明顯存在更深的聯繫……", "name": "拉維妮婭"}}, {"id": 269, "prop": "name", "attributes": {"content": "薩盧佐、威尼斯，還有卡車工會，這三方勢力到底在共同隱藏什麼？", "name": "拉維妮婭"}}, {"id": 270, "prop": "charslot", "attributes": {"duration": 0.5}}, {"id": 271, "prop": "PlaySound", "attributes": {"key": "$d_avg_paper2"}}, {"id": 272, "prop": "name", "attributes": {"content": "拉維妮婭闔上了卷宗，她的手撫過封面上法院的標誌和《新都市管理法案》的字樣。"}}, {"id": 273, "prop": "name", "attributes": {"content": "片刻後，她抬起了頭。"}}, {"id": 274, "prop": "name", "attributes": {"content": "德克薩斯看著眼前的朋友，如果說她剛剛還有些低落和迷惑，那麼現在，她已肉眼可見地重新振作了起來。"}}, {"id": 275, "prop": "dialog", "attributes": {}}, {"id": 276, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4065_judge_1#7$1", "duration": 0.5}}, {"id": 277, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 278, "prop": "name", "attributes": {"content": "明天就是狂歡節了，萊昂到現在還重傷未醒……我已經沒有多少時間去查明他們接下來會有怎樣的圖謀。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#7$1"}, {"id": 279, "prop": "name", "attributes": {"content": "不能讓局勢惡化，更不能坐以待斃。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#7$1"}, {"id": 280, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1028_texas2_1#3$1"}}, {"id": 281, "prop": "name", "attributes": {"content": "……你的意思是？", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#3$1"}, {"id": 282, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4065_judge_1#15$1"}}, {"id": 283, "prop": "name", "attributes": {"content": "這些人依然覺得《新都市管理法案》是可以利用的東西，那麼我會告訴他們，在新沃爾西尼，它確實是秩序的根本。", "name": "拉維妮婭"}, "figure_art": "avg_4065_judge_1#15$1"}, {"id": 284, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 285, "prop": "Dialog", "attributes": {}}, {"id": 286, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 287, "prop": "charslot", "attributes": {}}, {"id": 288, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 289, "prop": "Background", "attributes": {"image": "56_g12_saluzzowinery", "screenadapt": "coverall"}}, {"id": 290, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 291, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 292, "prop": "playMusic", "attributes": {"intro": "$darkalley_intro", "key": "$darkalley_loop", "volume": 0.6}}, {"id": 293, "prop": "animtext", "attributes": {"content": "<p=2>1100年11月8日    4:45 P.M.</>", "id": "at1", "name": "group_location_stamp", "style": "avg_only_medium", "pos": "-400,-200", "block": "false", "p": 2.0}}, {"id": 294, "prop": "delay", "attributes": {"time": 3.0}}, {"id": 295, "prop": "animtextclean", "attributes": {}}, {"id": 296, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 297, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.5}}, {"id": 298, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 299, "prop": "name", "attributes": {"content": "等等，你不能進去！", "name": "家族成員"}}, {"id": 300, "prop": "dialog", "attributes": {}}, {"id": 301, "prop": "playsound", "attributes": {"key": "$d_gen_doorclose", "volume": 0.7}}, {"id": 302, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 303, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 304, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1028_texas2_1#1$1", "duration": 0.5}}, {"id": 305, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 306, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_686_1#5$1"}}, {"id": 307, "prop": "name", "attributes": {"content": "德克薩斯？", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#5$1"}, {"id": 308, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_686_1#10$1"}}, {"id": 309, "prop": "name", "attributes": {"content": "無緣無故闖進我的酒莊，這可不像是你會做的事情。", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#10$1"}, {"id": 310, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1028_texas2_1#1$1"}}, {"id": 311, "prop": "name", "attributes": {"content": "我當然不能這麼做。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 312, "prop": "dialog", "attributes": {}}, {"id": 313, "prop": "charslot", "attributes": {}}, {"id": 314, "prop": "playsound", "attributes": {"key": "$d_gen_soldiersrun", "volume": 0.7}}, {"id": 315, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 316, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1553_1#1$2", "duration": 0.5}}, {"id": 317, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 318, "prop": "name", "attributes": {"content": "我說過我們會來找你的，阿爾貝托·薩盧佐先生。", "name": "警察"}, "figure_art": "avg_npc_1553_1#1$2"}, {"id": 319, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_686_1#1$1"}}, {"id": 320, "prop": "name", "attributes": {"content": "……", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#1$1"}, {"id": 321, "prop": "playsound", "attributes": {"key": "$d_avg_paper1"}}, {"id": 322, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1553_1#1$2"}}, {"id": 323, "prop": "name", "attributes": {"content": "這是近兩個月來薩盧佐酒業提交的所有資格審查文件。", "name": "警察"}, "figure_art": "avg_npc_1553_1#1$2"}, {"id": 324, "prop": "name", "attributes": {"content": "同一批員工，短短兩個月間在你們的註冊資料裡連續變換了好幾次身分，先是保全人員，再是釀酒師等專業技術人員……", "name": "警察"}, "figure_art": "avg_npc_1553_1#1$2"}, {"id": 325, "prop": "name", "attributes": {"content": "我們合理懷疑，薩盧佐酒業涉嫌以非法手段規避正常的背景審查流程。", "name": "警察"}, "figure_art": "avg_npc_1553_1#1$2"}, {"id": 326, "prop": "name", "attributes": {"content": "請跟我們回去接受調查。", "name": "警察"}, "figure_art": "avg_npc_1553_1#1$2"}, {"id": 327, "prop": "dialog", "attributes": {}}, {"id": 328, "prop": "charslot", "attributes": {}}, {"id": 329, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1554_1#1$1", "duration": 0.5}}, {"id": 330, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 331, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1554_1#1$1", "duration": 0.5}}, {"id": 332, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 333, "prop": "charslot", "attributes": {"slot": "left", "focus": "l"}}, {"id": 334, "prop": "name", "attributes": {"content": "變來變去，不是因為一直按照市政廳的要求在改嗎？", "name": "家族成員A"}}, {"id": 335, "prop": "name", "attributes": {"content": "你們突然把這些舊的資料翻出來，到底有什麼目的？", "name": "家族成員A"}}, {"id": 336, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 337, "prop": "name", "attributes": {"content": "別跟他們說那麼多，這幫警察明顯就是故意針對薩盧佐家！*敘拉古粗口*，我們還交了那麼多的認證金！", "name": "家族成員B"}}, {"id": 338, "prop": "name", "attributes": {"content": "總之，不能讓他們在薩盧佐的地盤上把老爺帶走——", "name": "家族成員B"}}, {"id": 339, "prop": "dialog", "attributes": {}}, {"id": 340, "prop": "charslot", "attributes": {}}, {"id": 341, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.7}}, {"id": 342, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_690_1#7$1", "duration": 1.0}}, {"id": 343, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 344, "prop": "name", "attributes": {"content": "住手。不要妨礙警察辦案。", "name": "德米特里"}, "figure_art": "avg_npc_690_1#7$1"}, {"id": 345, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_690_1#9$1"}}, {"id": 346, "prop": "name", "attributes": {"content": "如果他們只是懷疑薩盧佐酒業用非法手段規避背景審查，要解釋起來並不難……只是需要時間。", "name": "德米特里"}, "figure_art": "avg_npc_690_1#9$1"}, {"id": 347, "prop": "dialog", "attributes": {}}, {"id": 348, "prop": "charslot", "attributes": {}}, {"id": 349, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1554_1#1$1"}}, {"id": 350, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1554_1#1$1"}}, {"id": 351, "prop": "name", "attributes": {"content": "……", "name": "家族成員A&B"}, "figure_art": "avg_npc_1554_1#1$1"}, {"id": 352, "prop": "dialog", "attributes": {}}, {"id": 353, "prop": "charslot", "attributes": {}}, {"id": 354, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_686_1#1$1"}}, {"id": 355, "prop": "name", "attributes": {"content": "聽他的。", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#1$1"}, {"id": 356, "prop": "dialog", "attributes": {}}, {"id": 357, "prop": "charslot", "attributes": {}}, {"id": 358, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1554_1#1$1"}}, {"id": 359, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1554_1#1$1"}}, {"id": 360, "prop": "name", "attributes": {"content": "是，老爺。", "name": "家族成員A&B"}, "figure_art": "avg_npc_1554_1#1$1"}, {"id": 361, "prop": "dialog", "attributes": {}}, {"id": 362, "prop": "charslot", "attributes": {}}, {"id": 363, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_686_1#1$1"}}, {"id": 364, "prop": "name", "attributes": {"content": "是那個法官的主意，對吧？", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#1$1"}, {"id": 365, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1028_texas2_1#1$1"}}, {"id": 366, "prop": "name", "attributes": {"content": "什麼？", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 367, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_686_1#1$1"}}, {"id": 368, "prop": "name", "attributes": {"content": "她當然不會認為憑藉這樣不痛不癢的罪名就能拿我怎麼樣，但至少接下來這幾天，可以將我困在監獄裡。", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#1$1"}, {"id": 369, "prop": "name", "attributes": {"content": "我想，她應該已經去了小威尼斯或者伊雷妮那裡，不然來酒莊的不會是你。", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#1$1"}, {"id": 370, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1028_texas2_1#1$1"}}, {"id": 371, "prop": "name", "attributes": {"content": "我只是正好有空。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 372, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_686_1#9$1"}}, {"id": 373, "prop": "name", "attributes": {"content": "僅憑她掌握的資訊，能在這麼短的時間做出這麼雷厲風行的決策，夠果決。", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#9$1"}, {"id": 374, "prop": "name", "attributes": {"content": "我還記得去年她衝到我府邸找貝納爾多時的軟弱樣子——真是判若兩人。", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#9$1"}, {"id": 375, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1028_texas2_1#1$1"}}, {"id": 376, "prop": "name", "attributes": {"content": "這些你跟我說沒有用。你要是清清白白，就沒什麼好怕的。", "name": "德克薩斯"}, "figure_art": "avg_1028_texas2_1#1$1"}, {"id": 377, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_686_1#1$1"}}, {"id": 378, "prop": "name", "attributes": {"content": "當然，我跟你們走。我會盡量配合你們的調查。", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#1$1"}, {"id": 379, "prop": "name", "attributes": {"content": "我今天在法庭上就說過，這是新沃爾西尼市民應盡的義務。", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#1$1"}, {"id": 380, "prop": "name", "attributes": {"content": "更何況，整個薩盧佐酒業並不會因為我的離開而停止運轉。", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#1$1"}, {"id": 381, "prop": "name", "attributes": {"content": "德米特里，你在這段時間裡，應該已經熟悉我們在新沃爾西尼的業務了吧？", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#1$1"}, {"id": 382, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_690_1#1$1"}}, {"id": 383, "prop": "name", "attributes": {"content": "當然，阿爾貝托先生。", "name": "德米特里"}, "figure_art": "avg_npc_690_1#1$1"}, {"id": 384, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_686_1#9$1"}}, {"id": 385, "prop": "name", "attributes": {"content": "那暫時交給你了，薩盧佐酒業的經理。", "name": "阿爾貝托"}, "figure_art": "avg_npc_686_1#9$1"}, {"id": 386, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_690_1#1$1"}}, {"id": 387, "prop": "name", "attributes": {"content": "當然。", "name": "德米特里"}, "figure_art": "avg_npc_690_1#1$1"}, {"id": 388, "prop": "Dialog", "attributes": {}}, {"id": 389, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 390, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 391, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 392, "prop": "Image", "attributes": {}}, {"id": 393, "prop": "charslot", "attributes": {}}, {"id": 394, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}