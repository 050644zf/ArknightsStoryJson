: "Character", "attributes": {"name": "avg_npc_305_1#1$1", "name2": "avg_npc_305_1#1$1", "focus": 1.0}}, {"id": 68, "prop": "name", "attributes": {"content": "  還愣著幹什麼！一起上啊！", "name": "街頭青年"}, "figure_art": "avg_npc_305_1#1$1"}, {"id": 69, "prop": "Character", "attributes": {"name": "avg_npc_305_1#1$1"}}, {"id": 70, "prop": "name", "attributes": {"content": "  小姐！我們來幫忙了！", "name": "街頭青年"}, "figure_art": "avg_npc_305_1#1$1"}, {"id": 71, "prop": "dialog", "attributes": {}}, {"id": 72, "prop": "character", "attributes": {}}, {"id": 73, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 74, "prop": "name", "attributes": {"content": "  ——慢著！", "name": "鄭掌櫃"}}, {"id": 75, "prop": "dialog", "attributes": {}}, {"id": 76, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.6}}, {"id": 77, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1", "fadetime": 1.5, "block": "true"}}, {"id": 78, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 79, "prop": "Character", "attributes": {"name": "avg_npc_305_1#1$1"}}, {"id": 80, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 81, "prop": "name", "attributes": {"content": "  咿......", "name": "街頭青年"}, "figure_art": "avg_npc_305_1#1$1"}, {"id": 82, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 83, "prop": "name", "attributes": {"content": "  咳。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 84, "prop": "name", "attributes": {"content": "  這裡怎麼說也是客棧，二位再這麼鬧下去，瘡痍滿目，白給路人看笑話，怕是不太妥當。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 85, "prop": "Character", "attributes": {"name": "avg_npc_296_1#7$1"}}, {"id": 86, "prop": "name", "attributes": {"content": "  ......嘁。", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#7$1"}, {"id": 87, "prop": "Character", "attributes": {"name": "avg_npc_300_1#5$1"}}, {"id": 88, "prop": "name", "attributes": {"content": "  不過，二位打得精彩，給我們這些人開了眼界，賠償呢......我就不要了。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#5$1"}, {"id": 89, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 90, "prop": "name", "attributes": {"content": "  但現在還請給我一個薄面，今天就先算了吧。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 91, "prop": "Character", "attributes": {"name": "avg_npc_296_1#3$1"}}, {"id": 92, "prop": "name", "attributes": {"content": "  ......哼。", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#3$1"}, {"id": 93, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#1$1"}}, {"id": 94, "prop": "name", "attributes": {"content": "  抱歉了，掌櫃的。事後解開誤會，我們自會登門道歉。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#1$1"}, {"id": 95, "prop": "Character", "attributes": {"name": "avg_npc_296_1#7$1"}}, {"id": 96, "prop": "name", "attributes": {"content": "  ......看在掌櫃的面子上，這次就放過你吧。", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#7$1"}, {"id": 97, "prop": "Character", "attributes": {"name": "avg_npc_296_1#1$1"}}, {"id": 98, "prop": "name", "attributes": {"content": "  我不知道你們和他是什麼關係，勸你們好自為之，乖乖把他交出來。", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 99, "prop": "Character", "attributes": {"name": "avg_npc_296_1#6$1"}}, {"id": 100, "prop": "name", "attributes": {"content": "  要是包庇他，你們就都是同罪。放過你一時無妨，但尚蜀容不下你們這樣的法外之徒。", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#6$1"}, {"id": 101, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#1$1"}}, {"id": 102, "prop": "name", "attributes": {"content": "  真要是法外之徒，報警就是了，杜小姐何必私下動武呢？", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#1$1"}, {"id": 103, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 104, "prop": "name", "attributes": {"content": "  烏有兄弟說的是，再怎麼佔理，也不該一言不合就動起手來。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 105, "prop": "Character", "attributes": {"name": "avg_npc_296_1#5$1"}}, {"id": 106, "prop": "name", "attributes": {"content": "  ......你！", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#5$1"}, {"id": 107, "prop": "Character", "attributes": {"name": "avg_npc_300_1#4$1"}}, {"id": 108, "prop": "name", "attributes": {"content": "  這位小姐。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#4$1"}, {"id": 109, "prop": "name", "attributes": {"content": "  讓你的人退下吧。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#4$1"}, {"id": 110, "prop": "Character", "attributes": {"name": "avg_npc_296_1#6$1", "name2": "avg_npc_305_1#1$1", "focus": 2.0}}, {"id": 111, "prop": "name", "attributes": {"content": "  小、小姐，就這麼放走他......？抓著他一個，等著那個龍門人上鉤——", "name": "街頭青年"}, "figure_art": "avg_npc_305_1#1$1"}, {"id": 112, "prop": "Character", "attributes": {"name": "avg_npc_296_1#6$1", "name2": "avg_npc_305_1#1$1", "focus": 1.0}}, {"id": 113, "prop": "name", "attributes": {"content": "  ......別嚷嚷。", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#6$1"}, {"id": 114, "prop": "Character", "attributes": {"name": "avg_npc_296_1#6$1", "name2": "avg_npc_305_1#1$1", "focus": 1.0}}, {"id": 115, "prop": "name", "attributes": {"content": "  反正那個龍門人已經跑了，留住這一個也沒多大用。", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#6$1"}, {"id": 116, "prop": "Character", "attributes": {"name": "avg_npc_296_1#6$1", "name2": "avgnew_455_nothing_1#1$1", "focus": 1.0}}, {"id": 117, "prop": "name", "attributes": {"content": "  ......再說了，當真能留得住嗎？你是不是還有什麼手段沒使？", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#6$1"}, {"id": 118, "prop": "Character", "attributes": {"name": "avg_npc_296_1#6$1", "name2": "avgnew_455_nothing_1#7$1", "focus": 2.0}}, {"id": 119, "prop": "name", "attributes": {"content": "  沒有的事，和氣生財，和氣生財。既然這位小姐願意退一步，那是再好不過......", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#7$1"}, {"id": 120, "prop": "Character", "attributes": {"name": "avg_npc_296_1#1$1", "name2": "avgnew_455_nothing_1#7$1", "focus": 1.0}}, {"id": 121, "prop": "name", "attributes": {"content": "  烏有，我記住你了。", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 122, "prop": "Character", "attributes": {"name": "avg_npc_296_1#1$1", "name2": "avgnew_455_nothing_1#7$1", "focus": 2.0}}, {"id": 123, "prop": "name", "attributes": {"content": "  貴人多忘事，但願您別記著。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#7$1"}, {"id": 124, "prop": "Character", "attributes": {"name": "avg_npc_296_1#1$1", "name2": "avgnew_455_nothing_1#8$1", "focus": 2.0}}, {"id": 125, "prop": "dialog", "attributes": {}}, {"id": 126, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "xpos": 20.0, "ypos": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 127, "prop": "delay", "attributes": {"time": 1.1}}, {"id": 128, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "xpos": 40.0, "ypos": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 129, "prop": "delay", "attributes": {"time": 1.1}}, {"id": 130, "prop": "Character", "attributes": {"name": "avg_npc_296_1#1$1", "name2": "avgnew_455_nothing_1#8$1", "focus": 2.0}}, {"id": 131, "prop": "name", "attributes": {"content": "  （悄悄地，悄悄地......好，這個距離差不多能衝出去了......）", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#8$1"}, {"id": 132, "prop": "Character", "attributes": {"name": "avg_npc_296_1#1$1", "name2": "avgnew_455_nothing_1#8$1", "focus": 1.0}}, {"id": 133, "prop": "name", "attributes": {"content": "  我是賣鄭老頭一個面子，出了這道門檻，看誰還能保得住你。不如趁現在老老實實聽本小姐的話——", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 134, "prop": "dialog", "attributes": {}}, {"id": 135, "prop": "Character", "attributes": {"name": "avg_npc_296_1#1$1", "name2": "avgnew_455_nothing_1#8$1", "focus": 0.0}}, {"id": 136, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "xpos": 800.0, "ypos": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 137, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 0.6}}, {"id": 138, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 139, "prop": "Character", "attributes": {"name": "avg_npc_296_1#5$1"}}, {"id": 140, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 141, "prop": "name", "attributes": {"content": "  ——喂！人呢！？", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#5$1"}, {"id": 142, "prop": "name", "attributes": {"content": "  他、他怎麼就這麼跑沒影了！？你們在做什麼！？", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#5$1"}, {"id": 143, "prop": "Character", "attributes": {"name": "avg_npc_296_1#5$1", "name2": "avg_npc_305_1#1$1", "focus": 2.0}}, {"id": 144, "prop": "name", "attributes": {"content": "  ......呃......是小姐您剛才也沒說到底要不要放走他......", "name": "街頭青年"}, "figure_art": "avg_npc_305_1#1$1"}, {"id": 145, "prop": "Character", "attributes": {"name": "avg_npc_296_1#5$1", "name2": "avg_npc_305_1#1$1", "focus": 1.0}}, {"id": 146, "prop": "name", "attributes": {"content": "  ......愣著幹什麼！追啊！", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#5$1"}, {"id": 147, "prop": "Character", "attributes": {"name": "avg_npc_296_1#5$1", "name2": "avg_npc_305_1#1$1", "focus": 2.0}}, {"id": 148, "prop": "name", "attributes": {"content": "  是、是！", "name": "街頭青年"}, "figure_art": "avg_npc_305_1#1$1"}, {"id": 149, "prop": "dialog", "attributes": {}}, {"id": 150, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 0.6}}, {"id": 151, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "xpos": 300.0, "fadetime": 2.0, "block": "false"}}, {"id": 152, "prop": "character", "attributes": {"name": "avg_npc_296_1#6$1", "name2": "char_empty", "fadetime": 0.5}}, {"id": 153, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 154, "prop": "Character", "attributes": {"name": "avg_npc_296_1#6$1", "name2": "avgnew_npc_140_1#1$1", "focus": 2.0}}, {"id": 155, "prop": "name", "attributes": {"content": "  ......杜大小姐哎，您鬧得是不是太大了？", "name": "客棧夥計"}, "figure_art": "avgnew_npc_140_1#1$1"}, {"id": 156, "prop": "Character", "attributes": {"name": "avg_npc_296_1#5$1", "name2": "avgnew_npc_140_1#1$1", "focus": 1.0}}, {"id": 157, "prop": "name", "attributes": {"content": "  ......你讓開！", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#5$1"}, {"id": 158, "prop": "Character", "attributes": {"name": "avg_npc_296_1#5$1", "name2": "avgnew_npc_140_1#2$1", "focus": 2.0}}, {"id": 159, "prop": "name", "attributes": {"content": "  欸，欸，別——得了，家務事我可管不了......", "name": "客棧夥計"}, "figure_art": "avgnew_npc_140_1#2$1"}, {"id": 160, "prop": "Character", "attributes": {"name": "avg_npc_296_1#5$1"}}, {"id": 161, "prop": "name", "attributes": {"content": "  鄭老頭！你剛才為什麼無動於衷，反而還要攔著我！？", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#5$1"}, {"id": 162, "prop": "Character", "attributes": {"name": "avg_npc_296_1#5$1", "name2": "avg_npc_300_1#4$1", "focus": 2.0}}, {"id": 163, "prop": "name", "attributes": {"content": "  ......胡鬧。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#4$1"}, {"id": 164, "prop": "Character", "attributes": {"name": "avg_npc_296_1#5$1", "name2": "avg_npc_300_1#4$1", "focus": 1.0}}, {"id": 165, "prop": "name", "attributes": {"content": "  什麼胡鬧！你不是明知道他們會往應峰路走，才在這裡等著他們的嗎！？", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#5$1"}, {"id": 166, "prop": "name", "attributes": {"content": "  城裡幾十家客棧酒樓都是我們的眼線，要抓一個不知輕重的小賊不是輕而易舉——", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#5$1"}, {"id": 167, "prop": "Character", "attributes": {"name": "avg_npc_296_1#5$1", "name2": "avg_npc_300_1#4$1", "focus": 2.0}}, {"id": 168, "prop": "name", "attributes": {"content": "  ......不知輕重的是誰？", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#4$1"}, {"id": 169, "prop": "Character", "attributes": {"name": "avg_npc_296_1#9$1", "name2": "avg_npc_300_1#4$1", "focus": 1.0}}, {"id": 170, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 171, "prop": "name", "attributes": {"content": "  ......！", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#9$1"}, {"id": 172, "prop": "Character", "attributes": {"name": "avg_npc_296_1#9$1", "name2": "avg_npc_300_1#2$1", "focus": 2.0}}, {"id": 173, "prop": "name", "attributes": {"content": "  你不知道那隻酒盞是什麼物件，你更不知道剛才那龍門人，到底是什麼來頭。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#2$1"}, {"id": 174, "prop": "name", "attributes": {"content": "  何況剛才有高人在場。如果他們真鐵了心把事情鬧大，贏的會是他們，佔理的也會是他們。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#2$1"}, {"id": 175, "prop": "Character", "attributes": {"name": "avg_npc_296_1#6$1", "name2": "avg_npc_300_1#2$1", "focus": 1.0}}, {"id": 176, "prop": "name", "attributes": {"content": "  可是——", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#6$1"}, {"id": 177, "prop": "Character", "attributes": {"name": "avg_npc_296_1#6$1", "name2": "avg_npc_300_1#4$1", "focus": 2.0}}, {"id": 178, "prop": "name", "attributes": {"content": "  可是什麼？你知道這一紙委託，到底幾斤幾兩？那位佚名主顧，又是怎樣一位人物？", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#4$1"}, {"id": 179, "prop": "name", "attributes": {"content": "  憑你也想丟鏢局的臉嗎？", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#4$1"}, {"id": 180, "prop": "dialog", "attributes": {}}, {"id": 181, "prop": "stopmusic", "attributes": {"fadetime": 3.0}}, {"id": 182, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 183, "prop": "character", "attributes": {}}, {"id": 184, "prop": "Background", "attributes": {"image": "25_g02_yanalley_n", "screenadapt": "coverall", "fadetime": 0.1}}, {"id": 185, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.5, "block": "true"}}, {"id": 186, "prop": "PlaySound", "attributes": {"key": "$d_gen_soldiersrun", "volume": 0.5}}, {"id": 187, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 188, "prop": "Character", "attributes": {"name": "avg_npc_294_1#7$1"}}, {"id": 189, "prop": "name", "attributes": {"content": "  ......好像沒人追來。", "name": "老船夫"}, "figure_art": "avg_npc_294_1#7$1"}, {"id": 190, "prop": "Character", "attributes": {"name": "avg_npc_294_1#6$1"}}, {"id": 191, "prop": "playMusic", "attributes": {"intro": "$path_intro", "key": "$path_loop", "volume": 0.4}}, {"id": 192, "prop": "name", "attributes": {"content": "  對不起各位，本來該是我領路的，卻落得如此田地。", "name": "老船夫"}, "figure_art": "avg_npc_294_1#6$1"}, {"id": 193, "prop": "Character", "attributes": {"name": "avg_npc_294_1#5$1"}}, {"id": 194, "prop": "name", "attributes": {"content": "  可我也實在是沒想到，到了尚蜀城內，竟然還能遇上這種事情......", "name": "老船夫"}, "figure_art": "avg_npc_294_1#5$1"}, {"id": 195, "prop": "name", "attributes": {"content": "  留那小夥子一個人，真沒問題嗎？我們這算不算坑了他？", "name": "老船夫"}, "figure_art": "avg_npc_294_1#5$1"}, {"id": 196, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1"}}, {"id": 197, "prop": "name", "attributes": {"content": "  那個老闆和那位盛氣凌人的小姐怕是認識。留下殿後的那位好漢，恐怕沒那麼容易脫身。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 198, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avg_1021_kroos2_1#2$1", "focus": 2.0}}, {"id": 199, "prop": "name", "attributes": {"content": "  什麼......鯉先生怎麼知道的？", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#2$1"}, {"id": 200, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#8$1", "name2": "avg_1021_kroos2_1#2$1", "focus": 1.0}}, {"id": 201, "prop": "name", "attributes": {"content": "  那姑娘分明幾次都在留意掌櫃的一舉一動，我不會看走眼。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#8$1"}, {"id": 202, "prop": "name", "attributes": {"content": "  看走眼，生意就沒法做了嘛。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#8$1"}, {"id": 203, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#8$1", "name2": "avg_1021_kroos2_1#8$1", "focus": 2.0}}, {"id": 204, "prop": "name", "attributes": {"content": "  唔......", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#8$1"}, {"id": 205, "prop": "name", "attributes": {"content": "  只能相信小烏有的逃跑速度了，這點我倒是對他有信心。", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#8$1"}, {"id": 206, "prop": "Character", "attributes": {"name": "avg_npc_294_1#4$1", "name2": "avg_1021_kroos2_1#8$1", "focus": 1.0}}, {"id": 207, "prop": "name", "attributes": {"content": "  ......真沒事？", "name": "老船夫"}, "figure_art": "avg_npc_294_1#4$1"}, {"id": 208, "prop": "Character", "attributes": {"name": "avg_npc_294_1#4$1", "name2": "avg_1021_kroos2_1#1$1", "focus": 2.0}}, {"id": 209, "prop": "name", "attributes": {"content": "  沒事。那個女孩也不敢在光天化日之下做什麼出格舉動吧？雖然人少，可那時裡裡外外，還是有一些路人的。", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#1$1"}, {"id": 210, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avg_1021_kroos2_1#1$1", "focus": 1.0}}, {"id": 211, "prop": "name", "attributes": {"content": "  ......呼，能在這裡遇見你們羅德島，真是巧合。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 212, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avg_1021_kroos2_1#8$1", "focus": 2.0}}, {"id": 213, "prop": "name", "attributes": {"content": "  鯉先生怎麼會來尚蜀？是事務所的委託？", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#8$1"}, {"id": 214, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#9$1", "name2": "avg_1021_kroos2_1#8$1", "focus": 1.0}}, {"id": 215, "prop": "name", "attributes": {"content": "  算是吧，不過只是一個老朋友委託給我的私事。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#9$1"}, {"id": 216, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#9$1", "name2": "avg_1021_kroos2_1#2$1", "focus": 2.0}}, {"id": 217, "prop": "name", "attributes": {"content": "  ......是那個盒子？", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#2$1"}, {"id": 218, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#9$1", "name2": "avg_1021_kroos2_1#2$1", "focus": 1.0}}, {"id": 219, "prop": "name", "attributes": {"content": "  沒錯。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#9$1"}, {"id": 220, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#9$1", "name2": "avg_npc_294_1#6$1", "focus": 2.0}}, {"id": 221, "prop": "name", "attributes": {"content": "  可這真是奇了怪了，在這尚蜀城內，竟然還有人敢搶梁大人的東西？", "name": "老船夫"}, "figure_art": "avg_npc_294_1#6$1"}, {"id": 222, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avg_npc_294_1#6$1", "focus": 1.0}}, {"id": 223, "prop": "name", "attributes": {"content": "  不奇怪。如果能安安穩穩抵達尚蜀，梁大人又何苦特地找我呢？", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 224, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avg_1021_kroos2_1#2$1", "focus": 2.0}}, {"id": 225, "prop": "name", "attributes": {"content": "  梁大人？", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#2$1"}, {"id": 226, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avg_1021_kroos2_1#2$1", "focus": 1.0}}, {"id": 227, "prop": "name", "attributes": {"content": "  是我一位老同學......你就當是尚蜀的魏彥吾就行。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 228, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avg_1021_kroos2_1#8$1", "focus": 2.0}}, {"id": 229, "prop": "name", "attributes": {"content": "  唔啊......魏先生啊......", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#8$1"}, {"id": 230, "prop": "Character", "attributes": {"name": "avg_npc_294_1#4$1", "name2": "avg_1021_kroos2_1#8$1", "focus": 1.0}}, {"id": 231, "prop": "name", "attributes": {"content": "  ......聽這口氣，各位與龍門魏公是熟識？", "name": "老船夫"}, "figure_art": "avg_npc_294_1#4$1"}, {"id": 232, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avg_npc_294_1#4$1", "focus": 1.0}}, {"id": 233, "prop": "name", "attributes": {"content": "  平頭百姓也就罷了，可想在龍門混口飯吃的人，有幾個不熟知魏公？", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 234, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avg_npc_294_1#5$1", "focus": 2.0}}, {"id": 235, "prop": "name", "attributes": {"content": "  認識魏公，和魏公認識，是兩碼事。", "name": "老船夫"}, "figure_art": "avg_npc_294_1#5$1"}, {"id": 236, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#8$1", "name2": "avg_npc_294_1#5$1", "focus": 1.0}}, {"id": 237, "prop": "name", "attributes": {"content": "  確是如此，不過我和魏彥吾的那點孽緣，就先不提了吧。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#8$1"}, {"id": 238, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#8$1", "name2": "avg_npc_294_1#2$1", "focus": 2.0}}, {"id": 239, "prop": "name", "attributes": {"content": "  唉。可惜，我是結識不了魏公那般人物了。", "name": "老船夫"}, "figure_art": "avg_npc_294_1#2$1"}, {"id": 240, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#2$1", "name2": "avg_npc_294_1#2$1", "focus": 1.0}}, {"id": 241, "prop": "name", "attributes": {"content": "  ......了不起是了不起，但也沒有那麼了不起。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#2$1"}, {"id": 242, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#2$1", "name2": "avg_1021_kroos2_1#8$1", "focus": 2.0}}, {"id": 243, "prop": "name", "attributes": {"content": "  這麼說，那位梁大人豈不是個大人物？", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#8$1"}, {"id": 244, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avg_npc_294_1#1$1", "focus": 1.0}}, {"id": 245, "prop": "name", "attributes": {"content": "  能算大人物嗎？", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 246, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avg_npc_294_1#1$1", "focus": 2.0}}, {"id": 247, "prop": "name", "attributes": {"content": "  算，怎麼不算。", "name": "老船夫"}, "figure_art": "avg_npc_294_1#1$1"}, {"id": 248, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avg_npc_294_1#6$1", "focus": 2.0}}, {"id": 249, "prop": "name", "attributes": {"content": "  慢著，你這話的意思是龍門魏公不算，還是梁大人不算？", "name": "老船夫"}, "figure_art": "avg_npc_294_1#6$1"}, {"id": 250, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#9$1", "name2": "avg_npc_294_1#6$1", "focus": 1.0}}, {"id": 251, "prop": "name", "attributes": {"content": "  那就算吧，如今都是個大人物了，嘖嘖嘖。當年還只是個不懂變通的愣頭青呢。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#9$1"}, {"id": 252, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#9$1", "name2": "avg_1021_kroos2_1#1$1", "focus": 2.0}}, {"id": 253, "prop": "name", "attributes": {"content": "  ......鯉先生倒還是老樣子。", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#1$1"}, {"id": 254, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#10$1", "name2": "avg_1021_kroos2_1#1$1", "focus": 1.0}}, {"id": 255, "prop": "name", "attributes": {"content": "  呵，我在龍門討日子，和他一個尚蜀大官有多大關係？很久沒聯繫啦。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#10$1"}, {"id": 256, "prop": "Character", "attributes": {"name": "avg_npc_294_1#4$1"}}, {"id": 257, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 258, "prop": "name", "attributes": {"content": "  快瞧，是那小夥子。", "name": "老船夫"}, "figure_art": "avg_npc_294_1#4$1"}, {"id": 259, "prop": "Dialog", "attributes": {}}, {"id": 260, "prop": "character", "attributes": {}}, {"id": 261, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.6}}, {"id": 262, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#5$1", "name2": "char_empty", "fadetime": 0.7}}, {"id": 263, "prop": "delay", "attributes": {"time": 3.0}}, {"id": 264, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 0.6}}, {"id": 265, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "xpos": 200.0, "fadetime": 0.3, "block": "true"}}, {"id": 266, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 267, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "fadetime": 1.0, "block": "false"}}, {"id": 268, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#5$1", "name2": "avg_1021_kroos2_1#2$1", "fadetime": 0.7}}, {"id": 269, "prop": "delay", "attributes": {"time": 1.1}}, {"id": 270, "prop": "name", "attributes": {"content": "  小烏有！你沒事吧？", "name": "克洛絲"}}, {"id": 271, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#5$1", "name2": "avg_1021_kroos2_1#2$1", "focus": 1.0}}, {"id": 272, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 273, "prop": "name", "attributes": {"content": "  哎喲喲喲，別動，別動，渾身疼，渾身疼......", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#5$1"}, {"id": 274, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#5$1", "name2": "avg_1021_kroos2_1#2$1", "focus": 1.0}}, {"id": 275, "prop": "name", "attributes": {"content": "  恩人哪，你是有所不知啊，剛才那丫頭耍起瘋勁來那叫一個狠，我使了渾身解數才勉強招架，趁著掌櫃拉架的空檔，趕緊開溜啦——", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#5$1"}, {"id": 276, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#5$1", "name2": "avg_1021_kroos2_1#7$1", "focus": 2.0}}, {"id": 277, "prop": "name", "attributes": {"content": "  ......看你跑過來的模樣，分明就沒受傷嘛。", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#7$1"}, {"id": 278, "prop": "name", "attributes": {"content": "  扇子都收在手裡，哪使出渾身解數了嘛。", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#7$1"}, {"id": 279, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#1$1", "name2": "avg_1021_kroos2_1#7$1", "focus": 1.0}}, {"id": 280, "prop": "name", "attributes": {"content": "  呃......瞞不過恩人......不過太久沒大張旗鼓地動過手了，確實有些抽筋......", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#1$1"}, {"id": 281, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avgnew_455_nothing_1#1$1", "focus": 1.0}}, {"id": 282, "prop": "name", "attributes": {"content": "  ......這位小兄弟是？", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 283, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avg_1021_kroos2_1#1$1", "focus": 2.0}}, {"id": 284, "prop": "name", "attributes": {"content": "  幹員烏有。", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#1$1"}, {"id": 285, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avgnew_455_nothing_1#2$1", "focus": 2.0}}, {"id": 286, "prop": "name", "attributes": {"content": "  雖然還沒正式入職，不過我那一顆鞠躬盡瘁的心，已經在羅德島跳動久矣。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#2$1"}, {"id": 287, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avgnew_455_nothing_1#2$1", "focus": 1.0}}, {"id": 288, "prop": "name", "attributes": {"content": "  原來是新入職的幹員朋友，幸會。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 289, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avgnew_455_nothing_1#1$1", "focus": 2.0}}, {"id": 290, "prop": "name", "attributes": {"content": "  您好您好，聽恩人說，您也是羅德島的合作方？哎，不愧是羅德島，廣結善緣，深得人心，能結交到您這樣的......", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#1$1"}, {"id": 291, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#9$1", "name2": "avgnew_455_nothing_1#1$1", "focus": 1.0}}, {"id": 292, "prop": "name", "attributes": {"content": "  叫我老鯉就好。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#9$1"}, {"id": 293, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#9$1", "name2": "avgnew_455_nothing_1#1$1", "focus": 2.0}}, {"id": 294, "prop": "name", "attributes": {"content": "  鯉兄客氣。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#1$1"}, {"id": 295, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avgnew_455_nothing_1#1$1", "focus": 1.0}}, {"id": 296, "prop": "name", "attributes": {"content": "  那麼，兄弟你剛才說，那位掌櫃拉架，你才有機會跑出來？", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 297, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avgnew_455_nothing_1#6$1", "focus": 2.0}}, {"id": 298, "prop": "name", "attributes": {"content": "  正是，怎麼？", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#6$1"}, {"id": 299, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#2$1", "name2": "avgnew_455_nothing_1#6$1", "focus": 1.0}}, {"id": 300, "prop": "name", "attributes": {"content": "  ......嗯......看來事情也沒那麼簡單。"