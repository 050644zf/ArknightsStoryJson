s": {}}, {"id": 259, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.6}}, {"id": 260, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#1$1", "fadetime": 1.0, "block": "true"}}, {"id": 261, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 262, "prop": "name", "attributes": {"content": "  恩人說的沒錯。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#1$1"}, {"id": 263, "prop": "name", "attributes": {"content": "  雖說身份有別，但托人辦事，從來沒有語焉不詳的道理。俗話說得好，人心隔肚皮，不坦誠相待，怕是處理不好這件事。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#1$1"}, {"id": 264, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#1$1", "name2": "avg_1021_kroos2_1#1$1", "focus": 2.0}}, {"id": 265, "prop": "name", "attributes": {"content": "  我還擔心你迷路了呢。", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#1$1"}, {"id": 266, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#7$1", "name2": "avg_1021_kroos2_1#1$1", "focus": 1.0}}, {"id": 267, "prop": "name", "attributes": {"content": "  啊哈哈，恩人明鑑。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#7$1"}, {"id": 268, "prop": "Character", "attributes": {"name": "avg_npc_297_1#1$1"}}, {"id": 269, "prop": "name", "attributes": {"content": "  ......你還把她們當成你們的“幹員”。", "name": "左樂"}, "figure_art": "avg_npc_297_1#1$1"}, {"id": 270, "prop": "Character", "attributes": {"name": "avg_1021_kroos2_1#1$1"}}, {"id": 271, "prop": "name", "attributes": {"content": "  是的。", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#1$1"}, {"id": 272, "prop": "Character", "attributes": {"name": "avg_npc_297_1#2$1"}}, {"id": 273, "prop": "name", "attributes": {"content": "  ......", "name": "左樂"}, "figure_art": "avg_npc_297_1#2$1"}, {"id": 274, "prop": "name", "attributes": {"content": "少年沉默不語。"}}, {"id": 275, "prop": "name", "attributes": {"content": "作為最年輕的司歲台秉燭人，他必須要權衡利弊，做出選擇。"}}, {"id": 276, "prop": "name", "attributes": {"content": "這不是什麼驚為天人的秘密。"}}, {"id": 277, "prop": "name", "attributes": {"content": "但他不希望事情出現任何差池。"}}, {"id": 278, "prop": "Character", "attributes": {"name": "avg_npc_297_1#7$1"}}, {"id": 279, "prop": "name", "attributes": {"content": "  ......這隻酒盞裡寄宿著一匹凶獸。當然，只是他意識的部分。", "name": "左樂"}, "figure_art": "avg_npc_297_1#7$1"}, {"id": 280, "prop": "Character", "attributes": {"name": "avg_npc_297_1#7$1", "name2": "avg_npc_299_1#1$1", "focus": 2.0}}, {"id": 281, "prop": "name", "attributes": {"content": "  公子。", "name": "太合"}, "figure_art": "avg_npc_299_1#1$1"}, {"id": 282, "prop": "Character", "attributes": {"name": "avg_npc_297_1#6$1", "name2": "avg_npc_299_1#1$1", "focus": 1.0}}, {"id": 283, "prop": "name", "attributes": {"content": "  我自有分寸，若是之後司歲台怪罪下來，太合叔也不必念人情，依法處置便是。", "name": "左樂"}, "figure_art": "avg_npc_297_1#6$1"}, {"id": 284, "prop": "Character", "attributes": {"name": "avg_npc_297_1#6$1", "name2": "avg_npc_299_1#2$1", "focus": 2.0}}, {"id": 285, "prop": "name", "attributes": {"content": "  ......", "name": "太合"}, "figure_art": "avg_npc_299_1#2$1"}, {"id": 286, "prop": "Character", "attributes": {"name": "avg_1021_kroos2_1#2$1"}}, {"id": 287, "prop": "name", "attributes": {"content": "  寄宿？", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#2$1"}, {"id": 288, "prop": "Character", "attributes": {"name": "avg_npc_297_1#1$1"}}, {"id": 289, "prop": "name", "attributes": {"content": "  當代巨獸學家普遍認為，除了以某種形式凝出肉身實體，行走大地之外，這些古老巨物，也有手段寄宿於一些物件之中。", "name": "左樂"}, "figure_art": "avg_npc_297_1#1$1"}, {"id": 290, "prop": "name", "attributes": {"content": "  古籍常言，“獸與厚土行”，其實點出了這些生物的特性。", "name": "左樂"}, "figure_art": "avg_npc_297_1#1$1"}, {"id": 291, "prop": "Character", "attributes": {"name": "avg_1021_kroos2_1#5$1"}}, {"id": 292, "prop": "name", "attributes": {"content": "  ......呃，什麼物件都行？", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#5$1"}, {"id": 293, "prop": "Character", "attributes": {"name": "avg_npc_297_1#1$1"}}, {"id": 294, "prop": "name", "attributes": {"content": "  比較常見的是兵器。無論是古代薩卡茲的刀劍，還是如今工業產物下的法杖，都有案例。", "name": "左樂"}, "figure_art": "avg_npc_297_1#1$1"}, {"id": 295, "prop": "Character", "attributes": {"name": "avg_npc_297_1#2$1"}}, {"id": 296, "prop": "name", "attributes": {"content": "  只是具體原理，尚不明晰。", "name": "左樂"}, "figure_art": "avg_npc_297_1#2$1"}, {"id": 297, "prop": "Character", "attributes": {"name": "avg_1021_kroos2_1#8$1"}}, {"id": 298, "prop": "name", "attributes": {"content": "  那麼那隻酒盞也是？", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#8$1"}, {"id": 299, "prop": "Character", "attributes": {"name": "avg_npc_297_1#6$1"}}, {"id": 300, "prop": "name", "attributes": {"content": "  所到之處，器倀四起。雖然還不能確定，但是我們有理由懷疑。", "name": "左樂"}, "figure_art": "avg_npc_297_1#6$1"}, {"id": 301, "prop": "Character", "attributes": {"name": "avg_npc_297_1#1$1"}}, {"id": 302, "prop": "name", "attributes": {"content": "  酒盞是活的，卻沒有活動起來。它周圍的物件是死的，卻會因它而活。", "name": "左樂"}, "figure_art": "avg_npc_297_1#1$1"}, {"id": 303, "prop": "name", "attributes": {"content": "  這隻酒盞流落許久，我們也是因為某個偶然，才定位到它的位置。", "name": "左樂"}, "figure_art": "avg_npc_297_1#1$1"}, {"id": 304, "prop": "Character", "attributes": {"name": "avg_1021_kroos2_1#8$1"}}, {"id": 305, "prop": "name", "attributes": {"content": "  所以你們要找到那個罪人。", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#8$1"}, {"id": 306, "prop": "Character", "attributes": {"name": "avg_npc_297_1#1$1"}}, {"id": 307, "prop": "name", "attributes": {"content": "  ......不。", "name": "左樂"}, "figure_art": "avg_npc_297_1#1$1"}, {"id": 308, "prop": "name", "attributes": {"content": "  我剛才說了，製造它的，是一位罪人。可如今它的主人，則是另一位。", "name": "左樂"}, "figure_art": "avg_npc_297_1#1$1"}, {"id": 309, "prop": "Character", "attributes": {"name": "avg_1021_kroos2_1#8$1"}}, {"id": 310, "prop": "name", "attributes": {"content": "  什麼人？", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#8$1"}, {"id": 311, "prop": "Character", "attributes": {"name": "avg_npc_297_1#1$1"}}, {"id": 312, "prop": "name", "attributes": {"content": "  一個詩人。", "name": "左樂"}, "figure_art": "avg_npc_297_1#1$1"}, {"id": 313, "prop": "dialog", "attributes": {}}, {"id": 314, "prop