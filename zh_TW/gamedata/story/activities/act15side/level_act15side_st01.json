tributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 54, "prop": "playMusic", "attributes": {"intro": "$path_intro", "key": "$path_loop", "volume": 0.4}}, {"id": 55, "prop": "name", "attributes": {"content": "清晨時分，多雲天氣。"}}, {"id": 56, "prop": "dialog", "attributes": {}}, {"id": 57, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 58, "prop": "Background", "attributes": {"image": "25_g04_yaninn", "screenadapt": "coverall"}}, {"id": 59, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 60, "prop": "name", "attributes": {"content": "大炎尚蜀，應峰路，有一家客棧。"}}, {"id": 61, "prop": "name", "attributes": {"content": "大炎如今，還叫客棧的店，多也不多。"}}, {"id": 62, "prop": "name", "attributes": {"content": "不過這裡古色古香，好酒好茶，有尚蜀最好的風情在。"}}, {"id": 63, "prop": "name", "attributes": {"content": "紅色的牌匾，金色的字。"}}, {"id": 64, "prop": "name", "attributes": {"content": "“行裕”。"}}, {"id": 65, "prop": "dialog", "attributes": {}}, {"id": 66, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1", "fadetime": 2.0, "block": "true"}}, {"id": 67, "prop": "delay", "attributes": {"time": 3.0}}, {"id": 68, "prop": "name", "attributes": {"content": "  湖松酒十壇，雲遼酒三壇，歸行老酒六壇......嗯......", "name": "掌櫃模樣的人"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 69, "prop": "name", "attributes": {"content": "  劉二，你這兒的業績，怎麼比渡口那邊少了這麼多？", "name": "掌櫃模樣的人"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 70, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1", "name2": "avgnew_npc_140_1#2$1", "focus": 2.0}}, {"id": 71, "prop": "name", "attributes": {"content": "  這您不能怪我啊，渡口那兒月初不知怎麼的，熱熱鬧鬧地辦了好幾次宴，賣得比我們這好不是理所當然的嗎！", "name": "客棧夥計"}, "figure_art": "avgnew_npc_140_1#2$1"}, {"id": 72, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1", "name2": "avgnew_npc_140_1#2$1", "focus": 1.0}}, {"id": 73, "prop": "name", "attributes": {"content": "  擺幾次席，能差多少？", "name": "掌櫃模樣的人"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 74, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1", "name2": "avgnew_npc_140_1#2$1", "focus": 2.0}}, {"id": 75, "prop": "name", "attributes": {"content": "  哎喲喂，您別站著說話不腰疼。", "name": "客棧夥計"}, "figure_art": "avgnew_npc_140_1#2$1"}, {"id": 76, "prop": "name", "attributes": {"content": "  您那幾天不在尚蜀，是不知道那排場有多誇張......說那是開張吃半年，一點都不過分啊。", "name": "客棧夥計"}, "figure_art": "avgnew_npc_140_1#2$1"}, {"id": 77, "prop": "name", "attributes": {"content": "  再說了，前幾個月分明是我們業績更好，就這兩天翻了船。鄭大掌櫃，您可不能大小眼啊。", "name": "客棧夥計"}, "figure_art": "avgnew_npc_140_1#2$1"}, {"id": 78, "prop": "name", "attributes": {"content": "  要知道我們這家門店，可是最早做起來，最早做大的。其他店鋪——要我說啊——見到我們都得喊一聲老漢。", "name": "客棧夥計"}, "figure_art": "avgnew_npc_140_1#2$1"}, {"id": 79, "prop": "name", "attributes": {"content": "  您可不能搞隔代親，有了孫子忘了兒啊。", "name": "客棧夥計"}, "figure_art": "avgnew_npc_140_1#2$1"}, {"id": 80, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1", "name2": "avgnew_npc_140_1#2$1", "focus": 1.0}}, {"id": 81, "prop": "name", "attributes": {"content": "  哭喪什麼，誰是你老漢？我還什麼都沒說呢。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 82, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1", "name2": "avgnew_npc_140_1#1$1", "focus": 2.0}}, {"id": 83, "prop": "name", "attributes": {"content": "  真等您說出口，那不就全完囉。", "name": "客棧夥計"}, "figure_art": "avgnew_npc_140_1#1$1"}, {"id": 84, "prop": "name", "attributes": {"content": "  我就是運氣不好，沒碰上那幾個貴人......", "name": "客棧夥計"}, "figure_art": "avgnew_npc_140_1#1$1"}, {"id": 85, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1", "name2": "avgnew_npc_140_1#1$1", "focus": 1.0}}, {"id": 86, "prop": "name", "attributes": {"content": "  那怎麼不見你運氣好一回？", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 87, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1", "name2": "avgnew_npc_140_1#1$1", "focus": 2.0}}, {"id": 88, "prop": "name", "attributes": {"content": "  唉！貴人貴人，哪來這麼多貴人......", "name": "客棧夥計"}, "figure_art": "avgnew_npc_140_1#1$1"}, {"id": 89, "prop": "name", "attributes": {"content": "  我們一直都靠老主顧捧場，廣告也不肯打，哪怕請幾個漂亮姑娘帥小夥也好啊......", "name": "客棧夥計"}, "figure_art": "avgnew_npc_140_1#1$1"}, {"id": 90, "prop": "Character", "attributes": {"name": "avg_npc_300_1#4$1", "name2": "avgnew_npc_140_1#1$1", "focus": 1.0}}, {"id": 91, "prop": "name", "attributes": {"content": "  （瞪）......", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#4$1"}, {"id": 92, "prop": "Character", "attributes": {"name": "avg_npc_300_1#4$1", "name2": "avgnew_npc_140_1#2$1", "focus": 2.0}}, {"id": 93, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 94, "prop": "name", "attributes": {"content": "  我啥也沒說。剛才那是在放屁呢。", "name": "客棧夥計"}, "figure_art": "avgnew_npc_140_1#2$1"}, {"id": 95, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1", "name2": "avgnew_npc_140_1#2$1", "focus": 1.0}}, {"id": 96, "prop": "name", "attributes": {"content": "  開酒樓客棧，憑的是貴人，靠的是關係，這話是不假。可你又怎麼知道誰是貴人，誰不是呢？", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 97, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1", "name2": "avgnew_npc_140_1#1$1", "focus": 2.0}}, {"id": 98, "prop": "name", "attributes": {"content": "  我要是什麼都懂，我也當掌櫃啦。", "name": "客棧夥計"}, "figure_art": "avgnew_npc_140_1#1$1"}, {"id": 99, "prop": "Character", "attributes": {"name": "avg_npc_300_1#5$1", "name2": "avgnew_npc_140_1#1$1", "focus": 1.0}}, {"id": 100, "prop": "name", "attributes": {"content": "  那就好好學著。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#5$1"}, {"id": 101, "prop": "name", "attributes": {"content": "  有錢有勢有牌面的爺，是個明眼人都看得出來，哪輪得到你這不開竅的？", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#5$1"}, {"id": 102, "prop": "Character", "attributes": {"name": "avg_npc_300_1#5$1", "name2": "avgnew_npc_140_1#2$1", "focus": 2.0}}, {"id": 103, "prop": "name", "attributes": {"content": "  呃......", "name": "客棧夥計"}, "figure_art": "avgnew_npc_140_1#2$1"}, {"id": 104, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1", "name2": "avgnew_npc_140_1#2$1", "focus": 1.0}}, {"id": 105, "prop": "name", "attributes": {"content": "  走江湖也好，在城裡安家立業也好，只要人活著，少不了和別人打交道。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 106, "prop": "name", "attributes": {"content": "  只要打交道，就少不得一雙眼。識人，識事，我們才有今天的好日子。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 107, "prop": "Character", "attributes": {"name": "avg_npc_300_1#2$1", "name2": "avgnew_npc_140_1#2$1", "focus": 1.0}}, {"id": 108, "prop": "name", "attributes": {"content": "  整天不正經，打烊就去麻將館，你能有什麼出息......", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#2$1"}, {"id": 109, "prop": "Character", "attributes": {"name": "avg_npc_300_1#4$1", "name2": "avgnew_npc_140_1#2$1", "focus": 1.0}}, {"id": 110, "prop": "name", "attributes": {"content": "  ......", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#4$1"}, {"id": 111, "prop": "Character", "attributes": {"name": "avg_npc_300_1#4$1", "name2": "avgnew_npc_140_1#2$1", "focus": 2.0}}, {"id": 112, "prop": "name", "attributes": {"content": "  ......怎麼不罵了？", "name": "客棧夥計"}, "figure_art": "avgnew_npc_140_1#2$1"}, {"id": 113, "prop": "Character", "attributes": {"name": "avg_npc_300_1#4$1", "name2": "avgnew_npc_140_1#2$1", "focus": 1.0}}, {"id": 114, "prop": "name", "attributes": {"content": "  沒見門前有兩位客人嗎！還不快去迎客！", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#4$1"}, {"id": 115, "prop": "Character", "attributes": {"name": "avgnew_npc_140_1#2$1"}}, {"id": 116, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 117, "prop": "name", "attributes": {"content": "  哎喲......我還真沒看見，快快，裡邊請！本日頭兩位客人，送鹽花生兩碟，菊花茶一壺！", "name": "客棧夥計"}, "figure_art": "avgnew_npc_140_1#2$1"}, {"id": 118, "prop": "dialog", "attributes": {}}, {"id": 119, "prop": "character", "attributes": {}}, {"id": 120, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avg_npc_294_1#1$1", "fadetime": 1.0, "block": "true"}}, {"id": 121, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.6}}, {"id": 122, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 123, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#4$1", "name2": "avg_npc_294_1#1$1", "focus": 1.0}}, {"id": 124, "prop": "name", "attributes": {"content": "  我們似乎運氣不錯？", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#4$1"}, {"id": 125, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#4$1", "name2": "avg_npc_294_1#8$1", "focus": 2.0}}, {"id": 126, "prop": "name", "attributes": {"content": "  ......時間趕早，就當我先替梁大人，為您接風洗塵。", "name": "老船夫"}, "figure_art": "avg_npc_294_1#8$1"}, {"id": 127, "prop": "Character", "attributes": {"name": "avgnew_npc_140_1#1$1"}}, {"id": 128, "prop": "name", "attributes": {"content": "  二位先坐，茶水一會兒就到！", "name": "客棧夥計"}, "figure_art": "avgnew_npc_140_1#1$1"}, {"id": 129, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avg_npc_294_1#8$1", "focus": 1.0}}, {"id": 130, "prop": "name", "attributes": {"content": "  我還以為我們會直奔著梁府去。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 131, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avg_npc_294_1#1$1", "focus": 2.0}}, {"id": 132, "prop": "name", "attributes": {"content": "  你那位“朋友”，好歹是一方父母官，忙。", "name": "老船夫"}, "figure_art": "avg_npc_294_1#1$1"}, {"id": 133, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#8$1", "name2": "avg_npc_294_1#1$1", "focus": 1.0}}, {"id": 134, "prop": "name", "attributes": {"content": "  忙到怠慢朋友，看來是真忙。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#8$1"}, {"id": 135, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 136, "prop": "name", "attributes": {"content": "  ......", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 137, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1", "name2": "avgnew_npc_140_1#1$1", "focus": 2.0}}, {"id": 138, "prop": "name", "attributes": {"content": "  （大掌櫃大掌櫃，那您瞧著，這兩個人算不算貴人？）", "name": "客棧夥計"}, "figure_art": "avgnew_npc_140_1#1$1"}, {"id": 139, "prop": "Character", "attributes": {"name": "avg_npc_300_1#5$1", "name2": "avgnew_npc_140_1#1$1", "focus": 1.0}}, {"id": 140, "prop": "name", "attributes": {"content": "  ......呵。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#5$1"}, {"id": 141, "prop": "name", "attributes": {"content": "  少問多看，人不可貌相。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#5$1"}, {"id": 142, "prop": "dialog", "attributes": {}}, {"id": 143, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 144, "prop": "Background", "attributes": {"image": "25_g02_yanalley_n", "screenadapt": "coverall"}}, {"id": 145, "prop": "character", "attributes": {}}, {"id": 146, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 147, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 148, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 149, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 150, "prop": "Subtitle", "attributes": {"text": "尚蜀風高，撥雲弄月。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 151, "prop": "subtitle", "attributes": {}}, {"id": 152, "prop": "Subtitle", "attributes": {"text": "這塊地界，自古多山。 按說建立移動城市後，這些崎嶇地形，是不利於城市建設的。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 153, "prop": "subtitle", "attributes": {}}, {"id": 154, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 155, "prop": "Background", "attributes": {"image": "25_g05_mountaincity_d", "screenadapt": "coverall"}}, {"id": 156, "prop": "character", "attributes": {}}, {"id": 157, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 158, "prop": "Subtitle", "attributes": {"text": "可尚蜀人民不願放棄自己自古生存的故鄉， 既然搬山費事費力，那就將城市融入群山。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 159, "prop": "subtitle", "attributes": {}}, {"id": 160, "prop": "Subtitle", "attributes": {"text": "於是，不同於其他城市，尚蜀的城市地塊分散在了群巒之間， 相隔百米千米不等，各有風景。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 161, "prop": "subtitle", "attributes": {}}, {"id": 162, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 163, "prop": "Background", "attributes": {"image": "25_g06_mountainroad_d", "screenadapt": "coverall"}}, {"id": 164, "prop": "character", "attributes": {}}, {"id": 165, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 166, "prop": "Subtitle", "attributes": {"text": "幸好尚蜀地界人傑地靈，最近些年，都未曾遭遇天災。 尚蜀人在山上建立了新的城鎮，打通山體，修建索道、隧道。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 167, "prop": "subtitle", "attributes": {}}, {"id": 168, "prop": "Subtitle", "attributes": {"text": "更有甚者，在土木天師的協助下， 一些名山峻嶺，被直接挪移到了移動平台上......", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 169, "prop": "subtitle", "attributes": {}}, {"id": 170, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 171, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 172, "prop": "dialog", "attributes": {}}, {"id": 173, "prop": "Character", "attributes": {"name": "avg_1021_kroos2_1#5$1", "fadetime": 2.0, "block": "true"}}, {"id": 174, "prop": "delay", "attributes": {"time": 3.0}}, {"id": 175, "prop": "name", "attributes": {"content": "  ......慢著，土木天師是什麼？", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#5$1"}, {"id": 176, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#2$1", "name2": "avg_1021_kroos2_1#5$1", "focus": 1.0}}, {"id": 177, "prop": "name", "attributes": {"content": "  恩人有所不知，大炎設有不止一處天師府，天下學子但凡源石技藝小有所成，都可以報考加入，經過層層考校，為國效力。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#2$1"}, {"id": 178, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#1$1", "name2": "avg_1021_kroos2_1#5$1", "focus": 1.0}}, {"id": 179, "prop": "name", "attributes": {"content": "  源石技藝的應用方向有很多種，源石科學也是蓬勃發展，大炎天師自然也需要分門別類，此所謂術業有專攻。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#1$1"}, {"id": 180, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#1$1", "name2": "avg_1021_kroos2_1#2$1", "focus": 2.0}}, {"id": 181, "prop": "name", "attributes": {"content": "  我還以為這種酷酷的稱呼，都是指驚蟄小姐那樣能征善戰的施術者來著。", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#2$1"}, {"id": 182, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#1$1", "name2": "avg_1021_kroos2_1#2$1", "focus": 1.0}}, {"id": 183, "prop": "name", "attributes": {"content": "  驚蟄小姐就是恩人之前提過的羅德島的那位炎國大官？哎呀，其實很久以前確是如此，只不過時代變化，民生大過天嘛。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#1$1"}, {"id": 184, "prop": "name", "attributes": {"content": "  源石技術造福民眾，而對源石技藝與源石工程研究投入畢生心血的，就是大炎工部與各處天師府了。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#1$1"}, {"id": 185, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#1$1", "name2": "avg_1021_kroos2_1#8$1", "focus": 2.0}}, {"id": 186, "prop": "name", "attributes": {"content": "  把山挪到移動城市上啊......放在其他國家，這種事情肯定無法想像......", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#8$1"}, {"id": 187, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#2$1", "name2": "avg_1021_kroos2_1#8$1", "focus": 1.0}}, {"id": 188, "prop": "name", "attributes": {"content": "  那是。不過雖說山水有情，但要真是勞民傷財，倒也不至於折騰這麼大陣仗。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#2$1"}, {"id": 189, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#1$1", "name2": "avg_1021_kroos2_1#8$1", "focus": 1.0}}, {"id": 190, "prop": "name", "attributes": {"content": "  主要還是有些土木天師對家鄉心心念念，嘔心瀝血，非說什麼移山小事一樁，不能捨山莊村落於不顧，硬按著當地官員答應了下來......", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#1$1"}, {"id": 191, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#7$1", "name2": "avg_1021_kroos2_1#8$1", "focus": 1.0}}, {"id": 192, "prop": "name", "attributes": {"content": "  炎國有句老話，一方水土養一方人。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#7$1"}, {"id": 193, "prop": "name", "attributes": {"content": "  可惜我在源石技藝方面實在是捉襟見肘，不然如果我是那些建造移動城市的人，我也會是同樣的想法。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#7$1"}, {"id": 194, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#7$1", "name2": "avg_1021_kroos2_1#10$1", "focus": 2.0}}, {"id": 195, "prop": "name", "attributes": {"content": "  你們大炎人都是這樣嗎？", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#10$1"}, {"id": 196, "prop": "dialog", "attributes": {}}, {"id": 197, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#2$1"}}, {"id": 198, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 199, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#1$1"}}, {"id": 200, "prop": "name", "attributes": {"content": "  因為眼前有如此江山——", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#1$1"}, {"id": 201, "prop": "dialog", "attributes": {}}, {"id": 202, "prop": "PlaySound", "attributes": {"key": "$fan", "volume": 1.0}}, {"id": 203, "prop": "Blocker", "attributes": {"a": 1.0, "fadetime": 1.0, "block": "true"}}, {"id": 204, "prop": "Character", "attributes": {}}, {"id": 205, "prop": "Background", "attributes": {}}, {"id": 206, "prop": "Image", "attributes": {"image": "25_i09", "xScale": 1.3, "yScale": 1.3}}, {"id": 207, "prop": "ImageTween", "attributes": {"xTo": 0.0, "yTo": 0.0, "xScaleFrom": 1.3, "yScaleFrom": 1.3, "xScaleTo": 0.83, "yScaleTo": 0.83, "duration": 40.0, "block": "false"}}, {"id": 208, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 209, "prop": "name", "attributes": {"content": "  風光無限。早春聽雪，別有韻味。", "name": "烏有"}}, {"id": 210, "prop": "name", "attributes": {"content": "  如果恩人自小生活在這裡，興許也會有這種想法吧。", "name": "烏有"}}, {"id": 211, "prop": "name", "attributes": {"content": "  ......確實說不定呢。", "name": "克洛絲"}}, {"id": 212, "prop": "name", "attributes": {"content": "  呼——真清爽。", "name": "克洛絲"}}, {"id": 213, "prop": "name", "attributes": {"content": "  “尚蜀風高，撥雲弄月”，確實是名副其實。", "name": "克洛絲"}}, {"id": 214, "prop": "name", "attributes": {"content": "  尚蜀地界有“三山十七峰”的美景，來旅遊的人還挺多的，還會有一些外國貴族特地前來瞻仰呢。", "name": "烏有"}}, {"id": 215, "prop": "name", "attributes": {"content": "  唉，想必還是因為尋常百姓在這大地上跋山涉水太困難了，不然這些名勝古跡，怕是早就人滿為患了。", "name": "烏有"}}, {"id": 216, "prop": "name", "attributes": {"content": "  ......好舒服的風。我本來還擔心今天下雨，耽擱我們走山路。", "name": "克洛絲"}}, {"id": 217, "prop": "name", "attributes": {"content": "  恩人說的是。春風拂面，細雨紛來，潤物無聲。", "name": "烏有"}}, {"id": 218, "prop": "name", "attributes": {"content": "  之前我就想問了，你不是個練武的嗎？哪來這麼多文縐縐的用詞？", "name": "克洛絲"}}, {"id": 219, "prop": "name", "attributes": {"content": "  習武可不耽擱學文化，師父常這麼教訓。習武是傳統，學文也是傳統，好好學習，是現代人的義務......", "name": "烏有"}}, {"id": 220, "prop": "name", "attributes": {"content": "  ......再說，話術也是賺錢的門道嘛。", "name": "烏有"}}, {"id": 221, "prop": "name", "attributes": {"content": "  恩人，要不要順道遊覽一番最近的山頭？聽說這兩年，山裡的人也多起來了，熱鬧得很。", "name": "烏有"}}, {"id": 222, "prop": "name", "attributes": {"content": "  不了吧，我們進城休整一兩天，等到那姐妹倆與我們會合，就得繼續趕路了......", "name": "克洛絲"}}, {"id": 223, "prop": "name", "attributes": {"content": "  唉，不過我還是第一次有這種可惜了沿途風景的心情呢。", "name": "克洛絲"}}, {"id": 224, "prop": "name", "attributes": {"content": "  恩人向來專心致志，只向目標，心無二物，說明恩人工作認真，沒有絲毫懈怠呀。", "name": "烏有"}}, {"id": 225, "prop": "name", "attributes": {"content": "  ......沒有絲毫懈怠......我嗎？", "name": "克洛絲"}}, {"id": 226, "prop": "name", "attributes": {"content": "  當然！", "name": "烏有"}}, {"id": 227, "prop": "name", "attributes": {"content": "  這種好話可以多說點喔，我不會當真的。", "name": "克洛絲"}}, {"id": 228, "prop": "name", "attributes": {"content": "  欸，恩人，不過是帶我去辦事處入職罷了，這點小事，犯不著那麼急。", "name": "烏有"}}, {"id": 229, "prop": "name", "attributes": {"content": "  我也聽炎熔恩人說了，您這趟遠遊，本來也有放假散心的心思，那就更沒必要耽誤恩人遊山玩水，對吧？", "name": "烏有"}}, {"id": 230, "prop": "dialog", "attributes": {}}, {"id": 231, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 232, "prop": "image", "attributes": {}}, {"id": 233, "prop": "Background", "attributes": {"image": "25_g06_mountainroad_d", "screenadapt": "coverall"}}, {"id": 234, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 235, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#1$1", "name2": "avg_1021_kroos2_1#8$1", "focus": 2.0}}, {"id": 236, "prop": "name", "attributes": {"content": "  唉。", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#8$1"}, {"id": 237, "prop": "name", "attributes": {"content": "  要是小炎熔也在就好了......需要整理思緒的，也不止我一個人啊。", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#8$1"}, {"id": 238, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#1$1", "name2": "avg_1021_kroos2_1#8$1", "focus": 1.0}}, {"id": 239, "prop": "name", "attributes": {"content": "  炎熔恩人只是突然受了委託，走另一條路而已，想必沿途風景，也是看得到的。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#1$1"}, {"id": 240, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#1$1", "name2": "avg_1021_kroos2_1#5$1", "focus": 2.0}}, {"id": 241, "prop": "name", "attributes": {"content": "  我可不覺得小炎熔會是那種停下腳步來欣賞風景的人。", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#5$1"}, {"id": 242, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#7$1", "name2": "avg_1021_kroos2_1#5$1", "focus": 1.0}}, {"id": 243, "prop": "name", "attributes": {"content": "  哈哈，炎熔恩人一直如此。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#7$1"}, {"id": 244, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#7$1", "name2": "avg_1021_kroos2_1#6$1", "focus": 2.0}}, {"id": 245, "prop": "name", "attributes": {"content": "  ......其實以前，她不是現在這樣，當然我也不是。", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#6$1"}, {"id": 246, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#1$1", "name2": "avg_1021_kroos2_1#6$1", "focus": 1.0}}, {"id": 247, "prop": "name", "attributes": {"content": "  ......恩人不必介懷，事在變，人在變，世事無常。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#1$1"}, {"id": 248, "prop": "name", "attributes": {"content": "  我們還是早些趕路吧。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#1$1"}, {"id": 249, "prop": "stopmusic", "attributes": {"fadetime": 3.0}}, {"id": 250, "prop": "dialog", "attributes": {}}, {"id": 251, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 252, "prop": "character", "attributes": {}}, {"id": 253, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 254, "prop": "Background", "attributes": {"image": "25_g01_yanstreet_d", "screenadapt": "coverall"}}, {"id": 255, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.5, "block": "true"}}, {"id": 256, "prop": "playMusic", "attributes": {"intro": "$darkness01_intro", "key": "$darkness01_loop", "volume": 0.4}}, {"id": 257, "prop": "Character", "attributes": {"name": "avg_npc_303_1#1$1"}}, {"id": 258, "prop": "name", "attributes": {"content": "  杜小姐，人找到了。", "name": "街頭青年"}, "figure_art": "avg_npc_303_1#1$1"}, {"id": 259, "prop": "dialog", "attributes": {}}, {"id": 260, "prop": "character", "attributes": {}}, {"id": 261, "prop": "Character", "attributes": {"name": "avg_npc_296_1#1$1", "blackstart": 0.2, "blackend": 0.7, "fadetime": 1.0, "block": "true"}}, {"id": 262, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 263, "prop": "name", "attributes": {"content": "  確定？", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 264, "prop": "Character", "attributes": {"name": "avg_npc_303_1#1$1"}}, {"id": 265, "prop": "name", "attributes": {"content": "  錯不了，從爭山渡進城，已經到了未長區應峰路，安排了信得過的人，一路跟著呢。", "name": "街頭青年"}, "figure_art": "avg_npc_303_1#1$1"}, {"id": 266, "prop": "Character", "attributes": {"name": "avg_npc_296_1#1$1", "blackstart": 0.2, "blackend": 0.7}}, {"id": 267, "prop": "name", "attributes": {"content": "  龍門人，隨身帶了個古董匣子，對吧。", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 268, "prop": "Character", "attributes": {"name": "avg_npc_303_1#1$1"}}, {"id": 269, "prop": "name", "attributes": {"content": "  是，看得一清二楚。", "name": "街頭青年"}, "figure_art": "avg_npc_303_1#1$1"}, {"id": 270, "prop": "Character", "attributes": {"name": "avg_npc_296_1#1$1", "blackstart": 0.2, "blackend": 0.7}}, {"id": 271, "prop": "name", "attributes": {"content": "  出了岔子，你們可是要擔責的。", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 272, "prop": "Character", "attributes": {"name": "avg_npc_303_1#1$1"}}, {"id": 273, "prop": "name", "attributes": {"content": "  大小姐交代的事，出不了岔子。", "name": "街頭青年"}, "figure_art": "avg_npc_303_1#1$1"}, {"id": 274, "prop": "Character", "attributes": {"name": "avg_npc_296_1#1$1", "blackstart": 0.2, "blackend": 0.7}}, {"id": 275, "prop": "name", "attributes": {"content": "  ......好！", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#1$1"}, {"id": 276, "prop": "dialog", "attributes": {}}, {"id": 277, "prop": "character", "attributes": {}}, {"id": 278, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 279, "prop": "Character", "attributes": {"name": "avg_npc_296_1#6$1", "fadetime": 1.0, "block": "true"}}, {"id": 280, "prop": "PlaySound", "attributes": {"key": "$d_avg_footstep_stonestep", "volume": 0.6}}, {"id": 281, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 282, "prop": "name", "attributes": {"content": "  那我們就替那些膽小怕事的老傢伙們，去會一會這個江洋大盜！", "name": "杜小姐"}, "figure_art": "avg_npc_296_1#6$1"}, {"id": 283, "prop": "Dialog", "attributes": {}}, {"id": 284, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 285, "prop": "Dialog", "attributes": {}}, {"id": 286, "prop": "Character", "attributes": {}}, {"id": 287, "prop": "Image", "attributes": {}}, {"id": 288, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}