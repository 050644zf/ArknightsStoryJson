op": "delay", "attributes": {"time": 1.0}}, {"id": 313, "prop": "playMusic", "attributes": {"intro": "$nervous_intro", "key": "$nervous_loop", "volume": 0.4}}, {"id": 314, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#4$1"}}, {"id": 315, "prop": "name", "attributes": {"content": "  唔......剛才那是......夢？", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#4$1"}, {"id": 316, "prop": "Character", "attributes": {"name": "avg_npc_295_1#4$1", "name2": "avg_322_lmlee_1#4$1", "focus": 1.0}}, {"id": 317, "prop": "name", "attributes": {"content": "  你沒事吧？", "name": "梁洵"}, "figure_art": "avg_npc_295_1#4$1"}, {"id": 318, "prop": "Character", "attributes": {"name": "avg_npc_295_1#4$1", "name2": "avg_322_lmlee_1#4$1", "focus": 2.0}}, {"id": 319, "prop": "name", "attributes": {"content": "  我還沒到睡個覺就會出事的年紀......怎麼了？", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#4$1"}, {"id": 320, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#4$1", "name2": "avgnew_455_nothing_1#6$1", "focus": 2.0}}, {"id": 321, "prop": "name", "attributes": {"content": "  ......鯉先生，剛才有人說看見了小偷，抱著與您那隻相同的匣子飛簷走壁逃了。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#6$1"}, {"id": 322, "prop": "Character", "attributes": {"name": "avg_npc_295_1#1$1"}}, {"id": 323, "prop": "name", "attributes": {"content": "  匣子不見了？", "name": "梁洵"}, "figure_art": "avg_npc_295_1#1$1"}, {"id": 324, "prop": "Character", "attributes": {"name": "avg_npc_295_1#1$1", "name2": "avg_322_lmlee_1#1$1", "focus": 2.0}}, {"id": 325, "prop": "name", "attributes": {"content": "  你說那隻酒盞啊......沒事，在我這呢。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 326, "prop": "Character", "attributes": {"name": "avg_npc_295_1#1$1", "name2": "avg_322_lmlee_1#1$1", "focus": 1.0}}, {"id": 327, "prop": "name", "attributes": {"content": "  你是怎麼......", "name": "梁洵"}, "figure_art": "avg_npc_295_1#1$1"}, {"id": 328, "prop": "Character", "attributes": {"name": "avg_npc_295_1#1$1", "name2": "avg_322_lmlee_1#1$1", "focus": 2.0}}, {"id": 329, "prop": "name", "attributes": {"content": "  放匣子裡的是我剛才順手從櫥櫃上順下來的普通茶壺，拿墨水染了個漆黑。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 330, "prop": "name", "attributes": {"content": "  我還沒有傻到明知有人盯上這玩意，還不留個心眼的。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 331, "prop": "Character", "attributes": {"name": "avgnew_455_nothing_1#1$1"}}, {"id": 332, "prop": "name", "attributes": {"content": "  鯉先生真如同克洛絲恩人所說，一顆七竅玲瓏心，絕無紕漏啊。", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#1$1"}, {"id": 333, "prop": "Character", "attributes": {"name": "avg_npc_295_1#7$1", "name2": "avg_322_lmlee_1#1$1", "focus": 1.0}}, {"id": 334, "prop": "name", "attributes": {"content": "  ......", "name": "梁洵"}, "figure_art": "avg_npc_295_1#7$1"}, {"id": 335, "prop": "Character", "attributes": {"name": "avg_npc_295_1#7$1", "name2": "avg_322_lmlee_1#1$1", "focus": 2.0}}, {"id": 336, "prop": "name", "attributes": {"content": "  梁大人。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 337, "prop": "name", "attributes": {"content": "  能為了這一隻破古董就招惹一城知府，如果天底下的賊都是這個態度，近衛局只用等在煎餅攤前就好了。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 338, "prop": "name", "attributes": {"content": "  這東西到底什麼來歷？", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 339, "prop": "Character", "attributes": {"name": "avg_npc_295_1#2$1", "name2": "avg_322_lmlee_1#1$1", "focus": 1.0}}, {"id": 340, "prop": "name", "attributes": {"content": "  該告訴你的，我會告訴你的。", "name": "梁洵"}, "figure_art": "avg_npc_295_1#2$1"}, {"id": 341, "prop": "Character", "attributes": {"name": "avg_npc_295_1#1$1", "name2": "avg_322_lmlee_1#1$1", "focus": 1.0}}, {"id": 342, "prop": "name", "attributes": {"content": "  這也是我要拜託你的第二件事。", "name": "梁洵"}, "figure_art": "avg_npc_295_1#1$1"}, {"id": 343, "prop": "name", "attributes": {"content": "  找到它的主人。", "name": "梁洵"}, "figure_art": "avg_npc_295_1#1$1"}, {"id": 344, "prop": "Character", "attributes": {"name": "avg_npc_295_1#1$1", "name2": "avg_322_lmlee_1#2$1", "focus": 2.0}}, {"id": 345, "prop": "name", "attributes": {"content": "  ......原來如此。確實是個用得著偵探的工作。", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#2$1"}, {"id": 346, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avgnew_455_nothing_1#1$1", "focus": 1.0}}, {"id": 347, "prop": "name", "attributes": {"content": "  不過在此之前......烏有兄，你的克洛絲恩人呢？", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 348, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#1$1", "name2": "avgnew_455_nothing_1#11$1", "focus": 2.0}}, {"id": 349, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 350, "prop": "name", "attributes": {"content": "  呃......難、難道追出去了！？", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#11$1"}, {"id": 351, "prop": "name", "attributes": {"content": "  我去看看！", "name": "烏有"}, "figure_art": "avgnew_455_nothing_1#11$1"}, {"id": 352, "prop": "dialog", "attributes": {}}, {"id": 353, "prop": "character", "attributes": {}}, {"id": 354, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 355, "prop": "Background", "attributes": {"image": "25_g03_yandowntown_n", "screenadapt": "coverall"}}, {"id": 356, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 357, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 0.6}}, {"id": 358, "prop": "Character", "attributes": {"name": "avg_1021_kroos2_1#3$1", "fadetime": 1.0, "block": "true"}}, {"id": 359, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 360, "prop": "name", "attributes": {"content": "  ......", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#3$1"}, {"id": 361, "prop": "name", "attributes": {"content": "  （一路追到這裡......但這裡的夜市也太熱鬧了點吧？）", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#3$1"}, {"id": 362, "prop": 