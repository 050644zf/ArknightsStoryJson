, "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 219, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#4$1"}}, {"id": 220, "prop": "name", "attributes": {"content": "  我？", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#4$1"}, {"id": 221, "prop": "Character", "attributes": {"name": "avg_322_lmlee_1#8$1"}}, {"id": 222, "prop": "name", "attributes": {"content": "  ......我......", "name": "老鯉"}, "figure_art": "avg_322_lmlee_1#8$1"}, {"id": 223, "prop": "dialog", "attributes": {}}, {"id": 224, "prop": "character", "attributes": {"name": "avg_322_lmlee_1#1$1", "blackstart": 0.2, "blackend": 0.7, "fadetime": 1.0, "block": "true"}}, {"id": 225, "prop": "name", "attributes": {"content": "  ......對了。", "name": "老鯉？"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 226, "prop": "name", "attributes": {"content": "  我是來......找你敘舊的。", "name": "老鯉？"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 227, "prop": "dialog", "attributes": {}}, {"id": 228, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 229, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 230, "prop": "Subtitle", "attributes": {"text": "手談一局？", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 231, "prop": "subtitle", "attributes": {}}, {"id": 232, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 233, "prop": "character", "attributes": {"name": "avg_322_lmlee_1#1$1", "blackstart": 0.2, "blackend": 0.7}}, {"id": 234, "prop": "name", "attributes": {"content": "  ......不了，沒有懸念，算不得樂趣。", "name": "老鯉？"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 235, "prop": "dialog", "attributes": {}}, {"id": 236, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 237, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 238, "prop": "Subtitle", "attributes": {"text": "哎呀，這麼看不起我。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 239, "prop": "subtitle", "attributes": {}}, {"id": 240, "prop": "Subtitle", "attributes": {"text": "那就是來找酒喝的了？", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 241, "prop": "subtitle", "attributes": {}}, {"id": 242, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 243, "prop": "character", "attributes": {"name": "avg_322_lmlee_1#1$1", "blackstart": 0.2, "blackend": 0.7}}, {"id": 244, "prop": "name", "attributes": {"content": "  只是給你帶了件薄禮。", "name": "老鯉？"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 245, "prop": "dialog", "attributes": {}}, {"id": 246, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 247, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 248, "prop": "Subtitle", "attributes": {"text": "幾十年不見，禮輕情意重。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 249, "prop": "subtitle", "attributes": {}}, {"id": 250, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 251, "prop": "character", "attributes": {"name": "avg_322_lmlee_1#1$1", "blackstart": 0.2, "blackend": 0.7}}, {"id": 252, "prop": "name", "attributes": {"content": "  幾十年而已，彈指一揮間。", "name": "老鯉？"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 253, "prop": "dialog", "attributes": {}}, {"id": 254, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 255, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 256, "prop": "Subtitle", "attributes": {"text": "......這是？", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 257, "prop": "subtitle", "attributes": {}}, {"id": 258, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 259, "prop": "character", "attributes": {"name": "avg_322_lmlee_1#1$1", "blackstart": 0.2, "blackend": 0.7}}, {"id": 260, "prop": "name", "attributes": {"content": "  黑白一對，如光影相生，陰陽調和。", "name": "老鯉？"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 261, "prop": "name", "attributes": {"content": "  你選一隻吧，另一隻，我便自己留著了。", "name": "老鯉？"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 262, "prop": "dialog", "attributes": {}}, {"id": 263, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 264, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 265, "prop": "Subtitle", "attributes": {"text": "唔。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 266, "prop": "subtitle", "attributes": {}}, {"id": 267, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 268, "prop": "character", "attributes": {"name": "avg_322_lmlee_1#1$1", "blackstart": 0.2, "blackend": 0.7}}, {"id": 269, "prop": "name", "attributes": {"content": "  怎麼？不喜歡？", "name": "老鯉？"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 270, "prop": "dialog", "attributes": {}}, {"id": 271, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 272, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 273, "prop": "Subtitle", "attributes": {"text": "你騙得過別人，甚至能騙過其他兄弟姐妹，可你唯獨騙不了我。", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 274, "prop": "subtitle", "attributes": {}}, {"id": 275, "prop": "Subtitle", "attributes": {"text": "你......", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 276, "prop": "subtitle", "attributes": {}}, {"id": 277, "prop": "Subtitle", "attributes": {"text": "就不怕滿盤皆輸？", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 278, "prop": "subtitle", "attributes": {}}, {"id": 279, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 280, "prop": "character", "attributes": {"name": "avg_322_lmlee_1#1$1", "blackstart": 0.2, "blackend": 0.7}}, {"id": 281, "prop": "name", "attributes": {"content": "  怕，也不怕。", "name": "老鯉？"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 282, "prop": "name", "attributes": {"content": "  再說，只是大勢所迫罷了——", "name": "老鯉？"}, "figure_art": "avg_322_lmlee_1#1$1"}, {"id": 283, "prop": "dialog", "attributes": {}}, {"id": 284, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 285, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 286, "prop": "Subtitle", "attributes": {"text": "——", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 287, "prop": "subtitle", "attributes": {}}, {"id": 288, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 289, "prop": "delay", "attributes": {"time": 0.8}}, {"id": 290, "prop": "dialog", "attributes": {}}, {"id": 291, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 292, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {