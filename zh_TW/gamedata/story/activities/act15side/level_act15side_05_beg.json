t": "  ......啊！你——！", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#4$1"}, {"id": 210, "prop": "Character", "attributes": {"name": "avg_npc_302_1#1$1"}}, {"id": 211, "prop": "name", "attributes": {"content": "  ......", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 212, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#4$1"}}, {"id": 213, "prop": "name", "attributes": {"content": "  還給我！", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#4$1"}, {"id": 214, "prop": "Character", "attributes": {"name": "avg_npc_302_1#1$1"}}, {"id": 215, "prop": "name", "attributes": {"content": "  ......", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 216, "prop": "name", "attributes": {"content": "  ......", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 217, "prop": "name", "attributes": {"content": "  ......十年了。", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 218, "prop": "name", "attributes": {"content": "  十年前，你就是為了護這隻酒盞......看著我兒子死於非命。", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 219, "prop": "Character", "attributes": {"name": "avg_npc_300_1#4$1"}}, {"id": 220, "prop": "name", "attributes": {"content": "  ......尚塚！", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#4$1"}, {"id": 221, "prop": "Character", "attributes": {"name": "avg_npc_302_1#1$1"}}, {"id": 222, "prop": "name", "attributes": {"content": "  小女娃，這沒你什麼事了。", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 223, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#4$1"}}, {"id": 224, "prop": "name", "attributes": {"content": "  你趁我不注意搶了我的貨，還敢說沒我事了！？", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#4$1"}, {"id": 225, "prop": "Character", "attributes": {"name": "avg_npc_302_1#1$1"}}, {"id": 226, "prop": "name", "attributes": {"content": "  這貨本來也不是你的。", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 227, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#5$1"}}, {"id": 228, "prop": "name", "attributes": {"content": "  唔......", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#5$1"}, {"id": 229, "prop": "Character", "attributes": {"name": "avg_npc_300_1#4$1"}}, {"id": 230, "prop": "name", "attributes": {"content": "  尚塚，你昏頭了嗎！", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#4$1"}, {"id": 231, "prop": "Character", "attributes": {"name": "avg_npc_302_1#1$1"}}, {"id": 232, "prop": "name", "attributes": {"content": "  沒你什麼事了。", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 233, "prop": "Character", "attributes": {"name": "avg_npc_300_1#4$1"}}, {"id": 234, "prop": "name", "attributes": {"content": "  尚塚！", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#4$1"}, {"id": 235, "prop": "Character", "attributes": {"name": "avg_npc_302_1#3$1"}}, {"id": 236, "prop": "name", "attributes": {"content": "  滾！", "name": "挑山人"}, "figure_art": "avg_npc_302_1#3$1"}, {"id": 237, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#4$1"}}, {"id": 238, "prop": "name", "attributes": {"content": "  ......嘁！", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#4$1"}, {"id": 239, "prop": "name", "attributes": {"content": "  你們最好記住......我一定會把東西搶回來！", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#4$1"}, {"id": 240, "prop": "Dialog", "attributes": {}}, {"id": 241, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0}}, {"id": 242, "prop": "characteraction", "attributes": {"name": "middle", "type": "move", "xpos": 300.0, "fadetime": 1.0, "block": "false"}}, {"id": 243, "prop": "Character", "attributes": {"fadetime": 0.5}}, {"id": 244, "prop": "delay", "attributes": {"time": 3.0}}, {"id": 245, "prop": "Character", "attributes": {"name": "avg_npc_302_1#1$1"}}, {"id": 246, "prop": "name", "attributes": {"content": "  ......鄭清鉞。你的刀呢？", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 247, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 248, "prop": "name", "attributes": {"content": "  在家裡。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 249, "prop": "Character", "attributes": {"name": "avg_npc_302_1#1$1"}}, {"id": 250, "prop": "name", "attributes": {"content": "  哦。在家裡。", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 251, "prop": "name", "attributes": {"content": "  那年雨夜，走鏢路上，共犧牲了十幾號人。其中有一個兒子，一個父親。", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 252, "prop": "name", "attributes": {"content": "  兒子姓尚，是我的兒子。父親姓杜，是杜遙夜的親爹。", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 253, "prop": "name", "attributes": {"content": "  所以你就不戴刀了。", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 254, "prop": "name", "attributes": {"content": "  天大的笑話。", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 255, "prop": "Character", "attributes": {"name": "avg_npc_300_1#2$1"}}, {"id": 256, "prop": "name", "attributes": {"content": "  ......你恨我到現在。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#2$1"}, {"id": 257, "prop": "Character", "attributes": {"name": "avg_npc_302_1#6$1"}}, {"id": 258, "prop": "name", "attributes": {"content": "  我不恨你，我知道你不是故意的，責任在你，錯不在你。", "name": "挑山人"}, "figure_art": "avg_npc_302_1#6$1"}, {"id": 259, "prop": "name", "attributes": {"content": "  “先救貨，再救人”，哼？", "name": "挑山人"}, "figure_art": "avg_npc_302_1#6$1"}, {"id": 260, "prop": "Character", "attributes": {"name": "avg_npc_302_1#1$1"}}, {"id": 261, "prop": "name", "attributes": {"content": "  可貨沒了，人也沒了，難道還不許我怨你？", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 262, "prop": "name", "attributes": {"content": "  我必須向你討個說法，否則我活不下去。", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 263, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 264, "prop": "name", "attributes": {"content": "  ......我答應你。酒盞給我。你知道，這隻酒盞牽扯——", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 265, "prop": "Character", "attributes": {"name": "avg_npc_302_1#1$1"}}, {"id": 266, "prop": "name", "attributes": {"content": "  我不知道。當年他為這隻酒盞而死，今天，我要拿這隻酒盞給他陪葬。", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 267, "prop": "name", "attributes": {"content": "  我在山上等你，等你去取刀。", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 268, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 269, "prop": "dialog", "attributes": {}}, {"id": 270, "prop": "character", "attributes": {}}, {"id": 271, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 272, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 273, "prop": "Background", "attributes": {"image": "25_g01_yanstreet_d", "screenadapt": "coverall"}}, {"id": 274, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.5, "block": "true"}}, {"id": 275, "prop": "playMusic", "attributes": {"intro": "$darkness02_intro", "key": "$darkness02_loop", "volume": 0.4}}, {"id": 276, "prop": "Character", "attributes": {"name": "avg_1021_kroos2_1#4$1"}}, {"id": 277, "prop": "name", "attributes": {"content": "  ......慎師傅！", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#4$1"}, {"id": 278, "prop": "Character", "attributes": {"name": "avg_npc_294_1#4$1", "name2": "avg_1021_kroos2_1#4$1", "focus": 1.0}}, {"id": 279, "prop": "name", "attributes": {"content": "  嗯？你們怎麼先來了？我剛打算去梁府找你們呢。", "name": "老船夫"}, "figure_art": "avg_npc_294_1#4$1"}, {"id": 280, "prop": "name", "attributes": {"content": "  鯉小子呢？", "name": "老船夫"}, "figure_art": "avg_npc_294_1#4$1"}, {"id": 281, "prop": "Character", "attributes": {"name": "avg_npc_294_1#4$1", "name2": "avg_1021_kroos2_1#7$1", "focus": 2.0}}, {"id": 282, "prop": "name", "attributes": {"content": "  那隻酒盞被偷了，鯉先生讓我們來找您來著。", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#7$1"}, {"id": 283, "prop": "name", "attributes": {"content": "  他有交代過什麼嗎？", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#7$1"}, {"id": 284, "prop": "Character", "attributes": {"name": "avg_npc_294_1#6$1", "name2": "avg_1021_kroos2_1#7$1", "focus": 1.0}}, {"id": 285, "prop": "name", "attributes": {"content": "  ......他讓你們來找我，卻沒讓你們先去找那梁大人？", "name": "老船夫"}, "figure_art": "avg_npc_294_1#6$1"}, {"id": 286, "prop": "name", "attributes": {"content": "  你們分明是從梁府出來的？", "name": "老船夫"}, "figure_art": "avg_npc_294_1#6$1"}, {"id": 287, "prop": "Character", "attributes": {"name": "avg_npc_294_1#6$1", "name2": "avg_1021_kroos2_1#5$1", "focus": 2.0}}, {"id": 288, "prop": "name", "attributes": {"content": "  呃......是的。", "name": "克洛絲"}, "figure_art": "avg_1021_kroos2_1#5$1"}, {"id": 289, "prop": "Character", "attributes": {"name": "avg_npc_294_1#5$1", "name2": "avg_1021_kroos2_1#5$1", "focus": 1.0}}, {"id": 290, "prop": "name", "attributes": {"content": "  ......唉。沒讓你們找梁洵，說明他心底裡已經知道了......", "name": "老船夫"}, "figure_art": "avg_npc_294_1#5$1"}, {"id": 291, "prop": "Character", "attributes": {"name": "avg_npc_294_1#2$1", "name2": "avg_1021_kroos2_1#5$1", "focus": 1.0}}, {"id": 292, "prop": "name", "attributes": {"content": "  人精，人精，確實是人精。", "name": "老船夫"}, "figure_art": "avg_npc_294_1#2$1"}, {"id": 293, "prop": "dialog", "attributes": {}}, {"id": 294, "prop": "character", "attributes": {}}, {"id": 295, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 296, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 297, "prop": "Background", "attributes": {"image": "25_g04_yaninn", "screenadapt": "coverall"}}, {"id": 298, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 299, "prop": "Character", "attributes": {"name": "avg_npc_299_1#1$1", "fadetime": 1.5, "block": "true"}}, {"id": 300, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.6}}, {"id": 301, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 302, "prop": "Character", "attributes": {"name": "avg_npc_297_1#4$1", "name2": "avg_npc_299_1#1$1", "focus": 1.0}}, {"id": 303, "prop": "name", "attributes": {"content": "  太合叔，回來了？", "name": "左樂"}, "figure_art": "avg_npc_297_1#4$1"}, {"id": 304, "prop": "Character", "attributes": {"name": "avg_npc_297_1#1$1", "name2": "avg_npc_299_1#1$1", "focus": 1.0}}, {"id": 305, "prop": "name", "attributes": {"content": "  如何？", "name": "左樂"}, "figure_art": "avg_npc_297_1#1$1"}, {"id": 306, "prop": "Character", "attributes": {"name": "avg_npc_297_1#1$1", "name2": "avg_npc_299_1#1$1", "focus": 2.0}}, {"id": 307, "prop": "name", "attributes": {"content": "  以她身份而言，禮數周到，名副其實。", "name": "太合"}, "figure_art": "avg_npc_299_1#1$1"}, {"id": 308, "prop": "Character", "attributes": {"name": "avg_npc_297_1#7$1", "name2": "avg_npc_299_1#1$1", "focus": 1.0}}, {"id": 309, "prop": "name", "attributes": {"content": "  願意演這番禮數周到，說明還有斡旋餘地。", "name": "左樂"}, "figure_art": "avg_npc_297_1#7$1"}, {"id": 310, "prop": "name", "attributes": {"content": "  不論她本人做何動作，有何居心。太傅手諭在此，作不得假。", "name": "左樂"}, "figure_art": "avg_npc_297_1#7$1"}, {"id": 311, "prop": "Character", "attributes": {"name": "avg_npc_297_1#7$1", "name2": "avg_npc_299_1#1$1", "focus": 2.0}}, {"id": 312, "prop": "name", "attributes": {"content": "  她是個聰明人。", "name": "太合"}, "figure_art": "avg_npc_299_1#1$1"}, {"id": 313, "prop": "name", "attributes": {"content": "  我既以官身拜訪，她當有所覺察。", "name": "太合"}, "figure_art": "avg_npc_299_1#1$1"}, {"id": 314, "prop": "Character", "attributes": {"name": "avg_npc_297_1#5$1", "name2": "avg_npc_299_1#1$1", "focus": 1.0}}, {"id": 315, "prop": "name", "attributes": {"content": "  ......好。", "name": "左樂"}, "figure_art": "avg_npc_297_1#5$1"}, {"id": 316, "prop": "Character", "attributes": {"name": "avg_npc_297_1#5$1", "name2": "avg_npc_299_1#2$1", "focus": 2.0}}, {"id": 317, "prop": "name", "attributes": {"content": "  如今兩方都如勁弓滿弦，一觸即發。", "name": "太合"}, "figure_art": "avg_npc_299_1#2$1"}, {"id": 318, "prop": "Character", "attributes": {"name": "avg_npc_297_1#1$1", "name2": "avg_npc_299_1#1$1", "focus": 2.0}}, {"id": 319, "prop": "name", "attributes": {"content": "  唯有在惹出更多口舌非議之前，了結事端。", "name": "太合"}, "figure_art": "avg_npc_299_1#1$1"}, {"id": 320, "prop": "Character", "attributes": {"name": "avg_npc_297_1#2$1", "name2": "avg_npc_299_1#1$1", "focus": 1.0}}, {"id": 321, "prop": "name", "attributes": {"content": "  如果真的要讓所有人相信，我們的選擇能讓大炎永除後患，那我們自然得依那四個字——", "name": "左樂"}, "figure_art": "avg_npc_297_1#2$1"}, {"id": 322, "prop": "Character", "attributes": {"name": "avg_npc_297_1#6$1", "name2": "avg_npc_299_1#1$1", "focus": 1.0}}, {"id": 323, "prop": "name", "attributes": {"content": "  ——光明磊落。", "name": "左樂"}, "figure_art": "avg_npc_297_1#6$1"}, {"id": 324, "prop": "Dialog", "attributes": {}}, {"id": 325, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 326, "prop": "Character", "attributes": {}}, {"id": 327, "prop": "Image", "attributes": {}}, {"id": 328, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}