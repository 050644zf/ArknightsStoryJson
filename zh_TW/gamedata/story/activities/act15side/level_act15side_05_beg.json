{"lang": "zh_TW", "eventid": "act15side", "eventName": "將進酒", "entryType": "ACTIVITY", "storyCode": "IW-5", "avgTag": "行動前", "storyName": "貨與人", "storyInfo": "鄭掌櫃先一步截下了名為夜半的竊賊，卻被挑山人尚塚橫插一腳，奪走酒盞。克洛絲一行也找到老船夫，打算與老鯉會合。\n", "storyList": [{"id": 0, "prop": "HEADER", "attributes": {"key": "title_test", "is_skippable": "true", "fit_mode": "BLACK_MASK"}}, {"id": 1, "prop": "stopmusic", "attributes": {}}, {"id": 2, "prop": "Dialog", "attributes": {}}, {"id": 3, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 4, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 5, "prop": "playMusic", "attributes": {"intro": "$darkness01_intro", "key": "$darkness01_loop", "volume": 0.4}}, {"id": 6, "prop": "Background", "attributes": {"image": "25_g05_mountaincity_d", "screenadapt": "coverall"}}, {"id": 7, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 8, "prop": "name", "attributes": {"content": "山上的風，總是清爽的。"}}, {"id": 9, "prop": "name", "attributes": {"content": "一個清爽的早晨，總是適合解決一些不清不楚的事情。"}}, {"id": 10, "prop": "name", "attributes": {"content": "山間小鎮剛起炊煙，春雪未散，一老一小，相顧無言。"}}, {"id": 11, "prop": "name", "attributes": {"content": "只聽遠方一聲擊鑼。"}}, {"id": 12, "prop": "dialog", "attributes": {}}, {"id": 13, "prop": "character", "attributes": {}}, {"id": 14, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1", "fadetime": 1.0, "block": "true"}}, {"id": 15, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 16, "prop": "name", "attributes": {"content": "  等你很久了。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 17, "prop": "dialog", "attributes": {}}, {"id": 18, "prop": "character", "attributes": {}}, {"id": 19, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#8$1", "fadetime": 1.0, "block": "true"}}, {"id": 20, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 21, "prop": "name", "attributes": {"content": "  ......嘁，這傢伙......阿燈，先不要輕舉妄動。", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#8$1"}, {"id": 22, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 23, "prop": "name", "attributes": {"content": "  我見過你，嗯，原來是你。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 24, "prop": "name", "attributes": {"content": "  的確是出人意料，一個雷姆必拓人，一個從一開始就悄悄蟄伏在尚蜀的人。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 25, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#1$1"}}, {"id": 26, "prop": "name", "attributes": {"content": "  我可聽不懂啊。", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#1$1"}, {"id": 27, "prop": "Character", "attributes": {"name": "avg_npc_300_1#4$1"}}, {"id": 28, "prop": "name", "attributes": {"content": "  ......哼。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#4$1"}, {"id": 29, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#11$1"}}, {"id": 30, "prop": "name", "attributes": {"content": "  阿燈！", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#11$1"}, {"id": 31, "prop": "dialog", "attributes": {}}, {"id": 32, "prop": "character", "attributes": {}}, {"id": 33, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 34, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#4$1"}}, {"id": 35, "prop": "name", "attributes": {"content": "  什——！？", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#4$1"}, {"id": 36, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 37, "prop": "name", "attributes": {"content": "  套索？", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 38, "prop": "name", "attributes": {"content": "  你把這些眠獸訓練得不錯，如果是尋常人，此刻就該倒栽蔥紮在地裡了。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 39, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#8$1"}}, {"id": 40, "prop": "name", "attributes": {"content": "  （不僅能立刻發現背後的陷阱，還能穩穩把繩索踩在腳下......這老頭......）", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#8$1"}, {"id": 41, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 42, "prop": "name", "attributes": {"content": "  別擔心，我不難為你一個姑娘家。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 43, "prop": "name", "attributes": {"content": "  你知道你懷裡的那隻酒盞，是什麼東西嗎？", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 44, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#11$1"}}, {"id": 45, "prop": "name", "attributes": {"content": "  ......我不關心，也不在乎。問太多的賞金獵人，都是新手。", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#11$1"}, {"id": 46, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 47, "prop": "name", "attributes": {"content": "  那就要怪你自己了。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 48, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 49, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#4$1"}}, {"id": 50, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 51, "prop": "name", "attributes": {"content": "  別這麼得意！小帽！鑽頭！", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#4$1"}, {"id": 52, "prop": "dialog", "attributes": {}}, {"id": 53, "prop": "playMusic", "attributes": {"intro": "$normal02_intro", "key": "$normal02_loop", "volume": 0.4}}, {"id": 54, "prop": "Character", "attributes": {"name": "avg_npc_300_1#4$1"}}, {"id": 55, "prop": "PlaySound", "attributes": {"key": "$fightgeneral"}}, {"id": 56, "prop": "CameraShake", "attributes": {"duration": 0.4, "xstrength": 10.0, "ystrength": 12.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 57, "prop": "PlaySound", "attributes": {"key": "$fightgeneral"}}, {"id": 58, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 10.0, "ystrength": 12.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 59, "prop": "PlaySound", "attributes": {"key": "$d_avg_punch"}}, {"id": 60, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 10.0, "ystrength": 12.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 61, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#5$1"}}, {"id": 62, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 63, "prop": "name", "attributes": {"content": "  ——", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#5$1"}, {"id": 64, "prop": "Character", "attributes": {"name": "avg_npc_300_1#4$1"}}, {"id": 65, "prop": "name", "attributes": {"content": "  既然不知道是什麼，就老老實實把東西交出來，不要白白遭人利用。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#4$1"}, {"id": 66, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#4$1"}}, {"id": 67, "prop": "name", "attributes": {"content": "  你、你竟然對小帽——！你自找的！", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#4$1"}, {"id": 68, "prop": "dialog", "attributes": {}}, {"id": 69, "prop": "Character", "attributes": {"name": "avg_npc_300_1#4$1"}}, {"id": 70, "prop": "Blocker", "attributes": {"a": 0.7, "r": 0.95, "g": 0.95, "b": 0.95, "fadetime": 0.02, "block": "true"}}, {"id": 71, "prop": "PlaySound", "attributes": {"key": "$e_atk_arrow_h"}}, {"id": 72, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.95, "g": 0.95, "b": 0.95, "fadetime": 0.25, "block": "true"}}, {"id": 73, "prop": "CameraShake", "attributes": {"duration": 0.6, "xstrength": 5.0, "ystrength": 8.0, "vibrato": 30.0, "randomness": 90.0, "block": "true"}}, {"id": 74, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 75, "prop": "name", "attributes": {"content": "  ......無頭箭。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#4$1"}, {"id": 76, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#5$1"}}, {"id": 77, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 78, "prop": "name", "attributes": {"content": "  （用、用手抓住了？這個距離！？我可是才給弩換過弦的——！）", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#5$1"}, {"id": 79, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 80, "prop": "name", "attributes": {"content": "  好。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 81, "prop": "name", "attributes": {"content": "  念在你不願意傷人性命的份上，我給你一個機會。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 82, "prop": "name", "attributes": {"content": "  把這酒盞給我，然後告訴你背後的人：慎行，忌私。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 83, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#8$1"}}, {"id": 84, "prop": "name", "attributes": {"content": "  哼，你知道我背後是誰？", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#8$1"}, {"id": 85, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 86, "prop": "name", "attributes": {"content": "  知不知道不重要，重要的是，我能在這條路上堵住你。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 87, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#8$1"}}, {"id": 88, "prop": "name", "attributes": {"content": "  ......我憑什麼聽你的？", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#8$1"}, {"id": 89, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 90, "prop": "name", "attributes": {"content": "  你沒得選。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 91, "prop": "name", "attributes": {"content": "  你自己也許逃得掉，但你總不忍心看見，自己飼養的這些小畜生遭了殃。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 92, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#8$1"}}, {"id": 93, "prop": "name", "attributes": {"content": "  你威脅我？", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#8$1"}, {"id": 94, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 95, "prop": "name", "attributes": {"content": "  你有些身手，可除了擺弄弓弩，也沒啥功夫。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 96, "prop": "name", "attributes": {"content": "  大可不必敬酒不吃吃罰酒，混江湖，是要靠眼力識人的。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 97, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#1$1"}}, {"id": 98, "prop": "name", "attributes": {"content": "  ......確實，那個人也沒和我說，會有你這樣的高手來礙事。", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#1$1"}, {"id": 99, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 100, "prop": "name", "attributes": {"content": "  如果我拜託一個人去做一件危險的事，那我也多半不會全盤托出的。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 101, "prop": "name", "attributes": {"content": "  外鄉人，一份工作而已，何必搭上身家性命？", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 102, "prop": "name", "attributes": {"content": "  把盞給我，我以鏢局的名義擔保，那人許你多少錢財，我們雙倍奉上。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 103, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#2$1"}}, {"id": 104, "prop": "name", "attributes": {"content": "  ......哈，本來就是虧本買賣，義務勞動。", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#2$1"}, {"id": 105, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#1$1"}}, {"id": 106, "prop": "name", "attributes": {"content": "  算是幫朋友忙吧。", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#1$1"}, {"id": 107, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 108, "prop": "name", "attributes": {"content": "  朋友。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 109, "prop": "name", "attributes": {"content": "  原來你這樣的荒野流寇，也願意為朋友兩肋插刀。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 110, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#11$1"}}, {"id": 111, "prop": "name", "attributes": {"content": "  你好像對我們有點意見。", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#11$1"}, {"id": 112, "prop": "Character", "attributes": {"name": "avg_npc_300_1#2$1"}}, {"id": 113, "prop": "name", "attributes": {"content": "  ......沒有的事。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#2$1"}, {"id": 114, "prop": "name", "attributes": {"content": "  生意做久了，貴人多了，朋友也就少了。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#2$1"}, {"id": 115, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#11$1"}}, {"id": 116, "prop": "name", "attributes": {"content": "  那你就老老實實回去做生意。", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#11$1"}, {"id": 117, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 118, "prop": "name", "attributes": {"content": "  是啊，山上的生意是最好做的。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 119, "prop": "name", "attributes": {"content": "  這三山十七峰幾百條山道，哪條道上沒有供人歇腳休憩的茶館驛站，哪條道上......沒有我們的人？", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 120, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#1$1"}}, {"id": 121, "prop": "name", "attributes": {"content": "  ......", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#1$1"}, {"id": 122, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 123, "prop": "name", "attributes": {"content": "  望姑娘知曉輕重。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 124, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#1$1"}}, {"id": 125, "prop": "name", "attributes": {"content": "  你還真不把我放在眼裡。", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#1$1"}, {"id": 126, "prop": "name", "attributes": {"content": "  雖然正面開戰不是我的風格，但是都被挑釁到這個份上了......對吧，小傢伙們。", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#1$1"}, {"id": 127, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#4$1"}}, {"id": 128, "prop": "name", "attributes": {"content": "  （雷姆必拓語）讓這個老傢伙知道厲害！我們摸爬滾打這麼多年，也不是吃乾飯的！", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#4$1"}, {"id": 129, "prop": "Character", "attributes": {"name": "avg_npc_300_1#2$1"}}, {"id": 130, "prop": "name", "attributes": {"content": "  唉......", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#2$1"}, {"id": 131, "prop": "name", "attributes": {"content": "  執迷不悟。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#2$1"}, {"id": 132, "prop": "Character", "attributes": {"name": "avg_npc_300_1#4$1"}}, {"id": 133, "prop": "name", "attributes": {"content": "  若是如此，那就得罪——", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#4$1"}, {"id": 134, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 135, "prop": "dialog", "attributes": {}}, {"id": 136, "prop": "character", "attributes": {}}, {"id": 137, "prop": "Blocker", "attributes": {"a": 1.0, "r": 1.0, "g": 1.0, "b": 1.0, "afrom": 0.0, "rfrom": 0.0, "gfrom": 0.0, "bfrom": 0.0, "fadetime": 0.1, "block": "true"}}, {"id": 138, "prop": "PlaySound", "attributes": {"key": "$swordtsing2", "volume": 0.6}}, {"id": 139, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 0.1, "block": "false"}}, {"id": 140, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 10.0, "ystrength": 12.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 141, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 142, "prop": "name", "attributes": {"content": "哪怕有第三個人站在一旁，他也絕對看不清這一步，是怎麼踏上前來的。"}}, {"id": 143, "prop": "name", "attributes": {"content": "只因為這個人擅長走路，擅長爬山。他每天抬步踏步的次數，實在是太多太多。"}}, {"id": 144, "prop": "name", "attributes": {"content": "一聲脆響，地上，青磚碎裂，身前，煙塵濛濛，眼旁，是一根樸素無奇的竹木扁擔，微微發青。"}}, {"id": 145, "prop": "name", "attributes": {"content": "遠方，又一聲擊鑼。"}}, {"id": 146, "prop": "Character", "attributes": {"name": "avg_npc_300_1#4$1"}}, {"id": 147, "prop": "name", "attributes": {"content": "  ......", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#4$1"}, {"id": 148, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#4$1"}}, {"id": 149, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 150, "prop": "name", "attributes": {"content": "  ——怎、怎麼......這個人是從哪裡......啊，阿燈，別怕，鑽頭！快到我這裡......！", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#4$1"}, {"id": 151, "prop": "Character", "attributes": {"name": "avg_npc_300_1#4$1"}}, {"id": 152, "prop": "name", "attributes": {"content": "  ......是你。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#4$1"}, {"id": 153, "prop": "dialog", "attributes": {}}, {"id": 154, "prop": "character", "attributes": {}}, {"id": 155, "prop": "Character", "attributes": {"name": "avg_npc_302_1#1$1", "fadetime": 1.5, "block": "true"}}, {"id": 156, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.6}}, {"id": 157, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 158, "prop": "playMusic", "attributes": {"intro": "$nervous_intro", "key": "$nervous_loop", "volume": 0.4}}, {"id": 159, "prop": "name", "attributes": {"content": "  你終於上山了。", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 160, "prop": "name", "attributes": {"content": "  所以我來找你。", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 161, "prop": "Character", "attributes": {"name": "avg_npc_300_1#2$1"}}, {"id": 162, "prop": "name", "attributes": {"content": "  ......唉。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#2$1"}, {"id": 163, "prop": "name", "attributes": {"content": "  該來的總要來。躲是躲不完的。你又何必這麼著急？", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#2$1"}, {"id": 164, "prop": "Character", "attributes": {"name": "avg_npc_302_1#1$1"}}, {"id": 165, "prop": "name", "attributes": {"content": "  喂，小女娃。", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 166, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#5$1"}}, {"id": 167, "prop": "name", "attributes": {"content": "  ......叫我？", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#5$1"}, {"id": 168, "prop": "name", "attributes": {"content": "  （他的動作——這根木條是叫扁擔來著？他剛才做了什麼......把石磚地拍得粉碎？）", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#5$1"}, {"id": 169, "prop": "Character", "attributes": {"name": "avg_npc_302_1#1$1"}}, {"id": 170, "prop": "name", "attributes": {"content": "  你認得他？", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 171, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#1$1"}}, {"id": 172, "prop": "name", "attributes": {"content": "  不。", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#1$1"}, {"id": 173, "prop": "Character", "attributes": {"name": "avg_npc_302_1#1$1"}}, {"id": 174, "prop": "name", "attributes": {"content": "  那就是你們之間有什麼麻煩。", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 175, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 176, "prop": "name", "attributes": {"content": "  我們之間只站著你。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 177, "prop": "Character", "attributes": {"name": "avg_npc_302_1#1$1"}}, {"id": 178, "prop": "name", "attributes": {"content": "  說的對，那我就是你的麻煩。", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 179, "prop": "Character", "attributes": {"name": "avg_npc_300_1#1$1"}}, {"id": 180, "prop": "name", "attributes": {"content": "  事辦完了，我會去找你。但不是現在。", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#1$1"}, {"id": 181, "prop": "Character", "attributes": {"name": "avg_npc_302_1#1$1"}}, {"id": 182, "prop": "name", "attributes": {"content": "  ......小女娃，和你手裡護著的玩意，有關係？", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 183, "prop": "Character", "attributes": {"name": "avg_476_blkngt_1#5$1"}}, {"id": 184, "prop": "name", "attributes": {"content": "  ......啊......是......", "name": "夜半"}, "figure_art": "avg_476_blkngt_1#5$1"}, {"id": 185, "prop": "Character", "attributes": {"name": "avg_npc_300_1#4$1"}}, {"id": 186, "prop": "name", "attributes": {"content": "  你我私仇，別扯上這件大事！", "name": "鄭掌櫃"}, "figure_art": "avg_npc_300_1#4$1"}, {"id": 187, "prop": "Character", "attributes": {"name": "avg_npc_302_1#1$1"}}, {"id": 188, "prop": "name", "attributes": {"content": "  多大的事？", "name": "挑山人"}, "figure_art": "avg_npc_302_1#1$1"}, {"id": 189, "prop": "Character", "attributes": {"name": "avg_npc_300_1#4$1"}}, 