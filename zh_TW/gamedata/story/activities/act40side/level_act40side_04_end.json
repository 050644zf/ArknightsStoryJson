", "inverse": "false", "fadetime": 0.5, "block": "true"}}, {"id": 79, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovementsp"}}, {"id": 80, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_1040_blaze2_1#9$1", "posfrom": "-150,0", "posto": "50,0", "duration": 0.5}}, {"id": 81, "prop": "Delay", "attributes": {"time": 0.51}}, {"id": 82, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 83, "prop": "name", "attributes": {"content": "煌抓住了老人的手臂，想要將他拉到一旁，但吊燈已經落下——"}}, {"id": 84, "prop": "charslot", "attributes": {}}, {"id": 85, "prop": "dialog", "attributes": {}}, {"id": 86, "prop": "Delay", "attributes": {"time": 0.3}}, {"id": 87, "prop": "Blocker", "attributes": {"a": 0.2, "r": 1.0, "g": 1.0, "b": 1.0, "afrom": 0.6, "rfrom": 1.0, "gfrom": 1.0, "bfrom": 0.5, "fadetime": 1.5, "block": "false"}}, {"id": 88, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 15.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 89, "prop": "PlaySound", "attributes": {"key": "$d_avg_lightningmagic"}}, {"id": 90, "prop": "charslot", "attributes": {"duration": 0.3}}, {"id": 91, "prop": "PlaySound", "attributes": {"key": "$d_avg_smashcello", "delay": 1.0, "channel": "2"}}, {"id": 92, "prop": "PlaySound", "attributes": {"key": "$d_avg_windowbreak", "delay": 1.0, "channel": "3"}}, {"id": 93, "prop": "name", "attributes": {"content": "一聲沉悶的雷鳴後，原本徑直墜下的殘骸驟然改變了方向，被重重地砸在了牆上。"}}, {"id": 94, "prop": "dialog", "attributes": {}}, {"id": 95, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#16$1", "duration": 0.5}}, {"id": 96, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 97, "prop": "name", "attributes": {"content": "……沒事吧？", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#16$1"}, {"id": 98, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1040_blaze2_1#11$1"}}, {"id": 99, "prop": "name", "attributes": {"content": "驚蟄？！你怎麼會在這？", "name": "煌"}, "figure_ar