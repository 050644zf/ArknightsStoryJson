2_1#11$1"}, {"id": 120, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1040_blaze2_1#9$1"}}, {"id": 121, "prop": "name", "attributes": {"content": "咳咳……這煙，嗆死我了。", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#9$1"}, {"id": 122, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1619_1#4$1"}}, {"id": 123, "prop": "name", "attributes": {"content": "咳咳咳……那邊的立柱上有拉閘……", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#4$1"}, {"id": 124, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1040_blaze2_1#8$1"}}, {"id": 125, "prop": "name", "attributes": {"content": "這……這麼多……到底該拉哪個……", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#8$1"}, {"id": 126, "prop": "Dialog", "attributes": {}}, {"id": 127, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 128, "prop": "charslot", "attributes": {}}, {"id": 129, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 130, "prop": "Background", "attributes": {"image": "58_g15_restaurantlobby", "screenadapt": "coverall"}}, {"id": 131, "prop": "Blocker", "attributes": {"a": 0.2, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 2.0, "block": "true"}}, {"id": 132, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 133, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovementsp"}}, {"id": 134, "prop": "name", "attributes": {"content": "麟青硯身輕如羽，幾個起落間，那人已經被逼到角落。"}}, {"id": 135, "prop": "name", "attributes": {"content": "只隔著數公尺的距離，但空氣中煙塵瀰漫，麟青硯看不清楚那個人的身形。"}}, {"id": 136, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 5.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 137, "prop": "PlaySound", "attributes": {"key": "$d_avg_lightningmagic"}}, {"id": 138, "prop": "name", "attributes": {"content": "他正欲再跑時，一道炸雷就落在了他的身旁。"}}, {"id": 139, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#16$1"}}, {"id": 140, "prop": "name", "attributes": {"content": "站住！", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#16$1"}, {"id": 141, "prop": "name", "attributes": {"content": "你再動一下，下一道雷就會落在你頭上。", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#16$1"}, {"id": 142, "prop": "name", "attributes": {"content": "回答我的問題。", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#16$1"}, {"id": 143, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 144, "prop": "name", "attributes": {"content": "……", "name": "戴面具的人"}}, {"id": 145, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#16$1"}}, {"id": 146, "prop": "name", "attributes": {"content": "為什麼要在鼎豐樓縱火？你的目標是莫不服，還是其他人？", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#16$1"}, {"id": 147, "prop": "name", "attributes": {"content": "之前鬧出的幾次風波，也是你的手筆吧？", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#16$1"}, {"id": 148, "prop": "name", "attributes": {"content": "還有……卷牘庫？", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#16$1"}, {"id": 149, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 150, "prop": "name", "attributes": {"content": "……", "name": "戴面具的人"}}, {"id": 151, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#16$1"}}, {"id": 152, "prop": "name", "attributes": {"content": "三番五次地鬧出動靜，你……還有你的同黨，一定意有所指——為什麼？", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#16$1"}, {"id": 153, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 154, "prop": "name", "attributes": {"content": "……", "name": "戴面具的人"}}, {"id": 155, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#16$1"}}, {"id": 156, "prop": "name", "attributes": {"content": "不肯說？那我就帶你回大理寺再慢慢審——", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#16$1"}, {"id": 157, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 158, "prop": "name", "attributes": {"content": "……麟少卿既然問出了這樣的問題，心裡難道沒有答案？", "name": "戴面具的人"}}, {"id": 159, "prop": "name", "attributes": {"content": "麟少卿到底是看不到真相，還是因為不敢看，才假裝看不到？", "name": "戴面具的人"}}, {"id": 160, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#10$1"}}, {"id": 161, "prop": "name", "attributes": {"content": "什——", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#10$1"}, {"id": 162, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 163, "prop": "name", "attributes": {"content": "大理寺是個好地方，不過我現在還不想去。", "name": "戴面具的人"}}, {"id": 164, "prop": "name", "attributes": {"content": "另外，你意志不堅的時候，手裡的雷霆，沒那麼可怕。", "name": "戴面具的人"}}, {"id": 165, "prop": "name", "attributes": {"content": "……你該清醒一下了。", "name": "戴面具的人"}}, {"id": 166, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#16$1"}}, {"id": 167, "prop": "name", "attributes": {"content": "等等——", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#16$1"}, {"id": 168, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 169, "prop": "dialog", "attributes": {}}, {"id": 170, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#10$1"}}, {"id": 171, "prop": "playsound", "attributes": {"key": "$d_avg_carwash", "volume": 0.6}}, {"id": 172, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 173, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0}}, {"id": 174, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 175, "prop": "name", "attributes": {"content": "話音剛落，戴面具的人身形已動，麟青硯正要追時，頭頂的滅火裝置突然開啟。"}}, {"id": 176, "prop": "name", "attributes": {"content": "冰涼的水傾盆而下，澆得她滿頭滿臉。"}}, {"id": 177, "prop": "dialog", "attributes": {}}, {"id": 178, "prop": "charslot", "attributes": {}}, {"id": 179, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1040_blaze2_1#10$1", "duration": 0.5}}, {"id": 180, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 181, "prop": "name", "attributes": {"content": "驚蟄——", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#10$1"}, {"id": 182, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1040_blaze2_1#9$1"}}, {"id": 183, "prop": "name", "attributes": {"content": "你沒事吧？", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#9$1"}, {"id": 184, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#16$1"}}, {"id": 185, "prop": "name", "attributes": {"content": "……該死。", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#16$1"}, {"id": 186, "prop": "Dialog", "attributes": {}}, {"id": 187, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 188, "prop": "charslot", "attributes": {}}, {"id": 189, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 190, "prop": "Background", "attributes": {"image": "25_g11_yanroom", "screenadapt": "coverall"}}, {"id": 191, "prop": "playMusic", "attributes": {"intro": "$ponder_intro", "key": "$ponder_loop", "volume": 0.6}}, {"id": 192, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 193, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 194, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1635_1#1$1", "duration": 0.5}}, {"id": 195, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 196, "prop": "name", "attributes": {"content": "客人都已經安頓好了，只是有幾個人受了驚，好在沒人受傷……", "name": "慌張的廚師"}, "figure_art": "avg_npc_1635_1#1$1"}, {"id": 197, "prop": "name", "attributes": {"content": "我們已經報案了，官府的人應該馬上就會到……", "name": "慌張的廚師"}, "figure_art": "avg_npc_1635_1#1$1"}, {"id": 198, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1619_1#1$1"}}, {"id": 199, "prop": "name", "attributes": {"content": "官府的人，這邊不是已經有一位了嗎？", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 200, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#3$1"}}, {"id": 201, "prop": "name", "attributes": {"content": "……", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#3$1"}, {"id": 202, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1635_1#1$1"}}, {"id": 203, "prop": "name", "attributes": {"content": "總廚……您……", "name": "慌張的廚師"}, "figure_art": "avg_npc_1635_1#1$1"}, {"id": 204, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1619_1#1$1"}}, {"id": 205, "prop": "name", "attributes": {"content": "我沒事……多虧了這位姑娘。", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 206, "prop": "name", "attributes": {"content": "這裡也沒你們什麼事了，都回去吧。", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 207, "prop": "dialog", "attributes": {}}, {"id": 208, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 209, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1635_1#1$1"}}, {"id": 210, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 211, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 212, "prop": "name", "attributes": {"content": "幾名廚師離開後，麟青硯鎖上了房間的門。"}}, {"id": 213, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#1$1"}}, {"id": 214, "prop": "name", "attributes": {"content": "莫先生，可否留您說幾句話。", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#1$1"}, {"id": 215, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1619_1#1$1"}}, {"id": 216, "prop": "name", "attributes": {"content": "這位大人，和這位姑娘認識？", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 217, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1040_blaze2_1#2$1"}}, {"id": 218, "prop": "name", "attributes": {"content": "她是我朋友來著。", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#2$1"}, {"id": 219, "prop": "name", "attributes": {"content": "莫大廚，她在調查一樁很重要的案子，能不能麻煩您，儘量回答一下她的問題……？", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#2$1"}, {"id": 220, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1619_1#2$1"}}, {"id": 221, "prop": "name", "attributes": {"content": "哼……我莫某人不喜歡官府的事，但也不喜歡欠人情。今天被你救了一命，這人情是無論如何也還不清了。", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#2$1"}, {"id": 222, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1619_1#1$1"}}, {"id": 223, "prop": "name", "attributes": {"content": "好了。有什麼問題，就請問吧。", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 224, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#1$1"}}, {"id": 225, "prop": "name", "attributes": {"content": "我想在您的飯店裡找一位廚師，他是一樁案子的證人。", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#1$1"}, {"id": 226, "prop": "name", "attributes": {"content": "十年前，他應該在刑部死獄大牢裡，為那裡的死刑犯做“斷頭飯”。", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#1$1"}, {"id": 227, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1040_blaze2_1#2$1"}}, {"id": 228, "prop": "name", "attributes": {"content": "專門做斷頭飯的廚師……也能通過鼎豐樓的考核嗎？", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#2$1"}, {"id": 229, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#1$1"}}, {"id": 230, "prop": "name", "attributes": {"content": "鼎豐樓每年都要在百珍宴上為百官準備菜餚，所以每一位廚師的履歷必須清晰明瞭。", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#1$1"}, {"id": 231, "prop": "name", "attributes": {"content": "我想，這個廚師應該不難找到。", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#1$1"}, {"id": 232, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1619_1#1$1"}}, {"id": 233, "prop": "name", "attributes": {"content": "……大人想叫我怎麼回答？", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 234, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1619_1#5$1"}}, {"id": 235, "prop": "name", "attributes": {"content": "先是酒樓無端起火，再是說我們有廚師幫人做斷頭飯。我這鼎豐樓還要不要開下去了？", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#5$1"}, {"id": 236, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#2$1"}}, {"id": 237, "prop": "name", "attributes": {"content": "我體諒先生的難處，所以選在這樣私密的場合來向您討教。", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#2$1"}, {"id": 238, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1619_1#1$1"}}, {"id": 239, "prop": "name", "attributes": {"content": "……罷了，都是自己做過的事，沒什麼不能承認的。", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 240, "prop": "name", "attributes": {"content": "大人要找的那個廚師，死獄大牢裡那個叫莫小六的廚師，就是莫某人。", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 241, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1040_blaze2_1#11$1"}}, {"id": 242, "prop": "name", "attributes": {"content": "啊？！", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#11$1"}, {"id": 243, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#1$1"}}, {"id": 244, "prop": "name", "attributes": {"content": "果然……", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#1$1"}, {"id": 245, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1619_1#1$1"}}, {"id": 246, "prop": "name", "attributes": {"content": "做斷頭飯也不是什麼見不得人的活，王侯將相要吃飯，販夫走卒也要吃飯。", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 247, "prop": "name", "attributes": {"content": "我這手廚藝，就是在死獄大牢裡，幫天南地北的死刑犯做斷頭飯練出來的。", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 248, "prop": "name", "attributes": {"content": "我之所以改名隱藏身分，也只是不想為這家飯店帶來麻煩罷了。", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 249, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1040_blaze2_1#2$1"}}, {"id": 250, "prop": "name", "attributes": {"content": "我開始……有些佩服您了。", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#2$1"}, {"id": 251, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#1$1"}}, {"id": 252, "prop": "name", "attributes": {"content": "我想問您，是否還記得，十年前，有一個被打入大牢，名叫“顧筌”的人？", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#1$1"}, {"id": 253, "prop": "name", "attributes": {"content": "如果不記得這個名字的話，您應該還記得，幾十年來，唯一一個，被打入死獄，卻又被放出去的人。", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#1$1"}, {"id": 254, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1040_blaze2_1#11$1"}}, {"id": 255, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 256, "prop": "name", "attributes": {"content": "什麼？！", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#11$1"}, {"id": 257, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1040_blaze2_1#10$1"}}, {"id": 258, "prop": "name", "attributes": {"content": "等一下！你說我爸？我爸為什麼會是死刑犯？", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#10$1"}, {"id": 259, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#16$1"}}, {"id": 260, "prop": "name", "attributes": {"content": "……煌！", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#16$1"}, {"id": 261, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1619_1#7$1"}}, {"id": 262, "prop": "name", "attributes": {"content": "你說顧筌？他是你的父親？", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#7$1"}, {"id": 263, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1040_blaze2_1#12$1"}}, {"id": 264, "prop": "name", "attributes": {"content": "對……", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#12$1"}, {"id": 265, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#1$1"}}, {"id": 266, "prop": "name", "attributes": {"content": "您還記得他……", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#1$1"}, {"id": 267, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1619_1#3$1"}}, {"id": 268, "prop": "name", "attributes": {"content": "記得……太記得了。", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#3$1"}, {"id": 269, "prop": "name", "attributes": {"content": "我在大牢裡做了那麼多年斷頭飯，見過無數窮兇極惡之徒、奸佞宵小之輩。那些犯人，臨行前吃飯的眼神，大抵都是一個樣。", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#3$1"}, {"id": 270, "prop": "name", "attributes": {"content": "可我從來沒有在那座大牢裡見過，眼神那樣乾淨的人。", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#3$1"}, {"id": 271, "prop": "name", "attributes": {"content": "他和別的犯人不一樣，從進入大牢的第一天起，他就從來沒有哭天喊地，也沒有委屈叫冤過。", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#3$1"}, {"id": 272, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1619_1#1$1"}}, {"id": 273, "prop": "name", "attributes": {"content": "當時連我都很奇怪，像這樣的人，怎麼會出現在死獄裡。", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 274, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1040_blaze2_1#12$1"}}, {"id": 275, "prop": "name", "attributes": {"content": "我爸他……怎麼會……", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#12$1"}, {"id": 276, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#1$1"}}, {"id": 277, "prop": "name", "attributes": {"content": "那您是否知道，顧筌當時，是犯了什麼罪才被打入死獄？", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#1$1"}, {"id": 278, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1619_1#1$1"}}, {"id": 279, "prop": "name", "attributes": {"content": "當時不知道……", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 280, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#2$1"}}, {"id": 281, "prop": "name", "attributes": {"content": "當時？", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#2$1"}, {"id": 282, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1619_1#1$1"}}, {"id": 283, "prop": "name", "attributes": {"content": "那是在一年後，我加入了鼎豐樓，開始參與百珍宴，也拿到了幾年前百珍宴的菜單——", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 284, "prop": "name", "attributes": {"content": "我才知道，當年顧筌在百珍宴上，也向真龍獻過一道菜。正巧，就是這位姑娘剛才抽到的，“天下一白”。", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 285, "prop": "name", "attributes": {"content": "但是，他還在那盤菜旁邊放上了一個白麵饅頭，饅頭中間，夾著一塊紅色的腐乳。", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 286, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1040_blaze2_1#11$1"}}, {"id": 287, "prop": "name", "attributes": {"content": "這是……什麼意思？為什麼獻了這樣一道菜，就要被打入大牢？", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#11$1"}, {"id": 288, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#3$1"}}, {"id": 289, "prop": "name", "attributes": {"content": "……", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#3$1"}, {"id": 290, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1040_blaze2_1#8$1"}}, {"id": 291, "prop": "name", "attributes": {"content": "麟青硯，你為什麼不說話？", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#8$1"}, {"id": 292, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1619_1#1$1"}}, {"id": 293, "prop": "name", "attributes": {"content": "……你的家人跟你講過太師的事，但沒和你講過她最終的下場？", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 294, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1040_blaze2_1#13$1"}}, {"id": 295, "prop": "name", "attributes": {"content": "她的……下場？", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#13$1"}, {"id": 296, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#4$1"}}, {"id": 297, "prop": "name", "attributes": {"content": "……", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#4$1"}, {"id": 298, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#1$1"}}, {"id": 299, "prop": "name", "attributes": {"content": "四十年前，太師密謀刺殺前任真龍，事敗後自盡，其黨羽也被徹查，多達數千人……", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#1$1"}, {"id": 300, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1619_1#1$1"}}, {"id": 301, "prop": "name", "attributes": {"content": "顧筌在百珍宴上獻上的那道菜，就是意在為叛臣平反，惹得真龍大怒。", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 302, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1040_blaze2_1#10$1"}}, {"id": 303, "prop": "name", "attributes": {"content": "不可能……我爸和我講過很多次，太師一輩子為國為民，心懷天下，怎麼可能是謀逆的叛臣？！", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#10$1"}, {"id": 304, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#1$1"}}, {"id": 305, "prop": "name", "attributes": {"content": "……史書上的確是這樣寫的。", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#1$1"}, {"id": 306, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1040_blaze2_1#10$1"}}, {"id": 307, "prop": "name", "attributes": {"content": "史書上寫的就是真的嗎？！", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#10$1"}, {"id": 308, "prop": "name", "attributes": {"content": "麟青硯，要是史書上全是真的，你又在查什麼？！", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#10$1"}, {"id": 309, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#1$1"}}, {"id": 310, "prop": "name", "attributes": {"content": "……", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#1$1"}, {"id": 311, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1040_blaze2_1#9$1"}}, {"id": 312, "prop": "name", "attributes": {"content": "而且……而且我爸後來也沒有真的被殺對不對？那不就證明朝堂之上，還是有人相信太師和我爸是清白的嗎！", "name": "煌"}, "figure_art": "avg_1040_blaze2_1#9$1"}, {"id": 313, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#13$1"}}, {"id": 314, "prop": "name", "attributes": {"content": "這的確是疑點，如果顧筌真的是為太師案入獄，那後來他又為何會被放出來？", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#13$1"}, {"id": 315, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1619_1#3$1"}}, {"id": 316, "prop": "name", "attributes": {"content": "這也是讓我印象深刻的事……顧筌入獄以後，有兩個人見了他，這兩個人，我碰巧都認識……", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#3$1"}, {"id": 317, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1619_1#1$1"}}, {"id": 318, "prop": "name", "attributes": {"content": "一個是來為他送飯的人，是當時的大理寺少卿虞澄。", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 319, "prop": "name", "attributes": {"content": "另一個是帶他出去的人……前任禮部尚書，寧述。", "name": "莫不服"}, "figure_art": "avg_npc_1619_1#1$1"}, {"id": 320, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#10$1"}}, {"id": 321, "prop": "name", "attributes": {"content": "什麼……？！", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#10$1"}, {"id": 322, "prop": "charslot", "attributes": {}}, {"id": 323, "prop": "name", "attributes": {"content": "快！跟上！立刻包圍現場！", "name": "門外的聲音"}, "figure_art": "avg_npc_1612_1#10$1"}, {"id": 324, "prop": "dialog", "attributes": {}}, {"id": 325, "prop": "playsound", "attributes": {"key": "$d_gen_soldiersrun"}}, {"id": 326, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_1637_1#1$1", "duration": 1.0}}, {"id": 327, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1637_1#1$1", "duration": 1.0}}, {"id": 328, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 329, "prop": "charslot", "attributes": {}}, {"id": 330, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#16$1"}}, {"id": 331, "prop": "name", "attributes": {"content": "該死……偏偏這個時候……？！", "name": "麟青硯"}, "figure_art": "avg_npc_1637_1#1$1"}, {"id": 332, "prop": "charslot", "attributes": {}}, {"id": 333, "prop": "dialog", "attributes": {}}, {"id": 334, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 335, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1613_1#7$1", "duration": 1.5}}, {"id": 336, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 337, "prop": "name", "attributes": {"content": "真巧，麟少卿的動作倒是快我一步了。", "name": "諶徹"}, "figure_art": "avg_npc_1613_1#7$1"}, {"id": 338, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1612_1#1$1"}}, {"id": 339, "prop": "name", "attributes": {"content": "……前腳剛到，的確是巧。", "name": "麟青硯"}, "figure_art": "avg_npc_1612_1#1$1"}, {"id": 340, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1613_1#1$1"}}, {"id": 341, "prop": "name", "attributes": {"content": "大理寺調查鼎豐樓失火一案，請所有人配合。", "name": "諶徹"}, "figure_art": "avg_npc_1613_1#1$1"}, {"id": 342, "prop": "name", "attributes": {"content": "麟青硯，還有旁邊這位姑娘，都和我走一趟吧。", "name": "諶徹"}, "figure_art": "avg_npc_1613_1#1$1"}, {"id": 343, "prop": "Dialog", "attributes": {}}, {"id": 344, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 345, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 346, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 347, "prop": "Image", "attributes": {}}, {"id": 348, "prop": "charslot", "attributes": {}}, {"id": 349, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}