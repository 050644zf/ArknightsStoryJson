: 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 137, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 138, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 139, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1016_agoat2_1#2$2", "duration": 1.5}}, {"id": 140, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 141, "prop": "name", "attributes": {"content": "......", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#2$2"}, {"id": 142, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1007_1#1$1"}}, {"id": 143, "prop": "name", "attributes": {"content": "怎麼了，你在想什麼呢？", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 144, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1016_agoat2_1#7$2"}}, {"id": 145, "prop": "name", "attributes": {"content": "呃......不好意思，我......", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#7$2"}, {"id": 146, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1016_agoat2_1#2$2"}}, {"id": 147, "prop": "name", "attributes": {"content": "小黑羊......你是多利先生嗎？", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#2$2"}, {"id": 148, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1007_1#1$1"}}, {"id": 149, "prop": "name", "attributes": {"content": "我是多利，我也不是多利。", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 150, "prop": "name", "attributes": {"content": "我是誰，取決於我在你心中的樣子。", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 151, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1016_agoat2_1#9$2"}}, {"id": 152, "prop": "name", "attributes": {"content": "你和多利先生，有些不一樣。", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#9$2"}, {"id": 153, "prop": "name", "attributes": {"content": "那這些......都是小黑羊嗎？", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#9$2"}, {"id": 154, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1007_1#1$1"}}, {"id": 155, "prop": "name", "attributes": {"content": "不不，不能說“都是”。他們每隻都是獨一無二的，與這世界的聯繫也是獨一無二的。", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 156, "prop": "name", "attributes": {"content": "就像我們稱呼你們，也不會說這些都是“阿黛爾”。", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 157, "prop": "name", "attributes": {"content": "每一個“阿黛爾”，都是獨一無二的。", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 158, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1016_agoat2_1#2$2"}}, {"id": 159, "prop": "name", "attributes": {"content": "好吧。", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#2$2"}, {"id": 160, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1016_agoat2_1#11$2"}}, {"id": 161, "prop": "name", "attributes": {"content": "那你們為什麼要邀請我來這裡呢？", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#11$2"}, {"id": 162, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1007_1#1$1"}}, {"id": 163, "prop": "name", "attributes": {"content": "因為北風。", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 164, "prop": "name", "attributes": {"content": "因為收穫的快樂，我們要分享。能參與這個派對的每個成員都是被選擇過的。", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 165, "prop": "name", "attributes": {"content": "包括你，我的阿黛爾。", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 166, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1016_agoat2_1#3$2"}}, {"id": 167, "prop": "name", "attributes": {"content": "......這幾天經歷的事情，有些太奇妙了。", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#3$2"}, {"id": 168, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1007_1#1$1"}}, {"id": 169, "prop": "name", "attributes": {"content": "奇妙也是生活的一部分。", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 170, "prop": "name", "attributes": {"content": "小傢伙，你現在開心嗎？", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 171, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1016_agoat2_1#9$2"}}, {"id": 172, "prop": "name", "attributes": {"content": "我不知道......", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#9$2"}, {"id": 173, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1007_1#1$1"}}, {"id": 174, "prop": "name", "attributes": {"content": "讓我看看，你應該......", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 175, "prop": "name", "attributes": {"content": "你應該是不太開心的。", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 176, "prop": "name", "attributes": {"content": "你看那邊，她就是證據。", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 177, "prop": "Dialog", "attributes": {}}, {"id": 178, "prop": "charslot", "attributes": {}}, {"id": 179, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1004_1#1$1", "duration": 1.5}}, {"id": 180, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 181, "prop": "name", "attributes": {"content": "小黑羊們在箱子上往下看。"}}, {"id": 182, "prop": "Dialog", "attributes": {}}, {"id": 183, "prop": "charslot", "attributes": {"slot": "m", "action": "jump", "power": 3.0, "times": 1.0, "duration": 0.5, "isblock": "true"}}, {"id": 184, "prop": "charslot", "attributes": {"slot": "m", "action": "jump", "power": 5.0, "times": 1.0, "duration": 0.5, "isblock": "true"}}, {"id": 185, "prop": "name", "attributes": {"content": "一隻小小的、瘦弱的生物，嘗試著躍起——一次、兩次......但是它沒有成功，怎麼跳也跳不到箱子上。"}}, {"id": 186, "prop": "name", "attributes": {"content": "嗯......", "name": "外形小巧的生物"}}, {"id": 187, "prop": "Dialog", "attributes": {}}, {"id": 188, "prop": "charslot", "attributes": {}}, {"id": 189, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1016_agoat2_1#4$2"}}, {"id": 190, "prop": "name", "attributes": {"content": "它落單了嗎？", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#4$2"}, {"id": 191, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1007_1#1$1"}}, {"id": 192, "prop": "name", "attributes": {"content": "她現在看起來很虛弱，虛弱到跳不起來。", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 193, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1016_agoat2_1#2$2"}}, {"id": 194, "prop": "name", "attributes": {"content": "我們能幫幫它嗎......", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#2$2"}, {"id": 195, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1007_1#1$1"}}, {"id": 196, "prop": "name", "attributes": {"content": "現在還不能。", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 197, "prop": "name", "attributes": {"content": "等到火山爆發的時候，她才會有自己的樣子。", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 198, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1016_agoat2_1#2$2"}}, {"id": 199, "prop": "name", "attributes": {"content": "它也是你們的一員嗎？", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#2$2"}, {"id": 200, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1007_1#1$1"}}, {"id": 201, "prop": "name", "attributes": {"content": "是的，所有人最後都會成為我們的一員。", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 202, "prop": "Dialog", "attributes": {}}, {"id": 203, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 204, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 205, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 206, "prop": "charslot", "attributes": {}}, {"id": 207, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 208, "prop": "Background", "attributes": {"image": "41_g9_purewhitevolcano_inside", "screenadapt": "showall"}}, {"id": 209, "prop": "playMusic", "attributes": {"intro": "$path_intro", "key": "$path_loop", "volume": 0.6}}, {"id": 210, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 211, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 212, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_180_amgoat_1#1$1", "duration": 1.5}}, {"id": 213, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4106_bryota_1#1$1", "duration": 1.5}}, {"id": 214, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 215, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4106_bryota_1#1$1", "focus": "r"}}, {"id": 216, "prop": "name", "attributes": {"content": "早，阿黛爾小姐，要吃點什麼早餐嗎？", "name": "埃尼斯"}, "figure_art": "avg_4106_bryota_1#1$1"}, {"id": 217, "prop": "name", "attributes": {"content": "為什麼看起來沒什麼精神的樣子，要不要來一杯咖啡？", "name": "埃尼斯"}, "figure_art": "avg_4106_bryota_1#1$1"}, {"id": 218, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_180_amgoat_1#8$1", "focus": "l"}}, {"id": 219, "prop": "name", "attributes": {"content": "早安......", "name": "阿黛爾"}, "figure_art": "avg_180_amgoat_1#8$1"}, {"id": 220, "prop": "name", "attributes": {"content": "昨天晚上好像做了一個很長又很奇怪的夢，感覺很疲憊......", "name": "阿黛爾"}, "figure_art": "avg_180_amgoat_1#8$1"}, {"id": 221, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4106_bryota_1#1$1", "focus": "r"}}, {"id": 222, "prop": "name", "attributes": {"content": "按我們這裡的說法，白天太充沛的情緒，就會留到晚上夢裡再讓你好好品味。", "name": "埃尼斯"}, "figure_art": "avg_4106_bryota_1#1$1"}, {"id": 223, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_180_amgoat_1#9$1", "focus": "l"}}, {"id": 224, "prop": "name", "attributes": {"content": "夢到的是什麼呢......我記得好像是一個很吵鬧的夢......", "name": "阿黛爾"}, "figure_art": "avg_180_amgoat_1#9$1"}, {"id": 225, "prop": "Dialog", "attributes": {}}, {"id": 226, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_180_amgoat_1#9$1", "focus": "none"}}, {"id": 227, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 228, "prop": "name", "attributes": {"content": "是真的！我真的都看到了！", "name": "激動的小女孩"}}, {"id": 229, "prop": "Dialog", "attributes": {}}, {"id": 230, "prop": "charslot", "attributes": {}}, {"id": 231, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_992_1#1$1", "focus": "l"}}, {"id": 232, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_994_1#5$1", "focus": "l"}}, {"id": 233, "prop": "name", "attributes": {"content": "好好，我相信。", "name": "哈莉"}, "figure_art": "avg_npc_994_1#5$1"}, {"id": 234, "prop": "name", "attributes": {"content": "那你就要因為半夜私自離開房間和偷偷跑去靠近海的地塊這兩件事，兩個月不能吃冰淇淋囉。", "name": "哈莉"}, "figure_art": "avg_npc_994_1#5$1"}, {"id": 235, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_992_1#1$1", "focus": "r"}}, {"id": 236, "prop": "name", "attributes": {"content": "啊......", "name": "想吃冰淇淋的小女孩"}, "figure_art": "avg_npc_992_1#1$1"}, {"id": 237, "prop": "name", "attributes": {"content": "可是，昨晚我真的看到有一隻小毛羊跑到我的房間裡，它帶我去了有很多隻小毛羊的地方......", "name": "不甘心的小女孩"}, "figure_art": "avg_npc_992_1#1$1"}, {"id": 238, "prop": "name", "attributes": {"content": "有許多隻長得像棉花糖一樣的小毛羊，圍在貨櫃上又唱又跳的......", "name": "不甘心的小女孩"}, "figure_art": "avg_npc_992_1#1$1"}, {"id": 239, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_994_1#5$1", "focus": "l"}}, {"id": 240, "prop": "name", "attributes": {"content": "那按你的說法，就是有一群小毛羊邀請你去參加它們的午夜派對囉。", "name": "哈莉"}, "figure_art": "avg_npc_994_1#5$1"}, {"id": 241, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_992_1#1$1", "focus": "r"}}, {"id": 242, "prop": "name", "attributes": {"content": "我覺得應該是這樣的，因為我是好孩子......", "name": "不甘心的小女孩"}, "figure_art": "avg_npc_992_1#1$1"}, {"id": 243, "prop": "Dialog", "attributes": {}}, {"id": 244, "prop": "charslot", "attributes": {}}, {"id": 245, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_180_amgoat_1#5$1", "focus": "m"}}, {"id": 246, "prop": "name", "attributes": {"content": "——！", "name": "阿黛爾"}, "figure_art": "avg_180_amgoat_1#5$1"}, {"id": 247, "prop": "Dialog", "attributes": {}}, {"id": 248, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 249, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 250, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 251, "prop": "charslot", "attributes": {}}, {"id": 252, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 253, "prop": "Background", "attributes": {"image": "41_g5_siestaunbuiltland_d", "screenadapt": "showall"}}, {"id": 254, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 255, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 256, "prop": "name", "attributes": {"content": "一片狼藉。"}}, {"id": 257, "prop": "name", "attributes": {"content": "直到昨天為止，這裡還堆放著由峯馳物流運來的來自各個國家的特產商品。"}}, {"id": 258, "prop": "name", "attributes": {"content": "不出意外的話，它們也該出現在幾天後的商品博覽會上，向這座旅遊城市展示外部大地的樣子。"}}, {"id": 259, "prop": "name", "attributes": {"content": "但是現在，四處都是翻倒的貨架，貨物淩亂地散落一地，上面似乎還有些灰撲撲的腳印。"}}, {"id": 260, "prop": "Dialog", "attributes": {}}, {"id": 261, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0}}, {"id": 262, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_990_1#11$1", "duration": 1.5}}, {"id": 263, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 264, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_990_1#7$1"}}, {"id": 265, "prop": "name", "attributes": {"content": "這是，怎麼搞的......", "name": "拜松"}, "figure_art": "avg_npc_990_1#7$1"}, {"id": 266, "prop": "Dialog", "attributes": {}}, {"id": 267, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 268, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 269, "prop": "charslot", "attributes": {}}, {"id": 270, "prop": "Image", "attributes": {}}, {"id": 271, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}