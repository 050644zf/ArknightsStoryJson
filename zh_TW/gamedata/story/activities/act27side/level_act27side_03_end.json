oat2_1#2$2", "focus": "l"}}, {"id": 56, "prop": "name", "attributes": {"content": "鈴聲？沒有......可能是因為我很多時候，聽不太清......", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#2$2"}, {"id": 57, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1007_1#1$1", "focus": "r"}}, {"id": 58, "prop": "name", "attributes": {"content": "那你也該來加入我們的聚會。", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 59, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_1016_agoat2_1#4$2", "focus": "l"}}, {"id": 60, "prop": "name", "attributes": {"content": "在哪裡的聚會？", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#4$2"}, {"id": 61, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1007_1#1$1", "focus": "r"}}, {"id": 62, "prop": "name", "attributes": {"content": "下課鈴響了之後，世界的盡頭。", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 63, "prop": "name", "attributes": {"content": "但在那之前，我有一些東西要給你看看。", "name": "溫和的生物"}, "figure_art": "avg_npc_1007_1#1$1"}, {"id": 64, "prop": "Dialog", "attributes": {}}, {"id": 65, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 66, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 67, "prop": "charslot", "attributes": {}}, {"id": 68, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 69, "prop": "Background", "attributes": {"image": "41_g8_siestavolcanomuseum_inside", "screenadapt": "showall"}}, {"id": 70, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 71, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 72, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1007_1#1$1", "duration": 1.5, "focus": "m"}}, {"id": 73, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 74, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1007_1#1$1"}}, {"id": 75, "prop": "name", "attributes