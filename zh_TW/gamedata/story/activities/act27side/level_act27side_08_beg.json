ySound", "attributes": {"key": "$d_avg_underwateramb", "channel": "volcano", "loop": "false", "volume": 0.5}}, {"id": 309, "prop": "PlaySound", "attributes": {"key": "$firestorm", "volume": 0.2, "loop": "false", "channel": "fire"}}, {"id": 310, "prop": "playMusic", "attributes": {"intro": "$darkness02_intro", "key": "$darkness02_loop", "volume": 0.6}}, {"id": 311, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 312, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 313, "prop": "name", "attributes": {"content": "運具停在了山腳，熟悉的山脈已換了一副面貌。"}}, {"id": 314, "prop": "name", "attributes": {"content": "山上的植物早已枯萎，嶙峋的山岩更顯得高大。"}}, {"id": 315, "prop": "name", "attributes": {"content": "暮色將沉，在二人的心頭降下陰影。"}}, {"id": 316, "prop": "Dialog", "attributes": {}}, {"id": 317, "prop": "StopSound", "attributes": {"channel": "volcano", "fadetime": 1.0}}, {"id": 318, "prop": "StopSound", "attributes": {"channel": "fire", "fadetime": 1.0}}, {"id": 319, "prop": "Dialog", "attributes": {}}, {"id": 320, "prop": "PlaySound", "attributes": {"key": "$d_avg_runstop"}}, {"id": 321, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_1016_agoat2_1#4$1", "duration": 0.7}}, {"id": 322, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_999_1#1$1", "duration": 0.7}}, {"id": 323, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 324, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_1016_agoat2_1#4$1", "focus": "l"}}, {"id": 325, "prop": "name", "attributes": {"content": "這就是......汐斯塔火山。", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#4$1"}, {"id": 326, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_999_1#1$1", "focus": "r"}}, {"id": 327, "prop": "name", "attributes": {"content": "阿黛爾，小心點......", "name": "凱勒"}, "figure_art": "avg_npc_999_1#1$1"}, {"id": 328, "prop": "name", "attributes": {"content": "運具只能開到這裡，剩下的路只能徒步走了。", "name": "凱勒"}, "figure_art": "avg_npc_999_1#1$1"}, {"id": 329, "prop": "name", "attributes": {"content": "一號觀測站在山腰，離這裡還有一段路。", "name": "凱勒"}, "figure_art": "avg_npc_999_1#1$1"}, {"id": 330, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_1016_agoat2_1#1$1", "focus": "l"}}, {"id": 331, "prop": "name", "attributes": {"content": "我沒事的，我的體力還跟得上。", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#1$1"}, {"id": 332, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_999_1#5$1", "focus": "r"}}, {"id": 333, "prop": "name", "attributes": {"content": "嗯......", "name": "凱勒"}, "figure_art": "avg_npc_999_1#5$1"}, {"id": 334, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_999_1#5$1", "focus": "none"}}, {"id": 335, "prop": "name", "attributes": {"content": "學者低下了頭，心中刺痛著。"}}, {"id": 336, "prop": "name", "attributes": {"content": "......恐懼的人到底是誰呢？"}}, {"id": 337, "prop": "name", "attributes": {"content": "火山就在眼前，自己卻一步也無法上前。"}}, {"id": 338, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_1016_agoat2_1#2$1", "focus": "l"}}, {"id": 339, "prop": "name", "attributes": {"content": "凱勒老師，您還好嗎？", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#2$1"}, {"id": 340, "prop": "name", "attributes": {"content": "......要不要拉住我的手？", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#2$1"}, {"id": 341, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_999_1#5$1", "focus": "r"}}, {"id": 342, "prop": "name", "attributes": {"content": "......", "name": "凱勒"}, "figure_art": "avg_npc_999_1#5$1"}, {"id": 343, "prop": "Dialog", "attributes": {}}, {"id": 344, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 345, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 346, "prop": "charslot", "attributes": {}}, {"id": 347, "prop": "Background", "attributes": {"image": "41_g11_volcanomountainside", "screenadapt": "coverall", "block": "true"}}, {"id": 348, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 349, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 350, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 351, "prop": "name", "attributes": {"content": "暗紅色的溪流在山岩上蔓延爬行，如同血管。龐然巨物正在粗重地喘息。"}}, {"id": 352, "prop": "name", "attributes": {"content": "從地心到這座山崖，它們流過了漫長的歲月，熾熱、沉默。"}}, {"id": 353, "prop": "name", "attributes": {"content": "這段路似乎沒有阿黛爾想像的那麼遠，憑她現在的體力，還是能獨自爬到這山腰上。"}}, {"id": 354, "prop": "name", "attributes": {"content": "這段路又似乎比想像的要長很多，夠記憶在心底沖洗過無數回。"}}, {"id": 355, "prop": "Dialog", "attributes": {}}, {"id": 356, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_1016_agoat2_1#11$1", "focus": "r"}}, {"id": 357, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_999_1#1$1", "focus": "r"}}, {"id": 358, "prop": "name", "attributes": {"content": "設置的觀測站就在這裡了。", "name": "凱勒"}, "figure_art": "avg_npc_999_1#1$1"}, {"id": 359, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_999_1#10$1", "focus": "r"}}, {"id": 360, "prop": "name", "attributes": {"content": "這些儀器......有人來過這裡？", "name": "凱勒"}, "figure_art": "avg_npc_999_1#10$1"}, {"id": 361, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_1016_agoat2_1#11$1", "focus": "l"}}, {"id": 362, "prop": "name", "attributes": {"content": "可是山上沒有別人的腳印......", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#11$1"}, {"id": 363, "prop": "Dialog", "attributes": {}}, {"id": 364, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_1016_agoat2_1#11$1", "focus": "all"}}, {"id": 365, "prop": "Delay", "attributes": {"time": 0.2}}, {"id": 366, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovement", "volume": 0.7}}, {"id": 367, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_999_1#10$1", "afrom": 1.0, "ato": 0.0, "duration": 1.0}}, {"id": 368, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 369, "prop": "charslot", "attributes": {"duration": 0.3}}, {"id": 370, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 371, "prop": "PlaySound", "attributes": {"key": "$d_avg_flapradio", "volume": 0.6}}, {"id": 372, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 373, "prop": "playsound", "attributes": {"key": "$d_avg_labamb", "loop": "false", "channel": "aa", "volume": 0.8}}, {"id": 374, "prop": "stopSound", "attributes": {"channel": "aa", "fadetime": 3.0}}, {"id": 375, "prop": "PlaySound", "attributes": {"key": "$d_avg_scan", "volume": 1.0, "delay": 0.3}}, {"id": 376, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 377, "prop": "name", "attributes": {"content": "源石能量反應沒有變，但測溫裝置的確記錄到了高溫反應......", "name": "凱勒"}}, {"id": 378, "prop": "Dialog", "attributes": {}}, {"id": 379, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 380, "prop": "name", "attributes": {"content": "環顧四周，也只能看到陰影中漆黑的山岩與熔化的石頭。"}}, {"id": 381, "prop": "Dialog", "attributes": {}}, {"id": 382, "prop": "playsound", "attributes": {"key": "$d_avg_clothmovementsp"}}, {"id": 383, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 8.0, "ystrength": 10.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 384, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_999_1#10$1", "posfrom": "0,-20", "posto": "0,0", "afrom": 0.0, "ato": 1.0, "duration": 1.0}}, {"id": 385, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 386, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_999_1#10$1", "focus": "m"}}, {"id": 387, "prop": "name", "attributes": {"content": "奇怪......", "name": "凱勒"}, "figure_art": "avg_npc_999_1#10$1"}, {"id": 388, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_999_1#1$1", "focus": "m"}}, {"id": 389, "prop": "name", "attributes": {"content": "應該是沒什麼狀況了，重新調試好設備後我們就回去吧。", "name": "凱勒"}, "figure_art": "avg_npc_999_1#1$1"}, {"id": 390, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 391, "prop": "Dialog", "attributes": {}}, {"id": 392, "prop": "charslot", "attributes": {}}, {"id": 393, "prop": "PlaySound", "attributes": {"key": "$d_avg_footstep_stonestep", "volume": 0.6, "channel": "step1", "loop": "false"}}, {"id": 394, "prop": "stopsound", "attributes": {"channel": "step1", "fadetime": 2.0}}, {"id": 395, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_996_1#12$1", "duration": 1.0}}, {"id": 396, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 397, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_999_1#4$1", "focus": "m"}}, {"id": 398, "prop": "name", "attributes": {"content": "卡恩，你為什麼會來這裡？", "name": "凱勒"}, "figure_art": "avg_npc_999_1#4$1"}, {"id": 399, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_996_1#12$1", "focus": "m"}}, {"id": 400, "prop": "name", "attributes": {"content": "（氣喘吁吁）", "name": "卡恩"}, "figure_art": "avg_npc_996_1#12$1"}, {"id": 401, "prop": "name", "attributes": {"content": "聽說......你們......上火山了......", "name": "卡恩"}, "figure_art": "avg_npc_996_1#12$1"}, {"id": 402, "prop": "name", "attributes": {"content": "為什麼......", "name": "卡恩"}, "figure_art": "avg_npc_996_1#12$1"}, {"id": 403, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_999_1#1$1", "focus": "m"}}, {"id": 404, "prop": "name", "attributes": {"content": "監測站的數據出現了一些波動，阿黛爾很不放心，所以來檢查一下。", "name": "凱勒"}, "figure_art": "avg_npc_999_1#1$1"}, {"id": 405, "prop": "name", "attributes": {"content": "應該是意外導致的，我們正準備撤去安全的觀測點。", "name": "凱勒"}, "figure_art": "avg_npc_999_1#1$1"}, {"id": 406, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_996_1#12$1", "focus": "m"}}, {"id": 407, "prop": "name", "attributes": {"content": "......", "name": "卡恩"}, "figure_art": "avg_npc_996_1#12$1"}, {"id": 408, "prop": "Dialog", "attributes": {}}, {"id": 409, "prop": "charslot", "attributes": {}}, {"id": 410, "prop": "playsound", "attributes": {"key": "$smallearthquake", "volume": 0.6}}, {"id": 411, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 412, "prop": "CameraShake", "attributes": {"duration": 2.5, "xstrength": 40.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 413, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 414, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1016_agoat2_1#9$1", "focus": "m"}}, {"id": 415, "prop": "name", "attributes": {"content": "這座火山的確開始活躍起來了，爆發的時間可能還要提前一些......", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#9$1"}, {"id": 416, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_999_1#1$1", "focus": "m"}}, {"id": 417, "prop": "name", "attributes": {"content": "嗯，我們先回去。", "name": "凱勒"}, "figure_art": "avg_npc_999_1#1$1"}, {"id": 418, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_996_1#12$1", "focus": "m"}}, {"id": 419, "prop": "name", "attributes": {"content": "凱勒，站住......", "name": "卡恩"}, "figure_art": "avg_npc_996_1#12$1"}, {"id": 420, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1016_agoat2_1#11$1", "focus": "m"}}, {"id": 421, "prop": "name", "attributes": {"content": "卡恩前輩？", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#11$1"}, {"id": 422, "prop": "Dialog", "attributes": {}}, {"id": 423, "prop": "charslot", "attributes": {}}, {"id": 424, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 425, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovement", "volume": 0.5}}, {"id": 426, "prop": "PlaySound", "attributes": {"key": "$d_avg_paper2", "volume": 1.0, "delay": 0.8}}, {"id": 427, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 428, "prop": "name", "attributes": {"content": "氣喘吁吁的男人身體顫抖著，從懷中掏出一個資料袋。而在看到資料袋封面的瞬間，凱勒立即變了臉色。"}}, {"id": 429, "prop": "playMusic", "attributes": {"intro": "$drift_intro", "key": "$drift_loop", "volume": 0.6}}, {"id": 430, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_996_1#12$1", "focus": "m"}}, {"id": 431, "prop": "name", "attributes": {"content": "1095年9月，烏納火山，你為什麼突然離開了考察隊伍......", "name": "卡恩"}, "figure_art": "avg_npc_996_1#12$1"}, {"id": 432, "prop": "name", "attributes": {"content": "同年十一月，你沒有出席瑙曼夫婦的葬禮，卻有人在威廉大學與軍方的座談會上見過你。", "name": "卡恩"}, "figure_art": "avg_npc_996_1#12$1"}, {"id": 433, "prop": "name", "attributes": {"content": "還有，卡提亞·瑙曼關於源石與天災的研究資料，連阿黛爾都沒有見過，為什麼會出現在你與萊塔尼亞軍方的書信裡！", "name": "卡恩"}, "figure_art": "avg_npc_996_1#12$1"}, {"id": 434, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_996_1#8$1", "focus": "m"}}, {"id": 435, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 436, "prop": "name", "attributes": {"content": "凱勒......回答我的問題！", "name": "卡恩"}, "figure_art": "avg_npc_996_1#8$1"}, {"id": 437, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1016_agoat2_1#4$1", "focus": "m"}}, {"id": 438, "prop": "name", "attributes": {"content": "凱勒老師......", "name": "阿黛爾"}, "figure_art": "avg_1016_agoat2_1#4$1"}, {"id": 439, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_999_1#4$1", "focus": "m"}}, {"id": 440, "prop": "name", "attributes": {"content": "......", "name": "凱勒"}, "figure_art": "avg_npc_999_1#4$1"}, {"id": 441, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_999_1#5$1", "focus": "m"}}, {"id": 442, "prop": "name", "attributes": {"content": "阿黛爾，我說過，等這次觀測之後，我會對你坦白一切......", "name": "凱勒"}, "figure_art": "avg_npc_999_1#5$1"}, {"id": 443, "prop": "name", "attributes": {"content": "卡恩，這裡很危險，我們還是——", "name": "凱勒"}, "figure_art": "avg_npc_999_1#5$1"}, {"id": 444, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_996_1#12$1", "focus": "m"}}, {"id": 445, "prop": "name", "attributes": {"content": "凱勒......我們現在就站在這裡，站在瑙曼博士他們也來過的火山上。", "name": "卡恩"}, "figure_art": "avg_npc_996_1#12$1"}, {"id": 446, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_996_1#8$1", "focus": "m"}}, {"id": 447, "prop": "CameraShake", "att