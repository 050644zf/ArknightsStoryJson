_139#2"}, {"id": 308, "prop": "Dialog", "attributes": {}}, {"id": 309, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 310, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 311, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 312, "prop": "charslot", "attributes": {}}, {"id": 313, "prop": "Background", "attributes": {"image": "bg_canteen", "screenadapt": "showall"}}, {"id": 314, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 315, "prop": "playMusic", "attributes": {"intro": "$path_intro", "key": "$path_loop", "volume": 0.6}}, {"id": 316, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 317, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 318, "prop": "charslot", "attributes": {"slot": "m", "name": "char_002_amiya_1#2", "focus": "m"}}, {"id": 319, "prop": "name", "attributes": {"content": "小刻又跑到廚房來了嗎？", "name": "阿米婭"}, "figure_art": "char_002_amiya_1#2"}, {"id": 320, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_199_yak_1#1$1", "focus": "m"}}, {"id": 321, "prop": "name", "attributes": {"content": "是啊。", "name": "角峰"}, "figure_art": "avg_199_yak_1#1$1"}, {"id": 322, "prop": "name", "attributes": {"content": "不過，這次她的樣子好像有點奇怪。", "name": "角峰"}, "figure_art": "avg_199_yak_1#1$1"}, {"id": 323, "prop": "charslot", "attributes": {"slot": "m", "name": "char_002_amiya_1#6", "focus": "m"}}, {"id": 324, "prop": "name", "attributes": {"content": "奇怪？", "name": "阿米婭"}, "figure_art": "char_002_amiya_1#6"}, {"id": 325, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_199_yak_1#5$1", "focus": "m"}}, {"id": 326, "prop": "name", "attributes": {"content": "嗯——這次她回來之後變得有點沉默。", "name": "角峰"}, "figure_art": "avg_199_yak_1#5$1"}, {"id": 327, "prop": "charslot", "attributes": {"slot": "m", "name": "char_002_amiya_1#3", "focus": "m"}}, {"