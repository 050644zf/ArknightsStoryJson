og", "attributes": {}}, {"id": 409, "prop": "charslot", "attributes": {}}, {"id": 410, "prop": "PlayMusic", "attributes": {"intro": "$warchaos_intro", "key": "$warchaos_loop", "volume": 0.6}}, {"id": 411, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1424_1#1$1", "duration": 1.5}}, {"id": 412, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 413, "prop": "name", "attributes": {"content": "肚子……", "name": "刻俄柏？"}, "figure_art": "avg_npc_1424_1#1$1"}, {"id": 414, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_199_yak_1#4$1", "focus": "m"}}, {"id": 415, "prop": "name", "attributes": {"content": "這……這到底是怎麼回事？這是我們認識的小刻嗎？", "name": "角峰"}, "figure_art": "avg_199_yak_1#4$1"}, {"id": 416, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1424_1#1$1", "focus": "m"}}, {"id": 417, "prop": "name", "attributes": {"content": "嗯……", "name": "刻俄柏？"}, "figure_art": "avg_npc_1424_1#1$1"}, {"id": 418, "prop": "charslot", "attributes": {"slot": "m", "name": "char_002_amiya_1#4", "focus": "m"}}, {"id": 419, "prop": "name", "attributes": {"content": "我能從她的情緒感覺到，她依然是我們認識的小刻。", "name": "阿米婭"}, "figure_art": "char_002_amiya_1#4"}, {"id": 420, "prop": "name", "attributes": {"content": "她在克制，但是，她快要忍不住了……！", "name": "阿米婭"}, "figure_art": "char_002_amiya_1#4"}, {"id": 421, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4143_sensi_1#5$1", "focus": "m"}}, {"id": 422, "prop": "name", "attributes": {"content": "這……這是我們認識的小刻嗎？", "name": "先西"}, "figure_art": "avg_4143_sensi_1#5$1"}, {"id": 423, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1424_1#1$1", "focus": "m"}}, {"id": 424, "prop": "name", "attributes": {"content": "（嘶吼）", "name": "刻俄柏？"}, "figure_art": "avg_npc_1424_1#1$1"}, {"id": 425, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#20$1", "focus": "m"}}, {"id": 426, "prop": "name", "attributes": {"content": "……好帥！小刻，你原來還有這種本領！", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#20$1"},