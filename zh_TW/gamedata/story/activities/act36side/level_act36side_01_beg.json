ributes": {"slot": "m", "name": "avg_4143_sensi_1#3$1", "focus": "m"}}, {"id": 348, "prop": "name", "attributes": {"content": "這種未知的生物，千萬不要直接碰觸。", "name": "先西"}, "figure_art": "avg_4143_sensi_1#3$1"}, {"id": 349, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4143_sensi_1#1$1", "focus": "m"}}, {"id": 350, "prop": "name", "attributes": {"content": "這種伏地生活的動物，多半靠食用腐殖質維生，一般都會攜帶很多病菌和寄生蟲，直接上手觸摸的話說不定會被感染。", "name": "先西"}, "figure_art": "avg_4143_sensi_1#1$1"}, {"id": 351, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#1$1", "focus": "m"}}, {"id": 352, "prop": "name", "attributes": {"content": "的確……", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#1$1"}, {"id": 353, "prop": "Dialog", "attributes": {}}, {"id": 354, "prop": "charslot", "attributes": {"slot": "m", "action": "shake", "random": "true", "power": 5.0, "times": 10.0, "duration": 0.3, "isblock": "true"}}, {"id": 355, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#8$1", "focus": "m"}}, {"id": 356, "prop": "name", "attributes": {"content": "（嗯？……劍助？我們不是都已經發現這些蟲子了嗎？難道還有什麼危險……）", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#8$1"}, {"id": 357, "prop": "Dialog", "attributes": {}}, {"id": 358, "prop": "charslot", "attributes": {}}, {"id": 359, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 360, "prop": "PlaySound", "attributes": {"key": "$smallearthquake", "volume": 0.5}}, {"id": 361, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1430_1#1$1", "duration": 1.0}}, {"id": 362, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1430_1#1$1", "duration": 1.0}}, {"id": 363, "prop": "CameraShake", "attributes": {"duration": 4.5, "xstrength": 10.0, "ystrength": 10.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "true"}}, {"id": 364, "prop": "charslot", "attributes": {}}, {"id": 365, "prop": "PlayMusic", "attributes": {"intro": "$nervous_intro", "key": "$nervous_loop", "volume": 0.6}}, {"id": 36