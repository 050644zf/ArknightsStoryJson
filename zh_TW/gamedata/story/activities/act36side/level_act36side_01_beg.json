ure_art": "avg_4143_sensi_1#4$1"}, {"id": 386, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#8$1", "focus": "m"}}, {"id": 387, "prop": "name", "attributes": {"content": "居然、居然還會噴出腐蝕性液體！", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#8$1"}, {"id": 388, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#12$1", "focus": "m"}}, {"id": 389, "prop": "name", "attributes": {"content": "為什麼這時候還能在意這種事情啊！！", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#12$1"}, {"id": 390, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4144_chilc_1#15$1", "focus": "m"}}, {"id": 391, "prop": "name", "attributes": {"content": "我好像對牠們造成不了什麼傷害，交給你們了！", "name": "奇爾查克"}, "figure_art": "avg_4144_chilc_1#15$1"}, {"id": 392, "prop": "Dialog", "attributes": {}}, {"id": 393, "prop": "PlaySound", "attributes": {"key": "$runsand", "volume": 1.0}}, {"id": 394, "prop": "charslot", "attributes": {"duration": 1.5}}, {"id": 395, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 396, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#4$1", "focus": "m"}}, {"id": 397, "prop": "name", "attributes": {"content": "快過來！我們先進這個小木屋躲一躲！", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#4$1"}, {"id": 398, "prop": "Dialog", "attributes": {}}, {"id": 399, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 400, "prop": "PlaySound", "attributes": {"key": "$dooropenquite", "volume": 1.0}}, {"id": 401, "prop": "charslot", "attributes": {"slot": "l", "afrom": 0.0, "ato": 1.0, "duration": 0.5}}, {"id": 402, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_010", "posfrom": "-100,0", "posto": "-50,0", "duration": 1.5}}, {"id": 403, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 404, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#7$1", "focus": "m"}}, {"id": 405, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,0", "posto": "200,0", "duration": 1.5}}, {"id": 406, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 407, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#7$1", "focus": "m"}}, {"id": 408, "prop": "name", "attributes": {"content": "……呃……？", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#7$1"}, {"id": 409, "prop": "Dialog", "attributes": {}}, {"id": 410, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_010", "focus": "l"}}, {"id": 411, "prop": "name", "attributes": {"content": "……", "name": "？？？"}, "figure_art": "avg_npc_010"}, {"id": 412, "prop": "Dialog", "attributes": {}}, {"id": 413, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 414, "prop": "PlaySound", "attributes": {"key": "$e_atk_saw_n_1", "volume": 0.7, "channel": "3"}}, {"id": 415, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 416, "prop": "PlaySound", "attributes": {"key": "$e_atk_saw_n_1", "volume": 0.7, "channel": "4"}}, {"id": 417, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 418, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#2$1", "focus": "m"}}, {"id": 419, "prop": "playMusic", "attributes": {"intro": "$dontmaketrouble_intro", "key": "$dontmaketrouble_loop", "volume": 0.6}}, {"id": 420, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 10.0, "ystrength": 10.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 421, "prop": "name", "attributes": {"content": "啊啊啊啊啊啊啊啊啊這是什麼啊啊啊！！", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#2$1"}, {"id": 422, "prop": "Dialog", "attributes": {}}, {"id": 423, "prop": "PlaySound", "attributes": {"key": "$runsand", "volume": 1.0}}, {"id": 424, "prop": "charslot", "attributes": {"slot": "m", "afrom": 1.0, "ato": 0.0, "duration": 0.5}}, {"id": 425, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "200,0", "posto": "300,0", "duration": 1.5}}, {"id": 426, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 427, "prop": "charslot", "attributes": {}}, {"id": 428, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4144_chilc_1#7$1", "focus": "m"}}, {"id": 429, "prop": "name", "attributes": {"content": "先西，你認識這個穿著全身鎧甲的獸人嗎？", "name": "奇爾查克"}, "figure_art": "avg_4144_chilc_1#7$1"}, {"id": 430, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4143_sensi_1#4$1", "focus": "m"}}, {"id": 431, "prop": "name", "attributes": {"content": "嗯……老夫認識的獸人穿著都比較單薄，沒看過這樣的。他應該是木屋的主人，不然老夫問一問？", "name": "先西"}, "figure_art": "avg_4143_sensi_1#4$1"}, {"id": 432, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#2$1", "focus": "m"}}, {"id": 433, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 10.0, "ystrength": 10.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 434, "prop": "name", "attributes": {"content": "還問什麼？快、快跑啊！！", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#2$1"}, {"id": 435, "prop": "Dialog", "attributes": {}}, {"id": 436, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 437, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 438, "prop": "CameraShake", "attributes": {"duration": 2.0, "xstrength": 10.0, "ystrength": 10.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 439, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0, "channel": "1"}}, {"id": 440, "prop": "charslot", "attributes": {}}, {"id": 441, "prop": "Image", "attributes": {"image": "54_i1", "screenadapt": "coverall", "xScale": 1.1, "yScale": 1.1, "fadetime": 0.0}}, {"id": 442, "prop": "ImageTween", "attributes": {"xFrom": 30.0, "xTo": 0.0, "duration": 30.0, "xScaleFrom": 1.1, "yScaleFrom": 1.1, "xScaleTo": 1.0, "yScaleTo": 1.0, "block": "false"}}, {"id": 443, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 444, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 445, "prop": "name", "attributes": {"content": "先西，快把我放下來啦！", "name": "奇爾查克"}}, {"id": 446, "prop": "name", "attributes": {"content": "他、他還在追我們嗎？！！", "name": "瑪露希爾"}}, {"id": 447, "prop": "name", "attributes": {"content": "那是什麼生物啊，是某種獸人嗎？", "name": "萊歐斯"}}, {"id": 448, "prop": "name", "attributes": {"content": "真的不用老夫去問問嗎？", "name": "先西"}}, {"id": 449, "prop": "name", "attributes": {"content": "你們還在好奇什麼啊！他明顯是要拿著那把奇怪的大刀殺我們！一定是我們惹怒了他！", "name": "瑪露希爾"}}, {"id": 450, "prop": "name", "attributes": {"content": "我猜，惹怒他的是你的爆炸魔法吧！要不然你去跟他道個歉試試看？", "name": "奇爾查克"}}, {"id": 451, "prop": "name", "attributes": {"content": "我才不會向獸人道歉！而且不用魔法，怎麼趕走石頭蟲啊！", "name": "瑪露希爾"}}, {"id": 452, "prop": "name", "attributes": {"content": "這裡果然是沒來過的區域！好多新奇的東西！", "name": "萊歐斯"}}, {"id": 453, "prop": "name", "attributes": {"content": "還有先西，我自己會跑，你放我下來！欸欸欸——", "name": "奇爾查克"}}, {"id": 454, "prop": "name", "attributes": {"content": "我沒在任何書上看過，看起來蠻酷的……", "name": "萊歐斯"}}, {"id": 455, "prop": "name", "attributes": {"content": "萊歐斯！！", "name": "奇爾查克"}}, {"id": 456, "prop": "Dialog", "attributes": {}}, {"id": 457, "prop": "PlaySound", "attributes": {"key": "$e_atk_saw_n_2", "volume": 0.7, "channel": "1"}}, {"id": 458, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 459, "prop": "PlaySound", "attributes": {"key": "$e_atk_saw_n_2", "volume": 0.7, "channel": "2"}}, {"id": 460, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 461, "prop": "PlaySound", "attributes": {"key": "$e_atk_saw_n_2", "volume": 0.7, "channel": "3"}}, {"id": 462, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 463, "prop": "PlaySound", "attributes": {"key": "$e_atk_saw_n_2", "volume": 0.7, "channel": "4"}}, {"id": 464, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 465, "prop": "CameraShake", "attributes": {"duration": 1.5, "xstrength": 10.0, "ystrength": 10.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 466, "prop": "name", "attributes": {"content":