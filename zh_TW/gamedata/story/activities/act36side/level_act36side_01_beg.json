41_marcil_1#7$1", "focus": "m"}}, {"id": 80, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 10.0, "ystrength": 10.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 81, "prop": "name", "attributes": {"content": "你總算醒了，萊歐斯！", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#7$1"}, {"id": 82, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#9$1", "focus": "m"}}, {"id": 83, "prop": "name", "attributes": {"content": "你精神怎麼樣，有覺得頭暈嗎？", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#9$1"}, {"id": 84, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#13$1", "focus": "m"}}, {"id": 85, "prop": "name", "attributes": {"content": "頭倒是不太暈……但突然感覺有點餓了。", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#13$1"}, {"id": 86, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#1$1", "focus": "m"}}, {"id": 87, "prop": "name", "attributes": {"content": "這裡是……？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#1$1"}, {"id": 88, "prop": "Dialog", "attributes": {}}, {"id": 89, "prop": "charslot", "attributes": {}}, {"id": 90, "prop": "PlaySound", "attributes": {"key": "$d_avg_amb_forestnight_loop", "volume": 0.5, "channel": "1", "loop": "true", "fadetime": 1.5}}, {"id": 91, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 92, "prop": "Background", "attributes": {"image": "38_g20_skyblue_R2", "screenadapt": "showall", "fadetime": 2.5}}, {"id": 93, "prop": "Delay", "attributes": {"time": 6.0}}, {"id": 94, "prop": "Background", "attributes": {"image": "bg_forest", "screenadapt": "showall", "fadetime": 2.5}}, {"id": 95, "prop": "Delay", "attributes": {"time": 3.0}}, {"id": 96, "prop": "stopsound", "attributes": {"channel": "1", "fadetime": 1.5}}, {"id": 97, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#1$1", "duration": 1.5}}, {"id": 98, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 99, "prop": "name", "attributes": {"content": "天空、太陽、樹林……還有……", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#1$1"}, {"id": 100, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#11$1", "focus": "m"}}, {"id": 101, "prop": "name", "attributes": {"content": "這裡看起來很像是迷宮的外面，但不論是我、先西還是奇爾查克，都覺得這裡不是任何我們見過的地方。", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#11$1"}, {"id": 102, "prop": "Dialog", "attributes": {}}, {"id": 103, "prop": "PlaySound", "attributes": {"key": "$d_avg_magic_1", "volume": 1.0}}, {"id": 104, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 105, "prop": "Blocker", "attributes": {"a": 1.0, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 0.2, "block": "true"}}, {"id": 106, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.2, "block": "true"}}, {"id": 107, "prop": "PlaySound", "attributes": {"key": "$d_avg_magic_1", "volume": 1.0}}, {"id": 108, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 109, "prop": "Blocker", "attributes": {"a": 1.0, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 0.2, "block": "true"}}, {"id": 110, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 111, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#9$1", "focus": "m"}}, {"id": 112, "prop": "name", "attributes": {"content": "而且你看，還是沒有反應……我都試好幾次了，微小精靈一點都不回應我。", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#9$1"}, {"id": 113, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#1$1", "focus": "m"}}, {"id": 114, "prop": "multiline", "attributes": {"name": "萊歐斯", "content": "真是少見……"}}, {"id": 115, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#16$1", "focus": "m"}}, {"id": 116, "prop": "multiline", "attributes": {"name": "萊歐斯", "end": "true", "content": "先西？你在幹嘛？", "joined": "真是少見……先西？你在幹嘛？"}}, {"id": 117, "prop": "Dialog", "attributes": {}}, {"id": 118, "prop": "charslot", "attributes": {}}, {"id": 119, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovement", "volume": 1.0}}, {"id": 120, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4143_sensi_1#1$1", "afrom": 0.0, "ato": 1.0, "duration": 0.5}}, {"id": 121, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,-20", "posto": "0,0", "duration": 2.0}}, {"id": 122, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 123, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4143_sensi_1#1$1", "focus": "m"}}, {"id": 124, "prop": "name", "attributes": {"content": "老夫在調查這裡的土質。", "name": "先西"}, "figure_art": "avg_4143_sensi_1#1$1"}, {"id": 125, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4143_sensi_1#3$1", "focus": "m"}}, {"id": 126, "prop": "name", "attributes": {"content": "你們看，這裡的土壤濕潤、色深，在掌心揉搓變熱之後有臭味，說明裡面含有大量腐殖質……", "name": "先西"}, "figure_art": "avg_4143_sensi_1#3$1"}, {"id": 127, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#5$1", "focus": "m"}}, {"id": 128, "prop": "name", "attributes": {"content": "也就是說？", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#5$1"}, {"id": 129, "prop": "Dialog", "attributes": {}}, {"id": 130, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4143_sensi_1#2$1", "focus": "m"}}, {"id": 131, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 132, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4143_sensi_1#3$1", "focus": "m"}}, {"id": 133, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 134, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4143_sensi_1#3$1", "focus": "m"}}, {"id": 135, "prop": "name", "attributes": {"content": "也就是說，非常適合種植！和魔像背上的土質非常相像！", "name": "先西"}, "figure_art": "avg_4143_sensi_1#3$1"}, {"id": 136, "prop": "Dialog", "attributes": {}}, {"id": 137, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#22$1", "focus": "m"}}, {"id": 138, "prop": "name", "attributes": {"content": "沒問你這個！", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#22$1"}, {"id": 139, "prop": "Dialog", "attributes": {}}, {"id": 140, "prop": "charslot", "attributes": {}}, {"id": 141, "prop": "PlaySound", "attributes": {"key": "$d_avg_wing", "channel": "3"}}, {"id": 142, "prop": "Delay", "attributes": {"time": 0.2}}, {"id": 143, "prop": "PlaySound", "attributes": {"key": "$leaveshake", "channel": "1"}}, {"id": 144, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown1", "channel": "2"}}, {"id": 145, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 10.0, "ystrength": 10.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 146, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 147, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovement", "volume": 1.0}}, {"id": 148, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4144_chilc_1#15$1", "posfrom": "0,-20", "posto": "0,0", "afrom": 0.0, "ato": 1.0, "isblock": "true", "duration": 1.5}}, {"id": 149, "prop": "name", "attributes": {"content": "瑪露希爾！你把鳥都嚇到了，我差點被牠撞下來。", "name": "奇爾查克"}, "figure_art": "avg_4144_chilc_1#15$1"}, {"id": 150, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4144_chilc_1#12$1", "focus": "m"}}, {"id": 151, "prop": "name", "attributes": {"content": "我這有一個好消息和一個壞消息。首先，我們在周圍查看了一圈，都沒有看到什麼魔物，這附近應該非常安全。", "name": "奇爾查克"}, "figure_art": "avg_4144_chilc_1#12$1"}, {"id": 152, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#8$1", "focus": "m"}}, {"id": 153, "prop": "name", "attributes": {"content": "好消息是什麼？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#8$1"}, {"id": 154, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#13$1", "focus": "m"}}, {"id": 155, "prop": "name", "attributes": {"content": "沒有魔物不就是好消息嗎！", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#13$1"}, {"id": 156, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#1$1", "focus": "m"}}, {"id": 157, "prop": "name", "attributes": {"content": "壞消息呢？", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#1$1"}, {"id": 158, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4144_chilc_1#3$1", "focus": "m"}}, {"id": 159, "prop": "name", "attributes": {"content": "壞消息是，這個空間非常寬廣，而且周圍的環境和我知道的完全不一樣。", "name": "奇爾查克"}, "figure_art": "avg_4144_chilc_1#3$1"}, {"id": 160, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4144_chilc_1#10$1", "focus": "m"}}, {"id": 161, "prop": "name", "attributes": {"content": "我從上面看到，這裡甚至只是森林的邊緣。", "name": "奇爾查克"}, "figure_art": "avg_4144_chilc_1#10$1"}, {"id": 162, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4143_sensi_1#1$1", "focus": "m"}}, {"id": 163, "prop": "name", "attributes": {"content": "從一層到五層，老夫從來沒見過，也從來沒聽說過有人發現過這樣的地方。", "name": "先西"}, "figure_art": "avg_4143_sensi_1#1$1"}, {"id": 164, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#9$1", "focus": "m"}}, {"id": 165, "prop": "name", "attributes": {"content": "……也就是說……", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#9$1"}, {"id": 166, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#7$1", "focus": "m"}}, {"id": 167, "prop": "name", "attributes": {"content": "也就是說……？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#7$1"}, {"id": 168, "prop": "Dialog", "attributes": {}}, {"id": 169, "prop": "charslot", "attributes": {}}, {"id": 170, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4144_chilc_1#7$1", "focus": "all"}}, {"id": 171, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4141_marcil_1#2$1", "focus": "all"}}, {"id": 172, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 173, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4143_sensi_1#3$1", "focus": "all"}}, {"id": 174, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4142_laios_1#6$1", "focus": "all"}}, {"id": 175, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 176, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 10.0, "ystrength": 10.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 177, "prop": "name", "attributes": {"content": "我們可能是誤打誤撞來到了迷宮不為人知的新區域？！！", "name": "萊歐斯小隊"}}, {"id": 178, "prop": "charslot", "attributes": {}}, {"id": 179, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4143_sensi_1#1$1", "focus": "m"}}, {"id": 180, "prop": "name", "attributes": {"content": "天上飛過去的鳥都是從來沒看過的品種，很奇怪，與其說是另一個區域，這裡甚至更像是另一個空間。", "name": "先西"}, "figure_art": "avg_4143_sensi_1#1$1"}, {"id": 181, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#9$1", "focus": "m"}}, {"id": 182, "prop": "name", "attributes": {"content": "這裡有沒有可能就像是……活畫裡那樣？我們被帶到了一個像畫中世界一樣的新地方？", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#9$1"}, {"id": 183, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#9$1", "focus": "m"}}, {"id": 184, "prop": "name", "attributes": {"content": "也就是說，我們會遇到未知的魔物？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#9$1"}, {"id": 185, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#10$1", "focus": "m"}}, {"id": 186, "prop": "name", "attributes": {"content": "說不定還能試試牠們的味道？！", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#10$1"}, {"id": 187, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#4$1", "focus": "m"}}, {"id": 188, "prop": "name", "attributes": {"content": "你在說什麼鬼話！", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#4$1"}, {"id": 189, "prop": "name", "attributes": {"content": "我們的目的是趕快去救法琳，現在可不是能在未知區域浪費時間的時候！", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#4$1"}, {"id": 190, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#11$1", "focus": "m"}}, {"id": 191, "prop": "name", "attributes": {"content": "而且有一件事很重要，我剛剛嘗試了很多次，但在這裡我只能使用一些簡單的魔法。", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#11$1"}, {"id": 192, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#16$1", "focus": "m"}}, {"id": 193, "prop": "name", "attributes": {"content": "……這的確是一個很嚴肅的問題……", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#16$1"}, {"id": 194, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4143_sensi_1#3$1", "focus": "m"}}, {"id": 195, "prop": "name", "attributes": {"content": "而且……", "name": "先西"}, "figure_art": "avg_4143_sensi_1#3$1"}, {"id": 196, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#8$1", "focus": "m"}}, {"id": 197, "prop": "name", "attributes": {"content": "而且？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#8$1"}, {"id": 198, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4143_sensi_1#3$1", "focus": "m"}}, {"id": 199, "prop": "name", "attributes": {"content": "而且這片森林和土地很奇怪，很像是為了讓植被在這裡生長，專門有人開墾出來的一片區域，老夫很清楚這樣的手段。", "name": "先西"}, "figure_art": "avg_4143_sensi_1#3$1"}, {"id": 200, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#22$1", "focus": "m"}}, {"id": 201, "prop": "name", "attributes": {"content": "你根本沒有在意我的魔法變弱了這件事吧！！", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#22$1"}, {"id": 202, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4144_chilc_1#1$1", "focus": "m"}}, {"id": 203, "prop": "name", "attributes": {"content": "這樣說的話，我剛才其實還發現森林外面有座有點奇怪的木屋，裡面可能會有人。", "name": "奇爾查克"}, "figure_art": "avg_4144_chilc_1#1$1"}, {"id": 204, "prop": "name", "attributes": {"content": "我們先去那邊問問看吧，說不定能問到些什麼呢？", "name": "奇爾查克"}, "figure_art": "avg_4144_chilc_1#1$1"}, {"id": 205, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#9$1", "focus": "m"}}, {"id": 206, "prop": "name", "attributes": {"content": "你也在轉移話題！", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#9$1"}, {"id": 207, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#8$1", "focus": "m"}}, {"id": 208, "prop": "name", "attributes": {"content": "有點奇怪的木屋？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#8$1"}, {"id": 209, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#18$1", "focus": "m"}}, {"id": 210, "prop": "name", "attributes": {"content": "那就先去看看好了！", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#18$1"}, {"id": 211, "prop": "Dialog", "attributes": {}}, {"id": 212, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 213, "prop": "charslot", "attributes": {"duration": 1.5}}, {"id": 214, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 215, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#2$1", "focus": "m"}}, {"id": 216, "prop": "name", "attributes": {"content": "喂！", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#2$1"}, {"id": 217, "prop": "Dialog", "attributes": {}}, {"id": 218, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 219, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 220, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 221, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 222, "prop": "charslot", "attributes": {}}, {"id": 223, "prop": "Background", "attributes": {"image": "54_g1_bobfarm", "screenadapt": "showall"}}, {"id": 224, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 225, "prop": "PlayMusic", "attributes": {"key": "$darkness_03_loop", "volume": 0.6, "fadetime": 2.0}}, {"id": 226, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 227, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 228, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 229, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 230, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#13$1", "dur