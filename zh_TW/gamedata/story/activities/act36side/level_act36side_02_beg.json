r", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 150, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 151, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 152, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 1.0, "block": "true"}}, {"id": 153, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 154, "prop": "name", "attributes": {"content": "轟隆——！！！"}}, {"id": 155, "prop": "Dialog", "attributes": {}}, {"id": 156, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 157, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_070", "duration": 1.5}}, {"id": 158, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 159, "prop": "name", "attributes": {"content": "大祭司，大祭司，你在這裡嗎？", "name": "？？？"}, "figure_art": "avg_npc_070"}, {"id": 160, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#8$1", "focus": "m"}}, {"id": 161, "prop": "multiline", "attributes": {"name": "瑪露希爾", "content": "……什麼聲音？"}}, {"id": 162, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#2$1", "focus": "m"}}, {"id": 163, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 164, "prop": "multiline", "attributes": {"name": "瑪露希爾", "end": "true", "content": "——嗚哇！", "joined": "……什麼聲音？——嗚哇！"}}, {"id": 165, "prop": "name", "attributes": {"content": "鱷魚！還是長著鱷魚頭的獸人？！", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#2$1"}, {"id": 166, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_070", "focus": "m"}}, {"id": 167, "prop": "name", "attributes": {"content": "啊？獸人是什麼？", "name": "鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 168, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#2$1", "focus": "m"}}, {"id": 169, "prop": "name", "attributes": {"content": "還說話了！", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#2$1"}, {"id": 170, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_070", "focus": "m"}}, {"id": 171, "prop": "name", "attributes": {"content": "我會說話很奇怪嗎？——喂，那邊那兩個杜林，你們是從地下剛爬上來的？", "name": "鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 172, "prop": "Dialog", "attributes": {}}, {"id": 173, "prop": "charslot", "attributes": {}}, {"id": 174, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4144_chilc_1#1$1", "focus": "r"}}, {"id": 175, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4143_sensi_1#15$1", "focus": "r"}}, {"id": 176, "prop": "name", "attributes": {"content": "“杜林”？", "name": "先西"}, "figure_art": "avg_4143_sensi_1#15$1"}, {"id": 177, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4144_chilc_1#1$1", "focus": "l"}}, {"id": 178, "prop": "name", "attributes": {"content": "叫我們嗎？", "name": "奇爾查克"}, "figure_art": "avg_4144_chilc_1#1$1"}, {"id": 179, "prop": "Dialog", "attributes": {}}, {"id": 180, "prop": "charslot", "attributes": {}}, {"id": 181, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_070", "focus": "m"}}, {"id": 182, "prop": "name", "attributes": {"content": "除了你們兩個矮個子還有誰長得像杜林？", "name": "鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 183, "prop": "Dialog", "attributes": {}}, {"id": 184, "prop": "charslot", "attributes": {}}, {"id": 185, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4144_chilc_1#1$1", "focus": "r"}}, {"id": 186, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4143_sensi_1#15$1", "focus": "r"}}, {"id": 187, "prop": "name", "attributes": {"content": "也就是說，在他眼裡，我和奇爾查克是同一個種族？", "name": "先西"}, "figure_art": "avg_4143_sensi_1#15$1"}, {"id": 188, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4144_chilc_1#15$1", "focus": "l"}}, {"id": 189, "prop": "name", "attributes": {"content": "這裡沒有“半身人”這樣的說法嗎？", "name": "奇爾查克"}, "figure_art": "avg_4144_chilc_1#15$1"}, {"id": 190, "prop": "Dialog", "attributes": {}}, {"id": 191, "prop": "charslot", "attributes": {}}, {"id": 192, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_070", "focus": "m"}}, {"id": 193, "prop": "name", "attributes": {"content": "……什麼亂七八糟的，你們這群人應該是有點毛病。", "name": "鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 194, "prop": "name", "attributes": {"content": "對了，你們有沒有在這裡看到我們的大祭司？", "name": "鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 195, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#1$1", "focus": "m"}}, {"id": 196, "prop": "name", "attributes": {"content": "大祭司？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#1$1"}, {"id": 197, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_070", "focus": "m"}}, {"id": 198, "prop": "name", "attributes": {"content": "一個老頭，比我矮一點，戴個眼鏡。", "name": "鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 199, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#1$1", "focus": "m"}}, {"id": 200, "prop": "name", "attributes": {"content": "他為什麼會出現在這麼危險的地方？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#1$1"}, {"id": 201, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_070", "focus": "m"}}, {"id": 202, "prop": "name", "attributes": {"content": "大祭司的想法一向很神秘。", "name": "鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 203, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#16$1", "focus": "m"}}, {"id": 204, "prop": "name", "attributes": {"content": "但我們一路過來，沒見過這樣的老者。", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#16$1"}, {"id": 205, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_070", "focus": "m"}}, {"id": 206, "prop": "name", "attributes": {"content": "大祭司的行蹤的確也很神秘。", "name": "鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 207, "prop": "name", "attributes": {"content": "既然這樣，我還是回部落裡去好了，反正每次出來找他都是這樣。", "name": "鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 208, "prop": "name", "attributes": {"content": "再見，奇怪的遊客！", "name": "鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 209, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#1$1", "focus": "m"}}, {"id": 210, "prop": "name", "attributes": {"content": "等等！請問，你聽說過羅德島嗎？", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#1$1"}, {"id": 211, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_070", "focus": "m"}}, {"id": 212, "prop": "name", "attributes": {"content": "嘖嘖，你們算是幸運又有點不幸運。因為我好像聽過，又好像沒聽過。", "name": "鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 213, "prop": "name", "attributes": {"content": "但我肯定，部落裡有人知道這個什麼島在哪裡。", "name": "鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 214, "prop": "name", "attributes": {"content": "但是這個人……", "name": "鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 215, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#8$1", "focus": "m"}}, {"id": 216, "prop": "name", "attributes": {"content": "不會就是大祭司吧？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#8$1"}, {"id": 217, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_070", "focus": "m"}}, {"id": 218, "prop": "name", "attributes": {"content": "你猜對了。", "name": "鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 219, "prop": "name", "attributes": {"content": "不然這樣，你們和我回部落裡，通常我們出去找大祭司，總會找不到，但大祭司過一下子自己就回來了！", "name": "鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 220, "prop": "Dialog", "attributes": {}}, {"id": 221, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 222, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 223, "prop": "charslot", "attributes": {}}, {"id": 224, "prop": "Background", "attributes": {"image": "bg_village", "screenadapt": "showall"}}, {"id": 225, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 226, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 227, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 228, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 229, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_070", "duration": 1.5}}, {"id": 230, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4141_marcil_1#1$1", "duration": 1.5}}, {"id": 231, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 232, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_070", "focus": "l"}}, {"id": 233, "prop": "name", "attributes": {"content": "也就是說，你們之前在一座島上，上面有個大迷宮，你們走著走著就到這裡來了。", "name": "聰明的鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 234, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4141_marcil_1#1$1", "focus": "r"}}, {"id": 235, "prop": "name", "attributes": {"content": "差不多就是這樣，您知道些什麼嗎？", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#1$1"}, {"id": 236, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_070", "focus": "l"}}, {"id": 237, "prop": "name", "attributes": {"content": "嗯……島是什麼？", "name": "聰明的鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 238, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4141_marcil_1#14$1", "focus": "r"}}, {"id": 239, "prop": "name", "attributes": {"content": "啊？就是……海上的陸地。", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#14$1"}, {"id": 240, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_070", "focus": "l"}}, {"id": 241, "prop": "name", "attributes": {"content": "海是什麼？", "name": "聰明的鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 242, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4141_marcil_1#1$1", "focus": "r"}}, {"id": 243, "prop": "name", "attributes": {"content": "呃……就是有很多水的地方？", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#1$1"}, {"id": 244, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_070", "focus": "l"}}, {"id": 245, "prop": "name", "attributes": {"content": "那不是湖嗎？你說話好奇怪喔。", "name": "聰明的鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 246, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4141_marcil_1#9$1", "focus": "r"}}, {"id": 247, "prop": "name", "attributes": {"content": "唔，因為這裡是內陸嗎……", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#9$1"}, {"id": 248, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_070", "focus": "l"}}, {"id": 249, "prop": "name", "attributes": {"content": "是你的問題太奇怪了！我從沒聽過什麼海啊，島啊，叫梅利尼的村子啊，你們該不會是被人一尾巴從泰拉的另一邊掃過來的吧？", "name": "聰明的鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 250, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4141_marcil_1#9$1", "focus": "r"}}, {"id": 251, "prop": "name", "attributes": {"content": "泰拉……是什麼？", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#9$1"}, {"id": 252, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_070", "focus": "l"}}, {"id": 253, "prop": "name", "attributes": {"content": "就是這裡啊……", "name": "聰明的鱷魚頭獸人"}, "figure_art": "avg_npc_070"}, {"id": 254, "prop": "Dialog", "attributes": {}}, {"id": 255, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4141_marcil_1#22$1", "focus": "r"}}, {"id": 256, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 257, "prop": "name", "attributes": {"content": "瑪露希爾試圖從眼前的鱷魚人的眼神中找到他在耍自己的痕跡。"}}, {"id": 258, "prop": "name", "attributes": {"content": "可惜，在那直率的眼神中，只有“這人該不會是個笨蛋吧？”這樣一個訊息。"}}, {"id": 259, "prop": "Dialog", "attributes": {}}, {"id": 260, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 261, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 262, "prop": "charslot", "attributes": {}}, {"id": 263, "prop": "Background", "attributes": {"image": "bg_village", "screenadapt": "showall"}}, {"id": 264, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 265, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 266, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 267, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4144_chilc_1#11$1", "focus": "m"}}, {"id": 268, "prop": "name", "attributes": {"content": "總之就是，這群鱷……阿達克利斯裡說得上話的是大祭司，瑪露希爾剛剛炸壞的魔像就是他的……", "name": "奇爾查克"}, "figure_art": "avg_4144_chilc_1#11$1"}, {"id": 269, "prop": "Dialog", "attributes": {}}, {"id": 270, "prop": "charslot", "attributes": {}}, {"id": 271, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_071", "focus": "l"}}, {"id": 272, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_070", "focus": "l"}}, {"id": 273, "prop": "name", "attributes": {"content": "機甲。", "name": "阿達克利斯A"}, "figure_art": "avg_npc_071"}, {"id": 274, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_070", "focus": "r"}}, {"id": 275, "prop": "name", "attributes": {"content": "“無敵的酷東西”。", "name": "阿達克利斯B"}, "figure_art": "avg_npc_070"}, {"id": 276, "prop": "Dialog", "attributes": {}}, {"id": 277, "prop": "charslot", "attributes": {}}, {"id": 278, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#1$1", "focus": "m"}}, {"id": 279, "prop": "name", "attributes": {"content": "我們弄壞了他的“機甲”，他會願意幫我們找羅德島嗎？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#1$1"}, {"id": 280, "prop": "Dialog", "attributes": {}}, {"id": 281, "prop": "charslot", "attributes": {}}, {"id": 282, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_071", "focus": "l"}}, {"id": 283, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_070", "focus": "l"}}, {"id": 284, "prop": "name", "attributes": {"content": "沒有關係，就算沒有你們，那台機甲終究也會爆炸。", "name": "阿達克利斯A"}, "figure_art": "avg_npc_071"}, {"id": 285, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_070", "focus": "r"}}, {"id": 286, "prop": "name", "attributes": {"content": "就沒有不爆炸的。", "name": "阿達克利斯B"}, "figure_art": "avg_npc_070"}, {"id": 287, "prop": "Dialog", "attributes": {}}, {"id": 288, "prop": "charslot", "attributes": {}}, {"id": 289, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_070", "focus": "m"}}, {"id": 290, "prop": "name", "attributes": {"content": "大祭司很隨和的，只要等他回來跟他說明情況，想必他不會怪罪你們。", "name": "聰明的阿達克利斯"}, "figure_art": "avg_npc_070"}, {"id": 291, "prop": "name", "attributes": {"content": "大祭司也很仗義，看到你們在這裡迷路，他絕對不會見死不救。", "name": "聰明的阿達克利斯"}, "figure_art": "avg_npc_070"}, {"id": 292, "prop": "name", "attributes": {"content": "這就是我們的大祭司！", "name": "聰明的阿達克利斯"}, "figure_art": "avg_npc_070"}, {"id": 293, "prop": "Dialog", "attributes": {}}, {"id": 294, "prop": "charslot", "attributes": {}}, {"id": 295, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#1$1", "focus": "m"}}, {"id": 296, "prop": "name", "attributes": {"content": "話雖是這麼說，但我們也要想個辦法賠禮道歉才好……", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#1$1"}, {"id": 297, "prop": "Dialog", "attributes": {}}, {"id": 298, "prop": "charslot", "attributes": {}}, {"id": 299, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_070", "focus": "m"}}, {"id": 300, "prop": "name", "attributes": {"content": "不用在意啦——什麼味道這麼香，話說今天輪到誰做飯？", "name": "聰明的阿達克利斯"}, "figure_art": "avg_npc_070"}, {"id": 301, "prop": "Dialog", "attributes": {}}, {"id": 302, "prop": "charslot", "attributes": {}}, {"id": 303, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_071", "focus": "m"}}, {"id": 304, "prop": "name", "attributes": {"content": "是那個大鬍子杜林在做飯。", "name": "阿達克利斯戰士"}, "figure_art": "avg_npc_071"}, {"id": 305, "prop": "Dialog", "attributes": {}}, {"id": 306, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 307, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 308, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 309, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 310, "prop": "charslot", "attributes": {}}, {"id": 311, "prop": "Background", "attributes": {"image": "bg_jungle_1", "screenadapt": "showall"}}, {"id": 312, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 313, "prop": "PlayMusic", "attributes": {"key": "$normal_loop", "volume": 0.6, "fadetime": 2.0}}, {"id": 314, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 315, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 316, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#3$1", "focus": "m"}}, {"id": 317, "prop": "name", "attributes": {"content": "泰拉、阿卡胡拉、活畫、迷宮……", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#3$1"}, {"id": 318, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#11$1", "focus": "m"}}, {"id": 319, "prop": "name", "attributes": {"content": "嗚……不行，完全理不出頭緒……", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#11$1"}, {"id": 320, "prop": "name", "attributes": {"content": "魔法在這裡也可以使用，這就說明在法則上是有共通之處的……", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#11$1"}, {"id": 321, "prop": "name", "attributes": {"content": "……", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#11$1"}, {"id": 322, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#11$1", "focus": "m"}}, {"id": 323, "prop": "name", "attributes": {"content": "法琳，要是你還在的話，我一定會像萊歐斯那樣，對正在發生的這一切興致勃勃吧。", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#11$1"}, {"id": 324, "prop": "name", "attributes": {"content": "唉，真想念我們一起在學校學習的日子。", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#11$1"}, {"id": 325, "prop": "name", "attributes": {"content": "那時候……", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#11$1"}, {"id": 326, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#1$1", "focus": "m"}}, {"id": 327, "prop": "name", "attributes": {"content": "咦，這些小鳥吃的這個果子……", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#1$1"}, {"id": 328, "prop": "name", "attributes": {"content": "和那時候法琳給我吃的果子好像……", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#1$1"}, {"id": 329, "prop": "Dialog", "attributes": {}}, {"id": 330, "prop": "PlaySound", "attributes": {"key": "$d_avg_humaneat", "volume": 1.0, "channel": "2"}}, {"id": 331, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 332, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 333, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 334, "prop": "Blocker", "attributes": {"a": 0.3, "r": 0.5, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 335, "prop": "Blocker", "attributes": {"a": 0.3, "r": 0.0, "g": 0.5, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 336, "prop": "Blocker", "attributes": {"a": 0.3, "r": 0.0, "g": 0.0, "b": 0.5, "fadetime": 1.0, "block": "true"}}, {"id": 337, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 338, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#8$1", "focus": "m"}}, {"id": 339, "prop": "name", "attributes": {"content": "……", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#8$1"}, {"id": 340, "prop": "Dialog", "attributes": {}}, {"id": 341, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 342, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 343, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 344, "prop": "charslot", "attributes": {}}, {"id": 345, "prop": "Background", "attributes": {"image": "bg_village", "screenadapt": "showall"}}, {"id": 346, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 347, "prop": "PlayMusic", "attributes": {"intro": "$path_intro", "key": "$path_loop", "volume": 0.6, "fadetime": 1.0}}, {"id": 348, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 349, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 350, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_071", "focus": "l"}}, {"id": 351, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_070", "focus": "l"}}, {"id": 352, "prop": "name", "attributes": {"content": "好香啊，杜林做飯的手藝也這麼好？", "name": "阿達克利斯A"}, "figure_art": "avg_npc_071"}, {"id": 353, "prop": "Dialog", "attributes": {}}, {"id": 354, "prop": "charslot", "attributes": {}}, {"id": 355, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4143_sensi_1#15$1", "focus": "m"}}, {"id": 356, "prop": "name", "attributes": {"content": "老夫不是杜林……唉，就當老夫是杜林吧。", "name": "先西"}, "figure_art": "avg_4143_sensi_1#15$1"}, {"id": 357, "prop": "Dialog", "attributes": {}}, {"id": 358, "prop": "charslot", "attributes": {}}, {"id": 359, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_071", "focus": "l"}}, {"id": 360, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_070", "focus": "l"}}, {"id": 361, "prop": "name", "attributes": {"content": "快叫兄弟們都來嚐嚐大鬍子杜林的手藝！", "name": "阿達克利斯A"}, "figure_art": "avg_npc_071"}, {"id": 362, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_070", "focus": "r"}}, {"id": 363, "prop": "name", "attributes": {"content": "對了，你們剛才說要去找大祭司？", "name": "阿達克利斯B"}, "figure_art": "avg_npc_070"}, {"id": 364, "prop": "Dialog", "attributes": {}}, {"id": 365, "prop": "charslot", "attributes": {}}, {"id": 366, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#18$1", "focus": "m"}}, {"id": 367, "prop": "name", "attributes": {"content": "嗯，我們想要向他請教一些問題。", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#18$1"}, {"id": 368, "prop": "Dialog", "attributes": {}}, {"id": 369, "prop": "charslot", "attributes": {}}, {"id": 370, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_071", "focus": "l"}}, {"id": 371, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_070", "focus": "l"}}, {"id": 372, "prop": "name", "attributes": {"content": "也對，大祭司是這裡最聰明的人，但要見他沒那麼容易。要是他想見你們，你們就能見到他；要是他不願意，你們是一定見不到他的。", "name": "阿達克利斯A"}, "figure_art": "avg_npc_071"}, {"id": 373, "prop": "Dialog", "attributes": {}}, {"id": 374, "prop": "charslot", "attributes": {}}, {"id": 375, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4144_chilc_1#1$1", "focus": "m"}}, {"id": 376, "prop": "name", "attributes": {"content": "這倒是很符合智者的做派……那怎麼樣才能讓他想見我們呢？", "name": "奇爾查克"}, "figure_art": "avg_4144_chilc_1#1$1"}, {"id": 377, "prop": "Dialog", "attributes": {}}, {"id": 378, "prop": "charslot", "attributes": {}}, {"id": 379, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_071", "focus": "r"}}, {"id": 380, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_070", "focus": "r"}}, {"id": 381, "prop": "name", "attributes": {"content": "嗯……祖瑪瑪大姐交代過，要是我們想借用大祭司的智慧，就得搞出點熱鬧的動靜！", "name": "阿達克利斯B"}, "figure_art": "avg_npc_070"}, {"id": 382, "prop": "Dialog", "attributes": {}}, {"id": 383, "prop": "charslot", "attributes": {}}, {"id": 384, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4143_sensi_1#1$1", "focus": "m"}}, {"id": 385, "prop": "name", "attributes": {"content": "熱鬧的動靜……一頓大餐算嗎？", "name": "先西"}, "figure_art": "avg_4143_sensi_1#1$1"}, {"id": 386, "prop": "Dialog", "attributes": {}}, {"id": 387, "prop": "charslot", "attributes": {}}, {"id": 388, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_071", "focus": "r"}}, {"id": 389, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_070", "focus": "r"}}, {"id": 390, "prop": "name", "attributes": {"content": "差不多吧。", "name": "阿達克利斯B"}, "figure_art": "avg_npc_070"}, {"id": 391, "prop": "Dialog", "attributes": {}}, {"id": 392, "prop": "charslot", "attributes": {}}, {"id": 393, "prop": "charslot", "attributes": {"s