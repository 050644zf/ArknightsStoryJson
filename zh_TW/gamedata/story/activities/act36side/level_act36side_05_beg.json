p": "Dialog", "attributes": {}}, {"id": 103, "prop": "charslot", "attributes": {}}, {"id": 104, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 105, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 106, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_139#2", "duration": 1.0}}, {"id": 107, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 108, "prop": "name", "attributes": {"content": "辛苦了。", "name": "黎"}, "figure_art": "avg_npc_139#2"}, {"id": 109, "prop": "playMusic", "attributes": {"intro": "$path_intro", "key": "$path_loop", "volume": 0.6}}, {"id": 110, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#17$1", "focus": "m"}}, {"id": 111, "prop": "name", "attributes": {"content": "不會！鎮裡人願意收留我們，我們幫忙解決一些麻煩也是應該的。", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#17$1"}, {"id": 112, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4143_sensi_1#1$1", "focus": "m"}}, {"id": 113, "prop": "name", "attributes": {"content": "老夫還要去田裡幫忙種菜，先走一步。", "name": "先西"}, "figure_art": "avg_4143_sensi_1#1$1"}, {"id": 114, "prop": "Dialog", "attributes": {}}, {"id": 115, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 116, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 117, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 118, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4144_chilc_1#1$1", "focus": "m"}}, {"id": 119, "prop": "name", "attributes": {"content": "先西這傢伙，已經完全和鎮裡人混熟了嘛。", "name": "奇爾查克"}, "figure_art": "avg_4144_chilc_1#1$1"}, {"id": 120, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_139#2", "focus": "m"}}, {"id": 121, "prop": "name", "attributes": {"content": "奇爾查克小哥不也是嘛，張伯剛才還請我叫你解決墨魎就過去喝酒呢。", "name": "黎"}, "figure_art": "avg_npc_139#2"}, {"id": 122, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4144_chilc_1#2$1", "focus": "m"}}, {"id": 123, "prop": "name", "attributes": {"content": "那老伯也太不服輸了，喝不過我還硬要挑戰我……", "name": "奇爾查克"}, "figure_art": "avg_4144_chilc_1#2$1"}, {"id": 124, "prop": "Dialog", "attributes": {}}, {"id": 125, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 126, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 127, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 128, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#17$1", "focus": "m"}}, {"id": 129, "prop": "name", "attributes": {"content": "黎小姐，我今天能去你那裡喝茶嗎？", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#17$1"}, {"id": 130, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_139#2", "focus": "m"}}, {"id": 131, "prop": "name", "attributes": {"content": "瑪露希爾妹妹有空，我自然是有空的。", "name": "黎"}, "figure_art": "avg_npc_139#2"}, {"id": 132, "prop": "name", "attributes": {"content": "今天輪到瑪露希爾妹妹講你的冒險故事了，我可是非常期待。", "name": "黎"}, "figure_art": "avg_npc_139#2"}, {"id": 133, "prop": "name", "attributes": {"content": "不過……我還記得，你們剛到這裡時，說過自己還要去拯救萊歐斯小哥的妹妹。", "name": "黎"}, "figure_art": "avg_npc_139#2"}, {"id": 134, "prop": "name", "attributes": {"content": "還不出發沒關係嗎？", "name": "黎"}, "figure_art": "avg_npc_139#2"}, {"id": 135, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#17$1", "focus": "m"}}, {"id": 136, "prop": "name", "attributes": {"content": "……嗯，救法琳是我們的目的。", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#17$1"}, {"id": 137, "prop": "name", "attributes": {"content": "但是——", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#17$1"}, {"id": 138, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#18$1", "focus": "m"}}, {"id": 139, "prop": "name", "attributes": {"content": "要找到離開的方法畢竟不能急。", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#18$1"}, {"id": 140, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#17$1", "focus": "m"}}, {"id": 141, "prop": "name", "attributes": {"content": "而且，在這裡的生活也很好……", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#17$1"}, {"id": 142, "prop": "name", "attributes": {"content": "到時候再說吧，你說對吧，萊歐斯？", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#17$1"}, {"id": 143, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#8$1", "focus": "m"}}, {"id": 144, "prop": "name", "attributes": {"content": "嗯？什麼？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#8$1"}, {"id": 145, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#13$1", "focus": "m"}}, {"id": 146, "prop": "name", "attributes": {"content": "你又不聽我說話！", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#13$1"}, {"id": 147, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_139#2", "focus": "m"}}, {"id": 148, "prop": "name", "attributes": {"content": "……呵呵，萊歐斯小哥對墨魎的熱情如今在鎮裡也已經是無人不知了。", "name": "黎"}, "figure_art": "avg_npc_139#2"}, {"id": 149, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#16$1", "focus": "m"}}, {"id": 150, "prop": "name", "attributes": {"content": "但是這種叫墨魎的史萊姆真的很有趣。", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#16$1"}, {"id": 151, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#18$1", "focus": "m"}}, {"id": 152, "prop": "name", "attributes": {"content": "牠們有自己固定的形狀，能明顯看出頭身和四肢的區別，攻擊方式不是包裹敵人的頭部，更像是野獸攻擊人的方式，而且還會叫！", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#18$1"}, {"id": 153, "prop": "name", "attributes": {"content": "最特殊的是，我們每次擊殺魔物都會留下屍體，但牠們什麼都不會留下，除了一攤黑色的水。", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#18$1"}, {"id": 154, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#9$1", "focus": "m"}}, {"id": 155, "prop": "name", "attributes": {"content": "……", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#9$1"}, {"id": 156, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#1$1", "focus": "m"}}, {"id": 157, "prop": "name", "attributes": {"content": "我昨天把牠們的弱點告訴了鎮民們，但是鎮民們卻好像並不是很激動。", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#1$1"}, {"id": 158, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#22$1", "focus": "m"}}, {"id": 159, "prop": "name", "attributes": {"content": "因為對這種東西著迷的只有你一個啊。", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#22$1"}, {"id": 160, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#8$1", "focus": "m"}}, {"id": 161, "prop": "name", "attributes": {"content": "……是這樣嗎？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#8$1"}, {"id": 162, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#13$1", "focus": "m"}}, {"id": 163, "prop": "name", "attributes": {"content": "可是連奇爾查克都學會上手反擊了，這些鎮民卻一直學不會。每次看他們對付墨魎都好像根本不知道怎麼攻擊一樣。", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#13$1"}, {"id": 164, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_143#1"}}, {"id": 165, "prop": "name", "attributes": {"content": "嘎嘎！", "name": "墨魎"}, "figure_art": "avg_npc_143#1"}, {"id": 166, "prop": "Dialog", "attributes": {}}, {"id": 167, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 168, "prop": "CameraShake", "attributes": {"duration": 1.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 169, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.03, "block": "true"}}, {"id": 170, "prop": "PlaySound", "attributes": {"key": "$e_skill_skulsrsword", "volume": 1.0}}, {"id": 171, "prop": "charslot", "attributes": {"duration": 0.5}}, {"id": 172, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 173, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 174, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#13$1", "focus": "m"}}, {"id": 175, "prop": "name", "attributes": {"content": "我甚至覺得牠們還能聽得懂人說話……", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#13$1"}, {"id": 176, "prop": "name", "attributes": {"content": "這很奇怪，先西也說，牠們不像史萊姆一樣，有明確的器官部位……", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#13$1"}, {"id": 177, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#22$1", "focus": "m"}}, {"id": 178, "prop": "name", "attributes": {"content": "好了好了，我知道了。", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#22$1"}, {"id": 179, "prop": "Dialog", "attributes": {}}, {"id": 180, "prop": "charslot", "attributes": {}}, {"id": 181, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1427_1#1$1", "duration": 1.5}}, {"id": 182, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 183, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#1$1", "focus": "m"}}, {"id": 184, "prop": "name", "attributes": {"content": "嗯？還有漏網之魚嗎？", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#1$1"}, {"id": 185, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1427_1#1$1", "focus": "m"}}, {"id": 186, "prop": "name", "attributes": {"content": "嘎——", "name": "墨魎"}, "figure_art": "avg_npc_1427_1#1$1"}, {"id": 187, "prop": "Dialog", "attributes": {}}, {"id": 188, "prop": "PlaySound", "attributes": {"key": "$runsand", "volume": 1.0}}, {"id": 189, "prop": "charslot", "attributes": {"duration": 1.5}}, {"id": 190, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 191, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#1$1", "focus": "m"}}, {"id": 192, "prop": "name", "attributes": {"content": "嗯？這隻有點眼熟……牠臉上有痣，我好像之前看過……？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#1$1"}, {"id": 193, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#8$1", "focus": "m"}}, {"id": 194, "prop": "name", "attributes": {"content": "牠前幾天已經被我打死了啊，怎麼又出現了？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#8$1"}, {"id": 195, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#7$1", "focus": "m"}}, {"id": 196, "prop": "name", "attributes": {"content": "……什麼情況，難道牠們會復活？……我去看看！", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#7$1"}, {"id": 197, "prop": "Dialog", "attributes": {}}, {"id": 198, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0}}, {"id": 199, "prop": "charslot", "attributes": {"duration": 1.5}}, {"id": 200, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 201, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#1$1", "focus": "m"}}, {"id": 202, "prop": "name", "attributes": {"content": "記得回來吃飯！", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#1$1"}, {"id": 203, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#11$1", "focus": "m"}}, {"id": 204, "prop": "name", "attributes": {"content": "……唉，根本沒聽到。", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#11$1"}, {"id": 205, "prop": "name", "attributes": {"content": "對不起，這傢伙就這樣。", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#11$1"}, {"id": 206, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_139#2", "focus": "m"}}, {"id": 207, "prop": "name", "attributes": {"content": "沒關係。", "name": "黎"}, "figure_art": "avg_npc_139#2"}, {"id": 208, "prop": "name", "attributes": {"content": "比起這個，瑪露希爾妹妹，你還記得，你們已經來到婆山鎮多久了嗎？", "name": "黎"}, "figure_art": "avg_npc_139#2"}, {"id": 209, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#14$1", "focus": "m"}}, {"id": 210, "prop": "multiline", "attributes": {"name": "瑪露希爾", "content": "我當然……"}}, {"id": 211, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#1$1", "focus": "m"}}, {"id": 212, "prop": "multiline", "attributes": {"name": "瑪露希爾", "end": "true", "content": "咦？", "joined": "我當然……咦？"}}, {"id": 213, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#9$1", "focus": "m"}}, {"id": 214, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 215, "prop": "name", "attributes": {"content": "我們來到這裡多久了來著？", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#9$1"}, {"id": 216, "prop": "Dialog", "attributes": {}}, {"id": 217, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 218, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 219, "prop": "charslot", "attributes": {}}, {"id": 220, "prop": "Background", "attributes": {"image": "bg_plankroad", "screenadapt": "showall"}}, {"id": 221, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 222, "prop": "playMusic", "attributes": {"key": "$normal_loop", "volume": 0.6}}, {"id": 223, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 224, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 225, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_143#1", "duration": 1.5}}, {"id": 226, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_143#1", "duration": 1.5}}, {"id": 227, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 228, "prop": "charslot", "attributes": {}}, {"id": 229, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#7$1", "focus": "m"}}, {"id": 230, "prop": "name", "attributes": {"content": "等、等等……這也太多了吧？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#7$1"}, {"id": 231, "prop": "Dialog", "attributes": {}}, {"id": 232, "prop": "charslot", "attributes": {}}, {"id": 233, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_143#1"}}, {"id": 234, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_143#1"}}, {"id": 235, "prop": "name", "attributes": {"content": "嘎……", "name": "墨魎們"}, "figure_art": "avg_npc_143#1"}, {"id": 236, "prop": "Dialog", "attributes": {}}, {"id": 237, "prop": "charslot", "attributes": {}}, {"id": 238, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#14$1", "focus": "m"}}, {"id": 239, "prop": "name", "attributes": {"content": "我們在這裡待的時間不短了，每天都殺死了那麼多墨魎，沒想到這裡還有這麼多？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#14$1"}, {"id": 240, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#7$1", "focus": "m"}}, {"id": 241, "prop": "name", "attributes": {"content": "這麼多同類聚在一起也沒有產生內部爭鬥……牠們內部是非常和諧的狀態嗎？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#7$1"}, {"id": 242, "prop": "Dialog", "attributes": {}}, {"id": 243, "prop": "charslot", "attributes": {}}, {"id": 244, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_143#1"}}, {"id": 245, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_143#1"}}, {"id": 246, "prop": "name", "attributes": {"content": "……", "name": "墨魎們"}, "figure_art": "avg_npc_143#1"}, {"id": 247, "prop": "Dialog", "attributes": {}}, {"id": 248, "prop": "charslot", "attributes": {}}, {"id": 249, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#13$1", "focus": "m"}}, {"id": 250, "prop": "name", "attributes": {"content": "但沒有看到墨魎寶寶啊……？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#13$1"}, {"id": 251, "prop": "name", "attributes": {"content": "這麼一說，雌雄似乎也看不出來，這裡的都是成年體，沒有年老的，怎麼看都不像一個魔物生活的群落……", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#13$1"}, {"id": 252, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#7$1", "focus": "m"}}, {"id": 253, "prop": "name", "attributes": {"content": "欸？等等，剛剛那隻眼熟的一下子去哪裡了……", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#7$1"}, {"id": 254, "prop": "Dialog", "attributes": {}}, {"id": 255, "prop": "charslot", "attributes": {}}, {"id": 256, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_143#1"}}, {"id": 257, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 258, "prop": "charslot", "attributes": {"slot": "m", "action": "jump", "power": 30.0, "times": 1.0, "duration": 0.5, "isblock": "true"}}, {"id": 259, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 260, "prop": "charslot", "attributes": {}}, {"id": 261, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#8$1", "focus": "m"}}, {"id": 262, "prop": "name", "attributes": {"content": "……糟了，被發現了！", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#8$1"}, {"id": 263, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#7$1", "focus": "m"}}, {"id": 264, "prop": "name", "attributes": {"content": "得想個辦法，不能讓牠引來更多的墨魎！否則我一個人解決不了——", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#7$1"}, {"id": 265, "prop": "Dialog", "attributes": {}}, {"id": 266, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_143#1", "focus": "m"}}, {"id": 267, "prop": "charslot", "attributes": {"slot": "m", "action": "jump", "power": 30.0, "times": 1.0, "duration": 0.5, "isblock": "true"}}, {"id": 268, "prop": "charslot", "attributes": {"slot": "m", "action": "jump", "power": 30.0, "times": 1.0, "duration": 0.5, "isblock": "true"}}, {"id": 269, "prop": "charslot", "attributes": {"slot": "m", "action": "jump", "power": 30.0, "times": 1.0, "duration": 0.5, "isblock": "true"}}, {"id": 270, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 271, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#7$1", "focus": "m"}}, {"id": 272, "prop": "name", "attributes": {"content": "不好了，牠要叫了——", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#7$1"}, {"id": 273, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_143#1", "focus": "m"}}, {"id": 274, "prop": "name", "attributes": {"content": "——", "name": "墨魎"}, "figure_art": "avg_npc_143#1"}, {"id": 275, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#3$1", "focus": "m"}}, {"id": 276, "prop": "name", "attributes": {"content": "塞你一嘴水果！", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#3$1"}, {"id": 277, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_143#1", "focus": "m"}}, {"id": 278, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 279, "prop": "name", "attributes": {"content": "嘎……唔？吧唧吧唧……", "name": "墨魎"}, "figure_art": "avg_npc_143#1"}, {"id": 280, "prop": "name", "attributes": {"content": "吧唧吧唧……", "name": "墨魎"}, "figure_art": "avg_npc_143#1"}, {"id": 281, "prop": "name", "attributes": {"content": "嘎。", "name": "墨魎"}, "figure_art": "avg_npc_143#1"}, {"id": 282, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#8$1", "focus": "m"}}, {"id": 283, "prop": "name", "attributes": {"content": "什麼意思，還要？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#8$1"}, {"id": 284, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_143#1", "focus": "m"}}, {"id": 285, "prop": "name", "attributes": {"content": "嘎嘎。", "name": "墨魎"}, "figure_art": "avg_npc_143#1"}, {"id": 286, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#18$1", "focus": "m"}}, {"id": 287, "prop": "name", "attributes": {"content": "只要你別大聲叫，就可以。", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#18$1"}, {"id": 288, "prop": "name", "attributes": {"content": "給你，這都是我準備當零食吃的……你安安靜靜地吃，吃了之後跟過來，跟我一起繞到牆後……", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#18$1"}, {"id": 289, "prop": "Dialog", "attributes": {}}, {"id": 290, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,0", "posto": "100,0", "duration": 2.0}}, {"id": 291, "prop": "charslot", "attributes": {"slot": "m", "afrom": 1.0, "ato": 0.0, "duration": 1.0}}, {"id": 292, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 293, "prop": "charslot", "attributes": {}}, {"id": 294, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_143#1", "focus": "m"}}, {"id": 295, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 296, "prop": "charslot", "attributes": {"slot": "m", "action": "jump", "power": 30.0, "times": 1.0, "duration": 0.5, "isblock": "true"}}, {"id": 297, "prop": "charslot", "attributes": {"slot": "m", "action": "jump", "power": 30.0, "times": 1.0, "duration": 0.5, "isblock": "true"}}, {"id": 298, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 299, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,0", "posto": "100,0", "duration": 2.0}}, {"id": 300, "prop": "charslot", "attributes": {"slot": "m", "afrom": 1.0, "ato": 0.0, "duration": 1.0}}, {"id": 301, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 302, "prop": "charslot", "attributes": {}}, {"id": 303, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 304, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#10$1", "posfrom": "-100,0", "posto": "0,0", "duration": 2.0}}, {"id": 305, "prop": "charslot", "attributes": {"slot": "m", "afrom": 0.0, "ato": 1.0, "duration": 1.0}}, {"id": 306, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 307, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#10$1", "focus": "m"}}, {"id": 308, "prop": "name", "attributes": {"content": "……好乖啊，怎麼回事……", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#10$1"}, {"id": 309, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_143#1", "focus": "m"}}, {"id": 310, "prop": "name", "attributes": {"content": "（偷偷爬向牆後）", "name": "墨魎"}, "figure_art": "avg_npc_143#1"}, {"id": 311, "prop": "name", "attributes": {"content": "（瞄準掉在地上的杏子）", "name": "墨魎"}, "figure_art": "avg_npc_143#1"}, {"id": 312, "prop": "Dialog", "attributes": {}}, {"id": 313, "prop": "charslot", "attributes": {"slot": "m", "action": "jump", "posfrom": "0,0", "posto": "50,0", "power": 80.0, "times": 1.0, "duration": 0.5, "isblock": "true"}}, {"id": 314, "prop": "name", "attributes": {"content": "（成功叼到杏子並大快朵頤）", "name": "墨魎"}}, {"id": 315, "prop": "Dialog", "attributes": {}}, {"id": 316, "prop": "charslot", "attributes": {}}, {"id": 317, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#16$1", "focus": "m"}}, {"id": 318, "prop": "name", "attributes": {"content": "牠剛剛還在襲擊小鎮，現在為了幾個水果就變得溫順了？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#16$1"}, {"id": 319, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_143#1", "focus": "m"}}, {"id": 320, "prop": "name", "attributes": {"content": "（吃吃吃）", "name": "墨魎"}, "figure_art": "avg_npc_143#1"}, {"id": 321, "prop": "Dialog", "attributes": {}}, {"id": 322, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,0", "posto": "50,0", "duration": 0.5, "isblock": "true"}}, {"id": 323, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "50,0", "posto": "0,0", "duration": 0.3, "isblock": "true"}}, {"id": 324, "prop": "name", "attributes": {"content": "（一口咬住萊歐斯的口袋）", "name": "墨魎"}}, {"id": 325, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#8$1", "focus": "m"}}, {"id": 326, "prop": "name", "attributes": {"content": "……啊？這是在幹什麼？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#8$1"}, {"id": 327, "prop": "name", "attributes": {"content": "看上去是來攻擊鎮民的，但打贏了看不出開心，打輸了也就跑了，居然會躲在這裡偷吃杏子……！", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#8$1"}, {"id": 328, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#16$1", "focus": "m"}}, {"id": 329, "prop": "name", "attributes": {"content": "嗯……倒是會因為爭食而打架，但要說是為了食物，山上的果子肯定比鎮裡的多，這麼頻繁地攻擊小鎮，怎麼會只為吃幾個果子？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#16$1"}, {"id": 330, "prop": "name", "attributes": {"content": "鎮民沒抓走牠們的幼崽，也不像是侵佔了牠們的領地，牠們究竟哪裡來的敵意……？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#16$1"}, {"id": 331, "prop": "Dialog", "attributes": {}}, {"id": 332, "prop": "charslot", "attributes": {}}, {"id": 333, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1427_1#1$1", "duration": 1.5}}, {"id": 334, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 335, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#8$1", "focus": "m"}}, {"id": 336, "prop": "name", "attributes": {"content": "嗯？這不就是剛剛長著痣的那隻？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#8$1"}, {"id": 337, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#3$1", "focus": "m"}}, {"id": 338, "prop": "name", "attributes": {"content": "看招！", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#3$1"}, {"id": 339, "prop": "Dialog", "attributes": {}}, {"id": 340, "prop": "charslot", "attributes": {}}, {"id": 341, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovement", "volume": 1.0}}, {"id": 342, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1427_1#1$1", "focus": "m"}}, {"id": 343, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 344, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 345, "prop": "name", "attributes": {"content": "萊歐斯一抬手，一顆杏子飛出，噗的一聲，砸中了眼熟的墨魎的腦袋。"}}, {"id": 346, "prop": "Dialog", "attributes": {}}, {"id": 347, "prop": "charslot", "attributes": {"slot": "m", "action": "jump", "power": 50.0, "times": 1.0, "duration": 0.5, "isblock": "true"}}, {"id": 348, "prop": "charslot", "attributes": {"slot": "m", "action": "jump", "power": 50.0, "times": 1.0, "duration": 0.5, "isblock": "true"}}, {"id": 349, "prop": "name", "attributes": {"content": "牠被砸得差點跌倒，急得想要立起上半身站起來，用兩隻短手捂住腦袋。"}}, {"id": 350, "prop": "name", "attributes": {"content": "但隨即，牠也聞到了杏子香甜的氣息。"}}, {"id": 351, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1427_1#1$1", "focus": "m"}}, {"id": 352, "prop": "name", "attributes": {"content": "嘎嗚！", "name": "墨魎"}, "figure_art": "avg_npc_1427_1#1$1"}, {"id": 353, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#18$1", "focus": "m"}}, {"id": 354, "prop": "name", "attributes": {"content": "還真是來吃杏子的？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#18$1"}, {"id": 355, "prop": "name", "attributes": {"content": "接著。", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#18$1"}, {"id": 356, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1427_1#1$1", "focus": "m"}}, {"id": 357, "prop": "name", "attributes": {"content": "嘎嗚！嘎嗚！", "name": "墨魎"}, "figure_art": "avg_npc_1427_1#1$1"}, {"id": 358, "prop": "name", "attributes": {"content": "吧唧吧唧……", "name": "墨魎"}, "figure_art": "avg_npc_1427_1#1$1"}, {"id": 359, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#18$1", "focus": "m"}}, {"id": 360, "prop": "name", "attributes": {"content": "讓我仔細看看……長著痣，頭稍微大一點，尾巴細長但又有分岔……", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#18$1"}, {"id": 361, "prop": "name", "attributes": {"content": "你就是之前那隻！當時我就覺得你奇怪，肚子吃得那麼鼓，都走不動了，簡直不像來襲擊鎮子的！", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#18$1"}, {"id": 362, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1427_1#1$1", "focus": "m"}}, {"id": 363, "prop": "name", "attributes": {"content": "嘎嗚……", "name": "墨魎"}, "figure_art": "avg_npc_1427_1#1$1"}, {"id": 364, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#8$1", "focus": "m"}}, {"id": 365, "prop": "name", "attributes": {"content": "真的復活了嗎？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#8$1"}, {"id": 366, "prop": "name", "attributes": {"content": "也就是說，你們一直在這裡重複著死了又活的生活嗎？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#8$1"}, {"id": 367, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#18$1", "focus": "m"}}, {"id": 368, "prop": "name", "attributes": {"content": "嘿，這倒是很像我們在迷宮的生活。", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#18$1"}, {"id": 369, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1427_1#1$1", "focus": "m"}}, {"id": 370, "prop": "name", "attributes": {"content": "嘎嗚？", "name": "墨魎"}, "figure_art": "avg_npc_1427_1#1$1"}, {"id": 371, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#18$1", "focus": "m"}}, {"id": 372, "prop": "name", "attributes": {"content": "真是奇怪，有這樣的習性，你們去進攻鎮子又是為了什麼呢……？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#18$1"}, {"id": 373, "prop": "Dialog", "attributes": {}}, {"id": 374, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1427_1#1$1", "focus": "m"}}, {"id": 375, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 376, "prop": "charslot", "attributes": {"slot": "m", "action": "jump", "power": 50.0, "times": 1.0, "duration": 0.5, "isblock": "true"}}, {"id": 377, "prop": "charslot", "attributes": {"slot": "m", "action": "jump", "power": 50.0, "times": 1.0, "duration": 0.5, "isblock": "true"}}, {"id": 378, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 379, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#16$1", "focus": "m"}}, {"id": 380, "prop": "name", "attributes": {"content": "是想吃杏子嗎？", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#16$1"}, {"id": 381, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#18$1", "focus": "m"}}, {"id": 382, "prop": "name", "attributes": {"content": "嗯，我這裡還有最後一點……", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#18$1"}, {"id": 383, "prop": "Dialog", "attributes": {}}, {"id": 384, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 385, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 386, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 387, "prop": "Character", "attributes": {}}, {"id": 388, "prop": "charslot", "attributes": {}}, {"id": 389, "prop": "Image", "attributes": {}}, {"id": 390, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}