", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 131, "prop": "charslot", "attributes": {}}, {"id": 132, "prop": "Background", "attributes": {"image": "bg_barracks", "screenadapt": "showall"}}, {"id": 133, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 134, "prop": "playMusic", "attributes": {"intro": "$m_dia_street_intro", "key": "$m_dia_street_loop", "volume": 0.6}}, {"id": 135, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 136, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 137, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_534_1#1$1", "focus": "l"}}, {"id": 138, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_534_1#1$1", "focus": "l"}}, {"id": 139, "prop": "name", "attributes": {"content": "太好了，天災居然沒有毀掉我們的玉米地！這裡也沒有被沙塵暴侵襲，都好好的！", "name": "拓荒者A"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 140, "prop": "name", "attributes": {"content": "這幾天我一直擔心害怕的，玉米地要是沒了我們下半年就沒得吃也沒得賣了！", "name": "拓荒者A"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 141, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_534_1#1$1", "focus": "r"}}, {"id": 142, "prop": "name", "attributes": {"content": "老大，那我先去啟動無人機了？別的地方運氣可能沒我們這麼好，要是發現了我們這裡一點沒受損肯定會來搶的。", "name": "拓荒者B"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 143, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_534_1#1$1", "focus": "l"}}, {"id": 144, "prop": "name", "attributes": {"content": "去吧，記得調一下模式，別巡邏了，直接就是戰鬥模式。", "name": "拓荒者A"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 145, "prop": "name", "attributes": {"content": "對了，記得接一下那個羅德島的幹員，他今天災後回訪！", "name": "拓荒者A"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 146, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_534_1#1$1", "focus": "r"}}, {"id": 147, "prop": "name", "attributes": {"content": "好！", "name": "拓荒者B"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 148, "prop": "Dialog", "attributes": {}}, {"id": 149, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0, "channel": "2"}}, {"id": 150, "prop": "charslot", "attributes": {"slot": "r", "posfrom": "0,0", "posto": "200,0", "duration": 1.5}}, {"id": 151, "prop": "charslot", "attributes": {"slot": "r", "afrom": 1.0, "ato": 0.0, "duration": 0.5}}, {"id": 152, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 153, "prop": "charslot", "attributes": {"slot": "l", "focus": "none"}}, {"id": 154, "prop": "stopsound", "attributes": {"channel": "2"}}, {"id": 155, "prop": "name", "attributes": {"content": "嗯？不對啊……基站怎麼……", "name": "拓荒者B"}}, {"id": 156, "prop": "name", "attributes": {"content": "……無人機怎麼也完全不聽指揮……？訊號……老大，老大！！", "name": "拓荒者B"}}, {"id": 157, "prop": "Dialog", "attributes": {}}, {"id": 158, "prop": "stopsound", "attributes": {"channel": "2"}}, {"id": 159, "prop": "charslot", "attributes": {"slot": "l", "focus": "none"}}, {"id": 160, "prop": "name", "attributes": {"content": "——天、天災砸到了基站！無人機……失控了！", "name": "拓荒者B"}}, {"id": 161, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_534_1#1$1", "focus": "l"}}, {"id": 162, "prop": "name", "attributes": {"content": "別慌！先把基站停了！", "name": "拓荒者A"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 163, "prop": "charslot", "attributes": {"slot": "l", "focus": "none"}}, {"id": 164, "prop": "name", "attributes": {"content": "關不掉！", "name": "拓荒者B"}}, {"id": 165, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_534_1#1$1", "focus": "l"}}, {"id": 166, "prop": "name", "attributes": {"content": "*哥倫比亞俚語*！那你自己想辦法啊！白養你的嗎？", "name": "拓荒者A"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 167, "prop": "Dialog", "attributes": {}}, {"id": 168, "prop": "CameraShake", "attributes": {"duration": 1.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 169, "prop": "PlaySound", "attributes": {"key": "$d_avg_engingivup"}}, {"id": 170, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 171, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0, "channel": "2"}}, {"id": 172, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_534_1#1$1", "posfrom": "200,0", "posto": "0,0", "duration": 1.5}}, {"id": 173, "prop": "charslot", "attributes": {"slot": "r", "afrom": 0.0, "ato": 1.0, "duration": 0.5}}, {"id": 174, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 175, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_534_1#1$1", "focus": "r"}}, {"id": 176, "prop": "name", "attributes": {"content": "啊！！呃、呃，源石迴路……主線板……", "name": "拓荒者B"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 177, "prop": "Dialog", "attributes": {}}, {"id": 178, "prop": "charslot", "attributes": {}}, {"id": 179, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0, "channel": "2"}}, {"id": 180, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_090", "duration": 1.5}}, {"id": 181, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 182, "prop": "name", "attributes": {"content": "喂——你們這什麼狀況？！這麼不歡迎我？", "name": "羅德島外勤幹員"}, "figure_art": "avg_npc_090"}, {"id": 183, "prop": "Dialog", "attributes": {}}, {"id": 184, "prop": "charslot", "attributes": {}}, {"id": 185, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_534_1#1$1", "focus": "r"}}, {"id": 186, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_534_1#1$1", "focus": "r"}}, {"id": 187, "prop": "name", "attributes": {"content": "不是，不是！小錘子瑞恩，我記得你！你幫幫我，無人機失控了！", "name": "拓荒者B"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 188, "prop": "Dialog", "attributes": {}}, {"id": 189, "prop": "charslot", "attributes": {}}, {"id": 190, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_090", "focus": "m"}}, {"id": 191, "prop": "name", "attributes": {"content": "什麼？你稍微躲起來，我來幫你看看……", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 192, "prop": "Dialog", "attributes": {}}, {"id": 193, "prop": "charslot", "attributes": {}}, {"id": 194, "prop": "CameraShake", "attributes": {"duration": 1.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 195, "prop": "PlaySound", "attributes": {"key": "$d_gen_explo_n"}}, {"id": 196, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 197, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 198, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 199, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 200, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 1.0, "block": "true"}}, {"id": 201, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_534_1#1$1", "focus": "r"}}, {"id": 202, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_534_1#1$1", "focus": "r"}}, {"id": 203, "prop": "name", "attributes": {"content": "啊——誰？真的有人來趁亂搶劫？", "name": "拓荒者B"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 204, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_534_1#1$1", "focus": "l"}}, {"id": 205, "prop": "name", "attributes": {"content": "幹掉他們！！", "name": "拓荒者A"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 206, "prop": "Dialog", "attributes": {}}, {"id": 207, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 208, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 209, "prop": "charslot", "attributes": {}}, {"id": 210, "prop": "Background", "attributes": {"image": "bg_barracks", "screenadapt": "showall"}}, {"id": 211, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 212, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 213, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 214, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_090", "focus": "m"}}, {"id": 215, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 216, "prop": "PlaySound", "attributes": {"key": "$d_gen_transmissionget", "volume": 1.0, "channel": "2"}}, {"id": 217, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 218, "prop": "name", "attributes": {"content": "喂，任務記錄，這裡是瑞恩。", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 219, "prop": "name", "attributes": {"content": "首先是接回刻俄柏。呃……這個任務的難度有點高，情報顯示這孩子最後出現在這一帶，但是找起來可不簡單……", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 220, "prop": "name", "attributes": {"content": "然後，今天也是災後回訪的第一天，去“玉米窩”看一下情況，希望一切順……", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 221, "prop": "Dialog", "attributes": {}}, {"id": 222, "prop": "CameraShake", "attributes": {"duration": 1.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 223, "prop": "PlaySound", "attributes": {"key": "$d_gen_explo_n", "volume": 0.5}}, {"id": 224, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 225, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_090", "focus": "m"}}, {"id": 226, "prop": "name", "attributes": {"content": "什麼情況？！拓荒地打起來了？", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 227, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_090", "focus": "none"}}, {"id": 228, "prop": "name", "attributes": {"content": "啊！！呃、呃，源石迴路……主線板……", "name": "拓荒者B"}}, {"id": 229, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_090", "focus": "m"}}, {"id": 230, "prop": "name", "attributes": {"content": "（……沒看到外人？是他們自己內部出了問題？）", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 231, "prop": "name", "attributes": {"content": "（先試探一下吧……這群人都不是什麼好惹的……）", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 232, "prop": "Dialog", "attributes": {}}, {"id": 233, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 234, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 235, "prop": "charslot", "attributes": {}}, {"id": 236, "prop": "Background", "attributes": {"image": "bg_barracks", "screenadapt": "showall"}}, {"id": 237, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 238, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 239, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 240, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0, "channel": "2"}}, {"id": 241, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_090", "duration": 1.5}}, {"id": 242, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 243, "prop": "name", "attributes": {"content": "喂——你們這什麼狀況？！這麼不歡迎我？", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 244, "prop": "Dialog", "attributes": {}}, {"id": 245, "prop": "charslot", "attributes": {}}, {"id": 246, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_534_1#1$1", "focus": "r"}}, {"id": 247, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_534_1#1$1", "focus": "r"}}, {"id": 248, "prop": "name", "attributes": {"content": "不是，不是！小錘子瑞恩，我記得你！你幫幫我，無人機失控了！", "name": "拓荒者B"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 249, "prop": "Dialog", "attributes": {}}, {"id": 250, "prop": "charslot", "attributes": {}}, {"id": 251, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_090", "focus": "m"}}, {"id": 252, "prop": "name", "attributes": {"content": "（呼……還好，只是無人機失控，要是拓荒地亂了我就完蛋在這裡了……）", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 253, "prop": "name", "attributes": {"content": "什麼？你稍微躲起來，我來幫你看看……", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 254, "prop": "Dialog", "attributes": {}}, {"id": 255, "prop": "CameraShake", "attributes": {"duration": 1.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 256, "prop": "PlaySound", "attributes": {"key": "$d_gen_explo_n", "volume": 0.5}}, {"id": 257, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 258, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_090", "focus": "m"}}, {"id": 259, "prop": "name", "attributes": {"content": "咳咳咳咳咳！！", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 260, "prop": "name", "attributes": {"content": "（糟了，真是外面的拓荒者動手了！）", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 261, "prop": "Dialog", "attributes": {}}, {"id": 262, "prop": "charslot", "attributes": {}}, {"id": 263, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_534_1#1$1", "focus": "r"}}, {"id": 264, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_534_1#1$1", "focus": "r"}}, {"id": 265, "prop": "name", "attributes": {"content": "啊——誰？真的有人來趁亂搶劫？", "name": "拓荒者B"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 266, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_534_1#1$1", "focus": "l"}}, {"id": 267, "prop": "name", "attributes": {"content": "幹掉他們！！", "name": "拓荒者A"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 268, "prop": "Dialog", "attributes": {}}, {"id": 269, "prop": "charslot", "attributes": {}}, {"id": 270, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_090", "focus": "m"}}, {"id": 271, "prop": "name", "attributes": {"content": "（不行，我在這要是被當成羅德島參與拓荒地紛爭可就完了，先、先保護住他們，最好能調節一下矛盾——）", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 272, "prop": "name", "attributes": {"content": "大哥別衝動！對面多少人還不知道，我們先找掩體躲起來！", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 273, "prop": "Dialog", "attributes": {}}, {"id": 274, "prop": "charslot", "attributes": {}}, {"id": 275, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_534_1#1$1", "focus": "l"}}, {"id": 276, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_534_1#1$1", "focus": "l"}}, {"id": 277, "prop": "name", "attributes": {"content": "*粗口*老子都看到了，就四個人！其中還有兩個矮子，打爆他們！！", "name": "拓荒者A"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 278, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_534_1#1$1", "focus": "r"}}, {"id": 279, "prop": "name", "attributes": {"content": "衝啊！！", "name": "拓荒者B"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 280, "prop": "Dialog", "attributes": {}}, {"id": 281, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0}}, {"id": 282, "prop": "charslot", "attributes": {"duration": 1.5}}, {"id": 283, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 284, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_090", "focus": "m"}}, {"id": 285, "prop": "name", "attributes": {"content": "不——", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 286, "prop": "name", "attributes": {"content": "……嗯？就四個人？這什麼打劫組合？", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 287, "prop": "Dialog", "attributes": {}}, {"id": 288, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 289, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 290, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 291, "prop": "charslot", "attributes": {}}, {"id": 292, "prop": "Background", "attributes": {"image": "27_g26_dusk_wild", "screenadapt": "showall"}}, {"id": 293, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 294, "prop": "playMusic", "attributes": {"intro": "$normal02_intro", "key": "$normal02_loop", "volume": 0.6}}, {"id": 295, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 296, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 297, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#9$1", "focus": "m"}}, {"id": 298, "prop": "name", "attributes": {"content": "……兩撥人？小心點，他們手裡都拿著武器，還有那種瑪露希爾都沒辦法對付的魔法器具，不要輕舉妄動。", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#9$1"}, {"id": 299, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#13$1", "focus": "m"}}, {"id": 300, "prop": "name", "attributes": {"content": "氣死我了！我的頭髮都被炸亂了！我很喜歡這個編髮的啊！", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#13$1"}, {"id": 301, "prop": "Dialog", "attributes": {}}, {"id": 302, "prop": "charslot", "attributes": {}}, {"id": 303, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_534_1#1$1", "focus": "l"}}, {"id": 304, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_534_1#1$1", "focus": "l"}}, {"id": 305, "prop": "name", "attributes": {"content": "*粗口*以為老子是好惹的嗎？就四個人也敢炸我的糧倉？！", "name": "拓荒者A"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 306, "prop": "Dialog", "attributes": {}}, {"id": 307, "prop": "charslot", "attributes": {}}, {"id": 308, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_090", "focus": "m"}}, {"id": 309, "prop": "name", "attributes": {"content": "不！等等！幾位有話好好說！無人機還在天上亂飛，真的要現在就打起來嗎？", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 310, "prop": "Dialog", "attributes": {}}, {"id": 311, "prop": "charslot", "attributes": {}}, {"id": 312, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_534_1#1$1", "focus": "l"}}, {"id": 313, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_534_1#1$1", "focus": "l"}}, {"id": 314, "prop": "name", "attributes": {"content": "放屁！老子自己的無人機，還能把老子打死嗎？", "name": "拓荒者A"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 315, "prop": "Dialog", "attributes": {}}, {"id": 316, "prop": "charslot", "attributes": {}}, {"id": 317, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#13$1", "focus": "m"}}, {"id": 318, "prop": "name", "attributes": {"content": "明明是他們什麼都不說，單方面地攻擊我們！", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#13$1"}, {"id": 319, "prop": "Dialog", "attributes": {}}, {"id": 320, "prop": "charslot", "attributes": {}}, {"id": 321, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_534_1#1$1", "focus": "l"}}, {"id": 322, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_534_1#1$1", "focus": "l"}}, {"id": 323, "prop": "name", "attributes": {"content": "敢來炸我的糧倉，找死——", "name": "拓荒者A"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 324, "prop": "Dialog", "attributes": {}}, {"id": 325, "prop": "charslot", "attributes": {}}, {"id": 326, "prop": "PlaySound", "attributes": {"key": "$d_avg_drone", "volume": 1.0, "channel": "2"}}, {"id": 327, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1420_1#1$1", "posfrom": "200,150", "posto": "0,0", "duration": 1.5}}, {"id": 328, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1428_1#1$1", "posfrom": "200,0", "posto": "0,150", "duration": 1.5}}, {"id": 329, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1428_1#1$1", "posfrom": "200,-100", "posto": "0,-150", "duration": 1.5}}, {"id": 330, "prop": "charslot", "attributes": {"slot": "m", "afrom": 0.0, "ato": 1.0, "duration": 0.5}}, {"id": 331, "prop": "charslot", "attributes": {"slot": "l", "afrom": 0.0, "ato": 1.0, "duration": 0.5}}, {"id": 332, "prop": "charslot", "attributes": {"slot": "r", "afrom": 0.0, "ato": 1.0, "duration": 0.5}}, {"id": 333, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 334, "prop": "PlaySound", "attributes": {"key": "$d_avg_drone", "volume": 1.0, "channel": "2"}}, {"id": 335, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,0", "posto": "-200,0", "duration": 1.5}}, {"id": 336, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "0,150", "posto": "-200,150", "duration": 1.5}}, {"id": 337, "prop": "charslot", "attributes": {"slot": "r", "posfrom": "0,-150", "posto": "-200,-150", "duration": 1.5}}, {"id": 338, "prop": "charslot", "attributes": {"slot": "m", "afrom": 1.0, "ato": 0.0, "duration": 0.5}}, {"id": 339, "prop": "charslot", "attributes": {"slot": "l", "afrom": 1.0, "ato": 0.0, "duration": 0.5}}, {"id": 340, "prop": "charslot", "attributes": {"slot": "r", "afrom": 1.0, "ato": 0.0, "duration": 0.5}}, {"id": 341, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 342, "prop": "charslot", "attributes": {}}, {"id": 343, "prop": "charslot", "attributes": {}}, {"id": 344, "prop": "charslot", "attributes": {}}, {"id": 345, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 346, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#9$1", "focus": "m"}}, {"id": 347, "prop": "name", "attributes": {"content": "他們動手了，保護好自己，上！", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#9$1"}, {"id": 348, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4141_marcil_1#4$1", "focus": "m"}}, {"id": 349, "prop": "name", "attributes": {"content": "果然，這些魔法器具都是他們操控的！", "name": "瑪露希爾"}, "figure_art": "avg_4141_marcil_1#4$1"}, {"id": 350, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_090", "focus": "m"}}, {"id": 351, "prop": "name", "attributes": {"content": "唉呦……唉呦……都是老頑固，都勸不動啊……！", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 352, "prop": "name", "attributes": {"content": "在荒野上打架不知道會引來什麼啊，大家先停下來，有話好好說不好嗎？", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 353, "prop": "Dialog", "attributes": {}}, {"id": 354, "prop": "charslot", "attributes": {}}, {"id": 355, "prop": "name", "attributes": {"content": "彷彿是腳下的大地在這一刻聽到了他誠懇的祈求一般，地面突然發出劇烈的轟鳴。"}}, {"id": 356, "prop": "name", "attributes": {"content": "難道又是天災？這個念頭剛在幾人的腦中出現，隨即又被接下來的景象徹底擊碎。"}}, {"id": 357, "prop": "Dialog", "attributes": {}}, {"id": 358, "prop": "CameraShake", "attributes": {"duration": 1.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 359, "prop": "PlaySound", "attributes": {"key": "$a_bat_buildingshaking_1"}}, {"id": 360, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1423_1#1$1", "duration": 1.5}}, {"id": 361, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1423_1#1$1", "duration": 1.5}}, {"id": 362, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1423_1#1$1", "duration": 1.5}}, {"id": 363, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 364, "prop": "PlaySound", "attributes": {"key": "$a_bat_buildingshaking_2"}}, {"id": 365, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,0", "posto": "-200,0", "duration": 1.5}}, {"id": 366, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "0,0", "posto": "-250,0", "duration": 1.5}}, {"id": 367, "prop": "charslot", "attributes": {"slot": "r", "posfrom": "0,0", "posto": "-150,0", "duration": 1.5}}, {"id": 368, "prop": "charslot", "attributes": {"slot": "m", "afrom": 1.0, "ato": 0.0, "duration": 1.0}}, {"id": 369, "prop": "charslot", "attributes": {"slot": "l", "afrom": 1.0, "ato": 0.0, "duration": 1.0}}, {"id": 370, "prop": "charslot", "attributes": {"slot": "r", "afrom": 1.0, "ato": 0.0, "duration": 1.0}}, {"id": 371, "prop": "name", "attributes": {"content": "一大群如浪潮般的鉗獸似乎是終於不想再忍受無人機在自己的頭頂狂轟濫炸，整齊地高舉著自己的雙鉗，直向眾人而來——"}}, {"id": 372, "prop": "Dialog", "attributes": {}}, {"id": 373, "prop": "charslot", "attributes": {}}, {"id": 374, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4142_laios_1#8$1", "focus": "m"}}, {"id": 375, "prop": "name", "attributes": {"content": "——魔物群？！", "name": "萊歐斯"}, "figure_art": "avg_4142_laios_1#8$1"}, {"id": 376, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4143_sensi_1#5$1", "focus": "m"}}, {"id": 377, "prop": "name", "attributes": {"content": "快跑！只有我們四個打不過的！", "name": "先西"}, "figure_art": "avg_4143_sensi_1#5$1"}, {"id": 378, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4144_chilc_1#15$1", "focus": "m"}}, {"id": 379, "prop": "name", "attributes": {"content": "沒、沒有路了！牠們把我們包圍起來了！", "name": "奇爾查克"}, "figure_art": "avg_4144_chilc_1#15$1"}, {"id": 380, "prop": "multiline", "attributes": {"name": "奇爾查克", "content": "先往後退……"}}, {"id": 381, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,0", "posto": "-200,0", "duration": 1.5}}, {"id": 382, "prop": "charslot", "attributes": {"slot": "m", "afrom": 1.0, "ato": 0.0, "duration": 1.0}}, {"id": 383, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 384, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 10.0, "ystrength": 10.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 385, "prop": "PlaySound", "attributes": {"key": "$fightgeneral"}}, {"id": 386, "prop": "multiline", "attributes": {"name": "奇爾查克", "end": "true", "content": "哎呀！", "joined": "先往後退……哎呀！"}}, {"id": 387, "prop": "Dialog", "attributes": {}}, {"id": 388, "prop": "charslot", "attributes": {}}, {"id": 389, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_534_1#1$1", "focus": "l"}}, {"id": 390, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_534_1#1$1", "focus": "l"}}, {"id": 391, "prop": "name", "attributes": {"content": "——哎呀！誰不長眼撞老子？！老子一錘子——怎麼是你們？", "name": "拓荒者A"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 392, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_534_1#1$1", "focus": "r"}}, {"id": 393, "prop": "name", "attributes": {"content": "老大，沒有路了，我們都被這群鉗獸包圍了！", "name": "拓荒者B"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 394, "prop": "Dialog", "attributes": {}}, {"id": 395, "prop": "charslot", "attributes": {}}, {"id": 396, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_090", "focus": "m"}}, {"id": 397, "prop": "name", "attributes": {"content": "幾位，拜託了，聽我的吧，我們先一起對付牠們，好不好？", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 398, "prop": "Dialog", "attributes": {}}, {"id": 399, "prop": "charslot", "attributes": {}}, {"id": 400, "prop": "PlaySound", "attributes": {"key": "$d_avg_drone", "volume": 1.0, "channel": "2"}}, {"id": 401, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1428_1#1$1", "posfrom": "-200,0", "posto": "-100,0", "duration": 1.5}}, {"id": 402, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1420_1#1$1", "posfrom": "0,100", "posto": "0,0", "duration": 1.5}}, {"id": 403, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1428_1#1$1", "posfrom": "200,0", "posto": "100,0", "duration": 1.5}}, {"id": 404, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 405, "prop": "charslot", "attributes": {}}, {"id": 406, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_090", "focus": "m"}}, {"id": 407, "prop": "name", "attributes": {"content": "還、還有無人機！", "name": "瑞恩"}, "figure_art": "avg_npc_090"}, {"id": 408, "prop": "Dialog", "attributes": {}}, {"id": 409, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 410, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 411, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 412, "prop": "charslot", "attributes": {}}, {"id": 413, "prop": "Image", "attributes": {}}, {"id": 414, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}