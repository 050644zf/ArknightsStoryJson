: 206, "prop": "BackgroundTween", "attributes": {"xTo": 50.0, "duration": 1.0, "block": "true"}}, {"id": 207, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 208, "prop": "BackgroundTween", "attributes": {"xFrom": 50.0, "xTo": 0.0, "duration": 0.7, "block": "true"}}, {"id": 209, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 210, "prop": "BackgroundTween", "attributes": {"xScaleFrom": 1.1, "yScaleFrom": 1.1, "xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 0.5, "block": "true"}}, {"id": 211, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 212, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_867_1#1$1", "duration": 0.5}}, {"id": 213, "prop": "Delay", "attributes": {"time": 0.7}}, {"id": 214, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_867_1#1$1", "focus": "m"}}, {"id": 215, "prop": "name", "attributes": {"content": "（車廂內的總人數明顯超過了。）", "name": "怪帽子外國佬"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 216, "prop": "name", "attributes": {"content": "（當地平民和觀光客的人數基本上持平，唔，作為觀光列車，這倒是少見。）", "name": "怪帽子外國佬"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 217, "prop": "name", "attributes": {"content": "（最後排靠牆角堆放的麻袋有點古怪……麻袋內有異動，是違規攜帶的活物？）", "name": "怪帽子外國佬"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 218, "prop": "name", "attributes": {"content": "（唔，沒有其他異常，也沒有值得在意的人物……）", "name": "怪帽子外國佬"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 219, "prop": "name", "attributes": {"content": "（情報只指向開往銀心湖的列車，實際線索果然沒有那麼好找。）", "name": "怪帽子外國佬"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 220, "prop": "name", "attributes": {"content": "（還是得找個機會去包廂檢查一下……）", "name": "怪帽子外國佬"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 221, "prop": "Dialog", "attributes": {}}, {"id": 222, "prop": "stopsound", "attributes": {"channel": "slide", "fadetime": 1.5}}, {"id": 223, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_867_1#1$1", "focus": "n"}}, {"id": 224, "prop": "Delay", "attributes": {"time": 0.2}}, {"id": 225, "prop": "playsound", "attributes": {"key": "$d_avg_cardoorc", "volume": 0.4}}, {"id": 226, "prop": "name", "attributes": {"content": "咚。"}}, {"id": 227, "prop": "Dialog", "attributes": {}}, {"id": 228, "prop": "playsound", "attributes": {"key": "$d_avg_cardoorc", "volume": 0.2}}, {"id": 229, "prop": "PlaySound", "attributes": {"key": "$d_avg_cardoorc", "volume": 0.4, "loop": "false", "channel": "kk", "delay": 0.3}}, {"id": 230, "prop": "name", "attributes": {"content": "咚咚。"}}, {"id": 231, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_867_1#1$1", "focus": "m"}}, {"id": 232, "prop": "name", "attributes": {"content": "……", "name": "怪帽子外國佬"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 233, "prop": "Dialog", "attributes": {}}, {"id": 234, "prop": "charslot", "attributes": {}}, {"id": 235, "prop": "name", "attributes": {"content": "從剛剛起，椅背後方就一直傳來異動。"}}, {"id": 236, "prop": "name", "attributes": {"content": "謝拉格的列車上，難道有什麼專門踢人椅背的怪獸嗎？"}}, {"id": 237, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_867_1#1$1", "focus": "m"}}, {"id": 238, "prop": "name", "attributes": {"content": "…………", "name": "怪帽子外國佬"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 239, "prop": "Dialog", "attributes": {}}, {"id": 240, "prop": "charslot", "attributes": {}}, {"id": 241, "prop": "playsound", "attributes": {"key": "$d_avg_cardoorc", "volume": 0.4}}, {"id": 242, "prop": "PlaySound", "attributes": {"key": "$d_avg_cardoorc", "volume": 0.4, "loop": "false", "channel": "kk1", "delay": 0.2}}, {"id": 243, "prop": "PlaySound", "attributes": {"key": "$d_avg_cardoorc", "volume": 0.4, "loop": "false", "channel": "kk2", "delay": 0.4}}, {"id": 244, "prop": "PlaySound", "attributes": {"key": "$d_avg_cardoorc", "volume": 0.4, "loop": "false", "channel": "kk3", "delay": 0.6}}, {"id": 245, "prop": "PlaySound", "attributes": {"key": "$d_avg_cardoorc", "volume": 0.4, "loop": "false", "channel": "kk4", "delay": 0.8}}, {"id": 246, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 247, "prop": "name", "attributes": {"content": "咚咚咚咚咚。"}}, {"id": 248, "prop": "name", "attributes": {"content": "像是對他的無反應感到不滿，椅背又被連續踢了好幾下。"}}, {"id": 249, "prop": "name", "attributes": {"content": "片刻之後，坐在後排的孩子探出頭來。"}}, {"id": 250, "prop": "name", "attributes": {"content": "怪帽子叔叔，怪帽子叔叔。", "name": "淘氣的小孩"}}, {"id": 251, "prop": "name", "attributes": {"content": "叔叔，你是不是特別喜歡坐車啊，前兩天我也看到你了！", "name": "淘氣的小孩"}}, {"id": 252, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_867_1#1$1", "focus": "m"}}, {"id": 253, "prop": "name", "attributes": {"content": "……你見過我？", "name": "怪帽子外國佬"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 254, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_867_1#1$1", "focus": "n"}}, {"id": 255, "prop": "name", "attributes": {"content": "見過！", "name": "淘氣的小孩"}}, {"id": 256, "prop": "name", "attributes": {"content": "叔叔，你是不是之前沒看過鐵軌和火車，所以才特別喜歡坐車啊？", "name": "淘氣的小孩"}}, {"id": 257, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_867_1#1$1", "focus": "m"}}, {"id": 258, "prop": "name", "attributes": {"content": "咳咳。", "name": "怪帽子外國佬"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 259, "prop": "Dialog", "attributes": {}}, {"id": 260, "prop": "charslot", "attributes": {}}, {"id": 261, "prop": "name", "attributes": {"content": "叔叔你怎麼還咳嗽了啊？別害羞，我不會取笑你的！", "name": "淘氣的小孩"}}, {"id": 262, "prop": "name", "attributes": {"content": "我們這的火車可是很厲害的，我也好喜歡啊！我媽說，都是聖女大人和恩希歐迪斯老爺厲害，是耶拉岡德保佑我們呢！", "name": "淘氣的小孩"}}, {"id": 263, "prop": "name", "attributes": {"content": "不如……我把我的小火車玩具借給你，我們一起玩開火車遊戲吧，叔叔！", "name": "淘氣的小孩"}}, {"id": 264, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_281_1#1$1", "focus": "m"}}, {"id": 265, "prop": "name", "attributes": {"content": "玩什麼玩具！你乖乖回來坐好，別去煩人家！", "name": "急躁的母親"}, "figure_art": "avg_npc_281_1#1$1"}, {"id": 266, "prop": "name", "attributes": {"content": "實在不好意思啊，先生，打擾你了。", "name": "急躁的母親"}, "figure_art": "avg_npc_281_1#1$1"}, {"id": 267, "prop": "name", "attributes": {"content": "這孩子就是欠教訓，我一定好好管教他！", "name": "急躁的母親"}, "figure_art": "avg_npc_281_1#1$1"}, {"id": 268, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_867_1#1$1", "focus": "m"}}, {"id": 269, "prop": "name", "attributes": {"content": "不，沒什麼……", "name": "怪帽子外國佬"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 270, "prop": "name", "attributes": {"content": "（……）", "name": "怪帽子外國佬"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 271, "prop": "name", "attributes": {"content": "（這頂帽子……）", "name": "怪帽子外國佬"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 272, "prop": "name", "attributes": {"content": "（看起來很奇怪嗎？）", "name": "怪帽子外國佬"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 273, "prop": "Dialog", "attributes": {}}, {"id": 274, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 275, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 276, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 277, "prop": "charslot", "attributes": {}}, {"id": 278, "prop": "Background", "attributes": {"image": "45_g2_trainwalkway", "screenadapt": "coverall", "block": "true"}}, {"id": 279, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#1$1"}}, {"id": 280, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 281, "prop": "PlayMusic", "attributes": {"key": "$chill_loop", "volume": 0.6}}, {"id": 282, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 283, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 284, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#4$1", "focus": "m"}}, {"id": 285, "prop": "name", "attributes": {"content": "今天的乘客可真不少，新建成的耶拉岡德像看來確實是很受歡迎！", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#4$1"}, {"id": 286, "prop": "multiline", "attributes": {"name": "哈洛德", "content": "每次上車我都覺得，卡西米爾騎士競技的比賽現場——"}}, {"id": 287, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#8$1", "focus": "m"}}, {"id": 288, "prop": "charslot", "attributes": {"slot": "m", "action": "shake", "random": "true", "power": 5.0, "times": 60.0, "duration": 0.3}}, {"id": 289, "prop": "multiline", "attributes": {"name": "哈洛德", "content": "哎喲！有什麼東西在攻擊我的腳趾！"}}, {"id": 290, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#6$1", "focus": "m"}}, {"id": 291, "prop": "name", "attributes": {"content": "這是……羽獸？", "name": "烈夏"}, "figure_art": "avg_194_leto_1#6$1"}, {"id": 292, "prop": "Dialog", "attributes": {}}, {"id": 293, "prop": "charslot", "attributes": {}}, {"id": 294, "prop": "name", "attributes": {"content": "（用力啄咬）", "name": "出逃的羽獸"}}, {"id": 295, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#6$1", "focus": "m"}}, {"id": 296, "prop": "name", "attributes": {"content": "欸、欸欸欸，羽獸兄，高抬貴“首”……！", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#6$1"}, {"id": 297, "prop": "name", "attributes": {"content": "欸！", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#6$1"}, {"id": 298, "prop": "Dialog", "attributes": {}}, {"id": 299, "prop": "charslot", "attributes": {}}, {"id": 300, "prop": "PlaySound", "attributes": {"key": "$d_avg_wing", "volume": 1.0}}, {"id": 301, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 302, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "focus": "r"}}, {"id": 303, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_194_leto_1#13$1", "focus": "r"}}, {"id": 304, "prop": "name", "attributes": {"content": "就這樣把它放了？", "name": "烈夏"}, "figure_art": "avg_194_leto_1#13$1"}, {"id": 305, "prop": "name", "attributes": {"content": "沒問題嗎？我怎麼記得車上好像說是不能帶寵物的？", "name": "烈夏"}, "figure_art": "avg_194_leto_1#13$1"}, {"id": 306, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "focus": "l"}}, {"id": 307, "prop": "name", "attributes": {"content": "規矩是這麼定的，不過呢，有的時候不會查得太嚴，也算是給有需要的老鄉們行個方便嘛。", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 308, "prop": "name", "attributes": {"content": "放心，這種羽獸一般都會用麻袋裝著，不會出太大問題。", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 309, "prop": "name", "attributes": {"content": "不說這些。來吧，女士，我訂的包廂就在前面。", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 310, "prop": "Dialog", "attributes": {}}, {"id": 311, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "focus": "all"}}, {"id": 312, "prop": "delay", "attributes": {"time": 0.2}}, {"id": 313, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.6}}, {"id": 314, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 315, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 316, "prop": "Dialog", "attributes": {}}, {"id": 317, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 318, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 319, "prop": "charslot", "attributes": {}}, {"id": 320, "prop": "Background", "attributes": {"image": "45_g3_traincarriage", "screenadapt": "coverall", "block": "true"}}, {"id": 321, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 322, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 323, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 324, "prop": "PlaySound", "attributes": {"key": "$d_avg_cloakmovement", "volume": 1.0}}, {"id": 325, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "duration": 0.7}}, {"id": 326, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_194_leto_1#1$1", "duration": 0.7}}, {"id": 327, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 328, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_194_leto_1#1$1", "focus": "r"}}, {"id": 329, "prop": "name", "attributes": {"content": "呼……哈！", "name": "烈夏"}, "figure_art": "avg_194_leto_1#1$1"}, {"id": 330, "prop": "name", "attributes": {"content": "擠死我了，終於又能坐下來了！", "name": "烈夏"}, "figure_art": "avg_194_leto_1#1$1"}, {"id": 331, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_194_leto_1#8$1", "focus": "r"}}, {"id": 332, "prop": "name", "attributes": {"content": "沒想到這趟車的坐票這麼難買，這次真是多謝你幫忙，大叔！", "name": "烈夏"}, "figure_art": "avg_194_leto_1#8$1"}, {"id": 333, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "focus": "l"}}, {"id": 334, "prop": "name", "attributes": {"content": "舉手之勞，女士。", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 335, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_194_leto_1#8$1", "focus": "r"}}, {"id": 336, "prop": "name", "attributes": {"content": "對我不用這麼客氣，也別女士女士的了，叫我羅莎琳就行。", "name": "烈夏"}, "figure_art": "avg_194_leto_1#8$1"}, {"id": 337, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#14$1", "focus": "l"}}, {"id": 338, "prop": "multiline", "attributes": {"name": "哈洛德", "content": "那麼恭敬不如從命……"}}, {"id": 339, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "focus": "l"}}, {"id": 340, "prop": "multiline", "attributes": {"name": "哈洛德", "content": "“羅莎琳”，這是一個很適合你的名字。非常動聽。"}}, {"id": 341, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_194_leto_1#1$1", "focus": "r"}}, {"id": 342, "prop": "name", "attributes": {"content": "嘿嘿，好聽吧，是我媽取的。", "name": "烈夏"}, "figure_art": "avg_194_leto_1#1$1"}, {"id": 343, "prop": "name", "attributes": {"content": "大叔你叫什麼？", "name": "烈夏"}, "figure_art": "avg_194_leto_1#1$1"}, {"id": 344, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "focus": "l"}}, {"id": 345, "prop": "name", "attributes": {"content": "你可以稱呼我為哈洛德。當然，繼續叫“大叔”也沒問題。", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 346, "prop": "name", "attributes": {"content": "你的運氣不錯，羅莎琳。如果錯過這班車，恐怕就很難在天黑之前抵達銀心湖了。", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 347, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_194_leto_1#6$1", "focus": "r"}}, {"id": 348, "prop": "name", "attributes": {"content": "真的？", "name": "烈夏"}, "figure_art": "avg_194_leto_1#6$1"}, {"id": 349, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_194_leto_1#8$1", "focus": "r"}}, {"id": 350, "prop": "name", "attributes": {"content": "嘿，幸好最後還是趕上了。", "name": "烈夏"}, "figure_art": "avg_194_leto_1#8$1"}, {"id": 351, "prop": "name", "attributes": {"content": "哈洛德也是要去銀心湖吧？你是要去那裡幹嘛來著？", "name": "烈夏"}, "figure_art": "avg_194_leto_1#8$1"}, {"id": 352, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "focus": "l"}}, {"id": 353, "prop": "name", "attributes": {"content": "我想我已經回答過這個問題了？", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 354, "prop": "name", "attributes": {"content": "謝拉格的風光如此壯美，我當然是要去一飽眼福的啦。", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 355, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_194_leto_1#1$1", "focus": "r"}}, {"id": 356, "prop": "name", "attributes": {"content": "我可不會被騙到，你們這一大群人，看起來一點都不像是來觀光的。", "name": "烈夏"}, "figure_art": "avg_194_leto_1#1$1"}, {"id": 357, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#16$1", "focus": "l"}}, {"id": 358, "prop": "name", "attributes": {"content": "我們看著不像觀光客嗎？", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#16$1"}, {"id": 359, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_194_leto_1#8$1", "focus": "r"}}, {"id": 360, "prop": "name", "attributes": {"content": "不太像。", "name": "烈夏"}, "figure_art": "avg_194_leto_1#8$1"}, {"id": 361, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_194_leto_1#9$1", "focus": "r"}}, {"id": 362, "prop": "name", "attributes": {"content": "呃，更像是來找麻煩的。", "name": "烈夏"}, "figure_art": "avg_194_leto_1#9$1"}, {"id": 363, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#4$1", "focus": "l"}}, {"id": 364, "prop": "name", "attributes": {"content": "啊，哈哈，找麻煩？絕無此事！", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#4$1"}, {"id": 365, "prop": "name", "attributes": {"content": "我可是已經被謝拉格的風景人文迷得神魂顛倒，甚至開始考慮退休之後要不要乾脆來這裡養老了呢！", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#4$1"}, {"id": 366, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "focus": "l"}}, {"id": 367, "prop": "name", "attributes": {"content": "嗯，嗯，只要不出大問題，我們當然就可以是觀光客……", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 368, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_194_leto_1#13$1", "focus": "r"}}, {"id": 369, "prop": "name", "attributes": {"content": "那要是——", "name": "烈夏"}, "figure_art": "avg_194_leto_1#13$1"}, {"id": 370, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "focus": "l"}}, {"id": 371, "prop": "name", "attributes": {"content": "——那你呢，羅莎琳？", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 372, "prop": "name", "attributes": {"content": "在遊客裡，你的謝拉格語算是說得很不錯了，這是你頭一次來謝拉格？", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 373, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_194_leto_1#5$1", "focus": "r"}}, {"id": 374, "prop": "name", "attributes": {"content": "你這話題轉移得也太生硬了！", "name": "烈夏"}, "figure_art": "avg_194_leto_1#5$1"}, {"id": 375, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#6$1", "focus": "l"}}, {"id": 376, "prop": "name", "attributes": {"content": "哈哈。", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#6$1"}, {"id": 377, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_194_leto_1#8$1", "focus": "r"}}, {"id": 378, "prop": "name", "attributes": {"content": "算了。我沒有說過嗎？", "name": "烈夏"}, "figure_art": "avg_194_leto_1#8$1"}, {"id": 379, "prop": "name", "attributes": {"content": "我勉強算是半個謝拉格人吧，雖然我自己完全沒什麼感覺啦，我是跟著我媽在烏薩斯長大的。", "name": "烈夏"}, "figure_art": "avg_194_leto_1#8$1"}, {"id": 380, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "focus": "l"}}, {"id": 381, "prop": "name", "attributes": {"content": "哦，令堂是烏薩斯人？", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 382, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_194_leto_1#8$1", "focus": "r"}}, {"id": 383, "prop": "name", "attributes": {"content": "對。不過我媽告訴我說，我是在謝拉格出生的，我爸是個謝拉格人……", "name": "烈夏"}, "figure_art": "avg_194_leto_1#8$1"}, {"id": 384, "prop": "name", "attributes": {"content": "小時候的事我記不太清楚了，要說是旅行的話，也算是吧。", "name": "烈夏"}, "figure_art": "avg_194_leto_1#8$1"}, {"id": 385, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "focus": "l"}}, {"id": 386, "prop": "name", "attributes": {"content": "唔，原來如此。", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 387, "prop": "name", "attributes": {"content": "這麼說來，從見面起我就一直想問……", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 388, "prop": "name", "attributes": {"content": "羅莎琳，你一直抱在懷裡的盒子是什麼？", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 389, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_194_leto_1#7$1", "focus": "r"}}, {"id": 390, "prop": "name", "attributes": {"content": "這是……", "name": "烈夏"}, "figure_art": "avg_194_leto_1#7$1"}, {"id": 391, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_194_leto_1#2$1", "focus": "r"}}, {"id": 392, "prop": "name", "attributes": {"content": "……", "name": "烈夏"}, "figure_art": "avg_194_leto_1#2$1"}, {"id": 393, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "focus": "l"}}, {"id": 394, "prop": "name", "attributes": {"content": "抱歉，如果有冒犯到你的個人隱私，你可以什麼都不用說。", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 395, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_194_leto_1#9$1", "focus": "r"}}, {"id": 396, "prop": "name", "attributes": {"content": "沒事。也沒什麼不好說的，我只是在想該怎麼說……", "name": "烈夏"}, "figure_art": "avg_194_leto_1#9$1"}, {"id": 397, "prop": "name", "attributes": {"content": "這是我媽託付給我的……遺物。", "name": "烈夏"}, "figure_art": "avg_194_leto_1#9$1"}, {"id": 398, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#16$1", "focus": "l"}}, {"id": 399, "prop": "name", "attributes": {"content": "這……", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#16$1"}, {"id": 400, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#12$1", "focus": "l"}}, {"id": 401, "prop": "name", "attributes": {"content": "請容許我表達哀悼之情。", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#12$1"}, {"id": 402, "prop": "name", "attributes": {"content": "我很抱歉提及你的傷心之事，羅莎琳。", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#12$1"}, {"id": 403, "prop": "name", "attributes": {"content": "節哀。", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#12$1"}, {"id": 404, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_194_leto_1#8$1", "focus": "r"}}, {"id": 405, "prop": "name", "attributes": {"content": "嘁，我有什麼好傷心的？", "name": "烈夏"}, "figure_art": "avg_194_leto_1#8$1"}, {"id": 406, "prop": "name", "attributes": {"content": "我這次回來，就是為了完成我媽的心願。", "name": "烈夏"}, "figure_art": "avg_194_leto_1#8$1"}, {"id": 407, "prop": "Dialog", "attributes": {}}, {"id": 408, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 409, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 410, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 411, "prop": "charslot", "attributes": {}}, {"id": 412, "prop": "Background", "attributes": {"image": "24_g7_thoroughfare", "screenadapt": "coverall", "block": "true"}}, {"id": 413, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 414, "prop": "PlayMusic", "attributes": {"intro": "$mist_intro", "key": "$mist_loop", "volume": 0.6}}, {"id": 415, "prop": "PlaySound", "attributes": {"key": "$d_avg_snowstormflp", "volume": 0.4, "loop": "true", "channel": "wind1"}}, {"id": 416, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 417, "prop": "StopSound", "attributes": {"channel": "wind1", "fadetime": 2.0}}, {"id": 418, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 419, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#1$1", "duration": 0.7}}, {"id": 420, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 421, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#1$1", "focus": "m"}}, {"id": 422, "prop": "name", "attributes": {"content": "……", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#1$1"}, {"id": 423, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_279_1#1$1", "focus": "m"}}, {"id": 424, "prop": "name", "attributes": {"content": "鐧小姐，這……", "name": "趕馱獸的牧民"}, "figure_art": "avg_npc_279_1#1$1"}, {"id": 425, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#1$1", "focus": "m"}}, {"id": 426, "prop": "name", "attributes": {"content": "已經沒事了。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#1$1"}, {"id": 427, "prop": "name", "attributes": {"content": "該解決的，我都解決了。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#1$1"}, {"id": 428, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_279_1#1$1", "focus": "m"}}, {"id": 429, "prop": "name", "attributes": {"content": "多虧了您……鐧小姐。", "name": "趕馱獸的牧民"}, "figure_art": "avg_npc_279_1#1$1"}, {"id": 430, "prop": "name", "attributes": {"content": "不然誰知道會變成什麼樣，耶拉岡德在上，都是活生生的……", "name": "趕馱獸的牧民"}, "figure_art": "avg_npc_279_1#1$1"}, {"id": 431, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#1$1", "focus": "m"}}, {"id": 432, "prop": "name", "attributes": {"content": "我只能做到這一步。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#1$1"}, {"id": 433, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#5$1", "focus": "m"}}, {"id": 434, "prop": "name", "attributes": {"content": "抱歉。場面……不太好看。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#5$1"}, {"id": 435, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_279_1#1$1", "focus": "m"}}, {"id": 436, "prop": "name", "attributes": {"content": "唉，現在也只能這樣……", "name": "趕馱獸的牧民"}, "figure_art": "avg_npc_279_1#1$1"}, {"id": 437, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_275", "focus": "m"}}, {"id": 438, "prop": "name", "attributes": {"content": "老大，你身上的血跡要不要處理一下？", "name": "山雪鬼"}, "figure_art": "avg_npc_275"}, {"id": 439, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#11$1", "focus": "m"}}, {"id": 440, "prop": "name", "attributes": {"content": "等會再說。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#11$1"}, {"id": 441, "prop": "name", "attributes": {"content": "時間緊急，雖然我處理過，但難保後續不會再出問題。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#11$1"}, {"id": 442, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#7$1", "focus": "m"}}, {"id": 443, "prop": "name", "attributes": {"content": "現在最要緊的是找到“那個人”。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#7$1"}, {"id": 444, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_275", "focus": "m"}}, {"id": 445, "prop": "name", "attributes": {"content": "可是老大，我們接到消息，對方現在已經離開車站了。", "name": "山雪鬼"}, "figure_art": "avg_npc_275"}, {"id": 446, "prop": "name", "attributes": {"content": "如果現在去聯絡鐵路的人停車，恐怕會引起恐慌……", "name": "山雪鬼"}, "figure_art": "avg_npc_275"}, {"id": 447, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#1$1", "focus": "m"}}, {"id": 448, "prop": "name", "attributes": {"content": "停車？", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#1$1"}, {"id": 449, "prop": "name", "attributes": {"content": "沒必要。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#1$1"}, {"id": 450, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_275", "focus": "m"}}, {"id": 451, "prop": "name", "attributes": {"content": "那還能怎麼辦？", "name": "山雪鬼"}, "figure_art": "avg_npc_275"}, {"id": 452, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#8$1", "focus": "m"}}, {"id": 453, "prop": "name", "attributes": {"content": "你看下面。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#8$1"}, {"id": 454, "prop": "Dialog", "attributes": {}}, {"id": 455, "prop": "charslot", "attributes": {}}, {"id": 456, "prop": "PlaySound", "attributes": {"key": "$d_avg_trainwhistle", "volume": 0.6}}, {"id": 457, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 458, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_275", "focus": "m"}}, {"id": 459, "prop": "name", "attributes": {"content": "這是……", "name": "山雪鬼"}, "figure_art": "avg_npc_275"}, {"id": 460, "prop": "name", "attributes": {"content": "列車馬上就要通過下面的山道了！", "name": "山雪鬼"}, "figure_art": "avg_npc_275"}, {"id": 461, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#1$1", "focus": "m"}}, {"id": 462, "prop": "name", "attributes": {"content": "嗯。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#1$1"}, {"id": 463, "prop": "Dialog", "attributes": {}}, {"id": 464, "prop": "PlaySound", "attributes": {"key": "$d_avg_runstop", "volume": 1.0}}, {"id": 465, "prop": "charslot", "attributes": {"duration": 0.5}}, {"id": 466, "prop": "Delay", "attributes": {"time": 0.7}}, {"id": 467, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovementsp", "volume": 1.0}}, {"id": 468, "prop": "CameraShake", "attributes": {"duration": 0.7, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 469, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 470, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_275", "focus": "m"}}, {"id": 471, "prop": "name", "attributes": {"content": "等等，老、老大？！", "name": "山雪鬼"}, "figure_art": "avg_npc_275"}, {"id": 472, "prop": "Dialog", "attributes": {}}, {