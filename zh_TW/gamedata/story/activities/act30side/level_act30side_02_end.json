me": 0.3, "block": "true"}}, {"id": 333, "prop": "delay", "attributes": {"time": 0.3}}, {"id": 334, "prop": "name", "attributes": {"content": "——！", "name": "“灰禮帽”"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 335, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#11$1", "focus": "m"}}, {"id": 336, "prop": "name", "attributes": {"content": "我的時間不多。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#11$1"}, {"id": 337, "prop": "name", "attributes": {"content": "“灰禮帽”，別著急，我會記得你有這份懇談的意願。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#11$1"}, {"id": 338, "prop": "name", "attributes": {"content": "回頭我再單獨和你“談談”。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#11$1"}, {"id": 339, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_867_1#1$1", "focus": "m"}}, {"id": 340, "prop": "name", "attributes": {"content": "……", "name": "“灰禮帽”"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 341, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#2$1", "focus": "m"}}, {"id": 342, "prop": "name", "attributes": {"content": "現在。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#2$1"}, {"id": 343, "prop": "name", "attributes": {"content": "自己出來，別讓我動手。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#2$1"}, {"id": 344, "prop": "Dialog", "attributes": {}}, {"id": 345, "prop": "charslot", "attributes": {}}, {"id": 346, "prop": "name", "attributes": {"content": "……"}}, {"id": 347, "prop": "Dialog", "attributes": {}}, {"id": 348, "prop": "playsound", "attributes": {"key": "$d_avg_cloakmovement"}}, {"id": 349, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 350, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#12$1", "posfrom": "0,-50", "posto": "0,0", "afrom": 0.0, "ato": 1.0, "duration": 1.0}}, {"id": 351, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 352, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#12$1", "focus": "m"}}, {"id": 353, "prop": "name", "attributes": {"content": "咳、咳咳。", "name": "烈夏"}, "figure_art": "avg_194_leto_1#12$1"}, {"id": 354, "prop": "name", "attributes": {"content": "這位大姐，姐！我在這呢。", "name": "烈夏"}, "figure_art": "avg_194_leto_1#12$1"}, {"id": 355, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#10$1", "focus": "m"}}, {"id": 356, "prop": "name", "attributes": {"content": "咳咳，呸，地上還挺多灰……美女姐姐，你找我有事？", "name": "烈夏"}, "figure_art": "avg_194_leto_1#10$1"}, {"id": 357, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#1$1", "focus": "m"}}, {"id": 358, "prop": "name", "attributes": {"content": "我找的不是你。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#1$1"}, {"id": 359, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#6$1", "focus": "m"}}, {"id": 360, "prop": "name", "attributes": {"content": "啊？", "name": "烈夏"}, "figure_art": "avg_194_leto_1#6$1"}, {"id": 361, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#10$1", "focus": "m"}}, {"id": 362, "prop": "multiline", "attributes": {"name": "烈夏", "content": "可是這除了我沒別人……"}}, {"id": 363, "prop": "PlayMusic", "attributes": {"intro": "$farce_intro", "key": "$farce_loop", "volume": 0.6}}, {"id": 364, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#4$1", "focus": "m"}}, {"id": 365, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 10.0, "ystrength": 12.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 366, "prop": "multiline", "attributes": {"name": "烈夏", "content": "哎喲！"}}, {"id": 367, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#4$1", "focus": "m"}}, {"id": 368, "prop": "name", "attributes": {"content": "（你別亂動！）", "name": "烈夏"}, "figure_art": "avg_194_leto_1#4$1"}, {"id": 369, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#10$1", "focus": "m"}}, {"id": 370, "prop": "name", "attributes": {"content": "……你們在演什麼戲？", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#10$1"}, {"id": 371, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#10$1", "focus": "m"}}, {"id": 372, "prop": "name", "attributes": {"content": "什、什麼演戲？沒沒沒有的事！", "name": "烈夏"}, "figure_art": "avg_194_leto_1#10$1"}, {"id": 373, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#4$1", "focus": "m"}}, {"id": 374, "prop": "name", "attributes": {"content": "（欸大叔你安靜點！我這不是正在幫你遮掩嘛！）", "name": "烈夏"}, "figure_art": "avg_194_leto_1#4$1"}, {"id": 375, "prop": "Dialog", "attributes": {}}, {"id": 376, "prop": "charslot", "attributes": {}}, {"id": 377, "prop": "name", "attributes": {"content": "（別、別扯我的頭髮！）", "name": "？？？"}}, {"id": 378, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#10$1", "focus": "m"}}, {"id": 379, "prop": "name", "attributes": {"content": "……", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#10$1"}, {"id": 380, "prop": "name", "attributes": {"content": "你是羅德島的人？", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#10$1"}, {"id": 381, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#6$1", "focus": "m"}}, {"id": 382, "prop": "name", "attributes": {"content": "啊？我確實是……你知道羅德島？", "name": "烈夏"}, "figure_art": "avg_194_leto_1#6$1"}, {"id": 383, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#8$1", "focus": "m"}}, {"id": 384, "prop": "name", "attributes": {"content": "欸，美女姐姐，難道你是博士上次來認識的熟人？", "name": "烈夏"}, "figure_art": "avg_194_leto_1#8$1"}, {"id": 385, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#1$1", "focus": "m"}}, {"id": 386, "prop": "name", "attributes": {"content": "熟人？我不是。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#1$1"}, {"id": 387, "prop": "name", "attributes": {"content": "好了，我沒有太多時間閒聊。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#1$1"}, {"id": 388, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#2$1", "focus": "m"}}, {"id": 389, "prop": "name", "attributes": {"content": "在我耐心耗盡之前，出來。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#2$1"}, {"id": 390, "prop": "Dialog", "attributes": {}}, {"id": 391, "prop": "charslot", "attributes": {}}, {"id": 392, "prop": "name", "attributes": {"content": "（小祖宗，算了算了，快放我出來吧！）", "name": "？？？"}}, {"id": 393, "prop": "Dialog", "attributes": {}}, {"id": 394, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovement", "volume": 0.7}}, {"id": 395, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#8$1", "duration": 1.0}}, {"id": 396, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 8.0, "ystrength": 5.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 397, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 398, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#8$1", "focus": "m"}}, {"id": 399, "prop": "name", "attributes": {"content": "哈啊……！", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#8$1"}, {"id": 400, "prop": "name", "attributes": {"content": "你能這樣幫我確實令我感動，但羅莎琳你下手也太重了點……", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#8$1"}, {"id": 401, "prop": "name", "attributes": {"content": "嘶……我的頭髮，我的鬍子啊。", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#8$1"}, {"id": 402, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#1$1", "focus": "m"}}, {"id": 403, "prop": "name", "attributes": {"content": "終於找到你了。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#1$1"}, {"id": 404, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#6$1", "focus": "m"}}, {"id": 405, "prop": "name", "attributes": {"content": "……！", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#6$1"}, {"id": 406, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#6$1", "focus": "m"}}, {"id": 407, "prop": "name", "attributes": {"content": "怎麼，原來你們認識？", "name": "烈夏"}, "figure_art": "avg_194_leto_1#6$1"}, {"id": 408, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#3$1", "focus": "m"}}, {"id": 409, "prop": "multiline", "attributes": {"name": "哈洛德", "content": "咳，咳嗯。"}}, {"id": 410, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#1$1", "focus": "m"}}, {"id": 411, "prop": "multiline", "attributes": {"name": "哈洛德", "content": "不敢說相識，不過也曾有過幾面之緣。"}}, {"id": 412, "prop": "name", "attributes": {"content": "鐧女士，許久不見，讓您見笑了。", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 413, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#11$1", "focus": "m"}}, {"id": 414, "prop": "name", "attributes": {"content": "寒暄就不必了。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#11$1"}, {"id": 415, "prop": "name", "attributes": {"content": "克雷加文，山上的老雷昂急著找你。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#11$1"}, {"id": 416, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#16$1", "focus": "m"}}, {"id": 417, "prop": "name", "attributes": {"content": "……老雷昂？找我？", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#16$1"}, {"id": 418, "prop": "name", "attributes": {"content": "等會，是老雷昂找我，而不是鐧女士您要找我……？", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#16$1"}, {"id": 419, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#11$1", "focus": "m"}}, {"id": 420, "prop": "name", "attributes": {"content": "我受他所託，來找你。就這麼一回事。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#11$1"}, {"id": 421, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#16$1", "focus": "m"}}, {"id": 422, "prop": "name", "attributes": {"content": "他如此著急找我，是有何要事？", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#16$1"}, {"id": 423, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#11$1", "focus": "m"}}, {"id": 424, "prop": "name", "attributes": {"content": "這麼說來，我好像確實忘了點什麼……是什麼來著……", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#11$1"}, {"id": 425, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#1$1", "focus": "m"}}, {"id": 426, "prop": "name", "attributes": {"content": "你忘了莉莉還在等你。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#1$1"}, {"id": 427, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#7$1", "focus": "m"}}, {"id": 428, "prop": "name", "attributes": {"content": "……對了，是莉莉！", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#7$1"}, {"id": 429, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#14$1", "focus": "m"}}, {"id": 430, "prop": "name", "attributes": {"content": "什麼莉莉……不是吧，大叔，你把你對象忘了？", "name": "烈夏"}, "figure_art": "avg_194_leto_1#14$1"}, {"id": 431, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#5$1", "focus": "m"}}, {"id": 432, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 8.0, "ystrength": 10.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 433, "prop": "multiline", "attributes": {"name": "哈洛德", "content": "相好——？！"}}, {"id": 434, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#8$1", "focus": "m"}}, {"id": 435, "prop": "multiline", "attributes": {"name": "哈洛德", "content": "不是，咳咳，咳——"}}, {"id": 436, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_867_1#1$1", "focus": "m"}}, {"id": 437, "prop": "name", "attributes": {"content": "……子爵閣下，您如此行事，恐怕有損維多利亞的形象。", "name": "“灰禮帽”"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 438, "prop": "name", "attributes": {"content": "尊夫人和令千金如果知道此事……", "name": "“灰禮帽”"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 439, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#4$1", "focus": "m"}}, {"id": 440, "prop": "name", "attributes": {"content": "嗚哇，人渣。", "name": "烈夏"}, "figure_art": "avg_194_leto_1#4$1"}, {"id": 441, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#8$1", "focus": "m"}}, {"id": 442, "prop": "name", "attributes": {"content": "慢著！咳咳，該死的灰，不是！", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#8$1"}, {"id": 443, "prop": "name", "attributes": {"content": "莉莉是——", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#8$1"}, {"id": 444, "prop": "Dialog", "attributes": {}}, {"id": 445, "prop": "charslot", "attributes": {}}, {"id": 446, "prop": "PlaySound", "attributes": {"key": "$d_avg_trnrvlbrdcst", "volume": 0.7}}, {"id": 447, "prop": "CameraShake", "attributes": {"duration": 4.0, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 448, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 449, "prop": "name", "attributes": {"content": "各位乘客，本次列車即將抵達終點站——"}}, {"id": 450, "prop": "name", "attributes": {"content": "銀心湖站。"}}, {"id": 451, "prop": "name", "attributes": {"content": "請各位乘客收拾好隨身的行李物品，從各自車廂前後車門排隊下車。"}}, {"id": 452, "prop": "name", "attributes": {"content": "感謝您搭乘本次列車。"}}, {"id": 453, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#11$1", "focus": "m"}}, {"id": 454, "prop": "name", "attributes": {"content": "時間耽擱得還不算久。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#11$1"}, {"id": 455, "prop": "name", "attributes": {"content": "下車後你最好盡快上山去找老雷昂，他很急。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#11$1"}, {"id": 456, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#13$1", "focus": "m"}}, {"id": 457, "prop": "name", "attributes": {"content": "我們還是分道揚鑣吧，不然我媽會不高興的。", "name": "烈夏"}, "figure_art": "avg_194_leto_1#13$1"}, {"id": 458, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#8$1", "focus": "m"}}, {"id": 459, "prop": "name", "attributes": {"content": "不，咳咳，莉莉——", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#8$1"}, {"id": 460, "prop": "name", "attributes": {"content": "——她根本就不是人啊！", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#8$1"}, {"id": 461, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#4$1", "focus": "m"}}, {"id": 462, "prop": "name", "attributes": {"content": "你還要罵人家不是人？！", "name": "烈夏"}, "figure_art": "avg_194_leto_1#4$1"}, {"id": 463, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#6$1", "focus": "m"}}, {"id": 464, "prop": "name", "attributes": {"content": "不不不不。噗，好了，把我自己氣笑了。岔氣了。", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#6$1"}, {"id": 465, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#8$1", "focus": "m"}}, {"id": 466, "prop": "name", "attributes": {"content": "莉莉是馱獸。", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#8$1"}, {"id": 467, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#6$1", "focus": "m"}}, {"id": 468, "prop": "name", "attributes": {"content": "馱獸……？", "name": "烈夏"}, "figure_art": "avg_194_leto_1#6$1"}, {"id": 469, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_867_1#1$1", "focus": "m"}}, {"id": 470, "prop": "name", "attributes": {"content": "原來如此。", "name": "“灰禮帽”"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 471, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#1$1", "focus": "m"}}, {"id": 472, "prop": "name", "attributes": {"content": "……我沒說嗎？", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#1$1"}, {"id": 473, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#10$1", "focus": "m"}}, {"id": 474, "prop": "name", "attributes": {"content": "“灰禮帽”！你裝什麼裝！", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#10$1"}, {"id": 475, "prop": "name", "attributes": {"content": "我不信你手下的探子沒把我在謝拉格的行動匯報給你！", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#10$1"}, {"id": 476, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_867_1#1$1", "focus": "m"}}, {"id": 477, "prop": "name", "attributes": {"content": "很抱歉，您治癒的馱獸叫什麼名字，並不在需要我記憶的重點情報之中，閣下。", "name": "“灰禮帽”"}, "figure_art": "avg_npc_867_1#1$1"}, {"id": 478, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#6$1", "focus": "m"}}, {"id": 479, "prop": "name", "attributes": {"content": "……所以，其實大叔不是人渣，也不會有什麼危險？", "name": "烈夏"}, "figure_art": "avg_194_leto_1#6$1"}, {"id": 480, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_194_leto_1#1$1", "focus": "m"}}, {"id": 481, "prop": "name", "attributes": {"content": "又追又跑的，我以為是什麼性命攸關的大事呢。", "name": "烈夏"}, "figure_art": "avg_194_leto_1#1$1"}, {"id": 482, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4114_harold_1#8$1", "focus": "m"}}, {"id": 483, "prop": "name", "attributes": {"content": "我……唉！羅莎琳，這確實是事關我名譽的大事啊！", "name": "哈洛德"}, "figure_art": "avg_4114_harold_1#8$1"}, {"id": 484, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4116_blkkgt_1#1$1", "focus": "m"}}, {"id": 485, "prop": "name", "attributes": {"content": "你們想磨蹭多久？", "name": "鐧"}, "figure_art": "avg_4116_blkkgt_1#1$1"}, {"id": 486, "prop": "Dialog", "attributes": {}}, {"id": 487, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 488, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 489, "prop": "PlaySound", "attributes": {"key": "$d_avg_highheelfts", "volume": 0.8}}, {"id": 490, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 491, "prop": "name", "attributes": {"content": "別傻站著，擋路。", "name": "鐧"}}, {"id": 492, "prop": "name", "attributes": {"content": "車到站了。", "name": "鐧"}}, {"id": 493, "prop": "Dialog", "attributes": {}}, {"id": 494, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 495, "prop": "charslot", "attributes": {}}, {"id": 496, "prop": "Image", "attributes": {}}, {"id": 497, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}