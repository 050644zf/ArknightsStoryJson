ay", "attributes": {"time": 2.0}}, {"id": 39, "prop": "name", "attributes": {"content": "別再說了，角峰大哥。", "name": "魏斯"}, "figure_art": "avg_198_blackd_1#6$1"}, {"id": 40, "prop": "name", "attributes": {"content": "老爺的脾氣你應該最清楚，明知老爺肯定不會接受，又何必這樣？", "name": "魏斯"}, "figure_art": "avg_198_blackd_1#6$1"}, {"id": 41, "prop": "character", "attributes": {"name": "avg_198_blackd_1#6$1", "name2": "avg_199_yak_1#1$1", "focus": 2.0}}, {"id": 42, "prop": "name", "attributes": {"content": "......至少我得試試。", "name": "角峰"}, "figure_art": "avg_199_yak_1#1$1"}, {"id": 43, "prop": "name", "attributes": {"content": "老爺他......太冒險了。", "name": "角峰"}, "figure_art": "avg_199_yak_1#1$1"}, {"id": 44, "prop": "character", "attributes": {"name": "avg_198_blackd_1#8$1", "name2": "avg_199_yak_1#1$1", "focus": 1.0}}, {"id": 45, "prop": "name", "attributes": {"content": "風險與機遇並存，一直不都是這麼過來的？", "name": "魏斯"}, "figure_art": "avg_198_blackd_1#8$1"}, {"id": 46, "prop": "name", "attributes": {"content": "我們只需要聽老爺的。", "name": "魏斯"}, "figure_art": "avg_198_blackd_1#8$1"}, {"id": 47, "prop": "PlaySound", "attributes": {"key": "$d_avg_snowstormflp", "volume": 1.0, "loop": "true", "channel": "bse"}}, {"id": 48, "prop": "character", "attributes": {"name": "avg_198_blackd_1#8$1", "name2": "avg_199_yak_1#1$1", "focus": 2.0}}, {"id": 49, "prop": "name", "attributes": {"content": "......", "name": "角峰"}, "figure_art": "avg_199_yak_1#1$1"}, {"id": 50, "prop": "character", "attributes": {"name": "avg_198_blackd_1#8$1", "name2": "avg_199_yak_1#1$1", "focus": 1.0}}, {"id": 51, "prop": "name", "attributes": {"content": "呼......", "name": "魏斯"}, "figure_art": "avg_198_blackd_1#8$1"}, {"id": 52, "prop": "character", "attributes": {"name": "avg_198_blackd_1#5$1", "name2": "avg_199_yak_1#1$1", "focus": 1.0}}, {"id": 53, "prop": "name", "attributes": {"content": "真冷。這雪是不是越來越大了？", "name": "魏斯"}, "figure_art": "avg_198_blackd_1#5$1"}, {"id": 54, "prop": "StopSound", "attributes": {"channel": "bse", "fadetime": 1.0}}, {"id": 55, "prop": "Dialog", "attributes": {}}, {"id": 56, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 57, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 58, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 59, "prop": "Character", "attributes": {}}, {"id": 60, "prop": "Background", "attributes": {"image": "24_g6_square", "screenadapt": "showall"}}, {"id": 61, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 62, "prop": "PlayMusic", "attributes": {"intro": "$nervous_intro", "key": "$nervous_loop", "volume": 0.4}}, {"id": 63, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 64, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 65, "prop": "character", "attributes": {"name": "avg_npc_253_1#7$1", "name2": "avg_npc_254_1#1$1", "focus": 1.0, "fadetime": 1.5}}, {"id": 66, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 67, "prop": "name", "attributes": {"content": "真慢。", "name": "菈塔托絲"}, "figure_art": "avg_npc_253_1#7$1"}, {"id": 68, "prop": "name", "attributes": {"content": "要我們兩家一起等著他，好大的排場。", "name": "菈塔托絲"}, "figure_art": "avg_npc_253_1#7$1"}, {"id": 69, "prop": "character", "attributes": {"name": "avg_npc_253_1#7$1", "name2": "avg_npc_254_1#1$1", "focus": 2.0}}, {"id": 70, "prop": "name", "attributes": {"content": "他一路步行而來，這倒確實不錯。", "name": "阿克托斯"}, "figure_art": "avg_npc_254_1#1$1"}, {"id": 71, "prop": "character", "attributes": {"name": "avg_npc_253_1#4$1", "name2": "avg_npc_254_1#1$1", "focus": 1.0}}, {"id": 72, "prop": "name", "attributes": {"content": "真稀奇，你竟也會誇他？聽說這一路上，恩希歐迪斯是被交口稱讚，受歡迎得很啊。", "name": "菈塔托絲"}, "figure_art": "avg_npc_253_1#4$1"}, {"id": 73, "prop": "character", "attributes": {"name": "avg_npc_253_1#10$1", "name2": "avg_npc_254_1#1$1", "focus": 1.0}}, {"id": 74, "prop": "name", "attributes": {"content": "阿克托斯，你可要小心點，說不定再過幾天，耶拉岡德最虔誠的信徒就要從你阿克托斯變成他恩希歐迪斯了。", "name": "菈塔托絲"}, "figure_art": "avg_npc_253_1#10$1"}, {"id": 75, "prop": "character", "attributes": {"name": "avg_npc_253_1#10$1", "name2": "avg_npc_254_1#9$1", "focus": 2.0}}, {"id": 76, "prop": "name", "attributes": {"content": "風涼話就免了，菈塔托絲。", "name": "阿克托斯"}, "figure_art": "avg_npc_254_1#9$1"}, {"id": 77, "prop": "character", "attributes": {"name": "avg_npc_253_1#10$1", "name2": "avg_npc_254_1#1$1", "focus": 2.0}}, {"id": 78, "prop": "name", "attributes": {"content": "我雖不信任恩希歐迪斯，但他若做得對，我便說對。", "name": "阿克托斯"}, "figure_art": "avg_npc_254_1#1$1"}, {"id": 79, "prop": "name", "attributes": {"content": "如果你把我喊過來就是為了說這些，那就恕我不奉陪了。", "name": "阿克托斯"}, "figure_art": "avg_npc_254_1#1$1"}, {"id": 80, "prop": "character", "attributes": {"name": "avg_npc_253_1#7$1", "name2": "avg_npc_254_1#1$1", "focus": 1.0}}, {"id": 81, "prop": "name", "attributes": {"content": "我也沒有那麼閒，阿克托斯。", "name": "菈塔托絲"}, "figure_art": "avg_npc_253_1#7$1"}, {"id": 82, "prop": "name", "attributes": {"content": "我只是要提醒你。", "name": "菈塔托絲"}, "figure_art": "avg_npc_253_1#7$1"}, {"id": 83, "prop": "character", "attributes": {"name": "avg_npc_253_1#7$1", "name2": "avg_npc_254_1#3$1", "focus": 2.0}}, {"id": 84, "prop": "name", "attributes": {"content": "提醒？有什麼事是需要你菈塔托絲來提醒我的。", "name": "阿克托斯"}, "figure_art": "avg_npc_254_1#3$1"}, {"id": 85, "prop": "character", "attributes": {"name": "avg_npc_253_1#7$1", "name2": "avg_npc_254_1#3$1", "focus": 1.0}}, {"id": 86, "prop": "name", "attributes": {"content": "你認為沒有？", "name": "菈塔托絲"}, "figure_art": "avg_npc_253_1#7$1"}, {"id": 87, "prop": "character", "attributes": {"name": "avg_npc_253_1#8$1", "name2": "avg_npc_254_1#3$1", "focus": 1.0}}, {"id": 88, "prop": "name", "attributes": {"content": "阿克托斯，逞口舌之快對我們都沒有好處。在當下，我們兩家之間才是最牢固的盟友關係。", "name": "菈塔托絲"}, "figure_art": "avg_npc_253_1#8$1"}, {"id": 89, "prop": "character", "attributes": {"name": "avg_npc_253_1#8$1", "name2": "avg_npc_254_1#2$1", "focus": 2.0}}, {"id": 90, "prop": "name", "attributes": {"content": "......", "name": "阿克托斯"}, "figure_art": "avg_npc_254_1#2$1"}, {"id": 91, "prop": "character", "attributes": {"name": "avg_npc_253_1#8$1", "name2": "avg_npc_254_1#1$1", "focus": 2.0}}, {"id": 92, "prop": "name", "attributes": {"content": "逞口舌之快的恐怕不是我，菈塔托絲。", "name": "阿克托斯"}, "figure_art": "avg_npc_254_1#1$1"}, {"id": 93, "prop": "name", "attributes": {"content": "我不喜歡你和恩希歐迪斯的那種彎彎繞繞，我一向只看行動。", "name": "阿克托斯"}, "figure_art": "avg_npc_254_1#1$1"}, {"id": 94, "prop": "character", "attributes": {"name": "avg_npc_253_1#1$1", "name2": "avg_npc_254_1#1$1", "focus": 1.0}}, {"id": 95, "prop": "name", "attributes": {"content": "你只看行動，那正好。", "name": "菈塔托絲"}, "figure_art": "avg_npc_253_1#1$1"}, {"id": 96, "prop": "name", "attributes": {"content": "那我們就談談兩天前的那場爆炸。", "name": "菈塔托絲"}, "figure_art": "avg_npc_253_1#1$1"}, {"id": 97, "prop": "character", "attributes": {"name": "avg_npc_253_1#1$1", "name2": "avg_npc_254_1#3$1", "focus": 2.0}}, {"id": 98, "prop": "name", "attributes": {"content": "怎麼，難道菈塔托絲你要承認那是你布朗陶家所為？哼，我可不信，這事不是你的風格。", "name": "阿克托斯"}, "figure_art": "avg_npc_254_1#3$1"}, {"id": 99, "prop": "character", "attributes": {"name": "avg_npc_253_1#1$1", "name2": "avg_npc_254_1#9$1", "focus": 2.0}}, {"id": 100, "prop": "name", "attributes": {"content": "還是說，你知道主謀是誰？", "name": "阿克托斯"}, "figure_art": "avg_npc_254_1#9$1"}, {"id": 101, "prop": "character", "attributes": {"name": "avg_npc_253_1#1$1", "name2": "avg_npc_254_1#9$1", "focus": 1.0}}, {"id": 102, "prop": "name", "attributes": {"content": "......我要是說我知道呢？", "name": "菈塔托絲"}, "figure_art": "avg_npc_253_1#1$1"}, {"id": 103, "prop": "character", "attributes": {"name": "avg_npc_253_1#1$1", "name2": "avg_npc_254_1#5$1", "focus": 2.0}}, {"id": 104, "prop": "name", "attributes": {"content": "——此話當真？", "name": "阿克托斯"}, "figure_art": "avg_npc_254_1#5$1"}, {"id": 105, "prop": "character", "attributes": {"name": "avg_npc_253_1#1$1", "name2": "avg_npc_254_1#5$1", "focus": 1.0}}, {"id": 106, "prop": "name", "attributes": {"content": "絕無虛言。", "name": "菈塔托絲"}, "figure_art": "avg_npc_253_1#1$1"}, {"id": 107, "prop": "name", "attributes": {"content": "阿克托斯，你要不要猜猜，我們的這位援兵究竟會是什麼人？", "name": "菈塔托絲"}, "figure_art": "avg_npc_253_1#1$1"}, {"id": 108, "prop": "Dialog", "attributes": {}}, {"id": 109, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 110, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 111, "prop": "Character", "attributes": {}}, {"id": 112, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 113, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 114, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 115, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 116, "prop": "character", "attributes": {"name": "avg_npc_262_1#8$1"}}, {"id": 117, "prop": "name", "attributes": {"content": "莫希，莫希！", "name": "休露絲"}, "figure_art": "avg_npc_262_1#8$1"}, {"id": 118, "prop": "character", "attributes": {"name": "avg_npc_262_1#8$1"}}, {"id": 119, "prop": "name", "attributes": {"content": "人呢，跑哪兒去了......？！", "name": "休露絲"}, "figure_art": "avg_npc_262_1#8$1"}, {"id": 120, "prop": "Dialog", "attributes": {}}, {"id": 121, "prop": "Character", "attributes": {"name": "avg_npc_262_1#8$1", "name2": "char_empty"}}, {"id": 122, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 0.6}}, {"id": 123, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "xpos": 200.0, "fadetime": 0.3, "block": "true"}}, {"id": 124, "prop": "delay", "attributes": {"time": 0.51}}, {"id": 125, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "fadetime": 1.0, "block": "false"}}, {"id": 126, "prop": "Character", "attributes": {"name": "avg_npc_262_1#8$1", "name2": "avg_npc_255_1#1$1", "fadetime": 0.7}}, {"id": 127, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 128, "prop": "character", "attributes": {"name": "avg_npc_262_1#8$1", "name2": "avg_npc_255_1#1$1", "focus": 2.0}}, {"id": 129, "prop": "name", "attributes": {"content": "夫人。您找我？", "name": "莫希"}, "figure_art": "avg_npc_255_1#1$1"}, {"id": 130, "prop": "character", "attributes": {"name": "avg_npc_262_1#8$1", "name2": "avg_npc_255_1#1$1", "focus": 1.0}}, {"id": 131, "prop": "name", "attributes": {"content": "我找沒找你，這還用問嗎？！", "name": "休露絲"}, "figure_art": "avg_npc_262_1#8$1"}, {"id": 132, "prop": "character", "attributes": {"name": "avg_npc_262_1#7$1", "name2": "avg_npc_255_1#1$1", "focus": 1.0}}, {"id": 133, "prop": "name", "attributes": {"content": "平時你不是挺機靈的，怎麼偏偏在這種時候瞎跑！我明明說了這次狩獵一定要好好準備......算了，你準備得怎麼樣了？", "name": "休露絲"}, "figure_art": "avg_npc_262_1#7$1"}, {"id": 134, "prop": "name", "attributes": {"content": "我可實話和你說了，莫希，你是我手下最可靠的戰士。", "name": "休露絲"}, "figure_art": "avg_npc_262_1#7$1"}, {"id": 135, "prop": "name", "attributes": {"content": "這次我能不能給布朗陶家爭光，讓菈塔托絲那個臭女人沒話可說，可全都看你的表現了！", "name": "休露絲"}, "figure_art": "avg_npc_262_1#7$1"}, {"id": 136, "prop": "character", "attributes": {"name": "avg_npc_262_1#7$1", "name2": "avg_npc_255_1#8$1", "focus": 2.0}}, {"id": 137, "prop": "name", "attributes": {"content": "......", "name": "莫希"}, "figure_art": "avg_npc_255_1#8$1"}, {"id": 138, "prop": "name", "attributes": {"content": "夫人，恕我直言......", "name": "莫希"}, "figure_art": "avg_npc_255_1#8$1"}, {"id": 139, "prop": "character", "attributes": {"name": "avg_npc_262_1#8$1", "name2": "avg_npc_255_1#8$1", "focus": 1.0}}, {"id": 140, "prop": "name", "attributes": {"content": "你有什麼想說的就說，別扭扭捏捏的！", "name": "休露絲"}, "figure_art": "avg_npc_262_1#8$1"}, {"id": 141, "prop": "character", "attributes": {"name": "avg_npc_262_1#8$1", "name2": "avg_npc_255_1#1$1", "focus": 2.0}}, {"id": 142, "prop": "name", "attributes": {"content": "是。", "name": "莫希"}, "figure_art": "avg_npc_255_1#1$1"}, {"id": 143, "prop": "name", "attributes": {"content": "屬下認為，夫人若是真的有心在這次儀式上有所表現，令菈塔托絲夫人對您刮目相看，只將目光放在狩獵上，或許還有所不足。", "name": "莫希"}, "figure_art": "avg_npc_255_1#1$1"}, {"id": 144, "prop": "character", "attributes": {"name": "avg_npc_262_1#2$1", "name2": "avg_npc_255_1#1$1", "focus": 1.0}}, {"id": 145, "prop": "name", "attributes": {"content": "這我也知道......但除此之外還能怎麼辦？", "name": "休露絲"}, "figure_art": "avg_npc_262_1#2$1"}, {"id": 146, "prop": "character", "attributes": {"name": "avg_npc_262_1#7$1", "name2": "avg_npc_255_1#1$1", "focus": 1.0}}, {"id": 147, "prop": "name", "attributes": {"content": "菈塔托絲那女人總會把一切都想好，半點空間也不給我留。哼，就算我承認她比我聰明一點點好了。", "name": "休露絲"}, "figure_art": "avg_npc_262_1#7$1"}, {"id": 148, "prop": "character", "attributes": {"name": "avg_npc_262_1#8$1", "name2": "avg_npc_255_1#1$1", "focus": 1.0}}, {"id": 149, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 150, "prop": "name", "attributes": {"content": "但我也......我也不是個廢物！", "name": "休露絲"}, "figure_art": "avg_npc_262_1#8$1"}, {"id": 151, "prop": "character", "attributes": {"name": "avg_npc_262_1#7$1", "name2": "avg_npc_255_1#1$1", "focus": 1.0}}, {"id": 152, "prop": "name", "attributes": {"content": "所以這次不管怎麼樣，你都一定要給我大出風頭，莫希！", "name": "休露絲"}, "figure_art": "avg_npc_262_1#7$1"}, {"id": 153, "prop": "name", "attributes": {"content": "讓我們一起壓一壓菈塔托絲那個臭女人的氣焰，我一定要讓她好好瞧瞧我的厲害！", "name": "休露絲"}, "figure_art": "avg_npc_262_1#7$1"}, {"id": 154, "prop": "character", "attributes": {"name": "avg_npc_262_1#7$1", "name2": "avg_npc_255_1#1$1", "focus": 2.0}}, {"id": 155, "prop": "name", "attributes": {"content": "......", "name": "莫希"}, "figure_art": "avg_npc_255_1#1$1"}, {"id": 156, "prop": "name", "attributes": {"content": "......我明白您對布朗陶家的心意，夫人。", "name": "莫希"}, "figure_art": "avg_npc_255_1#1$1"}, {"id": 157, "prop": "character", "attributes": {"name": "avg_npc_262_1#7$1", "name2": "avg_npc_255_1#6$1", "focus": 2.0}}, {"id": 158, "prop": "name", "attributes": {"content": "既然如此，您就更不能只盯著狩獵本身來考慮這次的行動了。", "name": "莫希"}, "figure_art": "avg_npc_255_1#6$1"}, {"id": 159, "prop": "character", "attributes": {"name": "avg_npc_262_1#2$1", "name2": "avg_npc_255_1#6$1", "focus": 1.0}}, {"id": 160, "prop": "name", "attributes": {"content": "那你說說，我們還能幹點什麼？", "name": "休露絲"}, "figure_art": "avg_npc_262_1#2$1"}, {"id": 161, "prop": "character", "attributes": {"name": "avg_npc_262_1#2$1", "name2": "avg_npc_255_1#3$1", "focus": 2.0}}, {"id": 162, "prop": "name", "attributes": {"content": "如果夫人相信我的判斷——", "name": "莫希"}, "figure_art": "avg_npc_255_1#3$1"}, {"id": 163, "prop": "character", "attributes": {"name": "avg_npc_262_1#7$1", "name2": "avg_npc_255_1#3$1", "focus": 1.0}}, {"id": 164, "prop": "name", "attributes": {"content": "你這說的什麼廢話，我不信你還能信誰？", "name": "休露絲"}, "figure_art": "avg_npc_262_1#7$1"}, {"id": 165, "prop": "character", "attributes": {"name": "avg_npc_262_1#7$1", "name2": "avg_npc_255_1#2$1", "focus": 2.0}}, {"id": 166, "prop": "name", "attributes": {"content": "......", "name": "莫希"}, "figure_art": "avg_npc_255_1#2$1"}, {"id": 167, "prop": "character", "attributes": {"name": "avg_npc_262_1#7$1", "name2": "avg_npc_255_1#1$1", "focus": 2.0}}, {"id": 168, "prop": "name", "attributes": {"content": "感謝您的信任，夫人。那麼就請將此事交給我吧，我有一些想法......但需要見機行事，目前我還不能妄下結論。", "name": "莫希"}, "figure_art": "avg_npc_255_1#1$1"}, {"id": 169, "prop": "name", "attributes": {"content": "以及夫人，為了行動能夠順利，此事最好也不要對尤卡坦老爺提及。", "name": "莫希"}, "figure_art": "avg_npc_255_1#1$1"}, {"id": 170, "prop": "character", "attributes": {"name": "avg_npc_262_1#4$1", "name2": "avg_npc_255_1#1$1", "focus": 1.0}}, {"id": 171, "prop": "name", "attributes": {"content": "連尤卡坦也不行？", "name": "休露絲"}, "figure_art": "avg_npc_262_1#4$1"}, {"id": 172, "prop": "character", "attributes": {"name": "avg_npc_262_1#6$1", "name2": "avg_npc_255_1#1$1", "focus": 1.0}}, {"id": 173, "prop": "name", "attributes": {"content": "也對，那傢伙總是當我是個小姑娘一樣攔著我做事，還和菈塔托絲告密，別以為我不知道......", "name": "休露絲"}, "figure_art": "avg_npc_262_1#6$1"}, {"id": 174, "prop": "character", "attributes": {"name": "avg_npc_262_1#1$1", "name2": "avg_npc_255_1#1$1", "focus": 1.0}}, {"id": 175, "prop": "name", "attributes": {"content": "那就全都交給你了，莫希！一定不要讓我失望！", "name": "休露絲"}, "figure_art": "avg_npc_262_1#1$1"}, {"id": 176, "prop": "character", "attributes": {"name": "avg_npc_262_1#8$1", "name2": "avg_npc_255_1#6$1", "focus": 2.0}}, {"id": 177, "prop": "name", "attributes": {"content": "當然，請您放心......", "name": "莫希"}, "figure_art": "avg_npc_255_1#6$1"}, {"id": 178, "prop": "name", "attributes": {"content": "......屆時，屬下一定會讓您大出風頭。", "name": "莫希"}, "figure_art": "avg_npc_255_1#6$1"}, {"id": 179, "prop": "Dialog", "attributes": {}}, {"id": 180, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 181, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 182, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 183, "prop": "Character", "attributes": {}}, {"id": 184, "prop": "Background", "attributes": {"image": "24_g13_mountpath_s", "screenadapt": "showall"}}, {"id": 185, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 186, "prop": "playMusic", "attributes": {"intro": "$drift_intro", "key": "$drift_loop", "volume": 0.4}}, {"id": 187, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 188, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 189, "prop": "character", "attributes": {"name": "avg_174_slbell_1#1$1", "name2": "char_empty", "focus": 1.0, "fadetime": 1.5}}, {"id": 190, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 191, "prop": "musicvolume", "attributes": {"volume": 0.1, "fadetime": 2.0}}, {"id": 192, "prop": "name", "attributes": {"content": "“響鈴之音來自祂最澄澈的心靈，愛祂的人無不垂首聆聽，而耶拉岡德注視著所有虔誠的子民。”", "name": "恩雅"}, "figure_art": "avg_174_slbell_1#1$1"}, {"id": 193, "prop": "dialog", "attributes": {}}, {"id": 194, "prop": "Delay", "attributes": {"time": 0.7}}, {"id": 195, "prop": "PlaySound", "attributes": {"key": "$bigbell", "volume": 1.0}}, {"id": 196, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 197, "prop": "name", "attributes": {"content": "——聽。整點的鈴聲剛剛響起。", "name": "恩雅"}}, {"id": 198, "prop": "musicvolume", "attributes": {"volume": 0.4, "fadetime": 2.0}}, {"id": 199, "prop": "name", "attributes": {"content": "您險些就來遲了，恩希歐迪斯大人。", "name": "恩雅"}}, {"id": 200, "prop": "Dialog", "attributes": {}}, {"id": 201, "prop": "Character", "attributes": {"name": "avg_174_slbell_1#1$1", "name2": "char_empty"}}, {"id": 202, "prop": "PlaySound", "attributes": {"key": "$d_avg_snowbootwalk", "volume": 1.0}}, {"id": 203, "prop": "Character", "attributes": {"name": "avg_174_slbell_1#1$1", "name2": "avg_172_svrash_1#1$1", "fadetime": 1.5}}, {"id": 204, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 205, "prop": "character", "attributes": {"name": "avg_174_slbell_1#1$1", "name2": "avg_172_svrash_1#1$1", "focus": 2.0}}, {"id": 206, "prop": "name", "attributes": {"content": "請您原諒。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 207, "prop": "name", "attributes": {"content": "通向真知的路總不好走，這一定也是耶拉岡德給予希瓦艾什的考驗。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 208, "prop": "character", "attributes": {"name": "avg_174_slbell_1#1$1", "name2": "avg_172_svrash_1#1$1", "focus": 1.0}}, {"id": 209, "prop": "name", "attributes": {"content": "從圖里卡姆出發，步行來到喀蘭聖山，確實是辛苦了。", "name": "恩雅"}, "figure_art": "avg_174_slbell_1#1$1"}, {"id": 210, "prop": "character", "attributes": {"name": "avg_174_slbell_1#1$1", "name2": "avg_172_svrash_1#1$1", "focus": 1.0}}, {"id": 211, "prop": "name", "attributes": {"content": "但......希望您真的能夠找到正確的道路。", "name": "恩雅"}, "figure_art": "avg_174_slbell_1#1$1"}, {"id": 212, "prop": "character", "attributes": {"name": "avg_174_slbell_1#1$1", "name2": "avg_172_svrash_1#1$1", "focus": 2.0}}, {"id": 213, "prop": "name", "attributes": {"content": "有聖女大人的這句祝福，前路已然明朗。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 214, "prop": "character", "attributes": {"name": "avg_174_slbell_1#1$1", "name2": "avg_172_svrash_1#2$1", "focus": 2.0}}, {"id": 215, "prop": "name", "attributes": {"content": "正如此刻，我正朝耶拉岡德的教誨而去。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#2$1"}, {"id": 216, "prop": "character", "attributes": {"name": "avg_174_slbell_1#8$1", "name2": "avg_172_svrash_1#2$1", "focus": 1.0}}, {"id": 217, "prop": "name", "attributes": {"content": "......", "name": "恩雅"}, "figure_art": "avg_174_slbell_1#8$1"}, {"id": 218, "prop": "name", "attributes": {"content": "您的口才當真出眾，恩希歐迪斯大人。", "name": "恩雅"}, "figure_art": "avg_174_slbell_1#8$1"}, {"id": 219, "prop": "character", "attributes": {"name": "avg_174_slbell_1#8$1", "name2": "avg_172_svrash_1#1$1", "focus": 2.0}}, {"id": 220, "prop": "name", "attributes": {"content": "過譽了。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 221, "prop": "character", "attributes": {"name": "avg_174_slbell_1#8$1", "name2": "avg_172_svrash_1#9$1", "focus": 2.0}}, {"id": 222, "prop": "name", "attributes": {"content": "這次竟勞聖女大人親自接見，誠惶誠恐。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#9$1"}, {"id": 223, "prop": "character", "attributes": {"name": "avg_174_slbell_1#3$1", "name2": "avg_172_svrash_1#9$1", "focus": 1.0}}, {"id": 224, "prop": "name", "attributes": {"content": "恩希歐迪斯大人擺出如此陣仗，我又怎麼敢駁了您的面子。", "name": "恩雅"}, "figure_art": "avg_174_slbell_1#3$1"}, {"id": 225, "prop": "character", "attributes": {"name": "avg_174_slbell_1#3$1", "name2": "avg_172_svrash_1#1$1", "focus": 2.0}}, {"id": 226, "prop": "name", "attributes": {"content": "大長老現在何處？", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 227, "prop": "character", "attributes": {"name": "avg_174_slbell_1#1$1", "name2": "avg_172_svrash_1#1$1", "focus": 1.0}}, {"id": 228, "prop": "name", "attributes": {"content": "大長老在做祭拜的準備，我就出來迎接您了。", "name": "恩雅"}, "figure_art": "avg_174_slbell_1#1$1"}, {"id": 229, 