tes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 70.0, "fadeout": "true", "block": "false"}}, {"id": 241, "prop": "name", "attributes": {"content": "可能反而會對布朗陶家不利？！", "name": "極光"}, "figure_art": "avg_422_aurora_1#5$1"}, {"id": 242, "prop": "dialog", "attributes": {}}, {"id": 243, "prop": "character", "attributes": {"name": "avg_422_aurora_1#5$1"}}, {"id": 244, "prop": "Decision", "attributes": {"options": "也不儘然。", "values": "1"}, "targetLine": {"option1": "line245"}}, {"id": 245, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 246, "prop": "character", "attributes": {"name": "avg_npc_252"}}, {"id": 247, "prop": "name", "attributes": {"content": "我們的情報不足，尚不能見事件的全貌，無法真正鎖定幕後的主使與其目的。", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 248, "prop": "character", "attributes": {"name": "avg_npc_252"}}, {"id": 249, "prop": "name", "attributes": {"content": "現在唯一能確定的是有人想挑撥三家間的關係，換言之就是要破壞雪境的整體穩定，形勢對作為外人的博士你來說非常危險。", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 250, "prop": "character", "attributes": {"name": "avg_422_aurora_1#4$1"}}, {"id": 251, "prop": "name", "attributes": {"content": "現在怎麼辦，博士，我們是不是應該先想辦法回去？", "name": "極光"}, "figure_art": "avg_422_aurora_1#4$1"}, {"id": 252, "prop": "dialog", "attributes": {}}, {"id": 253, "prop": "character", "attributes": {"name": "avg_422_aurora_1#4$1"}}, {"id": 254, "prop": "Decision", "attributes": {"options": "還不是時候，這件事遠沒有結束。", "values": "1"}, "targetLine": {"option1": "line255"}}, {"id": 255, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 256, "prop": "character", "attributes": {"name": "avg_npc_252"}}, {"id": 257, "prop": "name", "attributes": {"content": "是的，這場鬧劇只是巨大風暴的一小部分。但我的職責很清晰，我得帶你離開最危險的事件中心，博士。", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 258, "prop": "dialog", "attributes": {}}, {"id": 259, "prop": "character", "attributes": {"name": "avg_npc_252"}}, {"id": 260, "prop": "Decision", "attributes": {"options": "我要收集更多的情報。;我要避免那些人被捕。;我要阻止幕後黑手挑起三家間的不和。", "values": "1;2;3"}, "targetLine": {"option1": "line261", "option2": "line264", "option3": "line267"}}, {"id": 261, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false, "targetLine": "line270"}, {"id": 262, "prop": "character", "attributes": {"name": "avg_npc_252"}}, {"id": 263, "prop": "name", "attributes": {"content": "知道得越多，處境就越危險，我們可能沒有時間來確保所有細節，博士。", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 264, "prop": "Predicate", "attributes": {"references": "2"}, "endOfOpt": false, "targetLine": "line270"}, {"id": 265, "prop": "character", "attributes": {"name": "avg_npc_252"}}, {"id": 266, "prop": "name", "attributes": {"content": "這恐怕還只是個開始，博士。", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 267, "prop": "Predicate", "attributes": {"references": "3"}, "endOfOpt": false, "targetLine": "line270"}, {"id": 268, "prop": "character", "attributes": {"name": "avg_npc_252"}}, {"id": 269, "prop": "name", "attributes": {"content": "我必須提醒您，博士，這也許早已超越了您來此的初衷。", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 270, "prop": "Predicate", "attributes": {"references": "1;2;3"}, "endOfOpt": true}, {"id": 271, "prop": "character", "attributes": {"name": "avg_npc_252"}}, {"id": 272, "prop": "name", "attributes": {"content": "既然您這麼判斷，而且看起來十分有把握......那我也不會阻攔您。", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 273, "prop": "character", "attributes": {"name": "avg_npc_252"}}, {"id": 274, "prop": "name", "attributes": {"content": "事已至此，訊使和角峰，尤其還有崖心，考慮到他們都是希瓦艾什家的人，您打算告訴他們嗎？", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 275, "prop": "dialog", "attributes": {}}, {"id": 276, "prop": "character", "attributes": {"name": "avg_npc_252"}}, {"id": 277, "prop": "Decision", "attributes": {"options": "不。;......;由你判斷。", "values": "1;2;3"}, "targetLine": {"option1": "line278", "option2": "line281", "option3": "line284"}}, {"id": 278, "prop": "Predicate", "attributes": {"referenc