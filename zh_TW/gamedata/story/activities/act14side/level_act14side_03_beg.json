ure_art": "avg_npc_252"}, {"id": 201, "prop": "character", "attributes": {"name": "avg_npc_252"}}, {"id": 202, "prop": "name", "attributes": {"content": "不管你有什麼樣的計畫，這都太冒險了。這話你可能不記得了，但我以前就跟你說過很多很多次。", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 203, "prop": "dialog", "attributes": {}}, {"id": 204, "prop": "character", "attributes": {"name": "avg_npc_252"}}, {"id": 205, "prop": "Decision", "attributes": {"options": "我還是很相信你的。", "values": "1"}, "targetLine": {"option1": "line206"}}, {"id": 206, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 207, "prop": "character", "attributes": {"name": "avg_npc_252"}}, {"id": 208, "prop": "name", "attributes": {"content": "任何人都會失手，就算是我也一樣。如果可以的話我希望你能降低我的工作難度。", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 209, "prop": "character", "attributes": {"name": "avg_npc_252"}}, {"id": 210, "prop": "name", "attributes": {"content": "雖然可能性不高，但是萬一那些襲擊者中混入了更加專業的戰鬥人員怎麼辦？", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 211, "prop": "character", "attributes": {"name": "avg_npc_252"}}, {"id": 212, "prop": "name", "attributes": {"content": "如果他們帶了弩箭，又怎麼辦？", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 213, "prop": "dialog", "attributes": {}}, {"id": 214, "prop": "character", "attributes": {"name": "avg_npc_252"}}, {"id": 215, "prop": "Decision", "attributes": {"options": "別擔心，他們的目的不在於殺我。", "values": "1"}, "targetLine": {"option1": "line216"}}, {"id": 216, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 217, "prop": "character", "attributes": {"name": "avg_422_aurora_1#4$1"}}, {"id": 218, "prop": "name", "attributes": {"content": "我向博士彙報一下情況。", "name": "極光"}, "figure_art": "avg_422_aurora_1#4$1"}, {"id": 219, "prop": "character", "attributes": {"name": "avg_422_aurora_1#1$1"}}, {"id": 220, "prop": "name", "attributes": {"content": "Sharp隊長與我各自遵照博士托人帶來的口信，分別去布朗陶家的宅邸和希瓦艾什家的工廠追蹤可疑人員。", "name": "極光"}, "figure_art": "avg_422_aurora_1#1$1"}, {"id"