40, "prop": "Character", "attributes": {"name": "avg_npc_284_1#1$1"}}, {"id": 141, "prop": "name", "attributes": {"content": "但是您的傷......！", "name": "謝拉格戰士"}, "figure_art": "avg_npc_284_1#1$1"}, {"id": 142, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#1$1"}}, {"id": 143, "prop": "name", "attributes": {"content": "小傷罷了。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 144, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#4$1"}}, {"id": 145, "prop": "name", "attributes": {"content": "很出色的隱匿技巧，出其不意......沒想到竟會有人在聖獵中動手，確實是我大意了。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#4$1"}, {"id": 146, "prop": "Character", "attributes": {}}, {"id": 147, "prop": "name", "attributes": {"content": "......", "name": "？？？"}}, {"id": 148, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#7$1"}}, {"id": 149, "prop": "name", "attributes": {"content": "怎麼，不出來嗎？", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#7$1"}, {"id": 150, "prop": "name", "attributes": {"content": "既然有膽量挑這種場合動手，便是對耶拉岡德的大不敬之舉，應當早有覺悟。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#7$1"}, {"id": 151, "prop": "name", "attributes": {"content": "怎麼，難道沒有想過嗎？", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#7$1"}, {"id": 152, "prop": "Character", "attributes": {}}, {"id": 153, "prop": "name", "attributes": {"content": "......不必用這種方法激我。", "name": "？？？"}}, {"id": 154, "prop": "dialog", "attributes": {}}, {"id": 155, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 156, "prop": "Character", "attributes": {"name": "avg_npc_255_1#1$1", "fadetime": 1.5}}, {"id": 157, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 158, "prop": "name", "attributes": {"content": "我既然敢動手，當然早想過後果。", "name": "莫希"}, "figure_art": "avg_npc_255_1#1$1"}, {"id": 159, "prop": "Character", "attributes": {"name": "avg_npc_255_1#7$1"}}, {"id": 160, "prop": "name", "attributes": {"content": "恩希歐迪斯，今天我走不出這片獵場，你也休想能夠安然離開！", "name": "莫希"}, "figure_art": "avg_npc_255_1#7$1"}, {"id": 161, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#1$1"}}, {"id": 162, "prop": "name", "attributes": {"content": "看來你的決心不假。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 163, "prop": "Character", "attributes": {"name": "avg_npc_255_1#6$1"}}, {"id": 164, "prop": "name", "attributes": {"content": "不用你說！", "name": "莫希"}, "figure_art": "avg_npc_255_1#6$1"}, {"id": 165, "prop": "name", "attributes": {"content": "恩希歐迪斯，你裝作虔誠，實則對耶拉岡德沒有半點敬畏之心，你對謝拉格造成的傷害大家都看在眼裡！", "name": "莫希"}, "figure_art": "avg_npc_255_1#6$1"}, {"id": 166, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#1$1"}}, {"id": 167, "prop": "name", "attributes": {"content": "這樣的說法倒是很少當面聽到人說。眼下的謝拉格，會對我敵意如此之大的人並不多。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 168, "prop": "name", "attributes": {"content": "會有這樣的指責，若不是被觸及了利益，就是真正虔誠的極端信者......", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 169, "prop": "name", "attributes": {"content": "你認為自己屬於哪一邊？", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 170, "prop": "Character", "attributes": {"name": "avg_npc_255_1#6$1"}}, {"id": 171, "prop": "name", "attributes": {"content": "......你怎麼以為我會乖乖告訴你？", "name": "莫希"}, "figure_art": "avg_npc_255_1#6$1"}, {"id": 172, "prop": "Character", "attributes": {"name": "avg_npc_284_1#1$1", "name2": "avg_npc_255_1#6$1", "focus": 1.0}}, {"id": 173, "prop": "name", "attributes": {"content": "恩希歐迪斯大人，小心！", "name": "謝拉格戰士"}, "figure_art": "avg_npc_284_1#1$1"}, {"id": 174, "prop": "Character", "attributes": {"name": "avg_npc_284_1#1$1", "name2": "avg_npc_255_1#6$1"}}, {"id": 175, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 40.0, "ystrength": 10.0, "vibrato": 30.0, "randomness": 20.0, "fadeout": "true", "block": "false"}}, {"id": 176, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 177, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 178, "prop": "PlaySound", "attributes": {"key": "$e_atk_arrow_h", "volume": 1.0}}, {"id": 179, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 180, "prop": "Delay", "attributes": {"time": 0.7}}, {"id": 181, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 3.0, "ystrength": 3.0, "vibrato": 10.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 182, "prop": "Character", "attributes": {"name": "char_empty", "name2": "avg_npc_255_1#1$1", "fadetime": 0.7}}, {"id": 183, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown1", "volume": 1.0}}, {"id": 184, "prop": "dialog", "attributes": {}}, {"id": 185, "prop": "Character", "attributes": {"name": "avg_npc_255_1#6$1"}}, {"id": 186, "prop": "name", "attributes": {"content": "少妨礙我！", "name": "莫希"}, "figure_art": "avg_npc_255_1#6$1"}, {"id": 187, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#1$1"}}, {"id": 188, "prop": "name", "attributes": {"content": "很遺憾。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 189, "prop": "name", "attributes": {"content": "這些忽然發狂的野獸也是提前準備好的吧？聖獵中，我隨行的護衛不多，若他們都被絆住手腳，這確實會是個難得的好機會。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 190, "prop": "name", "attributes": {"content": "但......看來你的機會到此為止了。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 191, "prop": "Character", "attributes": {"name": "avg_npc_255_1#6$1"}}, {"id": 192, "prop": "name", "attributes": {"content": "......你這是在小看我？", "name": "莫希"}, "figure_art": "avg_npc_255_1#6$1"}, {"id": 193, "prop": "name", "attributes": {"content": "你已經被我傷到，就算你再怎麼輕描淡寫，也沒法瞞過我！", "name": "莫希"}, "figure_art": "avg_npc_255_1#6$1"}, {"id": 194, "prop": "name", "attributes": {"content": "你的行動已經沒有那麼流暢了吧。只要我再射中你一次，就......", "name": "莫希"}, "figure_art": "avg_npc_255_1#6$1"}, {"id": 195, "prop": "Character", "attributes": {"n