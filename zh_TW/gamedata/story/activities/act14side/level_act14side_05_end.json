re_art": "avg_172_svrash_1#4$1"}, {"id": 321, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#1$1", "name2": "avg_npc_252", "focus": 1.0}}, {"id": 322, "prop": "name", "attributes": {"content": "你沒有阻攔她。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 323, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#1$1", "name2": "avg_npc_252", "focus": 2.0}}, {"id": 324, "prop": "name", "attributes": {"content": "我接到的任務裡不包括這一條。", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 325, "prop": "name", "attributes": {"content": "而且你看上去也並不吃驚。", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 326, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#1$1", "name2": "avg_npc_252", "focus": 1.0}}, {"id": 327, "prop": "name", "attributes": {"content": "能提前在獵場佈局的人選不多，要找證據，多少都能找得到。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 328, "prop": "name", "attributes": {"content": "雖然還是有人證在最省力......不過證人的生死倒也沒有那麼重要。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 329, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#1$1", "name2": "avg_npc_252", "focus": 2.0}}, {"id": 330, "prop": "name", "attributes": {"content": "......你的那幾個手下人都不在。", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 331, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#1$1", "name2": "avg_npc_252", "focus": 1.0}}, {"id": 332, "prop": "name", "attributes": {"content": "或許是都被發狂的野獸攔住了吧。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 333, "prop": "name", "attributes": {"content": "關於這一點，還要替我多謝博士。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 334, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#1$1", "name2": "avg_npc_252", "focus": 2.0}}, {"id": 335, "prop": "name", "attributes": {"content": "......", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 336, "prop": "Character", "attributes": {"name": "avg_199_yak_1#6$1"}}, {"id": 337, "prop": "name", "attributes": {"content": "老爺！", "name": "角峰"}, "figure_art": "avg_199_yak_1#6$1"}, {"id": 338, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#1$1", "name2": "avg_npc_252", "focus": 1.0}}, {"id": 339, "prop": "name", "attributes": {"content": "情況怎麼樣？", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 340, "prop": "Character", "attributes": {"name": "avg_199_yak_1#6$1"}}, {"id": 341, "prop": "name", "attributes": {"content": "都解決了。有人受了點傷，但沒什麼大礙。", "name": "角峰"}, "figure_art": "avg_199_yak_1#6$1"}, {"id": 342, "prop": "name", "attributes": {"content": "魏斯那邊剛剛傳了消息——", "name": "角峰"}, "figure_art": "avg_199_yak_1#6$1"}, {"id": 343, "prop": "Character", "attributes": {"name": "avg_199_yak_1#4$1"}}, {"id": 344, "prop": "name", "attributes": {"content": "Sharp先生，你怎麼會在這裡......？", "name": "角峰"}, "figure_art": "avg_199_yak_1#4$1"}, {"id": 345, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#1$1", "name2": "avg_npc_252", "focus": 2.0}}, {"id": 346, "prop": "name", "attributes": {"content": "任務。", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 347, "prop": "Character", "attributes": {"name": "avg_199_yak_1#4$1"}}, {"id": 348, "prop": "name", "attributes": {"content": "是博士的吩咐？難道博士竟預料到會有這樣的事發生......？", "name": "角峰"}, "figure_art": "avg_199_yak_1#4$1"}, {"id": 349, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#1$1", "name2": "avg_npc_252", "focus": 2.0}}, {"id": 350, "prop": "name", "attributes": {"content": "......", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 351, "prop": "name", "attributes": {"content": "你是怎麼認出我的？", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 352, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#1$1", "name2": "avg_npc_252", "focus": 1.0}}, {"id": 353, "prop": "name", "attributes": {"content": "這不是難事。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 354, "prop": "name", "attributes": {"content": "我說過。我對存在本身就能破壞局面的戰士，非常瞭解。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 355, "prop": "Character", "attributes": {"name": "avg_npc_254_1#7$1"}}, {"id": 356, "prop": "name", "attributes": {"content": "恩希歐迪斯！", "name": "阿克托斯"}, "figure_art": "avg_npc_254_1#7$1"}, {"id": 357, "prop": "name", "attributes": {"content": "你怎麼樣，刺客人呢？！", "name": "阿克托斯"}, "figure_art": "avg_npc_254_1#7$1"}, {"id": 358, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#1$1", "name2": "avg_npc_252", "focus": 2.0}}, {"id": 359, "prop": "name", "attributes": {"content": "......", "name": "Sharp"}, "figure_art": "avg_npc_252"}, {"id": 360, "prop": "dialog", "attributes": {}}, {"id": 361, "prop": "PlaySound", "attributes": {"key": "$d_avg_snowbootwalk", "volume": 1.0}}, {"id": 362, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "xpos": 300.0, "fadetime": 2.0, "block": "false"}}, {"id": 363, "prop": "character", "attributes": {"name": "avg_172_svrash_1#1$1", "name2": "char_empty", "fadetime": 0.5}}, {"id": 364, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 365, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#1$1"}}, {"id": 366, "prop": "name", "attributes": {"content": "阿克托斯，你會趕來實在出乎我的意料，這是否是希瓦艾什與佩爾羅契重歸於好的徵兆？", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 367, "prop": "Character", "attributes": {"name": "avg_npc_254_1#7$1"}}, {"id": 368, "prop": "name", "attributes": {"content": "呸！我來，與你沒有半點關係！", "name": "阿克托斯"}, "figure_art": "avg_npc_254_1#7$1"}, {"id": 369, "prop": "name", "attributes": {"content": "我不過是要將膽敢在耶拉岡德的祭典上作亂的卑鄙小人親手揪出！讓他付出應有的代價！", "name": "阿克托斯"}, "figure_art": "avg_npc_254_1#7$1"}, {"id": 370, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#7$1"}}, {"id": 371, "prop": "name", "attributes": {"content": "你確實是耶拉岡德最虔誠的信徒，阿克托斯。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#7$1"}, {"id": 372, "prop": "name", "attributes": {"content": "不過，恐怕你來遲了。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#7$1"}, {"id": 373, "prop": "Character", "attributes": {"name": "avg_npc_254_1#7$1"}}, {"id": 374, "prop": "name", "attributes": {"content": "你這是什麼意思？你恩希歐迪斯沒道理會放走區區一個刺客，人到底被你藏哪裡去了？", "name": "阿克托斯"}, "figure_art": "avg_npc_254_1#7$1"}, {"id": 375, "prop": "name", "attributes": {"content": "等等，這片懸崖......難道？！", "name": "阿克托斯"}, "figure_art": "avg_npc_254_1#7$1"}, {"id": 376, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#1$1"}}, {"id": 377, "prop": "name", "attributes": {"content": "就是你想的那樣，阿克托斯。我的部下會去搜索對方的蹤跡。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 378, "prop": "name", "attributes": {"content": "繼續狩獵吧。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 379, "prop": "Character", "attributes": {"name": "avg_npc_254_1#7$1"}}, {"id": 380, "prop": "name", "attributes": {"content": "地上有血，你受傷了？", "name": "阿克托斯"}, "figure_art": "avg_npc_254_1#7$1"}, {"id": 381, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#1$1"}}, {"id": 382, "prop": "name", "attributes": {"content": "小傷而已。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 383, "prop": "Character", "attributes": {"name": "avg_199_yak_1#6$1"}}, {"id": 384, "prop": "name", "attributes": {"content": "老爺，你的傷得立刻處理！", "name": "角峰"}, "figure_art": "avg_199_yak_1#6$1"}, {"id": 385, "prop": "name", "attributes": {"content": "至少......至少要先止血！", "name": "角峰"}, "figure_art": "avg_199_yak_1#6$1"}, {"id": 386, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#8$1"}}, {"id": 387, "prop": "name", "attributes": {"content": "繼續狩獵。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#8$1"}, {"id": 388, "prop": "name", "attributes": {"content": "耶拉岡德的祭典，不應因我個人緣故而有任何閃失。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#8$1"}, {"id": 389, "prop": "Character", "attributes": {"name": "avg_199_yak_1#6$1"}}, {"id": 390, "prop": "name", "attributes": {"content": "......", "name": "角峰"}, "figure_art": "avg_199_yak_1#6$1"}, {"id": 391, "prop": "Character", "attributes": {"name": "avg_172_svrash_1#1$1"}}, {"id": 392, "prop": "name", "attributes": {"content": "通知其他人，一切照常。", "name": "恩希歐迪斯"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 393, "prop": "Character", "attributes": {"name": "avg_199_yak_1#3$1"}}, {"id": 394, "prop": "name", "attributes": {"content": "......是。", "name": "角峰"}, "figure_art": "avg_199_yak_1#3$1"}, {"id": 395, "prop": "Dialog", "attributes": {}}, {"id": 396, "prop": "Character", "attributes": {}}, {"id": 397, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 398, "prop": "Background", "attributes": {"image": "24_g13_mountpath_s", "screenadapt": "showall", "fadetime": 1.5}}, {"id": 399, "prop": "PlaySound", "attributes": {"key": "$d_avg_snowstormlp", "volume": 1.0, "loop": "true", "channel": "bse", "fadetime": 2.0}}, {"id": 400, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 401, "prop": "name", "attributes": {"content": "在眾人矚目之下，希瓦艾什家年輕的主人邁開腳步。"}}, {"id": 402, "prop": "name", "attributes": {"content": "風雪縈繞在其周身，又在其頷首仰頭間四散，未有任何一冊經卷曾記載這樣一種身姿。"}}, {"id": 403, "prop": "name", "attributes": {"content": "斑駁的赤色在他身後由深到淡，最後歸為純白的印記，融入山川。"}}, {"id": 404, "prop": "name", "attributes": {"content": "無人敢攔，無人可阻。"}}, {"id": 405, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 406, "prop": "name", "attributes": {"content": "恩希歐迪斯向前走。"}}, {"id": 407, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 408, "prop": "StopSound", "attributes": {"channel": "bse", "fadetime": 1.0}}, {"id": 409, "prop": "Dialog", "attributes": {}}, {"id": 410, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 411, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 412, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 413, "prop": "Character", "attributes": {}}, {"id": 414, "prop": "Image", "attributes": {}}, {"id": 415, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}