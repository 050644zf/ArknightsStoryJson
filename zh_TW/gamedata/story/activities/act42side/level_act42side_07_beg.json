ontent": "萬國信使莫斯提馬、“監管人”菲亞梅塔。", "name": "保育員"}, "figure_art": "avg_npc_1785_1#1$1"}, {"id": 307, "prop": "name", "attributes": {"content": "兩位辛苦了，感謝兩位為拉特蘭的付出。現在，請移駕……", "name": "保育員"}, "figure_art": "avg_npc_1785_1#1$1"}, {"id": 308, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_213_mostma_1#8$1", "focus": "m"}}, {"id": 309, "prop": "name", "attributes": {"content": "移駕到那些已經塞滿人的育嬰室？", "name": "莫斯提馬"}, "figure_art": "avg_213_mostma_1#8$1"}, {"id": 310, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1785_1#1$1", "focus": "m"}}, {"id": 311, "prop": "name", "attributes": {"content": "儀式很快就要開始了，牧首將率先為在拉特蘭棲居已久的黎博利啟聖。之後，墮天使破碎的光環與光翼也將得到修補。", "name": "保育員"}, "figure_art": "avg_npc_1785_1#1$1"}, {"id": 312, "prop": "name", "attributes": {"content": "還請兩位儘快動身，我會為兩位引路……", "name": "保育員"}, "figure_art": "avg_npc_1785_1#1$1"}, {"id": 313, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 314, "prop": "Dialog", "attributes": {}}, {"id": 315, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_1041_angel2_1#9$5", "posfrom": "100,0", "posto": "100,0", "bstart": 0.2, "bend": 0.7, "afrom": 0.0, "ato": 0.0, "duration": 0.0, "focus": "m"}}, {"id": 316, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_1041_angel2_1#9$5", "action": "zoom", "poszoom": "0.5,0.5", "scale": 1.0, "duration": 0.0, "focus": "m", "bstart": 0.2, "bend": 0.7, "isblock": "true"}}, {"id": 317, "prop": "charslot", "attributes": {"slot": "l", "afrom": 0.0, "ato": 1.0, "duration": 1.0, "focus": "m", "bstart": 0.2, "bend": 0.7, "isblock": "true"}}, {"id": 318, "prop": "PlaySound", "attributes": {"key": "$d_avg_punchsp5", "volume": 0.7}}, {"id": 319, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 25.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 320, "prop": "Delay", "attributes": {"time": 0.7}}, {"id": 321, "prop": "charslot", "attributes": {"slot": "l", "afrom": 1.0, "ato": 0.0,