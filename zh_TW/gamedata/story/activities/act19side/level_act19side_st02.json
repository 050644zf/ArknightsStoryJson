"line238"}}, {"id": 238, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 239, "prop": "character", "attributes": {"name": "char_249_muesys_1#4"}}, {"id": 240, "prop": "name", "attributes": {"content": "他們又啟程了。", "name": "繆爾賽思"}, "figure_art": "char_249_muesys_1#4"}, {"id": 241, "prop": "character", "attributes": {"name": "char_249_muesys_1#4"}}, {"id": 242, "prop": "name", "attributes": {"content": "下一次......他們又會遇見什麼呢？", "name": "繆爾賽思"}, "figure_art": "char_249_muesys_1#4"}, {"id": 243, "prop": "character", "attributes": {"name": "char_249_muesys_1#4"}}, {"id": 244, "prop": "name", "attributes": {"content": "一次又一次，循環往復......", "name": "繆爾賽思"}, "figure_art": "char_249_muesys_1#4"}, {"id": 245, "prop": "character", "attributes": {"name": "char_249_muesys_1#4"}}, {"id": 246, "prop": "name", "attributes": {"content": "以前的家已經回不去了，也許永遠都不會有什麼新的地方可以被稱作家園。", "name": "繆爾賽思"}, "figure_art": "char_249_muesys_1#4"}, {"id": 247, "prop": "character", "attributes": {"name": "avg_npc_521_1#1$1"}}, {"id": 248, "prop": "name", "attributes": {"content": "博士，我發現萊茵的人正在挖掘實驗區的廢墟......", "name": "Mechanist"}, "figure_art": "avg_npc_521_1#1$1"}, {"id": 249, "prop": "character", "attributes": {"name": "avg_npc_521_1#1$1"}}, {"id": 250, "prop": "name", "attributes": {"content": "......繆爾賽思主任，你也在這裡。", "name": "Mechanist"}, "figure_art": "avg_npc_521_1#1$1"}, {"id": 251, "prop": "character", "attributes": {"name": "char_249_muesys_1#5"}}, {"id": 252, "prop": "name", "attributes": {"content": "......", "name": "繆爾賽思"}, "figure_art": "char_249_muesys_1#5"}, {"id": 253, "prop": "dialog", "attributes": {}}, {"id": 254, "prop": "character", "attributes": {"name": "char_249_muesys_1#5"}}, {"id": 255, "prop": "Decision", "attributes": {"options": "繆爾賽思......", "values": "1"}, "targetLine": {"option1": "line256"}}, {"id": 256, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 257, "prop": "dialog", "attributes": {}}, {"id": 258, "prop": "Decision", "attributes": {"options": "你想好什麼時候回答我的問題了嗎？", "values": "1"}, "targetLine": {"option1": "line259"}}, {"id": 259, "prop": "Predicate", "attributes": {"references": "1"}, "endOfOpt": false}, {"id": 260, "prop": "character", "attributes": {"name": "char_249_muesys_1#4"}}, {"id": 261, "prop": "name", "attributes": {"content": "問題......我在意的究竟是什麼嗎？", "name": "繆爾賽思"}, "figure_art": "char_249_muesys_1#4"}, {"id": 262, "prop": "character", "attributes": {"name": "char_249_muesys_1#5"}}, {"id": 263, "prop": "name", "attributes": {"content": "當我準備好開口的時候......", "name": "繆爾賽思"}, "figure_art": "char_249_muesys_1#5"}, {"id": 264, "prop": "character", "attributes": {"name": "char_249_muesys_1#1"}}, {"id": 265, "prop": "name", "attributes": {"content": "你會知道的，Dr.{@nickname}。", "name": "繆爾賽思"}, "figure_art": "char_249_muesys_1#1"}, {"id": 266, "prop": "Dialog", "attributes": {}}, {"id": 267, "prop": "stopmusic", "attributes": {"fadetime": 3.0}}, {"id": 268, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 269, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 270, "prop": "Background", "attributes": {"image": "29_g7_mainstreet_n", "screenadapt": "coverall"}}, {"id": 271, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 272, "prop": "Dialog", "attributes": {}}, {"id": 273, "prop": "PlayMusic", "attributes": {"intro": "$darkness01_intro", "key": "$darkness01_loop", "volume": 0.8, "crossfade": 1.0, "delay": 0.5}}, {"id": 274, "prop": "PlaySound", "attributes": {"key": "$transmission", "volume": 0.9}}, {"id": 275, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 276, "prop": "character", "attributes": {"name": "avg_npc_536_1#3$1"}}, {"id": 277, "prop": "name", "attributes": {"content": "......您放心，事情都處理好了，不會有民眾知道359號基地發生了什麼，更不可能有人拿這件事干擾您接下來的選舉。", "name": "霍爾海雅"}, "figure_art": "avg_npc_536_1#3$1"}, {"id": 278, "prop": "character", "attributes": {"name": "avg_npc_536_1#3$1"}}, {"id": 279, "prop": "name", "attributes": {"content": "是的，我已經離開特里蒙，正在前往特區的路上。", "name": "霍爾海雅"}, "figure_art": "avg_npc_536_1#3$1"}, {"id": 280, "prop": "character", "attributes": {"name": "avg_npc_536_1#3$1"}}, {"id": 281, "prop": "name", "attributes": {"content": "斐爾迪南......", "name": "霍爾海雅"}, "figure_art": "avg_npc_536_1#3$1"}, {"id": 282, "prop": "character", "attributes": {"name": "avg_npc_536_1#3$1"}}, {"id": 283, "prop": "name", "attributes": {"content": "他不會再構成任何威脅了，我向您保證。", "name": "霍爾海雅"}, "figure_art": "avg_npc_536_1#3$1"}, {"id": 284, "prop": "Dialog", "attributes": {}}, {"id": 285, "prop": "PlaySound", "attributes": {"key": "$transmission", "volume": 0.9}}, {"id": 286, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 287, "prop": "Character", "attributes": {"name": "avg_npc_399_1#1$1"}}, {"id": 288, "prop": "name", "attributes": {"content": "女士......您、您明明就在萊茵生命外面，您為什麼要欺騙副總統？", "name": "哥倫比亞雇傭兵"}, "figure_art": "avg_npc_399_1#1$1"}, {"id": 289, "prop": "character", "attributes": {"name": "avg_npc_536_1#3$1"}}, {"id": 290, "prop": "name", "attributes": {"content": "因為......", "name": "霍爾海雅"}, "figure_art": "avg_npc_536_1#3$1"}, {"id": 291, "prop": "character", "attributes": {"name": "avg_npc_536_1#1$1"}}, {"id": 292, "prop": "name", "attributes": {"content": "我從來不會忘記自己最初的目標。", "name": "霍爾海雅"}, "figure_art": "avg_npc_536_1#1$1"}, {"id": 293, "prop": "Dialog", "attributes": {}}, {"id": 294, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 295, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 296, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 297, "prop": "Background", "attributes": {"image": "27_g26_dusk_wild", "screenadapt": "coverall"}}, {"id": 298, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 299, "prop": "PlayMusic", "attributes": {"intro": "$drift_intro", "key": "$drift_loop", "volume": 0.8, "crossfade": 1.0, "delay": 0.5}}, {"id": 300, "prop": "PlaySound", "attributes": {"key": "$d_avg_mechawalk", "volume": 0.5}}, {"id": 301, "prop": "name", "attributes": {"content": "他記不清楚自己走了多遠。"}}, {"id": 302, "prop": "name", "attributes": {"content": "喉嚨裡的刺痛與乾澀提醒著他，他的身體經受不住這樣的勞累。"}}, {"id": 303, "prop": "name", "attributes": {"content": "可是......特里蒙彷彿就在身後。"}}, {"id": 304, "prop": "name", "attributes": {"content": "又可能是在身前。"}}, {"id": 305, "prop": "name", "attributes": {"content": "移動城市的陰影無比巨大，甚至隨著時間的流逝而不斷生長著。"}}, {"id": 306, "prop": "name", "attributes": {"content": "他要儘快......儘快......"}}, {"id": 307, "prop": "name", "attributes": {"content": "儘快去哪裡？最近的接應地點......那裡的人會不會和埃琳娜還有霍爾海雅一樣，背叛他？"}}, {"id": 308, "prop": "dialog", "attributes": {}}, {"id": 309, "prop": "character", "attributes": {"name": "avg_npc_534_1#1$1", "name2": "avg_npc_534_1#1$1", "fadetime": 2.0}}, {"id": 310, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 311, "prop": "name", "attributes": {"content": "......站住。", "name": "拓荒隊成員"}}, {"id": 312, "prop": "character", "attributes": {}}, {"id": 313, "prop": "name", "attributes": {"content": "......", "name": "沉默的動力甲"}}, {"id": 314, "prop": "character", "attributes": {"name": "avg_npc_534_1#1$1"}}, {"id": 315, "prop": "name", "attributes": {"content": "我們知道你是誰。", "name": "拓荒隊成員"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 316, "prop": "character", "attributes": {"name": "avg_npc_534_1#1$1"}}, {"id": 317, "prop": "name", "attributes": {"content": "斐爾迪南......你以為你在對我們做了那麼多之後，還能安然無恙地一走了之嗎？", "name": "拓荒隊成員"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 318, "prop": "character", "attributes": {}}, {"id": 319, "prop": "name", "attributes": {"content": "......", "name": "沉默的動力甲"}}, {"id": 320, "prop": "character", "attributes": {"name": "avg_npc_534_1#1$1"}}, {"id": 321, "prop": "name", "attributes": {"content": "別以為這鐵東西能嚇退我們。你只會誇誇其談，並不能真正駕馭它。", "name": "拓荒隊成員"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 322, "prop": "character", "attributes": {"name": "avg_npc_534_1#1$1"}}, {"id": 323, "prop": "name", "attributes": {"content": "就算你對我們開火，把我們全部殺死在這裡......", "name": "拓荒隊成員"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 324, "prop": "character", "attributes": {"name": "avg_npc_534_1#1$1"}}, {"id": 325, "prop": "name", "attributes": {"content": "你也會遇到下一批拓荒者。", "name": "拓荒隊成員"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 326, "prop": "character", "attributes": {"name": "avg_npc_534_1#1$1"}}, {"id": 327, "prop": "name", "attributes": {"content": "看看你眼前的荒野吧，這裡全都是你的敵人！", "name": "拓荒隊成員"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 328, "prop": "character", "attributes": {}}, {"id": 329, "prop": "name", "attributes": {"content": "......", "name": "沉默的動力甲"}}, {"id": 330, "prop": "name", "attributes": {"content": "沒有關係。"}}, {"id": 331, "prop": "name", "attributes": {"content": "他親手研發的“遞質”就在手邊，只要他選擇注射，他就能瞬間讓這動力甲聽話，這些所謂的敵人全都不足為懼。"}}, {"id": 332, "prop": "name", "attributes": {"content": "可是他為什麼沒有動？"}}, {"id": 333, "prop": "name", "attributes": {"content": "是因為他不像多蘿西，沒有那個勇氣嗎？"}}, {"id": 334, "prop": "name", "attributes": {"content": "還是因為......"}}, {"id": 335, "prop": "Dialog", "attributes": {}}, {"id": 336, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 337, "prop": "name", "attributes": {"content": "斐爾迪南，你才是那個被你眼中的宏大構想——被“時代”所拋下的人。"}}, {"id": 338, "prop": "name", "attributes": {"content": "因為你從不認為自己正身處這個時代之中。"}}, {"id": 339, "prop": "name", "attributes": {"content": "你口口聲聲說著把握當下，總是在思考，在操縱。你從不感受。"}}, {"id": 340, "prop": "name", "attributes": {"content": "這是誰的聲音？是......埃琳娜？"}}, {"id": 341, "prop": "name", "attributes": {"content": "是啊，要是不想被拋下的話......他必須成為其中一部分。"}}, {"id": 342, "prop": "dialog", "attributes": {}}, {"id": 343, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 344, "prop": "Background", "attributes": {"image": "27_g26_dusk_wild", "screenadapt": "coverall"}}, {"id": 345, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 346, "prop": "character", "attributes": {}}, {"id": 347, "prop": "name", "attributes": {"content": "......", "name": "沉默的動力甲"}}, {"id": 348, "prop": "name", "attributes": {"content": "動力甲沉默著，不再向前，也不再掙扎。"}}, {"id": 349, "prop": "name", "attributes": {"content": "它舉起了自己的雙臂......"}}, {"id": 350, "prop": "name", "attributes": {"content": "就像在擁抱面前的風、日光和大地一樣。"}}, {"id": 351, "prop": "name", "attributes": {"content": "憤怒的拓荒者們一擁而上，如同那頭在基地上空咆哮的銀色怪物——吞沒了面前鋼鐵鑄就的皮囊。"}}, {"id": 352, "prop": "Dialog", "attributes": {}}, {"id": 353, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 354, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 355, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 356, "prop": "Background", "attributes": {"image": "29_g10_senioroffice", "screenadapt": "coverall"}}, {"id": 357, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 358, "prop": "PlayMusic", "attributes": {"intro": "$darkness01_intro", "key": "$darkness01_loop", "volume": 0.8, "crossfade": 1.0, "delay": 0.5}}, {"id": 359, "prop": "Character", "attributes": {"name": "avg_npc_537_1#1$1"}}, {"id": 360, "prop": "name", "attributes": {"content": "......梅蘭德基金會對此事還有什麼疑問？", "name": "克麗斯騰"}, "figure_art": "avg_npc_537_1#1$1"}, {"id": 361, "prop": "character", "attributes": {}}, {"id": 362, "prop": "name", "attributes": {"content": "不，總轄女士。", "name": "？？？"}}, {"id": 363, "prop": "name", "attributes": {"content": "這一次我並非代表梅蘭德而來。", "name": "？？？"}}, {"id": 364, "prop": "Character", "attributes": {"name": "avg_npc_537_1#1$1"}}, {"id": 365, "prop": "name", "attributes": {"content": "......我的時間並不充裕。", "name": "克麗斯騰"}, "figure_art": "avg_npc_537_1#1$1"}, {"id": 366, "prop": "character", "attributes": {}}, {"id": 367, "prop": "name", "attributes": {"content": "正好，我也偏好有話直說。", "name": "？？？"}}, {"id": 368, "prop": "name", "attributes": {"content": "你回收了359號基地裡實驗中最核心的部分。", "name": "？？？"}}, {"id": 369, "prop": "name", "attributes": {"content": "“中樞”被多蘿西徹底摧毀——呈遞給政府的報告上是這麼寫的。", "name": "？？？"}}, {"id": 370, "prop": "name", "attributes": {"content": "而我恰巧看見了一支打扮低調的隊伍，將某一輛封閉的載具開進了你的私人實驗室。", "name": "？？？"}}, {"id": 371, "prop": "name", "attributes": {"content": "塞雷婭說你放任了斐爾迪南......倒不如說，你利用了他。", "name": "？？？"}}, {"id": 372, "prop": "name", "attributes": {"content": "你最想要的東西，如今的確到了你的桌子上。", "name": "？？？"}}, {"id": 373, "prop": "Character", "attributes": {"name": "avg_npc_537_1#1$1"}}, {"id": 374, "prop": "name", "attributes": {"content": "清掃359號基地是萊茵生命不得不承接的一項工作。", "name": "克麗斯騰"}, "figure_art": "avg_npc_537_1#1$1"}, {"id": 375, "prop": "Character", "attributes": {"name": "avg_npc_537_1#1$1"}}, {"id": 376, "prop": "name", "attributes": {"content": "每天都會有無數失敗實驗的副產物被銷毀。", "name": "克麗斯騰"}, "figure_art": "avg_npc_537_1#1$1"}, {"id": 377, "prop": "Character", "attributes": {"name": "avg_npc_537_1#1$1"}}, {"id": 378, "prop": "name", "attributes": {"content": "無論你以為自己看到的是什麼，那都並不值得萊茵之外的任何人關注。", "name": "克麗斯騰"}, "figure_art": "avg_npc_537_1#1$1"}, {"id": 379, "prop": "character", "attributes": {}}, {"id": 380, "prop": "name", "attributes": {"content": "銷毀？當然，那破銅爛鐵此刻肯定已經從你的桌上消失了。", "name": "？？？"}}, {"id": 381, "prop": "name", "attributes": {"content": "證據可以被毀滅，記憶可以被篡改，但任何事件只要發生了，就一定會對後續事件產生影響。", "name": "？？？"}}, {"id": 382, "prop": "name", "attributes": {"content": "洛肯，帕爾維斯，斐爾迪南......或許到了未來某個時間點，他們的名字不會留下任何記錄。", "name": "？？？"}}, {"id": 383, "prop": "name", "attributes": {"content": "但歷史的走向確實因他們而改變。", "name": "？？？"}}, {"id": 384, "prop": "name", "attributes": {"content": "可植入的施術單元，復活古代薩卡茲力量的嵌合技術，能被遠程操控的動力甲，更大範圍的精神實體網路......", "name": "？？？"}}, {"id": 385, "prop": "name", "attributes": {"content": "下一項震撼這個時代的實驗會是什麼呢？", "name": "？？？"}}, {"id": 386, "prop": "Character", "attributes": {"name": "avg_npc_537_1#1$1"}}, {"id": 387, "prop": "name", "attributes": {"content": "研究者只會探索一切可能性。", "name": "克麗斯騰"}, "figure_art": "avg_npc_537_1#1$1"}, {"id": 388, "prop": "Character", "attributes": {"name": "avg_npc_537_1#1$1"}}, {"id": 389, "prop": "name", "attributes": {"content": "我從不做預言。", "name": "克麗斯騰"}, "figure_art": "avg_npc_537_1#1$1"}, {"id": 390, "prop": "character", "attributes": {}}, {"id": 391, "prop": "name", "attributes": {"content": "假如記憶能夠跨越時間的限制，預言不過就是重新發現被掩埋的歷史。", "name": "？？？"}}, {"id": 392, "prop": "dialog", "attributes": {}}, {"id": 393, "prop": "character", "attributes": {}}, {"id": 394, "prop": "character", "attributes": {"name": "avg_npc_536_1#3$1", "fadetime": 1.0}}, {"id": 395, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 396, "prop": "name", "attributes": {"content": "我們重新認識一下彼此吧，克麗斯騰·萊特。", "name": "霍爾海雅"}, "figure_art": "avg_npc_536_1#3$1"}, {"id": 397, "prop": "character", "attributes": {"name": "avg_npc_536_1#3$1"}}, {"id": 398, "prop": "name", "attributes": {"content": "我是霍爾海雅，歷史學者，哥倫比亞占星研究協會名譽會長。", "name": "霍爾海雅"}, "figure_art": "avg_npc_536_1#3$1"}, {"id": 399, "prop": "character", "attributes": {"name": "avg_npc_536_1#2$1"}}, {"id": 400, "prop": "name", "attributes": {"content": "就讓我冒昧地做一次預言——", "name": "霍爾海雅"}, "figure_art": "avg_npc_536_1#2$1"}, {"id": 401, "prop": "character", "attributes": {"name": "avg_npc_536_1#2$1"}}, {"id": 402, "prop": "name", "attributes": {"content": "也許......很快我就會成為你最需要的合作夥伴。", "name": "霍爾海雅"}, "figure_art": "avg_npc_536_1#2$1"}, {"id": 403, "prop": "Dialog", "attributes": {}}, {"id": 404, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 405, "prop": "character", "attributes": {"fadetime": 0.0}}, {"id": 406, "prop": "Background", "attributes": {"image": "29_g9_headquarter", "screenadapt": "coverall"}}, {"id": 407, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 408, "prop": "character", "attributes": {"name": "avg_npc_529_1#1$1"}}, {"id": 409, "prop": "name", "attributes": {"content": "星極小姐，埃琳娜研究員還沒有回來。", "name": "萊茵研究員"}, "figure_art": "avg_npc_529_1#1$1"}, {"id": 410, "prop": "character", "attributes": {"name": "avg_274_Astesia_1#1"}}, {"id": 411, "prop": "name", "attributes": {"content": "嗯......她已經跟我說過。", "name": "星極"}, "figure_art": "avg_274_Astesia_1#1"}, {"id": 412, "prop": "character", "attributes": {"name": "avg_274_Astesia_1#7"}}, {"id": 413, "prop": "name", "attributes": {"content": "我只是想在這裡站一會，這樣的話，等她一回來，我就能看見她。", "name": "星極"}, "figure_art": "avg_274_Astesia_1#7"}, {"id": 414, "prop": "character", "attributes": {"name": "avg_npc_529_1#1$1"}}, {"id": 415, "prop": "name", "attributes": {"content": "哈哈......有時候我真羡慕埃琳娜，能有這樣關心著自己的姐姐。", "name": "萊茵研究員"}, "figure_art": "avg_npc_529_1#1$1"}, {"id": 416, "prop": "character", "attributes": {"name": "avg_274_Astesia_1#7"}}, {"id": 417, "prop": "name", "attributes": {"content": "唔......", "name": "星極"}, "figure_art": "avg_274_Astesia_1#7"}, {"id": 418, "prop": "dialog", "attributes": {}}, {"id": 419, "prop": "Character", "attributes": {"name": "char_empty"}}, {"id": 420, "prop": "characteraction", "attributes": {"name": "middle", "type": "move", "fadetime": 0.0, "block": "true"}}, {"id": 421, "prop": "Character", "attributes": {"name": "avg_npc_536_1#3$1", "fadetime": 0.5}}, {"id": 422, "prop": "characteraction", "attributes": {"name": "middle", "type": "move", "xpos": 150.0, "fadetime": 3.0, "block": "false"}}, {"id": 423, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.4}}, {"id": 424, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 425, "prop": "character", "attributes": {"fadetime": 2.0}}, {"id": 426, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 427, "prop": "character", "attributes": {"name": "avg_274_Astesia_1#7"}}, {"id": 428, "prop": "name", "attributes": {"content": "那位女士是......", "name": "星極"}, "figure_art": "avg_274_Astesia_1#7"}, {"id": 429, "prop": "character", "attributes": {"name": "avg_274_Astesia_1#4"}}, {"id": 430, "prop": "name", "attributes": {"content": "等等。", "name": "星極"}, "figure_art": "avg_274_Astesia_1#4"}, {"id": 431, "prop": "character", "attributes": {"name": "avg_274_Astesia_1#4"}}, {"id": 432, "prop": "name", "attributes": {"content": "天體儀......亮了？", "name": "星極"}, "figure_art": "avg_274_Astesia_1#4"}, {"id": 433, "prop": "dialog", "attributes": {}}, {"id": 434, "prop": "stopmusic", "attributes": {"fadetime": 3.0}}, {"id": 435, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 4.0, "block": "true"}}, {"id": 436, "prop": "Character", "attributes": {}}, {"id": 437, "prop": "Image", "attributes": {"image": "29_i10", "xScale": 0.85, "yScale": 0.85, "fadetime": 0.0}}, {"id": 438, "prop": "ImageTween", "attributes": {"xTo": 0.0, "yTo": 0.0, "duration": 40.0, "xScaleFrom": 0.85, "xScaleTo": 0.8, "yScaleFrom": 0.85, "yScaleTo": 0.8, "block": "false"}}, {"id": 439, "prop": "PlayMusic", "attributes": {"intro": "$newhope01_intro", "key": "$newhope01_loop", "volume": 0.8, "crossfade": 1.0, "delay": 0.5}}, {"id": 440, "prop": "Blocker", "attributes": {"a": 0.0, "fadetime": 3.0, "block": "false"}}, {"id": 441, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 442, "prop": "name", "attributes": {"content": "雨後的天幕總是格外清晰。"}}, {"id": 443, "prop": "name", "attributes": {"content": "這是為數不多值得克麗斯騰走出實驗室的理由之一。"}}, {"id": 444, "prop": "name", "attributes": {"content": "她並非喜愛著那些閃耀著的光點。猜想如果無法被證實，就只是自欺欺人的謊言。"}}, {"id": 445, "prop": "name", "attributes": {"content": "可謊言並不是毫無意義的。一個影子就算被扭曲了千萬遍，也依然是某樣真實之物的映射。"}}, {"id": 446, "prop": "name", "attributes": {"content": "謊言之所以存在，只為了昭示一件事——真相也確實存在。"}}, {"id": 447, "prop": "name", "attributes": {"content": "它就藏在這些閃耀的群星之間，而天幕並沒有看起來那麼遙遠。"}}, {"id": 448, "prop": "name", "attributes": {"content": "當她伸出手的時候，她一定能觸碰到它——"}}, {"id": 449, "prop": "name", "attributes": {"content": "觸碰到那千萬年來壓在人們頭頂的唯一真相。"}}, {"id": 450, "prop": "Dialog", "attributes": {}}, {"id": 451, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 452, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 453, "prop": "stopmusic", "attributes": {"fadetime": 3.0}}, {"id": 454, "prop": "Character", "attributes": {}}, {"id": 455, "prop": "Image", "attributes": {}}, {"id": 456, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}