}, {"id": 363, "prop": "character", "attributes": {"name": "avg_npc_527_1#1$1", "fadetime": 1.5}}, {"id": 364, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 365, "prop": "character", "attributes": {"name": "avg_npc_527_1#1$1", "name2": "avg_1027_greyy2_1#4$2", "focus": 1.0}}, {"id": 366, "prop": "name", "attributes": {"content": "你的記性還不錯。", "name": "瑪麗"}, "figure_art": "avg_npc_527_1#1$1"}, {"id": 367, "prop": "character", "attributes": {"name": "avg_npc_527_1#1$1", "name2": "avg_1027_greyy2_1#6$2", "focus": 2.0}}, {"id": 368, "prop": "name", "attributes": {"content": "您......您怎麼會在這裡？", "name": "格雷伊"}, "figure_art": "avg_1027_greyy2_1#6$2"}, {"id": 369, "prop": "character", "attributes": {"name": "avg_npc_527_1#1$1", "name2": "avg_1027_greyy2_1#6$2", "focus": 1.0}}, {"id": 370, "prop": "name", "attributes": {"content": "那傢伙躲哪去了？", "name": "瑪麗"}, "figure_art": "avg_npc_527_1#1$1"}, {"id": 371, "prop": "character", "attributes": {"name": "avg_npc_527_1#1$1", "name2": "avg_1027_greyy2_1#5$2", "focus": 2.0}}, {"id": 372, "prop": "name", "attributes": {"content": "那傢伙......您是指桑尼先生？", "name": "格雷伊"}, "figure_art": "avg_1027_greyy2_1#5$2"}, {"id": 373, "prop": "character", "attributes": {"name": "avg_npc_527_1#5$1", "name2": "avg_1027_greyy2_1#5$2", "focus": 1.0}}, {"id": 374, "prop": "name", "attributes": {"content": "叫他趕緊給我出來。在一個孩子背後躲躲藏藏，這像什麼樣子？！", "name": "瑪麗"}, "figure_art": "avg_npc_527_1#5$1"}, {"id": 375, "prop": "character", "attributes": {"name": "avg_npc_527_1#5$1", "name2": "avg_1027_greyy2_1#6$2", "focus": 2.0}}, {"id": 376, "prop": "name", "attributes": {"content": "那個，女士，我已經長大了......", "name": "格雷伊"}, "figure_art": "avg_1027_greyy2_1#6$2"}, {"id": 377, "prop": "character", "attributes": {"name": "avg_npc_527_1#1$1", "name2": "avg_1027_greyy2_1#6$2", "focus": 1.0}}, {"id": 378, "prop": "name", "attributes": {"content": "嗯，剛長大。", "name": "瑪麗"}, "figure_art": "avg_npc_527_1#1$1"}, {"id": 379, "prop": "name", "attributes": {"content": "說吧，孩子，他們都去了哪裡？", "name": "瑪麗"}, "figure_art": "avg_npc_527_1#1$1"}, {"id": 380, "prop": "character", "attributes": {"name": "avg_npc_527_1#1$1", "name2": "avg_1027_greyy2_1#5$2", "focus": 2.0}}, {"id": 381, "prop": "name", "attributes": {"content": "拓荒者們就在附近的屋子裡......", "name": "格雷伊"}, "figure_art": "avg_1027_greyy2_1#5$2"}, {"id": 382, "prop": "character", "attributes": {"name": "avg_npc_527_1#1$1", "name2": "avg_1027_greyy2_1#5$2", "focus": 1.0}}, {"id": 383, "prop": "name", "attributes": {"content": "你知不知道，當你不好意思的時候，你的耳朵會有反應？", "name": "瑪麗"}, "figure_art": "avg_npc_527_1#1$1"}, {"id": 384, "prop": "character", "attributes": {"name": "avg_npc_527_1#1$1", "name2": "avg_1027_greyy2_1#4$2", "focus": 2.0}}, {"id": 385, "prop": "name", "attributes": {"content": "啊......啊？", "name": "格雷伊"}, "figure_art": "avg_1027_greyy2_1#4$2"}, {"id": 386, "prop": "character", "attributes": {"name": "avg_npc_527_1#2$1", "name2": "avg_1027_greyy2_1#4$2", "focus": 1.0}}, {"id": 387, "prop": "name", "attributes": {"content": "騙你的。", "name": "瑪麗"}, "figure_art": "avg_npc_527_1#2$1"}, {"id": 388, "prop": "name", "attributes": {"content": "但你也太好騙了點，對吧？", "name": "瑪麗"}, "figure_art": "avg_npc_527_1#2$1"}, {"id": 389, "prop": "character", "attributes": {"name": "avg_npc_527_1#1$1", "name2": "avg_1027_greyy2_1#4$2", "focus": 1.0}}, {"id": 390, "prop": "name", "attributes": {"content": "你最好還是把你瞭解的情況都說出來，這對我們來說都最簡單。", "name": "瑪麗"}, "figure_art": "avg_npc_527_1#1$1"}, {"id": 391, "prop": "name", "attributes": {"content": "否則的話，這供電是你修的，你已經能算作妨礙執法了。", "name": "瑪麗"}, "figure_art": "avg_npc_527_1#1$1"}, {"id": 392, "prop": "name", "attributes": {"content": "要是我沒法把真正的壞蛋帶出去，我也可以選擇帶你走。", "name": "瑪麗"}, "figure_art": "avg_npc_527_1#1$1"}, {"id": 393, "prop": "character", "attributes": {"name": "avg_npc_527_1#1$1", "name2": "avg_1027_greyy2_1#5$2", "focus": 2.0}}, {"id": 394, "prop": "name", "attributes": {"content": "不，請不要這麼做......", "name": "格雷伊"}, "figure_art": "avg_1027_greyy2_1#5$2"}, {"id": 395, "prop": "name", "attributes": {"content": "我、我不想給博士添麻煩。", "name": "格雷伊"}, "figure_art": "avg_1027_greyy2_1#5$2"}, {"id": 396, "prop": "character", "attributes": {"name": "avg_npc_527_1#1$1", "name2": "avg_1027_greyy2_1#5$2", "focus": 1.0}}, {"id": 397, "prop": "name", "attributes": {"content": "那你還猶豫什麼呢？說吧。", "name": "瑪麗"}, "figure_art": "avg_npc_527_1#1$1"}, {"id": 398, "prop": "character", "attributes": {"name": "avg_npc_527_1#1$1", "name2": "avg_1027_greyy2_1#6$2", "focus": 2.0}}, {"id": 399, "prop": "name", "attributes": {"content": "女士，我不確定您會不會相信......", "name": "格雷伊"}, "figure_art": "avg_1027_greyy2_1#6$2"}, {"id": 400, "prop": "name", "attributes": {"content": "我們剛才被一種從未見過的、會變形的銀色物體襲擊了。", "name": "格雷伊"}, "figure_art": "avg_1027_greyy2_1#6$2"}, {"id": 401, "prop": "dialog", "attributes": {}}, {"id": 402, "prop": "Dialog", "attributes": {}}, {"id": 403, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 404, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 405, "prop": "Character", "attributes": {}}, {"id": 406, "prop": "Background", "attributes": {"image": "29_g4_corridor", "screenadapt": "showall"}}, {"id": 407, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 408, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 409, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 410, "prop": "character", "attributes": {"name": "avg_npc_535_1#11$1", "name2": "avg_135_halo_1#8$1", "focus": 1.0}}, {"id": 411, "prop": "name", "attributes": {"content": "所以，她在裡面。", "name": "桑尼"}, "figure_art": "avg_npc_535_1#11$1"}, {"id": 412, "prop": "character", "attributes": {"name": "avg_npc_535_1#11$1", "name2": "avg_135_halo_1#8$1", "focus": 2.0}}, {"id": 413, "prop": "name", "attributes": {"content": "是的，這裡就是多蘿西的實驗室，也是整個實驗區的中心。", "name": "埃琳娜"}, "figure_art": "avg_135_halo_1#8$1"}, {"id": 414, "prop": "character", "attributes": {"name": "avg_npc_535_1#11$1", "name2": "avg_135_halo_1#8$1", "focus": 1.0}}, {"id": 415, "prop": "name", "attributes": {"content": "你確定？", "name": "桑尼"}, "figure_art": "avg_npc_535_1#11$1"}, {"id": 416, "prop": "Character", "attributes": {"name": "avg_108_silent_1#10$1"}}, {"id": 417, "prop": "name", "attributes": {"content": "桑尼先生，你怎麼了？臉色突然這麼難看......", "name": "赫默"}, "figure_art": "avg_108_silent_1#10$1"}, {"id": 418, "prop": "Character", "attributes": {"name": "avg_npc_535_1#11$1"}}, {"id": 419, "prop": "name", "attributes": {"content": "......沒什麼。", "name": "桑尼"}, "figure_art": "avg_npc_535_1#11$1"}, {"id": 420, "prop": "name", "attributes": {"content": "人在靠近真相的時候總是會有些緊張。", "name": "桑尼"}, "figure_art": "avg_npc_535_1#11$1"}, {"id": 421, "prop": "name", "attributes": {"content": "薩姆，記得我跟你說過的話吧？做好準備。", "name": "桑尼"}, "figure_art": "avg_npc_535_1#11$1"}, {"id": 422, "prop": "Character", "attributes": {"name": "avg_npc_534_1#1$1"}}, {"id": 423, "prop": "name", "attributes": {"content": "好的，領隊。", "name": "拓荒隊成員"}, "figure_art": "avg_npc_534_1#1$1"}, {"id": 424, "prop": "Character", "attributes": {"name": "avg_npc_535_1#11$1"}}, {"id": 425, "prop": "name", "attributes": {"content": "烏比卡博士，你能打開這扇門嗎？", "name": "桑尼"}, "figure_art": "avg_npc_535_1#11$1"}, {"id": 426, "prop": "Character", "attributes": {"name": "avg_135_halo_1#8$1"}}, {"id": 427, "prop": "name", "attributes": {"content": "當然。", "name": "埃琳娜"}, "figure_art": "avg_135_halo_1#8$1"}, {"id": 428, "prop": "character", "attributes": {"name": "avg_108_silent_1#6$1", "name2": "avg_135_halo_1#8$1", "focus": 1.0}}, {"id": 429, "prop": "name", "attributes": {"content": "（埃琳娜。）", "name": "赫默"}, "figure_art": "avg_108_silent_1#6$1"}, {"id": 430, "prop": "character", "attributes": {"name": "avg_108_silent_1#6$1", "name2": "avg_135_halo_1#8$1", "focus": 2.0}}, {"id": 431, "prop": "name", "attributes": {"content": "（嗯？）", "name": "埃琳娜"}, "figure_art": "avg_135_halo_1#8$1"}, {"id": 432, "prop": "character", "attributes": {"name": "avg_108_silent_1#6$1", "name2": "avg_135_halo_1#8$1", "focus": 1.0}}, {"id": 433, "prop": "name", "attributes": {"content": "（拓荒者們的神情不對勁......）", "name": "赫默"}, "figure_art": "avg_108_silent_1#6$1"}, {"id": 434, "prop": "character", "attributes": {"name": "avg_108_silent_1#6$1", "name2": "avg_135_halo_1#3$1", "focus": 2.0}}, {"id": 435, "prop": "name", "attributes": {"content": "（但我們已經走到這裡了啊。）", "name": "埃琳娜"}, "figure_art": "avg_135_halo_1#3$1"}, {"id": 436, "prop": "name", "attributes": {"content": "（奧利維亞，你剛才說服了我。我以為我們都是來解決問題的。）", "name": "埃琳娜"}, "figure_art": "avg_135_halo_1#3$1"}, {"id": 437, "prop": "character", "attributes": {"name": "avg_108_silent_1#6$1", "name2": "avg_135_halo_1#3$1", "focus": 1.0}}, {"id": 438, "prop": "name", "attributes": {"content": "（我不確定......）", "name": "赫默"}, "figure_art": "avg_108_silent_1#6$1"}, {"id": 439, "prop": "Character", "attributes": {"name": "avg_npc_535_1#11$1"}}, {"id": 440, "prop": "name", "attributes": {"content": "博士，我們都在等著。", "name": "桑尼"}, "figure_art": "avg_npc_535_1#11$1"}, {"id": 441, "prop": "character", "attributes": {}}, {"id": 442, "prop": "name", "attributes": {"content": "我也是。", "name": "溫柔的女聲"}}, {"id": 443, "prop": "name", "attributes": {"content": "各位，請進。", "name": "溫柔的女聲"}}, {"id": 444, "prop": "dialog", "attributes": {}}, {"id": 445, "prop": "character", "attributes": {}}, {"id": 446, "prop": "name", "attributes": {"content": "埃琳娜的手並沒有落到掌紋鎖上。"}}, {"id": 447, "prop": "name", "attributes": {"content": "但在真正的主人的控制下，實驗室的門還是在所有人面前打開了。"}}, {"id": 448, "prop": "Dialog", "attributes": {}}, {"id": 449, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 450, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 451, "prop": "Character", "attributes": {}}, {"id": 452, "prop": "Background", "attributes": {"image": "29_g5_laboratory", "screenadapt": 