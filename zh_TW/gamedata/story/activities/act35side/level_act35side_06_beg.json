igure_art": "avg_npc_1478_1#1$1"}, {"id": 128, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4058_pepe_1#8$1", "focus": "l"}}, {"id": 129, "prop": "name", "attributes": {"content": "知道了，我這就過去。", "name": "佩佩"}, "figure_art": "avg_4058_pepe_1#8$1"}, {"id": 130, "prop": "name", "attributes": {"content": "那你和阿娜特呢？", "name": "佩佩"}, "figure_art": "avg_4058_pepe_1#8$1"}, {"id": 131, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1478_1#1$1", "focus": "r"}}, {"id": 132, "prop": "name", "attributes": {"content": "作為博物館的管理人員，我們總得將文物盡數找回來。", "name": "梅捷緹克緹"}, "figure_art": "avg_npc_1478_1#1$1"}, {"id": 133, "prop": "name", "attributes": {"content": "我們打算去街上看看。", "name": "梅捷緹克緹"}, "figure_art": "avg_npc_1478_1#1$1"}, {"id": 134, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4058_pepe_1#8$1", "focus": "l"}}, {"id": 135, "prop": "name", "attributes": {"content": "一有消息我就通知你們，再會。", "name": "佩佩"}, "figure_art": "avg_4058_pepe_1#8$1"}, {"id": 136, "prop": "dialog", "attributes": {}}, {"id": 137, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0}}, {"id": 138, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "0,0", "posto": "-200,0", "afrom": 1.0, "ato": 0.0, "duration": 0.5, "isblock": "true"}}, {"id": 139, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 140, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1478_1#2$1"}}, {"id": 141, "prop": "name", "attributes": {"content": "呼……", "name": "梅捷緹克緹"}, "figure_art": "avg_npc_1478_1#2$1"}, {"id": 142, "prop": "dialog", "attributes": {}}, {"id": 143, "prop": "charslot", "attributes": {}}, {"id": 144, "prop": "PlaySound", "attributes": {"key": "$d_avg_oldtvelectricity", "volume": 0.0, "loop": "true", "channel": "o"}}, {"id": 145, "prop": "SoundVolume", "attributes": {"volume": 1.0, "channel": "o", "fadetime": 2.0}}, {"id": 146, "prop": "name", "attributes": {"content": "呃，慢著，本台插播一條急訊。", "name": "電台廣播"}}, {"id": 147, "prop": "name", "attributes": {"content": "有市民發現家中取水器內流出的水變得渾濁，其中摻雜大量泥沙。", "name": "電台廣播"}}, {"id": 148, "prop": "name", "attributes": {"content": "護衛隊方面稱，他們正在緊急組織人力檢查城市老地下水通道，由於通道情況複雜，可能仍然需要時間……", "name": "電台廣播"}}, {"id": 149, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1478_1#5$1"}}, {"id": 150, "prop": "name", "attributes": {"content": "啊，這又是什麼情況？", "name": "梅捷緹克緹"}, "figure_art": "avg_npc_1478_1#5$1"}, {"id": 151, "prop": "dialog", "attributes": {}}, {"id": 152, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 153, "prop": "StopSound", "attributes": {"channel": "o", "fadetime": 2.0}}, {"id": 154, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 155, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 156, "prop": "charslot", "attributes": {}}, {"id": 157, "prop": "Background", "attributes": {"image": "53_g10_grandbazaar_d", "screenadapt": "coverall"}}, {"id": 158, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 159, "prop": "playMusic", "attributes": {"key": "$memory_loop", "volume": 0.6}}, {"id": 160, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 161, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 162, "prop": "PlaySound", "attributes": {"key": "$d_avg_fsmummy", "volume": 1.0}}, {"id": 163, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1479_1#1$1", "duration": 1.5, "isblock": "true"}}, {"id": 164, "prop": "name", "attributes": {"content": "……某人已經跟我說過這裡的故事了。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#1$1"}, {"id": 165, "prop": "name", "attributes": {"content": "寶石繁榮了大巴扎，與香料、綢緞、工藝品一同源源不斷地為這裡帶來財富。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#1$1"}, {"id": 166, "prop": "name", "attributes": {"content": "藉由寶石交易所，藉由這些有著特殊源石迴路的寶石，米納特哈瑪儀成為鑲嵌在沙海中的一顆晨星……", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#1$1"}, {"id": 167, "prop": "dialog", "attributes": {}}, {"id": 168, "prop": "PlaySound", "attributes": {"key": "$d_avg_bellshake", "volume": 1.0}}, {"id": 169, "prop": "charslot", "attributes": {"duration": 1.5, "isblock": "true"}}, {"id": 170, "prop": "PlaySound", "attributes": {"key": "$d_avg_sandstone", "volume": 1.0}}, {"id": 171, "prop": "Effect", "attributes": {"name": "$e_sandfall_01", "layer": 1.0}}, {"id": 172, "prop": "PlaySound", "attributes": {"key": "$d_avg_sand_lp", "volume": 0.0, "loop": "true", "channel": "sa"}}, {"id": 173, "prop": "SoundVolume", "attributes": {"volume": 1.0, "channel": "sa", "fadetime": 2.0}}, {"id": 174, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 175, "prop": "name", "attributes": {"content": "古老的建築不斷淌下黃沙，人們推開窗戶或走出大門，驚異地看向自己祖祖輩輩生活的房屋，繼而看向站在街道中央的祖拜爾。"}}, {"id": 176, "prop": "name", "attributes": {"content": "但祖拜爾卻彷彿沒有注意到他們。"}}, {"id": 177, "prop": "StopSound", "attributes": {"channel": "sa", "fadetime": 2.0}}, {"id": 178, "prop": "name", "attributes": {"content": "他俯身從黃沙中拾起一枚首飾，螺旋形金屬框架正中的寶石在日光下熠熠生輝。"}}, {"id": 179, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4140_lasher_1#1$1"}}, {"id": 180, "prop": "name", "attributes": {"content": "祖拜爾先生，您提起的壁畫就在前方。", "name": "拉恕爾"}, "figure_art": "avg_4140_lasher_1#1$1"}, {"id": 181, "prop": "name", "attributes": {"content": "我的外祖父曾說過，牆上的圖畫描繪了古薩爾貢人的生活，記錄著米納特哈瑪儀的誕生。", "name": "拉恕爾"}, "figure_art": "avg_4140_lasher_1#1$1"}, {"id": 182, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4140_lasher_1#3$1"}}, {"id": 183, "prop": "name", "attributes": {"content": "“即便河水乾涸，城市被掩埋在黃沙之下，它也不會褪色。”", "name": "拉恕爾"}, "figure_art": "avg_4140_lasher_1#3$1"}, {"id": 184, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1479_1#3$1"}}, {"id": 185, "prop": "name", "attributes": {"content": "……“不會褪色”，是的。就如同你我手中流過的每一顆寶石。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#3$1"}, {"id": 186, "prop": "name", "attributes": {"content": "只不過，不是河水乾涸，黃沙掩埋了昔日的城市。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#3$1"}, {"id": 187, "prop": "name", "attributes": {"content": "而是洪水毀去了那偉大建築的頂端，黃沙深處掩埋的輝煌成了千年的祕密。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#3$1"}, {"id": 188, "prop": "dialog", "attributes": {}}, {"id": 189, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 190, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 191, "prop": "charslot", "attributes": {}}, {"id": 192, "prop": "cgitem", "attributes": {"image": "cgitem_53_i04_1", "style": "cg", "pfrom": "-585,0", "pto": "-730,0", "pduration": 20.0, "sfrom": 1.0, "sto": 1.35, "sduration": 25.0, "layer": 1.0}}, {"id": 193, "prop": "cgitem", "attributes": {"image": "cgitem_53_i04_2", "style": "cg", "pfrom": "0,-233", "pto": "20,-330", "pduration": 20.0, "sfrom": 1.0, "sto": 1.35, "sduration": 25.0, "layer": 2.0}}, {"id": 194, "prop": "cgitem", "attributes": {"image": "cgitem_53_i04_3", "style": "cg", "pfrom": "-230,0", "pto": "-270,0", "pduration": 30.0, "sfrom": 1.0, "sto": 1.15, "sduration": 30.0, "layer": 3.0}}, {"id": 195, "prop": "Image", "attributes": {"image": "53_i04", "screenadapt": "coverall"}}, {"id": 196, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.0, "yScaleFrom": 1.0, "xScaleTo": 1.06, "yScaleTo": 1.06, "ease": "OutQuad", "duration": 30.0, "block": "false"}}, {"id": 197, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 198, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 199, "prop": "name", "attributes": {"content": "每一次日升月落，都是一個小輪迴的重新演繹。", "name": "祖拜爾"}}, {"id": 200, "prop": "name", "attributes": {"content": "短暫的一天是如此，漫長的一生是如此……", "name": "祖拜爾"}}, {"id": 201, "prop": "name", "attributes": {"content": "城市的枯榮，帝國的盛衰，大地的終始，亦是如此。", "name": "祖拜爾"}}, {"id": 202, "prop": "name", "attributes": {"content": "我想，雖然壁畫只能記載下萬古之中的一瞬，但這一瞬同樣會一遍遍輪迴重演，這就是它的價值。", "name": "拉恕爾"}}, {"id": 203, "prop": "name", "attributes": {"content": "沙阿命人繪製這些壁畫，並不是為了自己的名在輪迴中留存。", "name": "祖拜爾"}}, {"id": 204, "prop": "name", "attributes": {"content": "他要留下的是他對時間與生命的解釋本身，在那之後，世人便有可以效仿的依據。", "name": "祖拜爾"}}, {"id": 205, "prop": "name", "attributes": {"content": "“過去與未來之王”在此地建設了他的寶庫，於是在他身後漫長的“阿斯蘭戰爭”裡，無數王酋覬覦此地。", "name": "祖拜爾"}}, {"id": 206, "prop": "name", "attributes": {"content": "直到極南的熱風讓氣候發生巨變，這裡迎來滔天洪水，城牆傾頹，河流改道，土地變得面目全非。", "name": "祖拜爾"}}, {"id": 207, "prop": "name", "attributes": {"content": "人們在黃沙中搜尋寶庫的痕跡，卻一無所獲，於是他們開始相信，寶庫已經隨著洪水覆滅。", "name": "祖拜爾"}}, {"id": 208, "prop": "name", "attributes": {"content": "王酋的尋寶隊離開了，工匠和商人們來到這裡，在河邊建起了新的聚落。", "name": "祖拜爾"}}, {"id": 209, "prop": "name", "attributes": {"content": "我始終看著這一切。", "name": "祖拜爾"}}, {"id": 210, "prop": "name", "attributes": {"content": "我奉命守護這座寶庫，這是我的職責。", "name": "祖拜爾"}}, {"id": 211, "prop": "name", "attributes": {"content": "我徘徊在黃沙之中，歷盡日升日落，攔阻那些窺探祕密的不軌之徒。", "name": "祖拜爾"}}, {"id": 212, "prop": "name", "attributes": {"content": "而你，年輕人，你應該比任何人都更加確定——沙阿寶庫的本體，就在這座城市的地底。", "name": "祖拜爾"}}, {"id": 213, "prop": "dialog", "attributes": {}}, {"id": 214, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 215, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 216, "prop": "image", "attributes": {}}, {"id": 217, "prop": "hidecgitem", "attributes": {"image": "cgitem_53_i04_1"}}, {"id": 218, "prop": "hidecgitem", "attributes": {"image": "cgitem_53_i04_2"}}, {"id": 219, "prop": "hidecgitem", "attributes": {"image": "cgitem_53_i04_3"}}, {"id": 220, "prop": "Background", "attributes": {"image": "53_g10_grandbazaar_d", "screenadapt": "coverall"}}, {"id": 221, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 222, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1479_1#3$1"}}, {"id": 223, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 224, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 225, "prop": "name", "attributes": {"content": "“第四顆代表肝臟，我們清醒著進入夜晚，為了職責與義務。”……感謝你歸還的寶石，讓我回憶起更多往事。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#3$1"}, {"id": 226, "prop": "name", "attributes": {"content": "最初，成千上萬的能工巧匠來到一片荒蕪的米納特哈瑪儀。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#3$1"}, {"id": 227, "prop": "name", "attributes": {"content": "上至奇偉的黃金機關迷宮，下至手工雕琢的源石迴路寶石，工匠們創造了一切，然後將它們埋入黃沙。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#3$1"}, {"id": 228, "prop": "name", "attributes": {"content": "後世的人們大都相信，在耗盡心血的作業之後，所有的工匠也都被埋葬在了他們的造物身邊。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#3$1"}, {"id": 229, "prop": "name", "attributes": {"content": "但實際上，仍有一些工匠隱居在米納特哈瑪儀西南的一處村落，世代保守著“寶庫入口在何地”的祕密。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#3$1"}, {"id": 230, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4140_lasher_1#2$1"}}, {"id": 231, "prop": "name", "attributes": {"content": "……", "name": "拉恕爾"}, "figure_art": "avg_4140_lasher_1#2$1"}, {"id": 232, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1479_1#2$1"}}, {"id": 233, "prop": "name", "attributes": {"content": "該你來說了，年輕人。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#2$1"}, {"id": 234, "prop": "name", "attributes": {"content": "接下來的事情，便與你的家族有關了。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#2$1"}, {"id": 235, "prop": "charslot", "attributes": {}}, {"id": 236, "prop": "name", "attributes": {"content": "年輕的監管人緊閉雙目，似乎被沉重的記憶之沙淹沒。"}}, {"id": 237, "prop": "name", "attributes": {"content": "那段故事經過世代流傳，已經成為高懸於思緒荒漠上空的烈日，仰首便可望見。"}}, {"id": 238, "prop": "name", "attributes": {"content": "蒸騰著。炙烤著。煎熬著。"}}, {"id": 239, "prop": "dialog", "attributes": {}}, {"id": 240, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4140_lasher_1#2$1", "duration": 1.0, "isblock": "true"}}, {"id": 241, "prop": "name", "attributes": {"content": "……三百年前，許多帕夏王酋集結的軍隊找到了那個村子。", "name": "拉恕爾"}, "figure_art": "avg_4140_lasher_1#2$1"}, {"id": 242, "prop": "name", "attributes": {"content": "他們向村民們逼問寶庫的入口，堅持守密的人都被砍去了雙手。", "name": "拉恕爾"}, "figure_art": "avg_4140_lasher_1#2$1"}, {"id": 243, "prop": "name", "attributes": {"content": "因為不忍村民們繼續受害，一位失去雙手的寶石工匠主動找上王酋軍，提出要為他們引路。", "name": "拉恕爾"}, "figure_art": "avg_4140_lasher_1#2$1"}, {"id": 244, "prop": "name", "attributes": {"content": "在寶庫前，他見證了王酋軍與寶庫守護者的激戰，看到守護者雖然被打敗，但沒有他的法術，寶庫的大門便不會開啟。", "name": "拉恕爾"}, "figure_art": "avg_4140_lasher_1#2$1"}, {"id": 245, "prop": "name", "attributes": {"content": "憤怒的王酋軍剖開了守護者的胸膛，刮下了他身體內外鑲嵌的每一顆寶石。", "name": "拉恕爾"}, "figure_art": "avg_4140_lasher_1#2$1"}, {"id": 246, "prop": "name", "attributes": {"content": "儘管那位告密的工匠用盡所知的技術，指導自己年幼的孩子去修復守護者的身軀，但守護者終究沒有醒來。", "name": "拉恕爾"}, "figure_art": "avg_4140_lasher_1#2$1"}, {"id": 247, "prop": "name", "attributes": {"content": "……然後，米納特哈瑪儀的大巴扎立起了一架天平。那個工匠的孩子在成人之後安葬了守護者，又設立了一間寶石交易所。", "name": "拉恕爾"}, "figure_art": "avg_4140_lasher_1#2$1"}, {"id": 248, "prop": "name", "attributes": {"content": "從那以後，他的後人一直在這裡等待。", "name": "拉恕爾"}, "figure_art": "avg_4140_lasher_1#2$1"}, {"id": 249, "prop": "name", "attributes": {"content": "每一代先祖都竭盡所能，讓米納特哈瑪儀的寶石貿易更加繁榮。", "name": "拉恕爾"}, "figure_art": "avg_4140_lasher_1#2$1"}, {"id": 250, "prop": "name", "attributes": {"content": "百年千年，終有一日，人們能淘盡薩爾貢的黃沙，寶石匯聚在這座城市……", "name": "拉恕爾"}, "figure_art": "avg_4140_lasher_1#2$1"}, {"id": 251, "prop": "name", "attributes": {"content": "……我能夠將它們還給您。", "name": "拉恕爾"}, "figure_art": "avg_4140_lasher_1#2$1"}, {"id": 252, "prop": "dialog", "attributes": {}}, {"id": 253, "prop": "PlaySound", "attributes": {"key": "$d_avg_bellshake", "volume": 1.0}}, {"id": 254, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 255, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 256, "prop": "name", "attributes": {"content": "感覺到叉鈴抵上胸膛，監管人不敢睜開雙眼。"}}, {"id": 257, "prop": "name", "attributes": {"content": "但在他的眼前，卻彷彿有數百年的時光在瞬間流淌而過。"}}, {"id": 258, "prop": "name", "attributes": {"content": "日升月落，物換星移。監管人看到一座座城市興榮，復又消亡，眼前的建築緩慢地化為沙礫。"}}, {"id": 259, "prop": "dialog", "attributes": {}}, {"id": 260, "prop": "charslot", "attributes": {}}, {"id": 261, "prop": "Background", "attributes": {}}, {"id": 262, "prop": "Image", "attributes": {"image": "53_i09_1", "screenadapt": "coverall"}}, {"id": 263, "prop": "bgeffect", "attributes": {"name": "$eb_ancestor", "layer": 1.0}}, {"id": 264, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 265, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 266, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 267, "prop": "name", "attributes": {"content": "監管人看到一位古老的守護者行走在無邊際的沙漠中。"}}, {"id": 268, "prop": "name", "attributes": {"content": "守護者張開雙臂，沐浴在繁星的光芒之下，面向東方等待著日出。"}}, {"id": 269, "prop": "name", "attributes": {"content": "感知到有人在看自己，他垂下視線迎向監管人的目光。"}}, {"id": 270, "prop": "dialog", "attributes": {}}, {"id": 271, "prop": "Image", "attributes": {"image": "53_i09_2", "screenadapt": "coverall", "fadetime": 1.5}}, {"id": 272, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 273, "prop": "name", "attributes": {"content": "在守護者悲憫的注視中，監管人不禁顫抖。"}}, {"id": 274, "prop": "name", "attributes": {"content": "為他即將吐露的話語。"}}, {"id": 275, "prop": "name", "attributes": {"content": "……多麼漫長的時光啊。", "name": "祖拜爾"}}, {"id": 276, "prop": "name", "attributes": {"content": "你們自由了。", "name": "祖拜爾"}}, {"id": 277, "prop": "dialog", "attributes": {}}, {"id": 278, "prop": "stopmusic", "attributes": {"fadetime": 3.0}}, {"id": 279, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 280, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 281, "prop": "image", "attributes": {}}, {"id": 282, "prop": "bgeffect", "attributes": {}}, {"id": 283, "prop": "charslot", "attributes": {}}, {"id": 284, "prop": "Background", "attributes": {"image": "53_g12_gemexchange", "screenadapt": "coverall"}}, {"id": 285, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 286, "prop": "playMusic", "attributes": {"key": "$wasteland_loop", "volume": 0.6}}, {"id": 287, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 288, "prop": "PlaySound", "attributes": {"key": "$d_avg_fsmummy", "volume": 1.0}}, {"id": 289, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1479_1#1$1", "duration": 1.5, "isblock": "true"}}, {"id": 290, "prop": "name", "attributes": {"content": "好久不見了，二位。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#1$1"}, {"id": 291, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1479_1#2$1"}}, {"id": 292, "prop": "name", "attributes": {"content": "過去數百年，我有失於自己的職責，但如今我已重返人世，我將與這座城市一起，贖還我們欠下的時光。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#2$1"}, {"id": 293, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1482_1#1$1"}}, {"id": 294, "prop": "name", "attributes": {"content": "……", "name": "米奧"}, "figure_art": "avg_npc_1482_1#1$1"}, {"id": 295, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1479_1#4$1"}}, {"id": 296, "prop": "name", "attributes": {"content": "與此同時，我還有一個請求，希望二位能夠答應。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#4$1"}, {"id": 297, "prop": "name", "attributes": {"content": "如果那位夢魘當真是哈蘭杜汗的後裔，我將應沙阿之諾，為她打開寶庫。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#4$1"}, {"id": 298, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1479_1#1$1"}}, {"id": 299, "prop": "name", "attributes": {"content": "沃奧，請確認她的血脈。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#1$1"}, {"id": 300, "prop": "dialog", "attributes": {}}, {"id": 301, "prop": "PlaySound", "attributes": {"key": "$d_avg_dogbarknormal", "volume": 1.0}}, {"id": 302, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1483_1#1$1"}}, {"id": 303, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 304, "prop": "name", "attributes": {"content": "交由我便是。", "name": "沃奧"}, "figure_art": "avg_npc_1483_1#1$1"}, {"id": 305, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1479_1#1$1"}}, {"id": 306, "prop": "name", "attributes": {"content": "以及，我仍然需要對她進行一番考驗，若她最終無法走上天途，注定不算是合格的夢魘。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#1$1"}, {"id": 307, "prop": "name", "attributes": {"content": "無論如何，讓她踏出那一步。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#1$1"}, {"id": 308, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1483_1#1$1"}}, {"id": 309, "prop": "name", "attributes": {"content": "我明白。", "name": "沃奧"}, "figure_art": "avg_npc_1483_1#1$1"}, {"id": 310, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1482_1#4$1"}}, {"id": 311, "prop": "name", "attributes": {"content": "我不會也要一起去吧？我對那些夢魘可沒有什麼好感。", "name": "米奧"}, "figure_art": "avg_npc_1482_1#4$1"}, {"id": 312, "prop": "name", "attributes": {"content": "他們中的酒鬼含量實在是太高了，把酒灑得到處都是，我可不想費力再去舔自己的皮毛。", "name": "米奧"}, "figure_art": "avg_npc_1482_1#4$1"}, {"id": 313, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1479_1#1$1"}}, {"id": 314, "prop": "name", "attributes": {"content": "不，米奧，您需要幫我完成另外一項事情。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#1$1"}, {"id": 315, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1482_1#1$1"}}, {"id": 316, "prop": "name", "attributes": {"content": "說吧，年輕人。", "name": "米奧"}, "figure_art": "avg_npc_1482_1#1$1"}, {"id": 317, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1479_1#2$1"}}, {"id": 318, "prop": "name", "attributes": {"content": "在我陷入沉睡之後，沙阿的寶庫遭受了如此嚴重的破壞，這是我的失職。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#2$1"}, {"id": 319, "prop": "name", "attributes": {"content": "我不得不承認，即使有構裝體在旁協助，我的力量也無法與王酋帕夏集結的軍隊相抗衡。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#2$1"}, {"id": 320, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1482_1#1$1"}}, {"id": 321, "prop": "name", "attributes": {"content": "告訴我你的決定，我會為你做到，一如既往。", "name": "米奧"}, "figure_art": "avg_npc_1482_1#1$1"}, {"id": 322, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1479_1#3$1"}}, {"id": 323, "prop": "name", "attributes": {"content": "我遇到了一個孩子，我覺得她能幫我。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#3$1"}, {"id": 324, "prop": "name", "attributes": {"content": "她追尋著沙阿離去的足跡，找到了我流失在外的寶石，沒有她我無法甦醒。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#3$1"}, {"id": 325, "prop": "PlaySound", "attributes": {"key": "$d_avg_meowlong", "volume": 1.0}}, {"id": 326, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1482_1#2$1"}}, {"id": 327, "prop": "name", "attributes": {"content": "啊，你是說那個孩子嗎？我見過她，很不錯的孩子。", "name": "米奧"}, "figure_art": "avg_npc_1482_1#2$1"}, {"id": 328, "prop": "name", "attributes": {"content": "上進，活潑，就是有些執拗了。", "name": "米奧"}, "figure_art": "avg_npc_1482_1#2$1"}, {"id": 329, "prop": "name", "attributes": {"content": "讓我想起了她。", "name": "米奧"}, "figure_art": "avg_npc_1482_1#2$1"}, {"id": 330, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1479_1#3$1"}}, {"id": 331, "prop": "name", "attributes": {"content": "是啊，當我尋回自己的記憶後，那女孩的行為舉止都令我感到熟悉。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#3$1"}, {"id": 332, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1479_1#2$1"}}, {"id": 333, "prop": "name", "attributes": {"content": "一如當年，我與姐姐漫步在黃金之城的街巷中，那裡的一磚一瓦，她都清楚它們的來由。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#2$1"}, {"id": 334, "prop": "name", "attributes": {"content": "對那些上了年頭的東西，她總是格外著迷。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#2$1"}, {"id": 335, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1482_1#2$1"}}, {"id": 336, "prop": "name", "attributes": {"content": "你需要那女孩為你做什麼，祖拜爾？", "name": "米奧"}, "figure_art": "avg_npc_1482_1#2$1"}, {"id": 337, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1479_1#2$1"}}, {"id": 338, "prop": "name", "attributes": {"content": "我需要一個同伴，與我共同等候沙阿的歸來。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#2$1"}, {"id": 339, "prop": "PlaySound", "attributes": {"key": "$d_avg_bellshake", "volume": 1.0}}, {"id": 340, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1479_1#1$1"}}, {"id": 341, "prop": "name", "attributes": {"content": "米奧，請為我確認，她是否合格。", "name": "祖拜爾"}, "figure_art": "avg_npc_1479_1#1$1"}, {"id": 342, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1482_1#1$1"}}, {"id": 343, "prop": "name", "attributes": {"content": "好的，祖拜爾，如果那是你的願望。", "name": "米奧"}, "figure_art": "avg_npc_1482_1#1$1"}, {"id": 344, "prop": "name", "attributes": {"content": "我會去的。", "name": "米奧"}, "figure_art": "avg_npc_1482_1#1$1"}, {"id": 345, "prop": "dialog", "attributes": {}}, {"id": 346, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 347, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 348, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 349, "prop": "charslot", "attributes": {}}, {"id": 350, "prop": "Background", "attributes": {}}, {"id": 351, "prop": "Image", "attributes": {}}, {"id": 352, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}