": "l"}}, {"id": 90, "prop": "name", "attributes": {"content": "我把通訊器關掉，在這裡看了一晚上的書，發生什麼了？", "name": "佩佩"}, "figure_art": "avg_4058_pepe_1#12$1"}, {"id": 91, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1478_1#6$1", "focus": "r"}}, {"id": 92, "prop": "name", "attributes": {"content": "哈，昨夜發生那麼多事情，難不成你在這裡一無所知嗎？", "name": "梅捷緹克緹"}, "figure_art": "avg_npc_1478_1#6$1"}, {"id": 93, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4058_pepe_1#12$1", "focus": "l"}}, {"id": 94, "prop": "name", "attributes": {"content": "我不知道啊。", "name": "佩佩"}, "figure_art": "avg_4058_pepe_1#12$1"}, {"id": 95, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1478_1#6$1", "focus": "r"}}, {"id": 96, "prop": "multiline", "attributes": {"name": "梅捷緹克緹", "content": "你這個悶著頭來做事的個性真的是……"}}, {"id": 97, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1478_1#2$1", "focus": "r"}}, {"id": 98, "prop": "multiline", "attributes": {"name": "梅捷緹克緹", "end": "true", "content": "算了，我也不知道該說什麼了。", "joined": "你這個悶著頭來做事的個性真的是……算了，我也不知道該說什麼了。"}}, {"id": 99, "prop": "dialog", "attributes": {}}, {"id": 100, "prop": "PlaySound", "attributes": {"key": "$d_avg_button", "volume": 1.0}}, {"id": 101, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 102, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1478_1#1$1", "focus": "r"}}, {"id": 103, "prop": "name", "attributes": {"content": "直接聽吧。", "name": "梅捷緹克緹"}, "figure_art": "avg_npc_1478_1#1$1"}, {"id": 104, "prop": "dialog", "attributes": {}}, {"id": 105, "prop": "charslot", "attributes": {}}, {"id": 106, "prop": "PlaySound", "attributes": {"key": "$d_avg_oldtvelectricity", "volume": 0.0, "loop": "true", "channel": "o"}}, {"id": 107, "prop": "SoundVolume", "attributes": {"volume": 1.0, "channel": "o", "fadetime": 2.0}}, {"id": 108, "prop": "name", "attributes": {"content": "米城內多個區域發生緊急事件。", "name": "電台廣播"}}, {"id": 109, "prop": "name", "attributes": {"content": "有大量金屬構裝的人偶走上街頭，從居民家中搶奪大量寶石後離開