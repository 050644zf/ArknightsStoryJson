47, "prop": "backgroundTween", "attributes": {"xFrom": 80.0, "yFrom": 0.0, "yTo": 0.0, "xScaleFrom": 1.3, "yScaleFrom": 1.3, "xScaleTo": 1.3, "yScaleTo": 1.3, "duration": 0.2, "block": "false"}}, {"id": 148, "prop": "delay", "attributes": {"time": 0.3}}, {"id": 149, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_662_1#1$1", "focus": "l"}}, {"id": 150, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_724_1#3$1", "focus": "l"}}, {"id": 151, "prop": "name", "attributes": {"content": "還用得著你說？", "name": "塞爾蒙"}, "figure_art": "avg_npc_724_1#3$1"}, {"id": 152, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_662_1#1$1", "focus": "r"}}, {"id": 153, "prop": "name", "attributes": {"content": "你很清楚，憑你們的武力，越不過我的劍。所以剛才，你想虛張聲勢，嚇退我們。", "name": "陳"}, "figure_art": "avg_npc_662_1#1$1"}, {"id": 154, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_724_1#6$1", "focus": "l"}}, {"id": 155, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_662_1#1$1", "focus": "l"}}, {"id": 156, "prop": "name", "attributes": {"content": "......嘁。", "name": "塞爾蒙"}, "figure_art": "avg_npc_724_1#6$1"}, {"id": 157, "prop": "charslot", "attributes": {}}, {"id": 158, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_242", "focus": "m"}}, {"id": 159, "prop": "name", "attributes": {"content": "那我們現在怎麼辦？你總該有辦法吧？", "name": "塔拉流民"}, "figure_art": "avg_npc_242"}, {"id": 160, "prop": "charslot", "attributes": {}}, {"id": 161, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_724_1#6$1", "focus": "r"}}, {"id": 162, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_662_1#7$1", "focus": "r"}}, {"id": 163, "prop": "name", "attributes": {"content": "......難怪即使這身打扮會給你帶來危險，你卻仍選擇這樣穿。", "name": "陳"}, "figure_art": "avg_npc_662_1#7$1"}, {"id": 164, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_662_1#1$1", "focus": "r"}}, {"id": 165, "prop": "name", "attributes": {"content": "你想當這支隊伍的“領袖”。", "name": "陳"}, "figure_art": "avg_npc_662_1#1$1"}, {"id": 166, "prop": "stopsound", "attributes": {"fadetime": 1.0, "channel": "steam"}}, {"id": 167, "prop": "Dialog", "attributes": {}}, {"id": 168, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 169, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 170, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 171, "prop": "Character", "attributes": {}}, {"id": 172, "prop": "charslot", "attributes": {}}, {"id": 173, "prop": "Background", "attributes": {"image": "34_g1_victoriavillage", "screenadapt": "coverall"}}, {"id": 174, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 175, "prop": "playMusic", "attributes": {"intro": "$frontline_intro", "key": "$frontline_loop", "volume": 0.4}}, {"id": 176, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 177, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 178, "prop": "Dialog", "attributes": {}}, {"id": 179, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_npc_242"}}, {"id": 180, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 0.9, "channel": "run"}}, {"id": 181, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_222_bpipe_1#1", "posfrom": "0,0", "posto": "400,0", "duration": 0.0, "isblock": "true"}}, {"id": 182, "prop": "charslot", "attributes": {"slot": "right", "afrom": 1.0, "ato": 1.0, "posfrom": "400,0", "posto": "-200,0", "duration": 0.4, "isblock": "true"}}, {"id": 183, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 184, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.03, "block": "true"}}, {"id": 185, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 40.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 186, "prop": "PlaySound", "attributes": {"key": "$fightgeneral", "volume": 1.0}}, {"id": 187, "prop": "stopsound", "attributes": {"channel": "run"}}, {"id": 188, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 189, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_242", "focus": "l"}}, {"id": 190, "prop": "charslot", "attributes": {"slot": "left", "action": "shake", "random": "true", "power": 8.0, "times": 100.0, "isblock": "true"}}, {"id": 191, "prop": "name", "attributes": {"content": "呃......！", "name": "塔拉流民"}, "figure_art": "avg_npc_242"}, {"id": 192, "prop": "dialog", "attributes": {}}, {"id": 193, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown2", "volume": 1.0}}, {"id": 194, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "0,0", "posto": "0,-50", "afrom": 1.0, "ato": 0.0, "duration": 0.5, "focus": "l"}}, {"id": 195, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_222_bpipe_1#1", "focus": "r"}}, {"id": 196, "prop": "name", "attributes": {"content": "只是輕輕地撞一下，應該只會頭暈一會。我救人質的時候試過好幾次了，不會出錯的。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#1"}, {"id": 197, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_222_bpipe_1#2", "focus": "r"}}, {"id": 198, "prop": "name", "attributes": {"content": "......啊，昏過去了。是不是我太用力了？還是說，你們難道已經幾天沒吃飽飯了......", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#2"}, {"id": 199, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_222_bpipe_1#4", "focus": "r"}}, {"id": 200, "prop": "name", "attributes": {"content": "對不起......可是，搶劫也是不對的呀。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#4"}, {"id": 201, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_222_bpipe_1#6", "focus": "r"}}, {"id": 202, "prop": "name", "attributes": {"content": "——別想偷襲！", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#6"}, {"id": 203, "prop": "charslot", "attributes": {}}, {"id": 204, "prop": "dialog", "attributes": {}}, {"id": 205, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#6", "fadetime": 0.6}}, {"id": 206, "prop": "characteraction", "attributes": {"name": "middle", "type": "jump", "times": 1.0, "fadetime": 0.5, "block": "false"}}, {"id": 207, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#6", "name2": "avg_1020_reed2_1#1$1"}}, {"id": 208, "prop": "PlaySound", "attributes": {"key": "$d_avg_spear", "volume": 1.0}}, {"id": 209, "prop": "PlaySound", "attributes": {"key": "$d_avg_metallicclick", "volume": 1.0, "delay": 0.2}}, {"id": 210, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 211, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.1, "block": "true"}}, {"id": 212, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 20.0, "ystrength": 0.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 213, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.1, "block": "true"}}, {"id": 214, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 215, "prop": "name", "attributes": {"content": "長槍從身後揮來的瞬間，風笛本能地出手格擋。"}}, {"id": 216, "prop": "Character", "attributes": {"name": "avg_222_bpipe_1#2", "name2": "avg_1020_reed2_1#6$1"}}, {"id": 217, "prop": "PlaySound", "attributes": {"key": "$d_avg_runstop", "volume": 1.0}}, {"id": 218, "prop": "characteraction", "attributes": {"name": "left", "type": "jump", "power": 10.0, "times": 1.0, "fadetime": 0.1, "block": "true"}}, {"id": 219, "prop": "characteraction", "attributes": {"name": "right", "type": "jump", "xpos": 100.0, "power": 10.0, "times": 1.0, "fadetime": 0.1, "block": "true"}}, {"id": 220, "prop": "name", "attributes": {"content": "雙方各退一步。看清對方後，風笛睜大了眼睛。"}}, {"id": 221, "prop": "characteraction", "attributes": {"name": "left", "type": "move", "xpos": 100.0, "fadetime": 1.0}}, {"id": 222, "prop": "characteraction", "attributes": {"name": "right", "type": "move", "fadetime": 1.0}}, {"id": 223, "prop": "character", "attributes": {}}, {"id": 224, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_1020_reed2_1#6$1", "focus": "l"}}, {"id": 225, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_222_bpipe_1#5", "focus": "l"}}, {"id": 226, "prop": "name", "attributes": {"content": "——葦草？", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#5"}, {"id": 227, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_1020_reed2_1#6$1", "focus": "r"}}, {"id": 228, "prop": "name", "attributes": {"content": "......", "name": "葦草"}, "figure_art": "avg_1020_reed2_1#6$1"}, {"id": 229, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_222_bpipe_1#5", "focus": "l"}}, {"id": 230, "prop": "name", "attributes": {"content": "......你的傷好了？沒關係了？你怎麼在這裡......", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#5"}, {"id": 231, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_222_bpipe_1#2", "focus": "l"}}, {"id": 232, "prop": "name", "attributes": {"content": "啊，不對不對，你也是來搶劫的嗎？那我就不能放你過去了。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#2"}, {"id": 233, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_1020_reed2_1#1$1", "focus": "r"}}, {"id": 234, "prop": "name", "attributes": {"content": "......不，是我沒來得及阻止他們動手。", "name": "葦草"}, "figure_art": "avg_1020_reed2_1#1$1"}, {"id": 235, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_1020_reed2_1#12$1", "focus": "r"}}, {"id": 236, "prop": "name", "attributes": {"content": "但是，無論如何，我不想讓他們受傷......也不想讓他們被抓捕。", "name": "葦草"}, "figure_art": "avg_1020_reed2_1#12$1"}, {"id": 237, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_222_bpipe_1#8", "focus": "l"}}, {"id": 238, "prop": "name", "attributes": {"content": "欸，那我們要做的事情差不多呀，你不用這麼戒備地盯著我的。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#8"}, {"id": 239, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_222_bpipe_1#9", "focus": "l"}}, {"id": 240, "prop": "name", "attributes": {"content": "無論作為維多利亞的軍人，還是羅德島幹員，我們都不可能傷害平民。我和陳陳都是來勸架的。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#9"}, {"id": 241, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_222_bpipe_1#4", "focus": "l"}}, {"id": 242, "prop": "name", "attributes": {"content": "......呃，不過，不好意思，我的力氣可能對普通人來說有點大......", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#4"}, {"id": 243, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_222_bpipe_1#1", "focus": "l"}}, {"id": 244, "prop": "name", "attributes": {"content": "要不我幫你把這些昏倒的人背到陰涼處休息吧？他們是住在這座村莊嗎？", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#1"}, {"id": 245, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_1020_reed2_1#2$1", "focus": "r"}}, {"id": 246, "prop": "name", "attributes": {"content": "......請你，離開吧。", "name": "葦草"}, "figure_art": "avg_1020_reed2_1#2$1"}, {"id": 247, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_1020_reed2_1#1$1", "focus": "r"}}, {"id": 248, "prop": "name", "attributes": {"content": "衝突已經化解了。", "name": "葦草"}, "figure_art": "avg_1020_reed2_1#1$1"}, {"id": 249, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_222_bpipe_1#1", "focus": "l"}}, {"id": 250, "prop": "name", "attributes": {"content": "話是這麼說，可我還是想幫幫忙呀。看起來，你好像有什麼顧忌？", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#1"}, {"id": 251, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_1020_reed2_1#1$1", "focus": "r"}}, {"id": 252, "prop": "name", "attributes": {"content": "......", "name": "葦草"}, "figure_art": "avg_1020_reed2_1#1$1"}, {"id": 253, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_222_bpipe_1#4", "focus": "l"}}, {"id": 254, "prop": "name", "attributes": {"content": "唉，好吧，你還是不喜歡說話。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#4"}, {"id": 255, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_222_bpipe_1#4", "focus": "l"}}, {"id": 256, "prop": "name", "attributes": {"content": "在羅德島的時候，他們就不許我探望你，也不肯告訴我為什麼。我只能猜，是不是你不願意想起小丘郡的事情。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#4"}, {"id": 257, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_222_bpipe_1#5", "focus": "l"}}, {"id": 258, "prop": "name", "attributes": {"content": "......可是你怎麼跑到這裡來了？", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#5"}, {"id": 259, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_222_bpipe_1#7", "focus": "l"}}, {"id": 260, "prop": "name", "attributes": {"content": "而且，看起來還像是在荒野裡迷路了好多天一樣。你的任務是什麼呀，要不要我和陳陳陪你一起？", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#7"}, {"id": 261, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_222_bpipe_1#5", "focus": "l"}}, {"id": 262, "prop": "name", "attributes": {"content": "哎，想問你的事情太多啦，我的腦子都有些亂了。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#5"}, {"id": 263, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_1020_reed2_1#8$1", "focus": "r"}}, {"id": 264, "prop": "name", "attributes": {"content": "......不，沒關係。我只是，偶然被這些人邀請......護送他們。", "name": "葦草"}, "figure_art": "avg_1020_reed2_1#8$1"}, {"id": 265, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_1020_reed2_1#1$1", "focus": "r"}}, {"id": 266, "prop": "name", "attributes": {"content": "之前，我一個人在野外行動了很長時間，荒野上的危險，對我來說不算什麼。", "name": "葦草"}, "figure_art": "avg_1020_reed2_1#1$1"}, {"id": 267, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_1020_reed2_1#1$1", "focus": "r"}}, {"id": 268, "prop": "name", "attributes": {"content": "而且，我也不是在為羅德島執行任務。", "name": "葦草"}, "figure_art": "avg_1020_reed2_1#1$1"}, {"id": 269, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_1020_reed2_1#7$1", "focus": "r"}}, {"id": 270, "prop": "name", "attributes": {"content": "......我在追蹤與深池相關的一些事情。", "name": "葦草"}, "figure_art": "avg_1020_reed2_1#7$1"}, {"id": 271, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_222_bpipe_1#7", "focus": "l"}}, {"id": 272, "prop": "name", "attributes": {"content": "難怪......我和陳陳也是，所以我們才會在這裡撞見。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#7"}, {"id": 273, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_222_bpipe_1#7", "focus": "l"}}, {"id": 274, "prop": "name", "attributes": {"content": "在小丘郡的時候，你都受了那麼重的傷，一定也很在意深池......", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#7"}, {"id": 275, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_1020_reed2_1#2$1", "focus": "r"}}, {"id": 276, "prop": "name", "attributes": {"content": "深池裡，有人改變了我的命運，所以我想......試試還能不能從那裡扳回來什麼。", "name": "葦草"}, "figure_art": "avg_1020_reed2_1#2$1"}, {"id": 277, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_1020_reed2_1#2$1", "focus": "r"}}, {"id": 278, "prop": "name", "attributes": {"content": "無論是緩解他們帶去的痛苦，還是讓我自己感到平靜。", "name": "葦草"}, "figure_art": "avg_1020_reed2_1#2$1"}, {"id": 279, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_222_bpipe_1#8", "focus": "l"}}, {"id": 280, "prop": "name", "attributes": {"content": "......太好了。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#8"}, {"id": 281, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_222_bpipe_1#1", "focus": "l"}}, {"id": 282, "prop": "name", "attributes": {"content": "我們跟著商隊往這個方向走，原本就是想找一支最近出現在附近的深池部隊。也不知道為什麼，看到你的時候，我真的嚇了一跳。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#1"}, {"id": 283, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_222_bpipe_1#9", "focus": "l"}}, {"id": 284, "prop": "name", "attributes": {"content": "還好，你們跟深池一點關係都沒有。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#9"}, {"id": 285, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_1020_reed2_1#2$1", "focus": "r"}}, {"id": 286, "prop": "name", "attributes": {"content": "......", "name": "葦草"}, "figure_art": "avg_1020_reed2_1#2$1"}, {"id": 287, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_222_bpipe_1#1", "focus": "l"}}, {"id": 288, "prop": "name", "attributes": {"content": "這樣吧，我去和陳陳說一說，任務先緩幾天。她一定也很願意幫助這些人。", "name": "風笛"}, "figure_art": "avg_222_bpipe_1#1"}, {"id": 289, "prop": "Dialog", "attributes": {}}, {"id": 290, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 291, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 292, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 293, "prop": "Character", "attributes": {}}, {"id": 294, "prop": "charslot", "attributes": {}}, {"id": 295, "prop": "Background", "attributes": {"image": "34_g6_noblelivingroom", "screenadapt": "coverall"}}, {"id": 296, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 297, "prop": "playMusic", "attributes": {"intro": "$plot_intro", "key": "$plot_loop", "volume": 0.4}}, {"id": 298, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 299, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 300, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_228_1#1", "duration": 0.7}}, {"id": 301, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "duration": 0.7}}, {"id": 302, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 303, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_228_1#1", "focus": "l"}}, {"id": 304, "prop": "name", "attributes": {"content": "你猜，剛剛我是在幾個人的盯梢下走進這間會客室的？", "name": "阿赫茉妮"}, "figure_art": "avg_npc_228_1#1"}, {"id": 305, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 306, "prop": "name", "attributes": {"content": "我對你要如何在塔拉人和維多利亞人之間表演不感興趣。", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 307, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_228_1#1", "focus": "l"}}, {"id": 308, "prop": "name", "attributes": {"content": "那我實在應該感謝你特意趕來特倫特郡吸引視線。我以為，你會在軍隊中隱藏更長時間。", "name": "阿赫茉妮"}, "figure_art": "avg_npc_228_1#1"}, {"id": 309, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 310, "prop": "name", "attributes": {"content": "領袖的計劃走到這一步，我是威靈頓公爵的近衛隊成員，還是深池的軍官，這兩個身份已經沒有什麼區別。", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 311, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 312, "prop": "name", "attributes": {"content": "既然監視你的是開斯特的人，那他們應該早就掌握了這一情報。", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 313, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_228_1#1", "focus": "l"}}, {"id": 314, "prop": "name", "attributes": {"content": "城市外不斷出現小股深池部隊，還有深池大軍經過的傳言......這些就是做給他們看的。", "name": "阿赫茉妮"}, "figure_art": "avg_npc_228_1#1"}, {"id": 315, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_228_1#1", "focus": "l"}}, {"id": 316, "prop": "name", "attributes": {"content": "再加上一些神神秘秘的貿易訂單，現在恐怕連八卦一些的商人都已經知道，那位鐵公爵對這座城市有所圖謀。", "name": "阿赫茉妮"}, "figure_art": "avg_npc_228_1#1"}, {"id": 317, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_228_1#1", "focus": "l"}}, {"id": 318, "prop": "name", "attributes": {"content": "所有人都在四處打探，拼命猜測，那位公爵想借特倫特郡的舞台做什麼。", "name": "阿赫茉妮"}, "figure_art": "avg_npc_228_1#1"}, {"id": 319, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 320, "prop": "name", "attributes": {"content": "很符合領袖的期待。", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 321, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_228_1#1", "focus": "l"}}, {"id": 322, "prop": "name", "attributes": {"content": "是呀，如果我們真正的目的地被過早發現，各位公爵提前知道了領袖的決心，恐怕橡林郡外也會像倫蒂尼姆一樣熱鬧吧。", "name": "阿赫茉妮"}, "figure_art": "avg_npc_228_1#1"}, {"id": 323, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_228_1#1", "focus": "l"}}, {"id": 324, "prop": "name", "attributes": {"content": "你說，他們是更怕薩卡茲，還是更怕塔拉人？", "name": "阿赫茉妮"}, "figure_art": "avg_npc_228_1#1"}, {"id": 325, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 326, "prop": "name", "attributes": {"content": "把塔拉人和魔族相提並論？你沒資格開這種玩笑，維多利亞的菲林。", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 327, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 328, "prop": "name", "attributes": {"content": "......我聽說“間諜”死了。", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 329, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_228_1#2", "focus": "l"}}, {"id": 330, "prop": "name", "attributes": {"content": "是啊，從那以後，我們能得到的倫蒂尼姆城內的情報就大幅度減少了，確實可惜。", "name": "阿赫茉妮"}, "figure_art": "avg_npc_228_1#2"}, {"id": 331, "prop": "name", "attributes": {"content": "那裡不僅有薩卡茲，還蟄伏著一些......挺有意思的勢力。", "name": "阿赫茉妮"}, "figure_art": "avg_npc_228_1#2"}, {"id": 332, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 333, "prop": "name", "attributes": {"content": "我早就說過，你的感情用事一定會毀掉你的計劃。", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 334, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_228_1#7", "focus": "l"}}, {"id": 335, "prop": "name", "attributes": {"content": "感情用事？會這樣想我的人可真是不多了。", "name": "阿赫茉妮"}, "figure_art": "avg_npc_228_1#7"}, {"id": 336, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 337, "prop": "name", "attributes": {"content": "你不該想著給蔓德拉找一條生路。", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 338, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 339, "prop": "name", "attributes": {"content": "她被“雄辯家”利用，試圖分裂深池，本該和那六個叛徒一同死在小丘郡。", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 340, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_228_1#1", "focus": "l"}}, {"id": 341, "prop": "name", "attributes": {"content": "蔓德拉是“間諜”最信任的人，在確定“間諜”是否會背叛之前，處決她可算不上什麼明智之選。", "name": "阿赫茉妮"}, "figure_art": "avg_npc_228_1#1"}, {"id": 342, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 343, "prop": "name", "attributes": {"content": "藉口。", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 344, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 345, "prop": "name", "attributes": {"content": "救援“間諜”的任務，哪怕不值得你我親自去，也應該換一個更穩妥的人去做。", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 346, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_228_1#6", "focus": "l"}}, {"id": 347, "prop": "name", "attributes": {"content": "哦？這麼說，我和你關係不睦，沒機會害死你，這對你來說不是個好消息？", "name": "阿赫茉妮"}, "figure_art": "avg_npc_228_1#6"}, {"id": 348, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 349, "prop": "name", "attributes": {"content": "無意義的油嘴滑舌。", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 350, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_228_1#1", "focus": "l"}}, {"id": 351, "prop": "name", "attributes": {"content": "在公爵大人和領袖做出最終決定之前，你可不能輕舉妄動。", "name": "阿赫茉妮"}, "figure_art": "avg_npc_228_1#1"}, {"id": 352, "prop": "name", "attributes": {"content": "你能看出倫蒂尼姆情報的重要性，我怎麼會看不出呢。可我們最終會不會向倫蒂尼姆進軍，現在還是未知數呢。", "name": "阿赫茉妮"}, "figure_art": "avg_npc_228_1#1"}, {"id": 353, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 354, "prop": "name", "attributes": {"content": "取決於公爵之間的合作進展？", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 355, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_228_1#1", "focus": "l"}}, {"id": 356, "prop": "name", "attributes": {"content": "當然，不然我現在是在為什麼奔走？", "name": "阿赫茉妮"}, "figure_art": "avg_npc_228_1#1"}, {"id": 357, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 358, "prop": "name", "attributes": {"content": "......呵。我還記得四年前在飛地上的那場戰役，我們是怎麼苦苦等待大貴族們的合作結果的。", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 359, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 360, "prop": "name", "attributes": {"content": "與此同時，心思各異的使者在幾千公里外來回周旋，耐心地拉扯數周，只為了跟公爵說上一句話。", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 361, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 362, "prop": "name", "attributes": {"content": "阿赫茉妮，你最好是站在領袖這邊的。", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 363, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_228_1#1", "focus": "l"}}, {"id": 364, "prop": "name", "attributes": {"content": "不然呢？", "name": "阿赫茉妮"}, "figure_art": "avg_npc_228_1#1"}, {"id": 365, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 366, "prop": "name", "attributes": {"content": "蔓德拉已死，你想幫她的小心思我可以不再追究。", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 367, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 368, "prop": "name", "attributes": {"content": "但是，那個人還活著。", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 369, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_228_1#6", "focus": "l"}}, {"id": 370, "prop": "name", "attributes": {"content": "哦，你是說親愛的可憐的拉芙希妮。", "name": "阿赫茉妮"}, "figure_art": "avg_npc_228_1#6"}, {"id": 371, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 372, "prop": "name", "attributes": {"content": "“雄辯家”在小丘郡的陰謀不能再重演。只要她活著一天，對深池與領袖的威脅就始終存在。", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 373, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 374, "prop": "name", "attributes": {"content": "領袖把掌控她行蹤的任務交給了你。別再讓私情影響你，阿赫茉妮。你失敗不了太多次了。", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 375, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_228_1#2", "focus": "l"}}, {"id": 376, "prop": "name", "attributes": {"content": "唉，你對一名職業間諜的感情生活真是懷抱著太多幻想。", "name": "阿赫茉妮"}, "figure_art": "avg_npc_228_1#2"}, {"id": 377, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_723_1#1$1", "focus": "r"}}, {"id": 378, "prop": "name", "attributes": {"content": "......", "name": "“校官”"}, "figure_art": "avg_npc_723_1#1$1"}, {"id": 379, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_228_1#1", "focus": "l"}}, {"id": 380, "prop": "name", "attributes": {"content": "好啦好啦，別惡狠狠地盯著我了，“校官”大人，除非你想幫我化妝。我還有一場宴會要去呢。", "name": "阿赫茉妮"}, "figure_art": "avg_npc_228_1#1"}, {"id": 381, "prop": "Dialog", "attributes": {}}, {"id": 382, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 383, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 384, "prop": "stopmusic", "attributes": {"fadetime": 1.0}}, {"id": 385, "prop": "Character", "attributes": {}}, {"id": 386, "prop": "charslot", "attributes": {}}, {"id": 387, "prop": "Background", "attributes": {"image": "34_g4_swamp_n", "screenadapt": "coverall"}}, {"id": 388, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 389, "prop": "playMusic", "attributes": {"intro": "$darkness02_intro", "key": "$darkness02_loop", "volume": 0.4}}, {"id": 390, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 391, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 392, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_724_1#1$1", "duration": 0.5, "isblock": "true"}}, {"id": 393, "prop": "name", "attributes": {"content": "還是不錯的嘛，維恩，就跟那時候一樣。我總以為你沒什麼本事，結果你每次都能辦成一些事情。", "name": "塞爾蒙"}, "figure_art": "avg_npc_724_1#1$1"}, {"id": 394, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_725_1#2$1"}}, {"id": 395, "prop": "name", "attributes": {"content": "唉，借來這點口糧，又有什麼用呢？", "name": "維恩"}, "figure_art": "avg_npc_725_1#2$1"}, {"id": 396, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_724_1#1$1"}}, {"id": 397, "prop": "name", "attributes": {"content": "那兩個人，應該是維多利亞人吧？她們說了，能去城鎮替我們把用不著的東西換出去，也能給你們弄到防身的棍棒。", "name": "塞爾蒙"}, "figure_art": "avg_npc_724_1#1$1"}, {"id": 398, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_724_1#8$1"}}, {"id": 399, "prop": "name", "attributes": {"content": "有像樣的武器，你不該感到高興？", "name": "塞爾蒙"}, "figure_art": "avg_npc_724_1#8$1"}, {"id": 400, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_724_1#1$1"}}, {"id": 401, "prop": "name", "attributes": {"content": "好啦，拿你的小收音機聽聽，廣播裡有沒有商隊被打劫的事情。說不定那些膽小鬼怕被深池報復，根本不敢報警......", "name": "塞爾蒙"}, "figure_art": "avg_npc_724_1#1$1"}, {"id": 402, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_724_1#9$1"}}, {"id": 403, "prop": "name", "attributes": {"content": "......喂，維恩？", "name": "塞爾蒙"}, "figure_art": "avg_npc_724_1#9$1"}, {"id": 404, "prop": "name", "attributes": {"content": "你在回頭張望什麼呢。", "name": "塞爾蒙"}, "figure_art": "avg_npc_724_1#9$1"}, {"id": 405, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_725_1#4$1"}}, {"id": 406, "prop": "name", "attributes": {"content": "......那幾個感染者，從村子出來後就一直遠遠地跟著我們。", "name": "維恩"}, "figure_art": "avg_npc_725_1#4$1"}, {"id": 407, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_724_1#7$1"}}, {"id": 408, "prop": "name", "attributes": {"content": "他們還跟著啊？我們走得這麼快，以那幾個病人的腿腳，還帶著小孩，居然還能追上。", "name": "塞爾蒙"}, "figure_art": "avg_npc_724_1#7$1"}, {"id": 409, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_725_1#1$1"}}, {"id": 410, "prop": "name", "attributes": {"content": "是啊，他們要跟上我們，多不容易啊。", "name": "維恩"}, "figure_art": "avg_npc_725_1#1$1"}, {"id": 411, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_725_1#6$1"}}, {"id": 412, "prop": "name", "attributes": {"content": "我......我在擔心莫蘭。", "name": "維恩"}, "figure_art": "avg_npc_725_1#6$1"}, {"id": 413, "prop": "name", "attributes": {"content": "她的眼睛在幾年前那次饑荒裡就壞了，夜裡看不見路。現在敲過了熄火鐘，路上連一盞燈都沒剩下了。", "name": "維恩"}, "figure_art": "avg_npc_725_1#6$1"}, {"id": 414, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_724_1#10$1"}}, {"id": 415, "prop": "name", "attributes": {"content": "哦，聽起來還挺可憐。那請問他們跟著我們做什麼？難道我們看起來像是什麼救援隊嗎？", "name": "塞爾蒙"}, "figure_art": "avg_npc_724_1#10$1"}, {"id": 416, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_725_1#1$1"}}, {"id": 417, "prop": "name", "attributes": {"content": "我不知道，呃，可能是因為你這身衣服？", "name": "維恩"}, "figure_art": "avg_npc_725_1#1$1"}, {"id": 418, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_725_1#1$1"}}, {"id": 419, "prop": "name", "attributes": {"content": "你瞧，除了我以外，其他人都是把你當成真正的深池來對待的呀。", "name": "維恩"}, "figure_art": "avg_npc_725_1#1$1"}, {"id": 420, "prop": "name", "attributes": {"content": "大家都知道，深池會對塔拉人好，就這麼簡單。", "name": "維恩"}, "figure_art": "avg_npc_725_1#1$1"}, {"id": 421, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1020_reed2_1#2$1"}}, {"id": 422, "prop": "name", "attributes": {"content": "......我，去找他們。", "name": "葦草"}, "figure_art": "avg_1020_reed2_1#2$1"}, {"id": 423, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_725_1#4$1"}}, {"id": 424, "prop": "charslot", "attributes": {"slot": "m", "action": "shake", "random": "true", "power": 8.0, "times": 100.0, "isblock": "true", "duration": 0.2}}, {"id": 425, "prop": "name", "attributes": {"content": "啊，你嚇我一跳......你的聲音怎麼在發抖？你還好嗎？", "name": "維恩"}, "figure_art": "avg_npc_725_1#4$1"}, {"id": 426, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1020_reed2_1#13$1"}}, {"id": 427, "prop": "name", "attributes": {"content": "......", "name": "葦草"}, "figure_art": "avg_1020_reed2_1#13$1"}, {"id": 428, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1020_reed2_1#7$1"}}, {"id": 429, "prop": "name", "attributes": {"content": "......有更多人輪流站崗放哨，不是壞事......我們躲避巡邏隊會更容易一些。", "name": "葦草"}, "figure_art": "avg_1020_reed2_1#7$1"}, {"id": 430, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1020_reed2_1#7$1"}}, {"id": 431, "prop": "name", "attributes": {"content": "我......帶上他們一起走。", "name": "葦草"}, "figure_art": "avg_1020_reed2_1#7$1"}, {"id": 432, "prop": "Dialog", "attributes": {}}, {"id": 433, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 434, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 435, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 436, "prop": "Character", "attributes": {}}, {"id": 437, "prop": "charslot", "attributes": {}}, {"id": 438, "prop": "Image", "attributes": {}}, {"id": 439, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}