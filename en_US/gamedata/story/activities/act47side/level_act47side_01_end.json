1.2, "isblock": "true"}}, {"id": 142, "prop": "name", "attributes": {"content": "Kristen.", "name": "Nasti"}, "figure_art": "avg_npc_891_1#1$1"}, {"id": 143, "prop": "name", "attributes": {"content": "Her name was Kristen Wright.", "name": "Nasti"}, "figure_art": "avg_npc_891_1#1$1"}, {"id": 144, "prop": "dialog", "attributes": {}}, {"id": 145, "prop": "charslot", "attributes": {}}, {"id": 146, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 3.0, "keep": "true", "initamount": 0.0, "amount": 1.0, "block": "true"}}, {"id": 147, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 148, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 149, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 150, "prop": "charslot", "attributes": {}}, {"id": 151, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 0.0, "keep": "true", "initamount": 1.0, "amount": 0.0, "block": "false"}}, {"id": 152, "prop": "Background", "attributes": {"image": "38_g10_ecolab", "screenadapt": "coverall"}}, {"id": 153, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 154, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4212_nasti_1#1$1", "posfrom": "10,0", "posto": "10,0"}}, {"id": 155, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2039_1#7$1", "posfrom": "-10,0", "posto": "-10,0"}}, {"id": 156, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 157, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 158, "prop": "playMusic", "attributes": {"key": "$darkness_03_loop", "volume": 0.6}}, {"id": 159, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 160, "prop": "name", "attributes": {"content": "Lucky Cystybeast Food and Beverage will cancel their registration tomorrow, Director.", "name": "Sky Jagger"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 161, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 162, "prop": "name", "attributes": {"content": "They didn't pass the re-check?", "name": "Nasti"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 163, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 164, "prop": "name", "attributes": {"content": "Not even close. They were one of the first corporations that made the transformation to get into Propeller Paradise, riding on 'sky fever', when review criteria were less strict—", "name": "Sky Jagger"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 165, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#5$1"}}, {"id": 166, "prop": "name", "attributes": {"content": "What will happen to the testers they hired?", "name": "Nasti"}, "figure_art": "avg_4212_nasti_1#5$1"}, {"id": 167, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#8$1"}}, {"id": 168, "prop": "name", "attributes": {"content": "Their boss can't tell a motor from a transformer. I bet he just saw the name 'Propeller Paradise' as an opportunity to get rich quick...", "name": "Sky Jagger"}, "figure_art": "avg_npc_2039_1#8$1"}, {"id": 169, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#5$1"}}, {"id": 170, "prop": "name", "attributes": {"content": "What were you asking?", "name": "Sky Jagger"}, "figure_art": "avg_npc_2039_1#5$1"}, {"id": 171, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#4$1"}}, {"id": 172, "prop": "name", "attributes": {"content": "Nothing. You seem to like the name.", "name": "Nasti"}, "figure_art": "avg_4212_nasti_1#4$1"}, {"id": 173, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 174, "prop": "name", "attributes": {"content": "I wish they would just call it Galleria Stellaria.", "name": "Sky Jagger"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 175, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 176, "prop": "name", "attributes": {"content": "I know you didn't approve of publicizing the Ring Lab's technological legacy.", "name": "Nasti"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 177, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 178, "prop": "name", "attributes": {"content": "I have no intention of criticizing the Acting Control's decision, but overly conservative decision-making will only cause us to lose the respect we deserve.", "name": "Sky Jagger"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 179, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 180, "prop": "name", "attributes": {"content": "Countless tech firms have appeared out of nowhere, based on nothing but speckles of data. The Ring Lab that shone upon millions of Columbians is now educational toys accessible to anyone above the age of five...", "name": "Sky Jagger"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 181, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 182, "prop": "name", "attributes": {"content": "'Space' and 'universe' are the buzzwords on every Columbian's lips, but few remember that they came from Kristen's experiment logs that were made public.", "name": "Sky Jagger"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 183, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 184, "prop": "name", "attributes": {"content": "No one is truly commemorating her—not even you, Director Lunorey.", "name": "Sky Jagger"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 185, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 186, "prop": "name", "attributes": {"content": "Recording and retrospection are historians' work. Our job is to analyze validated data and follow a path that is effective and proven.", "name": "Nasti"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 187, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 188, "prop": "name", "attributes": {"content": "And what has come of this data and path?", "name": "Sky Jagger"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 189, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 190, "prop": "name", "attributes": {"content": "Over the past couple of years, Rhine has acquired a dozen smaller labs, making progress in projects large and small—with the notable exception of Kristen's legacy.", "name": "Sky Jagger"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 191, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 192, "prop": "name", "attributes": {"content": "At this exhibition, we will publish Rhine's subsequent research into the Galleria Stellaria for the first time, putting second-rate tech firms in their place, returning to the realm of aero-exploration and the public eye.", "name": "Sky Jagger"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 193, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 194, "prop": "name", "attributes": {"content": "I know the Vivarium was built on the data transmitted down from the Ring Lab, and that the development of a plant-based energy transmission system represents a monumental milestone in engineering design.", "name": "Sky Jagger"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 195, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#8$1"}}, {"id": 196, "prop": "name", "attributes": {"content": "Nurturing sprouts, paving botanical units, technical inspections... all these are for the sake of progressing our experiments. But is a 'vivarium' really enough, when it did not even get its day in the sun from the pre-expo?", "name": "Sky Jagger"}, "figure_art": "avg_npc_2039_1#8$1"}, {"id": 197, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#8$1"}}, {"id": 198, "prop": "name", "attributes": {"content": "......", "name": "Nasti"}, "figure_art": "avg_4212_nasti_1#8$1"}, {"id": 199, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 200, "prop": "name", "attributes": {"content": "Please, tell me, Director Lunorey. Rhine has bigger goals, don't we? Like how no one knew that Kristen was going to pierce the sky before the night she did it?", "name": "Sky Jagger"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 201, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 202, "prop": "name", "attributes": {"content": "That night over Trimounts was a long time ago.", "name": "Nasti"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 203, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 204, "prop": "name", "attributes": {"content": "......", "name": "Sky Jagger"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 205, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 206, "prop": "name", "attributes": {"content": "Get to inspecting the next company. Take note of the change in order.", "name": "Nasti"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 207, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 208, "prop": "name", "attributes": {"content": "Yes, ma'am.", "name": "Sky Jagger"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 209, "prop": "dialog", "attributes": {}}, {"id": 210, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "-10,0", "posto": "-30,0", "duration": 0.8, "isblock": "false"}}, {"id": 211, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 212, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 213, "prop": "name", "attributes": {"content": "Sky.", "name": "Nasti"}}, {"id": 214, "prop": "dialog", "attributes": {}}, {"id": 215, "prop": "delay", "attributes": {"time": 0.3}}, {"id": 216, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 217, "prop": "name", "attributes": {"content": "......", "name": "Sky Jagger"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 218, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#4$1"}}, {"id": 219, "prop": "name", "attributes": {"content": "I know how you feel, and I know that Kristen was the one who inspired you to join us.", "name": "Nasti"}, "figure_art": "avg_4212_nasti_1#4$1"}, {"id": 220, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#8$1"}}, {"id": 221, "prop": "name", "attributes": {"content": "Many people looked up at the sky that night. Not everyone chose to chase it.", "name": "Nasti"}, "figure_art": "avg_4212_nasti_1#8$1"}, {"id": 222, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#4$1"}}, {"id": 223, "prop": "name", "attributes": {"content": "Don't forget what made you take the first step.", "name": "Nasti"}, "figure_art": "avg_4212_nasti_1#4$1"}, {"id": 224, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 225, "prop": "name", "attributes": {"content": "...I'll prepare the inspection documents.", "name": "Sky Jagger"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 226, "prop": "dialog", "attributes": {}}, {"id": 227, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 228, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "-30,0", "posto": "-50,0", "afrom": 1.0, "ato": 0.0, "duration": 1.0, "isblock": "true"}}, {"id": 229, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 230, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#9$1"}}, {"id": 231, "prop": "name", "attributes": {"content": "......", "name": "Nasti"}, "figure_art": "avg_4212_nasti_1#9$1"}, {"id": 232, "prop": "dialog", "attributes": {}}, {"id": 233, "prop": "Dialog", "attributes": {}}, {"id": 234, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 235, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 236, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 237, "prop": "charslot", "attributes": {}}, {"id": 238, "prop": "Background", "attributes": {"image": "38_g13_trimountlivingroom", "screenadapt": "coverall"}}, {"id": 239, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 240, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 241, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1", "duration": 0.8, "isblock": "true"}}, {"id": 242, "prop": "name", "attributes": {"content": "Here's your pass, agreement form and business directory. Once again, I welcome you and your team on behalf of Propeller Paradise!", "name": "Staff"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 243, "prop": "name", "attributes": {"content": "Next! Can I help you?", "name": "Staff"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 244, "prop": "dialog", "attributes": {}}, {"id": 245, "prop": "charslot", "attributes": {}}, {"id": 246, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 247, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#2$1", "duration": 1.2, "isblock": "true"}}, {"id": 248, "prop": "name", "attributes": {"content": "I'm cancelling my business registration...", "name": "Aspen"}, "figure_art": "avg_npc_2041_1#2$1"}, {"id": 249, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 250, "prop": "name", "attributes": {"content": "What is the name of the business?", "name": "Staff"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 251, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#5$1"}}, {"id": 252, "prop": "name", "attributes": {"content": "Lucky Cystybeast Food and Beverage.", "name": "Aspen"}, "figure_art": "avg_npc_2041_1#5$1"}, {"id": 253, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 254, "prop": "name", "attributes": {"content": "You will be dismissing eighty-two testers, correct?", "name": "Staff"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 255, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#2$1"}}, {"id": 256, "prop": "name", "attributes": {"content": "Yes, I have their files and my own here.", "name": "Aspen"}, "figure_art": "avg_npc_2041_1#2$1"}, {"id": 257, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 258, "prop": "name", "attributes": {"content": "Thank you. One moment please.", "name": "Staff"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 259, "prop": "dialog", "attributes": {}}, {"id": 260, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1", "afrom": 1.0, "ato": 0.0, "duration": 0.8, "isblock": "true"}}, {"id": 261, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 262, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#2$1"}}, {"id": 263, "prop": "name", "attributes": {"content": "......", "name": "Aspen"}, "figure_art": "avg_npc_2041_1#2$1"}, {"id": 264, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#5$1"}}, {"id": 265, "prop": "name", "attributes": {"content": "Did the Shadow-Moon fall on my head or something? Why was I so sure I would make my money back that I hired eighty-two amateurs with no corporate experience?", "name": "Aspen"}, "figure_art": "avg_npc_2041_1#5$1"}, {"id": 266, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#5$1"}}, {"id": 267, "prop": "name", "attributes": {"content": "Every company does the same thing. Why does it have to be Lucky Cystybeast that gets the axe?", "name": "Aspen"}, "figure_art": "avg_npc_2041_1#5$1"}, {"id": 268, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#1$2"}}, {"id": 269, "prop": "name", "attributes": {"content": "A million gold certificates down the drain just because we were a little bit slow dealing with problems? You gotta be freaking kidding me!", "name": "Aspen"}, "figure_art": "avg_npc_2041_1#1$2"}, {"id": 270, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#1$2"}}, {"id": 271, "prop": "name", "attributes": {"content": "How the crap did One-Boot Shadow-Moon Real Estate solve that stupid '3D levitating boundary marker' technical issue? That bunch of cobblers?", "name": "Aspen"}, "figure_art": "avg_npc_2041_1#1$2"}, {"id": 272, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 273, "prop": "name", "attributes": {"content": "Your request has been processed, Mr. Aspen. The Propeller Paradise hotline will remain available until the end of the day.", "name": "Staff"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 274, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#2$1"}}, {"id": 275, "prop": "name", "attributes": {"content": "Okay...", "name": "Aspen"}, "figure_art": "avg_npc_2041_1#2$1"}, {"id": 276, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 277, "prop": "name", "attributes": {"content": "However, if you have certain 'special' needs, like One-Boot Shadow-Moon Real Estate did... we can help you with that.", "name": "Staff"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 278, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#4$1"}}, {"id": 279, "prop": "name", "attributes": {"content": "What do you mean?", "name": "Aspen"}, "figure_art": "avg_npc_2041_1#4$1"}, {"id": 280, "prop": "dialog", "attributes": {}}, {"id": 281, "prop": "charslot", "attributes": {}}, {"id": 282, "prop": "PlaySound", "attributes": {"key": "$d_avg_paper1", "volume": 1.0}}, {"id": 283, "prop": "name", "attributes": {"content": "The smiling staff member takes out the business directory that virtually everyone in Propeller Paradise has a copy of, and points to a phone number."}}, {"id": 284, "prop": "name", "attributes": {"content": "No name, no address, just an unremarkable phone number hidden among thousands, as tiny as Aspen's hope."}}, {"id": 285, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#4$1"}}, {"id": 286, "prop": "name", "attributes": {"content": "One phone call to this number is gonna solve all my problems? Lucky Cystybeast won't have to leave Propeller Paradise?", "name": "Aspen"}, "figure_art": "avg_npc_2041_1#4$1"}, {"id": 287, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 288, "prop": "name", "attributes": {"content": "Correct.", "name": "Staff"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 289, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#3$1"}}, {"id": 290, "prop": "name", "attributes": {"content": "Then I want to withdraw the terminations and the cancellation of registration—", "name": "Aspen"}, "figure_art": "avg_npc_2041_1#3$1"}, {"id": 291, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 292, "prop": "name", "attributes": {"content": "No need to worry. The registration of Lucky Cystybeast has not been cancelled. However, you do not need to withdraw the termination of your testers.", "name": "Staff"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 293, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 294, "prop": "name", "attributes": {"content": "This phone call will 'completely' solve your problems, and you won't need those people anymore.", "name": "Staff"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 295, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#5$1"}}, {"id": 296, "prop": "name", "attributes": {"content": "A miracle, or a scam...?", "name": "Aspen"}, "figure_art": "avg_npc_2041_1#5$1"}, {"id": 297, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#3$1"}}, {"id": 298, "prop": "name", "attributes": {"content": "Screw it. Anything to stay up here.", "name": "Aspen"}, "figure_art": "avg_npc_2041_1#3$1"}, {"id": 299, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 300, "prop": "dialog", "attributes": {}}, {"id": 301, "prop": "charslot", "attributes": {}}, {"id": 302, "prop": "PlaySound", "attributes": {"key": "$d_avg_telephone", "volume": 1.0}}, {"id": 303, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 304, "prop": "PlaySound", "attributes": {"key": "$d_avg_makephonecall", "volume": 1.0}}, {"id": 305, "prop": "delay", "attributes": {"time": 1.8}}, {"id": 306, "prop": "PlaySound", "attributes": {"key": "$d_avg_telephonebusy", "volume": 1.0}}, {"id": 307, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 308, "prop": "Dialog", "attributes": {}}, {"id": 309, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 310, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 311, "prop": "charslot", "attributes": {}}, {"id": 312, "prop": "Background", "attributes": {"image": "68_g7_airrestaurant", "screenadapt": "coverall"}}, {"id": 313, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 314, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 315, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 316, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2034_1#1$1", "duration": 1.5}}, {"id": 317, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2037_1#1$1", "duration": 1.5, "isblock": "true"}}, {"id": 318, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#6$1"}}, {"id": 319, "prop": "name", "attributes": {"content": "Mr. Tannen.", "name": "Mercia"}, "figure_art": "avg_npc_2037_1#6$1"}, {"id": 320, "prop": "playMusic", "attributes": {"key": "$normal_loop", "volume": 0.6}}, {"id": 321, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#3$1"}}, {"id": 322, "prop": "name", "attributes": {"content": "Let me guess. Nasti was skeptical, but she accepted the list and agreed to the proposal?", "name": "Gordon"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 323, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#1$1"}}, {"id": 324, "prop": "name", "attributes": {"content": "Yes. I checked the Engineering Department's inspection schedule for today, and it's exactly in the order that you proposed.", "name": "Mercia"}, "figure_art": "avg_npc_2037_1#1$1"}, {"id": 325, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#5$1"}}, {"id": 326, "prop": "name", "attributes": {"content": "But how did you know?", "name": "Mercia"}, "figure_art": "avg_npc_2037_1#5$1"}, {"id": 327, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#2$1"}}, {"id": 328, "prop": "name", "attributes": {"content": "I didn't know what she was going to choose. All I know was that I'm at the apex of my life right now, and everything is going my way!", "name": "Gordon"}, "figure_art": "avg_npc_2034_1#2$1"}, {"id": 329, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#1$1"}}, {"id": 330, "prop": "name", "attributes": {"content": "You're in good spirits.", "name": "Mercia"}, "figure_art": "avg_npc_2037_1#1$1"}, {"id": 331, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#8$1"}}, {"id": 332, "prop": "name", "attributes": {"content": "It's gonna take more than a Rhine director to move the needle.", "name": "Gordon"}, "figure_art": "avg_npc_2034_1#8$1"}, {"id": 333, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#3$1"}}, {"id": 334, "prop": "name", "attributes": {"content": "Open the letter on the table.", "name": "Gordon"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 335, "prop": "dialog", "attributes": {}}, {"id": 336, "prop": "PlaySound", "attributes": {"key": "$d_avg_paper2", "volume": 1.0}}, {"id": 337, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#11$1"}}, {"id": 338, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 339, "prop": "name", "attributes": {"content": "'From: Bureau of Alcohol, Tobacco, Arts Units, and Originium, To: Mr. Gordon Tannen. Congratulations on your appointment as Chief Executive of Propeller Paradise...'", "name": "Mercia"}, "figure_art": "avg_npc_2037_1#11$1"}, {"id": 340, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#11$1"}}, {"id": 341, "prop": "name", "attributes": {"content": "Two pages? I've never seen a congratulation letter this long.", "name": "Mercia"}, "figure_art": "avg_npc_2037_1#11$1"}, {"id": 342, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#1$1"}}, {"id": 343, "prop": "name", "attributes": {"content": "The reassignment letter that I got six months ago on the border was two lines.", "name": "Gordon"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 344, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#1$1"}}, {"id": 345, "prop": "name", "attributes": {"content": "Everyone thinks the ATAO is a sweet gig, but I didn't get to embezzle shit from the savages in Sami or the tribals in the Sargonian rainforest.", "name": "Gordon"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 346, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#3$1"}}, {"id": 347, "prop": "name", "attributes": {"content": "The old fox hated me, and the rest of the ATAO turned their noses up at me. Now? He's retired, and I'm promoted. Things sure can change in a hurry, don't they?", "name": "Gordon"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 348, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#3$1"}}, {"id": 349, "prop": "name", "attributes": {"content": "It's still light out, but a happy occasion like this calls for a—", "name": "Gordon"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 350, "prop": "dialog", "attributes": {}}, {"id": 351, "prop": "PlaySound", "attributes": {"key": "$d_avg_openbeer", "volume": 1.0}}, {"id": 352, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#6$1"}}, {"id": 353, "prop": "delay", "attributes": {"time": 0.3}}, {"id": 354, "prop": "name", "attributes": {"content": "A toast.", "name": "Mercia"}, "figure_art": "avg_npc_2037_1#6$1"}, {"id": 355, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#1$1"}}, {"id": 356, "prop": "name", "attributes": {"content": "Your champagne, sir.", "name": "Mercia"}, "figure_art": "avg_npc_2037_1#1$1"}, {"id": 357, "prop": "dialog", "attributes": {}}, {"id": 358, "prop": "PlaySound", "attributes": {"key": "$d_avg_winglssice", "volume": 1.0}}, {"id": 359, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 360, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#3$1"}}, {"id": 361, "prop": "name", "attributes": {"content": "Well done, Merry. You've made some progress in your time with me, whether we're talking about Nasti or this glass. Pour one for yourself.", "name": "Gordon"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 362, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#1$1"}}, {"id": 363, "prop": "name", "attributes": {"content": "Thank you, sir. However, the Rules are quite clear about not drinking on the job.", "name": "Mercia"}, "figure_art": "avg_npc_2037_1#1$1"}, {"id": 364, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#1$1"}}, {"id": 365, "prop": "name", "attributes": {"content": "Beastshit. I pulled that manual out of my ass.", "name": "Gordon"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 366, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#1$1"}}, {"id": 367, "prop": "name", "attributes": {"content": "In that case... would you like to say a few words?", "name": "Mercia"}, "figure_art": "avg_npc_2037_1#1$1"}, {"id": 368, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#1$1"}}, {"id": 369, "prop": "name", "attributes": {"content": "Yeah... the exhibition six days from now is just the start. My opening address will be the toast of all of Columbia.", "name": "Gordon"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 370, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#3$1"}}, {"id": 371, "prop": "name", "attributes": {"content": "Every rocket will have my face on it, and the largest district in Shadow-Moon will be named after me.", "name": "Gordon"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 372, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#2$1"}}, {"id": 373, "prop": "name", "attributes": {"content": "Rhine, ATAO, the District... no one's ever gonna tell Gordon Tannen what to do! This'll be <i>my</i> Propeller Paradise, forever and ever!", "name": "Gordon"}, "figure_art": "avg_npc_2034_1#2$1"}, {"id": 374, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#2$1"}}, {"id": 375, "prop": "name", "attributes": {"content": "Bottoms-up!", "name": "Gordon"}, "figure_art": "avg_npc_2034_1#2$1"}, {"id": 376, "prop": "PlaySound", "attributes": {"key": "$clink", "volume": 1.0}}, {"id": 377, "prop": "dialog", "attributes": {}}, {"id": 378, "prop": "charslot", "attributes": {}}, {"id": 379, "prop": "delay", "attributes": {"time": 1.2}}, {"id": 380, "prop": "PlaySound", "attributes": {"key": "$doorknockquite", "volume": 1.0}}, {"id": 381, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 382, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2034_1#1$1", "focus": "r"}}, {"id": 383, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2037_1#1$1", "focus": "r"}}, {"id": 384, "prop": "name", "attributes": {"content": "Who are you? Here for the party?", "name": "Gordon"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 385, "prop": "dialog", "attributes": {}}, {"id": 386, "prop": "charslot", "attributes": {}}, {"id": 387, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 388, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1000_1#1$1", "posfrom": "250,0", "posto": "0,0", "duration": 1.2, "isblock": "true"}}, {"id": 389, "prop": "name", "attributes": {"content": "Hello. Are you the Chief Executive of Propeller Paradise?", "name": "Unfamiliar Man"}, "figure_art": "avg_npc_1000_1#1$1"}, {"id": 390, "prop": "name", "attributes": {"content": "Oakley, newly appointed guide for Propeller Paradise. I'm supposed to report to a Mr. Gordon Tannen.", "name": "Unfamiliar Man"}, "figure_art": "avg_npc_1000_1#1$1"}, {"id": 391, "prop": "charslot", "attributes": {}}, {"id": 392, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2034_1#6$1", "focus": "r"}}, {"id": 393, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2037_1#1$1", "focus": "r"}}, {"id": 394, "prop": "name", "attributes": {"content": "......", "name": "Gordon"}, "figure_art": "avg_npc_2034_1#6$1"}, {"id": 395, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#12$1"}}, {"id": 396, "prop": "name", "attributes": {"content": "......", "name": "Mercia"}, "figure_art": "avg_npc_2037_1#12$1"}, {"id": 397, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 398, "prop": "name", "attributes": {"content": "Pffft—!", "name": "Gordon"}, "figure_art": "avg_npc_2034_1#6$1"}, {"id": 399, "prop": "charslot", "attributes": {}}, {"id": 400, "prop": "name", "attributes": {"content": "Gordon Tannen spits the champagne out of his mouth."}}, {"id": 401, "prop": "dialog", "attributes": {}}, {"id": 402, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 403, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 404, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 405, "prop": "charslot", "attributes": {}}, {"id": 406, "prop": "Background", "attributes": {}}, {"id": 407, "prop": "Image", "attributes": {}}, {"id": 408, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}