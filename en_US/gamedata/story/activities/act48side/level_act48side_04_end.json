me": "avg_npc_2087_1#1$1", "focus": "l"}}, {"id": 140, "prop": "name", "attributes": {"content": "Whoa, whoa—", "name": "Craftsmen Rep"}, "figure_art": "avg_npc_2087_1#1$1"}, {"id": 141, "prop": "Dialog", "attributes": {}}, {"id": 142, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2087_1#1$1", "focus": "r,l"}}, {"id": 143, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "0,0", "posto": "-100,0", "duration": 1.5, "focus": "r,l"}}, {"id": 144, "prop": "charslot", "attributes": {"slot": "r", "posfrom": "0,0", "posto": "100,0", "duration": 1.5, "focus": "r,l"}}, {"id": 145, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 146, "prop": "playsound", "attributes": {"key": "$d_avg_clothmovement"}}, {"id": 147, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2087_1#1$1", "focus": "m"}}, {"id": 148, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 149, "prop": "PlaySound", "attributes": {"key": "$rungeneral"}}, {"id": 150, "prop": "charslot", "attributes": {"slot": "m", "afrom": 1.0, "ato": 0.0, "duration": 1.5, "focus": "m"}}, {"id": 151, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 152, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "-100,0", "posto": "0,0", "duration": 1.5, "focus": "r,l"}}, {"id": 153, "prop": "charslot", "attributes": {"slot": "r", "posfrom": "100,0", "posto": "0,0", "duration": 1.5, "focus": "r,l"}}, {"id": 154, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 155, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2087_1#1$1", "focus": "l"}}, {"id": 156, "prop": "name", "attributes": {"content": "Xanthos? What's the hurry?", "name": "Craftsmen Rep"}, "figure_art": "avg_npc_2087_1#1$1"}, {"id": 157, "prop": "name", "attributes": {"content": "Is that Titi chasing after him?", "name": "Craftsmen Rep"}, "figure_art": "avg_npc_2087_1#1$1"}, {"id": 158, "prop": "Dialog", "attributes": {}}, {"id": 159, "prop": "charslot", "attributes": {}}, {"id": 160, "prop": "PlaySound", "attributes": {"key": "$rungeneral"}}, {"id": 161, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4056_titi_1#5$2", "duration": 1.5}}, {"id": 162, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 163, "prop": "name", "attributes": {"content": "Hey, Thanos! M-Make way!", "name": "Titi"}, "figure_art": "avg_4056_titi_1#5$2"}, {"id": 164, "prop": "Dialog", "attributes": {}}, {"id": 165, "prop": "charslot", "attributes": {}}, {"id": 166, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2087_1#1$1", "focus": "l"}}, {"id": 167, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2086_1#1$1", "focus": "l"}}, {"id": 168, "prop": "name", "attributes": {"content": "Is this a race? Where's the finish line?", "name": "Craftsmen Rep"}, "figure_art": "avg_npc_2087_1#1$1"}, {"id": 169, "prop": "name", "attributes": {"content": "Go, Titi, go! You can't lose to Xanthos when he has so much stuff on his back, right?", "name": "Craftsmen Rep"}, "figure_art": "avg_npc_2087_1#1$1"}, {"id": 170, "prop": "Dialog", "attributes": {}}, {"id": 171, "prop": "charslot", "attributes": {}}, {"id": 172, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4056_titi_1#15$2", "focus": "m"}}, {"id": 173, "prop": "name", "attributes": {"content": "No I can't!", "name": "Titi"}, "figure_art": "avg_4056_titi_1#15$2"}, {"id": 174, "prop": "Dialog", "attributes": {}}, {"id": 175, "prop": "PlaySound", "attributes": {"key": "$rungeneral"}}, {"id": 176, "prop": "charslot", "attributes": {"duration": 1.5}}, {"id": 177, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 178, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2087_1#1$1", "focus": "r"}}, {"id": 179, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2086_1#1$1", "focus": "r"}}, {"id": 180, "prop": "name", "attributes": {"content": "Careful with the apples!", "name": "Fruit Farmer Rep"}, "figure_art": "avg_npc_2086_1#1$1"}, {"id": 181, "prop": "Dialog", "attributes": {}}, {"id": 182, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 183, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 184, "prop": "charslot", "attributes": {}}, {"id": 185, "prop": "Background", "attributes": {"image": "69_g1_rivercrossing", "screenadapt": "coverall", "block": "true"}}, {"id": 186, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 187, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 188, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 189, "prop": "PlaySound", "attributes": {"key": "$rungeneral"}}, {"id": 190, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4166_varkis_1#1$1", "posfrom": "100,0", "posto": "0,0", "duration": 1.5, "focus": "m"}}, {"id": 191, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 192, "prop": "name", "attributes": {"content": "The Sargonian is persistent...", "name": "Xanthos"}, "figure_art": "avg_4166_varkis_1#1$1"}, {"id": 193, "prop": "name", "attributes": {"content": "But this is as far as you go.", "name": "Xanthos"}, "figure_art": "avg_4166_varkis_1#1$1"}, {"id": 194, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4166_varkis_1#1$1", "focus": "none"}}, {"id": 195, "prop": "name", "attributes": {"content": "Xanthos! The river is just ahead!", "name": "Titi"}}, {"id": 196, "prop": "name", "attributes": {"content": "The harp is out of its waterproof packaging! The water will ruin it!", "name": "Titi"}}, {"id": 197, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4166_varkis_1#16$1", "focus": "m"}}, {"id": 198, "prop": "name", "attributes": {"content": "I don't need a Sargonian to remind me, not when your people have ruined countless Minoan treasures.", "name": "Xanthos"}, "figure_art": "avg_4166_varkis_1#16$1"}, {"id": 199, "prop": "Dialog", "attributes": {}}, {"id": 200, "prop": "PlaySound", "attributes": {"key": "$rungeneral"}}, {"id": 201, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,0", "posto": "-100,0", "afrom": 1.0, "ato": 0.0, "duration": 1.0}}, {"id": 202, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 203, "prop": "PlaySound", "attributes": {"key": "$d_avg_woodenboat_sway_sharp"}}, {"id": 204, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 205, "prop": "PlaySound", "attributes": {"key": "$rungeneral"}}, {"id": 206, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4056_titi_1#11$2", "afrom": 0.0, "ato": 1.0, "posfrom": "100,0", "posto": "0,0", "duration": 1.0, "focus": "m"}}, {"id": 207, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 208, "prop": "name", "attributes": {"content": "Xanthos!", "name": "Titi"}, "figure_art": "avg_4056_titi_1#11$2"}, {"id": 209, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4056_titi_1#2$2", "focus": "m"}}, {"id": 210, "prop": "name", "attributes": {"content": "Wait, what's that sound... there's a boat under the pier? He had this carefully planned. It wasn't an impulsive act.", "name": "Titi"}, "figure_art": "avg_4056_titi_1#2$2"}, {"id": 211, "prop": "name", "attributes": {"content": "No, don't go—", "name": "Titi"}, "figure_art": "avg_4056_titi_1#2$2"}, {"id": 212, "prop": "Dialog", "attributes": {}}, {"id": 213, "prop": "PlaySound", "attributes": {"key": "$rungeneral"}}, {"id": 214, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,0", "posto": "-100,0", "afrom": 1.0, "ato": 0.0, "duration": 1.0}}, {"id": 215, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 216, "prop": "Blocker", "attributes": {"a": 1.0, "r": 1.0, "g": 1.0, "b": 1.0, "style": "slider", "inverse": "true", "fadetime": 0.3, "block": "true"}}, {"id": 217, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothstripfabric", "volume": 1.0, "channel": "2"}}, {"id": 218, "prop": "PlaySound", "attributes": {"key": "$d_avg_woodenboat_sway_sharp", "channel": "1"}}, {"id": 219, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "style": "slider", "inverse": "false", "fadetime": 0.3, "block": "true"}}, {"id": 220, "prop": "name", "attributes": {"content": "Arts-controlled ribbons fly toward the package on Xanthos's shoulder."}}, {"id": 221, "prop": "name", "attributes": {"content": "The Forte instinctively jumps back, placing the harp at the stern of the ship. The ribbons wind themselves around his arm, helping Titi jump onto the boat."}}, {"id": 222, "prop": "name", "attributes": {"content": "Xanthos! Ugh... it's swaying beneath my feet...", "name": "Titi"}}, {"id": 223, "prop": "name", "attributes": {"content": "We need to clear the air between us. Let's talk about this on dry land, shall we?", "name": "Titi"}}, {"id": 224, "prop": "name", "attributes": {"content": "I have nothing to say to a Sargonian.", "name": "Xanthos"}}, {"id": 225, "prop": "name", "attributes": {"content": "Let me apologize, then...", "name": "Titi"}}, {"id": 226, "prop": "Dialog", "attributes": {}}, {"id": 227, "prop": "PlaySound", "attributes": {"key": "$d_avg_bowstring_tightened"}}, {"id": 228, "prop": "CameraShake", "attributes": {"duration": 2.5, "xstrength": 10.0, "vibrato": 30.0, "randomness": 30.0, "fadeout": "true", "block": "false"}}, {"id": 229, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 230, "prop": "name", "attributes": {"content": "The two keep their eyes fixed on each other, one at the bow, the other at the stern. Xanthos clutches his oar and starts its motor, while Titi begins to glow with the light of her Originium Arts."}}, {"id": 231, "prop": "name", "attributes": {"content": "Ribbons fly from her clothes, grabbing the harp and pulling it towards the bow."}}, {"id": 232, "prop": "name", "attributes": {"content": "Xanthos cuts the ribbons, only to find that Titi has closed the distance with the harp. He runs to the bow, causing the boat to tip violently, throwing Titi off-balance and interrupting her Arts."}}, {"id": 233, "prop": "name", "attributes": {"content": "Both of them reach out desperately—"}}, {"id": 234, "prop": "Dialog", "attributes": {}}, {"id": 235, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovementsp", "volume": 1.0}}, {"id": 236, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 237, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 238, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 239, "prop": "charslot", "attributes": {}}, {"id": 240, "prop": "Image", "attributes": {}}, {"id": 241, "prop": "name", "attributes": {"content": "The dust cover on the relic is removed, revealing the legendary lost harp, in all its glory."}}, {"id": 242, "prop": "name", "attributes": {"content": "Every Minoan has heard the story of Kereseira and her harp, but precious few have seen it with their own eyes."}}, {"id": 243, "prop": "name", "attributes": {"content": "It remains proud and glorious, despite the passage of a thousand years. Sunlight falls on the metallic leaves decorating its pedestal, surrounding it with a gentle glow."}}, {"id": 244, "prop": "name", "attributes": {"content": "The pair fighting over the harp has no time to admire, as they watch the harp's trajectory change, less than a second before it hits the ground."}}, {"id": 245, "prop": "Dialog", "attributes": {}}, {"id": 246, "prop": "Image", "attributes": {"image": "69_i14", "xScale": 1.3, "yScale": 1.3}}, {"id": 247, "prop": "ImageTween", "attributes": {"duration": 105.0, "block": "false"}}, {"id": 248, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 249, "prop": "playsound", "attributes": {"key": "$d_avg_clocksound_loop", "loop": "true", "channel": "bgs", "volume": 0.0}}, {"id": 250, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 251, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "amount": 1.0, "fadetime": 4.0, "keep": "true"}}, {"id": 252, "prop": "playsound", "attributes": {"key": "$d_avg_timeslowdown", "volume": 0.3}}, {"id": 253, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 254, "prop": "SoundVolume", "attributes": {"volume": 0.5, "channel": "bgs", "fadetime": 2.0}}, {"id": 255, "prop": "name", "attributes": {"content": "Medjehtiqedti has never thought of herself as lucky."}}, {"id": 256, "prop": "name", "attributes": {"content": "The glory of her noble house had long faded away by her father's generation. Her father was obsessed with literature, while her mother, still clinging to old aristocratic habits, showed little interest in spending time with her daughter."}}, {"id": 257, "prop": "name", "attributes": {"content": "Titi spent most of her free time in her father's library, alone."}}, {"id": 258, "prop": "name", "attributes": {"content": "The knowledge she learned there was basic, shallow, but it nevertheless expanded her horizons, and instilled in her a strong sense of curiosity for everything. That was why she saved money to pay for her own studies in museology in Columbia."}}, {"id": 259, "prop": "name", "attributes": {"content": "She was excited, but nervous, when Padishah Khery appointed her to be the ambassador to Sargon."}}, {"id": 260, "prop": "name", "attributes": {"content": "On one hand, she was drawn to the wonders of Minoan culture and the stories of heroes; on the other hand, she was acutely aware of the challenges that the burden of history presented."}}, {"id": 261, "prop": "name", "attributes": {"content": "The joy that she gained from working with the temple craftsmen, the last visage of fantasy and daydream in her mind, would be shattered with the falling harp in less than a second."}}, {"id": 262, "prop": "Dialog", "attributes": {}}, {"id": 263, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 264, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 265, "prop": "charslot", "attributes": {}}, {"id": 266, "prop": "Image", "attributes": {}}, {"id": 267, "prop": "Image", "attributes": {"image": "69_i14", "xScale": 1.3, "yScale": 1.3}}, {"id": 268, "prop": "ImageTween", "attributes": {"xFrom": 380.0, "xTo": 200.0, "duration": 105.0, "block": "false"}}, {"id": 269, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 270, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 271, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 272, "prop": "name", "attributes": {"content": "Xanthos was not so arrogant as to think that his plan to take the harp back from the Sargonians was flawless."}}, {"id": 273, "prop": "name", "attributes": {"content": "He might go to jail, or have an Oripathy attack while carrying out the plan. He did not care that he was risking his life on something that would seem ridiculous to most."}}, {"id": 274, "prop": "name", "attributes": {"content": "To him, the only place where he would find peace was the battle on the border where Ithakos went, five years ago. There was no point in asking the meaning of anything that has happened since."}}, {"id": 275, "prop": "name", "attributes": {"content": "But the trickery of fate is even more cruel than in the heroic legends. Xanthos thought of many ends for himself, but never this one."}}, {"id": 276, "prop": "name", "attributes": {"content": "The precious harp is about to hit the ground, and there is nothing Xanthos can do about it. Should he be angry? Sad? Fearful? Or simply laugh at his own helplessness?"}}, {"id": 277, "prop": "name", "attributes": {"content": "The emotions that fate has impounded have returned to his empty chest. The tall Minoan warrior sees everything flash before his eyes."}}, {"id": 278, "prop": "name", "attributes": {"content": "The breeze of the Delphi Canal brushes against Xanthos's back. It has never felt so cold. He cannot help but tremble."}}, {"id": 279, "prop": "name", "attributes": {"content": "He can see the Sargonian woman's face. It is deathly pale. He knows that his own face is the same."}}, {"id": 280, "prop": "Dialog", "attributes": {}}, {"id": 281, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 282, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 283, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 284, "prop": "charslot", "attributes": {}}, {"id": 285, "prop": "Image", "attributes": {}}, {"id": 286, "prop": "Image", "attributes": {"image": "69_i14", "xScale": 1.3, "yScale": 1.3}}, {"id": 287, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 288, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 289, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 290, "prop": "stopsound", "attributes": {"channel": "bgs"}}, {"id": 291, "prop": "PlaySound", "attributes": {"key": "$d_avg_timetravel", "volume": 1.0}}, {"id": 292, "prop": "Image", "attributes": {"image": "69_i14", "xScale": 1.6, "yScale": 1.6, "fadetime": 1.5}}, {"id": 293, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.6, "yScaleFrom": 1.6, "xScaleTo": 0.8, "yScaleTo": 0.8, "duration": 3.0, "block": "false"}}, {"id": 294, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 295, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "amount": 0.0, "fadetime": 1.5, "keep": "true"}}, {"id": 296, "prop": "delay", "attributes": {"time": 3.5}}, {"id": 297, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 298, "prop": "PlaySound", "attributes": {"key": "$d_avg_heavyobject_woodcrack"}}, {"id": 299, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 300, "prop": "charslot", "attributes": {}}, {"id": 301, "prop": "Image", "attributes": {}}, {"id": 302, "prop": "Background", "attributes": {"image": "69_g1_rivercrossing", "screenadapt": "coverall", "block": "true"}}, {"id": 303, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 304, "prop": "PlayMusic", "attributes": {"intro": "$m_dia_street_intro", "key": "$m_dia_street_loop", "volume": 0.6}}, {"id": 305, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 306, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2088_1#1$1", "focus": "m"}}, {"id": 307, "prop": "name", "attributes": {"content": "We've arrested Xanthos the ferryman and his apprentice Lykeion on charges of robbery, Your Excellency.", "name": "Peace Officer"}, "figure_art": "avg_npc_2088_1#1$1"}, {"id": 308, "prop": "name", "attributes": {"content": "I sincerely apologize for the damages you've suffered... I know it's not my place to ask, but can the damaged item be—", "name": "Peace Officer"}, "figure_art": "avg_npc_2088_1#1$1"}, {"id": 309, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4056_titi_1#12$2", "focus": "m"}}, {"id": 310, "prop": "name", "attributes": {"content": "Thank you for your concern, officer. The item that was damaged was a personal effect, and not particularly valuable.", "name": "Titi"}, "figure_art": "avg_4056_titi_1#12$2"}, {"id": 311, "prop": "name", "attributes": {"content": "It was Xanthos the ferryman who ferried me across the river when I first came to Athenius. This was simply a minor misunderstanding. You can send the onlookers on their way.", "name": "Titi"}, "figure_art": "avg_4056_titi_1#12$2"}, {"id": 312, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2088_1#1$1", "focus": "m"}}, {"id": 313, "prop": "name", "attributes": {"content": "Yes, Your Excellency.", "name": "Peace Officer"}, "figure_art": "avg_npc_2088_1#1$1"}, {"id": 314, "prop": "name", "attributes": {"content": "If you do not intend to pursue this matter any further, then we will take the two suspects and proceed in accordance with the law.", "name": "Peace Officer"}, "figure_art": "avg_npc_2088_1#1$1"}, {"id": 315, "prop": "name", "attributes": {"content": "You two! Thank Kyría Mashayer for her magnanimity.", "name": "Peace Officer"}, "figure_art": "avg_npc_2088_1#1$1"}, {"id": 316, "prop": "Dialog", "attributes": {}}, {"id": 317, "prop": "charslot", "attributes": {}}, {"id": 318, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2069_1#1$1", "duration": 1.5}}, {"id": 319, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4166_varkis_1#1$2", "duration": 1.5}}, {"id": 320, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 321, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4166_varkis_1#1$2", "focus": "r"}}, {"id": 322, "prop": "name", "attributes": {"content": "......", "name": "Xanthos"}, "figure_art": "avg_4166_varkis_1#1$2"}, {"id": 323, "prop": "name", "attributes": {"content": "You don't know how to steer a boat. Grammateús Hekádemos can testify to that. You could have gotten off easily. Why put yourself in this situation with me, Lykeion?", "name": "Xanthos"}, "figure_art": "avg_4166_varkis_1#1$2"}, {"id": 324, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2069_1#8$1", "focus": "l"}}, {"id": 325, "prop": "name", "attributes": {"content": "You instructed me to provide a distraction on the boat because you know I'm a poor liar, Master Xanthos.", "name": "Lykeion"}, "figure_art": "avg_npc_2069_1#8$1"}, {"id": 326, "prop": "name", "attributes": {"content": "I knew about your plan and took action to help you. I must accept responsibility with you.", "name": "Lykeion"}, "figure_art": "avg_npc_2069_1#8$1"}, {"id": 327, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2069_1#1$1", "focus": "l"}}, {"id": 328, "prop": "name", "attributes": {"content": "Besides, I do not think that what you did was unreasonable.", "name": "Lykeion"}, "figure_art": "avg_npc_2069_1#1$1"}, {"id": 329, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4166_varkis_1#1$2", "focus": "r"}}, {"id": 330, "prop": "name", "attributes": {"content": "......", "name": "Xanthos"}, "figure_art": "avg_4166_varkis_1#1$2"}, {"id": 331, "prop": "Dialog", "attributes": {}}, {"id": 332, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "style": "slider", "inverse": "true", "fadetime": 2.0, "block": "true"}}, {"id": 333, "prop": "charslot", "attributes": {}}, {"id": 334, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2077_1#4$1", "focus": "l"}}, {"id": 335, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4056_titi_1#5$2", "focus": "r"}}, {"id": 336, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 337, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "style": "slider", "inverse": "true", "fadetime": 2.0, "block": "true"}}, {"id": 338, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2077_1#4$1", "focus": "l"}}, {"id": 339, "prop": "name", "attributes": {"content": "'A personal effect'? As if the officer believed that! She saw your courtesy as a way out, so she wouldn't have to prosecute her own people!", "name": "Behnui"}, "figure_art": "avg_npc_2077_1#4$1"}, {"id": 340, "prop": "name", "attributes": {"content": "The relic that is at the center of the first cultural exchange between Sargon and Minos since the establishment of diplomatic relations was stolen, and damaged during its retrieval. This would be more than enough to start a war if we were in Leithanien or Siracusa!", "name": "Behnui"}, "figure_art": "avg_npc_2077_1#4$1"}, {"id": 341, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4056_titi_1#5$2", "focus": "r"}}, {"id": 342, "prop": "name", "attributes": {"content": "I checked the harp. The damage was minor, only a crack on the pedestal. It can be easily repaired by filling and painting over the crack.", "name": "Titi"}, "figure_art": "avg_4056_titi_1#5$2"}, {"id": 343, "prop": "name", "attributes": {"content": "Under normal circumstances, I would have kept it untouched. But these are what we call <i>extenuating.</i> I can fix it so nothing looks out of place for the exchange ceremony in a few days.", "name": "Titi"}, "figure_art": "avg_4056_titi_1#5$2"}, {"id": 344, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2077_1#6$1", "focus": "l"}}, {"id": 345, "prop": "name", "attributes": {"content": "Hah. You may be descended from Sargonian nobility, but you've inherited none of your ancestors' political acumen.", "name": "Behnui"}, "figure_art": "avg_npc_2077_1#6$1"}, {"id": 346, "prop": "name", "attributes": {"content": "The Minoans are entirely at fault here. This is a perfect chance to punish the offenders severely, establish Sargon's authority and prestige, and—", "name": "Behnui"}, "figure_art": "avg_npc_2077_1#6$1"}, {"id": 347, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4056_titi_1#1$2", "focus": "r"}}, {"id": 348, "prop": "name", "attributes": {"content": "I know you're proud of your family's 'military exploits' in Minos, Behnui Effendi, and to you this is like revisiting old stomping grounds, in a sense.", "name": "Titi"}, "figure_art": "avg_4056_titi_1#1$2"}, {"id": 349, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4056_titi_1#2$2", "focus": "r"}}, {"id": 350, "prop": "name", "attributes": {"content": "But times have changed. Padishah Khery appointed us to visit Minos with Kereseira 's harp, not to show off Sargonian glory, but to repair the relationship between our two nations.", "name": "Titi"}, "figure_art": "avg_4056_titi_1#2$2"}, {"id": 351, "prop": "name", "attributes": {"content": "As emissaries of Sargon, our priority is to carry out the exchange ceremony successfully, not our own obsessions and interests. Am I wrong?", "name": "Titi"}, "figure_art": "avg_4056_titi_1#2$2"}, {"id": 352, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2077_1#6$1", "focus": "l"}}, {"id": 353, "prop": "name", "attributes": {"content": "......", "name": "Behnui"}, "figure_art": "avg_npc_2077_1#6$1"}, {"id": 354, "prop": "Dialog", "attributes": {}}, {"id": 355, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 356, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 357, "prop": "charslot", "attributes": {}}, {"id": 358, "prop": "Image", "attributes": {}}, {"id": 359, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}