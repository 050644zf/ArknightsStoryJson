 "PlaySound", "attributes": {"key": "$d_avg_airshiptakeoff", "volume": 0.0, "loop": "true", "channel": "machine"}}, {"id": 18, "prop": "SoundVolume", "attributes": {"volume": 0.8, "channel": "machine", "fadetime": 1.0}}, {"id": 19, "prop": "Delay", "attributes": {"time": 3.0}}, {"id": 20, "prop": "SoundVolume", "attributes": {"volume": 0.0, "channel": "machine", "fadetime": 3.0}}, {"id": 21, "prop": "name", "attributes": {"content": "Muffled noises echo through the empty cavern. Somewhere nearby, excavators continue their endless digging."}}, {"id": 22, "prop": "name", "attributes": {"content": "The air is colder and colder."}}, {"id": 23, "prop": "Dialog", "attributes": {}}, {"id": 24, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 25, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 26, "prop": "charslot", "attributes": {}}, {"id": 27, "prop": "Background", "attributes": {"image": "bg_wilderness_n", "screenadapt": "coverall", "block": "true"}}, {"id": 28, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 29, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 30, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 31, "prop": "name", "attributes": {"content": "The moment she's out of the cavern, a chill sets in."}}, {"id": 32, "prop": "name", "attributes": {"content": "But it merely spurs on her heart to run faster."}}, {"id": 33, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#2$2", "focus": "m"}}, {"id": 34, "prop": "name", "attributes": {"content": "How... How do I face her?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#2$2"}, {"id": 35, "prop": "Dialog", "attributes": {}}, {"id": 36, "prop": "charslot", "attributes": {}}, {"id": 37, "prop": "name", "attributes": {"content": "She cannot word it. She cannot face it."}}, {"id": 38, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 39, "prop": "name", "attributes": {"content": "Tut tut tut. Whatever will you do?", "name": "???"}}, {"id": 40, "prop": "Dialog", "attributes": {}}, {"id": 41, "prop": "PlaySound", "attributes": {"key": "$d_avg_openftstpwalk", "volume": 1.0, "loop": "true", "channel": "o"}}, {"id": 42, "prop": "StopSound", "attributes": {"channel": "o", "fadetime": 2.0}}, {"id": 43, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 44, "prop": "name", "attributes": {"content": "Sakiko does not need to turn her head to know who it is."}}, {"id": 45, "prop": "Dialog", "attributes": {}}, {"id": 46, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "duration": 0.7}}, {"id": 47, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 48, "prop": "playMusic", "attributes": {"intro": "$mist_intro", "key": "$mist_loop", "volume": 0.6}}, {"id": 49, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "focus": "m"}}, {"id": 50, "prop": "name", "attributes": {"content": "Now this girl's dreamland, I'm rather satisfied with!", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 51, "prop": "name", "attributes": {"content": "Sweet dreams for every child are the duty of the Castle of Dreams, and I've granted each one of her wishes.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 52, "prop": "name", "attributes": {"content": "Honestly, I'm surprised how smoothly this dream runs—no, flawlessly, in fact. Beyond my wildest expectations.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 53, "prop": "name", "attributes": {"content": "Besides, things have gotten even more interesting now, you know.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 54, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$2", "focus": "m"}}, {"id": 55, "prop": "name", "attributes": {"content": "...You're deceiving her.", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 56, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#20$1", "focus": "m"}}, {"id": 57, "prop": "name", "attributes": {"content": "No, no, no, nothing of the sort. We've had plenty of dealings, she and I. She knows full well what I am.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#20$1"}, {"id": 58, "prop": "name", "attributes": {"content": "Oh, seeing these results just fills my heart with joy.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#20$1"}, {"id": 59, "prop": "name", "attributes": {"content": "She knows it's all a dream and she still doesn't want to leave! Isn't that the very proof my dreamspinning is unmatched?", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#20$1"}, {"id": 60, "prop": "Dialog", "attributes": {}}, {"id": 61, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1937_1#3$1", "focus": "m"}}, {"id": 62, "prop": "PlaySound", "attributes": {"key": "$d_avg_yingying_ked_1", "volume": 1.0}}, {"id": 63, "prop": "name", "attributes": {"content": "(Chirping in agreement)", "name": "Corettons"}, "figure_art": "avg_npc_1937_1#3$1"}, {"id": 64, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 65, "prop": "Dialog", "attributes": {}}, {"id": 66, "prop": "charslot", "attributes": {}}, {"id": 67, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.6}}, {"id": 68, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#14$3", "duration": 1.0}}, {"id": 69, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 70, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "focus": "m"}}, {"id": 71, "prop": "name", "attributes": {"content": "Oh, you coming here...", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 72, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#1$1", "focus": "m"}}, {"id": 73, "prop": "name", "attributes": {"content": "Now that's interesting.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#1$1"}, {"id": 74, "prop": "name", "attributes": {"content": "Well, I'll leave you two to it, then! I trust you'll soon discover just how amusing this dream really is, Sakiko Togawa.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#1$1"}, {"id": 75, "prop": "Dialog", "attributes": {}}, {"id": 76, "prop": "PlaySound", "attributes": {"key": "$d_avg_shdwblwvr", "volume": 0.6}}, {"id": 77, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 78, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 79, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#14$3", "focus": "m"}}, {"id": 80, "prop": "name", "attributes": {"content": "Sakiko. Everyone's waiting for you. Let's go back.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 81, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$2", "focus": "m"}}, {"id": 82, "prop": "name", "attributes": {"content": "Go back?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 83, "prop": "name", "attributes": {"content": "Morpheus just vanished in front of you. Aren't you the least bit surprised...?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 84, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#14$3", "focus": "m"}}, {"id": 85, "prop": "name", "attributes": {"content": "No.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 86, "prop": "name", "attributes": {"content": "Everything here, we imagined together.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 87, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$2", "focus": "m"}}, {"id": 88, "prop": "name", "attributes": {"content": "'We'?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 89, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#14$3", "focus": "m"}}, {"id": 90, "prop": "name", "attributes": {"content": "You... aren't a part of us.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 91, "prop": "Dialog", "attributes": {}}, {"id": 92, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 93, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 94, "prop": "charslot", "attributes": {}}, {"id": 95, "prop": "Background", "attributes": {"image": "65_g9_warmrabbitnest", "screenadapt": "coverall", "block": "true"}}, {"id": 96, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 97, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 98, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 99, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#13$3", "focus": "m"}}, {"id": 100, "prop": "PlaySound", "attributes": {"key": "$d_avg_electricguitar", "volume": 0.6}}, {"id": 101, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 102, "prop": "Dialog", "attributes": {}}, {"id": 103, "prop": "charslot", "attributes": {}}, {"id": 104, "prop": "PlaySound", "attributes": {"key": "$d_avg_cheer_street", "volume": 0.8}}, {"id": 105, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 106, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "duration": 0.7}}, {"id": 107, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 108, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 109, "prop": "name", "attributes": {"content": "You play guitar so well, Mutsumi-chan!", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 110, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#13$3", "focus": "m"}}, {"id": 111, "prop": "name", "attributes": {"content": "Saki...", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#13$3"}, {"id": 112, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#16$3", "focus": "m"}}, {"id": 113, "prop": "name", "attributes": {"content": "No. Mum... Where did Saki go?", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#16$3"}, {"id": 114, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 115, "prop": "name", "attributes": {"content": "Saki-chan? Maybe she just went off somewhere...?", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 116, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#6$3", "focus": "m"}}, {"id": 117, "prop": "name", "attributes": {"content": "No, no. Saki... Saki would never abandon me.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#6$3"}, {"id": 118, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 119, "prop": "Dialog", "attributes": {}}, {"id": 120, "prop": "charslot", "attributes": {"duration": 0.7}}, {"id": 121, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 122, "prop": "name", "attributes": {"content": "The cheering crowd suddenly goes deathly quiet. They all stare straight at Mutsumi."}}, {"id": 123, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 124, "prop": "name", "attributes": {"content": "Mutsumi-chan, you seem to have forgotten—", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 125, "prop": "name", "attributes": {"content": "This isn't just your dream.", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 126, "prop": "Dialog", "attributes": {}}, {"id": 127, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "all"}}, {"id": 128, "prop": "delay", "attributes": {"time": 0.2}}, {"id": 129, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "afrom": 1.0, "ato": 0.0, "duration": 1.0}}, {"id": 130, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 131, "prop": "playsound", "attributes": {"key": "$d_avg_humanchange"}}, {"id": 132, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4183_mortis_1#14$3", "posfrom": "-200,0", "posto": "-200,0", "afrom": 0.0, "ato": 1.0, "duration": 1.0}}, {"id": 133, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 134, "prop": "PlayMusic", "attributes": {"key": "$monastery_sad_loop", "volume": 0.6}}, {"id": 135, "prop": "name", "attributes": {"content": "This is 'our' dream.", "name": "'Mutsumi's Mother'"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 136, "prop": "Dialog", "attributes": {}}, {"id": 137, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 138, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 139, "prop": "charslot", "attributes": {}}, {"id": 140, "prop": "Background", "attributes": {"image": "bg_wilderness_n", "screenadapt": "coverall", "block": "true"}}, {"id": 141, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#14$3", "focus": "m"}}, {"id": 142, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 143, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 144, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 145, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#14$3", "focus": "m"}}, {"id": 146, "prop": "name", "attributes": {"content": "'Us'.", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 147, "prop": "name", "attributes": {"content": "In this dream, every 'Mutsumi' has the chance to make her wish come true.", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 148, "prop": "name", "attributes": {"content": "Together with Mutsumi-chan, we've built a sweet dream that's ours and ours alone—where everyone can dream of happiness.", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 149, "prop": "name", "attributes": {"content": "We exist in Mutsumi-chan's mind. We've seen her life countless times over.", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 150, "prop": "name", "attributes": {"content": "In the end, we unanimously agreed that this—is the best ending for all the 'Mutsumis'—", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 151, "prop": "name", "attributes": {"content": "And you, Sakiko Togawa, are the enemy of this dream.", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 152, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#2$2", "focus": "m"}}, {"id": 153, "prop": "name", "attributes": {"content": "Mutsumi, what are you talking about?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#2$2"}, {"id": 154, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$2", "focus": "m"}}, {"id": 155, "prop": "name", "attributes": {"content": "I don't want you to suffer either, but we shouldn't hide away in dreams like this—", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 156, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#10$3", "focus": "m"}}, {"id": 157, "prop": "name", "attributes": {"content": "......", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#10$3"}, {"id": 158, "prop": "name", "attributes": {"content": "No, Mutsumi-chan gets to live a happy life here. That's the most important thing.", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#10$3"}, {"id": 159, "prop": "name", "attributes": {"content": "I'm not like the others. I want to talk things out with you, Sakiko.", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#10$3"}, {"id": 160, "prop": "name", "attributes": {"content": "You can stay here with me, and we'll protect Mutsumi-chan's sweet dream together.", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#10$3"}, {"id": 161, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#14$3", "focus": "m"}}, {"id": 162, "prop": "name", "attributes": {"content": "She's a fragile child. Odds are she still can't decide whether she wants to wake, or to stay here in bliss.", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 163, "prop": "name", "attributes": {"content": "So long as you choose to stay as well, and help us keep this dream going, it'll naturally become 'reality'.", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 164, "prop": "name", "attributes": {"content": "You are the sole determiner of 'reality' here. You <i>are</i> reality.", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 165, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#13$3", "focus": "m"}}, {"id": 166, "prop": "name", "attributes": {"content": "So. Stay with us, Sakiko.", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#13$3"}, {"id": 167, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$2", "focus": "m"}}, {"id": 168, "prop": "name", "attributes": {"content": "I refuse.", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 169, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#5$3", "focus": "m"}}, {"id": 170, "prop": "name", "attributes": {"content": "You... refuse?", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#5$3"}, {"id": 171, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$2", "focus": "m"}}, {"id": 172, "prop": "name", "attributes": {"content": "In <i>reality,</i> Mutsumi's body is lying out in the cold in the Castle of Dreams. Can you accept that as an ending, too?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 173, "prop": "name", "attributes": {"content": "If you truly love her, you would not be doing this to her.", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 174, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#7$3", "focus": "m"}}, {"id": 175, "prop": "name", "attributes": {"content": "As long as Mutsumi-chan is happy, as long as we can exist—what does it matter what's reality or not?!", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#7$3"}, {"id": 176, "prop": "name", "attributes": {"content": "I have Mutsumi-chan's every memory! I know your heart's deepest desire!", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#7$3"}, {"id": 177, "prop": "name", "attributes": {"content": "If you'll just stay here, I can even give you a whole, entire Ave{@nbs}Mujica!", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#7$3"}, {"id": 178, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#4$2", "focus": "m"}}, {"id": 179, "prop": "name", "attributes": {"content": "Shut up! You're not Mutsumi at all... She would never say that sort of thing.", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#4$2"}, {"id": 180, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#11$3", "focus": "m"}}, {"id": 181, "prop": "name", "attributes": {"content": "I like you, and I like Mutsumi-chan...", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#11$3"}, {"id": 182, "prop": "name", "attributes": {"content": "Why are you forcing me to choose like this?", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#11$3"}, {"id": 183, "prop": "Dialog", "attributes": {}}, {"id": 184, "prop": "charslot", "attributes": {}}, {"id": 185, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 186, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.7, "block": "true"}}, {"id": 187, "prop": "Subtitle", "attributes": {"text": "'Do it.'", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 188, "prop": "subtitle", "attributes": {}}, {"id": 189, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.7, "block": "true"}}, {"id": 190, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 191, "prop": "name", "attributes": {"content": "An unidentified voice hovers above their heads."}}, {"id": 192, "prop": "Dialog", "attributes": {}}, {"id": 193, "prop": "PlaySound", "attributes": {"key": "$smallearthquake", "volume": 0.5}}, {"id": 194, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 195, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.7, "block": "true"}}, {"id": 196, "prop": "Subtitle", "attributes": {"text": "'Do it, do it, do it.'", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 197, "prop": "subtitle", "attributes": {}}, {"id": 198, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.7, "block": "true"}}, {"id": 199, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 200, "prop": "name", "attributes": {"content": "The distant mountains seem to shake. The gravel on the ground jostles to a rhythm."}}, {"id": 201, "prop": "Dialog", "attributes": {}}, {"id": 202, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 203, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.7, "block": "true"}}, {"id": 204, "prop": "Subtitle", "attributes": {"text": "'Do it.'", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 205, "prop": "subtitle", "attributes": {}}, {"id": 206, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.7, "block": "true"}}, {"id": 207, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 208, "prop": "name", "attributes": {"content": "There's no one around to be seen, but Sakiko can almost feel countless gazes boring into her."}}, {"id": 209, "prop": "Dialog", "attributes": {}}, {"id": 210, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 211, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.7, "block": "true"}}, {"id": 212, "prop": "Subtitle", "attributes": {"text": "'Do it—!'", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 213, "prop": "subtitle", "attributes": {}}, {"id": 214, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.7, "block": "true"}}, {"id": 215, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 216, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#12$3", "focus": "m"}}, {"id": 217, "prop": "name", "attributes": {"content": "They're right. To Mutsumi-chan, we are her countless shadows.", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#12$3"}, {"id": 218, "prop": "name", "attributes": {"content": "So that the shadows may hide forever in the darkness, even the weakest light must be snuffed out.", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#12$3"}, {"id": 219, "prop": "Dialog", "attributes": {}}, {"id": 220, "prop": "charslot", "attributes": {"duration": 0.7}}, {"id": 221, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 222, "prop": "name", "attributes": {"content": "Step by tiny step, 'Mutsumi' forces Sakiko towards a precipice."}}, {"id": 223, "prop": "Dialog", "attributes": {}}, {"id": 224, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 225, "prop": "PlaySound", "attributes": {"key": "$d_avg_runstop", "volume": 1.0}}, {"id": 226, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 10.0, "ystrength": 12.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 227, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#5$2", "duration": 0.5}}, {"id": 228, "prop": "delay", "attributes": {"time": 0.7}}, {"id": 229, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#5$2", "focus": "m"}}, {"id": 230, "prop": "name", "attributes": {"content": "...What are you doing?!", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#5$2"}, {"id": 231, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#12$3", "focus": "m"}}, {"id": 232, "prop": "name", "attributes": {"content": "Sakiko...", "name": "'Mutsumi'"}, "figure_art": "avg_4183_mortis_1#12$3"}, {"id": 233, "prop": "Dialog", "attributes": {}}, {"id": 234, "prop": "charslot", "attributes": {}}, {"id": 235, "prop": "name", "attributes": {"content": "'Mutsumi' reaches out, placing her hand on Sakiko's shoulder."}}, {"id": 236, "prop": "Dialog", "attributes": {}}, {"id": 237, "prop": "playMusic", "attributes": {"key": "$darkness_03_loop", "volume": 0.6}}, {"id": 238, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovementsp", "volume": 1.0}}, {"id": 239, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 240, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 241, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.05, "block": "true"}}, {"id": 242, "prop": "Image", "attributes": {"image": "65_i08", "screenadapt": "coverall", "xScale": 1.3, "yScale": 1.3, "fadetime": 0.0, "x": 150.0}}, {"id": 243, "prop": "ImageTween", "attributes": {"xFrom": 150.0, "xTo": 0.0, "yTo": 0.0, "xScaleFrom": 1.3, "yScaleFrom": 1.3, "xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 30.0, "block": "false"}}, {"id": 244, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 1.5, "block": "true"}}, {"id": 245, "prop": "delay", "attributes": {"time": 3.0}}, {"id": 246, "prop": "name", "attributes": {"content": "Sakiko loses her balance. 'Mutsumi's' figure grows smaller and smaller."}}, {"id": 247, "prop": "name", "attributes": {"content": "I want Mutsumi-chan to be happy forever, Sakiko. I also don't want the 'Mutsumis' to have to disappear anymore.", "name": "'Mutsumi'"}}, {"id": 248, "prop": "name", "attributes": {"content": "I just have no choice...", "name": "'Mutsumi'"}}, {"id": 249, "prop": "name", "attributes": {"content": "Mutsumi-chan... doesn't need you.", "name": "'Mutsumi'"}}, {"id": 250, "prop": "Dialog", "attributes": {}}, {"id": 251, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 252, "prop": "Blocker", "attributes": {"a": 0.4, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 253, "prop": "Sticker", "attributes": {"id": "st1", "text": "'Please, just stay like this and don't let go of my hands—'", "x": 300.0, "y": 300.0, "alignment": "center", "size": 24.0, "delay": 0.0, "duration": 1.0, "width": 700.0}}, {"id": 254, "prop": "Sticker", "attributes": {"id": "st2", "text": "'Please don't ever, ever let me go.'", "x": 300.0, "y": 380.0, "alignment": "center", "size": 24.0, "delay": 0.0, "duration": 1.0, "width": 700.0}}, {"id": 255, "prop": "Sticker", "attributes": {"id": "st1", "duration": 1.0, "block": "false"}}, {"id": 256, "prop": "Sticker", "attributes": {"id": "st2", "duration": 1.0, "block": "false"}}, {"id": 257, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 258, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 259, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 260, "prop": "name", "attributes": {"content": "Goodbye forever, Sakiko.", "name": "'Mutsumi'"}}, {"id": 261, "prop": "Dialog", "attributes": {}}, {"id": 262, "prop": "stopmusic", "attributes": {"fadetime": 3.0}}, {"id": 263, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 264, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 265, "prop": "image", "attributes": {}}, {"id": 266, "prop": "charslot", "attributes": {}}, {"id": 267, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}