{"lang": "en_US", "eventid": "act45side", "eventName": "Somniloquium Serenum", "entryType": "ACTIVITY", "storyCode": "SS-5", "avgTag": "Before Operation", "storyName": "Invitation to the Ball", "storyInfo": "In Mutsumi's dream, she retains her memories, but opts not to leave, instead choosing to be an ordinary Rim Billitonian girl. Sakiko intends to persuade Mutsumi to leave, but after seeing just how much happier Mutsumi is now, she leaves while Mutsumi is performing, her heart conflicted.\n", "storyList": [{"id": 0, "prop": "HEADER", "attributes": {"key": "title_test", "is_skippable": "true", "fit_mode": "BLACK_MASK"}}, {"id": 1, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 2, "prop": "stopmusic", "attributes": {}}, {"id": 3, "prop": "Dialog", "attributes": {}}, {"id": 4, "prop": "Background", "attributes": {"image": "65_g10_dreamcastlestage", "screenadapt": "coverall", "block": "true"}}, {"id": 5, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 6, "prop": "playMusic", "attributes": {"intro": "$loneliness_intro", "key": "$loneliness_loop", "volume": 0.6}}, {"id": 7, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 8, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 9, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.7, "block": "true"}}, {"id": 10, "prop": "Subtitle", "attributes": {"text": "<i>We laugh together, we cry together.</i>", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 11, "prop": "Subtitle", "attributes": {"text": "<i>Up on this beautiful stage, we act out a vibrant monodrama.</i>", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 12, "prop": "Subtitle", "attributes": {"text": "<i>I do not fear death.</i>", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 13, "prop": "subtitle", "attributes": {}}, {"id": 14, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.7, "block": "true"}}, {"id": 15, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 16, "prop": "Dialog", "attributes": {}}, {"id": 17, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 18, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 19, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 20, "prop": "charslot", "attributes": {}}, {"id": 21, "prop": "Background", "attributes": {"image": "65_g9_warmrabbitnest", "screenadapt": "coverall", "block": "true"}}, {"id": 22, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 23, "prop": "PlayMusic", "attributes": {"key": "$normal_loop", "volume": 0.6}}, {"id": 24, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 25, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 26, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#1$3", "duration": 0.7}}, {"id": 27, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 28, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#1$3", "focus": "m"}}, {"id": 29, "prop": "name", "attributes": {"content": "Here, Saki. Drink.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#1$3"}, {"id": 30, "prop": "Dialog", "attributes": {}}, {"id": 31, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#3$2", "focus": "m"}}, {"id": 32, "prop": "Delay", "attributes": {"time": 0.3}}, {"id": 33, "prop": "PlaySound", "attributes": {"key": "$d_avg_drinkswllw", "volume": 0.6}}, {"id": 34, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 35, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#1$2", "focus": "m"}}, {"id": 36, "prop": "name", "attributes": {"content": "My throat doesn't hurt so much now...", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#1$2"}, {"id": 37, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#13$3", "focus": "m"}}, {"id": 38, "prop": "name", "attributes": {"content": "Good. Here. For you. Rim Billiton is all dust and sand. You need waterskins and goggles.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#13$3"}, {"id": 39, "prop": "Dialog", "attributes": {}}, {"id": 40, "prop": "charslot", "attributes": {}}, {"id": 41, "prop": "PlaySound", "attributes": {"key": "$d_avg_pcket", "volume": 0.7}}, {"id": 42, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 43, "prop": "name", "attributes": {"content": "Sakiko takes each item as Mutsumi offers them. She clutches them tightly. The swollen waterskin looks fit to burst."}}, {"id": 44, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#16$3", "focus": "m"}}, {"id": 45, "prop": "name", "attributes": {"content": "Saki. You seem bad. Are you sick?", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#16$3"}, {"id": 46, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$2", "focus": "m"}}, {"id": 47, "prop": "name", "attributes": {"content": "No, it's nothing...", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 48, "prop": "name", "attributes": {"content": "Mutsumi, you... remember me?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 49, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#14$3", "focus": "m"}}, {"id": 50, "prop": "name", "attributes": {"content": "Of course.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 51, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$2", "focus": "m"}}, {"id": 52, "prop": "name", "attributes": {"content": "You remember all the things we've been through?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 53, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#14$3", "focus": "m"}}, {"id": 54, "prop": "name", "attributes": {"content": "Mmhm. I remember all of it.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 55, "prop": "Dialog", "attributes": {}}, {"id": 56, "prop": "charslot", "attributes": {}}, {"id": 57, "prop": "name", "attributes": {"content": "Sakiko feels she can finally relax a little. She casts her gaze around—"}}, {"id": 58, "prop": "name", "attributes": {"content": "The long, narrow mineshaft they have been following dives deep into the ground, all the way down to here."}}, {"id": 59, "prop": "name", "attributes": {"content": "It is damp and dark, with only oil lanterns and stoves to provide feeble pinpricks of light."}}, {"id": 60, "prop": "name", "attributes": {"content": "There is space for only one between the bed and dining table, and based on the number of cups on that table, Mutsumi is not living here alone."}}, {"id": 61, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$2", "focus": "m"}}, {"id": 62, "prop": "name", "attributes": {"content": "Mutsumi, how... how long have you been living here?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 63, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#13$3", "focus": "m"}}, {"id": 64, "prop": "name", "attributes": {"content": "A year. Maybe more. There's nothing complicated to think about here, and time doesn't pass that clearly.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#13$3"}, {"id": 65, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$2", "focus": "m"}}, {"id": 66, "prop": "name", "attributes": {"content": "No... You can't sense the passing of time because you're in a dream.", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 67, "prop": "name", "attributes": {"content": "Mutsumi, why would you dream of <i>this</i>...?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 68, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#16$3", "focus": "m"}}, {"id": 69, "prop": "name", "attributes": {"content": "Dream...?", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#16$3"}, {"id": 70, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#12$2", "focus": "m"}}, {"id": 71, "prop": "name", "attributes": {"content": "I have something very important to tell you, Mutsumi. None of this is real. We need to—", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#12$2"}, {"id": 72, "prop": "Dialog", "attributes": {}}, {"id": 73, "prop": "charslot", "attributes": {}}, {"id": 74, "prop": "PlaySound", "attributes": {"key": "$dooropenquite", "volume": 1.0}}, {"id": 75, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 76, "prop": "name", "attributes": {"content": "Oh hello, now—back already, Mutsumi-chan?", "name": "???"}}, {"id": 77, "prop": "Dialog", "attributes": {}}, {"id": 78, "prop": "PlaySound", "attributes": {"key": "$d_avg_runstop", "volume": 1.0}}, {"id": 79, "prop": "PlaySound", "attributes": {"key": "$d_avg_kneelsnow_s", "volume": 1.0, "delay": 1.0}}, {"id": 80, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 81, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 12.0, "ystrength": 15.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 82, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 83, "prop": "name", "attributes": {"content": "Someone rushes in behind them, and tackles Mutsumi straight down on the soft bed."}}, {"id": 84, "prop": "name", "attributes": {"content": "M-Mum, you're all dusty, get off of me...", "name": "Mutsumi Wakaba"}}, {"id": 85, "prop": "name", "attributes": {"content": "Oh, but we haven't seen each other in nearly a day! Just let me hug you a bit!", "name": "???"}}, {"id": 86, "prop": "name", "attributes": {"content": "W-We have guests...", "name": "Mutsumi Wakaba"}}, {"id": 87, "prop": "Dialog", "attributes": {}}, {"id": 88, "prop": "PlaySound", "attributes": {"key": "$d_avg_cloakmovement", "volume": 1.0}}, {"id": 89, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1939_1#1$1", "duration": 1.0}}, {"id": 90, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4183_mortis_1#1$3", "duration": 1.0}}, {"id": 91, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 92, "prop": "Dialog", "attributes": {}}, {"id": 93, "prop": "charslot", "attributes": {}}, {"id": 94, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 95, "prop": "name", "attributes": {"content": "Oh! If it isn't Saki-chan!", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 96, "prop": "name", "attributes": {"content": "You haven't come over to ours in how long, now?", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 97, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#6$2", "focus": "m"}}, {"id": 98, "prop": "name", "attributes": {"content": "Minami-san...", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#6$2"}, {"id": 99, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 100, "prop": "name", "attributes": {"content": "Oh, no need to be so formal, just 'Minami' will do.", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 101, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#13$3", "focus": "m"}}, {"id": 102, "prop": "name", "attributes": {"content": "Mmhm. Sometimes I call Mum that too.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#13$3"}, {"id": 103, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$2", "focus": "m"}}, {"id": 104, "prop": "name", "attributes": {"content": "......", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 105, "prop": "name", "attributes": {"content": "Mutsumi, since when did you have such a good relationship with Minami-san...?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 106, "prop": "Dialog", "attributes": {}}, {"id": 107, "prop": "charslot", "attributes": {}}, {"id": 108, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 109, "prop": "name", "attributes": {"content": "We've always had one! We're mother and daughter, after all~", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 110, "prop": "name", "attributes": {"content": "Mutsumi-chan, how were today's earnings?", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 111, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#13$3", "focus": "m"}}, {"id": 112, "prop": "name", "attributes": {"content": "(Sifts through pockets) It was hot today, so more people wanted cucumber juice.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#13$3"}, {"id": 113, "prop": "Dialog", "attributes": {}}, {"id": 114, "prop": "charslot", "attributes": {}}, {"id": 115, "prop": "name", "attributes": {"content": "Mutsumi carefully opens the pouch in her hand. Within are a scant few coins."}}, {"id": 116, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 117, "prop": "name", "attributes": {"content": "Hooh—attagirl, Mutsumi-chan!", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 118, "prop": "name", "attributes": {"content": "(Sifts through pockets) Here, here's what I got.", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 119, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#15$3", "focus": "m"}}, {"id": 120, "prop": "name", "attributes": {"content": "Wow... You're amazing, Mum.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#15$3"}, {"id": 121, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 122, "prop": "name", "attributes": {"content": "Aren't I? I don't know why, but today I had a lot more people wanting their clothes mended!", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 123, "prop": "name", "attributes": {"content": "Your dad's been working hard too, putting in a full day's work at the construction site. When I went to drop off his lunch and saw his dust-covered face and exhausted look, I gave him special permission to go for a pint after work.", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 124, "prop": "name", "attributes": {"content": "I'm sure by now, he's downed a whole tanker!", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 125, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 126, "prop": "name", "attributes": {"content": "And to top it all off, now Saki-chan's here! You know what time I think it is? Time to get everyone together for dinner!", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 127, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#13$3", "focus": "m"}}, {"id": 128, "prop": "name", "attributes": {"content": "I'm glad. Eating with everyone is really nice.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#13$3"}, {"id": 129, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 130, "prop": "name", "attributes": {"content": "Isn't it just! And today was such a good day for us, we can't go being stingy now!", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 131, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$2", "focus": "m"}}, {"id": 132, "prop": "name", "attributes": {"content": "......", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 133, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 134, "prop": "name", "attributes": {"content": "Saki-chan, don't be shy! You're invited too!", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 135, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#16$3", "focus": "m"}}, {"id": 136, "prop": "name", "attributes": {"content": "Saki. What's wrong?", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#16$3"}, {"id": 137, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$2", "focus": "m"}}, {"id": 138, "prop": "name", "attributes": {"content": "No... Nothing...", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 139, "prop": "Dialog", "attributes": {}}, {"id": 140, "prop": "charslot", "attributes": {}}, {"id": 141, "prop": "name", "attributes": {"content": "They're clearly not a prosperous family. The bare mud walls, the dim lantern light..."}}, {"id": 142, "prop": "name", "attributes": {"content": "Why would Mutsumi's dream be like this?"}}, {"id": 143, "prop": "Dialog", "attributes": {}}, {"id": 144, "prop": "PlaySound", "attributes": {"key": "$doorknockquite", "volume": 1.0}}, {"id": 145, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 146, "prop": "PlaySound", "attributes": {"key": "$dooropenquite", "volume": 1.0}}, {"id": 147, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 148, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4081_warmy_1#11$2", "duration": 0.7}}, {"id": 149, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 150, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4081_warmy_1#11$2", "focus": "m"}}, {"id": 151, "prop": "name", "attributes": {"content": "Hello, Mutsumi, Minami... Oh, who's this?", "name": "Warmy"}, "figure_art": "avg_4081_warmy_1#11$2"}, {"id": 152, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#13$3", "focus": "m"}}, {"id": 153, "prop": "name", "attributes": {"content": "She's a friend from childhood. Saki.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#13$3"}, {"id": 154, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4081_warmy_1#4$2", "focus": "m"}}, {"id": 155, "prop": "name", "attributes": {"content": "Hello!", "name": "Warmy"}, "figure_art": "avg_4081_warmy_1#4$2"}, {"id": 156, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4081_warmy_1#1$2", "focus": "m"}}, {"id": 157, "prop": "name", "attributes": {"content": "I came over to ask if you all wanted dinner?", "name": "Warmy"}, "figure_art": "avg_4081_warmy_1#1$2"}, {"id": 158, "prop": "name", "attributes": {"content": "I made a lot tonight, and if you'd like, we can eat together.", "name": "Warmy"}, "figure_art": "avg_4081_warmy_1#1$2"}, {"id": 159, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 160, "prop": "name", "attributes": {"content": "...Now can we really accept?", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 161, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4081_warmy_1#10$2", "focus": "m"}}, {"id": 162, "prop": "name", "attributes": {"content": "Your neighbors say there hasn't been smoke from your chimney for a few days now...", "name": "Warmy"}, "figure_art": "avg_4081_warmy_1#10$2"}, {"id": 163, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#10$3", "focus": "m"}}, {"id": 164, "prop": "name", "attributes": {"content": "(Rubs stomach) Mmnh...", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#10$3"}, {"id": 165, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4081_warmy_1#1$2", "focus": "m"}}, {"id": 166, "prop": "name", "attributes": {"content": "Besides, it's been almost a month since the last party, right?", "name": "Warmy"}, "figure_art": "avg_4081_warmy_1#1$2"}, {"id": 167, "prop": "name", "attributes": {"content": "Everyone really wants to see Mutsumi perform again.", "name": "Warmy"}, "figure_art": "avg_4081_warmy_1#1$2"}, {"id": 168, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 169, "prop": "name", "attributes": {"content": "Well, if that's the case... What do you think, Mutsumi-chan?", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 170, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#5$3", "focus": "m"}}, {"id": 171, "prop": "name", "attributes": {"content": "M-M... Me?", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#5$3"}, {"id": 172, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 173, "prop": "name", "attributes": {"content": "I'm sure you want to see too, right, Saki? I could listen to it a hundred more times and still not get tired!", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 174, "prop": "name", "attributes": {"content": "If you don't mind, we can hold the party at ours! What a coincidence, we were just talking about inviting everyone over for dinner!", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 175, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#14$3", "focus": "m"}}, {"id": 176, "prop": "name", "attributes": {"content": "Saki, what do you think?", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 177, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#10$2", "focus": "m"}}, {"id": 178, "prop": "name", "attributes": {"content": "I...", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 179, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#1$2", "focus": "m"}}, {"id": 180, "prop": "name", "attributes": {"content": "I think... you should make the decision, Mutsumi.", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#1$2"}, {"id": 181, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#13$3", "focus": "m"}}, {"id": 182, "prop": "name", "attributes": {"content": "...Mm. I'm okay with it.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#13$3"}, {"id": 183, "prop": "Dialog", "attributes": {}}, {"id": 184, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 185, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 186, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 187, "prop": "charslot", "attributes": {}}, {"id": 188, "prop": "Background", "attributes": {"image": "65_g9_warmrabbitnest", "screenadapt": "coverall", "block": "true"}}, {"id": 189, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 190, "prop": "PlaySound", "attributes": {"key": "$d_avg_crwddiscuss_outside", "volume": 0.4, "loop": "true", "channel": "a"}}, {"id": 191, "prop": "playMusic", "attributes": {"intro": "$path_intro", "key": "$path_loop", "volume": 0.6}}, {"id": 192, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 193, "prop": "PlaySound", "attributes": {"key": "$clink"}}, {"id": 194, "prop": "PlaySound", "attributes": {"key": "$clink", "loop": "false", "channel": "1", "delay": 0.04}}, {"id": 195, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 196, "prop": "stopsound", "attributes": {"channel": "a", "fadetime": 1.5}}, {"id": 197, "prop": "name", "attributes": {"content": "Rowdy chatter, hearty laughs, clanking cups."}}, {"id": 198, "prop": "name", "attributes": {"content": "The cramped house is stuffed full with people, but nobody seems to mind the lack of space."}}, {"id": 199, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 200, "prop": "name", "attributes": {"content": "Alright, alright, time for another round!", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 201, "prop": "name", "attributes": {"content": "Now, a warm welcome to Mutsumi-chan's pal—Sakiko!", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 202, "prop": "Dialog", "attributes": {}}, {"id": 203, "prop": "charslot", "attributes": {}}, {"id": 204, "prop": "name", "attributes": {"content": "Eyyy! Hello, Sakiko!", "name": "Everyone"}}, {"id": 205, "prop": "name", "attributes": {"content": "Everyone turns to look at her, sitting in the corner."}}, {"id": 206, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 207, "prop": "name", "attributes": {"content": "(Lifting her pint glass) Sakiko...?", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 208, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$2", "focus": "m"}}, {"id": 209, "prop": "name", "attributes": {"content": "Ch—Cheers.", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 210, "prop": "Dialog", "attributes": {}}, {"id": 211, "prop": "charslot", "attributes": {}}, {"id": 212, "prop": "name", "attributes": {"content": "Cheers—!", "name": "Everyone"}}, {"id": 213, "prop": "Dialog", "attributes": {}}, {"id": 214, "prop": "PlaySound", "attributes": {"key": "$clink"}}, {"id": 215, "prop": "PlaySound", "attributes": {"key": "$clink", "loop": "false", "channel": "1", "delay": 0.04}}, {"id": 216, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 217, "prop": "name", "attributes": {"content": "With her welcomed, everyone's attention returns to the party. Sakiko leans against the wall alone, her eyes a mix of emotions as she watches it all unfold."}}, {"id": 218, "prop": "Dialog", "attributes": {}}, {"id": 219, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4182_oblvns_1#14$2", "focus": "r"}}, {"id": 220, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 221, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4183_mortis_1#14$3", "posfrom": "-150,0", "posto": "0,0", "duration": 1.0}}, {"id": 222, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 223, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4183_mortis_1#14$3", "focus": "l"}}, {"id": 224, "prop": "name", "attributes": {"content": "Saki.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 225, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4182_oblvns_1#14$2", "focus": "r"}}, {"id": 226, "prop": "name", "attributes": {"content": "Mutsumi...?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 227, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4183_mortis_1#10$3", "focus": "l"}}, {"id": 228, "prop": "name", "attributes": {"content": "Actually... I know about it all.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#10$3"}, {"id": 229, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4182_oblvns_1#6$2", "focus": "r"}}, {"id": 230, "prop": "name", "attributes": {"content": "Huh...?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#6$2"}, {"id": 231, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4183_mortis_1#10$3", "focus": "l"}}, {"id": 232, "prop": "name", "attributes": {"content": "This is all fake. Minami being so nice to me. It's all fake.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#10$3"}, {"id": 233, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4182_oblvns_1#6$2", "focus": "r"}}, {"id": 234, "prop": "name", "attributes": {"content": "Th-This—", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#6$2"}, {"id": 235, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4183_mortis_1#14$3", "focus": "l"}}, {"id": 236, "prop": "name", "attributes": {"content": "So when I saw you, I knew, it was time to go back.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 237, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4183_mortis_1#13$3", "focus": "l"}}, {"id": 238, "prop": "name", "attributes": {"content": "But... give me a chance.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#13$3"}, {"id": 239, "prop": "name", "attributes": {"content": "A chance to say goodbye. Then we can end it.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#13$3"}, {"id": 240, "prop": "name", "attributes": {"content": "Here, I can sing freely, just like everyone else.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#13$3"}, {"id": 241, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4182_oblvns_1#10$2", "focus": "r"}}, {"id": 242, "prop": "name", "attributes": {"content": "Mutsumi...", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 243, "prop": "Dialog", "attributes": {}}, {"id": 244, "prop": "PlaySound", "attributes": {"key": "$d_avg_walk_stage", "volume": 1.0, "loop": "false", "channel": "nw"}}, {"id": 245, "prop": "stopsound", "attributes": {"fadetime": 2.0, "channel": "nw"}}, {"id": 246, "prop": "charslot", "attributes": {"slot": "l", "afrom": 1.0, "ato": 0.0, "duration": 1.0}}, {"id": 247, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 248, "prop": "Dialog", "attributes": {}}, {"id": 249, "prop": "charslot", "attributes": {}}, {"id": 250, "prop": "name", "attributes": {"content": "Before Sakiko can even respond, Mutsumi picks up her guitar, and slowly walks up to the crowd."}}, {"id": 251, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 252, "prop": "name", "attributes": {"content": "You all ready, Mutsumi-chan?", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 253, "prop": "Dialog", "attributes": {}}, {"id": 254, "prop": "charslot", "attributes": {}}, {"id": 255, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 256, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#13$3", "duration": 1.0}}, {"id": 257, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 258, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#16$3", "focus": "m"}}, {"id": 259, "prop": "name", "attributes": {"content": "...Hi, everyone.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#16$3"}, {"id": 260, "prop": "Dialog", "attributes": {}}, {"id": 261, "prop": "charslot", "attributes": {}}, {"id": 262, "prop": "PlaySound", "attributes": {"key": "$d_avg_cheer_street", "volume": 1.0}}, {"id": 263, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 264, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#16$3", "focus": "m"}}, {"id": 265, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 266, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#9$3", "focus": "m"}}, {"id": 267, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 268, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#10$3", "focus": "m"}}, {"id": 269, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 270, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 271, "prop": "name", "attributes": {"content": "What is it, Mutsumi-chan? Something wrong?", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 272, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#16$3", "focus": "m"}}, {"id": 273, "prop": "name", "attributes": {"content": "...Chair. My chair.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#16$3"}, {"id": 274, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 275, "prop": "name", "attributes": {"content": "All ready for you. This one, yeah? The one you normally use?", "name": "Mutsumi's Mother"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 276, "prop": "Dialog", "attributes": {}}, {"id": 277, "prop": "charslot", "attributes": {}}, {"id": 278, "prop": "name", "attributes": {"content": "Mutsumi stares intently at the stool, its seat covered in deep cracks."}}, {"id": 279, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#13$3", "focus": "m"}}, {"id": 280, "prop": "name", "attributes": {"content": "Mm. That's it.", "name": "Mutsumi Wakaba"}, "figure_art": "avg_4183_mortis_1#13$3"}, {"id": 281, "prop": "Dialog", "attributes": {}}, {"id": 282, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 283, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothtrailground", "volume": 1.0}}, {"id": 284, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 285, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 286, "prop": "name", "attributes": {"content": "She slowly sits down. Everyone quiets their breathing."}}, {"id": 287, "prop": "Dialog", "attributes": {}}, {"id": 288, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 289, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 290, "prop": "charslot", "attributes": {}}, {"id": 291, "prop": "Background", "attributes": {"image": "bg_black", "screenadapt": "coverall"}}, {"id": 292, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 293, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 294, "prop": "multiline", "attributes": {"name": "Mutsumi Wakaba", "content": "Here goes. Please enjoy... "}}, {"id": 295, "prop": "multiline", "attributes": {"name": "Mutsumi Wakaba", "content": "<i>Haruhikage</i>."}}, {"id": 296, "prop": "Dialog", "attributes": {}}, {"id": 297, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 298, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 299, "prop": "charslot", "attributes": {}}, {"id": 300, "prop": "Image", "attributes": {"image": "65_i07_1", "screenadapt": "coverall", "block": "true"}}, {"id": 301, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 302, "prop": "playMusic", "attributes": {"intro": "$warm_intro", "key": "$warm_loop", "volume": 0.6}}, {"id": 303, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 304, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 305, "prop": "name", "attributes": {"content": "—!", "name": "Sakiko Togawa"}}, {"id": 306, "prop": "name", "attributes": {"content": "A melody Sakiko could never forget comes to life once more in Mutsumi's dream."}}, {"id": 307, "prop": "name", "attributes": {"content": "The same warm tone she remembered subtly soothes the hearts of all present."}}, {"id": 308, "prop": "name", "attributes": {"content": "The Mutsumi Wakaba before her is almost a stranger to Sakiko."}}, {"id": 309, "prop": "name", "attributes": {"content": "She is no longer the Mutsumi who struggles to express herself."}}, {"id": 310, "prop": "name", "attributes": {"content": "While her emotional expressions are still not very rich, here and now, she seems... so happy."}}, {"id": 311, "prop": "Dialog", "attributes": {}}, {"id": 312, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 313, "prop": "Blocker", "attributes": {"a": 0.4, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 314, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "'A heart grown numb with cold, a trembling gaze'", "x": 300.0, "y": 270.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0, "block": "true"}}, {"id": 315, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n'In all the world, I was alone'", "block": "true"}}, {"id": 316, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n'All I knew of spring was falling petals'", "block": "true"}}, {"id": 317, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n'And every year, my feelings are brushed off with indifference'", "block": "true"}}, {"id": 318, "prop": "Sticker", "attributes": {"id": "st1"}}, {"id": 319, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 320, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 321, "prop": "name", "attributes": {"content": "So this is what you wished for, Mutsumi...", "name": "Sakiko Togawa"}}, {"id": 322, "prop": "name", "attributes": {"content": "Sakiko has had countless opportunities to pull Mutsumi away from here, and she is certain Mutsumi would follow if she did."}}, {"id": 323, "prop": "name", "attributes": {"content": "But ultimately, she cannot bring herself to do it."}}, {"id": 324, "prop": "name", "attributes": {"content": "Not when this Mutsumi is so very happy."}}, {"id": 325, "prop": "name", "attributes": {"content": "The crowd lightly sways to the music. The feeble candlelight casts their shadows against the wall, like warm spring sunlight casting lilting shadows of trees."}}, {"id": 326, "prop": "name", "attributes": {"content": "Mutsumi sits on her stool, surrounded by all. Her eyes are closed, and as she strums, she gently sings."}}, {"id": 327, "prop": "name", "attributes": {"content": "What is on her mind in this moment?"}}, {"id": 328, "prop": "Dialog", "attributes": {}}, {"id": 329, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 330, "prop": "Blocker", "attributes": {"a": 0.4, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 331, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "'Heart-rending and endearing'", "x": 300.0, "y": 230.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0, "block": "true"}}, {"id": 332, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n'Now that I'm here, now that I feel'", "block": "true"}}, {"id": 333, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n'Heartwarming and tormenting'", "block": "true"}}, {"id": 334, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n'That me who couldn't cry that day'", "block": "true"}}, {"id": 335, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n'The light gently guides that me along with it—'", "block": "true"}}, {"id": 336, "prop": "Sticker", "attributes": {"id": "st1"}}, {"id": 337, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 338, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 339, "prop": "name", "attributes": {"content": "Some indescribable emotion clouds Sakiko's mind."}}, {"id": 340, "prop": "name", "attributes": {"content": "Is it gratification... or a refusal to accept things? Perhaps, a mix of the two."}}, {"id": 341, "prop": "name", "attributes": {"content": "Mutsumi Wakaba, as she is now, is much happier than when she was with Sakiko."}}, {"id": 342, "prop": "name", "attributes": {"content": "She sits there, alone on her stool, earnestly singing this familiar song."}}, {"id": 343, "prop": "Dialog", "attributes": {}}, {"id": 344, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 345, "prop": "Blocker", "attributes": {"a": 0.4, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 346, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "'Shimmering and sparkling, sail through the clouds'", "x": 300.0, "y": 200.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0, "block": "true"}}, {"id": 347, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n'My heart filled, it overflows'", "block": "true"}}, {"id": 348, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n'Shimmering and sparkling, down my cheeks, unnoticed'", "block": "true"}}, {"id": 349, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n'Burning, scorching, wetting my skin'", "block": "true"}}, {"id": 350, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n'Why is your hand so very warm?'", "block": "true"}}, {"id": 351, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n'Please, just stay like this and don't let go of my hands—'", "block": "true"}}, {"id": 352, "prop": "Sticker", "attributes": {"id": "st1"}}, {"id": 353, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 354, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 355, "prop": "name", "attributes": {"content": "If she does not let go—"}}, {"id": 356, "prop": "name", "attributes": {"content": "Then the happiness Mutsumi has found here—"}}, {"id": 357, "prop": "Dialog", "attributes": {}}, {"id": 358, "prop": "PlaySound", "attributes": {"key": "$d_avg_openftstprun", "volume": 1.0, "loop": "true", "channel": "nrun"}}, {"id": 359, "prop": "StopSound", "attributes": {"channel": "nrun", "fadetime": 4.0}}, {"id": 360, "prop": "Image", "attributes": {"image": "65_i07_2", "screenadapt": "coverall", "fadetime": 2.5, "block": "true"}}, {"id": 361, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 362, "prop": "name", "attributes": {"content": "Sakiko turns, and runs away in a panic."}}, {"id": 363, "prop": "name", "attributes": {"content": "And like that, she disappears into the night."}}, {"id": 364, "prop": "Dialog", "attributes": {}}, {"id": 365, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 366, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 367, "prop": "charslot", "attributes": {}}, {"id": 368, "prop": "Image", "attributes": {}}, {"id": 369, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}