{"lang": "en_US", "eventid": "act45side", "eventName": "Somniloquium Serenum", "entryType": "ACTIVITY", "storyCode": "SS-3", "avgTag": "Before Operation", "storyName": "Music Room's Radiance", "storyInfo": "In Umiri's dream, she has just been released from prison when an attempt is made on her life by a former boss's underling, Francis. Soon after, she receives yet another invitation from a 'Don' to join a Famiglia. As Sakiko searches for Umiri, she runs into Francis, and finds something is amiss.\n", "storyList": [{"id": 0, "prop": "HEADER", "attributes": {"key": "title_test", "is_skippable": "true", "fit_mode": "BLACK_MASK"}}, {"id": 1, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 2, "prop": "stopmusic", "attributes": {}}, {"id": 3, "prop": "Dialog", "attributes": {}}, {"id": 4, "prop": "Background", "attributes": {"image": "65_g10_dreamcastlestage", "screenadapt": "coverall", "block": "true"}}, {"id": 5, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 6, "prop": "playMusic", "attributes": {"intro": "$loneliness_intro", "key": "$loneliness_loop", "volume": 0.6}}, {"id": 7, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 8, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 9, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.7, "block": "true"}}, {"id": 10, "prop": "Subtitle", "attributes": {"text": "<i>The rain falls like tears, and I am but a single drop within this endless sea.</i>", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 11, "prop": "Subtitle", "attributes": {"text": "<i>In this lonely night, I am no longer lost.</i>", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 12, "prop": "Subtitle", "attributes": {"text": "<i>I do not fear being afraid.</i>", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 13, "prop": "subtitle", "attributes": {}}, {"id": 14, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.7, "block": "true"}}, {"id": 15, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 16, "prop": "Dialog", "attributes": {}}, {"id": 17, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 18, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 19, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 20, "prop": "charslot", "attributes": {}}, {"id": 21, "prop": "Background", "attributes": {"image": "bg_cellroomC", "screenadapt": "coverall", "block": "true"}}, {"id": 22, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 23, "prop": "PlayMusic", "attributes": {"key": "$wasteland_loop", "volume": 0.6}}, {"id": 24, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 25, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 26, "prop": "PlaySound", "attributes": {"key": "$d_gen_dooropen", "volume": 0.4}}, {"id": 27, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 28, "prop": "name", "attributes": {"content": "Prisoner 48038, step forward.", "name": "Jailer"}}, {"id": 29, "prop": "name", "attributes": {"content": "Sir! Your orders?", "name": "Excited Prisoner"}}, {"id": 30, "prop": "name", "attributes": {"content": "Did you forget anything when going over your personal effects?", "name": "Jailer"}}, {"id": 31, "prop": "name", "attributes": {"content": "No, sir, I made sure to check everything!", "name": "Excited Prisoner"}}, {"id": 32, "prop": "name", "attributes": {"content": "Head straight down the corridor to the little window at the end and sign your name. You're free to go after that.", "name": "Jailer"}}, {"id": 33, "prop": "name", "attributes": {"content": "Y-Yes, thank you, sir!", "name": "Excited Prisoner"}}, {"id": 34, "prop": "Dialog", "attributes": {}}, {"id": 35, "prop": "PlaySound", "attributes": {"key": "$d_avg_openftstprun", "volume": 1.0, "loop": "true", "channel": "a"}}, {"id": 36, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0, "delay": 1.5}}, {"id": 37, "prop": "StopSound", "attributes": {"channel": "a", "fadetime": 4.0}}, {"id": 38, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 39, "prop": "name", "attributes": {"content": "The sound of heavy jogging echoes down the corridor."}}, {"id": 40, "prop": "name", "attributes": {"content": "The heavy footsteps of boots gradually drew nearer, echoing down the hallway."}}, {"id": 41, "prop": "Dialog", "attributes": {}}, {"id": 42, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_134", "duration": 0.7}}, {"id": 43, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 44, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_134", "focus": "m"}}, {"id": 45, "prop": "name", "attributes": {"content": "Umiri.", "name": "Jailer"}, "figure_art": "avg_npc_134"}, {"id": 46, "prop": "Dialog", "attributes": {}}, {"id": 47, "prop": "charslot", "attributes": {}}, {"id": 48, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 49, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#1$3", "duration": 0.7}}, {"id": 50, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 51, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#1$3", "focus": "m"}}, {"id": 52, "prop": "name", "attributes": {"content": "Here.", "name": "Umiri Yahata"}, "figure_art": "avg_4186_tmoris_1#1$3"}, {"id": 53, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_134", "focus": "m"}}, {"id": 54, "prop": "name", "attributes": {"content": "Get lost. I don't want to see you again this year.", "name": "Jailer"}, "figure_art": "avg_npc_134"}, {"id": 55, "prop": "Dialog", "attributes": {}}, {"id": 56, "prop": "charslot", "attributes": {}}, {"id": 57, "prop": "PlaySound", "attributes": {"key": "$d_gen_dooropen", "volume": 0.8}}, {"id": 58, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 59, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#1$3", "focus": "m"}}, {"id": 60, "prop": "Delay", "attributes": {"time": 0.2}}, {"id": 61, "prop": "PlaySound", "attributes": {"key": "$d_avg_footstep_stonestep", "volume": 0.6, "channel": "step", "loop": "false"}}, {"id": 62, "prop": "stopsound", "attributes": {"channel": "step", "fadetime": 4.0}}, {"id": 63, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 64, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 65, "prop": "name", "attributes": {"content": "Umiri picks up her bass guitar case in one deft motion and strolls leisurely out of the prison."}}, {"id": 66, "prop": "Dialog", "attributes": {}}, {"id": 67, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 68, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 69, "prop": "charslot", "attributes": {}}, {"id": 70, "prop": "Background", "attributes": {"image": "33_g6_newtown_street", "screenadapt": "coverall", "block": "true"}}, {"id": 71, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 72, "prop": "PlaySound", "attributes": {"key": "$d_avg_rainlight_loop", "volume": 0.0, "loop": "true", "channel": "c"}}, {"id": 73, "prop": "SoundVolume", "attributes": {"volume": 1.0, "channel": "c", "fadetime": 2.0}}, {"id": 74, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 75, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 76, "prop": "name", "attributes": {"content": "Siracusa is much the same as ever, welcoming her return with an interminable drizzle."}}, {"id": 77, "prop": "Dialog", "attributes": {}}, {"id": 78, "prop": "stopsound", "attributes": {"channel": "c", "fadetime": 3.0}}, {"id": 79, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 80, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 81, "prop": "charslot", "attributes": {}}, {"id": 82, "prop": "Background", "attributes": {"image": "33_g10_smallrestaurant", "screenadapt": "coverall", "block": "true"}}, {"id": 83, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 84, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 85, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 86, "prop": "PlaySound", "attributes": {"key": "$d_avg_crowdrun", "volume": 0.8}}, {"id": 87, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_698_1#1$1", "duration": 1.0}}, {"id": 88, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_699_1#1$1", "duration": 1.0}}, {"id": 89, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 90, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_698_1#1$1", "focus": "l"}}, {"id": 91, "prop": "name", "attributes": {"content": "Put our boys and girls in every shop on this street and the next ones over. Everyone keeps an eye out. We are NOT letting her run away!", "name": "Lead Mobster"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 92, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_699_1#1$1", "focus": "r"}}, {"id": 93, "prop": "name", "attributes": {"content": "Got it!", "name": "Cautious Mobster"}, "figure_art": "avg_npc_699_1#1$1"}, {"id": 94, "prop": "Dialog", "attributes": {}}, {"id": 95, "prop": "charslot", "attributes": {}}, {"id": 96, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 97, "prop": "PlaySound", "attributes": {"key": "$d_avg_runstop", "volume": 1.0}}, {"id": 98, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_699_1#1$1", "duration": 0.5}}, {"id": 99, "prop": "delay", "attributes": {"time": 0.7}}, {"id": 100, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_699_1#1$1", "focus": "m"}}, {"id": 101, "prop": "name", "attributes": {"content": "Just got news from North Street, boss! She's heading this way!", "name": "Nervous Mobster"}, "figure_art": "avg_npc_699_1#1$1"}, {"id": 102, "prop": "charslot", "attributes": {}}, {"id": 103, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_698_1#1$1", "focus": "r"}}, {"id": 104, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_699_1#1$1", "focus": "r"}}, {"id": 105, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_699_1#1$1", "focus": "r"}}, {"id": 106, "prop": "name", "attributes": {"content": "Keep your eyes on her! Don't let her run off!", "name": "Lead Mobster"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 107, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_699_1#1$1", "focus": "l"}}, {"id": 108, "prop": "name", "attributes": {"content": "I... I don't think she's trying to hide, boss.", "name": "Nervous Mobster"}, "figure_art": "avg_npc_699_1#1$1"}, {"id": 109, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_698_1#1$1", "focus": "r"}}, {"id": 110, "prop": "name", "attributes": {"content": "...Get everyone back here, pronto!", "name": "Lead Mobster"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 111, "prop": "Dialog", "attributes": {}}, {"id": 112, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 113, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 114, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 115, "prop": "charslot", "attributes": {}}, {"id": 116, "prop": "Background", "attributes": {"image": "33_g2_srcalley", "screenadapt": "coverall", "block": "true"}}, {"id": 117, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 118, "prop": "PlaySound", "attributes": {"key": "$d_avg_rainlight_loop", "volume": 0.0, "loop": "true", "channel": "d"}}, {"id": 119, "prop": "SoundVolume", "attributes": {"volume": 1.0, "channel": "d", "fadetime": 2.0}}, {"id": 120, "prop": "playMusic", "attributes": {"intro": "$nervous_intro", "key": "$nervous_loop", "volume": 0.6}}, {"id": 121, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 122, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 123, "prop": "name", "attributes": {"content": "In the narrow alleyway, a gang of ghoulish thugs surrounds the girl with the bass guitar case."}}, {"id": 124, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 125, "prop": "name", "attributes": {"content": "We meet again... Umiri.", "name": "Lead Mobster"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 126, "prop": "name", "attributes": {"content": "Heh, and here I was wondering why a pro like you never got taken in by any famiglie.", "name": "Lead Mobster"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 127, "prop": "name", "attributes": {"content": "See, after ours fell on hard times, I asked around, and that's how I learned you made your career out of being a traitor.", "name": "Lead Mobster"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 128, "prop": "name", "attributes": {"content": "You've gone through a dozen names bouncing around every famiglia out there.", "name": "Lead Mobster"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 129, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#9$3", "focus": "m"}}, {"id": 130, "prop": "name", "attributes": {"content": "Our contracts never said we couldn't do work for others.", "name": "Umiri Yahata"}, "figure_art": "avg_4186_tmoris_1#9$3"}, {"id": 131, "prop": "name", "attributes": {"content": "And like I said long ago: I only take my reward and fulfill the duties that match it.", "name": "Umiri Yahata"}, "figure_art": "avg_4186_tmoris_1#9$3"}, {"id": 132, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 133, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 12.0, "ystrength": 15.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 134, "prop": "name", "attributes": {"content": "Is that why you sold our secrets to our enemies?!", "name": "Lead Mobster"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 135, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#12$3", "focus": "m"}}, {"id": 136, "prop": "name", "attributes": {"content": "...I don't know what you're talking about.", "name": "Umiri Yahata"}, "figure_art": "avg_4186_tmoris_1#12$3"}, {"id": 137, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 138, "prop": "name", "attributes": {"content": "Don't play dumb, you goddamn traitor! Ever since you showed up, our people have been getting screwed left and right!", "name": "Lead Mobster"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 139, "prop": "name", "attributes": {"content": "All thanks to me and the don being stupid enough to trust you. We even invited you to join us!", "name": "Lead Mobster"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 140, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#7$3", "focus": "m"}}, {"id": 141, "prop": "name", "attributes": {"content": "Francis, I don't remember what I've done to offend you all—", "name": "Umiri Yahata"}, "figure_art": "avg_4186_tmoris_1#7$3"}, {"id": 142, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 143, "prop": "name", "attributes": {"content": "Hmph. What, you owe so many people you can't even remember?!", "name": "Francis"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 144, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 145, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 146, "prop": "name", "attributes": {"content": "The don's dead, everyone's dead! We had hundreds of people, and now it's just our dozen left!", "name": "Francis"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 147, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#7$3", "focus": "m"}}, {"id": 148, "prop": "name", "attributes": {"content": "...What do you mean?", "name": "Umiri Yahata"}, "figure_art": "avg_4186_tmoris_1#7$3"}, {"id": 149, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 150, "prop": "name", "attributes": {"content": "We busted our asses moving from Columbia to this stupid place, but you had to go and get everyone killed!", "name": "Francis"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 151, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#7$3", "focus": "m"}}, {"id": 152, "prop": "name", "attributes": {"content": "I...", "name": "Umiri Yahata"}, "figure_art": "avg_4186_tmoris_1#7$3"}, {"id": 153, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_699_1#1$1", "focus": "m"}}, {"id": 154, "prop": "name", "attributes": {"content": "No more talk. There's enough of us here to teach her a very painful lesson today!", "name": "Angry Mobster"}, "figure_art": "avg_npc_699_1#1$1"}, {"id": 155, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#12$3", "focus": "m"}}, {"id": 156, "prop": "name", "attributes": {"content": "I don't want to have to fight with you...", "name": "Umiri Yahata"}, "figure_art": "avg_4186_tmoris_1#12$3"}, {"id": 157, "prop": "Dialog", "attributes": {}}, {"id": 158, "prop": "charslot", "attributes": {}}, {"id": 159, "prop": "name", "attributes": {"content": "Umiri tries to stay the impending clash through words, but the gang shows no signs of relenting as they approach her—"}}, {"id": 160, "prop": "name", "attributes": {"content": "She is forced to put her case down."}}, {"id": 161, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 162, "prop": "name", "attributes": {"content": "Alright... let's get her!", "name": "Francis"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 163, "prop": "Dialog", "attributes": {}}, {"id": 164, "prop": "PlaySound", "attributes": {"key": "$d_avg_swordexsheath", "volume": 1.0}}, {"id": 165, "prop": "PlaySound", "attributes": {"key": "$d_avg_attack_ready", "volume": 0.6, "delay": 0.7}}, {"id": 166, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 167, "prop": "Dialog", "attributes": {}}, {"id": 168, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 169, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 170, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 171, "prop": "charslot", "attributes": {}}, {"id": 172, "prop": "Image", "attributes": {"image": "cg_rainsplash", "screenadapt": "coverall", "fadetime": 0.0, "block": "true"}}, {"id": 173, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 174, "prop": "PlaySound", "attributes": {"key": "$d_avg_shallowswalk", "volume": 1.0, "loop": "true", "channel": "s"}}, {"id": 175, "prop": "StopSound", "attributes": {"channel": "s", "fadetime": 2.5}}, {"id": 176, "prop": "PlayMusic", "attributes": {"intro": "$mist_intro", "key": "$mist_loop", "volume": 0.6}}, {"id": 177, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 178, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 179, "prop": "name", "attributes": {"content": "I wouldn't go any further, now, bambina.", "name": "Kind Old Lady"}}, {"id": 180, "prop": "name", "attributes": {"content": "Something just started up over there. You're not safe alone. Go the long way round, quick.", "name": "Kind Old Lady"}}, {"id": 181, "prop": "name", "attributes": {"content": "...Thank you for the warning.", "name": "Behatted Girl"}}, {"id": 182, "prop": "name", "attributes": {"content": "The girl pays the passerby's advice no heed. She continues on in the exact direction she was warned against."}}, {"id": 183, "prop": "Dialog", "attributes": {}}, {"id": 184, "prop": "PlaySound", "attributes": {"key": "$d_avg_shallowswalk", "volume": 1.0}}, {"id": 185, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 186, "prop": "Dialog", "attributes": {}}, {"id": 187, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 188, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 189, "prop": "image", "attributes": {}}, {"id": 190, "prop": "charslot", "attributes": {}}, {"id": 191, "prop": "Background", "attributes": {"image": "33_g2_srcalley", "screenadapt": "coverall", "block": "true"}}, {"id": 192, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 193, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 194, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 195, "prop": "name", "attributes": {"content": "The rain patters against the ground, washing Siracusa's every stain away."}}, {"id": 196, "prop": "name", "attributes": {"content": "The girl steps into the alley. It is clean and tidy, so utterly spotless as to seem newly built."}}, {"id": 197, "prop": "name", "attributes": {"content": "Siracusa's cleaners are consummate professionals."}}, {"id": 198, "prop": "name", "attributes": {"content": "Not the slightest stench of blood hangs in the humid air."}}, {"id": 199, "prop": "Dialog", "attributes": {}}, {"id": 200, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#2$3", "duration": 1.0}}, {"id": 201, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 202, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#2$3", "focus": "m"}}, {"id": 203, "prop": "name", "attributes": {"content": "......", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#2$3"}, {"id": 204, "prop": "name", "attributes": {"content": "Umiri... where are you?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#2$3"}, {"id": 205, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#2$3", "focus": "n"}}, {"id": 206, "prop": "name", "attributes": {"content": "You... You looking for Umiri?", "name": "???"}}, {"id": 207, "prop": "Dialog", "attributes": {}}, {"id": 208, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#2$3", "focus": "m"}}, {"id": 209, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 210, "prop": "Dialog", "attributes": {}}, {"id": 211, "prop": "charslot", "attributes": {}}, {"id": 212, "prop": "Delay", "attributes": {"time": 0.2}}, {"id": 213, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "duration": 1.0}}, {"id": 214, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 215, "prop": "Dialog", "attributes": {}}, {"id": 216, "prop": "StopSound", "attributes": {"channel": "d", "fadetime": 2.0}}, {"id": 217, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 218, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 219, "prop": "charslot", "attributes": {}}, {"id": 220, "prop": "Background", "attributes": {"image": "33_g11_mansionhall", "screenadapt": "coverall", "block": "true"}}, {"id": 221, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 222, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 223, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 224, "prop": "name", "attributes": {"content": "The billiards room of a casino. Nobody would expect someone to live here."}}, {"id": 225, "prop": "name", "attributes": {"content": "A few cardboard boxes are assembled into a makeshift bed. The most basic of toiletries fill a bag nabbed for free from a fast food joint."}}, {"id": 226, "prop": "Dialog", "attributes": {}}, {"id": 227, "prop": "PlaySound", "attributes": {"key": "$d_avg_openenvelope_slow", "volume": 1.0}}, {"id": 228, "prop": "Delay", "attributes": {"time": 3.0}}, {"id": 229, "prop": "PlaySound", "attributes": {"key": "$d_avg_coin"}}, {"id": 230, "prop": "PlaySound", "attributes": {"key": "$d_avg_coin", "loop": "false", "channel": "coin2", "delay": 0.6}}, {"id": 231, "prop": "name", "attributes": {"content": "The billiards table is covered in envelopes, envelopes containing Umiri's payment."}}, {"id": 232, "prop": "name", "attributes": {"content": "She opens them up one after the other, tossing the golden coins within onto the table. Soon, the pile of coins stamped with 'Famiglia' and 'Ordine' has become a miniature mountain."}}, {"id": 233, "prop": "name", "attributes": {"content": "And there the coins are left, out in the open, without the slightest protection. She wouldn't care the slightest bit if they went missing."}}, {"id": 234, "prop": "Dialog", "attributes": {}}, {"id": 235, "prop": "PlaySound", "attributes": {"key": "$d_avg_papertear", "volume": 1.0}}, {"id": 236, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 237, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#7$3", "focus": "m"}}, {"id": 238, "prop": "name", "attributes": {"content": "...Hmm?", "name": "Umiri Yahata"}, "figure_art": "avg_4186_tmoris_1#7$3"}, {"id": 239, "prop": "Dialog", "attributes": {}}, {"id": 240, "prop": "charslot", "attributes": {}}, {"id": 241, "prop": "name", "attributes": {"content": "Umiri checks over the envelope in her hand once more. There is nothing in it."}}, {"id": 242, "prop": "name", "attributes": {"content": "She flips it over. On its front is the insignia of a famiglia, along with the sender's address."}}, {"id": 243, "prop": "Dialog", "attributes": {}}, {"id": 244, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 245, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 246, "prop": "charslot", "attributes": {}}, {"id": 247, "prop": "Background", "attributes": {"image": "33_g7_reception", "screenadapt": "coverall", "block": "true"}}, {"id": 248, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 249, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 250, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 251, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_699_1#1$1", "focus": "m"}}, {"id": 252, "prop": "name", "attributes": {"content": "She's here, boss.", "name": "Serious Mobster"}, "figure_art": "avg_npc_699_1#1$1"}, {"id": 253, "prop": "Dialog", "attributes": {}}, {"id": 254, "prop": "charslot", "attributes": {}}, {"id": 255, "prop": "Delay", "attributes": {"time": 0.2}}, {"id": 256, "prop": "PlaySound", "attributes": {"key": "$d_avg_walk_stage", "volume": 1.0, "loop": "false", "channel": "nw"}}, {"id": 257, "prop": "stopsound", "attributes": {"fadetime": 2.0, "channel": "nw"}}, {"id": 258, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#1$3", "duration": 1.0}}, {"id": 259, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 260, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#1$3", "focus": "n"}}, {"id": 261, "prop": "name", "attributes": {"content": "The guys in the prison didn't give you any trouble, did they?", "name": "Wizened Voice"}}, {"id": 262, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#11$3", "focus": "m"}}, {"id": 263, "prop": "name", "attributes": {"content": "They're all old friends. Besides, they know who my employer is. They wouldn't want to stick their hands in the fire.", "name": "Umiri Yahata"}, "figure_art": "avg_4186_tmoris_1#11$3"}, {"id": 264, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#12$3", "focus": "m"}}, {"id": 265, "prop": "name", "attributes": {"content": "But I imagine you didn't summon me just to ask that, did you, sir?", "name": "Umiri Yahata"}, "figure_art": "avg_4186_tmoris_1#12$3"}, {"id": 266, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#12$3", "focus": "n"}}, {"id": 267, "prop": "name", "attributes": {"content": "Kheheh. Just concerned for a business partner, that's all.", "name": "Wizened Voice"}}, {"id": 268, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#12$3", "focus": "m"}}, {"id": 269, "prop": "name", "attributes": {"content": "Sir, when did we become partners?", "name": "Umiri Yahata"}, "figure_art": "avg_4186_tmoris_1#12$3"}, {"id": 270, "prop": "name", "attributes": {"content": "When you signed your contract with me, you wouldn't even use your famiglia's name.", "name": "Umiri Yahata"}, "figure_art": "avg_4186_tmoris_1#12$3"}, {"id": 271, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#12$3", "focus": "n"}}, {"id": 272, "prop": "name", "attributes": {"content": "Well, if you want to become 'partners', and I know you do, then let me lay my cards out—", "name": "Wizened Voice"}}, {"id": 273, "prop": "name", "attributes": {"content": "Umiri, I'd like to have you for a long-term job.", "name": "Wizened Voice"}}, {"id": 274, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#7$3", "focus": "m"}}, {"id": 275, "prop": "name", "attributes": {"content": "What kind of job requires us to meet face-to-face?", "name": "Umiri Yahata"}, "figure_art": "avg_4186_tmoris_1#7$3"}, {"id": 276, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#7$3", "focus": "n"}}, {"id": 277, "prop": "name", "attributes": {"content": "I'm thinking... of inviting you into the famiglia.", "name": "Wizened Voice"}}, {"id": 278, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#6$3", "focus": "m"}}, {"id": 279, "prop": "name", "attributes": {"content": "......", "name": "Umiri Yahata"}, "figure_art": "avg_4186_tmoris_1#6$3"}, {"id": 280, "prop": "name", "attributes": {"content": "What... did you say?", "name": "Umiri Yahata"}, "figure_art": "avg_4186_tmoris_1#6$3"}, {"id": 281, "prop": "Dialog", "attributes": {}}, {"id": 282, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 283, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 284, "prop": "charslot", "attributes": {}}, {"id": 285, "prop": "Background", "attributes": {"image": "33_g11_mansionhall", "screenadapt": "coverall", "block": "true"}}, {"id": 286, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 287, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 288, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 289, "prop": "PlaySound", "attributes": {"key": "$d_avg_open_door", "volume": 0.6}}, {"id": 290, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 291, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.6}}, {"id": 292, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#12$2", "duration": 1.0}}, {"id": 293, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 294, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#12$2", "focus": "m"}}, {"id": 295, "prop": "name", "attributes": {"content": "There's nobody inside.", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#12$2"}, {"id": 296, "prop": "Dialog", "attributes": {}}, {"id": 297, "prop": "charslot", "attributes": {}}, {"id": 298, "prop": "PlaySound", "attributes": {"key": "$d_avg_runstop", "volume": 1.0}}, {"id": 299, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "duration": 0.5}}, {"id": 300, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 301, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#12$2", "focus": "m"}}, {"id": 302, "prop": "name", "attributes": {"content": "Why did you insist on coming along? You're obviously afraid of her.", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#12$2"}, {"id": 303, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 304, "prop": "name", "attributes": {"content": "You're not a mafioso, you wouldn't get it! I gotta... I gotta get revenge, for everyone's sake!", "name": "Francis"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 305, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$2", "focus": "m"}}, {"id": 306, "prop": "name", "attributes": {"content": "What exactly happened between you and Umiri that you find so unforgivable?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 307, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 308, "prop": "name", "attributes": {"content": "If you ever got betrayed the way we did, you wouldn't forgive her either...", "name": "Francis"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 309, "prop": "name", "attributes": {"content": "Our famiglia was mostly ordinary folk running away from the Columbian frontier. We didn't have much of a network or resources, so we've always been looked down upon by the local mafia.", "name": "Francis"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 310, "prop": "name", "attributes": {"content": "Fast forward a couple of years, and one day, the boss decides to spend a fortune hiring someone.", "name": "Francis"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 311, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$2", "focus": "m"}}, {"id": 312, "prop": "name", "attributes": {"content": "And that was Umiri?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 313, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 314, "prop": "name", "attributes": {"content": "Yep. Once we hired her, it was peace and quiet for a long, long time.", "name": "Francis"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 315, "prop": "name", "attributes": {"content": "Those were the good days. Didn't have to worry about anyone raiding our place, or looking for trouble at our door...", "name": "Francis"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 316, "prop": "name", "attributes": {"content": "But when we invited her to actually join the famiglia, she declined. Then the next day, she vanished. Just, gone.", "name": "Francis"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 317, "prop": "name", "attributes": {"content": "And right as we started getting suspicious, a bunch of goons stormed in to stab us in the gut. No idea who sent them.", "name": "Francis"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 318, "prop": "name", "attributes": {"content": "I still can't bear to look back at what happened that day... It was too much, too much!", "name": "Francis"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 319, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$2", "focus": "m"}}, {"id": 320, "prop": "name", "attributes": {"content": "And you're under the impression Umiri sold you out?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 321, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 322, "prop": "name", "attributes": {"content": "Well, who else could it be?! You're crazy if you think it's a coincidence!", "name": "Francis"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 323, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#10$2", "focus": "m"}}, {"id": 324, "prop": "name", "attributes": {"content": "...I'm not willing to believe that Umiri would betray someone like this.", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 325, "prop": "name", "attributes": {"content": "The Umiri I know is much like you've described. Strong and capable, a reassuring presence.", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 326, "prop": "name", "attributes": {"content": "And always eager to uphold her duty as part of a group.", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 327, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 328, "prop": "name", "attributes": {"content": "I mean, but facts are facts...", "name": "Francis"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 329, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#12$2", "focus": "m"}}, {"id": 330, "prop": "name", "attributes": {"content": "Did you see any trace of her amongst the people in that raid?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#12$2"}, {"id": 331, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 332, "prop": "name", "attributes": {"content": "...I did not.", "name": "Francis"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 333, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#12$2", "focus": "m"}}, {"id": 334, "prop": "name", "attributes": {"content": "Then do you remember what the raiders themselves looked like?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#12$2"}, {"id": 335, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 336, "prop": "name", "attributes": {"content": "Can't forget for the rest of my life.", "name": "Francis"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 337, "prop": "Dialog", "attributes": {}}, {"id": 338, "prop": "charslot", "attributes": {}}, {"id": 339, "prop": "name", "attributes": {"content": "Sakiko takes a deep breath, moving her hand to the self-defense weapon in her pocket."}}, {"id": 340, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$2", "focus": "m"}}, {"id": 341, "prop": "name", "attributes": {"content": "What if... someone was deliberately trying to break you apart?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 342, "prop": "name", "attributes": {"content": "What if... someone was keeping a close eye on Umiri this entire time?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 343, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 344, "prop": "name", "attributes": {"content": "...What're you trying to say?", "name": "Francis"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 345, "prop": "Dialog", "attributes": {}}, {"id": 346, "prop": "charslot", "attributes": {}}, {"id": 347, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 348, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 349, "prop": "PlaySound", "attributes": {"key": "$d_avg_opencabinet", "volume": 0.8}}, {"id": 350, "prop": "PlaySound", "attributes": {"key": "$d_avg_open_drawer", "volume": 1.0, "delay": 0.3}}, {"id": 351, "prop": "PlaySound", "attributes": {"key": "$d_avg_opencabinet", "volume": 1.0, "loop": "false", "channel": "k", "delay": 0.5}}, {"id": 352, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 353, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 354, "prop": "name", "attributes": {"content": "Before Francis can react, the cabinet doors all around them are thrown wide open."}}, {"id": 355, "prop": "name", "attributes": {"content": "Within each is a burly mobster, and all together, they raise their weapons at the pair in the center of the room."}}, {"id": 356, "prop": "Dialog", "attributes": {}}, {"id": 357, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_699_1#1$1", "duration": 1.0}}, {"id": 358, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_699_1#1$1", "duration": 1.0}}, {"id": 359, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 360, "prop": "playsound", "attributes": {"key": "$d_avg_gunequip", "volume": 0.7}}, {"id": 361, "prop": "PlaySound", "attributes": {"key": "$d_avg_gunload", "volume": 0.9, "delay": 0.2}}, {"id": 362, "prop": "PlaySound", "attributes": {"key": "$shotgunreload", "volume": 1.0, "delay": 0.4}}, {"id": 363, "prop": "playsound", "attributes": {"key": "$d_avg_gunequip", "channel": "1", "volume": 0.3}}, {"id": 364, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 365, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_699_1#1$1", "focus": "all"}}, {"id": 366, "prop": "name", "attributes": {"content": "No funny moves.", "name": "Mysterious Mobsters"}}, {"id": 367, "prop": "Dialog", "attributes": {}}, {"id": 368, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 369, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 370, "prop": "charslot", "attributes": {}}, {"id": 371, "prop": "Image", "attributes": {}}, {"id": 372, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}