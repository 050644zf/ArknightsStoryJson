"avg_4182_oblvns_1#10$2"}, {"id": 17, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#5$1", "focus": "m"}}, {"id": 18, "prop": "name", "attributes": {"content": "I know better than anyone how much you've changed. I'm your mother, after all.", "name": "Mother"}, "figure_art": "avg_npc_1941_1#5$1"}, {"id": 19, "prop": "name", "attributes": {"content": "I can hear it all—how hard you've been working... I know your job must be so hectic, and yet you've kept up with your piano practice.", "name": "Mother"}, "figure_art": "avg_npc_1941_1#5$1"}, {"id": 20, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#6$2", "focus": "m"}}, {"id": 21, "prop": "name", "attributes": {"content": "Huh?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#6$2"}, {"id": 22, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#5$1", "focus": "m"}}, {"id": 23, "prop": "name", "attributes": {"content": "It seems you've gone through quite a lot out there...", "name": "Mother"}, "figure_art": "avg_npc_1941_1#5$1"}, {"id": 24, "prop": "Dialog", "attributes": {}}, {"id": 25, "prop": "charslot", "attributes": {}}, {"id": 26, "prop": "PlaySound", "attributes": {"key": "$doorknockquite", "volume": 1.0}}, {"id": 27, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 28, "prop": "name", "attributes": {"content": "Hate to disturb you two while you're practicing! Supper's ready?", "name": "Father"}}, {"id": 29, "prop": "Dialog", "attributes": {}}, {"id": 30, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 31, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 32, "prop": "charslot", "attributes": {}}, {"id": 33, "prop": "Background", "attributes": {"image": "65_g5_sakikodininghall", "screenadapt": "coverall", "block": "true"}}, {"id": 34, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 35, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 36, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 37, "prop": "PlaySound", "attributes": {"key": "$d_avg_dishes", "volume": 1.0}}, {"id": 38, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 39, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#11$2", "focus": "m"}}, {"id": 40, "prop": "name", "attributes": {"content": "Mm—this is wonderful!", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#11$2"}, {"id": 41, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1940_1#6$1", "focus": "m"}}, {"id": 42, "prop": "name", "attributes": {"content": "What do you think? My cooking's really improved, eh?", "name": "Father"}, "figure_art": "avg_npc_1940_1#6$1"}, {"id": 43, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#5$1", "focus": "m"}}, {"id": 44, "prop": "name", "attributes": {"content": "You don't know the half of it, Sakiko... He had me taste-test so much in order to finally get to this point.", "name": "Mother"}, "figure_art": "avg_npc_1941_1#5$1"}, {"id": 45, "prop": "Dialog", "attributes": {}}, {"id": 46, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1940_1#5$1", "focus": "m"}}, {"id": 47, "prop": "PlaySound", "attributes": {"key": "$d_avg_plateplace", "volume": 1.0}}, {"id": 48, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 49, "prop": "name", "attributes": {"content": "Hurry and give this salad a try, hm?", "name": "Father"}, "figure_art": "avg_npc_1940_1#5$1"}, {"id": 50, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#11$2", "focus": "m"}}, {"id": 51, "prop": "name", "attributes": {"content": "Mmh! Delicious!", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#11$2"}, {"id": 52, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1940_1#6$1", "focus": "m"}}, {"id": 53, "prop": "name", "attributes": {"content": "I've made a lot of minor adjustments so it's more to your liking! Not half bad, eh?", "name": "Father"}, "figure_art": "avg_npc_1940_1#6$1"}, {"id": 54, "prop": "name", "attributes": {"content": "And there's plenty more dishes you love on the way!", "name": "Father"}, "figure_art": "avg_npc_1940_1#6$1"}, {"id": 55, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#11$2", "focus": "m"}}, {"id": 56, "prop": "name", "attributes": {"content": "Yep!", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#11$2"}, {"id": 57, "prop": "Dialog", "attributes": {}}, {"id": 58, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 59, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 60, "prop": "charslot", "attributes": {}}, {"id": 61, "prop": "Background", "attributes": {"image": "65_g5_sakikodininghall", "screenadapt": "coverall", "block": "true"}}, {"id": 62, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$2", "focus": "m"}}, {"id": 63, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 64, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 65, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 66, "prop": "charslot", "attributes": {"slot": "m", "action": "shake", "random": "true", "power": 5.0, "times": 50.0, "duration": 0.4}}, {"id": 67, "prop": "name", "attributes": {"content": "Ngh... Ugh...", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 68, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#3$1", "focus": "m"}}, {"id": 69, "prop": "name", "attributes": {"content": "Sakiko? Sakiko!", "name": "Mother"}, "figure_art": "avg_npc_1941_1#3$1"}, {"id": 70, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1940_1#2$1", "focus": "m"}}, {"id": 71, "prop": "name", "attributes": {"content": "Wh-What's wrong?", "name": "Father"}, "figure_art": "avg_npc_1940_1#2$1"}, {"id": 72, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$2", "focus": "m"}}, {"id": 73, "prop": "name", "attributes": {"content": "I think—I've had a little too much to eat...", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 74, "prop": "Dialog", "attributes": {}}, {"id": 75, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 76, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 77, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 78, "prop": "charslot", "attributes": {}}, {"id": 79, "prop": "Background", "attributes": {"image": "31_g3_mini12_farmland", "screenadapt": "coverall", "block": "true"}}, {"id": 80, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 81, "prop": "PlayMusic", "attributes": {"key": "$saferoom_loop", "volume": 0.6}}, {"id": 82, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 83, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 84, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#7$1", "focus": "m"}}, {"id": 85, "prop": "name", "attributes": {"content": "Are you feeling better now...?", "name": "Mother"}, "figure_art": "avg_npc_1941_1#7$1"}, {"id": 86, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1940_1#3$1", "focus": "m"}}, {"id": 87, "prop": "name", "attributes": {"content": "Sorry, I think I overdid it a little...", "name": "Father"}, "figure_art": "avg_npc_1940_1#3$1"}, {"id": 88, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#3$1", "focus": "m"}}, {"id": 89, "prop": "name", "attributes": {"content": "Honestly, your father never changes...", "name": "Mother"}, "figure_art": "avg_npc_1941_1#3$1"}, {"id": 90, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#1$1", "focus": "m"}}, {"id": 91, "prop": "name", "attributes": {"content": "But that's his style, I suppose. Honestly, most times it's quite adorable of him.", "name": "Mother"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 92, "prop": "name", "attributes": {"content": "You'll forgive him, won't you?", "name": "Mother"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 93, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#10$2", "focus": "m"}}, {"id": 94, "prop": "name", "attributes": {"content": "I...", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 95, "prop": "dialog", "attributes": {}}, {"id": 96, "prop": "charslot", "attributes": {}}, {"id": 97, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 98, "prop": "Subtitle", "attributes": {"text": "Can I truly forgive him?", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 99, "prop": "Subtitle", "attributes": {"text": "When the man who shares his face has broken my heart countless times?", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 100, "prop": "subtitle", "attributes": {}}, {"id": 101, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 102, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 103, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#5$1", "focus": "m"}}, {"id": 104, "prop": "name", "attributes": {"content": "He really loves you, you know.", "name": "Mother"}, "figure_art": "avg_npc_1941_1#5$1"}, {"id": 105, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#6$2", "focus": "m"}}, {"id": 106, "prop": "name", "attributes": {"content": "—!", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#6$2"}, {"id": 107, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#6$1", "focus": "m"}}, {"id": 108, "prop": "name", "attributes": {"content": "And so do I.", "name": "Mother"}, "figure_art": "avg_npc_1941_1#6$1"}, {"id": 109, "prop": "name", "attributes": {"content": "I really love the both of you.", "name": "Mother"}, "figure_art": "avg_npc_1941_1#6$1"}, {"id": 110, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#6$2", "focus": "m"}}, {"id": 111, "prop": "name", "attributes": {"content": "Mother, where is this coming from...?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#6$2"}, {"id": 112, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#1$1", "focus": "m"}}, {"id": 113, "prop": "name", "attributes": {"content": "I've been going through our photo albums more and more while you were away.", "name": "Mother"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 114, "prop": "name", "attributes": {"content": "I started from when you were born... then when you were one, then two, then three...", "name": "Mother"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 115, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#6$2", "focus": "m"}}, {"id": 116, "prop": "name", "attributes": {"content": "My childhood memory nearly failed me…", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#6$2"}, {"id": 117, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#1$1", "focus": "m"}}, {"id": 118, "prop": "name", "attributes": {"content": "Maybe. But there's nothing more important, nothing more special to a parent than their child.", "name": "Mother"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 119, "prop": "name", "attributes": {"content": "When you were born, your palm wasn't even half as big as mine.", "name": "Mother"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 120, "prop": "name", "attributes": {"content": "But look at you now. Yours is even a little bigger.", "name": "Mother"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 121, "prop": "dialog", "attributes": {}}, {"id": 122, "prop": "charslot", "attributes": {}}, {"id": 123, "prop": "name", "attributes": {"content": "Sakiko's mother takes her hand and brings their palms together."}}, {"id": 124, "prop": "name", "attributes": {"content": "For some reason beyond herself, Sakiko grasps her mother's hand and locks fingers with hers."}}, {"id": 125, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#13$2", "focus": "m"}}, {"id": 126, "prop": "name", "attributes": {"content": "Mother, your hand is so warm...", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#13$2"}, {"id": 127, "prop": "dialog", "attributes": {}}, {"id": 128, "prop": "charslot", "attributes": {}}, {"id": 129, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 130, "prop": "Subtitle", "attributes": {"text": "Was this how warm her palm is?", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 131, "prop": "Subtitle", "attributes": {"text": "Is this all real? Is everything I'm enjoying right now rational, reasonable?", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 132, "prop": "Subtitle", "attributes": {"text": "How can it be this warm, and yet this heartrending?", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 133, "prop": "subtitle", "attributes": {}}, {"id": 134, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 135, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 136, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#6$1", "focus": "m"}}, {"id": 137, "prop": "name", "attributes": {"content": "That's right. I'm right here.", "name": "Mother"}, "figure_art": "avg_npc_1941_1#6$1"}, {"id": 138, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#8$2", "focus": "m"}}, {"id": 139, "prop": "name", "attributes": {"content": "Mother...", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#8$2"}, {"id": 140, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#5$1", "focus": "m"}}, {"id": 141, "prop": "name", "attributes": {"content": "Go on. You can cry all you want. I always comforted you like this when you cried.", "name": "Mother"}, "figure_art": "avg_npc_1941_1#5$1"}, {"id": 142, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#8$2", "focus": "m"}}, {"id": 143, "prop": "name", "attributes": {"content": "Huh? Was I... really such a crybaby?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#8$2"}, {"id": 144, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#5$1", "focus": "m"}}, {"id": 145, "prop": "name", "attributes": {"content": "When you were very, veeery little. Oh, you would make the biggest fuss over a single sweet.", "name": "Mother"}, "figure_art": "avg_npc_1941_1#5$1"}, {"id": 146, "prop": "name", "attributes": {"content": "You may be a strong young woman now, but you were a big crybaby back then.", "name": "Mother"}, "figure_art": "avg_npc_1941_1#5$1"}, {"id": 147, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#10$2", "focus": "m"}}, {"id": 148, "prop": "name", "attributes": {"content": "R-Really? I don't remember at all...", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 149, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#6$1", "focus": "m"}}, {"id": 150, "prop": "name", "attributes": {"content": "*giggle* Your mother would never lie to you.", "name": "Mother"}, "figure_art": "avg_npc_1941_1#6$1"}, {"id": 151, "prop": "dialog", "attributes": {}}, {"id": 152, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#10$2", "focus": "m"}}, {"id": 153, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 154, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#1$2", "focus": "m"}}, {"id": 155, "prop": "name", "attributes": {"content": "Then... Do you remember my high school entrance ceremony?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#1$2"}, {"id": 156, "prop": "dialog", "attributes": {}}, {"id": 157, "prop": "charslot", "attributes": {}}, {"id": 158, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 159, "prop": "Subtitle", "attributes": {"text": "During my last year of middle school, my mother died of illness.", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 160, "prop": "Subtitle", "attributes": {"text": "Even if they're nonexistent memories, even if they're things that never happened", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 161, "prop": "Subtitle", "attributes": {"text": "But right now, all I want is the most beautiful answers I can get.", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 162, "prop": "Subtitle", "attributes": {"text": "I want to convince myself, to create the most wonderful memories, to believe in the sweetest dream I can.", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 163, "prop": "subtitle", "attributes": {}}, {"id": 164, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 165, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 166, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#6$1", "focus": "m"}}, {"id": 167, "prop": "name", "attributes": {"content": "Of course. I remember you in your school uniform. Our whole family took a photo together at the school gate.", "name": "Mother"}, "figure_art": "avg_npc_1941_1#6$1"}, {"id": 168, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#13$2", "focus": "m"}}, {"id": 169, "prop": "name", "attributes": {"content": "Yes, that sounds right... Oh, that does bring me back.", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#13$2"}, {"id": 170, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#1$2", "focus": "m"}}, {"id": 171, "prop": "name", "attributes": {"content": "What else have we done together? Mother... I want you to tell me. Tell me about all the memories we share.", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#1$2"}, {"id": 172, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#5$1", "focus": "m"}}, {"id": 173, "prop": "name", "attributes": {"content": "Sakiko, just how long have you been away from home? Aren't you the clingy one today?", "name": "Mother"}, "figure_art": "avg_npc_1941_1#5$1"}, {"id": 174, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#2$2", "focus": "m"}}, {"id": 175, "prop": "name", "attributes": {"content": "Home...", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#2$2"}, {"id": 176, "prop": "dialog", "attributes": {}}, {"id": 177, "prop": "charslot", "attributes": {}}, {"id": 178, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 179, "prop": "Subtitle", "attributes": {"text": "When did the word 'home' start sounding so foreign to me?", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 180, "prop": "subtitle", "attributes": {}}, {"id": 181, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 182, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 183, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#1$1", "focus": "m"}}, {"id": 184, "prop": "name", "attributes": {"content": "Hmm... Well, if you want, I'll reminisce a little more.", "name": "Mother"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 185, "prop": "name", "attributes": {"content": "Now where should I begin?", "name": "Mother"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 186, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#1$2", "focus": "m"}}, {"id": 187, "prop": "name", "attributes": {"content": "Let's start from when I was born. I want to hear it all.", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#1$2"}, {"id": 188, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1941_1#1$1", "focus": "m"}}, {"id": 189, "prop": "name", "attributes": {"content": "Okay, then we'll start from the day you were born...", "name": "Mother"}, "figure_art": "avg_npc_1941_1#1$1"}, {"id": 190, "prop": "dialog", "attributes": {}}, {"id": 191, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 192, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 193, "prop": "name", "attributes": {"content": "And so, down the country path, at a leisurely pace, Sakiko and her mother walk side-by-side, and it feels as if they could walk forever."}}, {"id": 194, "prop": "name", "attributes": {"content": "Just like that sweet, beautiful stretch of time they shared back when it all began. Unhurried and without end."}}, {"id": 195, "prop": "name", "attributes": {"content": "Their hands, the umbilical cord that connected them in the very beginning."}}, {"id": 196, "prop": "dialog", "attributes": {}}, {"id": 197, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 198, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 199, "prop": "name", "attributes": {"content": "Sakiko—", "name": "???"}}, {"id": 200, "prop": "dialog", "attributes": {}}, {"id": 201, "prop": "CameraShake", "attributes": {"xstrength": 5.0, "ystrength": 5.0, "vibrato": 20.0, "randomness": 90.0, "fadeout": "false", "block": "false"}}, {"id": 202, "prop": "PlaySound", "attributes": {"key": "$d_avg_enginerun", "volume": 0.0, "loop": "true", "channel": "bse"}}, {"id": 203, "prop": "SoundVolume", "attributes": {"channel": "bse", "volume": 0.3, "fadetime": 2.5}}, {"id": 204, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 205, "prop": "name", "attributes": {"content": "You found your way home!", "name": "Vigna"}}, {"id": 206, "prop": "name", "attributes": {"content": "Miss Vigna, this carriage seems to be out of order. Now let me down!", "name": "Iris"}}, {"id": 207, "prop": "name", "attributes": {"content": "Let's see... W—Wait, these controls aren't like what I learned at Rhodes Island!", "name": "Vigna"}}, {"id": 208, "prop": "name", "attributes": {"content": "Oh, crap, crap, crap, we can't stop!", "name": "Vigna"}}, {"id": 209, "prop": "name", "attributes": {"content": "We're going to crash!", "name": "Iris"}}, {"id": 210, "prop": "name", "attributes": {"content": "Sakiko, out of the way—!", "name": "Bena"}}, {"id": 211, "prop": "Dialog", "attributes": {}}, {"id": 212, "prop": "StopSound", "attributes": {"channel": "bse", "fadetime": 2.0}}, {"id": 213, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 214, "prop": "CameraShake", "attributes": {"duration": 0.1, "xstrength": 5.0, "ystrength": 5.0, "vibrato": 20.0, "randomness": 90.0, "fadeout": "false", "block": "true"}}, {"id": 215, "prop": "image", "attributes": {}}, {"id": 216, "prop": "charslot", "attributes": {}}, {"id": 217, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}