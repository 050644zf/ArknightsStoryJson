s": "m"}}, {"id": 91, "prop": "name", "attributes": {"content": "\tOh, and then when the dream shattered and you were trapped in dreamless Limbo... how did <i>that</i> feel?", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 92, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$1", "focus": "m"}}, {"id": 93, "prop": "name", "attributes": {"content": "No matter how sweet those dreams were, they have to come to an end.", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#9$1"}, {"id": 94, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$1", "focus": "m"}}, {"id": 95, "prop": "name", "attributes": {"content": "You pry into their most fragile parts and dramatize them over and over...", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#9$1"}, {"id": 96, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#1$1", "focus": "m"}}, {"id": 97, "prop": "name", "attributes": {"content": "\tMust say, I don't agree.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#1$1"}, {"id": 98, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#1$1", "focus": "m"}}, {"id": 99, "prop": "name", "attributes": {"content": "\tBefore you barged into their dreams uninvited, they'd all but forgotten about you and your insignificant little band.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#1$1"}, {"id": 100, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$1", "focus": "m"}}, {"id": 101, "prop": "name", "attributes": {"content": "Ave{@nbs}Mujica is our contract. They entrusted their lives to me—", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#9$1"}, {"id": 102, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#13$1", "focus": "m"}}, {"id": 103, "prop": "name", "attributes": {"content": "\tYou were the only one who ever cared about it!", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#13$1"}, {"id": 104, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#4$1", "focus": "m"}}, {"id": 105, "prop": "name", "attributes": {"content": "What do you—?!", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#4$1"}, {"id": 106, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "focus": "m"}}, {"id": 107, "prop": "name", "attributes": {"content": "Heard it for yourself, didn't you?", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 108, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#15$1", "focus": "m"}}, {"id": 109, "prop": "name", "attributes": {"content": "One after another, they all rejected you.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#15$1"}, {"id": 110, "prop": "Dialog", "attributes": {}}, {"id": 111, "prop": "PlaySound", "attributes": {"key": "$d_avg_spiritwhoosh", "volume": 0.6}}, {"id": 112, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 113, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 114, "prop": "charslot", "attributes": {}}, {"id": 115, "prop": "Background", "attributes": {"image": "bg_lmstreet_1", "screenadapt": "coverall"}}, {"id": 116, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 117, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 118, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 119, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#2$3", "focus": "m"}}, {"id": 120, "prop": "name", "attributes": {"content": "Not a chance. Everyone here loves me for the actress I am.", "name": "Nyamu Yūtenji"}, "figure_art": "avg_4185_amoris_1#2$3"}, {"id": 121, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#7$3", "focus": "m"}}, {"id": 122, "prop": "name", "attributes": {"content": 