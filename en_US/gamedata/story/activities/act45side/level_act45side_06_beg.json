adetime": 1.0, "block": "true"}}, {"id": 34, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 35, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#12$2", "focus": "m"}}, {"id": 36, "prop": "name", "attributes": {"content": "You kept hopping from group to group, yet you never found a place to truly belong... Is this really the life you want?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#12$2"}, {"id": 37, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#12$2", "focus": "m"}}, {"id": 38, "prop": "name", "attributes": {"content": "You should never have had to bear this pain...", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#12$2"}, {"id": 39, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#12$2", "focus": "m"}}, {"id": 40, "prop": "name", "attributes": {"content": "Umiri, let's get out of here. Together.", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#12$2"}, {"id": 41, "prop": "Dialog", "attributes": {}}, {"id": 42, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 43, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 44, "prop": "charslot", "attributes": {}}, {"id": 45, "prop": "Background", "attributes": {"image": "65_g4_islandharbor_n", "screenadapt": "coverall"}}, {"id": 46, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 47, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 48, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 49, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#2$2", "focus": "m"}}, {"id": 50, "prop": "name", "attributes": {"content": "I will find you. I have to...", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#2$2"}, {"id": 51, "prop": "charslot", "attributes": {"slot": "m", 