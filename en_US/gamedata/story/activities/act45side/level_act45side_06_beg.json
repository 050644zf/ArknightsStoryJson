hata"}, "figure_art": "avg_4186_tmoris_1#9$3"}, {"id": 140, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#3$3", "focus": "m"}}, {"id": 141, "prop": "name", "attributes": {"content": "I don't need someone to save me.", "name": "Umiri Yahata"}, "figure_art": "avg_4186_tmoris_1#3$3"}, {"id": 142, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#3$3", "focus": "m"}}, {"id": 143, "prop": "name", "attributes": {"content": "And no one could save me.", "name": "Umiri Yahata"}, "figure_art": "avg_4186_tmoris_1#3$3"}, {"id": 144, "prop": "Dialog", "attributes": {}}, {"id": 145, "prop": "PlaySound", "attributes": {"key": "$d_avg_spiritwhoosh", "volume": 0.6}}, {"id": 146, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 147, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 148, "prop": "charslot", "attributes": {}}, {"id": 149, "prop": "Background", "attributes": {"image": "65_g4_islandharbor_n", "screenadapt": "coverall"}}, {"id": 150, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 151, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 152, "prop": "PlaySound", "attributes": {"key": "$d_avg_sea", "volume": 0.6, "loop": "true", "channel": "sea"}}, {"id": 153, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 154, "prop": "name", "attributes": {"content": "......"}}, {"id": 155, "prop": "Dialog", "attributes": {}}, {"id": 156, "prop": "stopSound", "attributes": {"key": "$d_avg_sea", "fadetime": 0.5, "channel": "sea"}}, {"id": 157, "prop": "PlaySound", "attributes": {"key": "$d_avg_spiritwhoosh", "volume": 0.6}}, {"id": 158, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 159, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 160, "prop": "charslot", "attributes": {}}, {"id": 161, "prop": "Background", "attributes": {"image": "bg_wilderness_n", "screenadapt": "coverall"}}, {"id": 162, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 163, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 164, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 165, "prop": "name", "attributes": {"content": "\tI knew it. Mutsumi-chan didn't need Sakiko.", "name": "'Mutsumi'"}}, {"id": 166, "prop": "Dialog", "attributes": {}}, {"id": 167, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 168, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 169, "prop": "charslot", "attributes": {}}, {"id": 170, "prop": "Background", "attributes": {"image": "65_g2_dreamcastlehall", "screenadapt": "coverall", "block": "true"}}, {"id": 171, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 172, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 173, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 174, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#19$1", "focus": "m"}}, {"id": 175, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 176, "prop": "name", "attributes": {"content": "Hahahah-hah... Hah-hahahahah!!!", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#19$1"}, {"id": 177, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#19$1", "focus": "m"}}, {"id": 178, "prop": "name", "attributes": {"content": "\tI got to see every one of your sorriest, most helpless, most laughable moments.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#19$1"}, {"id": 179, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "focus": "m"}}, {"id": 180, "prop": "name", "attributes": {"content": "You may have destroyed the dreams I spun, but I suppose this makes us even.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 181, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "focus": "m"}}, {"id": 182, "prop": "name", "attributes": {"content": "\tAnd I have to thank you. You roamed their dreams again and again...", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 183, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#1$1", "focus": "m"}}, {"id": 184, "prop": "name", "attributes": {"content": "\tIn the process, proving to me that the dreamlands I wove were perfect, impeccable.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#1$1"}, {"id": 185, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#1$1", "focus": "m"}}, {"id": 186, "prop": "name", "attributes": {"content": "\tAnd now, even that pest ought to admit it. It's me. I'm the most talented of us all in the Castle of Dreams.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#1$1"}, {"id": 187, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$1", "focus": "m"}}, {"id": 188, "prop": "name", "attributes": {"content": "'Pest'?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#9$1"}, {"id": 189, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#5$1", "focus": "m"}}, {"id": 190, "prop": "name", "attributes": {"content": "\tDidn't you meet her in your dream?", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#5$1"}, {"id": 191, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#17$1", "focus": "m"}}, {"id": 192, "prop": "name", "attributes": {"content": "\tThe snooty girl? Flowery high-nobility frock? All the outdated pleasantries?", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#17$1"}, {"id": 193, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#17$1", "focus": "m"}}, {"id": 194, "prop": "name", "attributes": {"content": "\tJust being around her puts me ill at ease.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#17$1"}, {"id": 195, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#4$1", "focus": "m"}}, {"id": 196, "prop": "name", "attributes": {"content": "Iris is this place's master. You are nothing but a fraud!", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#4$1"}, {"id": 197, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#4$1", "focus": "m"}}, {"id": 198, "prop": "name", "attributes": {"content": "She said it! No matter how sweet the dream, one has to wake up in the end—", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#4$1"}, {"id": 199, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$1", "focus": "m"}}, {"id": 200, "prop": "name", "attributes": {"content": "Nngh—!", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$1"}, {"id": 201, "prop": "name", "attributes": {"content": "Sakiko feels her vocal cords freeze in place. She cannot make even the slightest peep."}}, {"id": 202, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#15$1", "focus": "m"}}, {"id": 203, "prop": "name", "attributes": {"content": "\tYou know what? I finally understand why you get on my nerves so much.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#15$1"}, {"id": 204, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#9$1", "focus": "m"}}, {"id": 205, "prop": "name", "attributes": {"content": "\tYou're just like her. You never listen to what others think. You just sit there spouting big, empty words forever.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#9$1"}, {"id": 206, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#9$1", "focus": "m"}}, {"id": 207, "prop": "name", "attributes": {"content": "\tYou say they entrusted their lives to you, but let's be fair. You just don't want to be abandoned by others. Isn't that right?", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#9$1"}, {"id": 208, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#9$1", "focus": "m"}}, {"id": 209, "prop": "name", "attributes": {"content": "\tI've seen your life. There's not much to it. Just a princess's stubborn struggle after her fall from grace.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#9$1"}, {"id": 210, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#10$1", "focus": "m"}}, {"id": 211, "prop": "name", "attributes": {"content": "\tEach and every action of yours was done to deceive and persuade yourself, and to present yourself as never having fallen.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#10$1"}, {"id": 212, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#10$1", "focus": "m"}}, {"id": 213, "prop": "name", "attributes": {"content": "\tYou're self-important, conceited, and an utter lost cause.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#10$1"}, {"id": 214, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#16$1", "focus": "m"}}, {"id": 215, "prop": "name", "attributes": {"content": "\tWhat exactly does your band entail? Hmph. Just a bunch of girls using a so-called contract to bind one another for fun.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#16$1"}, {"id": 216, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#1$1", "focus": "m"}}, {"id": 217, "prop": "name", "attributes": {"content": "\tAnd now that they've all found happiness, of course they're abandoning you. Poor Sakiko Togawa. All alone once more.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#1$1"}, {"id": 218, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#1$1", "focus": "m"}}, {"id": 219, "prop": "name", "attributes": {"content": "\tIf you really believe what Iris said, then fine, I'll prepare another round of the sweetest dreams for you.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#1$1"}, {"id": 220, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#1$1", "focus": "m"}}, {"id": 221, "prop": "name", "attributes": {"content": "\tIt'll be perfect, impeccable. Realize it's a farce all you want, you still won't want to wake up.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#1$1"}, {"id": 222, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#1$1", "focus": "m"}}, {"id": 223, "prop": "name", "attributes": {"content": "\tLike your bandmates, you'll wallow in your dreams, unable to ever pluck yourself out.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#1$1"}, {"id": 224, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$1", "focus": "m"}}, {"id": 225, "prop": "name", "attributes": {"content": "Nngh—!", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$1"}, {"id": 226, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#11$1", "focus": "m"}}, {"id": 227, "prop": "name", "attributes": {"content": "\tSomething to say? Alright, you get one last time. Speak your mind.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#11$1"}, {"id": 228, "prop": "dialog", "attributes": {}}, {"id": 229, "prop": "charslot", "attributes": {}}, {"id": 230, "prop": "name", "attributes": {"content": "The impish girl draws a pattern in the air, and there is a sensation of chains falling away."}}, {"id": 231, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#4$1", "focus": "m"}}, {"id": 232, "prop": "name", "attributes": {"content": "I—", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#4$1"}, {"id": 233, "prop": "dialog", "attributes": {}}, {"id": 234, "prop": "charslot", "attributes": {}}, {"id": 235, "prop": "name", "attributes": {"content": "Then, the chains are pulled tight once again."}}, {"id": 236, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#19$1", "focus": "m"}}, {"id": 237, "prop": "name", "attributes": {"content": "\tHahahah-hah-hah!", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#19$1"}, {"id": 238, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "focus": "m"}}, {"id": 239, "prop": "name", "attributes": {"content": "\tI knew it. You are <i>much</i> cuter when you're not talking!", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 240, "prop": "name", "attributes": {"content": "As Sakiko struggles, Morpheus paces closer, step by step. Out reaches her right hand, and she places it on Sakiko's cheek."}}, {"id": 241, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "focus": "m"}}, {"id": 242, "prop": "name", "attributes": {"content": "\tO ye, Princess of Hypocrisy. While you were on your dream tour, I've come to completely understand you as a person.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 243, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "focus": "m"}}, {"id": 244, "prop": "name", "attributes": {"content": "\tWhat you thirst for the most, what you need the most, and what you fear the most.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 245, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "focus": "m"}}, {"id": 246, "prop": "name", "attributes": {"content": "\tBut don't worry. This dream? Will be absolutely perfect. You'll be more awake than ever. Not that you'll ever want to wake up.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 247, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#17$1", "focus": "m"}}, {"id": 248, "prop": "name", "attributes": {"content": " Now sleep, my noble, selfish, conceited little doll girl.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#17$1"}, {"id": 249, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#17$1", "focus": "m"}}, {"id": 250, "prop": "name", "attributes": {"content": "\tSweet dreams.", "name": "Morpheus"}, "figure_art": "avg_npc_1942_1#17$1"}, {"id": 251, "prop": "Dialog", "attributes": {}}, {"id": 252, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 253, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 254, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 255, "prop": "charslot", "attributes": {}}, {"id": 256, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 257, "prop": "name", "attributes": {"content": "Clank, clunk."}}, {"id": 258, "prop": "name", "attributes": {"content": "Sakiko? Sakiko!", "name": "???"}}, {"id": 259, "prop": "dialog", "attributes": {}}, {"id": 260, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 261, "prop": "name", "attributes": {"content": "Mm... hmm?", "name": "Sakiko Togawa"}}, {"id": 262, "prop": "dialog", "attributes": {}}, {"id": 263, "prop": "Background", "attributes": {"image": "46_g1_transporter", "screenadapt": "coverall", "block": "true"}}, {"id": 264, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 265, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 266, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 267, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#4$2", "focus": "m"}}, {"id": 268, "prop": "name", "attributes": {"content": "I am NOT the kind of person you claim I—", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#4$2"}, {"id": 269, "prop": "charslot", "attributes": {}}, {"id": 270, "prop": "name", "attributes": {"content": "Sakiko bursts out yelling, but she is no longer in the castle, and Morpheus is nowhere to be found."}}, {"id": 271, "prop": "dialog", "attributes": {}}, {"id": 272, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_290_vigna_1#4$1", "focus": "m", "duration": 1.0}}, {"id": 273, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 274, "prop": "PlayMusic", "attributes": {"intro": "$mist_intro", "key": "$mist_loop", "volume": 0.6}}, {"id": 275, "prop": "name", "attributes": {"content": "\tYou okay? You look terrible. You have another nightmare?", "name": "Vigna"}, "figure_art": "avg_290_vigna_1#4$1"}, {"id": 276, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$2", "focus": "m"}}, {"id": 277, "prop": "name", "attributes": {"content": "I'm... back in my dream again.", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 278, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_290_vigna_1#4$1", "focus": "m"}}, {"id": 279, "prop": "name", "attributes": {"content": "\tWhat are you talking about? Didn't you just wake up?", "name": "Vigna"}, "figure_art": "avg_290_vigna_1#4$1"}, {"id": 280, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_290_vigna_1#4$1", "focus": "m"}}, {"id": 281, "prop": "name", "attributes": {"content": "\tWhat, you sleep so long your brain's fuzzy?", "name": "Vigna"}, "figure_art": "avg_290_vigna_1#4$1"}, {"id": 282, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#6$2", "focus": "m"}}, {"id": 283, "prop": "name", "attributes": {"content": "Iris and Bena are here...", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#6$2"}, {"id": 284, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_338_iris_1#1$1", "focus": "m"}}, {"id": 285, "prop": "name", "attributes": {"content": "Er, how do you do... I don't believe I introduced myself?", "name": "Iris"}, "figure_art": "avg_338_iris_1#1$1"}, {"id": 286, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_369_bena_1#5$1", "focus": "m"}}, {"id": 287, "prop": "name", "attributes": {"content": "I think she was already asleep when we got on?", "name": "Bena"}, "figure_art": "avg_369_bena_1#5$1"}, {"id": 288, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#6$2", "focus": "m"}}, {"id": 289, "prop": "name", "attributes": {"content": "Vigna and I aren't late... The dream has changed...", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#6$2"}, {"id": 290, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_290_vigna_1#11$1", "focus": "m"}}, {"id": 291, "prop": "name", "attributes": {"content": "\tSakiko, you know, you keep saying some pretty weird stuff—", "name": "Vigna"}, "figure_art": "avg_290_vigna_1#11$1"}, {"id": 292, "prop": "dialog", "attributes": {}}, {"id": 293, "prop": "charslot", "attributes": {}}, {"id": 294, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 295, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 296, "prop": "Subtitle", "attributes": {"text": "We are heading to a small town in Victoria to find a girl named Ann who is acquainted with Iris.", "x": 300.0, "y": 350.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 297, "prop": "Subtitle", "attributes": {"text": "This vehicle will have a flat tire soon. We will be forced to get off to fix the tire, delaying us by a few hours...", "x": 300.0, "y": 350.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 298, "prop": "subtitle", "attributes": {}}, {"id": 299, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 300, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 301, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$2", "focus": "m"}}, {"id": 302, "prop": "name", "attributes": {"content": "Are we going to Victoria to find Ann?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 303, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_290_vigna_1#11$1", "focus": "m"}}, {"id": 304, "prop": "name", "attributes": {"content": "\tWho's Ann? Do you know, Iris?", "name": "Vigna"}, "figure_art": "avg_290_vigna_1#11$1"}, {"id": 305, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_338_iris_1#4$1", "focus": "m"}}, {"id": 306, "prop": "name", "attributes": {"content": "I don't. Is that a friend of yours who lives there?", "name": "Iris"}, "figure_art": "avg_338_iris_1#4$1"}, {"id": 307, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$2", "focus": "m"}}, {"id": 308, "prop": "name", "attributes": {"content": "What...? You don't know her, Iris?", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 309, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#10$2", "focus": "m"}}, {"id": 310, "prop": "name", "attributes": {"content": "Then Vigna and I...", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 311, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_290_vigna_1#1$1", "focus": "m"}}, {"id": 312, "prop": "name", "attributes": {"content": "\tUh, hello? We're on a field mission not too far away from your home. I figured I'd bring you back for a break, let you see your family.", "name": "Vigna"}, "figure_art": "avg_290_vigna_1#1$1"}, {"id": 313, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_290_vigna_1#5$1", "focus": "m"}}, {"id": 314, "prop": "name", "attributes": {"content": " You've been mega busy with work. Gotta be a while since the last time you went home, right?", "name": "Vigna"}, "figure_art": "avg_290_vigna_1#5$1"}, {"id": 315, "prop": "dialog", "attributes": {}}, {"id": 316, "prop": "charslot", "attributes": {}}, {"id": 317, "prop": "PlaySound", "attributes": {"key": "$drift", "volume": 0.6}}, {"id": 318, "prop": "CameraShake", "attributes": {"duration": 2.0, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 319, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 320, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_338_iris_1#4$1", "focus": "m"}}, {"id": 321, "prop": "name", "attributes": {"content": "What's going on? Why did the car suddenly stop?!", "name": "Iris"}, "figure_art": "avg_338_iris_1#4$1"}, {"id": 322, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_369_bena_1#5$1", "focus": "m"}}, {"id": 323, "prop": "name", "attributes": {"content": "Did a tire burst?!", "name": "Bena"}, "figure_art": "avg_369_bena_1#5$1"}, {"id": 324, "prop": "charslot", "attributes": {}}, {"id": 325, "prop": "name", "attributes": {"content": "*huff*... *huff*... *pant*... Phew, we almost hit a burdenbeast!", "name": "Driver"}, "figure_art": "avg_369_bena_1#5$1"}, {"id": 326, "prop": "name", "attributes": {"content": "That was close, but no worries. We can be back on the road right away!", "name": "Driver"}, "figure_art": "avg_369_bena_1#5$1"}, {"id": 327, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#10$2", "focus": "m"}}, {"id": 328, "prop": "name", "attributes": {"content": "......", "name": "Sakiko Togawa"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 329, "prop": "charslot", "attributes": {}}, {"id": 330, "prop": "name", "attributes": {"content": "As the engine starts humming again, the view outside the window begins to move once more."}}, {"id": 331, "prop": "Dialog", "attributes": {}}, {"id": 332, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 333, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 334, "prop": "charslot", "attributes": {}}, {"id": 335, "prop": "Background"