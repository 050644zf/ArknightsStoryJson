{"lang": "en_US", "eventid": "main_16", "eventName": "Abnormal Spectrum", "entryType": "MAINLINE", "storyCode": "EG-10", "avgTag": "Interlude", "storyName": "No Way Forward", "storyInfo": "The charity of the virtuous shall reach every corner of this great land.\n", "storyList": [{"id": 0, "prop": "HEADER", "attributes": {"key": "title_test", "is_skippable": "true", "fit_mode": "BLACK_MASK"}}, {"id": 1, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 2, "prop": "stopmusic", "attributes": {}}, {"id": 3, "prop": "Dialog", "attributes": {}}, {"id": 4, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 5, "prop": "Background", "attributes": {"image": "66_g8_farnorthtundra_aurora", "screenadapt": "coverall"}}, {"id": 6, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 7, "prop": "playMusic", "attributes": {"key": "$monastery_sad_loop", "volume": 0.6}}, {"id": 8, "prop": "Subtitle", "attributes": {"text": "*huff*... *huff*...", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 9, "prop": "Subtitle", "attributes": {"text": "It hurts... the rocks are piercing the flesh... I can almost hear them growing. Why am I still alive?", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 10, "prop": "Subtitle", "attributes": {"text": "I'm exhausted. I can't feel my limbs... Run! Run to the east!", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 11, "prop": "Subtitle", "attributes": {"text": "Death awaits in the south. Death awaits in the north. In the west... the mines there are a dead end, just like those in the Far North.", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 12, "prop": "Subtitle", "attributes": {"text": "I can run from the Far North... but how do I run from pain?", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 13, "prop": "subtitle", "attributes": {}}, {"id": 14, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 15, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 16, "prop": "dialog", "attributes": {}}, {"id": 17, "prop": "animtext", "attributes": {"content": "<p=1>Far North Border, Ursus</>", "id": "at1", "name": "group_location_stamp", "style": "avg_only_heavy", "pos": "-400,-200", "block": "false", "p": 1.0}}, {"id": 18, "prop": "delay", "attributes": {"time": 3.0}}, {"id": 19, "prop": "animtextclean", "attributes": {}}, {"id": 20, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 21, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1969_1#1$1", "duration": 1.0}}, {"id": 22, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 23, "prop": "name", "attributes": {"content": "Urgh...", "name": "Infected Miner"}, "figure_art": "avg_npc_1969_1#1$1"}, {"id": 24, "prop": "name", "attributes": {"content": "I can't... run... anymore...", "name": "Infected Miner"}, "figure_art": "avg_npc_1969_1#1$1"}, {"id": 25, "prop": "name", "attributes": {"content": "This is it...", "name": "Infected Miner"}, "figure_art": "avg_npc_1969_1#1$1"}, {"id": 26, "prop": "dialog", "attributes": {}}, {"id": 27, "prop": "playsound", "attributes": {"key": "$d_avg_snowbodyfall"}}, {"id": 28, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,0", "posto": "0,-60", "duration": 0.7, "afrom": 1.0, "ato": 0.0}}, {"id": 29, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 30, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 2.0, "ystrength": 10.0, "vibrato": 10.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 31, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 32, "prop": "name", "attributes": {"content": "......", "name": "Infected Miner"}}, {"id": 33, "prop": "dialog", "attributes": {}}, {"id": 34, "prop": "charslot", "attributes": {}}, {"id": 35, "prop": "playsound", "attributes": {"key": "$d_avg_snowbootwalk", "volume": 0.5}}, {"id": 36, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 37, "prop": "name", "attributes": {"content": "Is someone there?", "name": "Distant Voice"}}, {"id": 38, "prop": "name", "attributes": {"content": "I'll take a look—", "name": "Distant Voice"}}, {"id": 39, "prop": "name", "attributes": {"content": "No, please let me...", "name": "Distant Voice"}}, {"id": 40, "prop": "name", "attributes": {"content": "I can sense that it's only a poor soul who has suffered much.", "name": "Distant Voice"}}, {"id": 41, "prop": "dialog", "attributes": {}}, {"id": 42, "prop": "playsound", "attributes": {"key": "$d_avg_snowbootwalk"}}, {"id": 43, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1719_1#2$1", "duration": 1.0}}, {"id": 44, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 45, "prop": "name", "attributes": {"content": "Exhausted, dehydrated, starved...", "name": "???"}, "figure_art": "avg_npc_1719_1#2$1"}, {"id": 46, "prop": "name", "attributes": {"content": "You're Infected too.", "name": "???"}, "figure_art": "avg_npc_1719_1#2$1"}, {"id": 47, "prop": "charslot", "attributes": {}}, {"id": 48, "prop": "name", "attributes": {"content": "*cough* *cough*!", "name": "Infected Miner"}, "figure_art": "avg_npc_1719_1#2$1"}, {"id": 49, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 50, "prop": "name", "attributes": {"content": "He's one of us, comrades!", "name": "Anxious Voice"}}, {"id": 51, "prop": "name", "attributes": {"content": "Please, save him, just as you saved all of us—", "name": "Anxious Voice"}}, {"id": 52, "prop": "name", "attributes": {"content": "Perform your miracle!", "name": "Anxious Voice"}}, {"id": 53, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1719_1#2$1"}}, {"id": 54, "prop": "name", "attributes": {"content": "It's not a miracle...", "name": "???"}, "figure_art": "avg_npc_1719_1#2$1"}, {"id": 55, "prop": "name", "attributes": {"content": "Oripathy is not the main reason for his pain. I can only stop his illness from tormenting him, but I cannot give him food, clean water, or a safe place to sleep.", "name": "???"}, "figure_art": "avg_npc_1719_1#2$1"}, {"id": 56, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1719_1#4$1"}}, {"id": 57, "prop": "name", "attributes": {"content": "I can't perform miracles. I'm not all-powerful. I simply... believe.", "name": "???"}, "figure_art": "avg_npc_1719_1#4$1"}, {"id": 58, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 59, "prop": "name", "attributes": {"content": "You're always so humble. We understand.", "name": "Pious Voice"}}, {"id": 60, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1719_1#2$1"}}, {"id": 61, "prop": "name", "attributes": {"content": "...Can you hear me, sir?", "name": "???"}, "figure_art": "avg_npc_1719_1#2$1"}, {"id": 62, "prop": "name", "attributes": {"content": "I'll hold your hand...", "name": "???"}, "figure_art": "avg_npc_1719_1#2$1"}, {"id": 63, "prop": "dialog", "attributes": {}}, {"id": 64, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1719_1#3$1"}}, {"id": 65, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 66, "prop": "name", "attributes": {"content": "'Believe. Believe in our life.'", "name": "???"}, "figure_art": "avg_npc_1719_1#3$1"}, {"id": 67, "prop": "name", "attributes": {"content": "'Believe in our body and mind, believe every beat of our heart, believe every inhale and exhale.'", "name": "???"}, "figure_art": "avg_npc_1719_1#3$1"}, {"id": 68, "prop": "name", "attributes": {"content": "'Believe that we are the source of all strength.'", "name": "???"}, "figure_art": "avg_npc_1719_1#3$1"}, {"id": 69, "prop": "name", "attributes": {"content": "No longer will you live in fear of death.", "name": "???"}, "figure_art": "avg_npc_1719_1#3$1"}, {"id": 70, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 71, "prop": "name", "attributes": {"content": "The pain brought about by the rapid growth of Originium in his body begins to fade."}}, {"id": 72, "prop": "name", "attributes": {"content": "He can still hear the voices, but he is no longer writhing in pain."}}, {"id": 73, "prop": "name", "attributes": {"content": "Wh-Who are you?", "name": "Infected Miner"}, "figure_art": "avg_npc_1719_1#3$1"}, {"id": 74, "prop": "name", "attributes": {"content": "You saved me...", "name": "Infected Miner"}, "figure_art": "avg_npc_1719_1#3$1"}, {"id": 75, "prop": "name", "attributes": {"content": "*cough* *cough*—", "name": "Infected Miner"}, "figure_art": "avg_npc_1719_1#3$1"}, {"id": 76, "prop": "name", "attributes": {"content": "What can I do to repay you?", "name": "Infected Miner"}, "figure_art": "avg_npc_1719_1#3$1"}, {"id": 77, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1719_1#2$1"}}, {"id": 78, "prop": "name", "attributes": {"content": "You can call me Hierda, like everyone else here.", "name": "???"}, "figure_art": "avg_npc_1719_1#2$1"}, {"id": 79, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 80, "prop": "name", "attributes": {"content": "A miracle—", "name": "Anxious Voice"}}, {"id": 81, "prop": "name", "attributes": {"content": "Hierda has once again saved our comrade!", "name": "Anxious Voice"}}, {"id": 82, "prop": "name", "attributes": {"content": "She saved all of us! With her motherly caress, she takes away our pain!", "name": "Anxious Voice"}}, {"id": 83, "prop": "name", "attributes": {"content": "Hierda!", "name": "Anxious Voice"}}, {"id": 84, "prop": "name", "attributes": {"content": "Hierda.", "name": "Pious Voice"}}, {"id": 85, "prop": "name", "attributes": {"content": "Hierda!", "name": "Many Voices"}}, {"id": 86, "prop": "charslot", "attributes": {}}, {"id": 87, "prop": "name", "attributes": {"content": "Hierda... Hierda.", "name": "Infected Miner"}, "figure_art": "avg_npc_1719_1#2$1"}, {"id": 88, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1719_1#2$1"}}, {"id": 89, "prop": "name", "attributes": {"content": "Yes, that is my name.", "name": "Hierda"}, "figure_art": "avg_npc_1719_1#2$1"}, {"id": 90, "prop": "charslot", "attributes": {}}, {"id": 91, "prop": "name", "attributes": {"content": "What do you look like? I can't see you clearly, or any of the others...", "name": "Infected Miner"}, "figure_art": "avg_npc_1719_1#2$1"}, {"id": 92, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1719_1#1$1"}}, {"id": 93, "prop": "name", "attributes": {"content": "Your head is wounded. Did you fall and hurt yourself?", "name": "Hierda"}, "figure_art": "avg_npc_1719_1#1$1"}, {"id": 94, "prop": "name", "attributes": {"content": "Maybe a mild brain hemorrhage is affecting your vision. Don't worry, we can help you walk...", "name": "Hierda"}, "figure_art": "avg_npc_1719_1#1$1"}, {"id": 95, "prop": "name", "attributes": {"content": "Where are you going?", "name": "Hierda"}, "figure_art": "avg_npc_1719_1#1$1"}, {"id": 96, "prop": "charslot", "attributes": {}}, {"id": 97, "prop": "name", "attributes": {"content": "I don't know...", "name": "Infected Miner"}, "figure_art": "avg_npc_1719_1#1$1"}, {"id": 98, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1719_1#2$1"}}, {"id": 99, "prop": "name", "attributes": {"content": "Then come with us, for now.", "name": "Hierda"}, "figure_art": "avg_npc_1719_1#2$1"}, {"id": 100, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 101, "prop": "name", "attributes": {"content": "You're taking us to a place without pain, right?", "name": "Pious Voice"}}, {"id": 102, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1719_1#2$1"}}, {"id": 103, "prop": "name", "attributes": {"content": "Yes, as long as you're willing to come with me...", "name": "Hierda"}, "figure_art": "avg_npc_1719_1#2$1"}, {"id": 104, "prop": "Dialog", "attributes": {}}, {"id": 105, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 106, "prop": "charslot", "attributes": {}}, {"id": 107, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 108, "prop": "Background", "attributes": {"image": "60_g9_seasurface_ex", "screenadapt": "coverall"}}, {"id": 109, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 110, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 111, "prop": "name", "attributes": {"content": "As long as we believe.", "name": "Hierda"}}, {"id": 112, "prop": "Dialog", "attributes": {}}, {"id": 113, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 114, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 115, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 116, "prop": "hidecgitem", "attributes": {}}, {"id": 117, "prop": "Image", "attributes": {}}, {"id": 118, "prop": "charslot", "attributes": {}}, {"id": 119, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}