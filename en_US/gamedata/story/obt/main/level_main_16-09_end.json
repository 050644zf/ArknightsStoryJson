 0.4, "channel": "a", "fadetime": 0.5}}, {"id": 193, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 194, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 195, "prop": "name", "attributes": {"content": "No, no... I won! I killed him!", "name": "Rankin"}, "figure_art": "avg_npc_1963_1#7$1"}, {"id": 196, "prop": "name", "attributes": {"content": "I can save everyone...!", "name": "Rankin"}, "figure_art": "avg_npc_1963_1#7$1"}, {"id": 197, "prop": "dialog", "attributes": {}}, {"id": 198, "prop": "charslot", "attributes": {}}, {"id": 199, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0, "loop": "true", "channel": "r"}}, {"id": 200, "prop": "StopSound", "attributes": {"channel": "r", "fadetime": 1.0}}, {"id": 201, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4207_branch_1#6$1", "posfrom": "-200,0", "posto": "0,0", "duration": 0.5, "isblock": "true"}}, {"id": 202, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 203, "prop": "name", "attributes": {"content": "<i>Uchitel!</i>", "name": "Vetochki"}, "figure_art": "avg_4207_branch_1#6$1"}, {"id": 204, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1963_1#6$1"}}, {"id": 205, "prop": "name", "attributes": {"content": "What are you doing here, Vetochki? Get to safety!", "name": "Rankin"}, "figure_art": "avg_npc_1963_1#6$1"}, {"id": 206, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4207_branch_1#10$1"}}, {"id": 207, "prop": "name", "attributes": {"content": "<i>Uchitel</i>, I-I...!", "name": "Vetochki"}, "figure_art": "avg_4207_branch_1#10$1"}, {"id": 208, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1963_1#7$1"}}, {"id": 209, "prop": "name", "attributes": {"content": "Didn't you hear me?!", "name": "Rankin"}, "figure_art": "avg_npc_1963_1#7$1"}, {"id": 210, "prop": "charslot", "attributes": {}}, {"id": 211, "prop": "name", "attributes": {"content": "Rankin tries to shake off Vetochki's hands, but the girl grabs his arm with all her strength."}}, {"id": 212, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4207_branch_1#10$1"}}, {"id": 213, "prop": "name", "attributes": {"content": "B-Babushka, sh-she's gone!", "name": "Vetochki"}, "figure_art": "avg_4207_branch_1#10$1"}, {"id": 214, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1963_1#6$1"}}, {"id": 215, "prop": "name", "attributes": {"content": "What? Wasn't she with you?", "name": "Rankin"}, "figure_art": "avg_npc_1963_1#6$1"}, {"id": 216, "prop": "charslot", "attributes": {}}, {"id": 217, "prop": "name", "attributes": {"content": "The stammering girl gestures furiously, trying to explain what happened, but the terror on her face says it all."}}, {"id": 218, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 219, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1963_1#5$1"}}, {"id": 220, "prop": "name", "attributes": {"content": "Nikto!", "name": "Rankin"}, "figure_art": "avg_npc_1963_1#5$1"}, {"id": 221, "prop": "name", "attributes": {"content": "Continue the evacuation! We'll go find Nadia!", "name": "Rankin"}, "figure_art": "avg_npc_1963_1#5$1"}, {"id": 222, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1967_1#1$1"}}, {"id": 223, "prop": "name", "attributes": {"content": "O-Okay!", "name": "Nikto"}, "figure_art": "avg_npc_1967_1#1$1"}, {"id": 224, "prop": "dialog", "attributes": {}}, {"id": 225, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 226, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "style": "slider", "inverse": "true", "fadetime": 2.0, "block": "true"}}, {"id": 227, "prop": "charslot", "attributes": {}}, {"id": 228, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "style": "slider", "inverse": "true", "fadetime": 2.0, "block": "true"}}, {"id": 229, "prop": "name", "attributes": {"content": "Rankin and Vetochki dart through the fire. The houses on both sides of them are burning, and the slightest misstep could set their clothes on fire."}}, {"id": 230, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4207_branch_1#10$1"}}, {"id": 231, "prop": "name", "attributes": {"content": "Babushka... Babushka!", "name": "Vetochki"}, "figure_art": "avg_4207_branch_1#10$1"}, {"id": 232, "prop": "charslot", "attributes": {}}, {"id": 233, "prop": "name", "attributes": {"content": "Rankin wants to yell too, but the feeling of helplessness continues to accumulate in his heart. It is stuck in his throat, preventing him from making a sound, preventing him from breathing."}}, {"id": 234, "prop": "name", "attributes": {"content": "He knows full well what a fire like this means for an invalid old woman."}}, {"id": 235, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4207_branch_1#10$1"}}, {"id": 236, "prop": "name", "attributes": {"content": "<i>Uchitel</i>, I... you... mm!", "name": "Vetochki"}, "figure_art": "avg_4207_branch_1#10$1"}, {"id": 237, "prop": "charslot", "attributes": {}}, {"id": 238, "prop": "name", "attributes": {"content": "At the smoke-filled intersection, Vetochki covers her mouth and points to herself, then at Rankin, and finally towards the fork in the path."}}, {"id": 239, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1963_1#10$1"}}, {"id": 240, "prop": "name", "attributes": {"content": "No, Vetochki... you must not go off on your own... listen to me...", "name": "Rankin"}, "figure_art": "avg_npc_1963_1#10$1"}, {"id": 241, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4207_branch_1#10$1"}}, {"id": 242, "prop": "name", "attributes": {"content": "<i>Uchitel!</i>", "name": "Vetochki"}, "figure_art": "avg_4207_branch_1#10$1"}, {"id": 243, "prop": "charslot", "attributes": {}}, {"id": 244, "prop": "name", "attributes": {"content": "The girl's face is red as tears flow from her eyes. She holds her hands together in a strange gesture of prayer."}}, {"id": 245, "prop": "name", "attributes": {"content": "She is not praying to the Tsar, nor to the Yurodstvo. She is praying to Rankin."}}, {"id": 246, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1963_1#3$1"}}, {"id": 247, "prop": "name", "attributes": {"content": "I...", "name": "Rankin"}, "figure_art": "avg_npc_1963_1#3$1"}, {"id": 248, "prop": "dialog", "attributes": {}}, {"id": 249, "prop": "SoundVolume", "attributes": {"volume": 0.0, "channel": "a", "fadetime": 0.5}}, {"id": 250, "prop": "PlaySound", "attributes": {"key": "$flashback", "volume": 0.8}}, {"id": 251, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 252, "prop": "Blocker", "attributes": {"a": 1.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.5, "block": "true"}}, {"id": 253, "prop": "charslot", "attributes": {}}, {"id": 254, "prop": "bgeffect", "attributes": {}}, {"id": 255, "prop": "Background", "attributes": {}}, {"id": 256, "prop": "Image", "attributes": {"image": "avg_8_29", "screenadapt": "coverall", "xScale": 1.05, "yScale": 1.05, "fadetime": 0.0}}, {"id": 257, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.05, "yScaleFrom": 1.05, "xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 20.0, "block": "false"}}, {"id": 258, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "amount": 1.0, "keep": "true"}}, {"id": 259, "prop": "Delay", "attributes": {"time": 0.1}}, {"id": 260, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.5, "block": "true"}}, {"id": 261, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 262, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 263, "prop": "Blocker", "attri