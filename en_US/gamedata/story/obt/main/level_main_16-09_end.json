{"lang": "en_US", "eventid": "main_16", "eventName": "Abnormal Spectrum", "entryType": "MAINLINE", "storyCode": "16-9", "avgTag": "After Operation", "storyName": "Defense of the Mad", "storyInfo": "The mad miner believes it is his duty to kill the villagers, just as he had to kill his son when they stole the vehicles. Fire rages across the village, and it is as though Rankin's nightmare has come true.\n", "storyList": [{"id": 0, "prop": "HEADER", "attributes": {"key": "title_test", "is_skippable": "true", "fit_mode": "BLACK_MASK"}}, {"id": 1, "prop": "stopmusic", "attributes": {}}, {"id": 2, "prop": "dialog", "attributes": {}}, {"id": 3, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 4, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 5, "prop": "charslot", "attributes": {}}, {"id": 6, "prop": "PlaySound", "attributes": {"key": "$d_avg_snowstormflp", "volume": 0.0, "loop": "true", "channel": "sn"}}, {"id": 7, "prop": "SoundVolume", "attributes": {"volume": 1.0, "channel": "sn", "fadetime": 2.0}}, {"id": 8, "prop": "Background", "attributes": {"image": "66_g14_ursusvillage", "screenadapt": "coverall"}}, {"id": 9, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 10, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 11, "prop": "name", "attributes": {"content": "The nights of deep autumn are cold in Ursus. Snow falls from the branches as the cold winds blow."}}, {"id": 12, "prop": "name", "attributes": {"content": "The crowd has already dispersed. There is no light coming from the distant huts."}}, {"id": 13, "prop": "name", "attributes": {"content": "A tiny flicker of flame still burns on the charred firewood in the middle of the clearing, clinging to its last gasp of life as the north winds tear at it."}}, {"id": 14, "prop": "dialog", "attributes": {}}, {"id": 15, "prop": "SoundVolume", "attributes": {"volume": 0.2, "channel": "sn", "fadetime": 2.0}}, {"id": 16, "prop": "PlaySound", "attributes": {"key": "$d_avg_firewood_throw", "volume": 1.0}}, {"id": 17, "prop": "playsound", "attributes": {"key": "$d_avg_warmbonfire_loop", "loop": "true", "channel": "a", "volume": 0.0}}, {"id": 18, "prop": "SoundVolume", "attributes": {"volume": 1.0, "fadetime": 2.0, "channel": "a"}}, {"id": 19, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 20, "prop": "name", "attributes": {"content": "A piece of thick firewood is thrown into the pile, and sparks fly in the air."}}, {"id": 21, "prop": "dialog", "attributes": {}}, {"id": 22, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1971_1#1$1", "duration": 1.0, "isblock": "true"}}, {"id": 23, "prop": "name", "attributes": {"content": "They...", "name": "Hawley"}, "figure_art": "avg_npc_1971_1#1$1"}, {"id": 24, "prop": "name", "attributes": {"content": "They found us.", "name": "Hawley"}, "figure_art": "avg_npc_1971_1#1$1"}, {"id": 25, "prop": "charslot", "attributes": {}}, {"id": 26, "prop": "name", "attributes": {"content": "Dry firewood lies in ash, slowly becoming charred and twisted, before being swallowed by the leaping flames."}}, {"id": 27, "prop": "name", "attributes": {"content": "The fire shines upon the face of the feeble Infected, but he feels no warmth."}}, {"id": 28, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1971_1#1$1"}}, {"id": 29, "prop": "name", "attributes": {"content": "The people here... everyone.", "name": "Hawley"}, "figure_art": "avg_npc_1971_1#1$1"}, {"id": 30, "prop": "name", "attributes": {"content": "They must be wiped away... like Ganea was...", "name": "Hawley"}, "figure_art": "avg_npc_1971_1#1$1"}, {"id": 31, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1971_1#7$1"}}, {"id": 32, "prop": "name", "attributes": {"content": "This way, they will never...", "name": "Hawley"}, "figure_art": "avg_npc_1971_1#7$1"}, {"id": 33, "prop": "name", "attributes": {"content": "They will never lose their goodness, nor abandon purity...", "name": "Hawley"}, "figure_art": "avg_npc_1971_1#7$1"}, {"id": 34, "prop": "name", "attributes": {"content": "Their souls shall never be defiled.", "name": "Hawley"}, "figure_art": "avg_npc_1971_1#7$1"}, {"id": 35, "prop": "charslot", "attributes": {}}, {"id": 36, "prop": "name", "attributes": {"content": "He is in pain, a pain that penetrates his heart like a needle."}}, {"id": 37, "prop": "name", "attributes": {"content": "He is cold, shivering like he just fell into a frozen lake."}}, {"id": 38, "prop": "name", "attributes": {"content": "He must make himself warm again."}}, {"id": 39, "prop": "dialog", "attributes": {}}, {"id": 40, "prop": "PlaySound", "attributes": {"key": "$d_avg_firewood_throw", "volume": 0.2}}, {"id": 41, "prop": "Delay", "attributes": {"time": 0.7}}, {"id": 42, "prop": "PlaySound", "attributes": {"key": "$d_avg_firewood_throw", "volume": 0.5}}, {"id": 43, "prop": "Delay", "attributes": {"time": 0.7}}, {"id": 44, "prop": "PlaySound", "attributes": {"key": "$d_avg_firewood_throw", "volume": 1.0}}, {"id": 45, "prop": "Delay", "attributes": {"time": 0.7}}, {"id": 46, "prop": "name", "attributes": {"content": "One piece, two pieces, three pieces."}}, {"id": 47, "prop": "name", "attributes": {"content": "One bundle, two bundles, three bundles."}}, {"id": 48, "prop": "name", "attributes": {"content": "The flame that was so faint now pokes its head from the gaps in the wood like a burning demon, threatening to touch its creator with its tongue."}}, {"id": 49, "prop": "name", "attributes": {"content": "The frail miner picks up a burning firewood and walks toward the silent houses."}}, {"id": 50, "prop": "dialog", "attributes": {}}, {"id": 51, "prop": "StopSound", "attributes": {"channel": "a", "fadetime": 2.0}}, {"id": 52, "prop": "PlaySound", "attributes": {"key": "$d_avg_snowbootwalk", "volume": 1.0}}, {"id": 53, "prop": "SoundVolume", "attributes": {"volume": 0.2, "channel": "sn", "fadetime": 2.0}}, {"id": 54, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 55, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 56, "prop": "charslot", "attributes": {}}, {"id": 57, "prop": "Background", "attributes": {"image": "bg_newiceforest_3", "screenadapt": "coverall"}}, {"id": 58, "prop": "SoundVolume", "attributes": {"volume": 1.0, "channel": "sn", "fadetime": 2.0}}, {"id": 59, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 60, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 61, "prop": "name", "attributes": {"content": "Tap, click, tap, click."}}, {"id": 62, "prop": "name", "attributes": {"content": "The footsteps are rhythmic, one stronger than the other."}}, {"id": 63, "prop": "dialog", "attributes": {}}, {"id": 64, "prop": "PlaySound", "attributes": {"key": "$d_avg_snowbootwalk", "volume": 1.0}}, {"id": 65, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1971_1#4$1", "duration": 1.5, "isblock": "true"}}, {"id": 66, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 67, "prop": "name", "attributes": {"content": "Asleep... asleep!", "name": "Hawley"}, "figure_art": "avg_npc_1971_1#4$1"}, {"id": 68, "prop": "name", "attributes": {"content": "They're all asleep.", "name": "Hawley"}, "figure_art": "avg_npc_1971_1#4$1"}, {"id": 69, "prop": "name", "attributes": {"content": "You do not know what desperation awaits you, what judgment you will face.", "name": "Hawley"}, "figure_art": "avg_npc_1971_1#4$1"}, {"id": 70, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1971_1#5$1"}}, {"id": 71, "prop": "name", "attributes": {"content": "Aiding and abetting the Infected before selling them out. Blissful ignorance, docile as a burdenbeast!", "name": "Hawley"}, "figur