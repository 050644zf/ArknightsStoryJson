1971_1#4$1"}}, {"id": 92, "prop": "name", "attributes": {"content": "Cleansing—", "name": "Hawley"}, "figure_art": "avg_npc_1971_1#4$1"}, {"id": 93, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 94, "prop": "name", "attributes": {"content": "The flames awaken all that has withered."}}, {"id": 95, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1971_1#5$1"}}, {"id": 96, "prop": "name", "attributes": {"content": "Salvation!", "name": "Hawley"}, "figure_art": "avg_npc_1971_1#5$1"}, {"id": 97, "prop": "dialog", "attributes": {}}, {"id": 98, "prop": "StopSound", "attributes": {"channel": "sn", "fadetime": 2.0}}, {"id": 99, "prop": "PlaySound", "attributes": {"key": "$firestorm", "volume": 1.0}}, {"id": 100, "prop": "PlayMusic", "attributes": {"key": "$m_bat_act37d0d0_01_loop", "volume": 0.6}}, {"id": 101, "prop": "bgeffect", "attributes": {"name": "$eb_062cg_phantom_front", "fade": "true", "fadetime": 1.5, "layer": 1.0}}, {"id": 102, "prop": "playsound", "attributes": {"key": "$d_avg_churchfire", "loop": "true", "channel": "a", "volume": 0.0}}, {"id": 103, "prop": "SoundVolume", "attributes": {"volume": 0.7, "fadetime": 2.0, "channel": "a"}}, {"id": 104, "prop": "charslot", "attributes": {"duration": 1.5, "isblock": "true"}}, {"id": 105, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 106, "prop": "name", "attributes": {"content": "He has never felt so acutely alive."}}, {"id": 107, "prop": "dialog", "attributes": {}}, {"id": 108, "prop": "StopSound", "attributes": {"channel": "a", "fadetime": 2.0}}, {"id": 109, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 110, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 111, "prop": "charslot", "attributes": {}}, {"id": 112, "prop": "bgeffect", "attributes": {}}, {"id": 113, "prop": "Background", "attributes": {"image": "34_g10_tent_inside", "screenadapt": "coverall"}}, {"id": 114, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 115, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 116, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 117, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovement", "volume": 1.0}}, {"id": 118, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1963_1#1$1", "posfrom": "0,-50", "posto": "0,0", "duration": 0.5, "isblock": "true"}}, {"id": 119, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 120, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 121, "prop": "name", "attributes": {"content": "The ringing continues in his head. In the nightmare, Rankin is clinging to the last vestige of cognition and sanity."}}, {"id": 122, "prop": "name", "attributes": {"content": "His sensations are returning, but the wailing grown nearer, not more distant."}}, {"id": 123, "prop": "name", "attributes": {"content": "He forces himself up and staggers towards the door of the tent, seeking a breath of fresh air."}}, {"id": 124, "prop": "dialog", "attributes": {}}, {"id": 125, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 126, "prop": "charslot", "attributes": {"duration": 1.5, "isblock": "true"}}, {"id": 127, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 128, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 129, "prop": "charslot", "attributes": {}}, {"id": 130, "prop": "bgeffect", "attributes": {"name": "$eb_smoke_01", "layer": 1.0}}, {"id": 131, "prop": "Background", "attributes": {"image": "bg_snowconutry_3", "screenadapt": "coverall"}}, {"id": 132, "prop": "playsound", "attributes": {"key": "$d_avg_churchfire", "loop": "true", "channel": "a", "volume": 0.0}}, {"id": 133, "prop": "SoundVolume", "attributes": {"volume": 0.4, "fadetime": 2.0, "channel": "a"}}, {"id": 134, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 135, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 136, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 137, "prop": "name", "attributes": {"content": "Hot air rushes at him, evaporating the sweat in an instant."}}, {"id": 138, "prop": "name", "attributes": {"content": "In the blink of an eye, all the feelings return to his body."}}, {"id": 139, "prop": "name", "attributes": {"content": "This is not a dream. It is real. The stuff of his nightmares has found a foothold in reality."}}, {"id": 140, "prop": "name", "attributes": {"content": "Everywhere, people are fleeing, as the houses that once offered refuge are devoured by fire."}}, {"id": 141, "prop": "name", "attributes": {"content": "In the gushing smoke, the scent of charred despair clutches at everyone's throats like a demonic claw. How tiny is man in the presence of terror."}}, {"id": 142, "prop": "dialog", "attributes": {}}, {"id": 143, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0}}, {"id": 144, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1967_1#5$1", "duration": 1.0, "isblock": "true"}}, {"id": 145, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 146, "prop": "name", "attributes": {"content": "Rankin!", "name": "Nikto"}, "figure_art": "avg_npc_1967_1#5$1"}, {"id": 147, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1963_1#6$1"}}, {"id": 148, "prop": "name", "attributes": {"content": "What... what happened?", "name": "Rankin"}, "figure_art": "avg_npc_1963_1#6$1"}, {"id": 149, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1967_1#5$1"}}, {"id": 150, "prop": "name", "attributes": {"content": "No idea. The fire started all of a sudden. We can't put it out!", "name": "Nikto"}, "figure_art": "avg_npc_1967_1#5$1"}, {"id": 151, "prop": "name", "attributes": {"content": "All we can do is evacuate the others!", "name": "Nikto"}, "figure_art": "avg_npc_1967_1#5$1"}, {"id": 152, "prop": "dialog", "attributes": {}}, {"id": 153, "prop": "charslot", "attributes": {}}, {"id": 154, "prop": "PlaySound", "attributes": {"key": "$d_avg_walkfast", "volume": 1.0}}, {"id": 155, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1969_1#1$1", "posfrom": "-200,0", "posto": "0,0", "duration": 0.6}}, {"id": 156, "prop": "Delay", "attributes": {"time": 0.2}}, {"id": 157, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1963_1#1$1", "posfrom": "200,0", "posto": "0,0", "duration": 0.8}}, {"id": 158, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 159, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1969_1#1$1", "focus": "l"}}, {"id": 160, "prop": "name", "attributes": {"content": "The food we traded for is still inside. I have to go in—", "name": "Excited Miner"}, "figure_art": "avg_npc_1969_1#1$1"}, {"id": 161, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1963_1#7$1", "focus": "r"}}, {"id": 162, "prop": "name", "attributes": {"content": "Now is not the time!", "name": "Rankin"}, "figure_art": "avg_npc_1963_1#7$1"}, {"id": 163, "prop": "name", "attributes": {"content": "Wake everyone! Get them out of the village! Go!", "name": "Rankin"}, "figure_art": "avg_npc_1963_1#7$1"}, {"id": 164, "prop": "charslot", "attributes": {}}, {"id": 165, "prop": "name", "attributes": {"content": "But his commands do not bring order to the crowd. Fear continues to spread unchecked."}}, {"id": 166, "prop": "dialog", "attributes": {}}, {"id": 167, "prop": "SoundVolume", "attributes": {"volume": 0.0, "channel": "a", "fadetime": 0.5}}, {"id": 168, "prop": "PlaySound", "attributes": {"key": "$flashback", "volume": 0.8}}, {"id": 169, "prop": "Blocker", "attributes": {"a": 0.0, "r": 255.0, "g": 255.0, "b": 255.0, "fadetime": 0.0, "block": "true"}}, {"id": 170, "pro