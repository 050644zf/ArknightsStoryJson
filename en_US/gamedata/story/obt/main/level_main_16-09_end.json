83, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1971_1#7$1", "focus": "m", "posfrom": "-200,0", "posto": "-230,0", "afrom": 1.0, "ato": 1.0, "duration": 0.4}}, {"id": 284, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4207_branch_1#10$1", "posfrom": "-200,0", "posto": "-150,0", "afrom": 1.0, "ato": 1.0, "duration": 0.4}}, {"id": 285, "prop": "delay", "attributes": {"time": 0.4}}, {"id": 286, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 287, "prop": "name", "attributes": {"content": "Ugh...!", "name": "Vetochki"}, "figure_art": "avg_4207_branch_1#10$1"}, {"id": 288, "prop": "dialog", "attributes": {}}, {"id": 289, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 290, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "-230,0", "posto": "100,0", "focus": "m", "bstart": 0.2, "bend": 0.7, "afrom": 1.0, "ato": 0.0, "duration": 1.5, "isblock": "true"}}, {"id": 291, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 292, "prop": "charslot", "attributes": {}}, {"id": 293, "prop": "name", "attributes": {"content": "A shadow flashes across their vision. He is limping, but there is an unusual strength in his steps, as though he is being drawn in by something."}}, {"id": 294, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1963_1#6$1"}}, {"id": 295, "prop": "name", "attributes": {"content": "Hawley? Where are you going?!", "name": "Rankin"}, "figure_art": "avg_npc_1963_1#6$1"}, {"id": 296, "prop": "charslot", "attributes": {}}, {"id": 297, "prop": "name", "attributes": {"content": "The hunched figure ignores Rankin's cries, walking towards the sea of flames at the end of the path."}}, {"id": 298, "prop": "name", "attributes": {"content": "Surrounded by the bright light of fire, his figure casts no shadow. He prepares to welcome baptism by fire, like the Yurodstvo walking towards the execution grounds in legend."}}, {"id": 299, "prop": "dialog", "attributes": {}}, {"id": 300, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0}}, {"id": 301, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4207_branch_1#1$1", "posfrom": "-300,0", "posto": "0,0", "duration": 0.5}}, {"id": 302, "prop": "delay", "attributes": {"time": 0.3}}, {"id": 303, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,0", "posto": "300,0", "afrom": 1.0, "ato": 0.0, "duration": 0.5}}, {"id": 304, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 305, "prop": "charslot", "attributes": {}}, {"id": 306, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 307, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1963_1#7$1"}}, {"id": 308, "prop": "name", "attributes": {"content": "Vetochki! Wait!", "name": "Rankin"}, "figure_art": "avg_npc_1963_1#7$1"}, {"id": 309, "prop": "charslot", "attributes": {}}, {"id": 310, "prop": "name", "attributes": {"content": "I have committed murder.", "name": "Hawley"}, "figure_art": "avg_npc_1963_1#7$1"}, {"id": 311, "prop": "name", "attributes": {"content": "Not for food, nor for water, nor for abode.", "name": "Hawley"}, "figure_art": "avg_npc_1963_1#7$1"}, {"id": 312, "prop": "name", "attributes": {"content": "He continues to walk as he chants, and pushes open a burning door."}}, {"id": 313, "prop": "dialog", "attributes": {}}, {"id": 314, "prop": "StopSound", "attributes": {"channel": "a", "fadetime": 2.0}}, {"id": 315, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 316, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 317, "prop": "charslot", "attributes": {}}, {"id": 318, "prop": "Background", "attributes": {}}, {"id": 319, "prop": "bgeffect", "attributes": {}}, {"id": 320, "prop": "Image", "attributes": {"image": "66_i23", "screenadapt": "coverall", "xScale": 1.05, "yScale": 1.05, "fadetime": 0.0}}, {"id": 321, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.05, "yScaleFrom": 1.05, "xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 20.0, "block": "false"}}, {"id": 322, "prop": "PlaySound", "attributes": {"key": "$firestorm", "volume": 1.0}}, {"id": 323, "prop": "playsound", "attributes": {"key": "$d_avg_churchfire", "loop": "true", "channel": "a", "volume": 0.0}}, {"id": 324, "prop": "SoundVolume", "attributes": {"volume": 0.7, "fadetime": 2.0, "channel": "a"}}, {"id": 325, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 326, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 327, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 328, "prop": "name", "attributes": {"content": "Even the scorching light of the flames cannot stop Rankin from seeing what is inside the house, over Hawley's head—"}}, {"id": 329, "prop": "name", "attributes": {"content": "Flames roil and writhe as charred beams totter, cracking like the moaning of the dying."}}, {"id": 330, "prop": "name", "attributes": {"content": "An old woman sits straight in the middle of it all."}}, {"id": 331, "prop": "name", "attributes": {"content": "......", "name": "Old Woman"}}, {"id": 332, "prop": "name", "attributes": {"content": "She is sitting on the last chair without a sound. The flames are only inches from her, but they cannot touch her, as though an invisible wall is keeping them at bay."}}, {"id": 333, "prop": "name", "attributes": {"content": "She has not a speck of ash or dust on her. Even her hair is immaculately clean. Her eyes gently shut, but at the same time she seems to be watching everything."}}, {"id": 334, "prop": "name", "attributes": {"content": "I have cleansed their souls.", "name": "Hawley"}}, {"id": 335, "prop": "dialog", "attributes": {}}, {"id": 336, "prop": "StopSound", "attributes": {"channel": "a", "fadetime": 2.0}}, {"id": 337, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 338, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 339, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 340, "prop": "charslot", "attributes": {}}, {"id": 341, "prop": "Background", "attributes": {}}, {"id": 342, "prop": "Image", "attributes": {}}, {"id": 343, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}