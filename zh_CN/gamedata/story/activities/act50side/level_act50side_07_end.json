{"lang": "zh_CN", "eventid": "act50side", "eventName": "泡影苍霆", "entryType": "ACTIVITY", "storyCode": "TD-7", "avgTag": "行动后", "storyName": "为什么全是死脑筋？", "storyInfo": "宝巫迦试图与“雷之主”同归于尽，梓兰和空爆及时出现并制止了她。而后，月见夜和斑弥罗也赶到，“A6小队”再次集结。", "storyList": [{"id": 0, "prop": "HEADER", "attributes": {"key": "title_test", "is_skippable": "true", "fit_mode": "BLACK_MASK"}}, {"id": 1, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 2, "prop": "stopmusic", "attributes": {}}, {"id": 3, "prop": "Dialog", "attributes": {}}, {"id": 4, "prop": "Background", "attributes": {"image": "71_g10_bottomruins", "screenadapt": "coverall", "block": "true"}}, {"id": 5, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 6, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 7, "prop": "PlayMusic", "attributes": {"intro": "$tense_intro", "key": "$tense_loop", "volume": 0.6}}, {"id": 8, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 9, "prop": "PlaySound", "attributes": {"key": "$d_avg_purifymagic", "volume": 1.0, "channel": "1"}}, {"id": 10, "prop": "bgeffect", "attributes": {"name": "$eb_light", "layer": 1.0}}, {"id": 11, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#8$1", "focus": "m"}}, {"id": 12, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 13, "prop": "StopSound", "attributes": {"channel": "1", "fadetime": 2.5}}, {"id": 14, "prop": "bgeffect", "attributes": {}}, {"id": 15, "prop": "CameraShake", "attributes": {"duration": 2.0, "xstrength": 70.0, "ystrength": 70.0, "vibrato": 70.0, "randomness": 95.0, "fadeout": "true", "block": "false"}}, {"id": 16, "prop": "bgeffect", "attributes": {"name": "$eb_smock", "layer": 1.0}}, {"id": 17, "prop": "PlaySound", "attributes": {"key": "$MHR_skillroar_normal", "volume": 1.0}}, {"id": 18, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2102_1#1$2", "focus": "m"}}, {"id": 19, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 20, "prop": "bgeffect", "attributes": {}}, {"id": 21, "prop": "charslot", "attributes": {}}, {"id": 22, "prop": "bgeffect", "attributes": {"name": "$eb_light", "layer": 1.0}}, {"id": 23, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#6$1", "focus": "m"}}, {"id": 24, "prop": "name", "attributes": {"content": "还差......一点。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#6$1"}, {"id": 25, "prop": "bgeffect", "attributes": {}}, {"id": 26, "prop": "charslot", "attributes": {}}, {"id": 27, "prop": "name", "attributes": {"content": "她正在用自己的力量与“雷之主”对抗，双方互不相让。"}}, {"id": 28, "prop": "name", "attributes": {"content": "但是，这一点......就是咫尺天涯。"}}, {"id": 29, "prop": "bgeffect", "attributes": {"name": "$eb_light", "layer": 1.0}}, {"id": 30, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#6$1", "focus": "m"}}, {"id": 31, "prop": "name", "attributes": {"content": "......身为巫女，身为国主，吾早就做好了准备。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#6$1"}, {"id": 32, "prop": "bgeffect", "attributes": {}}, {"id": 33, "prop": "charslot", "attributes": {}}, {"id": 34, "prop": "name", "attributes": {"content": "为了弥补这最后一点的差距，只需要付出生命的代价就好了。"}}, {"id": 35, "prop": "name", "attributes": {"content": "而对她来说，这永远是最微不足道的代价。"}}, {"id": 36, "prop": "bgeffect", "attributes": {"name": "$eb_light", "layer": 1.0}}, {"id": 37, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#8$1", "focus": "m"}}, {"id": 38, "prop": "name", "attributes": {"content": "母亲，请保佑吾。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#8$1"}, {"id": 39, "prop": "charslot", "attributes": {}}, {"id": 40, "prop": "bgeffect", "attributes": {}}, {"id": 41, "prop": "name", "attributes": {"content": "只要是为了泡影国，为了使命，为了责任......"}}, {"id": 42, "prop": "name", "attributes": {"content": "即使不为了这些，哪怕只是为了让梓兰小姐和空爆小姐返回自己的家园。"}}, {"id": 43, "prop": "name", "attributes": {"content": "这也是值得的。"}}, {"id": 44, "prop": "bgeffect", "attributes": {"name": "$eb_light", "layer": 1.0}}, {"id": 45, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#8$1", "focus": "m"}}, {"id": 46, "prop": "multiline", "attributes": {"name": "宝巫迦", "content": "吾一定要......"}}, {"id": 47, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#6$1", "focus": "m"}}, {"id": 48, "prop": "multiline", "attributes": {"name": "宝巫迦", "content": "杀死“雷之主”......"}}, {"id": 49, "prop": "charslot", "attributes": {}}, {"id": 50, "prop": "bgeffect", "attributes": {}}, {"id": 51, "prop": "name", "attributes": {"content": "宝巫迦摘下眼罩，她的右眼开始闪烁起耀眼的光芒。"}}, {"id": 52, "prop": "name", "attributes": {"content": "这是巫女代代相传的杀手锏，唯有在穷途末路之时才使用的招式。"}}, {"id": 53, "prop": "name", "attributes": {"content": "主动使用它要消耗巨大的生命力，而稍有不慎，就有可能断送生命。"}}, {"id": 54, "prop": "name", "attributes": {"content": "但反过来说，若是下定决心，则可以生命为代价，爆发巨大的能量。"}}, {"id": 55, "prop": "name", "attributes": {"content": "能量在她的眼眶聚集，她感到视线开始模糊，以至于，她似乎看到了幻象——"}}, {"id": 56, "prop": "name", "attributes": {"content": "她看到了两个不该出现的人，站在了她的面前。"}}, {"id": 57, "prop": "name", "attributes": {"content": "她们不应该出现在这里的。"}}, {"id": 58, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 59, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#7$2", "focus": "m"}}, {"id": 60, "prop": "name", "attributes": {"content": "已经可以了，宝巫迦。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#7$2"}, {"id": 61, "prop": "charslot", "attributes": {}}, {"id": 62, "prop": "name", "attributes": {"content": "梓兰握住宝巫迦的手，温柔地将她从浓雾之中拉了出来。"}}, {"id": 63, "prop": "name", "attributes": {"content": "而空爆，也理所当然一般地将她护到了身后。"}}, {"id": 64, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_1048_orchd2_1#1$2", "focus": "r"}}, {"id": 65, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2100_1#4$1", "focus": "r"}}, {"id": 66, "prop": "name", "attributes": {"content": "你们不该来的，这样做的话，吾就功亏一篑了！", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#4$1"}, {"id": 67, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_1048_orchd2_1#9$2", "focus": "l"}}, {"id": 68, "prop": "name", "attributes": {"content": "......", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$2"}, {"id": 69, "prop": "Dialog", "attributes": {}}, {"id": 70, "prop": "charslot", "attributes": {}}, {"id": 71, "prop": "PlaySound", "attributes": {"key": "$d_avg_knockhead_cartoon", "volume": 0.4}}, {"id": 72, "prop": "CameraShake", "attributes": {"duration": 0.4, "xstrength": 10.0, "ystrength": 10.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 73, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 74, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#11$1", "focus": "m"}}, {"id": 75, "prop": "name", "attributes": {"content": "好痛......", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#11$1"}, {"id": 76, "prop": "Dialog", "attributes": {}}, {"id": 77, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 78, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 79, "prop": "Dialog", "attributes": {}}, {"id": 80, "prop": "charslot", "attributes": {}}, {"id": 81, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 82, "prop": "Image", "attributes": {"image": "71_i07", "fadetime": 0.0, "xScale": 1.05, "yScale": 1.05}}, {"id": 83, "prop": "ImageTween", "attributes": {"xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 15.0, "block": "false"}}, {"id": 84, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 85, "prop": "PlayMusic", "attributes": {"intro": "$newhope02_intro", "key": "$newhope02_loop", "volume": 0.6}}, {"id": 86, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 87, "prop": "name", "attributes": {"content": "“雷之主”缓缓站起，它高大的身姿投下的阴影笼罩了几人。"}}, {"id": 88, "prop": "name", "attributes": {"content": "但是，梓兰和空爆丝毫没有后退的意思。"}}, {"id": 89, "prop": "name", "attributes": {"content": "......为什么？", "name": "宝巫迦"}}, {"id": 90, "prop": "name", "attributes": {"content": "我和空爆的身边，确实有一个和你长得一模一样的孩子。", "name": "梓兰"}}, {"id": 91, "prop": "name", "attributes": {"content": "......你们长得很像，但是性格却完全相反。", "name": "梓兰"}}, {"id": 92, "prop": "name", "attributes": {"content": "我把她——泡普卡当妹妹看待。她很胆小，也缺乏主见，如果没有人拉着她前进的话，她能在原地一个人待到大地毁灭。", "name": "梓兰"}}, {"id": 93, "prop": "name", "attributes": {"content": "但是，我只是她在罗德岛期间的队长，我无法一辈子当她的队长。", "name": "梓兰"}}, {"id": 94, "prop": "name", "attributes": {"content": "她总要学着自立。", "name": "梓兰"}}, {"id": 95, "prop": "name", "attributes": {"content": "我并不想要求她一定要成为什么样的人......但她至少要学会去思考，自己想要成为什么样的人。", "name": "梓兰"}}, {"id": 96, "prop": "name", "attributes": {"content": "而你，你很独立自主，也有行动力，你知道自己想要什么。", "name": "梓兰"}}, {"id": 97, "prop": "name", "attributes": {"content": "我确实有过一个念头——要是泡普卡能向你靠近一点就好了。", "name": "梓兰"}}, {"id": 98, "prop": "name", "attributes": {"content": "但我很快就打消了这个想法。因为宝巫迦是宝巫迦，泡普卡是泡普卡。", "name": "梓兰"}}, {"id": 99, "prop": "name", "attributes": {"content": "至少现在，我希望你能向她靠近一点——学会依靠别人一些。", "name": "梓兰"}}, {"id": 100, "prop": "name", "attributes": {"content": "你们......", "name": "宝巫迦"}}, {"id": 101, "prop": "name", "attributes": {"content": "下次，你再那样自顾自地走开，我可要更用力地敲你的头了。", "name": "梓兰"}}, {"id": 102, "prop": "Dialog", "attributes": {}}, {"id": 103, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 104, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 105, "prop": "Dialog", "attributes": {}}, {"id": 106, "prop": "Image", "attributes": {}}, {"id": 107, "prop": "charslot", "attributes": {}}, {"id": 108, "prop": "Background", "attributes": {"image": "71_g10_bottomruins", "screenadapt": "coverall"}}, {"id": 109, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 110, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 111, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 112, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_1048_orchd2_1#1$2", "focus": "r"}}, {"id": 113, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2100_1#4$1", "focus": "r"}}, {"id": 114, "prop": "name", "attributes": {"content": "吾......没错。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#4$1"}, {"id": 115, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2100_1#11$1", "focus": "r"}}, {"id": 116, "prop": "name", "attributes": {"content": "就算你们不来，吾也可以完成自己的使命。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#11$1"}, {"id": 117, "prop": "Dialog", "attributes": {}}, {"id": 118, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_1048_orchd2_1#6$2", "focus": "l"}}, {"id": 119, "prop": "CameraShake", "attributes": {"duration": 0.4, "xstrength": 10.0, "ystrength": 10.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 120, "prop": "PlaySound", "attributes": {"key": "$d_avg_knockhead_cartoon", "volume": 1.0}}, {"id": 121, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 122, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_1048_orchd2_1#6$2", "focus": "l"}}, {"id": 123, "prop": "name", "attributes": {"content": "哪有什么注定的使命。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#6$2"}, {"id": 124, "prop": "charslot", "attributes": {}}, {"id": 125, "prop": "PlaySound", "attributes": {"key": "$MHR_dog_voice3", "volume": 0.8}}, {"id": 126, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyD_1#1$1", "focus": "m"}}, {"id": 127, "prop": "name", "attributes": {"content": "（警惕的低吼）", "name": "义经"}, "figure_art": "avg_4215_buddyD_1#1$1"}, {"id": 128, "prop": "Dialog", "attributes": {}}, {"id": 129, "prop": "charslot", "attributes": {}}, {"id": 130, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 131, "prop": "PlaySound", "attributes": {"key": "$d_avg_snarl_1", "volume": 1.0}}, {"id": 132, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2105_1#1$1", "afrom": 0.0, "ato": 1.0, "duration": 1.0}}, {"id": 133, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2105_1#1$1", "afrom": 0.0, "ato": 1.0, "duration": 1.3}}, {"id": 134, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 135, "prop": "charslot", "attributes": {}}, {"id": 136, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyC_1#1$5", "focus": "m"}}, {"id": 137, "prop": "PlaySound", "attributes": {"key": "$MHR_cat_voice3", "volume": 1.0}}, {"id": 138, "prop": "name", "attributes": {"content": "梓兰，空爆，先带陛下撤离这里喵！", "name": "政宗"}, "figure_art": "avg_4215_buddyC_1#1$5"}, {"id": 139, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#8$2", "focus": "m"}}, {"id": 140, "prop": "name", "attributes": {"content": "......不。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#8$2"}, {"id": 141, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyC_1#1$4", "focus": "m"}}, {"id": 142, "prop": "PlaySound", "attributes": {"key": "$MHR_cat_voice2", "volume": 1.0}}, {"id": 143, "prop": "name", "attributes": {"content": "为什喵？！", "name": "政宗"}, "figure_art": "avg_4215_buddyC_1#1$4"}, {"id": 144, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#9$2", "focus": "m"}}, {"id": 145, "prop": "name", "attributes": {"content": "你看“雷之主”——", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$2"}, {"id": 146, "prop": "PlaySound", "attributes": {"key": "$MHR_skillroar_normal", "volume": 1.0}}, {"id": 147, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2102_1#1$2", "focus": "m"}}, {"id": 148, "prop": "name", "attributes": {"content": "（极度愤怒的吼叫）", "name": "“雷之主”"}, "figure_art": "avg_npc_2102_1#1$2"}, {"id": 149, "prop": "Dialog", "attributes": {}}, {"id": 150, "prop": "bgeffect", "attributes": {}}, {"id": 151, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,0", "posto": "-150,0", "afrom": 1.0, "ato": 0.0, "duration": 1.0}}, {"id": 152, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 153, "prop": "charslot", "attributes": {}}, {"id": 154, "prop": "PlaySound", "attributes": {"key": "$MHR_normalpunch_roar", "volume": 1.0}}, {"id": 155, "prop": "Delay", "attributes": {"time": 0.1}}, {"id": 156, "prop": "PlaySound", "attributes": {"key": "$MHR_normalpunch_voice", "volume": 1.0}}, {"id": 157, "prop": "Delay", "attributes": {"time": 0.01}}, {"id": 158, "prop": "PlaySound", "attributes": {"key": "$MHR_normalpunch_echo", "volume": 1.0}}, {"id": 159, "prop": "Delay", "attributes": {"time": 0.01}}, {"id": 160, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 161, "prop": "Blocker", "attributes": {"a": 1.0, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 0.05, "block": "true"}}, {"id": 162, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.3, "block": "true"}}, {"id": 163, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2105_1#1$1"}}, {"id": 164, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 165, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown1", "volume": 1.0}}, {"id": 166, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2105_1#1$1", "posfrom": "0,0", "posto": "-20,-50", "afrom": 1.0, "ato": 0.0, "duration": 1.0}}, {"id": 167, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 168, "prop": "charslot", "attributes": {}}, {"id": 169, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#7$2", "focus": "m"}}, {"id": 170, "prop": "name", "attributes": {"content": "它在帮我们？", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#7$2"}, {"id": 171, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#6$2", "focus": "m"}}, {"id": 172, "prop": "name", "attributes": {"content": "它身上冒出的黑气少了许多......或许，和宝巫迦的战斗让它清醒了。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#6$2"}, {"id": 173, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#6$2", "focus": "m"}}, {"id": 174, "prop": "name", "attributes": {"content": "对哦，如果它真的不是什么坏家伙，而且身上又有前代陛下的力量，它会觉得这些咒鬼才是真正的威胁好像也是正常的事。", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#6$2"}, {"id": 175, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyC_1#1$6", "focus": "m"}}, {"id": 176, "prop": "PlaySound", "attributes": {"key": "$MHR_cat_voice1", "volume": 1.0}}, {"id": 177, "prop": "name", "attributes": {"content": "或许雷狼龙只是认为咒鬼的威胁比你们大喵！", "name": "政宗"}, "figure_art": "avg_4215_buddyC_1#1$6"}, {"id": 178, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#6$2", "focus": "m"}}, {"id": 179, "prop": "name", "attributes": {"content": "我没有天真到那个地步，但是，我们都听到了前代陛下的遗言。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#6$2"}, {"id": 180, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#9$2", "focus": "m"}}, {"id": 181, "prop": "name", "attributes": {"content": "她说，不要对抗“雷之主”，要利用它的力量。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$2"}, {"id": 182, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#5$1", "focus": "m"}}, {"id": 183, "prop": "name", "attributes": {"content": "......什么？！", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#5$1"}, {"id": 184, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#6$1", "focus": "m"}}, {"id": 185, "prop": "name", "attributes": {"content": "这怎么可能！母亲有什么理由......", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#6$1"}, {"id": 186, "prop": "name", "attributes": {"content": "况且，就算是这样，“雷之主”伤害了月见夜，而且掀起了兽潮！", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#6$1"}, {"id": 187, "prop": "charslot", "attributes": {}}, {"id": 188, "prop": "Dialog", "attributes": {}}, {"id": 189, "prop": "PlaySound", "attributes": {"key": "$d_avg_steammachine_footstep", "volume": 1.0, "channel": "6"}}, {"id": 190, "prop": "StopSound", "attributes": {"channel": "1", "fadetime": 2.5}}, {"id": 191, "prop": "CameraShake", "attributes": {"duration": 2.5, "xstrength": 70.0, "ystrength": 70.0, "vibrato": 70.0, "randomness": 95.0, "fadeout": "true", "block": "false"}}, {"id": 192, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 193, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#4$2", "focus": "m"}}, {"id": 194, "prop": "name", "attributes": {"content": "这个声音是——", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#4$2"}, {"id": 195, "prop": "charslot", "attributes": {}}, {"id": 196, "prop": "Dialog", "attributes": {}}, {"id": 197, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0, "channel": "1"}}, {"id": 198, "prop": "StopSound", "attributes": {"channel": "1", "fadetime": 1.5}}, {"id": 199, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2106_1#1$1", "afrom": 0.0, "ato": 1.0, "duration": 1.5}}, {"id": 200, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2107_1#1$1", "afrom": 0.0, "ato": 1.0, "duration": 1.5}}, {"id": 201, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 202, "prop": "charslot", "attributes": {}}, {"id": 203, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0, "channel": "2"}}, {"id": 204, "prop": "StopSound", "attributes": {"channel": "2", "fadetime": 1.5}}, {"id": 205, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2101_1#1$1", "afrom": 0.0, "ato": 1.0, "duration": 1.5}}, {"id": 206, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2103_1#1$1", "afrom": 0.0, "ato": 1.0, "duration": 1.5}}, {"id": 207, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 208, "prop": "charslot", "attributes": {}}, {"id": 209, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#5$1", "focus": "m"}}, {"id": 210, "prop": "name", "attributes": {"content": "武士们？为什么你们会，难道——", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#5$1"}, {"id": 211, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#1$1", "focus": "m"}}, {"id": 212, "prop": "name", "attributes": {"content": "陛下。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#1$1"}, {"id": 213, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#5$1", "focus": "m"}}, {"id": 214, "prop": "name", "attributes": {"content": "月见夜，你没事吗？！", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#5$1"}, {"id": 215, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2103_1#1$1", "focus": "m"}}, {"id": 216, "prop": "name", "attributes": {"content": "哼，这家伙哪里像没事的样子？", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 217, "prop": "name", "attributes": {"content": "非要我用机器把他驮过来。", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 218, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#9$1", "focus": "m"}}, {"id": 219, "prop": "name", "attributes": {"content": "陛下，我有千言万语想告诉您。但有一件事，眼下恐怕是最重要的。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#9$1"}, {"id": 220, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#4$1", "focus": "m"}}, {"id": 221, "prop": "name", "attributes": {"content": "“雷之主”或许不是罪魁祸首。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#4$1"}, {"id": 222, "prop": "Dialog", "attributes": {}}, {"id": 223, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 224, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "style": "slider", "inverse": "true", "fadetime": 2.0, "block": "true"}}, {"id": 225, "prop": "charslot", "attributes": {}}, {"id": 226, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "style": "slider", "inverse": "false", "fadetime": 2.0, "block": "true"}}, {"id": 227, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#7$2", "focus": "m"}}, {"id": 228, "prop": "name", "attributes": {"content": "你是说，“雷之主”救了你？！", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#7$2"}, {"id": 229, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#4$1", "focus": "m"}}, {"id": 230, "prop": "name", "attributes": {"content": "没错。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#4$1"}, {"id": 231, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#6$1", "focus": "m"}}, {"id": 232, "prop": "name", "attributes": {"content": "当时，我被爆炸波及，周围又有咒鬼靠近，我本以为必死无疑，“雷之主”却在此时出现，将咒鬼一扫而空。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#6$1"}, {"id": 233, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#1$1", "focus": "m"}}, {"id": 234, "prop": "name", "attributes": {"content": "在那之后的事，我就不知道了。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#1$1"}, {"id": 235, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#6$2", "focus": "m"}}, {"id": 236, "prop": "name", "attributes": {"content": "等等，难道我看到的，不是“雷之主”带着咒鬼把你击倒，是它救了你之后，在那里用巫女的力量净化那些咒鬼？！", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#6$2"}, {"id": 237, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#6$1", "focus": "m"}}, {"id": 238, "prop": "name", "attributes": {"content": "我恐怕......是这样的。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#6$1"}, {"id": 239, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#1$1", "focus": "m"}}, {"id": 240, "prop": "name", "attributes": {"content": "等到醒来后，我得知陛下的去向，立刻就动身想来告诉您这件事。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#1$1"}, {"id": 241, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#4$1", "focus": "m"}}, {"id": 242, "prop": "name", "attributes": {"content": "难道，母亲真的是将力量托付给了“雷之主”？", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#4$1"}, {"id": 243, "prop": "name", "attributes": {"content": "......但这样并非解释不通。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#4$1"}, {"id": 244, "prop": "name", "attributes": {"content": "如果说，“雷之主”本就不是“诅咒”的传播者，而是受害者......", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#4$1"}, {"id": 245, "prop": "name", "attributes": {"content": "如果说，母亲知道，“雷之主”一直在凭借本能捕食被“诅咒”感染的野兽......", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#4$1"}, {"id": 246, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#8$1", "focus": "m"}}, {"id": 247, "prop": "name", "attributes": {"content": "而它之所以一直吸收“诅咒”也能活下来，是因为，母亲将力量给了它......", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#8$1"}, {"id": 248, "prop": "name", "attributes": {"content": "那么，吾等过去见到的“雷之主”，就不是灾难引发者，它只是受到灾难吸引，才会出现在那里......", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#8$1"}, {"id": 249, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#8$1", "focus": "m"}}, {"id": 250, "prop": "multiline", "attributes": {"name": "宝巫迦", "content": "真正的罪魁祸首......"}}, {"id": 251, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#5$1", "focus": "m"}}, {"id": 252, "prop": "multiline", "attributes": {"name": "宝巫迦", "content": "是“诅咒”，或者说，是“御轮”？！"}}, {"id": 253, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#6$2", "focus": "m"}}, {"id": 254, "prop": "name", "attributes": {"content": "也就是说，“雷之主”至少不是我们的敌人？", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#6$2"}, {"id": 255, "prop": "PlaySound", "attributes": {"key": "$MHR_dog_voice3", "volume": 0.8}}, {"id": 256, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyD_1#1$5", "focus": "m"}}, {"id": 257, "prop": "name", "attributes": {"content": "（警惕的低吼）", "name": "义经"}, "figure_art": "avg_4215_buddyD_1#1$5"}, {"id": 258, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyC_1#1$2", "focus": "m"}}, {"id": 259, "prop": "PlaySound", "attributes": {"key": "$MHR_cat_voice1", "volume": 1.0}}, {"id": 260, "prop": "name", "attributes": {"content": "没错......咒鬼看起来也在向“御轮”靠近喵。", "name": "政宗"}, "figure_art": "avg_4215_buddyC_1#1$2"}, {"id": 261, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyC_1#1$3", "focus": "m"}}, {"id": 262, "prop": "name", "attributes": {"content": "虽然不知道它们想干什么，但肯定不是什么好事喵......", "name": "政宗"}, "figure_art": "avg_4215_buddyC_1#1$3"}, {"id": 263, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#8$1", "focus": "m"}}, {"id": 264, "prop": "name", "attributes": {"content": "无论如何，若要彻底启动“御轮”，吾的力量都是不够的，吾需要“雷之主”身上属于母亲的那一部分力量。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#8$1"}, {"id": 265, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#1$2", "focus": "m"}}, {"id": 266, "prop": "name", "attributes": {"content": "那能不能让它帮我们的忙？", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#1$2"}, {"id": 267, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#5$1", "focus": "m"}}, {"id": 268, "prop": "name", "attributes": {"content": "帮忙？", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#5$1"}, {"id": 269, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#4$1", "focus": "m"}}, {"id": 270, "prop": "name", "attributes": {"content": "它只是野兽——", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#4$1"}, {"id": 271, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#5$2", "focus": "m"}}, {"id": 272, "prop": "name", "attributes": {"content": "野兽也有本能，至少知道谁对自己威胁最大，不然也不会逮着咒鬼杀，对吧？", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#5$2"}, {"id": 273, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#8$2", "focus": "m"}}, {"id": 274, "prop": "name", "attributes": {"content": "......有道理。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#8$2"}, {"id": 275, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#6$2", "focus": "m"}}, {"id": 276, "prop": "name", "attributes": {"content": "就算它听不懂我们的话，只要它知道什么威胁最大，自然就是我们的帮手。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#6$2"}, {"id": 277, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#4$2", "focus": "m"}}, {"id": 278, "prop": "name", "attributes": {"content": "也就是说，任务目标确定了，对吧，队长？", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#4$2"}, {"id": 279, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#4$2", "focus": "m"}}, {"id": 280, "prop": "name", "attributes": {"content": "队长？", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#4$2"}, {"id": 281, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#1$2", "focus": "m"}}, {"id": 282, "prop": "name", "attributes": {"content": "是啊。", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#1$2"}, {"id": 283, "prop": "charslot", "attributes": {}}, {"id": 284, "prop": "name", "attributes": {"content": "梓兰注意到，宝巫迦和月见夜也点了点头。"}}, {"id": 285, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#10$2", "focus": "m"}}, {"id": 286, "prop": "name", "attributes": {"content": "你们一个是将军，一个是国主，看我干什么？", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#10$2"}, {"id": 287, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#4$1", "focus": "m"}}, {"id": 288, "prop": "name", "attributes": {"content": "吾......虽然依然相信自己的做法没有错，但是，吾必须承认，你的方法或许更好。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#4$1"}, {"id": 289, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#3$1", "focus": "m"}}, {"id": 290, "prop": "name", "attributes": {"content": "眼下，你能做出比吾更加正确的判断。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#3$1"}, {"id": 291, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#5$1", "focus": "m"}}, {"id": 292, "prop": "name", "attributes": {"content": "如果没有梓兰小姐在我倒下后，替我指挥军队，泡影国此时已经一团乱麻，你留下的那封信，也给了我勇气。狩猎团全员，听你调遣。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#5$1"}, {"id": 293, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2103_1#1$1", "focus": "m"}}, {"id": 294, "prop": "name", "attributes": {"content": "如果不是空爆的武器，我也开发不出这台“斑弥罗特制击龙枪”，你指哪儿，我打哪儿！", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 295, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#14$2", "focus": "m"}}, {"id": 296, "prop": "name", "attributes": {"content": "呃......原来那个东西真的有用啊！我还以为单纯逗我们玩的呢！", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#14$2"}, {"id": 297, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2103_1#1$1", "focus": "m"}}, {"id": 298, "prop": "name", "attributes": {"content": "当然有！我说过多少次了，我可是正经的发明家！", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 299, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#5$2", "focus": "m"}}, {"id": 300, "prop": "name", "attributes": {"content": "那你至少改一改你命名的品味吧！", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#5$2"}, {"id": 301, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#4$2", "focus": "m"}}, {"id": 302, "prop": "name", "attributes": {"content": "......", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#4$2"}, {"id": 303, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#1$2", "focus": "m"}}, {"id": 304, "prop": "name", "attributes": {"content": "梓兰姐，下令吧。", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#1$2"}, {"id": 305, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#7$2", "focus": "m"}}, {"id": 306, "prop": "name", "attributes": {"content": "真拿你们没办法。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#7$2"}, {"id": 307, "prop": "Dialog", "attributes": {}}, {"id": 308, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#8$2", "focus": "m"}}, {"id": 309, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 310, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#9$2", "focus": "m"}}, {"id": 311, "prop": "name", "attributes": {"content": "那么，接下来由我来布置作战任务。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$2"}, {"id": 312, "prop": "Dialog", "attributes": {}}, {"id": 313, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 314, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 315, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 316, "prop": "Dialog", "attributes": {}}, {"id": 317, "prop": "charslot", "attributes": {}}, {"id": 318, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 319, "prop": "playMusic", "attributes": {"intro": "$batmeeting_intro", "key": "$batmeeting_loop", "volume": 0.6}}, {"id": 320, "prop": "Image", "attributes": {"image": "71_i08", "fadetime": 0.0, "xScale": 1.2, "yScale": 1.2}}, {"id": 321, "prop": "ImageTween", "attributes": {"xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 15.0, "block": "false"}}, {"id": 322, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 323, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 324, "prop": "name", "attributes": {"content": "群兽环伺，情况危急。"}}, {"id": 325, "prop": "name", "attributes": {"content": "梓兰感觉自己的大脑前所未有地清晰。"}}, {"id": 326, "prop": "name", "attributes": {"content": "任务的目标是接近“雷之主”。", "name": "梓兰"}}, {"id": 327, "prop": "name", "attributes": {"content": "但我们的目的不是狩猎它，而是帮助它彻底摆脱“诅咒”。", "name": "梓兰"}}, {"id": 328, "prop": "name", "attributes": {"content": "月见夜，你和你的手下作为先锋，打开道路。", "name": "梓兰"}}, {"id": 329, "prop": "name", "attributes": {"content": "我明白了，定不辱命。", "name": "月见夜"}}, {"id": 330, "prop": "name", "attributes": {"content": "斑弥罗，你来配合月见夜。", "name": "梓兰"}}, {"id": 331, "prop": "name", "attributes": {"content": "怎么配合？", "name": "斑弥罗"}}, {"id": 332, "prop": "name", "attributes": {"content": "按你喜欢的方式炸个痛快。", "name": "梓兰"}}, {"id": 333, "prop": "name", "attributes": {"content": "哈！这个我喜欢！", "name": "斑弥罗"}}, {"id": 334, "prop": "name", "attributes": {"content": "空爆，你和我一起掩护宝巫迦。", "name": "梓兰"}}, {"id": 335, "prop": "PlaySound", "attributes": {"key": "$MHR_caxe_creek", "volume": 1.0}}, {"id": 336, "prop": "name", "attributes": {"content": "好嘞！", "name": "空爆"}}, {"id": 337, "prop": "name", "attributes": {"content": "宝巫迦。", "name": "梓兰"}}, {"id": 338, "prop": "name", "attributes": {"content": "吾在。", "name": "宝巫迦"}}, {"id": 339, "prop": "name", "attributes": {"content": "你的任务是——", "name": "梓兰"}}, {"id": 340, "prop": "name", "attributes": {"content": "不要留下遗憾。", "name": "梓兰"}}, {"id": 341, "prop": "name", "attributes": {"content": "......吾知道了。", "name": "宝巫迦"}}, {"id": 342, "prop": "name", "attributes": {"content": "这次任务十分危险，希望你们量力而行。", "name": "梓兰"}}, {"id": 343, "prop": "name", "attributes": {"content": "成功之后......请你们吃烤肉。", "name": "梓兰"}}, {"id": 344, "prop": "name", "attributes": {"content": "好寒酸啊，梓兰姐！", "name": "空爆"}}, {"id": 345, "prop": "name", "attributes": {"content": "不满意就换个队长去吧。", "name": "梓兰"}}, {"id": 346, "prop": "name", "attributes": {"content": "那还是不要了，嘿嘿。", "name": "空爆"}}, {"id": 347, "prop": "name", "attributes": {"content": "总觉得有一段时间没有凑到一起过了。", "name": "空爆"}}, {"id": 348, "prop": "name", "attributes": {"content": "果然A6小队还得是这样才对劲嘛。", "name": "空爆"}}, {"id": 349, "prop": "name", "attributes": {"content": "怎么感觉我和义经被排挤了喵！", "name": "政宗"}}, {"id": 350, "prop": "PlaySound", "attributes": {"key": "$MHR_dog_voice1", "volume": 0.8}}, {"id": 351, "prop": "name", "attributes": {"content": "（不忿的喷气）", "name": "义经"}}, {"id": 352, "prop": "name", "attributes": {"content": "我也要吃烤肉喵！", "name": "政宗"}}, {"id": 353, "prop": "name", "attributes": {"content": "行了行了，到时候让你来烤肉，满意了吧？", "name": "梓兰"}}, {"id": 354, "prop": "name", "attributes": {"content": "那还差不多喵！", "name": "政宗"}}, {"id": 355, "prop": "name", "attributes": {"content": "出发吧。", "name": "梓兰"}}, {"id": 356, "prop": "Dialog", "attributes": {}}, {"id": 357, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 358, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 359, "prop": "bgeffect", "attributes": {}}, {"id": 360, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 361, "prop": "Image", "attributes": {}}, {"id": 362, "prop": "charslot", "attributes": {}}], "OPTIONTRACE": true}