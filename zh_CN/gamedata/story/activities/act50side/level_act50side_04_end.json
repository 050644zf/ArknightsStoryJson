npc_2100_1#9$1", "focus": "m"}}, {"id": 144, "prop": "name", "attributes": {"content": "放心，“异兽”彻底死了。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#9$1"}, {"id": 145, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#9$2", "focus": "m"}}, {"id": 146, "prop": "name", "attributes": {"content": "宝巫迦，你......", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$2"}, {"id": 147, "prop": "PlayMusic", "attributes": {"key": "$calm_loop", "volume": 0.6}}, {"id": 148, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#8$1", "focus": "m"}}, {"id": 149, "prop": "name", "attributes": {"content": "吾的身体没事了。吾能感觉到，刚才一直牵引着吾的某种东西消失了。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#8$1"}, {"id": 150, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#4$2", "focus": "m"}}, {"id": 151, "prop": "name", "attributes": {"content": "那究竟是什么？", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#4$2"}, {"id": 152, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#4$1", "focus": "m"}}, {"id": 153, "prop": "name", "attributes": {"content": "吾......不知道。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#4$1"}, {"id": 154, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 155, "prop": "name", "attributes": {"content": "不过，至少两位可以放心，吾等已经完成了对“异兽”的狩猎。接下来，吾会按照传统，将两位送回家乡。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 156, "prop": "dialog", "attributes": {}}, {"id": 157, "prop": "charslot", "attributes": {}}, {"id": 158, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 159, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#1$1", "focus": "m", "duration": 1.0}}, {"id": 160, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 161, "prop": "name", "attributes": {"content": "恭喜陛下。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#1$1"}, {"id": 162, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 163, "prop": "name", "attributes": {"content": "客套话就免了吧，月见夜。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 164, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#5$1", "focus": "m"}}, {"id": 165, "prop": "name", "attributes": {"content": "我是发自内心地为陛下和两位“异兽猎人”的胜利感到高兴。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#5$1"}, {"id": 166, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 167, "prop": "name", "attributes": {"content": "既然你为吾等高兴，就该让吾去找“雷之主”。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 168, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#1$1", "focus": "m"}}, {"id": 169, "prop": "name", "attributes": {"content": "这是两码事。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#1$1"}, {"id": 170, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#8$2", "focus": "m"}}, {"id": 171, "prop": "name", "attributes": {"content": "行了，听你说这些我就头疼。现在“异兽”也解决了，下一步我们该怎么回去？", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#8$2"}, {"id": 172, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#1$1", "focus": "m"}}, {"id": 173, "prop": "name", "attributes": {"content": "接下来，请陛下净化“异兽”尸体，启动“御轮”，将两位“异兽猎人”送回去吧。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#1$1"}, {"id": 174, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 175, "prop": "name", "attributes": {"content": "归还祭典呢？", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 176, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#1$1", "focus": "m"}}, {"id": 177, "prop": "name", "attributes": {"content": "陛下。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#1$1"}, {"id": 178, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#9$1", "focus": "m"}}, {"id": 179, "prop": "name", "attributes": {"content": "这是传统。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#9$1"}, {"id": 180, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#6$2", "focus": "m"}}, {"id": 181, "prop": "name", "attributes": {"content": "祭典？", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#6$2"}, {"id": 182, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 183, "prop": "name", "attributes": {"content": "这场祭典，既是为了感谢“御轮”的馈赠，也是为了告别“异兽猎人”。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 184, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 185, "prop": "name", "attributes": {"content": "吾等会将“异兽”的尸体运回，由吾通过仪式净化“异兽”的尸体。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 186, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 187, "prop": "name", "attributes": {"content": "而后，国民们会提取其中最有用的部位，制作成相应的武器或者道具送给“异兽猎人”作为纪念。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 188, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 189, "prop": "name", "attributes": {"content": "其余的部分，则或成为食材，或成为装饰，变成祭典的一部分。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 190, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 191, "prop": "name", "attributes": {"content": "而在祭典的最后，吾将启动“御轮”，将“异兽猎人”送回家乡。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 192, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 193, "prop": "name", "attributes": {"content": "月见夜，你要让两位“异兽猎人”以为吾国不知感恩吗？", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 194, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#6$1", "focus": "m"}}, {"id": 195, "prop": "name", "attributes": {"content": "......换作以往，听说“异兽”被狩猎，泡影国的人们或许会欢欣鼓舞。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#6$1"}, {"id": 196, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#6$1", "focus": "m"}}, {"id": 197, "prop": "name", "attributes": {"content": "但现在，“雷之主”的影响还未消去，不是举办祭典的时候。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#6$1"}, {"id": 198, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#6$1", "focus": "m"}}, {"id": 199, "prop": "name", "attributes": {"content": "就算是这样——", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#6$1"}, {"id": 200, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#10$2", "focus": "m"}}, {"id": 201, "prop": "name", "attributes": {"content": "打住。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#10$2"}, {"id": 202, "prop": "dialog", "attributes": {}}, {"id": 203, "prop": "charslot", "attributes": {}}, {"id": 204, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2101_1#9$1", "focus": "all"}}, {"id": 205, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2100_1#9$1", "focus": "all"}}, {"id": 206, "prop": "name", "attributes": {"content": "梓兰小姐怎么看？", "name": "月见夜&宝巫迦"}}, {"id": 207, "prop": "charslot", "attributes": {}}, {"id": 208, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#6$2", "focus": "m"}}, {"id": 209, "prop": "name", "attributes": {"content": "我们本来就急着回家，就算真的要举办祭典，我也未必有兴致。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#6$2"}, {"id": 210, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#6$2", "focus": "m"}}, {"id": 211, "prop": "name", "attributes": {"content": "泡影国的人们对我们已经付出了足够多的善意，我们也不需要你们再做些什么。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#6$2"}, {"id": 212, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#6$2", "focus": "m"}}, {"id": 213, "prop": "name", "attributes": {"content": "况且，月见夜说的也对，事急从权，就这样吧。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#6$2"}, {"id": 214, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#1$1", "focus": "m"}}, {"id": 215, "prop": "name", "attributes": {"content": "感谢你的理解，梓兰小姐。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#1$1"}, {"id": 216, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#6$2", "focus": "m"}}, {"id": 217, "prop": "name", "attributes": {"content": "不过，这样就可以了吗？", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#6$2"}, {"id": 218, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#8$1", "focus": "m"}}, {"id": 219, "prop": "name", "attributes": {"content": "......是的，这样就可以了。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#8$1"}, {"id": 220, "prop": "dialog", "attributes": {}}, {"id": 221, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 222, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 223, "prop": "Dialog", "attributes": {}}, {"id": 224, "prop": "charslot", "attributes": {}}, {"id": 225, "prop": "Background", "attributes": {"image": "71_g5_snowymountpath", "screenadapt": "coverall"}}, {"id": 226, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 227, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 228, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 229, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyC_1#1$2", "focus": "m"}}, {"id": 230, "prop": "PlaySound", "attributes": {"key": "$MHR_cat_voice3", "volume": 1.0}}, {"id": 231, "prop": "name", "attributes": {"content": "梓兰刚才问陛下的那句话是什么意思喵？", "name": "政宗"}, "figure_art": "avg_4215_buddyC_1#1$2"}, {"id": 232, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#6$2", "focus": "m"}}, {"id": 233, "prop": "name", "attributes": {"content": "梓兰姐是问宝巫迦，她真的只狩猎“异兽”熔火蜗就可以了吗？", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#6$2"}, {"id": 234, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#6$2", "focus": "m"}}, {"id": 235, "prop": "name", "attributes": {"content": "而宝巫迦做出了肯定的答复。", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#6$2"}, {"id": 236, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyC_1#1$2", "focus": "m"}}, {"id": 237, "prop": "name", "attributes": {"content": "真奇怪喵，梓兰不是最想回去的人喵？为什么这个问题听起来像是，如果宝巫迦想要深究雷狼龙的问题，她会帮忙喵？", "name": "政宗"}, "figure_art": "avg_4215_buddyC_1#1$2"}, {"id": 238, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyC_1#1$2", "focus": "m"}}, {"id": 239, "prop": "name", "attributes": {"content": "这不是自找麻烦喵？", "name": "政宗"}, "figure_art": "avg_4215_buddyC_1#1$2"}, {"id": 240, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#1$2", "focus": "m"}}, {"id": 241, "prop": "name", "attributes": {"content": "梓兰姐就是这样的人。", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#1$2"}, {"id": 242, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#1$2", "focus": "m"}}, {"id": 243, "prop": "name", "attributes": {"content": "嘴上说着不想管别人的麻烦，只想做好自己的事，结果不知不觉就会去插手别人的问题。", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#1$2"}, {"id": 244, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#1$2", "focus": "m"}}, {"id": 245, "prop": "name", "attributes": {"content": "然后美其名曰——“不这么办还能怎么办？”", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#1$2"}, {"id": 246, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyC_1#1$2", "focus": "m"}}, {"id": 247, "prop": "name", "attributes": {"content": "听起来真矛盾喵。", "name": "政宗"}, "figure_art": "avg_4215_buddyC_1#1$2"}, {"id": 248, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#11$2", "focus": "m"}}, {"id": 249, "prop": "name", "attributes": {"content": "梓兰姐就是很矛盾喵。", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#11$2"}, {"id": 250, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyC_1#1$6", "focus": "m"}}, {"id": 251, "prop": "PlaySound", "attributes": {"key": "$MHR_cat_voice3", "volume": 1.0}}, {"id": 252, "prop": "name", "attributes": {"content": "不要学我说话喵！", "name": "政宗"}, "figure_art": "avg_4215_buddyC_1#1$6"}, {"id": 253, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#9$1", "focus": "m"}}, {"id": 254, "prop": "name", "attributes": {"content": "又在背后说我什么坏话呢？", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$1"}, {"id": 255, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#14$2", "focus": "m"}}, {"id": 256, "prop": "name", "attributes": {"content": "哪有，我在说梓兰姐是全天下最好的队长呢。", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#14$2"}, {"id": 257, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#9$1", "focus": "m"}}, {"id": 258, "prop": "name", "attributes": {"content": "我信你就见鬼了。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$1"}, {"id": 259, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 260, "prop": "name", "attributes": {"content": "梓兰小姐，空爆小姐，既然事急从权，那吾便在此地进行仪式了。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 261, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#6$1", "focus": "m"}}, {"id": 262, "prop": "name", "attributes": {"content": "好。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#6$1"}, {"id": 263, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 264, "prop": "name", "attributes": {"content": "请退后一些。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 265, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#6$1", "focus": "m"}}, {"id": 266, "prop": "name", "attributes": {"content": "她要做什么？", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#6$1"}, {"id": 267, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#1$2", "focus": "m"}}, {"id": 268, "prop": "name", "attributes": {"content": "我知道了，宝巫迦又要跳舞了。", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#1$2"}, {"id": 269, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#1$2", "focus": "m"}}, {"id": 270, "prop": "name", "attributes": {"content": "梓兰姐，瞧着吧，这可能是我们最后一次看到了。", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#1$2"}, {"id": 271, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#4$1", "focus": "m"}}, {"id": 272, "prop": "name", "attributes": {"content": "跳舞？", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#4$1"}, {"id": 273, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#5$2", "focus": "m"}}, {"id": 274, "prop": "name", "attributes": {"content": "没错。", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#5$2"}, {"id": 275, "prop": "dialog", "attributes": {}}, {"id": 276, "prop": "charslot", "attributes": {}}, {"id": 277, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 278, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 279, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 280, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#8$1", "focus": "m"}}, {"id": 281, "prop": "PlaySound", "attributes": {"key": "$d_avg_slbellbtl", "volume": 1.0}}, {"id": 282, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 20.0, "randomness": 10.0, "fadeout": "true", "block": "false"}}, {"id": 283, "prop": "name", "attributes": {"content": "以吾身为囚——", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#8$1"}, {"id": 284, "prop": "dialog", "attributes": {}}, {"id": 285, "prop": "charslot", "attributes": {}}, {"id": 286, "prop": "name", "attributes": {"content": "随着她的舞蹈，熔火蜗尸体上残留的黑气开始被牵引，缓慢而有序地被宝巫迦吸收。"}}, {"id": 287, "prop": "name", "attributes": {"content": "她的脸色变得愈发苍白，但眼神却异常坚定。"}}, {"id": 288, "prop": "name", "attributes": {"content": "黑气经过她的身体，似乎被某种力量“过滤”，最终化作纯净的无色能量，涌向她身后的“御轮”。"}}, {"id": 289, "prop": "name", "attributes": {"content": "“御轮”的圆弧开始发出柔和的白光，光芒越来越亮，随后，一扇银白色的“门”出现在宝巫迦的身侧。"}}, {"id": 290, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#1$2", "focus": "m"}}, {"id": 291, "prop": "name", "attributes": {"content": "成功了！梓兰姐，快看！我们可以回家了！", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#1$2"}, {"id": 292, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#4$1", "focus": "m"}}, {"id": 293, "prop": "name", "attributes": {"content": "空爆，等等！不对劲！", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#4$1"}, {"id": 294, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#7$2", "focus": "m"}}, {"id": 295, "prop": "name", "attributes": {"content": "咦——", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#7$2"}, {"id": 296, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#8$1", "focus": "m"}}, {"id": 297, "prop": "name", "attributes": {"content": "听吾之命——", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#8$1"}, {"id": 298, "prop": "dialog", "attributes": {}}, {"id": 299, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 300, "prop": "PlaySound", "attributes": {"key": "$d_avg_purifymagic", "volume": 1.0, "channel": "5"}}, {"id": 301, "prop": "bgeffect", "attributes": {"name": "$eb_light", "layer": 1.0}}, {"id": 302, "prop": "StopSound", "attributes": {"channel": "5", "fadetime": 2.5}}, {"id": 303, "prop": "delay", "attributes": {"time": 4.0}}, {"id": 304, "prop": "PlaySound", "attributes": {"key": "$d_avg_magicchange", "volume": 1.0}}, {"id": 305, "prop": "bgeffect", "attributes": {"duration": 3.0}}, {"id": 306, "prop": "charslot", "attributes": {}}, {"id": 307, "prop": "name", "attributes": {"content": "“御轮”的光芒在达到顶点的瞬间，毫无征兆地熄灭了。天地间仿佛被抽走了声音和色彩，陷入一片死寂。"}}, {"id": 308, "prop": "name", "attributes": {"content": "纯白色的“门”眨眼间变成了黑色，紧接着，一股更加深沉的黑暗从这道“门”中喷涌而出。"}}, {"id": 309, "prop": "dialog", "attributes": {}}, {"id": 310, "prop": "PlaySound", "attributes": {"key": "$d_avg_snarl_1", "volume": 1.0}}, {"id": 311, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2105_1#1$1", "afrom": 0.0, "ato": 1.0, "duration": 1.5}}, {"id": 312, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 313, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#7$2", "focus": "m"}}, {"id": 314, "prop": "playMusic", "attributes": {"intro": "$plot_intro", "key": "$plot_loop", "volume": 0.6}}, {"id": 315, "prop": "name", "attributes": {"content": "这家伙......长得像牙兽，但又根本不是牙兽......到底是怎么回事？！", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#7$2"}, {"id": 316, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#5$1", "focus": "m"}}, {"id": 317, "prop": "name", "attributes": {"content": "咒鬼......为什么咒鬼会出现在这里？！", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#5$1"}, {"id": 318, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#8$2", "focus": "m"}}, {"id": 319, "prop": "name", "attributes": {"content": "咒鬼？！", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#8$2"}, {"id": 320, "prop": "dialog", "attributes": {}}, {"id": 321, "prop": "charslot", "attributes": {}}, {"id": 322, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#4$2", "focus": "m", "duration": 0.4}}, {"id": 323, "prop": "PlaySound", "attributes": {"key": "$MHR_caxe_creek", "volume": 1.0}}, {"id": 324, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 325, "prop": "name", "attributes": {"content": "月见夜，到底怎么回事？！", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#4$2"}, {"id": 326, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#10$1", "focus": "m"}}, {"id": 327, "prop": "name", "attributes": {"content": "咒鬼是禁忌......", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#10$1"}, {"id": 328, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#10$1", "focus": "m"}}, {"id": 329, "prop": "name", "attributes": {"content": "在泡影国的历史上，曾经发生过一次巨大的灾难，在那次灾难之中，被“诅咒”侵染的狼群毁灭了曾经的泡影国。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#10$1"}, {"id": 330, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#10$1", "focus": "m"}}, {"id": 331, "prop": "name", "attributes": {"content": "这些被“诅咒”侵染的狼，正是咒鬼。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#10$1"}, {"id": 332, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#10$1", "focus": "m"}}, {"id": 333, "prop": "name", "attributes": {"content": "从那次灾难中幸存下来的先祖们，在重新建立了泡影国之后，将周边的狼狩猎殆尽......", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#10$1"}, {"id": 334, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#4$2", "focus": "m"}}, {"id": 335, "prop": "name", "attributes": {"content": "狼......你是说牙兽？", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#4$2"}, {"id": 336, "prop": "dialog", "attributes": {}}, {"id": 337, "prop": "charslot", "attributes": {}}, {"id": 338, "prop": "dialog", "attributes": {}}, {"id": 339, "prop": "PlaySound", "attributes": {"key": "$d_avg_snarl_1", "volume": 1.0}}, {"id": 340, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2105_1#1$1", "afrom": 0.0, "ato": 1.0, "duration": 1.5}}, {"id": 341, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2105_1#1$1", "afrom": 0.0, "ato": 1.0, "duration": 1.5}}, {"id": 342, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 343, "prop": "charslot", "attributes": {}}, {"id": 344, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#8$2", "focus": "m"}}, {"id": 345, "prop": "name", "attributes": {"content": "宝巫迦，这门里还在不断往外涌出咒鬼，不能想想办法吗？！", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#8$2"}, {"id": 346, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#6$1", "focus": "m"}}, {"id": 347, "prop": "name", "attributes": {"content": "吾做不到！", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#6$1"}, {"id": 348, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#6$1", "focus": "m"}}, {"id": 349, "prop": "name", "attributes": {"content": "有什么东西在阻止它关上！", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#6$1"}, {"id": 350, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#9$1", "focus": "m"}}, {"id": 351, "prop": "name", "attributes": {"content": "这些咒鬼......它们的存在就预示着灾祸，难道是吾将它们召来——", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#9$1"}, {"id": 352, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#5$2", "focus": "m"}}, {"id": 353, "prop": "name", "attributes": {"content": "别慌神，这不是你的错，宝巫迦！", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#5$2"}, {"id": 354, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#10$1", "focus": "m"}}, {"id": 355, "prop": "name", "attributes": {"content": "没错，陛下，您的行动没有丝毫问题！一定是有其他东西——", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#10$1"}, {"id": 356, "prop": "dialog", "attributes": {}}, {"id": 357, "prop": "charslot", "attributes": {}}, {"id": 358, "prop": "dialog", "attributes": {}}, {"id": 359, "prop": "PlaySound", "attributes": {"key": "$MHR_skillroar_hyper", "volume": 1.0}}, {"id": 360, "prop": "delay", "attributes": {"time": 3.0}}, {"id": 361, "prop": "Dialog", "attributes": {}}, {"id": 362, "prop": "name", "attributes": {"content": "众人惊恐地抬头望去，只见远方的山崖之上，一头通体覆盖着青色鳞甲、周身缠绕着青白色雷电的巨兽，正昂首发出咆哮。"}}, {"id": 363, "prop": "name", "attributes": {"content": "它站在高高的山崖上，睥睨正在发生的一切。"}}, {"id": 364, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#7$2", "focus": "m"}}, {"id": 365, "prop": "name", "attributes": {"content": "“雷之主”？！", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#7$2"}, {"id": 366, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#5$2", "focus": "m"}}, {"id": 367, "prop": "name", "attributes": {"content": "这家伙，难道说是它影响了“御轮”？！", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#5$2"}, {"id": 368, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#5$1", "focus": "m"}}, {"id": 369, "prop": "name", "attributes": {"content": "“雷之主”，难道是你......你一直都在等待着这一刻吗？", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#5$1"}, {"id": 370, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#5$1", "focus": "m"}}, {"id": 371, "prop": "name", "attributes": {"content": "你之所以没有来干扰吾的狩猎，是因为你一直都在等待吾启动“御轮”的这一刻，是吗？！", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#5$1"}, {"id": 372, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#6$1", "focus": "m"}}, {"id": 373, "prop": "name", "attributes": {"content": "回答吾！", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#6$1"}, {"id": 374, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#6$1", "focus": "m"}}, {"id": 375, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 10.0, "ystrength": 12.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 376, "prop": "name", "attributes": {"content": "回答吾——！！！！", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#6$1"}, {"id": 377, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#10$1", "focus": "m"}}, {"id": 378, "prop": "name", "attributes": {"content": "陛下，不可莽撞！", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#10$1"}, {"id": 379, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#6$1", "focus": "m"}}, {"id": 380, "prop": "name", "attributes": {"content": "“雷之主”正在破坏“试炼”！", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#6$1"}, {"id": 381, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#6$1", "focus": "m"}}, {"id": 382, "prop": "name", "attributes": {"content": "难道就算这样你也要阻止吾吗，月见夜？！", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#6$1"}, {"id": 383, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#7$1", "focus": "m"}}, {"id": 384, "prop": "name", "attributes": {"content": "我——", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#7$1"}, {"id": 385, "prop": "dialog", "attributes": {}}, {"id": 386, "prop": "charslot", "attributes": {}}, {"id": 387, "prop": "PlaySound", "attributes": {"key": "$bigbell", "volume": 3.0}}, {"id": 388, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 389, "prop": "name", "attributes": {"content": "突然，嘹亮且急促的钟声自远处的山脚下传来。"}}, {"id": 390, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#5$2", "focus": "m"}}, {"id": 391, "prop": "name", "attributes": {"content": "什么声音？！", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#5$2"}, {"id": 392, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyC_1#1$2", "focus": "m"}}, {"id": 393, "prop": "PlaySound", "attributes": {"key": "$MHR_cat_voice2", "volume": 1.0}}, {"id": 394, "prop": "name", "attributes": {"content": "这是警报喵！", "name": "政宗"}, "figure_art": "avg_4215_buddyC_1#1$2"}, {"id": 395, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#2$1", "focus": "m"}}, {"id": 396, "prop": "name", "attributes": {"content": "这是狩猎团的紧急警报......平时是不会敲响这道警报的，除非——", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#2$1"}, {"id": 397, "prop": "dialog", "attributes": {}}, {"id": 398, "prop": "charslot", "attributes": {}}, {"id": 399, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0}}, {"id": 400, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2111_1#1$1", "focus": "m", "duration": 1.0}}, {"id": 401, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 402, "prop": "name", "attributes": {"content": "\t将军，大事不好！", "name": "武士"}, "figure_art": "avg_npc_2111_1#1$1"}, {"id": 403, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2111_1#1$1", "focus": "m"}}, {"id": 404, "prop": "name", "attributes": {"content": "\t从“御轮”方向的雪山脚下和竹林中涌出了大量被“诅咒”侵染的野兽。", "name": "武士"}, "figure_art": "avg_npc_2111_1#1$1"}, {"id": 405, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2111_1#1$1", "focus": "m"}}, {"id": 406, "prop": "name", "attributes": {"content": "\t它们正在靠近都城！", "name": "武士"}, "figure_art": "avg_npc_2111_1#1$1"}, {"id": 407, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#10$1", "focus": "m"}}, {"id": 408, "prop": "name", "attributes": {"content": "传令下去，让狩猎团立刻组织防线，无论如何，不能让野兽们靠近都城！", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#10$1"}, {"id": 409, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2111_1#1$1", "focus": "m"}}, {"id": 410, "prop": "name", "attributes": {"content": "\t将军您呢？我们需要您的指挥！", "name": "武士"}, "figure_art": "avg_npc_2111_1#1$1"}, {"id": 411, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#10$1", "focus": "m"}}, {"id": 412, "prop": "name", "attributes": {"content": "我——我会立刻返回都城。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#10$1"}, {"id": 413, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2111_1#1$1", "focus": "m"}}, {"id": 414, "prop": "name", "attributes": {"content": "\t是！", "name": "武士"}, "figure_art": "avg_npc_2111_1#1$1"}, {"id": 415, "prop": "dialog", "attributes": {}}, {"id": 416, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 417, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0}}, {"id": 418, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 419, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#9$2", "focus": "m"}}, {"id": 420, "prop": "name", "attributes": {"content": "这家伙，不仅拦住了我们回家的路，还从门里召唤了兽群......但是，为什么它会——", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$2"}, {"id": 421, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#9$2", "focus": "m"}}, {"id": 422, "prop": "name", "attributes": {"content": "管不了这些了，擒贼先擒王！", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#9$2"}, {"id": 423, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#9$2", "focus": "m"}}, {"id": 424, "prop": "name", "attributes": {"content": "“雷之主”是这些野兽的首领对吧？宝巫迦，我们现在立刻杀到它面前，把它解决掉吧！", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#9$2"}, {"id": 425, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#11$1", "focus": "m"}}, {"id": 426, "prop": "name", "attributes": {"content": "吾......", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#11$1"}, {"id": 427, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#6$2", "focus": "m"}}, {"id": 428, "prop": "name", "attributes": {"content": "宝巫迦？", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#6$2"}, {"id": 429, "prop": "dialog", "attributes": {}}, {"id": 430, "prop": "charslot", "attributes": {}}, {"id": 431, "prop": "name", "attributes": {"content": "空爆走到宝巫迦身前拉住她，却发现她纹丝不动。"}}, {"id": 432, "prop": "name", "attributes": {"content": "她这才看到宝巫迦的表情——"}}, {"id": 433, "prop": "name", "attributes": {"content": "咬牙切齿，却又无可奈何。"}}, {"id": 434, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#9$2", "focus": "m"}}, {"id": 435, "prop": "name", "attributes": {"content": "空爆，别说傻话。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$2"}, {"id": 436, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#9$2", "focus": "m"}}, {"id": 437, "prop": "name", "attributes": {"content": "你怎么保证自己杀到它面前之前，泡影国不会先被咒鬼们消灭？", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$2"}, {"id": 438, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#12$2", "focus": "m"}}, {"id": 439, "prop": "name", "attributes": {"content": "但是从门里冒出的黑不溜秋的家伙根本没完没了啊！", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#12$2"}, {"id": 440, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#12$2", "focus": "m"}}, {"id": 441, "prop": "name", "attributes": {"content": "趁现在解决它是最好的办法吧，谁知道它等会儿又会跑到哪里去！", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#12$2"}, {"id": 442, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#9$2", "focus": "m"}}, {"id": 443, "prop": "name", "attributes": {"content": "别忘了，只有宝巫迦能够消除“诅咒”。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$2"}, {"id": 444, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#8$2", "focus": "m"}}, {"id": 445, "prop": "name", "attributes": {"content": "——啊啊啊啊，可恶！怎么这么麻烦！“雷之主”这个混蛋！", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#8$2"}, {"id": 446, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#9$2", "focus": "m"}}, {"id": 447, "prop": "name", "attributes": {"content": "至少，在找到一个合适的方法前，我们不能拿泡影国的安危开玩笑。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$2"}, {"id": 448, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#13$2", "focus": "m"}}, {"id": 449, "prop": "name", "attributes": {"content": "可是——", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#13$2"}, {"id": 450, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#12$2", "focus": "m"}}, {"id": 451, "prop": "name", "attributes": {"content": "“雷之主”就在那里！错过这个机会，下次不知道是什么时候了！", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#12$2"}, {"id": 452, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#10$1", "focus": "m"}}, {"id": 453, "prop": "name", "attributes": {"content": "在过去，我阻止陛下狩猎“雷之主”，归根结底，是因为它尚未对我们露出獠牙。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#10$1"}, {"id": 454, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#10$1", "focus": "m"}}, {"id": 455, "prop": "name", "attributes": {"content": "然而，“雷之主”既然已经成为这次灾难的源头，陛下想要讨伐它，我也不好阻拦。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#10$1"}, {"id": 456, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#9$1", "focus": "m"}}, {"id": 457, "prop": "name", "attributes": {"content": "但是......", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#9$1"}, {"id": 458, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 459, "prop": "name", "attributes": {"content": "不用说了。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 460, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 461, "prop": "name", "attributes": {"content": "梓兰小姐说得对。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 462, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#6$1", "focus": "m"}}, {"id": 463, "prop": "name", "attributes": {"content": "吾是一国之主，即使吾现在杀到它面前，泡影国若是在那之前毁灭，一切又有什么意义？", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#6$1"}, {"id": 464, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#6$1", "focus": "m"}}, {"id": 465, "prop": "name", "attributes": {"content": "回城，准备应对兽潮。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#6$1"}, {"id": 466, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2101_1#9$1", "focus": "m"}}, {"id": 467, "prop": "name", "attributes": {"content": "陛下英明。", "name": "月见夜"}, "figure_art": "avg_npc_2101_1#9$1"}, {"id": 468, "prop": "dialog", "attributes": {}}, {"id": 469, "prop": "charslot", "attributes": {}}, {"id": 470, "prop": "name", "attributes": {"content": "宝巫迦转身向都城走去。"}}, {"id": 471, "prop": "name", "attributes": {"content": "转身前，她深深地看了一眼远处山头上的“雷之主”。"}}, {"id": 472, "prop": "name", "attributes": {"content": "像是要将它的样子刻入灵魂之中。"}}, {"id": 473, "prop": "Dialog", "attributes": {}}, {"id": 474, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 475, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 476, "prop": "bgeffect", "attributes": {}}, {"id": 477, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 478, "prop": "Image", "attributes": {}}, {"id": 479, "prop": "charslot", "attributes": {}}], "OPTIONTRACE": true}