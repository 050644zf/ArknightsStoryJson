y": "$MHR_dog_voice3", "volume": 1.0}}, {"id": 94, "prop": "PlaySound", "attributes": {"key": "$MHR_dog_attack", "volume": 1.0}}, {"id": 95, "prop": "PlaySound", "attributes": {"key": "$MHR_hit_slash_arrow", "volume": 1.0}}, {"id": 96, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 97, "prop": "Blocker", "attributes": {"a": 1.0, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 0.05, "block": "true"}}, {"id": 98, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.3, "block": "true"}}, {"id": 99, "prop": "delay", "attributes": {"time": 0.6}}, {"id": 100, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2112_1#1$1"}}, {"id": 101, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 102, "prop": "PlaySound", "attributes": {"key": "$bodyfalldown1", "volume": 1.0}}, {"id": 103, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 104, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 105, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyD_1#1$1", "focus": "m", "duration": 1.0}}, {"id": 106, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 107, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2a_1#7$1", "focus": "m"}}, {"id": 108, "prop": "name", "attributes": {"content": "义经？！", "name": "空爆"}, "figure_art": "avg_1049_catap2a_1#7$1"}, {"id": 109, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyD_1#1$5", "focus": "m"}}, {"id": 110, "prop": "PlaySound", "attributes": {"key": "$MHR_dog_voice3"}}, {"id": 111, "prop": "name", "attributes": {"content": "（不耐烦的低吼）", "name": "义经"}, "figure_art": "avg_4215_buddyD_1#1$5"}, {"id": 112, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2a_1#9$1", "focus": "m"}}, {"id": 113, "prop": "name", "attributes": {"content": "好吧，看来你的性格跟我差不多——别想独自抢走所有风头！", "name": "空爆"}, "figure_art": "avg_1049_catap2a_1#9$1"}, {"id": 114, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2a_1#9$1", "focus": "m"}}, {"id": 115, "prop": "name", "attributes": {"content": "要不来比一比谁解决的多吧？", "name": "空爆"}, "figure_art": "avg_1049_catap2a_1#9$1"}, {"id": 116, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyD_1#1$5", "focus": "m"}}, {"id": 117, "prop": "PlaySound", "attributes": {"key": "$MHR_dog_voice3"}}, {"id": 118, "prop": "name", "attributes": {"content": "（不屑的低吼）", "name": "义经"}, "figure_art": "avg_4215_buddyD_1#1$5"}, {"id": 119, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2a_1#9$1", "focus": "m"}}, {"id": 120, "prop": "name", "attributes": {"content": "嘿，这要是在火山，我可能就要慌了，但是，我已经吃过亏了！", "name": "空爆"}, "figure_art": "avg_1049_catap2a_1#9$1"}, {"id": 121, "prop": "dialog", "attributes": {}}, {"id": 122, "prop": "charslot", "attributes": {}}, {"id": 123, "prop": "dialog", "attributes": {}}, {"id": 124, "prop": "charslot", "attributes": {}}, {"id": 125, "prop": "Effect", "attributes": {"name": "$e_spark_01_mid", "layer": 1.0}}, {"id": 126, "prop": "playsound", "attributes": {"key": "$MHR_caxe_switch"}}, {"id": 127, "prop": "playsound", "attributes": {"key": "$MHR_drawsword_finish"}}, {"id": 128, "prop": "CameraShake", "attributes": {"duration": 0.2, "ystrength": 40.0, "xstrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 129, "prop": "delay", "attributes": {"time": 0.3}}, {"id": 130, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#12$2", "focus": "m", "duration": 1.0}}, {"id": 131, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 132, "prop": "charslot", "attributes": {}}, {"id": 133, "prop": "name", "attributes": {"content": "空爆迅速地将盾斧形态切换回剑盾形态，与她僵持的钳兽失去了角力的对象，瞬间扑了个空。"}}, {"id": 134, "prop": "dialog", "attributes": {}}, {"id": 135, "prop": "playsound", "attributes": {"key": "$MHR_caxe_insect"}}, {"id": 136, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 137, "