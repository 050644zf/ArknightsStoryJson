0,0", "duration": 1.5}}, {"id": 20, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 21, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovement"}}, {"id": 22, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "-200,0", "posto": "0,0", "duration": 1.5}}, {"id": 23, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 24, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_282_catap_1#5$1", "focus": "r", "duration": 1.0}}, {"id": 25, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 26, "prop": "name", "attributes": {"content": "呃，你们在干嘛呢？", "name": "空爆"}, "figure_art": "avg_282_catap_1#5$1"}, {"id": 27, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2106_1#1$1", "focus": "l"}}, {"id": 28, "prop": "name", "attributes": {"content": "是“异兽猎人”阁下啊。", "name": "搬运的武士"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 29, "prop": "name", "attributes": {"content": "我们正在把这具熔火蜗的尸体运往宫中。", "name": "搬运的武士"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 30, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_282_catap_1#8$1", "focus": "r"}}, {"id": 31, "prop": "name", "attributes": {"content": "不是要把它的壳做成什么炭吗，为什么要把它搬到宫里去？", "name": "空爆"}, "figure_art": "avg_282_catap_1#8$1"}, {"id": 32, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2106_1#1$1", "focus": "l"}}, {"id": 33, "prop": "name", "attributes": {"content": "因为它的肉经过陛下的净化，还可以成为食材。", "name": "搬运的武士"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 34, "prop": "name", "attributes": {"content": "而且，这十年来，由于“雷之主”的存在，我们能够狩猎的范围越来越小，哪怕是一点食物，我们也不能浪费。", "name": "搬运的武士"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 35, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_282_catap_1#5$1", "focus": "r"}}, {"id": 36, "prop": "name", "attributes": {"content": "净化？泡......宝巫迦陛下真的能做到这种事吗？", "name": "空爆"}, "figure_art": "avg_282_catap_1#5$1"}, {"id": 37, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2106_1#1$1", "focus": "l"}}, {"id": 38, "prop": "name", "attributes": {"content": "没错，这也是陛下之所以是陛下的原因。", "name": "搬运的武士"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 39, "prop": "name", "attributes": {"content": "有些事，只有陛下才能做到。", "name": "搬运的武士"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 40, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_282_catap_1#9$1", "focus": "r"}}, {"id": 41, "prop": "name", "attributes": {"content": "也就是说，你们现在正要把这具尸体拿去让陛下净化？", "name": "空爆"}, "figure_art": "avg_282_catap_1#9$1"}, {"id": 42, "prop": "name", "attributes": {"content": "我能去看看是怎么净化的吗？", "name": "空爆"}, "figure_art": "avg_282_catap_1#9$1"}, {"id": 43, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2106_1#1$1", "focus": "l"}}, {"id": 44, "prop": "name", "attributes": {"content": "......抱歉，陛下进行净化的场所，是祭祀重地，即使是“异兽猎人”，也不能轻易进入。", "name": "搬运的武士"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 45, "prop": "name", "attributes": {"content": "如果您真的想知道，请去向将军阁下或者陛下本人获得许可吧。", "name": "搬运的武士"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 46, "prop": "name", "attributes": {"content": "别发呆，继续，陛下还在等着我们呢！", "name": "搬运的武士"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 47, "prop": "Dialog", "attributes": {}}, {"id": 48, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0, "channel": "1"}}, {"id": 49, "prop": "StopSound", "attributes": {"channel": "1", "fadetime": 1.5}}, {"id": 50, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "0,0", "posto": "300,0", "duration": 1.5, "afrom": 1.0, "ato": 0.0, "focus": "l"}}, {"id": 51, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 52, "prop": "charslot", "attributes": {}}, {"id": 53, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#8$1", "focus": "m"}}, {"id": 54, "prop": "name", "attributes": {"content": "嘁，你们的陛下在准备净化，你们的将军，呃，反正我也不知道在哪......这不就是不让我看的意思嘛。", "name": "空爆"}, "figure_art": "avg_282_catap_1#8$1"}, {"id": 55, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#9$1", "focus": "m"}}, {"id": 56, "prop": "name", "attributes": {"content": "哼，你们不让我看，我非要看。", "name": "空爆"}, "figure_art": "avg_282_catap_1#9$1"}, {"id": 57, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#1$1", "focus": "m"}}, {"id": 58, "prop": "name", "attributes": {"content": "我倒要搞清楚，这个地方到底是怎么一回事！", "name": "空爆"}, "figure_art": "avg_282_catap_1#1$1"}, {"id": 59, "prop": "Dialog", "attributes": {}}, {"id": 60, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 61, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 62, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 63, "prop": "Dialog", "attributes": {}}, {"id": 64, "prop": "charslot", "attributes": {}}, {"id": 65, "prop": "Background", "attributes": {"image": "71_g1_impermanence_street", "screenadapt": "coverall"}}, {"id": 66, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 67, "prop": "PlayMusic", "attributes": {"key": "$normal_loop", "volume": 0.6}}, {"id": 68, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 69, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 70, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#2", "focus": "m"}}, {"id": 71, "prop": "name", "attributes": {"content": "......", "name": "梓兰"}, "figure_art": "char_278_orchid_1#2"}, {"id": 72, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#5", "focus": "m"}}, {"id": 73, "prop": "name", "attributes": {"content": "（假设我的行为在监控之下，那么刚才我看到的那一切都是演戏吗？）", "name": "梓兰"}, "figure_art": "char_278_orchid_1#5"}, {"id": 74, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#1", "focus": "m"}}, {"id": 75, "prop": "name", "attributes": {"content": "（有什么方法能找到这里的漏洞呢......）", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 76, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#1", "focus": "m"}}, {"id": 77, "prop": "name", "attributes": {"content": "（咦，这么说来，这里好像不是一座移动城市？）", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 78, "prop": "Dialog", "attributes": {}}, {"id": 79, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 80, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "0,0", "posto": "150,0", "duration": 1.5, "afrom": 1.0, "ato": 0.0}}, {"id": 81, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 82, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#1", "posfrom": "-150,0", "posto": "0,0", "duration": 1.5, "afrom": 0.0, "ato": 1.0}}, {"id": 83, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2108_1#1$1"}}, {"id": 84, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 85, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#1", "focus": "l"}}, {"id": 86, "prop": "name", "attributes": {"content": "请问，这座城市可以移动吗？", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 87, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2108_1#1$1", "focus": "r"}}, {"id": 88, "prop": "name", "attributes": {"content": "“异兽猎人”阁下，您这个问题真是够奇怪的。", "name": "泡影国百姓A"}, "figure_art": "avg_npc_2108_1#1$1"}, {"id": 89, "prop": "name", "attributes": {"content": "城市怎么会移动呢？打我记事以来，我已经看着这座“御轮”几十年啦。", "name": "泡影国百姓A"}, "figure_art": "avg_npc_2108_1#1$1"}, {"id": 90, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#3", "focus": "l"}}, {"id": 91, "prop": "name", "attributes": {"content": "......没有移动城市，那你们怎么应付天灾？", "name": "梓兰"}, "figure_art": "char_278_orchid_1#3"}, {"id": 92, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2108_1#1$1", "focus": "r"}}, {"id": 93, "prop": "name", "attributes": {"content": "天灾？天灾又是什么？", "name": "泡影国百姓A"}, "figure_art": "avg_npc_2108_1#1$1"}, {"id": 94, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#2", "focus": "l"}}, {"id": 95, "prop": "name", "attributes": {"content": "天灾就是，呃，类似“异兽”一样的灾难？", "name": "梓兰"}, "figure_art": "char_278_orchid_1#2"}, {"id": 96, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2108_1#1$1", "focus": "r"}}, {"id": 97, "prop": "name", "attributes": {"content": "没听说过。", "name": "泡影国百姓A"}, "figure_art": "avg_npc_2108_1#1$1"}, {"id": 98, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#3", "focus": "l"}}, {"id": 99, "prop": "name", "attributes": {"content": "你们这里的人从没得过矿石病？", "name": "梓兰"}, "figure_art": "char_278_orchid_1#3"}, {"id": 100, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2108_1#1$1", "focus": "r"}}, {"id": 101, "prop": "name", "attributes": {"content": "矿石病？", "name": "泡影国百姓A"}, "figure_art": "avg_npc_2108_1#1$1"}, {"id": 102, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#1", "focus": "l"}}, {"id": 103, "prop": "name", "attributes": {"content": "就是身上会长石头的病——", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 104, "prop": "Dialog", "attributes": {}}, {"id": 105, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 106, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 107, "prop": "charslot", "attributes": {}}, {"id": 108, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 50.0, "ystrength": 60.0, "vibrato": 70.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 109, "prop": "Blocker", "attributes": {"a": 0.7, "r": 0.95, "g": 0.95, "b": 0.95, "fadetime": 0.02, "block": "true"}}, {"id": 110, "prop": "PlaySound", "attributes": {"key": "$d_sp_ballista"}}, {"id": 111, "prop": "PlaySound", "attributes": {"key": "$d_avg_statuecollapse", "volume": 1.0}}, {"id": 112, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.95, "g": 0.95, "b": 0.95, "fadetime": 0.25, "block": "true"}}, {"id": 113, "prop": "name", "attributes": {"content": "......嘭！"}}, {"id": 114, "prop": "name", "attributes": {"content": "远处的房舍突然传出一声巨响，奇形怪状的竹制器物被抛到了半空之中。"}}, {"id": 115, "prop": "name", "attributes": {"content": "一把铳炮一样的物体猛然坠落，带着火花滑行到众人脚边。"}}, {"id": 116, "prop": "name", "attributes": {"content": "接着是缓缓飘落的屋顶......"}}, {"id": 117, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 118, "prop": "PlayMusic", "attributes": {"intro": "$nervous_intro", "key": "$nervous_loop", "volume": 0.6}}, {"id": 119, "prop": "charslot", "attributes": {}}, {"id": 120, "prop": "Dialog", "attributes": {}}, {"id": 121, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0}}, {"id": 122, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2109_1#1$1", "duration": 1.5, "afrom": 0.0, "ato": 1.0}}, {"id": 123, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 124, "prop": "charslot", "attributes": {}}, {"id": 125, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#3", "focus": "m"}}, {"id": 126, "prop": "name", "attributes": {"content": "怎么了？", "name": "梓兰"}, "figure_art": "char_278_orchid_1#3"}, {"id": 127, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2109_1#1$1", "focus": "m"}}, {"id": 128, "prop": "name", "attributes": {"content": "呼，呼——快、快来人，不好了！斑弥罗大人的工坊爆炸了！", "name": "工坊学徒"}, "figure_art": "avg_npc_2109_1#1$1"}, {"id": 129, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2108_1#1$1", "focus": "m"}}, {"id": 130, "prop": "name", "attributes": {"content": "斑弥罗大人不是天天都会搞些动静出来吗，放着他不管就好吧。", "name": "泡影国百姓A"}, "figure_art": "avg_npc_2108_1#1$1"}, {"id": 131, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2109_1#1$1", "focus": "m"}}, {"id": 132, "prop": "name", "attributes": {"content": "不一样，他今天去仓库里取了一些熔火蜗的壳，说是要做个大家伙。", "name": "工坊学徒"}, "figure_art": "avg_npc_2109_1#1$1"}, {"id": 133, "prop": "name", "attributes": {"content": "结果，结果——他现在身上插了好几块石头！快去帮帮他！", "name": "工坊学徒"}, "figure_art": "avg_npc_2109_1#1$1"}, {"id": 134, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#3", "focus": "m"}}, {"id": 135, "prop": "name", "attributes": {"content": "（......等等，熔火蜗的壳，那不就是源石虫背上的源石结晶吗！如果那些源石结晶爆炸的话——）", "name": "梓兰"}, "figure_art": "char_278_orchid_1#3"}, {"id": 136, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#4", "focus": "m"}}, {"id": 137, "prop": "name", "attributes": {"content": "（我真是个蠢材，刚才看到那些熔火蜗尸体的时候就该想到的！）", "name": "梓兰"}, "figure_art": "char_278_orchid_1#4"}, {"id": 138, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#2", "focus": "m"}}, {"id": 139, "prop": "name", "attributes": {"content": "（如果是源石爆炸......）", "name": "梓兰"}, "figure_art": "char_278_orchid_1#2"}, {"id": 140, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#1", "focus": "m"}}, {"id": 141, "prop": "name", "attributes": {"content": "（啧，他会死的！）", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 142, "prop": "Dialog", "attributes": {}}, {"id": 143, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 144, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 145, "prop": "Dialog", "attributes": {}}, {"id": 146, "prop": "charslot", "attributes": {}}, {"id": 147, "prop": "Background", "attributes": {"image": "71_g2_impermanence_room", "screenadapt": "coverall"}}, {"id": 148, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0}}, {"id": 149, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 150, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 151, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 152, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2103_1#1$1", "focus": "r"}}, {"id": 153, "prop": "name", "attributes": {"content": "疼疼疼......", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 154, "prop": "Dialog", "attributes": {}}, {"id": 155, "prop": "PlaySound", "attributes": {"key": "$d_avg_open_door", "volume": 1.0}}, {"id": 156, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#1", "posfrom": "-150,0", "posto": "0,0", "duration": 1.5, "afrom": 0.0, "ato": 1.0}}, {"id": 157, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 158, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#1", "focus": "l"}}, {"id": 159, "prop": "name", "attributes": {"content": "斑点！", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 160, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2103_1#1$1", "focus": "r"}}, {"id": 161, "prop": "name", "attributes": {"content": "我是斑弥罗！疼疼......", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 162, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#3", "focus": "l"}}, {"id": 163, "prop": "name", "attributes": {"content": "你没事吧！", "name": "梓兰"}, "figure_art": "char_278_orchid_1#3"}, {"id": 164, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2103_1#1$1", "focus": "r"}}, {"id": 165, "prop": "name", "attributes": {"content": "给铳枪加个压，没想到这玩意这么不经折腾。", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 166, "prop": "name", "attributes": {"content": "本来以为“火竹炭”当作弹药应该还挺坚硬的，结果一开火就碎开了，炸得到处都是......", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 167, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#1", "focus": "l"}}, {"id": 168, "prop": "name", "attributes": {"content": "让我看看！", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 169, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2103_1#1$1", "focus": "r"}}, {"id": 170, "prop": "name", "attributes": {"content": "啊？这有什么好看的，小伤而已。我早就习惯了——哎，疼，你轻点！", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 171, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#1", "focus": "l"}}, {"id": 172, "prop": "multiline", "attributes": {"name": "梓兰", "content": "小伤？！这可是源石爆......"}}, {"id": 173, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 174, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#3", "focus": "l"}}, {"id": 175, "prop": "multiline", "attributes": {"name": "梓兰", "content": "炸......？"}}, {"id": 176, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#3", "focus": "l"}}, {"id": 177, "prop": "name", "attributes": {"content": "梓兰认真看了一眼地上的结晶碎片。"}}, {"id": 178, "prop": "name", "attributes": {"content": "多年的经验让她已经能够一眼判断出一块结晶是不是源石结晶。"}}, {"id": 179, "prop": "PlayMusic", "attributes": {"key": "$normal_loop", "volume": 0.6}}, {"id": 180, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#5", "focus": "l"}}, {"id": 181, "prop": "name", "attributes": {"content": "这些......是普通的结晶，不是源石......？", "name": "梓兰"}, "figure_art": "char_278_orchid_1#5"}, {"id": 182, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2103_1#1$1", "focus": "r"}}, {"id": 183, "prop": "name", "attributes": {"content": "源石是什么？", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 184, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#1", "focus": "l"}}, {"id": 185, "prop": "name", "attributes": {"content": "源石虫的背上应该有大量的源石结晶，如果被那些结晶划伤，应该会加重你的矿石病——", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 186, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2103_1#1$1", "focus": "r"}}, {"id": 187, "prop": "name", "attributes": {"content": "矿石病？那又是什么？", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 188, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#3", "focus": "l"}}, {"id": 189, "prop": "name", "attributes": {"content": "......？！", "name": "梓兰"}, "figure_art": "char_278_orchid_1#3"}, {"id": 190, "prop": "Dialog", "attributes": {}}, {"id": 191, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "0,0", "posto": "150,0", "duration": 1.0}}, {"id": 192, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 193, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2103_1#1$1", "focus": "r"}}, {"id": 194, "prop": "name", "attributes": {"content": "喂，你要干什么？！", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 195, "prop": "name", "attributes": {"content": "别靠近我，我要喊人了——", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 196, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 50.0, "ystrength": 50.0, "vibrato": 60.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 197, "prop": "name", "attributes": {"content": "救命啊——", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 198, "prop": "Dialog", "attributes": {}}, {"id": 199, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#1"}}, {"id": 200, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2103_1#1$1"}}, {"id": 201, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 60.0, "randomness": 10.0, "fadeout": "true", "block": "false"}}, {"id": 202, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovement"}}, {"id": 203, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 204, "prop": "name", "attributes": {"content": "梓兰猛地掀开斑弥罗的上衣。"}}, {"id": 205, "prop": "name", "attributes": {"content": "梓兰知道，在斑点肚脐眼旁边，应该有两块突出的源石结晶。"}}, {"id": 206, "prop": "name", "attributes": {"content": "但是，斑弥罗的肚子上，只有长得很健康的毛发。"}}, {"id": 207, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#1", "focus": "l"}}, {"id": 208, "prop": "name", "attributes": {"content": "你的身上有没有长一种石头？", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 209, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2103_1#1$1", "focus": "r"}}, {"id": 210, "prop": "name", "attributes": {"content": "没有。", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 211, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#5", "focus": "l"}}, {"id": 212, "prop": "name", "attributes": {"content": "......", "name": "梓兰"}, "figure_art": "char_278_orchid_1#5"}, {"id": 213, "prop": "name", "attributes": {"content": "难道你真的不是斑点？", "name": "梓兰"}, "figure_art": "char_278_orchid_1#5"}, {"id": 214, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2103_1#1$1", "focus": "r"}}, {"id": 215, "prop": "name", "attributes": {"content": "我早就说过了，我叫斑弥罗！", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 216, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#4", "focus": "l"}}, {"id": 217, "prop": "name", "attributes": {"content": "怎么可能......", "name": "梓兰"}, "figure_art": "char_278_orchid_1#4"}, {"id": 218, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2103_1#1$1", "focus": "r"}}, {"id": 219, "prop": "name", "attributes": {"content": "你这么信誓旦旦，连我都要怀疑我是不是其实叫斑点了......", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 220, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#1", "focus": "l"}}, {"id": 221, "prop": "name", "attributes": {"content": "对了，还有一种可能性......", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 222, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#3", "focus": "l"}}, {"id": 223, "prop": "name", "attributes": {"content": "你是去拿了一袋熔火蜗背上的石头，对吧？", "name": "梓兰"}, "figure_art": "char_278_orchid_1#3"}, {"id": 224, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2103_1#1$1", "focus": "r"}}, {"id": 225, "prop": "name", "attributes": {"content": "那又怎么了？", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 226, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#1", "focus": "l"}}, {"id": 227, "prop": "name", "attributes": {"content": "那些石头存放的仓库在哪？", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 228, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2103_1#1$1", "focus": "r"}}, {"id": 229, "prop": "name", "attributes": {"content": "宫廷侧面，那座比较高的屋子。", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 230, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#1", "focus": "l"}}, {"id": 231, "prop": "name", "attributes": {"content": "我知道了。", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 232, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#5", "focus": "l"}}, {"id": 233, "prop": "name", "attributes": {"content": "（没错，还有一种可能性——）", "name": "梓兰"}, "figure_art": "char_278_orchid_1#5"}, {"id": 234, "prop": "name", "attributes": {"content": "（将熔火蜗，也就是源石虫的尸体收集起来，不是为了什么做成“火竹炭”，而是......）", "name": "梓兰"}, "figure_art": "char_278_orchid_1#5"}, {"id": 235, "prop": "name", "attributes": {"content": "（有人想要掩盖这里存在源石这个事实。）", "name": "梓兰"}, "figure_art": "char_278_orchid_1#5"}, {"id": 236, "prop": "name", "attributes": {"content": "（我必须找到熔火蜗的尸体。）", "name": "梓兰"}, "figure_art": "char_278_orchid_1#5"}, {"id": 237, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#1", "focus": "l"}}, {"id": 238, "prop": "name", "attributes": {"content": "谢谢你，好好休息。", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 239, "prop": "Dialog", "attributes": {}}, {"id": 240, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0, "channel": "1"}}, {"id": 241, "prop": "StopSound", "attributes": {"channel": "1", "fadetime": 1.0}}, {"id": 242, "prop": "charslot", "attributes": {"slot": "l", "name": "char_278_orchid_1#1", "posfrom": "150,0", "posto": "-100,0", "duration": 1.5, "afrom": 1.0, "ato": 0.0}}, {"id": 243, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 244, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2103_1#1$1", "focus": "r"}}, {"id": 245, "prop": "name", "attributes": {"content": "喂，喂！", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 246, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 247, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2103_1#1$1", "focus": "r"}}, {"id": 248, "prop": "name", "attributes": {"content": "真是个莫名其妙的女人。", "name": "斑弥罗"}, "figure_art": "avg_npc_2103_1#1$1"}, {"id": 249, "prop": "Dialog", "attributes": {}}, {"id": 250, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 251, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 252, "prop": "Dialog", "attributes": {}}, {"id": 253, "prop": "charslot", "attributes": {}}, {"id": 254, "prop": "Background", "attributes": {"image": "71_g3_impermanence_palace", "screenadapt": "coverall"}}, {"id": 255, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 256, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 257, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 258, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#1$1", "afrom": 0.0, "ato": 1.0, "duration": 1.5}}, {"id": 259, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 260, "prop": "name", "attributes": {"content": "空爆轻巧地跳过几根横梁，没有发出一丝声响。"}}, {"id": 261, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#3$1", "focus": "m"}}, {"id": 262, "prop": "name", "attributes": {"content": "噢，好险好险，还好这里的人警戒心不怎么强。", "name": "空爆"}, "figure_art": "avg_282_catap_1#3$1"}, {"id": 263, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#8$1", "focus": "m"}}, {"id": 264, "prop": "name", "attributes": {"content": "这里就是泡普卡举行仪式的地方了吧。", "name": "空爆"}, "figure_art": "avg_282_catap_1#8$1"}, {"id": 265, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#9$1", "focus": "m"}}, {"id": 266, "prop": "name", "attributes": {"content": "让我看一看，她到底在干什么......", "name": "空爆"}, "figure_art": "avg_282_catap_1#9$1"}, {"id": 267, "prop": "charslot", "attributes": {}}, {"id": 268, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 269, "prop": "name", "attributes": {"content": "刚才被武士们拖进房间的熔火蜗尸体，静静地躺在那里。"}}, {"id": 270, "prop": "name", "attributes": {"content": "午后的阳光照射进房间内，尸体上正在冒出的黑气尤为明显。"}}, {"id": 271, "prop": "name", "attributes": {"content": "那“诅咒”究竟是什么东西？", "name": "空爆"}, "figure_art": "avg_282_catap_1#9$1"}, {"id": 272, "prop": "charslot", "attributes": {}}, {"id": 273, "prop": "name", "attributes": {"content": "空旷的房间中央，身为国主的宝巫迦，坐在尸体前方，口中正在默念着什么。"}}, {"id": 274, "prop": "name", "attributes": {"content": "而在她的背后，整齐地跪坐着两排头戴面巾的侍女。"}}, {"id": 275, "prop": "name", "attributes": {"content": "万籁无声。"}}, {"id": 276, "prop": "name", "attributes": {"content": "一切都显得神圣而诡异。"}}, {"id": 277, "prop": "PlaySound", "attributes": {"key": "$d_avg_slbellbtl", "volume": 1.0}}, {"id": 278, "prop": "name", "attributes": {"content": "“铃——”"}}, {"id": 279, "prop": "name", "attributes": {"content": "“以吾身为囚——”"}}, {"id": 280, "prop": "name", "attributes": {"content": "随着一声铃声响起，侍女们齐齐开口，唱起了一首乐曲，而宝巫迦也跟着乐曲开始舞蹈。"}}, {"id": 281, "prop": "name", "attributes": {"content": "而后，令空爆感到不可思议的一幕发生了......"}}, {"id": 282, "prop": "name", "attributes": {"content": "那些黑气，竟然就像被什么东西牵引一般，从尸体上被剥离。"}}, {"id": 283, "prop": "name", "attributes": {"content": "如果用一个她能想象到的最直观的比喻来形容，那就是这些黑气，就像是被吸尘器吸走了一样。"}}, {"id": 284, "prop": "Dialog", "attributes": {}}, {"id": 285, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#8$1", "afrom": 0.0, "ato": 1.0, "duration": 1.5}}, {"id": 286, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 287, "prop": "PlaySound", "attributes": {"key": "$d_avg_purifymagic", "volume": 1.0, "channel": "5"}}, {"id": 288, "prop": "bgeffect", "attributes": {"name": "$eb_light", "layer": 1.0}}, {"id": 289, "prop": "StopSound", "attributes": {"channel": "5", "fadetime": 2.5}}, {"id": 290, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 291, "prop": "bgeffect", "attributes": {"duration": 2.0}}, {"id": 292, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 293, "prop": "name", "attributes": {"content": "而那台吸尘器，毫无疑问是正在舞蹈的宝巫迦。"}}, {"id": 294, "prop": "name", "attributes": {"content": "随着舞蹈的进行，宝巫迦身上逐渐蒙上了一层淡淡的光芒，黑气往她的身上聚集，并最终被她吸收。"}}, {"id": 295, "prop": "charslot", "attributes": {}}, {"id": 296, "prop": "name", "attributes": {"content": "（等等......她的表情好难受......那些尸体上的黑气......都跑到她身上去了！）", "name": "空爆"}, "figure_art": "avg_npc_2100_1#8$1"}, {"id": 297, "prop": "name", "attributes": {"content": "（对了，泡普卡的眼睛是很特殊没错......难道就是为了这个，泡普卡才变成了这样？）", "name": "空爆"}, "figure_art": "avg_npc_2100_1#8$1"}, {"id": 298, "prop": "name", "attributes": {"content": "（可恶！这根本不是什么净化，这是在折磨她！我就知道有问题！他们竟然通过这种方式来利用她！）", "name": "空爆"}, "figure_art": "avg_npc_2100_1#8$1"}, {"id": 299, "prop": "name", "attributes": {"content": "（不行，我看不下去了。必须得阻止她！）", "name": "空爆"}, "figure_art": "avg_npc_2100_1#8$1"}, {"id": 300, "prop": "Dialog", "attributes": {}}, {"id": 301, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 302, "prop": "charslot", "attributes": {}}, {"id": 303, "prop": "PlayMusic", "attributes": {"intro": "$nervous_intro", "key": "$nervous_loop", "volume": 0.6}}, {"id": 304, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0}}, {"id": 305, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#4$1", "afrom": 0.0, "ato": 1.0, "duration": 1.5}}, {"id": 306, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 307, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#4$1", "focus": "m"}}, {"id": 308, "prop": "name", "attributes": {"content": "你们真是好大的胆子！", "name": "空爆"}, "figure_art": "avg_282_catap_1#4$1"}, {"id": 309, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#5$1", "focus": "m"}}, {"id": 310, "prop": "name", "attributes": {"content": "空爆小姐？！", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#5$1"}, {"id": 311, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#9$1", "focus": "m"}}, {"id": 312, "prop": "name", "attributes": {"content": "快退下，吾的仪式尚未结束，“诅咒”会伤到你的！", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#9$1"}, {"id": 313, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#4$1", "focus": "m"}}, {"id": 314, "prop": "name", "attributes": {"content": "退下？怎么可能。", "name": "空爆"}, "figure_art": "avg_282_catap_1#4$1"}, {"id": 315, "prop": "name", "attributes": {"content": "别再被他们骗了！这个仪式有问题，他们在折磨你！我来带你走！", "name": "空爆"}, "figure_art": "avg_282_catap_1#4$1"}, {"id": 316, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#5$1", "focus": "m"}}, {"id": 317, "prop": "name", "attributes": {"content": "折磨？不——", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#5$1"}, {"id": 318, "prop": "Dialog", "attributes": {}}, {"id": 319, "prop": "charslot", "attributes": {}}, {"id": 320, "prop": "Blocker", "attributes": {"a": 1.0, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 0.1, "block": "true"}}, {"id": 321, "prop": "PlaySound", "attributes": {"key": "$d_avg_swordwhoosh", "volume": 1.0}}, {"id": 322, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "false"}}, {"id": 323, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 324, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyC_1#1$6", "duration": 2.0}}, {"id": 325, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 326, "prop": "PlaySound", "attributes": {"key": "$MHR_cat_voice1", "volume": 1.0}}, {"id": 327, "prop": "name", "attributes": {"content": "陛下，请继续仪式喵。", "name": "？？？"}, "figure_art": "avg_4215_buddyC_1#1$6"}, {"id": 328, "prop": "name", "attributes": {"content": "这家伙由我政宗来对付喵。", "name": "？？？"}, "figure_art": "avg_4215_buddyC_1#1$6"}, {"id": 329, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#5$1", "focus": "m"}}, {"id": 330, "prop": "name", "attributes": {"content": "......好，吾会尽快结束。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#5$1"}, {"id": 331, "prop": "Dialog", "attributes": {}}, {"id": 332, "prop": "charslot", "attributes": {"slot": "m", "afrom": 1.0, "ato": 0.0, "duration": 1.5}}, {"id": 333, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 334, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#5$1", "focus": "m"}}, {"id": 335, "prop": "name", "attributes": {"content": "会说话的云兽......？", "name": "空爆"}, "figure_art": "avg_282_catap_1#5$1"}, {"id": 336, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyC_1#1$6", "focus": "m"}}, {"id": 337, "prop": "PlaySound", "attributes": {"key": "$MHR_cat_voice3", "volume": 1.0}}, {"id": 338, "prop": "name", "attributes": {"content": "不是云兽，是政宗喵！", "name": "政宗"}, "figure_art": "avg_4215_buddyC_1#1$6"}, {"id": 339, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyC_1#1$6", "focus": "m"}}, {"id": 340, "prop": "name", "attributes": {"content": "听说这一代的“异兽猎人”来了，就赶回来看看......", "name": "政宗"}, "figure_art": "avg_4215_buddyC_1#1$6"}, {"id": 341, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyC_1#1$6", "focus": "m"}}, {"id": 342, "prop": "name", "attributes": {"content": "没想到是这么不讲理的家伙喵。", "name": "政宗"}, "figure_art": "avg_4215_buddyC_1#1$6"}, {"id": 343, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#4$1", "focus": "m"}}, {"id": 344, "prop": "name", "attributes": {"content": "不讲理？不讲理的是你们才对！", "name": "空爆"}, "figure_art": "avg_282_catap_1#4$1"}, {"id": 345, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyC_1#1$6", "focus": "m"}}, {"id": 346, "prop": "PlaySound", "attributes": {"key": "$MHR_cat_voice3", "volume": 1.0}}, {"id": 347, "prop": "name", "attributes": {"content": "你根本不理解这里在发生什么......就让我来告诉你喵。", "name": "政宗"}, "figure_art": "avg_4215_buddyC_1#1$6"}, {"id": 348, "prop": "Dialog", "attributes": {}}, {"id": 349, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 350, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 351, "prop": "bgeffect", "attributes": {}}, {"id": 352, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 353, "prop": "Image", "attributes": {}}, {"id": 354, "prop": "charslot", "attributes": {}}], "OPTIONTRACE": true}