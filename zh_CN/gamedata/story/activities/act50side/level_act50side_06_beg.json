": {"time": 1.0}}, {"id": 140, "prop": "charslot", "attributes": {}}, {"id": 141, "prop": "Dialog", "attributes": {}}, {"id": 142, "prop": "charslot", "attributes": {}}, {"id": 143, "prop": "bgeffect", "attributes": {}}, {"id": 144, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#8$2", "focus": "m"}}, {"id": 145, "prop": "name", "attributes": {"content": "宝巫迦——！！！", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#8$2"}, {"id": 146, "prop": "charslot", "attributes": {}}, {"id": 147, "prop": "Dialog", "attributes": {}}, {"id": 148, "prop": "bgeffect", "attributes": {"name": "$eb_smoke_01", "layer": 1.0}}, {"id": 149, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 150, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#9$1", "afrom": 0.0, "ato": 1.0, "duration": 2.0}}, {"id": 151, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 152, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#6$1", "focus": "m"}}, {"id": 153, "prop": "bgeffect", "attributes": {}}, {"id": 154, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyC_1#1$1", "focus": "m"}}, {"id": 155, "prop": "name", "attributes": {"content": "她没事喵！", "name": "政宗"}, "figure_art": "avg_4215_buddyC_1#1$1"}, {"id": 156, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#12$2", "focus": "m"}}, {"id": 157, "prop": "name", "attributes": {"content": "她疯了！她居然利用爆炸的冲击力作为掩护和推力来移动，只为了靠近熔火蜗！", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#12$2"}, {"id": 158, "prop": "Dialog", "attributes": {}}, {"id": 159, "prop": "PlaySound", "attributes": {"key": "$d_avg_purifymagic", "volume": 1.0, "channel": "5"}}, {"id": 160, "prop": "bgeffect", "attributes": {"name": "$eb_light", "layer": 1.0}}, {"id": 161, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#8$1", "focus": "m"}}, {"id": 162, "prop": "StopSound", "attributes": {"channel": "5", "fadetime": 2.5}}, {"id": 163, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 164, "prop": "bgeffect", "attributes": {}}, {"id": 165, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#7$2", "focus": "m"}}, {"id": 166, "prop": "name", "attributes": {"content": "她......她居然在直接净化熔火蜗？！", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#7$2"}, {"id": 167, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4215_buddyC_1#1$4", "focus": "m"}}, {"id": 168, "prop": "PlaySound", "attributes": {"key": "$MHR_cat_voice3", "volume": 1.0}}, {"id": 169, "prop": "name", "attributes": {"content": "别做傻事喵！陛下，这对你的身体损耗很大喵！", "name": "政宗"}, "figure_art": "avg_4215_buddyC_1#1$4"}, {"id": 170, "prop": "charslot", "attributes": {}}, {"id": 171, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#8$1", "focus": "m"}}, {"id": 172, "prop": "bgeffect", "attributes": {"name": "$eb_light", "layer": 1.0}}, {"id": 173, "prop": "name", "attributes": {"content": "......", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#8$1"}, {"id": 174, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 175, "prop": "charslot", "attributes": {}}, {"id": 176, "prop": "bgeffect", "attributes": {}}, {"id": 177, "prop": "stopmusic", "attributes": {"fadetime": 3.0}}, {"id": 178, "prop": "name", "attributes": {"content": "然而，宝巫迦对于周围的一切都置若罔闻。"}}, {"id": 179, "prop": "name", "attributes": {"content": "她只是压制着熔火蜗，无论熔火蜗怎么甩动身体，她都一动不动。"}}, {"id": 180, "prop": "name", "attributes": {"content": "直到熔火蜗的身体缓缓瘫倒。"}}, {"id": 181, "prop": "Dialog", "attributes": {}}, {"id": 182, "prop": "PlaySound", "attributes": {"key": "$d_avg_giantmonster_fall", "volume": 1.0, "channel": "fall"}}, {"id": 183, "prop": "StopSound", "attributes": {"channel": "fall", "fadetime": 3.0}}, {"id": 184, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 185, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#11$2", "focus": "m"}}, {"id": 186, "prop": "name", "attributes": {"content": "宝巫迦！我们可以帮你的！", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#11$2"}, {"id": 187, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#8$1", "focus": "m"}}, {"id": 188, "prop": "name", "attributes": {"content": "......还不够。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#8$1"}, {"id": 189, "prop": "PlayMusic", "attributes": {"intro": "$drift_intro", "key": "$drift_loop", "volume": 0.6}}, {"id": 190, "prop": "name", "attributes": {"content": "宝巫迦站起身，她没有看任何人，径直走向了天坑的边缘，那姿态，仿佛要抛下身后的一切，独自跃入深渊。"}}, {"id": 191, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#9$2", "focus": "m"}}, {"id": 192, "prop": "name", "attributes": {"content": "站住！", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$2"}, {"id": 193, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#4$1", "focus": "m"}}, {"id": 194, "prop": "name", "attributes": {"content": "这不关你们的事了。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#4$1"}, {"id": 195, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#5$2", "focus": "m"}}, {"id": 196, "prop": "name", "attributes": {"content": "你的士兵怎么办？你的国家怎么办？他们都在看着你！", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#5$2"}, {"id": 197, "prop": "charslot", "attributes": {}}, {"id": 198, "prop": "name", "attributes": {"content": "宝巫迦缓缓地回头，空洞的眼神看得梓兰心中一寒。"}}, {"id": 199, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2100_1#11$1", "focus": "l"}}, {"id": 200, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2106_1#1$1", "focus": "l"}}, {"id": 201, "prop": "name", "attributes": {"content": "吾现在......什么也看不见。吾只要它的命。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#11$1"}, {"id": 202, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2106_1#1$1", "focus": "r"}}, {"id": 203, "prop": "name", "attributes": {"content": "陛下，请......三思。", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 204, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2100_1#6$1", "focus": "l"}}, {"id": 205, "prop": "name", "attributes": {"content": "月见夜如今已经倒下，你们还要代替他阻止吾吗？", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#6$1"}, {"id": 206, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2106_1#1$1", "focus": "r"}}, {"id": 207, "prop": "name", "attributes": {"content": "正因为将军倒下了，我才要代替将军说这句话——", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 208, "prop": "name", "attributes": {"content": "狩猎“雷之主”一事，需要从长——", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 209, "prop": "charslot", "attributes": {}}, {"id": 210, "prop": "Dialog", "attributes": {}}, {"id": 211, "prop": "Background", "attributes": {"image": "bg_black", "screenadapt": "coverall", "block": "true"}}, {"id": 212, "prop": "PlaySound", "attributes": {"key": "$swordtsing4", "volume": 1.0}}, {"id": 213, "prop": "delay", "attributes": {"time": 0.1}}, {"id": 214, "prop": "Effect", "attributes": {"name": "$e_spark_01_mid"}}, {"id": 215, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 216, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 217, "prop": "Background", "attributes": {"image": "71_g4_bambooforest", "screenadapt": "coverall", "block": "true"}}, {"id": 218, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2100_1#6$1"}}, {"id": 219, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#8$2", "posfrom": "0,0", "posto": "100,0", "afrom": 0.0, "ato": 1.0, "duration": 0.0}}, {"id": 220, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2106_1#1$1", "posfrom": "0,0", "posto": "200,0", "afrom": 0.0, "ato": 1.0, "duration": 0.0}}, {"id": 221, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 222, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#8$2", "focus": "m"}}, {"id": 223, "prop": "name", "attributes": {"content": "宝巫迦，别冲动！", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#8$2"}, {"id": 224, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2100_1#6$1", "focus": "l"}}, {"id": 225, "prop": "name", "attributes": {"content": "“雷之主”已经危害到了吾国！它还伤害了月见夜！", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#6$1"}, {"id": 226, "prop": "name", "attributes": {"content": "你要吾如何冷静？！", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#6$1"}, {"id": 227, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2106_1#1$1", "focus": "r"}}, {"id": 228, "prop": "name", "attributes": {"content": "我等日夜追随将军，将军如今倒下，我等心中也万分难过。", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 229, "prop": "name", "attributes": {"content": "但正因如此，我等才谨记将军教诲，狩猎“雷之主”一事，需要从长计议！", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 230, "prop": "Dialog", "attributes": {}}, {"id": 231, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovement", "volume": 1.0}}, {"id": 232, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#7$2"}}, {"id": 233, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "0,0", "posto": "50,0", "duration": 0.5}}, {"id": 234, "prop": "charslot", "attributes": {"slot": "m", "posfrom": "100,0", "posto": "140,0", "duration": 0.5}}, {"id": 235, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 236, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1049_catap2_1#7$2", "focus": "m"}}, {"id": 237, "prop": "name", "attributes": {"content": "呜哇——", "name": "空爆"}, "figure_art": "avg_1049_catap2_1#7$2"}, {"id": 238, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2100_1#6$1", "focus": "l"}}, {"id": 239, "prop": "name", "attributes": {"content": "让开！", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#6$1"}, {"id": 240, "prop": "charslot", "attributes": {}}, {"id": 241, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#8$2", "focus": "m"}}, {"id": 242, "prop": "name", "attributes": {"content": "......", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#8$2"}, {"id": 243, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#5$2", "focus": "m"}}, {"id": 244, "prop": "name", "attributes": {"content": "都给我住手！", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#5$2"}, {"id": 245, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2106_1#1$1", "focus": "m"}}, {"id": 246, "prop": "name", "attributes": {"content": "梓兰小姐，请您——", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 247, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#5$2", "focus": "m"}}, {"id": 248, "prop": "name", "attributes": {"content": "你们真是被那家伙教得跟他一样死脑筋。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#5$2"}, {"id": 249, "prop": "name", "attributes": {"content": "现在最要紧的是把你们的将军抬上担架，送回城里急救！他还没死！", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#5$2"}, {"id": 250, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#9$2", "focus": "m"}}, {"id": 251, "prop": "name", "attributes": {"content": "然后留下一批人守在这里，防止有野兽从天坑下爬上来！", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$2"}, {"id": 252, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2106_1#1$1", "focus": "m"}}, {"id": 253, "prop": "name", "attributes": {"content": "但——", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 254, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#5$2", "focus": "m"}}, {"id": 255, "prop": "name", "attributes": {"content": "没有但是！", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#5$2"}, {"id": 256, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2106_1#1$1", "focus": "m"}}, {"id": 257, "prop": "name", "attributes": {"content": "明白。按照梓兰小姐的话做！", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 258, "prop": "charslot", "attributes": {}}, {"id": 259, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2107_1#1$1"}}, {"id": 260, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2107_1#1$1"}}, {"id": 261, "prop": "name", "attributes": {"content": "是！", "name": "武士们"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 262, "prop": "charslot", "attributes": {}}, {"id": 263, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#8$2", "focus": "m"}}, {"id": 264, "prop": "name", "attributes": {"content": "然后是你，宝巫迦。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#8$2"}, {"id": 265, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#9$2", "focus": "m"}}, {"id": 266, "prop": "name", "attributes": {"content": "我不管你现在脑子里在想什么。但你想下去，我也想下去。那家伙不死，我们回不了家。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$2"}, {"id": 267, "prop": "name", "attributes": {"content": "我不会劝你放下仇恨，那很虚伪。但是，你应该比任何人都清楚“雷之主”的强大。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$2"}, {"id": 268, "prop": "name", "attributes": {"content": "所以，我们会和你一起去狩猎它。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$2"}, {"id": 269, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#4$1", "focus": "m"}}, {"id": 270, "prop": "name", "attributes": {"content": "......好。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#4$1"}, {"id": 271, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#3$2", "focus": "m"}}, {"id": 272, "prop": "name", "attributes": {"content": "（看她的眼神，她并没有被我说服，但现在也没有别的办法了......）", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#3$2"}, {"id": 273, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2106_1#1$1", "focus": "m"}}, {"id": 274, "prop": "name", "attributes": {"content": "梓兰小姐......", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 275, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#9$2", "focus": "m"}}, {"id": 276, "prop": "name", "attributes": {"content": "我从没答应过你们的将军，要阻止宝巫迦去狩猎“雷之主”。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$2"}, {"id": 277, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2106_1#1$1", "focus": "m"}}, {"id": 278, "prop": "name", "attributes": {"content": "但——", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 279, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#9$2", "focus": "m"}}, {"id": 280, "prop": "name", "attributes": {"content": "你们的将军应该告诉过你们，狩猎团是为了什么而存在的。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$2"}, {"id": 281, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2106_1#1$1", "focus": "m"}}, {"id": 282, "prop": "name", "attributes": {"content": "是为了让陛下能够狩猎“雷之主”。", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 283, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#6$2", "focus": "m"}}, {"id": 284, "prop": "name", "attributes": {"content": "现在不正是那个时候了吗？", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#6$2"}, {"id": 285, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2106_1#1$1", "focus": "m"}}, {"id": 286, "prop": "name", "attributes": {"content": "您......说得是。", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 287, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#6$2", "focus": "m"}}, {"id": 288, "prop": "name", "attributes": {"content": "（低声）这是眼下最好的方法，我会尽量想办法稳住她。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#6$2"}, {"id": 289, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2106_1#1$1", "focus": "m"}}, {"id": 290, "prop": "name", "attributes": {"content": "......万事拜托您了。", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 291, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#8$2", "focus": "m"}}, {"id": 292, "prop": "name", "attributes": {"content": "拿纸和笔来。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#8$2"}, {"id": 293, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2106_1#1$1", "focus": "m"}}, {"id": 294, "prop": "name", "attributes": {"content": "咦？", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 295, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#9$2", "focus": "m"}}, {"id": 296, "prop": "name", "attributes": {"content": "我要写一封信。告诉斑弥罗，等你们的将军醒后代我将信交给他。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$2"}, {"id": 297, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2106_1#1$1", "focus": "m"}}, {"id": 298, "prop": "name", "attributes": {"content": "我明白了。", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 299, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#5$2", "focus": "m"}}, {"id": 300, "prop": "name", "attributes": {"content": "政宗，空爆，义经！准备绳索和照明用具！", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#5$2"}, {"id": 301, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1048_orchd2_1#9$2", "focus": "m"}}, {"id": 302, "prop": "name", "attributes": {"content": "我们......准备狩猎。", "name": "梓兰"}, "figure_art": "avg_1048_orchd2_1#9$2"}, {"id": 303, "prop": "Dialog", "attributes": {}}, {"id": 304, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 305, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 306, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 307, "prop": "Dialog", "attributes": {}}, {"id": 308, "prop": "charslot", "attributes": {}}, {"id": 309, "prop": "Background", "attributes": {"image": "71_g1_impermanence_street", "screenadapt": "coverall"}}, {"id": 310, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 311, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 312, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 313, "prop": "playMusic", "attributes": {"intro": "$nervous_intro", "key": "$nervous_loop", "volume": 0.6}}, {"id": 314, "prop": "CameraShake", "attributes": {"duration": 0.7, "xstrength": 60.0, "ystrength": 60.0, "vibrato": 70.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 315, "prop": "PlaySound", "attributes": {"key": "$d_avg_woodengate_crack", "volume": 1.0}}, {"id": 316, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 317, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2106_1#1$1", "focus": "m"}}, {"id": 318, "prop": "name", "attributes": {"content": "不行了！门快破了！快用滚木和火油！", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 319, "prop": "name", "attributes": {"content": "它们的眼睛！它们的关节！那里是弱点！全员，听我命令，集火攻击它们的薄弱处！", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 320, "prop": "Dialog", "attributes": {}}, {"id": 321, "prop": "charslot", "attributes": {}}, {"id": 322, "prop": "PlaySound", "attributes": {"key": "$d_avg_hiddenweapon_hitshield", "volume": 1.0, "channel": "1"}}, {"id": 323, "prop": "PlaySound", "attributes": {"key": "$d_avg_hiddenweapon_hitshield", "volume": 1.0, "channel": "2", "delay": 0.2}}, {"id": 324, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 325, "prop": "PlaySound", "attributes": {"key": "$d_avg_snarl_1", "volume": 1.0}}, {"id": 326, "prop": "name", "attributes": {"content": "（惬意的喊叫）", "name": "兽群们"}}, {"id": 327, "prop": "Dialog", "attributes": {}}, {"id": 328, "prop": "PlaySound", "attributes": {"key": "$d_avg_arrow_rain", "volume": 1.0}}, {"id": 329, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 330, "prop": "name", "attributes": {"content": "城墙上的武士们也纷纷射出箭矢，但都如石沉大海，无法对那些皮糙肉厚的野兽造成任何有效伤害。"}}, {"id": 331, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2106_1#1$1", "focus": "m"}}, {"id": 332, "prop": "name", "attributes": {"content": "不行......太硬了......", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 333, "prop": "charslot", "attributes": {}}, {"id": 334, "prop": "name", "attributes": {"content": "兽群们仿佛被这些骚扰激怒，它们后退几步，发出震耳欲聋的咆哮，随即以更猛烈的姿态，全力撞向了城门。"}}, {"id": 335, "prop": "Dialog", "attributes": {}}, {"id": 336, "prop": "CameraShake", "attributes": {"duration": 0.7, "xstrength": 60.0, "ystrength": 60.0, "vibrato": 70.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 337, "prop": "PlaySound", "attributes": {"key": "$d_avg_woodengate_crack", "volume": 1.0}}, {"id": 338, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 339, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2106_1#1$1", "focus": "r"}}, {"id": 340, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2107_1#1$1", "focus": "r"}}, {"id": 341, "prop": "name", "attributes": {"content": "完了——！", "name": "随从武士"}, "figure_art": "avg_npc_2107_1#1$1"}, {"id": 342, "prop": "name", "attributes": {"content": "果然，没有将军和陛下在，我们是不行的！", "name": "随从武士"}, "figure_art": "avg_npc_2107_1#1$1"}, {"id": 343, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2106_1#1$1", "focus": "l"}}, {"id": 344, "prop": "name", "attributes": {"content": "......不，还不到放弃的时候！", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 345, "prop": "name", "attributes": {"content": "陛下和两位“异兽猎人”已经前往狩猎“雷之主”了，我们要撑到那个时候——", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 346, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2107_1#1$1", "focus": "r"}}, {"id": 347, "prop": "name", "attributes": {"content": "要撑到什么时候？", "name": "随从武士"}, "figure_art": "avg_npc_2107_1#1$1"}, {"id": 348, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2106_1#1$1", "focus": "l"}}, {"id": 349, "prop": "name", "attributes": {"content": "......就算是为了将军，我们也必须保护好都城！", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 350, "prop": "name", "attributes": {"content": "将军保护了这个国家十年之久，现在，轮到我们保护他了！", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 351, "prop": "name", "attributes": {"content": "要跑就跑吧，我不会怪你。", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 352, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2107_1#1$1", "focus": "r"}}, {"id": 353, "prop": "name", "attributes": {"content": "......对不住，队长。", "name": "随从武士"}, "figure_art": "avg_npc_2107_1#1$1"}, {"id": 354, "prop": "Dialog", "attributes": {}}, {"id": 355, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0, "channel": "4"}}, {"id": 356, "prop": "StopSound", "attributes": {"channel": "4", "fadetime": 1.5}}, {"id": 357, "prop": "charslot", "attributes": {"slot": "r", "posfrom": "0,0", "posto": "150,0", "afrom": 1.0, "ato": 0.0, "duration": 1.5, "focus": "r"}}, {"id": 358, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 359, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2106_1#1$1", "focus": "l"}}, {"id": 360, "prop": "name", "attributes": {"content": "跑吧，跑了也好。", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 361, "prop": "Dialog", "attributes": {}}, {"id": 362, "prop": "charslot", "attributes": {}}, {"id": 363, "prop": "PlaySound", "attributes": {"key": "$d_avg_snarl_1", "volume": 1.0}}, {"id": 364, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2105_1#1$1", "afrom": 0.0, "ato": 1.0, "duration": 1.5}}, {"id": 365, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2105_1#1$1", "afrom": 0.0, "ato": 1.0, "duration": 1.5}}, {"id": 366, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 367, "prop": "charslot", "attributes": {}}, {"id": 368, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2106_1#1$1", "focus": "m"}}, {"id": 369, "prop": "name", "attributes": {"content": "哼，野兽们，到你们的死期了。", "name": "武士队长"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 370, "prop": "Dialog", "attributes": {}}, {"id": 371, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 372, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 373, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 374, "prop": "Dialog", "attributes": {}}, {"id": 375, "prop": "charslot", "attributes": {}}, {"id": 376, "prop": "Background", "attributes": {"image": "71_g9_undergroundbamboo", "screenadapt": "coverall"}}, {"id": 377, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "amount": 0.8, "keep": "true"}}, {"id": 378, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 379, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 380, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 381, "prop": "PlayMusic", "attributes": {"intro": "$distressed_intro", "key": "$distressed_loop", "volume": 0.6}}, {"id": 382, "prop": "name", "attributes": {"content": "月见夜还记得见前代陛下最后一面时的情景。"}}, {"id": 383, "prop": "name", "attributes": {"content": "陛下，请三思。", "name": "月见夜"}}, {"id": 384, "prop": "name", "attributes": {"content": "斥候的回报很不乐观，此次的“异兽”远比记载中任何一次都要强大。我们尚未做好万全的准备，远征队......已经折损了近半。", "name": "月见夜"}}, {"id": 385, "prop": "name", "attributes": {"content": "......", "name": "月见夜"}}, {"id": 386, "prop": "name", "attributes": {"content": "您还是不愿听我的吗？", "name": "月见夜"}}, {"id": 387, "prop": "name", "attributes": {"content": "您的身体......您以为我没有发现吗？那晚您在庭院中咳出的血，那方手帕上刺眼的漆黑！", "name": "月见夜"}}, {"id": 388, "prop": "name", "attributes": {"content": "您早已被“诅咒”深度侵蚀，再去战斗，无异于自尽！", "name": "月见夜"}}, {"id": 389, "prop": "name", "attributes": {"content": "您不为自己着想，也请为国家着想！为宝巫迦殿下着想！她还那么年幼，她不能没有母亲！泡影国也不能没有您！", "name": "月见夜"}}, {"id": 390, "prop": "name", "attributes": {"content": "......", "name": "月见夜"}}, {"id": 391, "prop": "name", "attributes": {"content": "是我的错吗？是我不够强大，才需要您一次又一次地亲赴险境？只要您说，只要您一句话，我愿意为您献上一切！", "name": "月见夜"}}, {"id": 392, "prop": "name", "attributes": {"content": "所以......求您了......留下来。不要去。", "name": "月见夜"}}, {"id": 393, "prop": "name", "attributes": {"content": "为什么......为什么还是要走？", "name": "月见夜"}}, {"id": 394, "prop": "name", "attributes": {"content": "站住！我命令您站住！", "name": "月见夜"}}, {"id": 395, "prop": "name", "attributes": {"content": "......不......我没有资格命令您......", "name": "月见夜"}}, {"id": 396, "prop": "name", "attributes": {"content": "求您......别走......", "name": "月见夜"}}, {"id": 397, "prop": "name", "attributes": {"content": "......", "name": "月见夜"}}, {"id": 398, "prop": "Dialog", "attributes": {}}, {"id": 399, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 400, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 401, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 402, "prop": "name", "attributes": {"content": "那是他最后一次见到前代陛下。"}}, {"id": 403, "prop": "name", "attributes": {"content": "我们已经失去了前代陛下。"}}, {"id": 404, "prop": "name", "attributes": {"content": "泡影国不能再失去宝巫迦陛下了。"}}, {"id": 405, "prop": "name", "attributes": {"content": "宝巫迦陛下天资聪颖，假以时日，必然能够成长为和前代陛下一样出色的国主。"}}, {"id": 406, "prop": "name", "attributes": {"content": "但是，时间，对了，我们需要时间......"}}, {"id": 407, "prop": "name", "attributes": {"content": "为了时间，为了宝巫迦陛下能够顺利长大......"}}, {"id": 408, "prop": "name", "attributes": {"content": "我情愿让她去恨我，去将对“雷之主”的恨意倾泻到我的身上。"}}, {"id": 409, "prop": "name", "attributes": {"content": "至少这样更安全。"}}, {"id": 410, "prop": "name", "attributes": {"content": "但是——"}}, {"id": 411, "prop": "name", "attributes": {"content": "这样便对吗？"}}, {"id": 412, "prop": "Dialog", "attributes": {}}, {"id": 413, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 414, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 415, "prop": "bgeffect", "attributes": {}}, {"id": 416, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "amount": 0.0, "keep": "true"}}, {"id": 417, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 418, "prop": "Image", "attributes": {}}, {"id": 419, "prop": "charslot", "attributes": {}}], "OPTIONTRACE": true}