, {"id": 275, "prop": "charslot", "attributes": {}}, {"id": 276, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#1", "focus": "m"}}, {"id": 277, "prop": "name", "attributes": {"content": "空爆，你太莽撞了！", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 278, "prop": "charslot", "attributes": {}}, {"id": 279, "prop": "name", "attributes": {"content": "抱歉，梓兰姐......", "name": "空爆"}, "figure_art": "char_278_orchid_1#1"}, {"id": 280, "prop": "Dialog", "attributes": {}}, {"id": 281, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovement", "volume": 1.0}}, {"id": 282, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#8$1", "posfrom": "0,-80", "posto": "0,0", "afrom": 0.0, "ato": 1.0, "duration": 1.5}}, {"id": 283, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 284, "prop": "PlayMusic", "attributes": {"intro": "$m_dia_street_intro", "key": "$m_dia_street_loop", "volume": 0.6}}, {"id": 285, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#5$1", "focus": "m"}}, {"id": 286, "prop": "name", "attributes": {"content": "你刚才扔的是异臭弹吧？", "name": "空爆"}, "figure_art": "avg_282_catap_1#5$1"}, {"id": 287, "prop": "charslot", "attributes": {}}, {"id": 288, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#2", "focus": "m"}}, {"id": 289, "prop": "name", "attributes": {"content": "......之前逃跑的时候顺便捡了两颗，泡普卡说，对驱赶野兽有奇效，我就留了个心眼。", "name": "梓兰"}, "figure_art": "char_278_orchid_1#2"}, {"id": 290, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#3$1", "focus": "m"}}, {"id": 291, "prop": "name", "attributes": {"content": "不愧是梓兰姐！", "name": "空爆"}, "figure_art": "avg_282_catap_1#3$1"}, {"id": 292, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#8$1", "focus": "m"}}, {"id": 293, "prop": "name", "attributes": {"content": "不过，那就是“雷之主”啊......好厉害啊。", "name": "空爆"}, "figure_art": "avg_282_catap_1#8$1"}, {"id": 294, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#1", "focus": "m"}}, {"id": 295, "prop": "name", "attributes": {"content": "下次再见到它，不准随便出手。", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 296, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#8$1", "focus": "m"}}, {"id": 297, "prop": "name", "attributes": {"content": "哦......", "name": "空爆"}, "figure_art": "avg_282_catap_1#8$1"}, {"id": 298, "prop": "Dialog", "attributes": {}}, {"id": 299, "prop": "charslot", "attributes": {}}, {"id": 300, "prop": "PlaySound", "attributes": {"key": "$rungeneral", "volume": 1.0, "channel": "2"}}, {"id": 301, "prop": "StopSound", "attributes": {"channel": "2", "fadetime": 1.5}}, {"id": 302, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#6$1", "afrom": 0.0, "ato": 1.0, "duration": 1.5}}, {"id": 303, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 304, "prop": "multiline", "attributes": {"name": "宝巫迦", "content": "两位！吾刚才好像听到了“雷之主”的叫声，"}}, {"id": 305, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#5$1", "focus": "m"}}, {"id": 306, "prop": "multiline", "attributes": {"name": "宝巫迦", "content": "你们——"}}, {"id": 307, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#1$1", "focus": "m"}}, {"id": 308, "prop": "name", "attributes": {"content": "呃，嘿嘿。", "name": "空爆"}, "figure_art": "avg_282_catap_1#1$1"}, {"id": 309, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#2", "focus": "m"}}, {"id": 310, "prop": "name", "attributes": {"content": "我们和它短暂地交了手。", "name": "梓兰"}, "figure_art": "char_278_orchid_1#2"}, {"id": 311, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#6$1", "focus": "m"}}, {"id": 312, "prop": "name", "attributes": {"content": "这太莽撞了，两位！", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#6$1"}, {"id": 313, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#1$1", "focus": "m"}}, {"id": 314, "prop": "name", "attributes": {"content": "梓兰姐已经训过我啦。", "name": "空爆"}, "figure_art": "avg_282_catap_1#1$1"}, {"id": 315, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#8$1", "focus": "m"}}, {"id": 316, "prop": "name", "attributes": {"content": "幸好两位平安无事......", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#8$1"}, {"id": 317, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 318, "prop": "name", "attributes": {"content": "吾已经将这一带的熔火蜗都清理掉了。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 319, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#1", "focus": "m"}}, {"id": 320, "prop": "name", "attributes": {"content": "找到“异兽”的踪迹了吗？", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 321, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#8$1", "focus": "m"}}, {"id": 322, "prop": "name", "attributes": {"content": "......没有。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#8$1"}, {"id": 323, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#1", "focus": "m"}}, {"id": 324, "prop": "name", "attributes": {"content": "宝巫迦，熔火蜗真的是这里的生物吗？", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 325, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 326, "prop": "name", "attributes": {"content": "当然。熔火蜗一直是栖息在泡影国周边的野兽。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 327, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#8$1", "focus": "m"}}, {"id": 328, "prop": "name", "attributes": {"content": "但看它的样子不该是栖息在火山之类的地方吗，这里是竹林吧？", "name": "空爆"}, "figure_art": "avg_282_catap_1#8$1"}, {"id": 329, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#4$1", "focus": "m"}}, {"id": 330, "prop": "name", "attributes": {"content": "两位有所不知，“御轮”之下虽然是雪山，但雪山之下却是熔岩地带。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#4$1"}, {"id": 331, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 332, "prop": "name", "attributes": {"content": "那里正是熔火蜗栖息的地方。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 333, "prop": "Dialog", "attributes": {}}, {"id": 334, "prop": "charslot", "attributes": {}}, {"id": 335, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 336, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2106_1#1$1", "afrom": 0.0, "ato": 1.0, "duration": 1.5}}, {"id": 337, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 338, "prop": "name", "attributes": {"content": "陛下，我们可以开始打扫战场了吗？", "name": "领头武士"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 339, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 340, "prop": "name", "attributes": {"content": "去吧，这一带已经安全了。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 341, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2106_1#1$1", "focus": "m"}}, {"id": 342, "prop": "name", "attributes": {"content": "不愧是陛下！", "name": "领头武士"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 343, "prop": "name", "attributes": {"content": "感谢“御轮”的恩赐，感谢巫女的引导，我等泡影国的子民，将心怀敬意地使用这些神赐之物。", "name": "领头武士"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 344, "prop": "name", "attributes": {"content": "将熔火蜗的尸体都搬回去，然后采集一切有用的素材。", "name": "领头武士"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 345, "prop": "charslot", "attributes": {}}, {"id": 346, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2107_1#1$1"}}, {"id": 347, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2107_1#1$1"}}, {"id": 348, "prop": "name", "attributes": {"content": "是！", "name": "随从武士们"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 349, "prop": "Dialog", "attributes": {}}, {"id": 350, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 351, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2107_1#1$1", "afrom": 1.0, "ato": 0.0, "duration": 1.5}}, {"id": 352, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2107_1#1$1", "afrom": 1.0, "ato": 0.0, "duration": 1.5}}, {"id": 353, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 354, "prop": "charslot", "attributes": {}}, {"id": 355, "prop": "PlaySound", "attributes": {"key": "$d_avg_stnecrve", "volume": 1.0}}, {"id": 356, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 357, "prop": "PlaySound", "attributes": {"key": "$d_avg_stnecrve", "volume": 1.0}}, {"id": 358, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 359, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#11$1", "focus": "m"}}, {"id": 360, "prop": "name", "attributes": {"content": "呃......他们在干什么？", "name": "空爆"}, "figure_art": "avg_282_catap_1#11$1"}, {"id": 361, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 362, "prop": "name", "attributes": {"content": "熔火蜗平日生活在熔岩地带，很少成群出现，它的壳能够做成可以长时间燃烧的“火竹炭”。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 363, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2106_1#1$1", "focus": "m"}}, {"id": 364, "prop": "name", "attributes": {"content": "没错！这种“火竹炭”结实好用，但是熔火蜗太少见了，今天这一批的量，今年我们过冬都不用愁了。", "name": "领头武士"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 365, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#8$1", "focus": "m"}}, {"id": 366, "prop": "name", "attributes": {"content": "那那边在兴高采烈砍竹子的又是为什么......？", "name": "空爆"}, "figure_art": "avg_282_catap_1#8$1"}, {"id": 367, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2106_1#1$1", "focus": "m"}}, {"id": 368, "prop": "name", "attributes": {"content": "我们平时就会用竹子来制作各种东西，而熔火蜗的温度比国内最大的炉子都要高，能够将这些竹子烤得无比坚硬。", "name": "领头武士"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 369, "prop": "name", "attributes": {"content": "这种熔火蜗烤好的竹子，我们称之为“烈竹”。", "name": "领头武士"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 370, "prop": "name", "attributes": {"content": "用“烈竹”做成的武器也好，家具也好，都十分耐用。", "name": "领头武士"}, "figure_art": "avg_npc_2106_1#1$1"}, {"id": 371, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#3$1", "focus": "m"}}, {"id": 372, "prop": "name", "attributes": {"content": "有意思，我也来帮忙！", "name": "空爆"}, "figure_art": "avg_282_catap_1#3$1"}, {"id": 373, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#1", "focus": "m"}}, {"id": 374, "prop": "name", "attributes": {"content": "......只有靠“试炼”才能获得这么多吗？ ", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 375, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#1$1", "focus": "m"}}, {"id": 376, "prop": "name", "attributes": {"content": "是的。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 377, "prop": "name", "attributes": {"content": "每十年一次的“试炼”中出现的“异兽”，以及它掀起的异变，会对周边的环境造成很大影响。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#1$1"}, {"id": 378, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#3$1", "focus": "m"}}, {"id": 379, "prop": "name", "attributes": {"content": "其中虽然有许多危机，但同时也为吾等带来了许多平时无法获得的东西。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#3$1"}, {"id": 380, "prop": "name", "attributes": {"content": "因此，对泡影国来说，“试炼”是危机，也是机遇。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#3$1"}, {"id": 381, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2100_1#8$1", "focus": "m"}}, {"id": 382, "prop": "name", "attributes": {"content": "狩地之兽，得天之赐，这正是泡影国的做法。", "name": "宝巫迦"}, "figure_art": "avg_npc_2100_1#8$1"}, {"id": 383, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#3", "focus": "m"}}, {"id": 384, "prop": "name", "attributes": {"content": "......", "name": "梓兰"}, "figure_art": "char_278_orchid_1#3"}, {"id": 385, "prop": "Dialog", "attributes": {}}, {"id": 386, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 387, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 388, "prop": "Dialog", "attributes": {}}, {"id": 389, "prop": "charslot", "attributes": {}}, {"id": 390, "prop": "Background", "attributes": {"image": "71_g4_bambooforest", "screenadapt": "coverall"}}, {"id": 391, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 392, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 393, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 394, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#1", "focus": "m"}}, {"id": 395, "prop": "name", "attributes": {"content": "将“试炼”造成的影响视作恩赐，甚至在生活上依靠这种恩赐，这未免太缺乏稳定性了。", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 396, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#5$1", "focus": "m"}}, {"id": 397, "prop": "name", "attributes": {"content": "哦？这块烈竹的材质真不错，拿来做弹药的素材应该稳定性不错......", "name": "空爆"}, "figure_art": "avg_282_catap_1#5$1"}, {"id": 398, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#5", "focus": "m"}}, {"id": 399, "prop": "name", "attributes": {"content": "而且，他们难道从来没有想过深究这一切的原因吗？", "name": "梓兰"}, "figure_art": "char_278_orchid_1#5"}, {"id": 400, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#9$1", "focus": "m"}}, {"id": 401, "prop": "name", "attributes": {"content": "梓兰姐，大概是熔火蜗经过的原因，地上有好多烤焦的花花草草，有些味道闻起来还不错欸。", "name": "空爆"}, "figure_art": "avg_282_catap_1#9$1"}, {"id": 402, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#1", "focus": "m"}}, {"id": 403, "prop": "name", "attributes": {"content": "你到底有没有听我说话！", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 404, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#3$1", "focus": "m"}}, {"id": 405, "prop": "name", "attributes": {"content": "我在听啊。", "name": "空爆"}, "figure_art": "avg_282_catap_1#3$1"}, {"id": 406, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#1", "focus": "m"}}, {"id": 407, "prop": "name", "attributes": {"content": "......我不相信他们的这套说辞，我们要想办法搞清楚这里究竟是什么地方。", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 408, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#8$1", "focus": "m"}}, {"id": 409, "prop": "name", "attributes": {"content": "其实我觉得还挺说得通欸。", "name": "空爆"}, "figure_art": "avg_282_catap_1#8$1"}, {"id": 410, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#2", "focus": "m"}}, {"id": 411, "prop": "name", "attributes": {"content": "那你留下吧。", "name": "梓兰"}, "figure_art": "char_278_orchid_1#2"}, {"id": 412, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#1$1", "focus": "m"}}, {"id": 413, "prop": "name", "attributes": {"content": "欸，我不是相信他们啦，只是我觉得这种生活方式没有梓兰姐你想象的那么说不通而已。", "name": "空爆"}, "figure_art": "avg_282_catap_1#1$1"}, {"id": 414, "prop": "name", "attributes": {"content": "反正，源石虫这件事也太穿帮啦。", "name": "空爆"}, "figure_art": "avg_282_catap_1#1$1"}, {"id": 415, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#8$1", "focus": "m"}}, {"id": 416, "prop": "name", "attributes": {"content": "如果这里真的像梓兰姐你说的那样，是一座巨大摄影棚，或者帕夏的后花园啥的，就算我们要走，也得带上他们三个吧？", "name": "空爆"}, "figure_art": "avg_282_catap_1#8$1"}, {"id": 417, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#1", "focus": "m"}}, {"id": 418, "prop": "name", "attributes": {"content": "我知道。接下来，我们分头行动。", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 419, "prop": "name", "attributes": {"content": "我去收集情报。你身手比我好，你去调查他们身上发生了什么。", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 420, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#3$1", "focus": "m"}}, {"id": 421, "prop": "name", "attributes": {"content": "嘿嘿，这个我喜欢！", "name": "空爆"}, "figure_art": "avg_282_catap_1#3$1"}, {"id": 422, "prop": "charslot", "attributes": {"slot": "m", "name": "char_278_orchid_1#1", "focus": "m"}}, {"id": 423, "prop": "name", "attributes": {"content": "记住，首要任务是调查，找到线索，不要冲动行事。我们的最终目的是解救同伴，并一起逃离这里。", "name": "梓兰"}, "figure_art": "char_278_orchid_1#1"}, {"id": 424, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_282_catap_1#3$1", "focus": "m"}}, {"id": 425, "prop": "name", "attributes": {"content": "明白了！", "name": "空爆"}, "figure_art": "avg_282_catap_1#3$1"}, {"id": 426, "prop": "Dialog", "attributes": {}}, {"id": 427, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 428, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 429, "prop": "bgeffect", "attributes": {}}, {"id": 430, "prop": "gridbg", "attributes": {}}, {"id": 431, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 432, "prop": "Image", "attributes": {}}, {"id": 433, "prop": "charslot", "attributes": {}}], "OPTIONTRACE": true}