": {"key": "$MHR_hyperpunch_hit1", "volume": 1.0}}, {"id": 151, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 152, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 50.0, "ystrength": 50.0, "vibrato": 60.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 153, "prop": "PlaySound", "attributes": {"key": "$MHR_hyperpunch_hit1", "volume": 1.0}}, {"id": 154, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 155, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 50.0, "ystrength": 50.0, "vibrato": 60.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 156, "prop": "PlaySound", "attributes": {"key": "$MHR_hyperpunch_hit1", "volume": 1.0}}, {"id": 157, "prop": "Delay", "attributes": {"time": 3.0}}, {"id": 158, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 6.0, "block": "false"}}, {"id": 159, "prop": "PlayMusic", "attributes": {"intro": "$MHR_bat_monsterhunter2boss_intro", "key": "$MHR_bat_monsterhunter2boss_loop", "volume": 0.6}}, {"id": 160, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 161, "prop": "name", "attributes": {"content": "危急时刻，一声响彻天地的咆哮从不远处传来。"}}, {"id": 162, "prop": "name", "attributes": {"content": "一头青色的巨大野兽，优雅地从林中漫步而出。"}}, {"id": 163, "prop": "name", "attributes": {"content": "竹子如同积木一样倒下，像是臣服于君王的降临，又似在逃离鬼神的接近。"}}, {"id": 164, "prop": "name", "attributes": {"content": "当月光终于照耀在它的身上时，一瞬间，周围的一切仿佛凝固，连心跳都仿佛静止了。"}}, {"id": 165, "prop": "name", "attributes": {"content": "它头上的尖角恰似冠冕，在月光下闪烁着冷芒。"}}, {"id": 166, "prop": "name", "attributes": {"content": "它的身躯，宛若夜色中沉睡的宝石，却又在每一次肌肉的鼓动间折射出碎裂的白光，仿佛万千闪电被囚禁在片片鳞甲下，急欲破壳而出。"}}, {"id": 167, "prop": "name", "attributes": {"content": "当它阔步而来，大地先行震颤，每一次爪锋触及岩石，都激起蜿蜒电弧。长尾挥洒，电弧骤起，犹如新月撕开夜幕。"}}, {"id": 168, "prop": "name", "attributes": {"content": "上一刻还让两人感到棘手的熔火蜗，在它的面前，竟显得有些可爱。"}}, {"id": 169, "prop": "Dialog", "attributes": {}}, {"id": 170, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 50.0, "ystrength": 50.0, "vibrato": 60.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 171, "prop": "PlaySound", "attributes": {"key": "$MHR_skillroar_hyper", "volume": 1.0}}, {"id": 172, "prop": "PlaySound", "attributes": {"key": "$MHR_normalpunch_voice", "volume": 1.0}}, {"id": 173, "prop": "PlaySound", "attributes": {"key": "$MHR_normalpunch_echo", "volume": 1.0}}, {"id": 174, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 175, "prop": "Blocker", "attributes": {"a": 1.0, "r": 1.0, "g": 1.0, "b": 1.0, "fadetime": 0.05, "block": "true"}}, {"id": 176, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "false"}}, {"id": 177, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 178, "prop": "name", "attributes": {"content": "那......那是什么？我从来没见过这种生物——", "name": "空爆"}}, {"id": 179, "prop": "name", "attributes": {"content": "这家伙......难道就是“雷之主”？！", "name": "梓兰"}}, {"id": 180, "prop": "name", "attributes": {"content": "居然只一击就把大型源石虫解决了......", "name": "空爆"}}, {"id": 181, "prop": "name", "attributes": {"content": "......", "name": "“雷之主”"}}, {"id": 182, "prop": "Dialog", "attributes": {}}, {"id": 183, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 184, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 185, "prop": "Dialog", "attributes": {}}, {"id": 186, "prop": "Image", "attributes": {}}, {"id": 187, "prop": "charslot", "attributes": {}}, {"id": 188, "prop": "hidecgitem", "attributes": {}}, {"id": 189, "prop": "Background", "attributes": {"image": "71_g4_bambooforest", "screenadapt": "coverall"}}, {"id": 190, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 191, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 192, "prop": "Del