e": 1.0}}, {"id": 122, "prop": "Delay", "attributes": {"time": 3.5}}, {"id": 123, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 124, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 125, "prop": "charslot", "attributes": {}}, {"id": 126, "prop": "verticalbg", "attributes": {}}, {"id": 127, "prop": "image", "attributes": {"image": "49_i07", "screenadapt": "coverall"}}, {"id": 128, "prop": "ImageTween", "attributes": {"xScaleFrom": 1.2, "yScaleFrom": 1.2, "xScaleTo": 1.0, "yScaleTo": 1.0, "duration": 40.0, "block": "false"}}, {"id": 129, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 130, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 131, "prop": "Delay", "attributes": {"time": 3.5}}, {"id": 132, "prop": "name", "attributes": {"content": "原来......"}}, {"id": 133, "prop": "name", "attributes": {"content": "在被文明荒废的漫长时间里，也有这些堪称伟大的时刻留下痕迹，如同那些迅速熄灭的恒星。"}}, {"id": 134, "prop": "name", "attributes": {"content": "多么难得啊，陆不再执着于她天真的计划，就连弗里斯顿也选择交出了希望。"}}, {"id": 135, "prop": "name", "attributes": {"content": "AMa-10，这就是你留恋的？"}}, {"id": 136, "prop": "name", "attributes": {"content": "原来这就是你的理由......Dr.{@nickname}。"}}, {"id": 137, "prop": "name", "attributes": {"content": "只是因为你在他们的文明中，看到了与我们相似的挣扎？"}}, {"id": 138, "prop": "Dialog", "attributes": {}}, {"id": 139, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 140, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 141, "prop": "image", "attributes": {}}, {"id": 142, "prop": "charslot", "attributes": {}}, {"id": 143, "prop": "Background", "attributes": {"image": "60_g4_rhodesabyss_w", "screenadapt": "coverall", "block": "true"}}, {"id": 144, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 145, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 146, "prop": "name", "attributes": {"content": "可是，这还不够，远远不够。"}}, {"id": 147, "prop": "name", "attributes": {"content": "我理解你的情感，但这不足以让我为他们的存续让出空间。"}}, {"id": 148, "prop": "name", "attributes": {"content": "我们的时间不多了，源石的生长还需要更多土壤与时间，而末日近在眼前。"}}, {"id": 149, "prop": "name", "attributes": {"content": "如果......如果你相信他们最终能够揭开那道帷幕，那他们也理应能够跨过眼前这些不值一提的障碍，超过他们自身。"}}, {"id": 150, "prop": "name", "attributes": {"content": "尽管向我证明吧。"}}, {"id": 151, "prop": "Dialog", "attributes": {}}, {"id": 152, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 153, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 154, "prop": "charslot", "attributes": {}}, {"id": 155, "prop": "Image", "attributes": {}}], "OPTIONTRACE": true}