0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 255, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 256, "prop": "playMusic", "attributes": {"intro": "$ponder_intro", "key": "$ponder_loop", "volume": 0.6}}, {"id": 257, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4071_peper_1#8$1", "focus": "m"}}, {"id": 258, "prop": "name", "attributes": {"content": "这里......这些士兵，都被杀死了？", "name": "明椒"}, "figure_art": "avg_4071_peper_1#8$1"}, {"id": 259, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4071_peper_1#8$1", "focus": "m"}}, {"id": 260, "prop": "name", "attributes": {"content": "是敌人吗？！如果我早些发现的话......", "name": "明椒"}, "figure_art": "avg_4071_peper_1#8$1"}, {"id": 261, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 262, "prop": "name", "attributes": {"content": "......", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 263, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 264, "prop": "name", "attributes": {"content": "他们的家属会收到抚恤金，如果有家属的话。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 265, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4071_peper_1#5$1", "focus": "m"}}, {"id": 266, "prop": "name", "attributes": {"content": "我们必须防备......", "name": "明椒"}, "figure_art": "avg_4071_peper_1#5$1"}, {"id": 267, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 268, "prop": "name", "attributes": {"content": "不用。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 269, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4071_peper_1#8$1", "focus": "m"}}, {"id": 270, "prop": "name", "attributes": {"content": "你的那副表情......你早就知道？", "name": "明椒"}, "figure_art": "avg_4071_peper_1#8$1"}, {"id": 271, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4071_peper_1#9$1", "focus": "m"}}, {"id": 272, "prop": "name", "attributes": {"content": "你......这也是你计划的一部分......", "name": "明椒"}, "figure_art": "avg_4071_peper_1#9$1"}, {"id": 273, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 274, "prop": "name", "attributes": {"content": "这是卡兹戴尔军事委员会的安排。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 275, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 276, "prop": "name", "attributes": {"content": "雇佣兵，牺牲是在所难免的，我以为你的队长早就教过你这一点。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 277, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4071_peper_1#5$1", "focus": "m"}}, {"id": 278, "prop": "name", "attributes": {"content": "你是个将军，他们是你的士兵！", "name": "明椒"}, "figure_art": "avg_4071_peper_1#5$1"}, {"id": 279, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 280, "prop": "name", "attributes": {"content": "是啊，我是个将军，这就是我的工作。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 281, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 282, "prop": "name", "attributes": {"content": "无论是我们的敌人还是我们自己，需要做的事情就是把一个个生命投进这个名为战争的巨口中——", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 283, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 284, "prop": "name", "attributes": {"content": "并祈祷它能吐出让我们称心如意的结果。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 285, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 286, "prop": "name", "attributes": {"content": "这就是以我的立场能做的所有行为。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 287, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4071_peper_1#10$1", "focus": "m"}}, {"id": 288, "prop": "name", "attributes": {"content": "你——", "name": "明椒"}, "figure_art": "avg_4071_peper_1#10$1"}, {"id": 289, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 290, "prop": "name", "attributes": {"content": "所以我会过来，我会过来注视着这一切。看过这里每一张年轻的苍白的脸庞。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 291, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 292, "prop": "name", "attributes": {"content": "我必须牢记，这是我做出的决定。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 293, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 294, "prop": "name", "attributes": {"content": "我不会说这是萨卡兹不得不付出的代价，雇佣兵。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 295, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 296, "prop": "name", "attributes": {"content": "维多利亚人杀死了他们，但是是我让他们被维多利亚人杀死。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 297, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4071_peper_1#10$1", "focus": "m"}}, {"id": 298, "prop": "name", "attributes": {"content": "为什么要这样做？", "name": "明椒"}, "figure_art": "avg_4071_peper_1#10$1"}, {"id": 299, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 300, "prop": "name", "attributes": {"content": "为了点燃火焰。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 301, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 302, "prop": "name", "attributes": {"content": "点燃一场遍及这片大地的火焰。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 303, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 304, "prop": "name", "attributes": {"content": "而我们......萨卡兹，唯有在这样一片纷争的大地上，才有可能找到自己的位置，找到自己生存的空间。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 305, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 306, "prop": "name", "attributes": {"content": "雇佣兵，你必须学会熟悉它。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 307, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 308, "prop": "name", "attributes": {"content": "熟悉它，憎恨它，最后接受它。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 309, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 310, "prop": "name", "attributes": {"content": "因为这是唯一的办法。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 311, "prop": "dialog", "attributes": {}}, {"id": 312, "prop": "charslot", "attributes": {}}, {"id": 313, "prop": "PlaySound", "attributes": {"key": "$firestorm", "volume": 0.3}}, {"id": 314, "prop": "name", "attributes": {"content": "一团明亮的火焰猛然在封锁区中升起，老旧的大楼在熊熊燃烧。"}}, {"id": 315, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4071_peper_1#8$1", "focus": "m"}}, {"id": 316, "prop": "name", "attributes": {"content": "又是......火灾吗？", "name": "明椒"}, "figure_art": "avg_4071_peper_1#8$1"}, {"id": 317, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 318, "prop": "name", "attributes": {"content": "不，那是第一簇火苗。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 319, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 320, "prop": "name", "attributes": {"content": "雇佣兵，跟我来吧，我们需要回到飞空艇上。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 321, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_404_1#1$1", "focus": "m"}}, {"id": 322, "prop": "name", "attributes": {"content": "客人们都已经入席了。", "name": "曼弗雷德"}, "figure_art": "avg_npc_404_1#1$1"}, {"id": 323, "prop": "Dialog", "attributes": {}}, {"id": 324, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 325, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 326, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 327, "prop": "Character", "attributes": {}}, {"id": 328, "prop": "Image", "attributes": {}}], "OPTIONTRACE": true}