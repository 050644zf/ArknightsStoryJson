#14$2", "focus": "m"}}, {"id": 209, "prop": "name", "attributes": {"content": "か、乾杯……", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 210, "prop": "Dialog", "attributes": {}}, {"id": 211, "prop": "charslot", "attributes": {}}, {"id": 212, "prop": "name", "attributes": {"content": "乾杯――！", "name": "周りの人たち"}}, {"id": 213, "prop": "Dialog", "attributes": {}}, {"id": 214, "prop": "PlaySound", "attributes": {"key": "$clink"}}, {"id": 215, "prop": "PlaySound", "attributes": {"key": "$clink", "loop": "false", "channel": "1", "delay": 0.04}}, {"id": 216, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 217, "prop": "name", "attributes": {"content": "乾杯の挨拶が終わると、参加者は再びパーティーを楽しみ始めた。祥子は部屋の隅の壁にひとり寄りかかりながら、複雑な表情で目の前の光景を見つめていた。"}}, {"id": 218, "prop": "Dialog", "attributes": {}}, {"id": 219, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4182_oblvns_1#14$2", "focus": "r"}}, {"id": 220, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 221, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4183_mortis_1#14$3", "posfrom": "-150,0", "posto": "0,0", "duration": 1.0}}, {"id": 222, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 223, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4183_mortis_1#14$3", "focus": "l"}}, {"id": 224, "prop": "name", "attributes": {"content": "祥。", "name": "若葉睦"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 225, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4182_oblvns_1#14$2", "focus": "r"}}, {"id": 226, "prop": "name", "attributes": {"content": "睦……？", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 227, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4183_mortis_1#10$3", "focus": "l"}}, {"id": 228, "prop": "name", "attributes": {"content": "実は……全部知ってるの。", "name": "若葉睦"}, "figure_art": "avg_4183_mortis_1#10$3"}, {"id": 229, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4182_oblvns_1#6$2", "focus": "r"}}, {"id": 230, "prop": "name", "attributes": {"content": "え……？", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#6$2"}, {"id": 231, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4183_mortis_1#10$3", "focus": "l"}}, {"id": 232, "prop": "name", "attributes": {"content": "これは、全部嘘だって……みなみちゃんの優しさも、全部嘘。", "name": "若葉睦"}, "figure_art": "avg_4183_mortis_1#10$3"}, {"id": 233, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4182_oblvns_1#6$2", "focus": "r"}}, {"id": 234, "prop": "name", "attributes": {"content": "そ、それは――", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#6$2"}, {"id": 235, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4183_mortis_1#14$3", "focus": "l"}}, {"id": 236, "prop": "name", "attributes": {"content": "祥に会った時に分かった。そろそろ帰らなきゃいけないって。", "name": "若葉睦"}, "figure_art": "avg_4183_mortis_1#14$3"}, {"id": 237, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4183_mortis_1#13$3", "focus": "l"}}, {"id": 238, "prop": "name", "attributes": {"content": "でも……もう一回、チャンスが欲しい。", "name": "若葉睦"}, "figure_art": "avg_4183_mortis_1#13$3"}, {"id": 239, "prop": "name", "attributes": {"content": "これで最後にする。ちゃんとさよならするから。", "name": "若葉睦"}, "figure_art": "avg_4183_mortis_1#13$3"}, {"id": 240, "prop": "name", "attributes": {"content": "せめて、夢の中だけでも……私も、みんなみたいに、自由に歌わせて。", "name": "若葉睦"}, "figure_art": "avg_4183_mortis_1#13$3"}, {"id": 241, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4182_oblvns_1#10$2", "focus": "r"}}, {"id": 242, "prop": "name", "attributes": {"content": "睦……", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 243, "prop": "Dialog", "attributes": {}}, {"id": 244, "prop": "PlaySound", "attributes": {"key": "$d_avg_walk_stage", "volume": 1.0, "loop": "false", "channel": "nw"}}, {"id": 245, "prop": "stopsound", "attributes": {"fadetime": 2.0, "channel": "nw"}}, {"id": 246, "prop": "charslot", "attributes": {"slot": "l", "afrom": 1.0, "ato": 0.0, "duration": 1.0}}, {"id": 247, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 248, "prop": "Dialog", "attributes": {}}, {"id": 249, "prop": "charslot", "attributes": {}}, {"id": 250, "prop": "name", "attributes": {"content": "祥子の返事を待たずに、睦はクラシックギターを抱えたままゆっくりと人だかりの方へと歩いていく。"}}, {"id": 251, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 252, "prop": "name", "attributes": {"content": "睦ちゃん、準備はいい？", "name": "睦の母"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 253, "prop": "Dialog", "attributes": {}}, {"id": 254, "prop": "charslot", "attributes": {}}, {"id": 255, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 256, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#13$3", "duration": 1.0}}, {"id": 257, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 258, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#16$3", "focus": "m"}}, {"id": 259, "prop": "name", "attributes": {"content": "……うん。", "name": "若葉睦"}, "figure_art": "avg_4183_mortis_1#16$3"}, {"id": 260, "prop": "Dialog", "attributes": {}}, {"id": 261, "prop": "charslot", "attributes": {}}, {"id": 262, "prop": "PlaySound", "attributes": {"key": "$d_avg_cheer_street", "volume": 1.0}}, {"id": 263, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 264, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#16$3", "focus": "m"}}, {"id": 265, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 266, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#9$3", "focus": "m"}}, {"id": 267, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 268, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#10$3", "focus": "m"}}, {"id": 269, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 270, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 271, "prop": "name", "attributes": {"content": "どうしたの、睦ちゃん。何かあった？", "name": "睦の母"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 272, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#16$3", "focus": "m"}}, {"id": 273, "prop": "name", "attributes": {"content": "私の椅子……どこ？", "name": "若葉睦"}, "figure_art": "avg_4183_mortis_1#16$3"}, {"id": 274, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1939_1#1$1", "focus": "m"}}, {"id": 275, "prop": "name", "attributes": {"content": "用意してるわよ。ほら、この椅子、いつも使ってたでしょ？", "name": "睦の母"}, "figure_art": "avg_npc_1939_1#1$1"}, {"id": 276, "prop": "Dialog", "attributes": {}}, {"id": 277, "prop": "charslot", "attributes": {}}, {"id": 278, "prop": "name", "attributes": {"content": "睦は、座面に裂け目のある黒い椅子をじっと見つめた。"}}, {"id": 279, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#13$3", "focus": "m"}}, {"id": 280, "prop": "name", "attributes": {"content": "うん。", "name": "若葉睦"}, "figure_art": "avg_4183_mortis_1#13$3"}, {"id": 281, "prop": "Dialog", "attributes": {}}, {"id": 282, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 283, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothtrailground", "volume": 1.0}}, {"id": 284, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 285, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 286, "prop": "name", "attributes": {"content": "睦がゆっくり腰を下ろすと、周囲がしんと静まった。"}}, {"id": 287, "prop": "Dialog", "attributes": {}}, {"id": 288, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 289, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 290, "prop": "charslot", "attributes": {}}, {"id": 291, "prop": "Background", "attributes": {"image": "bg_black", "screenadapt": "coverall"}}, {"id": 292, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 293, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 294, "prop": "multiline", "attributes": {"name": "若葉睦", "content": "弾くね……"}}, {"id": 295, "prop": "multiline", "attributes": {"name": "若葉睦", "content": "『春日影』。"}}, {"id": 296, "prop": "Dialog", "attributes": {}}, {"id": 297, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 298, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 299, "prop": "charslot", "attributes": {}}, {"id": 300, "prop": "Image", "attributes": {"image": "65_i07_1", "screenadapt": "coverall", "block": "true"}}, {"id": 301, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 302, "prop": "playMusic", "attributes": {"intro": "$warm_intro", "key": "$warm_loop", "volume": 0.6}}, {"id": 303, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 304, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 305, "prop": "name", "attributes": {"content": "――！", "name": "豊川祥子"}}, {"id": 306, "prop": "name", "attributes": {"content": "一生忘れることのできないメロディーが、睦の夢の中で再び奏でられた。"}}, {"id": 307, "prop": "name", "attributes": {"content": "あの日と同じ、温かい音色が、その場にいる皆の心をしっとりと癒やしていく。"}}, {"id": 308, "prop": "name", "attributes": {"content": "しかしその曲を弾く睦の姿は、祥子には別人のように思えた。"}}, {"id": 309, "prop": "name", "attributes": {"content": "かつてギターで悩んでいた睦ではない。"}}, {"id": 310, "prop": "name", "attributes": {"content": "相変わらず感情表現が豊かではないが、ここにいる睦は、とても幸せそうにしている。"}}, {"id": 311, "prop": "Dialog", "attributes": {}}, {"id": 312, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 313, "prop": "Blocker", "attributes": {"a": 0.4, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 314, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "「悴んだ心　ふるえる眼差し」", "x": 300.0, "y": 270.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0, "block": "true"}}, {"id": 315, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n「世界で　僕は ひとりぼっちだった」", "block": "true"}}, {"id": 316, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n「散ることしか知らない春は」", "block": "true"}}, {"id": 317, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n「毎年　冷たくあしらう」", "block": "true"}}, {"id": 318, "prop": "Sticker", "attributes": {"id": "st1"}}, {"id": 319, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 320, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 321, "prop": "name", "attributes": {"content": "睦、これがあなたの……", "name": "豊川祥子"}}, {"id": 322, "prop": "name", "attributes": {"content": "今日、睦をここから連れ出せる機会は何度もあった。そして、おそらく睦もそれを受け入れただろう。"}}, {"id": 323, "prop": "name", "attributes": {"content": "しかし、どうしても連れ出すことができなかった。"}}, {"id": 324, "prop": "name", "attributes": {"content": "睦が心の底から幸せそうだったから。"}}, {"id": 325, "prop": "name", "attributes": {"content": "蝋燭のかすかな灯りが、音楽に合わせて揺れる人々の影を壁に落とす。その影は、まるで暖かな春の日差しが作る木陰のように揺れていた。"}}, {"id": 326, "prop": "name", "attributes": {"content": "睦は椅子に腰かけ、皆に囲まれている。目を閉じ、弦の指で指を滑らせながら、静かに歌っていた。"}}, {"id": 327, "prop": "name", "attributes": {"content": "今、睦は何を思っているのだろう？"}}, {"id": 328, "prop": "Dialog", "attributes": {}}, {"id": 329, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 330, "prop": "Blocker", "attributes": {"a": 0.4, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 331, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n「せつなくて　いとおしい」", "x": 300.0, "y": 230.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0, "block": "true"}}, {"id": 332, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n「今ならば　分かる気がする」", "block": "true"}}, {"id": 333, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n「しあわせで　くるおしい」", "block": "true"}}, {"id": 334, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n「あの日泣けなかった僕を」", "block": "true"}}, {"id": 335, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n「光は　やさしく連れ立つよ――」", "block": "true"}}, {"id": 336, "prop": "Sticker", "attributes": {"id": "st1"}}, {"id": 337, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 338, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 339, "prop": "name", "attributes": {"content": "それを見ているうちに、祥子はある感情に囚われた。"}}, {"id": 340, "prop": "name", "attributes": {"content": "それは安堵か、後悔か……あるいはその両方かもしれない。"}}, {"id": 341, "prop": "name", "attributes": {"content": "今の睦は、二人でいる時よりもずっと楽しそうにしている。"}}, {"id": 342, "prop": "name", "attributes": {"content": "一人で椅子に座り、ひたむきにあの日の歌を歌っている。"}}, {"id": 343, "prop": "Dialog", "attributes": {}}, {"id": 344, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 345, "prop": "Blocker", "attributes": {"a": 0.4, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 346, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "「雲間をぬって　きらりきらり」", "x": 300.0, "y": 200.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0, "block": "true"}}, {"id": 347, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n「心満たしては　溢れ」", "block": "true"}}, {"id": 348, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n「いつしか頬を　きらりきらり」", "block": "true"}}, {"id": 349, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n「熱く　熱く濡らしてゆく」", "block": "true"}}, {"id": 350, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n「君の手は　どうしてこんなに温かいの？」", "block": "true"}}, {"id": 351, "prop": "Sticker", "attributes": {"id": "st1", "multi": "true", "text": "\\n\\n「ねぇお願い、どうかこのまま、離さないでいて――」", "block": "true"}}, {"id": 352, "prop": "Sticker", "attributes": {"id": "st1"}}, {"id": 353, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 354, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 355, "prop": "name", "attributes": {"content": "手を離さなければ――"}}, {"id": 356, "prop": "name", "attributes": {"content": "睦の、幸せのために――"}}, {"id": 357, "prop": "Dialog", "attributes": {}}, {"id": 358, "prop": "PlaySound", "attributes": {"key": "$d_avg_openftstprun", "volume": 1.0, "loop": "true", "channel": "nrun"}}, {"id": 359, "prop": "StopSound", "attributes": {"channel": "nrun", "fadetime": 4.0}}, {"id": 360, "prop": "Image", "attributes": {"image": "65_i07_2", "screenadapt": "coverall", "fadetime": 2.5, "block": "true"}}, {"id": 361, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 362, "prop": "name", "attributes": {"content": "祥子はステージに背を向け、その場から逃げ出した。"}}, {"id": 363, "prop": "name", "attributes": {"content": "そうして、夜の闇に消えていった。"}}, {"id": 364, "prop": "Dialog", "attributes": {}}, {"id": 365, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 366, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 367, "prop": "charslot", "attributes": {}}, {"id": 368, "prop": "Image", "attributes": {}}, {"id": 369, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}