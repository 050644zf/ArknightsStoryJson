{"lang": "ja_JP", "eventid": "act45side", "eventName": "安らかな譫言", "entryType": "ACTIVITY", "storyCode": "SS-3", "avgTag": "戦闘前", "storyName": "音楽室を照らす光", "storyInfo": "夢の中で刑務所に入っていた海鈴は、出所した直後に元雇い主の用心棒フランシスから追われる身となった後、「ドン」から彼のファミリーに加わるよう誘いを受ける。一方で海鈴を探していた祥子はその途中でフランシスと出会い、何か裏があることに気づいた。\n", "storyList": [{"id": 0, "prop": "HEADER", "attributes": {"key": "title_test", "is_skippable": "true", "fit_mode": "BLACK_MASK"}}, {"id": 1, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 2, "prop": "stopmusic", "attributes": {}}, {"id": 3, "prop": "Dialog", "attributes": {}}, {"id": 4, "prop": "Background", "attributes": {"image": "65_g10_dreamcastlestage", "screenadapt": "coverall", "block": "true"}}, {"id": 5, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 6, "prop": "playMusic", "attributes": {"intro": "$loneliness_intro", "key": "$loneliness_loop", "volume": 0.6}}, {"id": 7, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 8, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 9, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.7, "block": "true"}}, {"id": 10, "prop": "Subtitle", "attributes": {"text": "<i>涙のように大雨が降り注ぐ。私は、果てしない海の一滴の水に過ぎない。</i>", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 11, "prop": "Subtitle", "attributes": {"text": "<i>ひとり歩む夜、もう迷いはしない。</i>", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 12, "prop": "Subtitle", "attributes": {"text": "<i>我、恐れることを恐れるなかれ。</i>", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 13, "prop": "subtitle", "attributes": {}}, {"id": 14, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.7, "block": "true"}}, {"id": 15, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 16, "prop": "Dialog", "attributes": {}}, {"id": 17, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 18, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 19, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 20, "prop": "charslot", "attributes": {}}, {"id": 21, "prop": "Background", "attributes": {"image": "bg_cellroomC", "screenadapt": "coverall", "block": "true"}}, {"id": 22, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 23, "prop": "PlayMusic", "attributes": {"key": "$wasteland_loop", "volume": 0.6}}, {"id": 24, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 25, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 26, "prop": "PlaySound", "attributes": {"key": "$d_gen_dooropen", "volume": 0.4}}, {"id": 27, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 28, "prop": "name", "attributes": {"content": "囚人番号48038、出てきなさい。", "name": "看守"}}, {"id": 29, "prop": "name", "attributes": {"content": "看守さん、どうしました？", "name": "興奮する犯人"}}, {"id": 30, "prop": "name", "attributes": {"content": "私物の確認だ、忘れ物はないか？", "name": "看守"}}, {"id": 31, "prop": "name", "attributes": {"content": "ありません、全部揃ってます！", "name": "興奮する犯人"}}, {"id": 32, "prop": "name", "attributes": {"content": "廊下をまっすぐ進んで、一番奥の窓口でサインしろ。そうすればお前はもう自由の身だ。", "name": "看守"}}, {"id": 33, "prop": "name", "attributes": {"content": "は……はい！　ありがとうございます！", "name": "興奮する犯人"}}, {"id": 34, "prop": "Dialog", "attributes": {}}, {"id": 35, "prop": "PlaySound", "attributes": {"key": "$d_avg_openftstprun", "volume": 1.0, "loop": "true", "channel": "a"}}, {"id": 36, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0, "delay": 1.5}}, {"id": 37, "prop": "StopSound", "attributes": {"channel": "a", "fadetime": 4.0}}, {"id": 38, "prop": "Delay", "attributes": {"time": 2.5}}, {"id": 39, "prop": "name", "attributes": {"content": "足早に小走りする音が廊下に響き渡る。"}}, {"id": 40, "prop": "name", "attributes": {"content": "続いて重々しいブーツの足音が、廊下の奥へと少しずつ近付いていく。"}}, {"id": 41, "prop": "Dialog", "attributes": {}}, {"id": 42, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_134", "duration": 0.7}}, {"id": 43, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 44, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_134", "focus": "m"}}, {"id": 45, "prop": "name", "attributes": {"content": "海鈴。", "name": "看守"}, "figure_art": "avg_npc_134"}, {"id": 46, "prop": "Dialog", "attributes": {}}, {"id": 47, "prop": "charslot", "attributes": {}}, {"id": 48, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 49, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#1$3", "duration": 0.7}}, {"id": 50, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 51, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#1$3", "focus": "m"}}, {"id": 52, "prop": "name", "attributes": {"content": "はい。", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#1$3"}, {"id": 53, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_134", "focus": "m"}}, {"id": 54, "prop": "name", "attributes": {"content": "行け。今年中はもう顔を見せるなよ。", "name": "看守"}, "figure_art": "avg_npc_134"}, {"id": 55, "prop": "Dialog", "attributes": {}}, {"id": 56, "prop": "charslot", "attributes": {}}, {"id": 57, "prop": "PlaySound", "attributes": {"key": "$d_gen_dooropen", "volume": 0.8}}, {"id": 58, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 59, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#1$3", "focus": "m"}}, {"id": 60, "prop": "Delay", "attributes": {"time": 0.2}}, {"id": 61, "prop": "PlaySound", "attributes": {"key": "$d_avg_footstep_stonestep", "volume": 0.6, "channel": "step", "loop": "false"}}, {"id": 62, "prop": "stopsound", "attributes": {"channel": "step", "fadetime": 4.0}}, {"id": 63, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 64, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 65, "prop": "name", "attributes": {"content": "海鈴は慣れた手つきで楽器ケースを持つと、ゆっくりと監獄を後にした。"}}, {"id": 66, "prop": "Dialog", "attributes": {}}, {"id": 67, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 68, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 69, "prop": "charslot", "attributes": {}}, {"id": 70, "prop": "Background", "attributes": {"image": "33_g6_newtown_street", "screenadapt": "coverall", "block": "true"}}, {"id": 71, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 72, "prop": "PlaySound", "attributes": {"key": "$d_avg_rainlight_loop", "volume": 0.0, "loop": "true", "channel": "c"}}, {"id": 73, "prop": "SoundVolume", "attributes": {"volume": 1.0, "channel": "c", "fadetime": 2.0}}, {"id": 74, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 75, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 76, "prop": "name", "attributes": {"content": "シラクーザは以前と変わらず、降りしきる小雨で彼女を出迎えた。"}}, {"id": 77, "prop": "Dialog", "attributes": {}}, {"id": 78, "prop": "stopsound", "attributes": {"channel": "c", "fadetime": 3.0}}, {"id": 79, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 80, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 81, "prop": "charslot", "attributes": {}}, {"id": 82, "prop": "Background", "attributes": {"image": "33_g10_smallrestaurant", "screenadapt": "coverall", "block": "true"}}, {"id": 83, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 84, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 85, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 86, "prop": "PlaySound", "attributes": {"key": "$d_avg_crowdrun", "volume": 0.8}}, {"id": 87, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_698_1#1$1", "duration": 1.0}}, {"id": 88, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_699_1#1$1", "duration": 1.0}}, {"id": 89, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 90, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_698_1#1$1", "focus": "l"}}, {"id": 91, "prop": "name", "attributes": {"content": "この通りと、それから前後の通り、すべての店に見張りをつけろ。絶対にあの女を逃がすな！", "name": "用心棒のリーダー"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 92, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_699_1#1$1", "focus": "r"}}, {"id": 93, "prop": "name", "attributes": {"content": "はっ！", "name": "慎重な用心棒"}, "figure_art": "avg_npc_699_1#1$1"}, {"id": 94, "prop": "Dialog", "attributes": {}}, {"id": 95, "prop": "charslot", "attributes": {}}, {"id": 96, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 97, "prop": "PlaySound", "attributes": {"key": "$d_avg_runstop", "volume": 1.0}}, {"id": 98, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_699_1#1$1", "duration": 0.5}}, {"id": 99, "prop": "delay", "attributes": {"time": 0.7}}, {"id": 100, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_699_1#1$1", "focus": "m"}}, {"id": 101, "prop": "name", "attributes": {"content": "兄貴、北通りから報告が入りました。奴がこっちに向かっているそうです！", "name": "慌てる用心棒"}, "figure_art": "avg_npc_699_1#1$1"}, {"id": 102, "prop": "charslot", "attributes": {}}, {"id": 103, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_698_1#1$1", "focus": "r"}}, {"id": 104, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_699_1#1$1", "focus": "r"}}, {"id": 105, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_699_1#1$1", "focus": "r"}}, {"id": 106, "prop": "name", "attributes": {"content": "しっかり見張っておけ、逃がすんじゃねぇぞ！", "name": "用心棒のリーダー"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 107, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_699_1#1$1", "focus": "l"}}, {"id": 108, "prop": "name", "attributes": {"content": "に……逃げる気はないようです。", "name": "慌てる用心棒"}, "figure_art": "avg_npc_699_1#1$1"}, {"id": 109, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_698_1#1$1", "focus": "r"}}, {"id": 110, "prop": "name", "attributes": {"content": "……全員ここに集めろ！", "name": "用心棒のリーダー"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 111, "prop": "Dialog", "attributes": {}}, {"id": 112, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 113, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 114, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 115, "prop": "charslot", "attributes": {}}, {"id": 116, "prop": "Background", "attributes": {"image": "33_g2_srcalley", "screenadapt": "coverall", "block": "true"}}, {"id": 117, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 118, "prop": "PlaySound", "attributes": {"key": "$d_avg_rainlight_loop", "volume": 0.0, "loop": "true", "channel": "d"}}, {"id": 119, "prop": "SoundVolume", "attributes": {"volume": 1.0, "channel": "d", "fadetime": 2.0}}, {"id": 120, "prop": "playMusic", "attributes": {"intro": "$nervous_intro", "key": "$nervous_loop", "volume": 0.6}}, {"id": 121, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 122, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 123, "prop": "name", "attributes": {"content": "狭い路地で、凶悪な顔つきの用心棒たちが、楽器ケースを提げていた少女を取り囲んでいた。"}}, {"id": 124, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 125, "prop": "name", "attributes": {"content": "また会ったな……海鈴。", "name": "用心棒のリーダー"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 126, "prop": "name", "attributes": {"content": "ハッ、どうにも不思議だったぜ。お前みたいな腕利きを、どうしてどのファミリーも抱え込まないのか……", "name": "用心棒のリーダー"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 127, "prop": "name", "attributes": {"content": "うちのファミリーが被害に遭ってから、あちこち聞いて回ってようやく知ったのさ。お前が悪名高い「裏切者」だってことをな。", "name": "用心棒のリーダー"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 128, "prop": "name", "attributes": {"content": "お前はこれまで十数回も名前を変えては、各ファミリーを渡り歩いて依頼を受けていたんだ。", "name": "用心棒のリーダー"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 129, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#9$3", "focus": "m"}}, {"id": 130, "prop": "name", "attributes": {"content": "他のファミリーの仕事を受けるなと？　契約書にはそう書かれていなかったはずですが", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#9$3"}, {"id": 131, "prop": "name", "attributes": {"content": "私はただ報酬を受け取り、相応の仕事を果たすだけ――最初からそう言っていたはずです。", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#9$3"}, {"id": 132, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 133, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 12.0, "ystrength": 15.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 134, "prop": "name", "attributes": {"content": "だから俺たちの機密情報を敵にチクったってのか！？", "name": "用心棒のリーダー"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 135, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#12$3", "focus": "m"}}, {"id": 136, "prop": "name", "attributes": {"content": "……話が見えませんね。", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#12$3"}, {"id": 137, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 138, "prop": "name", "attributes": {"content": "*クルビアスラング*、とぼけるんじゃねぇ！　お前が来てから、俺たちの仲間が次々罠にはめられてるんだ！", "name": "用心棒のリーダー"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 139, "prop": "name", "attributes": {"content": "俺もボスも、あの時はお前を信じて、ファミリーに引き入れてやったんだぞ！", "name": "用心棒のリーダー"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 140, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#7$3", "focus": "m"}}, {"id": 141, "prop": "name", "attributes": {"content": "フランシスさん、あなたたちを怒らせるようなことをした覚えはありませんが。", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#7$3"}, {"id": 142, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 143, "prop": "name", "attributes": {"content": "ふん、裏切った相手が多すぎて、いちいち思い出せねぇってか！？", "name": "フランシス"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 144, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 145, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 146, "prop": "name", "attributes": {"content": "ボスも、仲間たちも皆死んだ。何百人もいたファミリーが、残ったのは十数人だけだ！", "name": "フランシス"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 147, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#7$3", "focus": "m"}}, {"id": 148, "prop": "name", "attributes": {"content": "……どういうことですか。", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#7$3"}, {"id": 149, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 150, "prop": "name", "attributes": {"content": "俺たちはクルビアからやっとの思いでこのクソッタレな場所に流れ着いたんだ。それが全部、お前一人の手で壊滅さ！", "name": "フランシス"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 151, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#7$3", "focus": "m"}}, {"id": 152, "prop": "name", "attributes": {"content": "いえ、私は……", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#7$3"}, {"id": 153, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_699_1#1$1", "focus": "m"}}, {"id": 154, "prop": "name", "attributes": {"content": "無駄話はその辺にしておけ。こっちにはこれだけ人数がいるんだ。今日こそ痛い目を見てもらうぞ！", "name": "怒る用心棒"}, "figure_art": "avg_npc_699_1#1$1"}, {"id": 155, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#12$3", "focus": "m"}}, {"id": 156, "prop": "name", "attributes": {"content": "あなたたちと揉める気はないのですが……", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#12$3"}, {"id": 157, "prop": "Dialog", "attributes": {}}, {"id": 158, "prop": "charslot", "attributes": {}}, {"id": 159, "prop": "name", "attributes": {"content": "海鈴は穏便に済ませるべく穏やかな口調で話していたが、相手は一歩も引く素振りを見せず迫ってくる。"}}, {"id": 160, "prop": "name", "attributes": {"content": "それを見て、海鈴は仕方なく提げていた楽器ケースを下ろした。"}}, {"id": 161, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 162, "prop": "name", "attributes": {"content": "お前ら……俺に続け！", "name": "フランシス"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 163, "prop": "Dialog", "attributes": {}}, {"id": 164, "prop": "PlaySound", "attributes": {"key": "$d_avg_swordexsheath", "volume": 1.0}}, {"id": 165, "prop": "PlaySound", "attributes": {"key": "$d_avg_attack_ready", "volume": 0.6, "delay": 0.7}}, {"id": 166, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 167, "prop": "Dialog", "attributes": {}}, {"id": 168, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 169, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 170, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 171, "prop": "charslot", "attributes": {}}, {"id": 172, "prop": "Image", "attributes": {"image": "cg_rainsplash", "screenadapt": "coverall", "fadetime": 0.0, "block": "true"}}, {"id": 173, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 174, "prop": "PlaySound", "attributes": {"key": "$d_avg_shallowswalk", "volume": 1.0, "loop": "true", "channel": "s"}}, {"id": 175, "prop": "StopSound", "attributes": {"channel": "s", "fadetime": 2.5}}, {"id": 176, "prop": "PlayMusic", "attributes": {"intro": "$mist_intro", "key": "$mist_loop", "volume": 0.6}}, {"id": 177, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 178, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 179, "prop": "name", "attributes": {"content": "お嬢ちゃん、これ以上先には行かない方がいいよ。", "name": "親切なおばあさん"}}, {"id": 180, "prop": "name", "attributes": {"content": "さっき向こうでトラブルがあってね。一人で行くのは危険だから、別の道を通りな。", "name": "親切なおばあさん"}}, {"id": 181, "prop": "name", "attributes": {"content": "……ご忠告ありがとうございます。", "name": "帽子を被った少女"}}, {"id": 182, "prop": "name", "attributes": {"content": "少女は通行人の忠告を無視して、そのまま突き進んでいった。"}}, {"id": 183, "prop": "Dialog", "attributes": {}}, {"id": 184, "prop": "PlaySound", "attributes": {"key": "$d_avg_shallowswalk", "volume": 1.0}}, {"id": 185, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 186, "prop": "Dialog", "attributes": {}}, {"id": 187, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 188, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 189, "prop": "image", "attributes": {}}, {"id": 190, "prop": "charslot", "attributes": {}}, {"id": 191, "prop": "Background", "attributes": {"image": "33_g2_srcalley", "screenadapt": "coverall", "block": "true"}}, {"id": 192, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 193, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 194, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 195, "prop": "name", "attributes": {"content": "ぽつぽつと降る雨が、シラクーザを洗い流していく。"}}, {"id": 196, "prop": "name", "attributes": {"content": "まるで舗装されたばかりの道のように、路地はさっぱりと掃除されていた。"}}, {"id": 197, "prop": "name", "attributes": {"content": "シラクーザの清掃員はいつも通り手際がいい。"}}, {"id": 198, "prop": "name", "attributes": {"content": "湿った空気の中に、血の匂いは少しも感じられなかった。"}}, {"id": 199, "prop": "Dialog", "attributes": {}}, {"id": 200, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#2$3", "duration": 1.0}}, {"id": 201, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 202, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#2$3", "focus": "m"}}, {"id": 203, "prop": "name", "attributes": {"content": "……", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#2$3"}, {"id": 204, "prop": "name", "attributes": {"content": "どなたか、八幡海鈴という方をご存知の方は……", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#2$3"}, {"id": 205, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#2$3", "focus": "n"}}, {"id": 206, "prop": "name", "attributes": {"content": "あんた……海鈴を探してるのか？", "name": "？？？"}}, {"id": 207, "prop": "Dialog", "attributes": {}}, {"id": 208, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#2$3", "focus": "m"}}, {"id": 209, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 210, "prop": "Dialog", "attributes": {}}, {"id": 211, "prop": "charslot", "attributes": {}}, {"id": 212, "prop": "Delay", "attributes": {"time": 0.2}}, {"id": 213, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "duration": 1.0}}, {"id": 214, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 215, "prop": "Dialog", "attributes": {}}, {"id": 216, "prop": "StopSound", "attributes": {"channel": "d", "fadetime": 2.0}}, {"id": 217, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 218, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 219, "prop": "charslot", "attributes": {}}, {"id": 220, "prop": "Background", "attributes": {"image": "33_g11_mansionhall", "screenadapt": "coverall", "block": "true"}}, {"id": 221, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 222, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 223, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 224, "prop": "name", "attributes": {"content": "娯楽施設内のビリヤードルーム。ここを住処にしている者がいるなど、誰ひとり考えもしないだろう。"}}, {"id": 225, "prop": "name", "attributes": {"content": "何枚かの段ボールを並べたベッドが敷かれ、最低限の生活用品はすべてファストフード店の袋に詰め込まれていた。"}}, {"id": 226, "prop": "Dialog", "attributes": {}}, {"id": 227, "prop": "PlaySound", "attributes": {"key": "$d_avg_openenvelope_slow", "volume": 1.0}}, {"id": 228, "prop": "Delay", "attributes": {"time": 3.0}}, {"id": 229, "prop": "PlaySound", "attributes": {"key": "$d_avg_coin"}}, {"id": 230, "prop": "PlaySound", "attributes": {"key": "$d_avg_coin", "loop": "false", "channel": "coin2", "delay": 0.6}}, {"id": 231, "prop": "name", "attributes": {"content": "ビリヤード台の上には大量の封筒が置かれている。その中身はどれも海鈴への報酬だった。"}}, {"id": 232, "prop": "name", "attributes": {"content": "海鈴がそれらの封筒を次々と開き、中の金貨をテーブルの上に一枚一枚置いていくと、「ファミリー」「秩序」と刻まれた金貨が塔のように積み上がった。"}}, {"id": 233, "prop": "name", "attributes": {"content": "その金貨は無防備なまま置かれていた。たとえある日その全てがなくなったとしても、彼女は気にも留めないだろう。"}}, {"id": 234, "prop": "Dialog", "attributes": {}}, {"id": 235, "prop": "PlaySound", "attributes": {"key": "$d_avg_papertear", "volume": 1.0}}, {"id": 236, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 237, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#7$3", "focus": "m"}}, {"id": 238, "prop": "name", "attributes": {"content": "……ん？", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#7$3"}, {"id": 239, "prop": "Dialog", "attributes": {}}, {"id": 240, "prop": "charslot", "attributes": {}}, {"id": 241, "prop": "name", "attributes": {"content": "海鈴はもう一度封筒の中を覗いたが――何も入っていない。"}}, {"id": 242, "prop": "name", "attributes": {"content": "封筒を裏返すと、そこにはファミリーの紋章と、差出人の住所が押印されていた。"}}, {"id": 243, "prop": "Dialog", "attributes": {}}, {"id": 244, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 245, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 246, "prop": "charslot", "attributes": {}}, {"id": 247, "prop": "Background", "attributes": {"image": "33_g7_reception", "screenadapt": "coverall", "block": "true"}}, {"id": 248, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 249, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 250, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 251, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_699_1#1$1", "focus": "m"}}, {"id": 252, "prop": "name", "attributes": {"content": "ドン、奴が来ました。", "name": "厳つい用心棒"}, "figure_art": "avg_npc_699_1#1$1"}, {"id": 253, "prop": "Dialog", "attributes": {}}, {"id": 254, "prop": "charslot", "attributes": {}}, {"id": 255, "prop": "Delay", "attributes": {"time": 0.2}}, {"id": 256, "prop": "PlaySound", "attributes": {"key": "$d_avg_walk_stage", "volume": 1.0, "loop": "false", "channel": "nw"}}, {"id": 257, "prop": "stopsound", "attributes": {"fadetime": 2.0, "channel": "nw"}}, {"id": 258, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#1$3", "duration": 1.0}}, {"id": 259, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 260, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#1$3", "focus": "n"}}, {"id": 261, "prop": "name", "attributes": {"content": "監獄の連中に余計なことをされていないか？", "name": "年老いた声"}}, {"id": 262, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#11$3", "focus": "m"}}, {"id": 263, "prop": "name", "attributes": {"content": "わざわざ揉め事は起こさないでしょう。どれも見知った顔ぶれでしたし、彼らも私のバックに誰がついているかは知っていますので。", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#11$3"}, {"id": 264, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#12$3", "focus": "m"}}, {"id": 265, "prop": "name", "attributes": {"content": "私を呼びつけたのは、そんな些細なことを訊くためではありませんよね。", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#12$3"}, {"id": 266, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#12$3", "focus": "n"}}, {"id": 267, "prop": "name", "attributes": {"content": "ははっ、ただビジネスパートナーの身を案じただけだ。", "name": "年老いた声"}}, {"id": 268, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#12$3", "focus": "m"}}, {"id": 269, "prop": "name", "attributes": {"content": "ドン、いつから私たちはパートナーの間柄になったんですか？", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#12$3"}, {"id": 270, "prop": "name", "attributes": {"content": "以前契約を交わした時は、ファミリーの名義で私に依頼することすら消極的だったと記憶していますが。", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#12$3"}, {"id": 271, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#12$3", "focus": "n"}}, {"id": 272, "prop": "name", "attributes": {"content": "より「パートナー」と呼ぶに相応しい関係になるためには、これからは腹を割って話さねばならん――", "name": "年老いた声"}}, {"id": 273, "prop": "name", "attributes": {"content": "海鈴、私はお前と長期的な取引がしたいと考えている。", "name": "年老いた声"}}, {"id": 274, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#7$3", "focus": "m"}}, {"id": 275, "prop": "name", "attributes": {"content": "わざわざ直接会って話さなければならないほどの取引ですか？", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#7$3"}, {"id": 276, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#7$3", "focus": "n"}}, {"id": 277, "prop": "name", "attributes": {"content": "お前を――うちのファミリーに迎え入れたい。", "name": "年老いた声"}}, {"id": 278, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4186_tmoris_1#6$3", "focus": "m"}}, {"id": 279, "prop": "name", "attributes": {"content": "……", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#6$3"}, {"id": 280, "prop": "name", "attributes": {"content": "ふむ、話を聞かせてもらいましょう。", "name": "八幡海鈴"}, "figure_art": "avg_4186_tmoris_1#6$3"}, {"id": 281, "prop": "Dialog", "attributes": {}}, {"id": 282, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 283, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 284, "prop": "charslot", "attributes": {}}, {"id": 285, "prop": "Background", "attributes": {"image": "33_g11_mansionhall", "screenadapt": "coverall", "block": "true"}}, {"id": 286, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 287, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 288, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 289, "prop": "PlaySound", "attributes": {"key": "$d_avg_open_door", "volume": 0.6}}, {"id": 290, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 291, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.6}}, {"id": 292, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#12$2", "duration": 1.0}}, {"id": 293, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 294, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#12$2", "focus": "m"}}, {"id": 295, "prop": "name", "attributes": {"content": "誰もいませんわね。", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#12$2"}, {"id": 296, "prop": "Dialog", "attributes": {}}, {"id": 297, "prop": "charslot", "attributes": {}}, {"id": 298, "prop": "PlaySound", "attributes": {"key": "$d_avg_runstop", "volume": 1.0}}, {"id": 299, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "duration": 0.5}}, {"id": 300, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 301, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#12$2", "focus": "m"}}, {"id": 302, "prop": "name", "attributes": {"content": "そんなに彼女が怖いのなら、どうしてついて来ましたの？", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#12$2"}, {"id": 303, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 304, "prop": "name", "attributes": {"content": "マフィアじゃないあんたには分からないだろうな。俺は……仲間の敵を討たなきゃならねぇんだ！", "name": "フランシス"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 305, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$2", "focus": "m"}}, {"id": 306, "prop": "name", "attributes": {"content": "そこまでの恨みを持つなんて……あなたたちと彼女との間に一体何があったか、お聞きしてもよいかしら？", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 307, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 308, "prop": "name", "attributes": {"content": "あんたもこういう「裏切り」を経験したら、俺たちの気持ちも理解できるだろうよ……", "name": "フランシス"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 309, "prop": "name", "attributes": {"content": "うちのファミリーのメンバーは、ほとんどがクルビアの開拓地から逃れてきた一般人だ。人脈も資源も乏しいせいで、地元のマフィアにはいつもバカにされてきた。", "name": "フランシス"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 310, "prop": "name", "attributes": {"content": "そんな状況が何年も続いていたが、ある日俺たちのボスは、大金を積んである用心棒を雇ったんだ。", "name": "フランシス"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 311, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$2", "focus": "m"}}, {"id": 312, "prop": "name", "attributes": {"content": "それが彼女でしたのね。", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 313, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 314, "prop": "name", "attributes": {"content": "ああ。奴を雇ってから、俺たちはかなり長い間平穏な日々を過ごせた。", "name": "フランシス"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 315, "prop": "name", "attributes": {"content": "あの頃は本当に良かった。突然アジトを襲われることもなけりゃ、誰かが嫌がらせに来る心配もなかった……", "name": "フランシス"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 316, "prop": "name", "attributes": {"content": "だが、ボスが海鈴をファミリーに迎え入れようとしたら、奴はそれを拒み、次の日には跡形もなく消えちまったんだ。", "name": "フランシス"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 317, "prop": "name", "attributes": {"content": "それを俺たちが不審に思っていた時、敵対組織の奴らを誰かが招き入れて、アジトを襲撃させやがったのさ。それでボスも仲間も皆死んじまった……", "name": "フランシス"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 318, "prop": "name", "attributes": {"content": "思い出したくもねえ……本当に悲惨だったぜ。", "name": "フランシス"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 319, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$2", "focus": "m"}}, {"id": 320, "prop": "name", "attributes": {"content": "彼女があなたたちを売ったとおっしゃいますの？", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 321, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 322, "prop": "name", "attributes": {"content": "あいつ以外に誰がいる！？　偶然にしては出来過ぎだ！", "name": "フランシス"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 323, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#10$2", "focus": "m"}}, {"id": 324, "prop": "name", "attributes": {"content": "……彼女が裏切るなんて、わたくしは信じられませんわ。", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 325, "prop": "name", "attributes": {"content": "わたくしの知るあの方は、あなたのおっしゃるように、優れた能力を持つ、頼もしい方でした。", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 326, "prop": "name", "attributes": {"content": "いつどこに所属していても、自分の役割を全うする方ですのよ。そんな八幡さんが裏切るなど……", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 327, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 328, "prop": "name", "attributes": {"content": "だが、これが事実だ。", "name": "フランシス"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 329, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#12$2", "focus": "m"}}, {"id": 330, "prop": "name", "attributes": {"content": "襲撃してきた人たちの中に、彼女の姿は？", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#12$2"}, {"id": 331, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 332, "prop": "name", "attributes": {"content": "……いいや。", "name": "フランシス"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 333, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#12$2", "focus": "m"}}, {"id": 334, "prop": "name", "attributes": {"content": "では襲撃者の顔は覚えてます？", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#12$2"}, {"id": 335, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 336, "prop": "name", "attributes": {"content": "ああ、一生忘れねぇよ。", "name": "フランシス"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 337, "prop": "Dialog", "attributes": {}}, {"id": 338, "prop": "charslot", "attributes": {}}, {"id": 339, "prop": "name", "attributes": {"content": "祥子は深く息を吸うと、ポケットの護身用武器に手を伸ばした。"}}, {"id": 340, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$2", "focus": "m"}}, {"id": 341, "prop": "name", "attributes": {"content": "もし……八幡さんとあなたたちの関係が、故意に引き裂かれたものだとしたら？", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 342, "prop": "name", "attributes": {"content": "もし……八幡さんが、何者かにずっと監視されていたとしたら？", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#9$2"}, {"id": 343, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_698_1#1$1", "focus": "m"}}, {"id": 344, "prop": "name", "attributes": {"content": "……どういう意味だ？", "name": "フランシス"}, "figure_art": "avg_npc_698_1#1$1"}, {"id": 345, "prop": "Dialog", "attributes": {}}, {"id": 346, "prop": "charslot", "attributes": {}}, {"id": 347, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 348, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 349, "prop": "PlaySound", "attributes": {"key": "$d_avg_opencabinet", "volume": 0.8}}, {"id": 350, "prop": "PlaySound", "attributes": {"key": "$d_avg_open_drawer", "volume": 1.0, "delay": 0.3}}, {"id": 351, "prop": "PlaySound", "attributes": {"key": "$d_avg_opencabinet", "volume": 1.0, "loop": "false", "channel": "k", "delay": 0.5}}, {"id": 352, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 353, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 354, "prop": "name", "attributes": {"content": "フランシスが反応する間もなく、唐突に周囲のクローゼットや大型キャビネットがすべて開かれた。"}}, {"id": 355, "prop": "name", "attributes": {"content": "その中には屈強な体格の用心棒が立っており、手に持った武器を一斉に部屋の中央の二人に向けて構える。"}}, {"id": 356, "prop": "Dialog", "attributes": {}}, {"id": 357, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_699_1#1$1", "duration": 1.0}}, {"id": 358, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_699_1#1$1", "duration": 1.0}}, {"id": 359, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 360, "prop": "playsound", "attributes": {"key": "$d_avg_gunequip", "volume": 0.7}}, {"id": 361, "prop": "PlaySound", "attributes": {"key": "$d_avg_gunload", "volume": 0.9, "delay": 0.2}}, {"id": 362, "prop": "PlaySound", "attributes": {"key": "$shotgunreload", "volume": 1.0, "delay": 0.4}}, {"id": 363, "prop": "playsound", "attributes": {"key": "$d_avg_gunequip", "channel": "1", "volume": 0.3}}, {"id": 364, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 365, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_699_1#1$1", "focus": "all"}}, {"id": 366, "prop": "name", "attributes": {"content": "動くな。", "name": "謎の用心棒"}}, {"id": 367, "prop": "Dialog", "attributes": {}}, {"id": 368, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 369, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 370, "prop": "charslot", "attributes": {}}, {"id": 371, "prop": "Image", "attributes": {}}, {"id": 372, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}