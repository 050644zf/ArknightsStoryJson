}}, {"id": 212, "prop": "Subtitle", "attributes": {"text": "「殺れ――」", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 213, "prop": "subtitle", "attributes": {}}, {"id": 214, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.7, "block": "true"}}, {"id": 215, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 216, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#12$3", "focus": "m"}}, {"id": 217, "prop": "name", "attributes": {"content": "私たちは睦ちゃんにとって、いくつもある影のひとつなんだ。", "name": "「睦」"}, "figure_art": "avg_4183_mortis_1#12$3"}, {"id": 218, "prop": "name", "attributes": {"content": "影がずっと暗闇に隠れるためには、みんなの言う通り、ちょっとした光でも消しておかなきゃ。", "name": "「睦」"}, "figure_art": "avg_4183_mortis_1#12$3"}, {"id": 219, "prop": "Dialog", "attributes": {}}, {"id": 220, "prop": "charslot", "attributes": {"duration": 0.7}}, {"id": 221, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 222, "prop": "name", "attributes": {"content": "「睦」は一歩ずつ祥子に迫り、崖際に追い詰めていく。"}}, {"id": 223, "prop": "Dialog", "attributes": {}}, {"id": 224, "prop": "stopmusic", "attributes": {"fadetime": 1.5}}, {"id": 225, "prop": "PlaySound", "attributes": {"key": "$d_avg_runstop", "volume": 1.0}}, {"id": 226, "prop": "CameraShake", "attributes": {"duration": 0.5, "xstrength": 10.0, "ystrength": 12.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 227, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#5$2", "duration": 0.5}}, {"id": 228, "prop": "delay", "attributes": {"time": 0.7}}, {"id": 229, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#5$2", "focus": "m"}}, {"id": 230, "prop": "name", "attributes": {"content": "……一体何を……！？", "name": "豊川祥子"}, "figure_art": "avg_4182_oblvns_1#5$2"}, {"id": 231, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4183_mortis_1#12$3", "focus": "m"}}, {"id": 232, "prop": "name", "attr