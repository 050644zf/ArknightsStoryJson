{"lang": "ja_JP", "eventid": "act45side", "eventName": "安らかな譫言", "entryType": "ACTIVITY", "storyCode": "SS-2", "avgTag": "戦闘前", "storyName": "静かな廊下の端と端", "storyInfo": "にゃむは夢の中でドラマーとしての身分を捨て、龍門の芸能界の道に進んでいた。しかし毎日演技の練習に励み、様々なイベントに出演する彼女は、芸能活動をあまり楽しめてはいないようだ。ようやく取れた休暇も、ソラと共演するバラエティ番組の予定で埋まってしまう。\n", "storyList": [{"id": 0, "prop": "HEADER", "attributes": {"key": "title_test", "is_skippable": "true", "fit_mode": "BLACK_MASK"}}, {"id": 1, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 2, "prop": "stopmusic", "attributes": {}}, {"id": 3, "prop": "Dialog", "attributes": {}}, {"id": 4, "prop": "Background", "attributes": {"image": "65_g10_dreamcastlestage", "screenadapt": "coverall", "block": "true"}}, {"id": 5, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 6, "prop": "playMusic", "attributes": {"intro": "$loneliness_intro", "key": "$loneliness_loop", "volume": 0.6}}, {"id": 7, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 8, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 9, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.7, "block": "true"}}, {"id": 10, "prop": "Subtitle", "attributes": {"text": "<i>幾千幾万の視線の中、人形のように、身じろぎもしない。</i>", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 11, "prop": "Subtitle", "attributes": {"text": "<i>彼らが求める場所へと赴き、彼らが望む声を届ける。</i>", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 12, "prop": "Subtitle", "attributes": {"text": "<i>我、愛を恐れるなかれ。</i>", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 13, "prop": "subtitle", "attributes": {}}, {"id": 14, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.7, "block": "true"}}, {"id": 15, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 16, "prop": "Dialog", "attributes": {}}, {"id": 17, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 18, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 19, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 20, "prop": "charslot", "attributes": {}}, {"id": 21, "prop": "Background", "attributes": {"image": "bg_wilderness_m", "screenadapt": "coverall", "block": "true"}}, {"id": 22, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 23, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 24, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 25, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#3$2", "duration": 0.7}}, {"id": 26, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 27, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#3$2", "focus": "m"}}, {"id": 28, "prop": "name", "attributes": {"content": "もう丸二日も人の姿を見てない……", "name": "道に迷う少女"}, "figure_art": "avg_4185_amoris_1#3$2"}, {"id": 29, "prop": "name", "attributes": {"content": "龍門……龍門はどこにあるの？　お家はどこ？", "name": "道に迷う少女"}, "figure_art": "avg_4185_amoris_1#3$2"}, {"id": 30, "prop": "name", "attributes": {"content": "お父さん、お母さん……喉渇いた……疲れたよ……", "name": "道に迷う少女"}, "figure_art": "avg_4185_amoris_1#3$2"}, {"id": 31, "prop": "name", "attributes": {"content": "遠くに見える……あれは……ビル？", "name": "道に迷う少女"}, "figure_art": "avg_4185_amoris_1#3$2"}, {"id": 32, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$2", "focus": "m"}}, {"id": 33, "prop": "name", "attributes": {"content": "すぐそこだ……眠っちゃ……ダメ……", "name": "道に迷う少女"}, "figure_art": "avg_4185_amoris_1#1$2"}, {"id": 34, "prop": "Dialog", "attributes": {}}, {"id": 35, "prop": "PlaySound", "attributes": {"key": "$d_avg_cloakmovement", "volume": 1.0}}, {"id": 36, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 37, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 38, "prop": "name", "attributes": {"content": "……", "name": "道に迷う少女"}}, {"id": 39, "prop": "Dialog", "attributes": {}}, {"id": 40, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 41, "prop": "name", "attributes": {"content": "カット！", "name": "？？？"}}, {"id": 42, "prop": "Dialog", "attributes": {}}, {"id": 43, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 44, "prop": "Background", "attributes": {"image": "65_g7_filmandtvstudio", "screenadapt": "coverall", "fadetime": 1.5, "block": "true"}}, {"id": 45, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 46, "prop": "playMusic", "attributes": {"key": "$comedy_loop", "volume": 0.6}}, {"id": 47, "prop": "name", "attributes": {"content": "すごいよ、にゃむちゃん！　まさに俺が思い描いていたシーンそのものだ！", "name": "監督"}}, {"id": 48, "prop": "name", "attributes": {"content": "平凡な田舎の少女がすべてをかなぐり捨て、音楽の夢を追って旅へ踏み出す。", "name": "監督"}}, {"id": 49, "prop": "name", "attributes": {"content": "このシーンは彼女のどん底を描いた場面だ。そしてこの後、彼女は自分を見込んでくれる恩人と出会い、龍門一の人気アーティストになる。", "name": "監督"}}, {"id": 50, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#8$3", "focus": "m"}}, {"id": 51, "prop": "name", "attributes": {"content": "お褒めいただいて光栄です〜！", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#8$3"}, {"id": 52, "prop": "name", "attributes": {"content": "脚本を読ませていただいた時、なんだかこの主人公にすごく共感しちゃったんです。", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#8$3"}, {"id": 53, "prop": "Dialog", "attributes": {}}, {"id": 54, "prop": "charslot", "attributes": {}}, {"id": 55, "prop": "name", "attributes": {"content": "当然だ！　今回の脚本と役は、にゃむちゃんに合わせて用意したものだからね！", "name": "監督"}}, {"id": 56, "prop": "name", "attributes": {"content": "*尚蜀方言*、新年の上映に合わせるために、急遽修正した脚本だろうが……", "name": "脚本家"}}, {"id": 57, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "m"}}, {"id": 58, "prop": "name", "attributes": {"content": "え……？", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#1$3"}, {"id": 59, "prop": "Dialog", "attributes": {}}, {"id": 60, "prop": "charslot", "attributes": {}}, {"id": 61, "prop": "name", "attributes": {"content": "スポンサーが『ドラマーガール』の大ヒットを羨んで、君をこの映画の主演に抜擢したんだ。", "name": "脚本家"}}, {"id": 62, "prop": "name", "attributes": {"content": "それで、君の事務所は映画を新年に上映するよう要求して、監督は一週間以内に脚本を書き直せと命令してきた……", "name": "脚本家"}}, {"id": 63, "prop": "name", "attributes": {"content": "本来の結末では……少女は死ぬ間際、幻とも現実ともつかない夢を見るはずだった。", "name": "脚本家"}}, {"id": 64, "prop": "name", "attributes": {"content": "眩い光の中、才能に恵まれなかった少女がふらふらと授賞式の壇上に上がっていく。", "name": "脚本家"}}, {"id": 65, "prop": "name", "attributes": {"content": "平凡な少女は夢の中で皆に認められ、ついに心の平穏を手に入れる――", "name": "脚本家"}}, {"id": 66, "prop": "name", "attributes": {"content": "それこそがこの映画に相応しい、皮肉のこもった結末だったんだ！", "name": "脚本家"}}, {"id": 67, "prop": "name", "attributes": {"content": "*龍門スラング*、そんなくだらない脚本、にゃむちゃんの力がなかったら、これだけの出資を得られたと思うか？", "name": "監督"}}, {"id": 68, "prop": "name", "attributes": {"content": "誰がそんな出資を求めたって言うんだ？　スポンサーの顔色を伺うのに必死で、芸術の追求を忘れやがって！", "name": "脚本家"}}, {"id": 69, "prop": "name", "attributes": {"content": "現実にはそんな夢物語なんて存在しない。凡人が大勢の注目を浴びる舞台に立てるわけがないんだ！", "name": "脚本家"}}, {"id": 70, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 71, "prop": "name", "attributes": {"content": "*尚蜀方言*、都会育ちのあんたには理解できないだろうな！　だが田舎育ちの俺には分かるんだよ！", "name": "脚本家"}}, {"id": 72, "prop": "name", "attributes": {"content": "三流脚本家が。思い知らせてやる――", "name": "監督"}}, {"id": 73, "prop": "Dialog", "attributes": {}}, {"id": 74, "prop": "PlaySound", "attributes": {"key": "$d_avg_punchsp5"}}, {"id": 75, "prop": "PlaySound", "attributes": {"key": "$d_avg_punch02", "delay": 0.4}}, {"id": 76, "prop": "PlaySound", "attributes": {"key": "$fightgeneral", "volume": 0.6, "delay": 0.7}}, {"id": 77, "prop": "CameraShake", "attributes": {"duration": 1.5, "xstrength": 25.0, "ystrength": 25.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 78, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 79, "prop": "name", "attributes": {"content": "言い争う内に二人の距離は徐々に近付き、ついに殴り合いにまで発展していった。"}}, {"id": 80, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#3$4", "focus": "m"}}, {"id": 81, "prop": "name", "attributes": {"content": "落ち着いてください！　一旦話し合って……", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#3$4"}, {"id": 82, "prop": "Dialog", "attributes": {}}, {"id": 83, "prop": "charslot", "attributes": {}}, {"id": 84, "prop": "PlaySound", "attributes": {"key": "$d_avg_punch02"}}, {"id": 85, "prop": "CameraShake", "attributes": {"duration": 0.7, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 86, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 87, "prop": "name", "attributes": {"content": "あんたの撮ったゴミみたいなカット、ずっと前から*尚蜀スラング*文句をつけたいと思ってたんだ！", "name": "脚本家"}}, {"id": 88, "prop": "name", "attributes": {"content": "覚えてろよ、この映画で俺が出世したら、*龍門スラング*真っ先にお前をクビにしてやる！", "name": "監督"}}, {"id": 89, "prop": "Dialog", "attributes": {}}, {"id": 90, "prop": "PlaySound", "attributes": {"key": "$d_avg_punch", "volume": 0.6}}, {"id": 91, "prop": "CameraShake", "attributes": {"duration": 0.7, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 92, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 93, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#4$3", "focus": "m"}}, {"id": 94, "prop": "name", "attributes": {"content": "ちょっと！　喧嘩してる場合じゃ――", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#4$3"}, {"id": 95, "prop": "Dialog", "attributes": {}}, {"id": 96, "prop": "charslot", "attributes": {"duration": 0.5}}, {"id": 97, "prop": "PlaySound", "attributes": {"key": "$d_avg_crwddiscuss_outside", "volume": 0.0, "loop": "true", "channel": "c"}}, {"id": 98, "prop": "SoundVolume", "attributes": {"volume": 0.5, "channel": "c", "fadetime": 1.0}}, {"id": 99, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 100, "prop": "Dialog", "attributes": {}}, {"id": 101, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 102, "prop": "stopsound", "attributes": {"channel": "c", "fadetime": 2.0}}, {"id": 103, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 104, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 105, "prop": "charslot", "attributes": {}}, {"id": 106, "prop": "Background", "attributes": {"image": "bg_deluxeroom", "screenadapt": "coverall", "block": "true"}}, {"id": 107, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 108, "prop": "playMusic", "attributes": {"key": "$normal_loop", "volume": 0.6}}, {"id": 109, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 110, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 111, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1260_1#1$1", "focus": "m"}}, {"id": 112, "prop": "name", "attributes": {"content": "病院から連絡がありました。監督と脚本家さんは、同じ病室のちょうど向かいのベッドに寝ているそうです。", "name": "マネージャー"}, "figure_art": "avg_npc_1260_1#1$1"}, {"id": 113, "prop": "name", "attributes": {"content": "でも首を固定されているので、お互い睨み合うことしかできないとか。", "name": "マネージャー"}, "figure_art": "avg_npc_1260_1#1$1"}, {"id": 114, "prop": "name", "attributes": {"content": "困りましたね、しばらく撮影は中断になりそうです……", "name": "マネージャー"}, "figure_art": "avg_npc_1260_1#1$1"}, {"id": 115, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "m"}}, {"id": 116, "prop": "name", "attributes": {"content": "そうですか……。まあ、最近ゆっくりと休めてなかったので、ちょうどよかったかもです〜。", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#1$3"}, {"id": 117, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1260_1#1$1", "focus": "m"}}, {"id": 118, "prop": "name", "attributes": {"content": "今後の撮影スケジュールについては、目処が立ったら連絡しますので、それまでは待機でお願いしますね。", "name": "マネージャー"}, "figure_art": "avg_npc_1260_1#1$1"}, {"id": 119, "prop": "Dialog", "attributes": {}}, {"id": 120, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.6}}, {"id": 121, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 122, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 123, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#2$3", "focus": "m"}}, {"id": 124, "prop": "name", "attributes": {"content": "（小声）ふぅ、なんかホッとした……", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#2$3"}, {"id": 125, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#7$3", "focus": "m"}}, {"id": 126, "prop": "name", "attributes": {"content": "ダメダメ、気を抜いてる場合じゃない――", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#7$3"}, {"id": 127, "prop": "Dialog", "attributes": {}}, {"id": 128, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#7$3", "focus": "n"}}, {"id": 129, "prop": "PlaySound", "attributes": {"key": "$phonevibration", "volume": 0.8}}, {"id": 130, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 131, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#3$4", "focus": "m"}}, {"id": 132, "prop": "name", "attributes": {"content": "おかーさん……？", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#3$4"}, {"id": 133, "prop": "Dialog", "attributes": {}}, {"id": 134, "prop": "PlaySound", "attributes": {"key": "$d_avg_walk_stage", "volume": 1.0, "loop": "false", "channel": "nw"}}, {"id": 135, "prop": "stopsound", "attributes": {"fadetime": 3.0, "channel": "nw"}}, {"id": 136, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 137, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 138, "prop": "PlaySound", "attributes": {"key": "$d_avg_trnpndor", "volume": 0.7}}, {"id": 139, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 140, "prop": "Background", "attributes": {"image": "bg_rooftop_2", "screenadapt": "coverall", "fadetime": 1.0, "block": "true"}}, {"id": 141, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 142, "prop": "name", "attributes": {"content": "少女は電話を取ると、窓を開けてベランダに出た。"}}, {"id": 143, "prop": "name", "attributes": {"content": "にゃむ、晩ご飯な食べたつね？　最近は忙（せわ）しかと？", "name": "電話越しの声"}}, {"id": 144, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "m"}}, {"id": 145, "prop": "name", "attributes": {"content": "食べたばい。", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#1$3"}, {"id": 146, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "n"}}, {"id": 147, "prop": "name", "attributes": {"content": "うちの麦のまたよう穫れたばい。毎日朝早うから外出て、日の沈むまで働きっぱなしだったたいね。", "name": "電話越しの声"}}, {"id": 148, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#8$3", "focus": "m"}}, {"id": 149, "prop": "name", "attributes": {"content": "はぁ、前にも言ったたい？　無理せんで、田舎でのんびり暮らせばよかたいて。", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#8$3"}, {"id": 150, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#8$3", "focus": "n"}}, {"id": 151, "prop": "name", "attributes": {"content": "あんたのくたびれとらんか心配しとるとたい。疲れの溜まっとるなら、いっぺん休みに帰ってきなっせ。", "name": "電話越しの声"}}, {"id": 152, "prop": "name", "attributes": {"content": "そうそう、今年の連休で何か食べたかもんのあるね？　おとーちゃんと一緒に用意しとくけん……", "name": "電話越しの声"}}, {"id": 153, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#3$4", "focus": "m"}}, {"id": 154, "prop": "name", "attributes": {"content": "連休の時は帰れんたい！　みんな休んどる時が、アタシの一番忙（せわ）しか時だけん……", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#3$4"}, {"id": 155, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#3$4", "focus": "n"}}, {"id": 156, "prop": "name", "attributes": {"content": "そぎゃんね……", "name": "電話越しの声"}}, {"id": 157, "prop": "name", "attributes": {"content": "（かすかに聞こえる声）かーちゃん、ねーちゃんやっと電話出たと？", "name": "電話越しの声"}}, {"id": 158, "prop": "PlaySound", "attributes": {"key": "$d_avg_walkfast", "volume": 0.3}}, {"id": 159, "prop": "name", "attributes": {"content": "（近付いてくる足音）", "name": "電話越しの声"}}, {"id": 160, "prop": "name", "attributes": {"content": "ねーちゃん！　テレビでねーちゃんの出とる新しい映画の予告やっとったばい！", "name": "電話越しの声"}}, {"id": 161, "prop": "name", "attributes": {"content": "こっちな映画館のなかけん残念たい、あったらチケット買ったとにね……", "name": "電話越しの声"}}, {"id": 162, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#8$3", "focus": "m"}}, {"id": 163, "prop": "name", "attributes": {"content": "ふふ、心配しなすな。後でディスクの出たら、ねーちゃんがそっちに送るけんね。", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#8$3"}, {"id": 164, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#8$3", "focus": "n"}}, {"id": 165, "prop": "name", "attributes": {"content": "やったー！", "name": "電話越しの声"}}, {"id": 166, "prop": "name", "attributes": {"content": "ねーちゃん、映画ん中でドラムば叩いとったと、だごむしゃんよかった！", "name": "電話越しの声"}}, {"id": 167, "prop": "name", "attributes": {"content": "俺も最近、前にねーちゃんの使（つこ）とったやつでドラムの練習ば始めたばい！", "name": "電話越しの声"}}, {"id": 168, "prop": "name", "attributes": {"content": "ねーちゃん最近どんどんドラム上手なっとる！　俺もいつか、ねーちゃんみたいにステージでライブしたか！", "name": "電話越しの声"}}, {"id": 169, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "m"}}, {"id": 170, "prop": "name", "attributes": {"content": "アタシは……あはは、最近忙（せわ）しかけん、そぎゃん練習できとらんつたい。", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#1$3"}, {"id": 171, "prop": "name", "attributes": {"content": "ばってん、練習サボる気はなかけんね。明日はちょうど休みだし、一緒に練習頑張ろうたい！", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#1$3"}, {"id": 172, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "n"}}, {"id": 173, "prop": "name", "attributes": {"content": "うん！　かーちゃんがもう寝ろて言わすけん、ねーちゃんも早（は）よ寝なっせ！", "name": "電話越しの声"}}, {"id": 174, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "m"}}, {"id": 175, "prop": "name", "attributes": {"content": "みんな体には気をつけなっせー。おやすみー。", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#1$3"}, {"id": 176, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "n"}}, {"id": 177, "prop": "name", "attributes": {"content": "おやすみー！", "name": "電話越しの声"}}, {"id": 178, "prop": "Dialog", "attributes": {}}, {"id": 179, "prop": "charslot", "attributes": {}}, {"id": 180, "prop": "PlaySound", "attributes": {"key": "$d_avg_phonestop", "volume": 1.0}}, {"id": 181, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 182, "prop": "PlaySound", "attributes": {"key": "$phonevibration", "volume": 0.8}}, {"id": 183, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 184, "prop": "PlaySound", "attributes": {"key": "$d_avg_ringoff", "volume": 1.0}}, {"id": 185, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 186, "prop": "name", "attributes": {"content": "にゃむさん、先ほど事務所から急に連絡がありまして、大型バラエティ番組から出演オファーが来ているそうです。", "name": "電話越しの声"}}, {"id": 187, "prop": "name", "attributes": {"content": "収録は明日の夜八時から、翌日の二時までの予定です。こちらで大丈夫そうですか？", "name": "電話越しの声"}}, {"id": 188, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#4$3", "focus": "m"}}, {"id": 189, "prop": "name", "attributes": {"content": "かなり急ですね……", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#4$3"}, {"id": 190, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#4$3", "focus": "n"}}, {"id": 191, "prop": "name", "attributes": {"content": "それが……もう一人のゲストが、アイドルのソラさんなんです。", "name": "電話越しの声"}}, {"id": 192, "prop": "name", "attributes": {"content": "ソラさんはこちらに引けを取らないほど人気のアイドルで、業界の内外問わず非常に評判のいい方なんですよ。", "name": "電話越しの声"}}, {"id": 193, "prop": "name", "attributes": {"content": "これは注目を集める絶好のチャンスです。タイトなスケジュールにはなりますが、またとない機会ですので……", "name": "電話越しの声"}}, {"id": 194, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#2$3", "focus": "m"}}, {"id": 195, "prop": "name", "attributes": {"content": "ふぅん……", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#2$3"}, {"id": 196, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "m"}}, {"id": 197, "prop": "name", "attributes": {"content": "じゃあ――「みなさんとの共演楽しみにしてます！」って伝えてください。", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#1$3"}, {"id": 198, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "n"}}, {"id": 199, "prop": "name", "attributes": {"content": "分かりました。では今日のお仕事は終了ですね。", "name": "電話越しの声"}}, {"id": 200, "prop": "name", "attributes": {"content": "お疲れ様でした、にゃむさん。おやすみなさい。", "name": "電話越しの声"}}, {"id": 201, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#2$3", "focus": "m"}}, {"id": 202, "prop": "name", "attributes": {"content": "（……少なくとも、今日はやっとゆっくり眠れるかな。）", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#2$3"}, {"id": 203, "prop": "Dialog", "attributes": {}}, {"id": 204, "prop": "PlaySound", "attributes": {"key": "$d_avg_phonestop", "volume": 1.0}}, {"id": 205, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 206, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "m"}}, {"id": 207, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 208, "prop": "PlaySound", "attributes": {"key": "$d_avg_walk_stage", "volume": 1.0, "loop": "false", "channel": "nw1"}}, {"id": 209, "prop": "stopsound", "attributes": {"fadetime": 3.0, "channel": "nw1"}}, {"id": 210, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 211, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 212, "prop": "PlaySound", "attributes": {"key": "$d_avg_trnclsdor", "volume": 0.7}}, {"id": 213, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 214, "prop": "Background", "attributes": {"image": "bg_deluxeroom", "screenadapt": "coverall", "fadetime": 1.0, "block": "true"}}, {"id": 215, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 216, "prop": "Dialog", "attributes": {}}, {"id": 217, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovement", "volume": 0.7}}, {"id": 218, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothtrailground", "volume": 1.0, "delay": 1.2}}, {"id": 219, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 220, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 221, "prop": "name", "attributes": {"content": "彼女は顔を上げて、テーブルの上にある時計に目を向けた。時刻は「00:23」を示している。"}}, {"id": 222, "prop": "name", "attributes": {"content": "ソファに勢いよく倒れ込むと、すぐに身体が中に沈んでいき、彼女の全身はクッションにしっかりと包み込まれた。"}}, {"id": 223, "prop": "Dialog", "attributes": {}}, {"id": 224, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 225, "prop": "name", "attributes": {"content": "ドラム、もう何ヶ月も叩いてないなー……", "name": "祐天寺にゃむ"}}, {"id": 226, "prop": "name", "attributes": {"content": "にゃむは重い足取りで電子ドラムの前に向かった。シンバルの上には、うっすらと埃がかぶっている。"}}, {"id": 227, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#7$3", "focus": "m"}}, {"id": 228, "prop": "name", "attributes": {"content": "……スティックどこいったっけ？", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#7$3"}, {"id": 229, "prop": "Dialog", "attributes": {}}, {"id": 230, "prop": "charslot", "attributes": {}}, {"id": 231, "prop": "name", "attributes": {"content": "最後にいつスティックを握ったかも、思い出せなくなっていた。"}}, {"id": 232, "prop": "name", "attributes": {"content": "実家にいた頃だっけ？　それとも、もっと前の『ドラマーガール』撮影の時だったっけ？"}}, {"id": 233, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#7$3", "focus": "m"}}, {"id": 234, "prop": "name", "attributes": {"content": "……ま、いっか。テレビでも観て寝よ。", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#7$3"}, {"id": 235, "prop": "Dialog", "attributes": {}}, {"id": 236, "prop": "charslot", "attributes": {}}, {"id": 237, "prop": "PlaySound", "attributes": {"key": "$d_avg_walk_stage", "volume": 1.0, "loop": "false", "channel": "slide1"}}, {"id": 238, "prop": "stopsound", "attributes": {"fadetime": 2.0, "channel": "slide1"}}, {"id": 239, "prop": "charslot", "attributes": {"duration": 0.7}}, {"id": 240, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 241, "prop": "PlaySound", "attributes": {"key": "$d_avg_devicebeep", "volume": 1.0}}, {"id": 242, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 243, "prop": "name", "attributes": {"content": "ファンのみなさんこんばんは、新人女優のにゃむでーす！", "name": "テレビの声"}}, {"id": 244, "prop": "name", "attributes": {"content": "アタシが主演の最新映画『ドラマーガール』が上映中だよ！　すんごい面白い映画だから、みんな映画館で観てみてねー。", "name": "テレビの声"}}, {"id": 245, "prop": "Dialog", "attributes": {}}, {"id": 246, "prop": "PlaySound", "attributes": {"key": "$d_avg_result", "volume": 0.5}}, {"id": 247, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 248, "prop": "name", "attributes": {"content": "アタシの夢は龍門一の――ううん、テラで一番のドラマーになること！", "name": "テレビの声"}}, {"id": 249, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#3$4", "focus": "m"}}, {"id": 250, "prop": "name", "attributes": {"content": "……", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#3$4"}, {"id": 251, "prop": "Dialog", "attributes": {}}, {"id": 252, "prop": "charslot", "attributes": {}}, {"id": 253, "prop": "name", "attributes": {"content": "アタシと一緒に、理想の自分になろ？", "name": "テレビの声"}}, {"id": 254, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$4", "focus": "m"}}, {"id": 255, "prop": "name", "attributes": {"content": "……", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#1$4"}, {"id": 256, "prop": "name", "attributes": {"content": "プロとして生きる以上、何かを手放さないといけない時もある……それで間違ってないよね。", "name": "祐天寺にゃむ"}, "figure_art": "avg_4185_amoris_1#1$4"}, {"id": 257, "prop": "Dialog", "attributes": {}}, {"id": 258, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 259, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 260, "prop": "charslot", "attributes": {}}, {"id": 261, "prop": "Image", "attributes": {}}, {"id": 262, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}