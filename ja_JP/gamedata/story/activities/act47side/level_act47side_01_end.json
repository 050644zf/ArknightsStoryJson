}}, {"id": 55, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1044_1#1$1", "focus": "l", "isblock": "true"}}, {"id": 56, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1044_1#1$1", "focus": "l", "isblock": "true"}}, {"id": 57, "prop": "name", "attributes": {"content": "白衣を羽織ったくらいで、偉くなったつもりか？　お前もその小娘も、大統領の服を着たってスラムから来たクズなんだよ。", "name": "街のならず者A"}, "figure_art": "avg_npc_1044_1#1$1"}, {"id": 58, "prop": "dialog", "attributes": {}}, {"id": 59, "prop": "charslot", "attributes": {}}, {"id": 60, "prop": "PlaySound", "attributes": {"key": "$d_avg_punch", "volume": 1.0}}, {"id": 61, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 62, "prop": "delay", "attributes": {"time": 0.3}}, {"id": 63, "prop": "PlaySound", "attributes": {"key": "$d_avg_punch02", "volume": 1.0}}, {"id": 64, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 30.0, "ystrength": 30.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 65, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 66, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2039_1#10$2", "posfrom": "0,-60", "posto": "0,0", "duration": 2.0, "isblock": "false"}}, {"id": 67, "prop": "charslot", "attributes": {"slot": "m", "action": "shake", "power": 7.0, "times": 30.0, "duration": 0.5, "isblock": "false"}}, {"id": 68, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 69, "prop": "name", "attributes": {"content": "ハッ……ドブの中の鼷獣には、偉大という言葉の意味なんざ、一生わからないんだろうな。", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#10$2"}, {"id": 70, "prop": "charslot", "attributes": {"slot": "m", "focus": "m", "name": "avg_npc_1044_1#1$1"}}, {"id": 71, "prop": "name", "attributes": {"content": "なんだと！？　もう一遍言ってみろ！", "name": "街のならず者B"}, "figure_art": "avg_npc_1044_1#1$1"}, {"id": 72, "prop": "dialog", "attributes": {}}, {"id": 73, "prop": "cha