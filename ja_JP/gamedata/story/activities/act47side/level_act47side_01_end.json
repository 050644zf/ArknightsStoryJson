name", "attributes": {"content": "あ、あの、申し訳ない……", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#5$2"}, {"id": 134, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2039_1#3$2"}}, {"id": 135, "prop": "name", "attributes": {"content": "あの人、あの空の上の偉大な人……", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#3$2"}, {"id": 136, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2039_1#12$2"}}, {"id": 137, "prop": "name", "attributes": {"content": "あの人の名前を、教えてもらえませんか？", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#12$2"}, {"id": 138, "prop": "dialog", "attributes": {}}, {"id": 139, "prop": "charslot", "attributes": {}}, {"id": 140, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_891_1#1$1", "posfrom": "200,0", "posto": "200,0", "bstart": 0.2, "bend": 0.7, "isblock": "true"}}, {"id": 141, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_891_1#1$1", "posfrom": "-200,0", "posto": "-200,0", "duration": 1.2, "isblock": "true"}}, {"id": 142, "prop": "name", "attributes": {"content": "クリステン。", "name": "ナスティ"}, "figure_art": "avg_npc_891_1#1$1"}, {"id": 143, "prop": "name", "attributes": {"content": "クリステン・ライトだ。", "name": "ナスティ"}, "figure_art": "avg_npc_891_1#1$1"}, {"id": 144, "prop": "dialog", "attributes": {}}, {"id": 145, "prop": "charslot", "attributes": {}}, {"id": 146, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 3.0, "keep": "true", "initamount": 0.0, "amount": 1.0, "block": "true"}}, {"id": 147, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 148, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 149, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 150, "prop": "charslot", "attributes": {}}, {"id": 151, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 0.0, "keep": "true", "initamount": 1.0, "amount": 0.0, "block": "false"}}, {"id": 152, "prop": "Background", "attributes": {"image": "38_g10_ecolab", "screenadapt": "coverall"}}, {"id": 153, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 154, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4212_nasti_1#1$1", "posfrom": "10,0", "posto": "10,0"}}, {"id": 155, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2039_1#7$1", "posfrom": "-10,0", "posto": "-10,0"}}, {"id": 156, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 157, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 158, "prop": "playMusic", "attributes": {"key": "$darkness_03_loop", "volume": 0.6}}, {"id": 159, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 160, "prop": "name", "attributes": {"content": "ナスティ主任、ラッキーシスティビーストフードは明日滞在資格取り消しの手続きを行います。", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 161, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 162, "prop": "name", "attributes": {"content": "再チェックに合格できなかったのか？", "name": "ナスティ"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 163, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 164, "prop": "name", "attributes": {"content": "全く基準に達していませんでした。一番最初にパークへ入った組織転換企業の一つなんですが、大衆の「天空フィーバー」に迎合するために、当時の審査条件はかなり緩くて――", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 165, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#5$1"}}, {"id": 166, "prop": "name", "attributes": {"content": "彼らに雇われたモニターはどうなる？", "name": "ナスティ"}, "figure_art": "avg_4212_nasti_1#5$1"}, {"id": 167, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#8$1"}}, {"id": 168, "prop": "name", "attributes": {"content": "あの支配人、モーターの種類もろくにわかってないんですよ。きっと「プロペラパラダイス」の名前を借りて大儲けすることしか考えてなくて……", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#8$1"}, {"id": 169, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#5$1"}}, {"id": 170, "prop": "name", "attributes": {"content": "え、今なんて？", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#5$1"}, {"id": 171, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#4$1"}}, {"id": 172, "prop": "name", "attributes": {"content": "いや。このパークの名前をかなり気に入っているようだな。", "name": "ナスティ"}, "figure_art": "avg_4212_nasti_1#4$1"}, {"id": 173, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 174, "prop": "name", "attributes": {"content": "そのまま「星の庭」って呼ばれてたら、もっと良かったんですけどね。", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 175, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 176, "prop": "name", "attributes": {"content": "スカイ、君がリングラボの技術遺産の公開に賛成していないことは知っている。", "name": "ナスティ"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 177, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 178, "prop": "name", "attributes": {"content": "「統括代理」の決定を非難するつもりはありませんよ。ですが、保守的すぎる決断は、我々が本来得るはずだったリスペクトを失わせています。", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 179, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 180, "prop": "name", "attributes": {"content": "欠片程度のデータサポートだけで、多くのテクノロジー企業が生まれています。一方で何千何万ものクルビア国民を照らすリングラボは、五歳の子供でも遊べるような知育用おもちゃにされて……", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 181, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 182, "prop": "name", "attributes": {"content": "今やクルビア人の誰もが「宇宙」と口にしますが、この新しい言葉の出典がクリステンさんの公開した実験日誌であることを覚えている人は、ほとんどいないんです。", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 183, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 184, "prop": "name", "attributes": {"content": "本当の意味で、クリステンさんを追悼する人間なんて一人もいません。ナスティ主任、あなたですらもです。", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 185, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 186, "prop": "name", "attributes": {"content": "記録と回顧は歴史学者の仕事だ。我々が成すべきことは、検証されたデータを分析し、確実かつ有効な方向性に進むことだけだ。", "name": "ナスティ"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 187, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 188, "prop": "name", "attributes": {"content": "ですが、そのデータと方向性はどうなりました？", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 189, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 190, "prop": "name", "attributes": {"content": "ここ二年の間、ライン生命は十数の小型ラボを買収し、様々なプロジェクトを推し進めています。ただ一つ、クリステンの遺産だけを残して。", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 191, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 192, "prop": "name", "attributes": {"content": "このエキスポで我々は、ライン生命の星の庭に対する後続の研究成果を初公開して、三流以下のテクノロジー企業たちに心底感服させて、天空探索という領域と大衆の視野へと戻るんです。", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 193, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 194, "prop": "name", "attributes": {"content": "生態研究園がリングラボからのデータに基づいていることも、植物を用いたエネルギー輸送でエネルギー供給システムを構築することが工学設計上の偉業と言えるものだということも知っています。", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 195, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#8$1"}}, {"id": 196, "prop": "name", "attributes": {"content": "苗の栽培やプランターユニットの舗設に、エンジニアリングチェック。これらすべては我々の実験を進めるため……ですが、事前見学に展示される機会ももらえない「植物園」だけで足りるのですか？", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#8$1"}, {"id": 197, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#8$1"}}, {"id": 198, "prop": "name", "attributes": {"content": "……", "name": "ナスティ"}, "figure_art": "avg_4212_nasti_1#8$1"}, {"id": 199, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 200, "prop": "name", "attributes": {"content": "どうか教えてください、ナスティ主任。あの夜以前に誰もクリステンさんが天幕を突き破ろうとしていたなんて知らなかったように、ライン生命もここでより大きな目標があるんですよね？", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 201, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 202, "prop": "name", "attributes": {"content": "トリマウンツの夜はすでに過ぎて久しい。", "name": "ナスティ"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 203, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 204, "prop": "name", "attributes": {"content": "……", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 205, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 206, "prop": "name", "attributes": {"content": "次の企業の点検に向けて準備を頼む。リストの順番に調整が入ったので、気を付けてくれ。", "name": "ナスティ"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 207, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 208, "prop": "name", "attributes": {"content": "はい。", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 209, "prop": "dialog", "attributes": {}}, {"id": 210, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "-10,0", "posto": "-30,0", "duration": 0.8, "isblock": "false"}}, {"id": 211, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 212, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 213, "prop": "name", "attributes": {"content": "スカイ。", "name": "ナスティ"}}, {"id": 214, "prop": "dialog", "attributes": {}}, {"id": 215, "prop": "delay", "attributes": {"time": 0.3}}, {"id": 216, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 217, "prop": "name", "attributes": {"content": "……", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 218, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#4$1"}}, {"id": 219, "prop": "name", "attributes": {"content": "気持ちはわかる。君がクリステンに感化されてライン生命に入ったことも知っている。", "name": "ナスティ"}, "figure_art": "avg_4212_nasti_1#4$1"}, {"id": 220, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#8$1"}}, {"id": 221, "prop": "name", "attributes": {"content": "あの夜、大勢の者が空を見上げた。だが、誰もが空を追い求め始めたわけではない。", "name": "ナスティ"}, "figure_art": "avg_4212_nasti_1#8$1"}, {"id": 222, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#4$1"}}, {"id": 223, "prop": "name", "attributes": {"content": "君に第一歩を踏み出させた理由を忘れるな。", "name": "ナスティ"}, "figure_art": "avg_4212_nasti_1#4$1"}, {"id": 224, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 225, "prop": "name", "attributes": {"content": "……点検用の資料を準備してきます、主任。", "name": "スカイ"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 226, "prop": "dialog", "attributes": {}}, {"id": 227, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 228, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "-30,0", "posto": "-50,0", "afrom": 1.0, "ato": 0.0, "duration": 1.0, "isblock": "true"}}, {"id": 229, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 230, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#9$1"}}, {"id": 231, "prop": "name", "attributes": {"content": "……", "name": "ナスティ"}, "figure_art": "avg_4212_nasti_1#9$1"}, {"id": 232, "prop": "dialog", "attributes": {}}, {"id": 233, "prop": "Dialog", "attributes": {}}, {"id": 234, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 235, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 236, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 237, "prop": "charslot", "attributes": {}}, {"id": 238, "prop": "Background", "attributes": {"image": "38_g13_trimountlivingroom", "screenadapt": "coverall"}}, {"id": 239, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 240, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 241, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1", "duration": 0.8, "isblock": "true"}}, {"id": 242, "prop": "name", "attributes": {"content": "……権限カード、契約書とパーク内汎用連絡先一覧をお受け取りください。改めて、あなたのチームの「プロペラパラダイス」加入を歓迎します。ようこそ！", "name": "スタッフ"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 243, "prop": "name", "attributes": {"content": "次の方！　何かお手伝いできることは？", "name": "スタッフ"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 244, "prop": "dialog", "attributes": {}}, {"id": 245, "prop": "charslot", "attributes": {}}, {"id": 246, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 247, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#2$1", "duration": 1.2, "isblock": "true"}}, {"id": 248, "prop": "name", "attributes": {"content": "滞在資格の取り消しを……", "name": "アスペン"}, "figure_art": "avg_npc_2041_1#2$1"}, {"id": 249, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 250, "prop": "name", "attributes": {"content": "どの企業の代表の方でしょうか？", "name": "スタッフ"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 251, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#5$1"}}, {"id": 252, "prop": "name", "attributes": {"content": "ラッキーシスティビーストフードです。", "name": "アスペン"}, "figure_art": "avg_npc_2041_1#5$1"}, {"id": 253, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 254, "prop": "name", "attributes": {"content": "合計八十二名のモニターの解約ですね？", "name": "スタッフ"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 255, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#2$1"}}, {"id": 256, "prop": "name", "attributes": {"content": "はい、彼らと私自身の資料は全部こちらに。", "name": "アスペン"}, "figure_art": "avg_npc_2041_1#2$1"}, {"id": 257, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 258, "prop": "name", "attributes": {"content": "かしこまりました、少々お待ちください。", "name": "スタッフ"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 259, "prop": "dialog", "attributes": {}}, {"id": 260, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1", "afrom": 1.0, "ato": 0.0, "duration": 0.8, "isblock": "true"}}, {"id": 261, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 262, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#2$1"}}, {"id": 263, "prop": "name", "attributes": {"content": "……", "name": "アスペン"}, "figure_art": "avg_npc_2041_1#2$1"}, {"id": 264, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#5$1"}}, {"id": 265, "prop": "name", "attributes": {"content": "はあ、俺は影月に頭でもぶたれたのかな？　エキスポに参加すれば絶対元が取れると確信して、むやみやたらに八十二人も企業での就職経験がない素人を雇ってメンツを立てる真似をするなんて……", "name": "アスペン"}, "figure_art": "avg_npc_2041_1#5$1"}, {"id": 266, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#5$1"}}, {"id": 267, "prop": "name", "attributes": {"content": "だけど、ここの企業は全部同じ事やってるじゃないか。なんでよりによって消えるのがうちなんだ！", "name": "アスペン"}, "figure_art": "avg_npc_2041_1#5$1"}, {"id": 268, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#1$2"}}, {"id": 269, "prop": "name", "attributes": {"content": "問題点への対処がちょっと遅れただけで、百万以上の金券がパーになるのか？　ふざけるな！", "name": "アスペン"}, "figure_art": "avg_npc_2041_1#1$2"}, {"id": 270, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#1$2"}}, {"id": 271, "prop": "name", "attributes": {"content": "ちくしょうが。ワンブーツシャドウムーン不動産はその「三次元浮遊境界杭」とやらの技術問題をどうやって解決したんだ？　靴職人どもしかいないくせに？", "name": "アスペン"}, "figure_art": "avg_npc_2041_1#1$2"}, {"id": 272, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 273, "prop": "name", "attributes": {"content": "ミスター・アスペン、手続きが終わりました。パーク内の通信は本日までお使いいただけます。", "name": "スタッフ"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 274, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#2$1"}}, {"id": 275, "prop": "name", "attributes": {"content": "わかりました……", "name": "アスペン"}, "figure_art": "avg_npc_2041_1#2$1"}, {"id": 276, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 277, "prop": "name", "attributes": {"content": "ですが、もしワンブーツシャドウムーン不動産と同じく、あなたにも「特別」な需要があるのでしたら……喜んで対応させていただきますよ。", "name": "スタッフ"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 278, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#4$1"}}, {"id": 279, "prop": "name", "attributes": {"content": "はあ？　どういう意味だ？", "name": "アスペン"}, "figure_art": "avg_npc_2041_1#4$1"}, {"id": 280, "prop": "dialog", "attributes": {}}, {"id": 281, "prop": "charslot", "attributes": {}}, {"id": 282, "prop": "PlaySound", "attributes": {"key": "$d_avg_paper1", "volume": 1.0}}, {"id": 283, "prop": "name", "attributes": {"content": "微笑むスタッフはパーク内にいる者の誰もが一冊は持っている連絡先一覧を取り出し、そのうち一つの電話番号をアスペンに示した。"}}, {"id": 284, "prop": "name", "attributes": {"content": "名前も住所も記載がなく、数万の電話番号の間に埋もれたこの目立たない一連の数字は、まるでアスペンに残された微かな希望のようだった。"}}, {"id": 285, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#4$1"}}, {"id": 286, "prop": "name", "attributes": {"content": "ここに電話をかければ、俺が今抱えてる問題は解決できるのか？　「ラッキーシスティビースト」は、サイエンスパークを離れなくても済むのか？", "name": "アスペン"}, "figure_art": "avg_npc_2041_1#4$1"}, {"id": 287, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 288, "prop": "name", "attributes": {"content": "はい。", "name": "スタッフ"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 289, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#3$1"}}, {"id": 290, "prop": "name", "attributes": {"content": "ならば、職員の解雇を取り消したい、それに企業滞在資格の取り消し申請も――", "name": "アスペン"}, "figure_art": "avg_npc_2041_1#3$1"}, {"id": 291, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 292, "prop": "name", "attributes": {"content": "ご安心ください、「ラッキーシスティビースト」の滞在資格は取り消していません。ですが、モニターの解雇は撤回不要かと。", "name": "スタッフ"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 293, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1041_1#1$1"}}, {"id": 294, "prop": "name", "attributes": {"content": "電話はあなたが抱えている問題を「徹底的」に解決するでしょう。そうすればモニターの方々はもう必要ありません。", "name": "スタッフ"}, "figure_art": "avg_npc_1041_1#1$1"}, {"id": 295, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#5$1"}}, {"id": 296, "prop": "name", "attributes": {"content": "奇跡なのか？　それとも、詐欺か……？", "name": "アスペン"}, "figure_art": "avg_npc_2041_1#5$1"}, {"id": 297, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2041_1#3$1"}}, {"id": 298, "prop": "name", "attributes": {"content": "考えるのはもうやめた。ここに残れるのなら、試してやろうじゃないか。", "name": "アスペン"}, "figure_art": "avg_npc_2041_1#3$1"}, {"id": 299, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 300, "prop": "dialog", "attributes": {}}, {"id": 301, "prop": "charslot", "attributes": {}}, {"id": 302, "prop": "PlaySound", "attributes": {"key": "$d_avg_telephone", "volume": 1.0}}, {"id": 303, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 304, "prop": "PlaySound", "attributes": {"key": "$d_avg_makephonecall", "volume": 1.0}}, {"id": 305, "prop": "delay", "attributes": {"time": 1.8}}, {"id": 306, "prop": "PlaySound", "attributes": {"key": "$d_avg_telephonebusy", "volume": 1.0}}, {"id": 307, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 308, "prop": "Dialog", "attributes": {}}, {"id": 309, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 310, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 311, "prop": "charslot", "attributes": {}}, {"id": 312, "prop": "Background", "attributes": {"image": "68_g7_airrestaurant", "screenadapt": "coverall"}}, {"id": 313, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 314, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 315, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 316, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2034_1#1$1", "duration": 1.5}}, {"id": 317, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2037_1#1$1", "duration": 1.5, "isblock": "true"}}, {"id": 318, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#6$1"}}, {"id": 319, "prop": "name", "attributes": {"content": "ゴードン長官。", "name": "マーシア"}, "figure_art": "avg_npc_2037_1#6$1"}, {"id": 320, "prop": "playMusic", "attributes": {"key": "$normal_loop", "volume": 0.6}}, {"id": 321, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#3$1"}}, {"id": 322, "prop": "name", "attributes": {"content": "ふむ、当ててみようじゃねぇか。ナスティは半信半疑ながらも俺が提案したリストを受け取って、俺の提案を飲んだ。違うか？", "name": "ゴードン"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 323, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#1$1"}}, {"id": 324, "prop": "name", "attributes": {"content": "はい、エンジニア部門の今日の点検予定を確認したところ、完全に長官が指定した順番通りでした。", "name": "マーシア"}, "figure_art": "avg_npc_2037_1#1$1"}, {"id": 325, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#5$1"}}, {"id": 326, "prop": "name", "attributes": {"content": "ですが、どうしてそれをご存じなのですか？", "name": "マーシア"}, "figure_art": "avg_npc_2037_1#5$1"}, {"id": 327, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#2$1"}}, {"id": 328, "prop": "name", "attributes": {"content": "ナスティが最終的にどんな選択をしたかは知らんが、俺は今人生で一番輝かしい日々を過ごしているんだ。何をやっても俺の思い通りだぜ！", "name": "ゴードン"}, "figure_art": "avg_npc_2034_1#2$1"}, {"id": 329, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#1$1"}}, {"id": 330, "prop": "name", "attributes": {"content": "確かに、とてもお喜びになっておりますね。", "name": "マーシア"}, "figure_art": "avg_npc_2037_1#1$1"}, {"id": 331, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#8$1"}}, {"id": 332, "prop": "name", "attributes": {"content": "いや、たかがライン生命の主任じゃ、俺の心を動かすにゃ足りねぇな。", "name": "ゴードン"}, "figure_art": "avg_npc_2034_1#8$1"}, {"id": 333, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#3$1"}}, {"id": 334, "prop": "name", "attributes": {"content": "テーブルにある手紙を読んでみろ。", "name": "ゴードン"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 335, "prop": "dialog", "attributes": {}}, {"id": 336, "prop": "PlaySound", "attributes": {"key": "$d_avg_paper2", "volume": 1.0}}, {"id": 337, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#11$1"}}, {"id": 338, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 339, "prop": "name", "attributes": {"content": "「酒類・煙草・アーツユニット及び源石製品管理局からゴードン・タネン長官へ、『プロペラパラダイス』の総責任者への御就任をお祝いすべく、書状をお送りさせていただきました……」", "name": "マーシア"}, "figure_art": "avg_npc_2037_1#11$1"}, {"id": 340, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#11$1"}}, {"id": 341, "prop": "name", "attributes": {"content": "二枚綴りですか？　これほど長いお祝いの言葉なんて見たことがありません。", "name": "マーシア"}, "figure_art": "avg_npc_2037_1#11$1"}, {"id": 342, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#1$1"}}, {"id": 343, "prop": "name", "attributes": {"content": "六ヶ月前、クルビアの国境で俺が受け取った異動メールはたったの二行しかなかったぜ。", "name": "ゴードン"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 344, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#1$1"}}, {"id": 345, "prop": "name", "attributes": {"content": "どいつも管理局でのポジションは稼げると思っているが、あの七年間、俺はサーミの野蛮人やサルゴンジャングルの原住民から「甘い汁」なんてこれっぽちも吸えてねぇよ。", "name": "ゴードン"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 346, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#3$1"}}, {"id": 347, "prop": "name", "attributes": {"content": "あの時、狡猾な老いぼれは俺のことが目障りで、管理局の他の人間も俺にいい顔をしなかった。それがどうだ？　あいつは定年退職、俺は昇進だ。風向きってのは変わるもんだ。", "name": "ゴードン"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 348, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#3$1"}}, {"id": 349, "prop": "name", "attributes": {"content": "まだ昼間だが、めでたい日だからな。まさに――", "name": "ゴードン"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 350, "prop": "dialog", "attributes": {}}, {"id": 351, "prop": "PlaySound", "attributes": {"key": "$d_avg_openbeer", "volume": 1.0}}, {"id": 352, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#6$1"}}, {"id": 353, "prop": "delay", "attributes": {"time": 0.3}}, {"id": 354, "prop": "name", "attributes": {"content": "杯を傾けるにちょうどいい、ですね。", "name": "マーシア"}, "figure_art": "avg_npc_2037_1#6$1"}, {"id": 355, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#1$1"}}, {"id": 356, "prop": "name", "attributes": {"content": "長官、お望みのシャンパンです。", "name": "マーシア"}, "figure_art": "avg_npc_2037_1#1$1"}, {"id": 357, "prop": "dialog", "attributes": {}}, {"id": 358, "prop": "PlaySound", "attributes": {"key": "$d_avg_winglssice", "volume": 1.0}}, {"id": 359, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 360, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#3$1"}}, {"id": 361, "prop": "name", "attributes": {"content": "さすがの手際だな、マーちゃん。ナスティの件も、この酒も、あんたが俺の側で成長した証だ。自分の分も注ぎな。", "name": "ゴードン"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 362, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#1$1"}}, {"id": 363, "prop": "name", "attributes": {"content": "ありがとうございます。ですが、秘書規程に則れば、仕事中の飲酒は禁じられているはずです。", "name": "マーシア"}, "figure_art": "avg_npc_2037_1#1$1"}, {"id": 364, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#1$1"}}, {"id": 365, "prop": "name", "attributes": {"content": "気にすんな、その冊子は俺のでっちあげだしな。", "name": "ゴードン"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 366, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#1$1"}}, {"id": 367, "prop": "name", "attributes": {"content": "でしたら……何か祝辞をお願いしてもよろしいでしょうか？", "name": "マーシア"}, "figure_art": "avg_npc_2037_1#1$1"}, {"id": 368, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#1$1"}}, {"id": 369, "prop": "name", "attributes": {"content": "うむ……六日後のエキスポは、ほんの起点に過ぎない。俺の開会式辞は、必ずやクルビアを揺るがすものになる。", "name": "ゴードン"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 370, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#3$1"}}, {"id": 371, "prop": "name", "attributes": {"content": "俺はこれから、全てのロケットの外装に俺の胸像が刻まれて、影月に建てられる一番大きな街が、俺にちなんで名付けられるのを見届けるんだ。", "name": "ゴードン"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 372, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#2$1"}}, {"id": 373, "prop": "name", "attributes": {"content": "ライン生命だろうが、管理局だろうが、D.C.政府だろうが、俺に命令することはできやしねぇ。変なヘマさえしなければ、ここは永遠にゴードン・タネンの「プロペラパラダイス」だ！", "name": "ゴードン"}, "figure_art": "avg_npc_2034_1#2$1"}, {"id": 374, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_npc_2034_1#2$1"}}, {"id": 375, "prop": "name", "attributes": {"content": "乾杯！", "name": "ゴードン"}, "figure_art": "avg_npc_2034_1#2$1"}, {"id": 376, "prop": "PlaySound", "attributes": {"key": "$clink", "volume": 1.0}}, {"id": 377, "prop": "dialog", "attributes": {}}, {"id": 378, "prop": "charslot", "attributes": {}}, {"id": 379, "prop": "delay", "attributes": {"time": 1.2}}, {"id": 380, "prop": "PlaySound", "attributes": {"key": "$doorknockquite", "volume": 1.0}}, {"id": 381, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 382, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2034_1#1$1", "focus": "r"}}, {"id": 383, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2037_1#1$1", "focus": "r"}}, {"id": 384, "prop": "name", "attributes": {"content": "誰だ？　俺のパーティーに飛び入り参加か？", "name": "ゴードン"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 385, "prop": "dialog", "attributes": {}}, {"id": 386, "prop": "charslot", "attributes": {}}, {"id": 387, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 388, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1000_1#1$1", "posfrom": "250,0", "posto": "0,0", "duration": 1.2, "isblock": "true"}}, {"id": 389, "prop": "name", "attributes": {"content": "こんにちは、サイエンスパークの総責任者の方ですか？", "name": "見知らぬ男"}, "figure_art": "avg_npc_1000_1#1$1"}, {"id": 390, "prop": "name", "attributes": {"content": "私、オークリーと申します。「プロペラパラダイス」に特別招聘された解説員で、ゴードン長官へ着任のごあいさつに参りました。", "name": "見知らぬ男"}, "figure_art": "avg_npc_1000_1#1$1"}, {"id": 391, "prop": "charslot", "attributes": {}}, {"id": 392, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2034_1#6$1", "focus": "r"}}, {"id": 393, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2037_1#1$1", "focus": "r"}}, {"id": 394, "prop": "name", "attributes": {"content": "……", "name": "ゴードン"}, "figure_art": "avg_npc_2034_1#6$1"}, {"id": 395, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2037_1#12$1"}}, {"id": 396, "prop": "name", "attributes": {"content": "……", "name": "マーシア"}, "figure_art": "avg_npc_2037_1#12$1"}, {"id": 397, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 398, "prop": "name", "attributes": {"content": "ブッフォーー！", "name": "ゴードン"}, "figure_art": "avg_npc_2034_1#6$1"}, {"id": 399, "prop": "charslot", "attributes": {}}, {"id": 400, "prop": "name", "attributes": {"content": "ゴードンは口に含んだシャンパンを全て噴き出してしまった。"}}, {"id": 401, "prop": "dialog", "attributes": {}}, {"id": 402, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 403, "prop": "Blocker", "attributes": {"a": 