utes": {"key": "$dooropenquite"}}, {"id": 191, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 192, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_172_svrash_1#1$1", "duration": 1.0}}, {"id": 193, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "duration": 1.0}}, {"id": 194, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 195, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "focus": "l"}}, {"id": 196, "prop": "name", "attributes": {"content": "또 찾아와 귀찮게 굴어 죄송합니다, 엔시오데스 님.", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 197, "prop": "name", "attributes": {"content": "골치 아픈 때인 만큼 만나고 싶은 사람은 따로 있겠지만……", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 198, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_172_svrash_1#10$1", "focus": "r"}}, {"id": 199, "prop": "name", "attributes": {"content": "우리 사이에 그게 무슨 말씀입니까.", "name": "엔시오데스"}, "figure_art": "avg_172_svrash_1#10$1"}, {"id": 200, "prop": "name", "attributes": {"content": "자작님께서는 쉐라그를 보살펴 주시지 않았습니까. 그래서 저도 직접 찾아뵙고 감사 인사를 드리려던 참이었습니다.", "name": "엔시오데스"}, "figure_art": "avg_172_svrash_1#10$1"}, {"id": 201, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#14$1", "focus": "l"}}, {"id": 202, "prop": "name", "attributes": {"content": "별말씀을요…… 쉐라그를 다시 찾으니 참으로 감개무량합니다.", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#14$1"}, {"id": 203, "prop": "name", "attributes": {"content": "이곳에 올 때마다 좋은 소식을 전해주고, 이 늙은이는 설산에서 좀 쉬고 싶었는데 말입니다.", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#14$1"}, {"id": 204, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "focus": "l"}}, {"id": 205, "prop": "name", "attributes": {"content": "하지만 세상일이라는 건 워낙 변화무쌍하지 않습니까, 임기응변이라는 것도 배워야 하는 법이겠죠.", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 206, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_172_svrash_1#1$1", "focus": "r"}}, {"id": 207, "prop": "name", "attributes": {"content": "그래도 자작님께서 캐스터 공작을 위해 제게 나쁜 소식을 전하진 않을 거라고 생각합니다.", "name": "엔시오데스"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 208, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#11$1", "focus": "l"}}, {"id": 209, "prop": "name", "attributes": {"content": "음, 그 노인네의 일에는 더 이상 관여할 생각 없습니다.", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#11$1"}, {"id": 210, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#14$1", "focus": "l"}}, {"id": 211, "prop": "name", "attributes": {"content": "아 물론, 지난번에 쉐라그에 왔을 때를 생각해 보면…… 제가 관여하는 걸 더 싫어했던 건 그쪽이었지만요.", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#14$1"}, {"id": 212, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_172_svrash_1#1$1", "focus": "r"}}, {"id": 213, "prop": "name", "attributes": {"content": "그렇다면 자작님께서는……", "name": "엔시오데스"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 214, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#4$1", "focus": "l"}}, {"id": 215, "prop": "name", "attributes": {"content": "허허, 본론으로 들어갑시다. 바쁘신 거 압니다.", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#4$1"}, {"id": 216, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "focus": "l"}}, {"id": 217, "prop": "name", "attributes": {"content": "엔시오데스 님에게 작별 인사를 하러 왔습니다.", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 218, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_172_svrash_1#2$1", "focus": "r"}}, {"id": 219, "prop": "name", "attributes": {"content": "최근에 빅토리아에 대한 여론이 자작님께 폐가 됐다면 제가……", "name": "엔시오데스"}, "figure_art": "avg_172_svrash_1#2$1"}, {"id": 220, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#6$1", "focus": "l"}}, {"id": 221, "prop": "name", "attributes": {"content": "아니…… 그게 아닙니다……", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#6$1"}, {"id": 222, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#11$1", "focus": "l"}}, {"id": 223, "prop": "name", "attributes": {"content": "……전 터무니없는 기대를 약간이나마 품고 있었습니다. 그 노인네도 이젠 '어진 말'을 할 나이가 됐잖습니까.", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#11$1"}, {"id": 224, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#8$1", "focus": "l"}}, {"id": 225, "prop": "name", "attributes": {"content": "근데, 그러면 어진 마음을 보여야 하는 거 아닙니까? 물론, 지금은 이 지경이 되어버렸죠.", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#8$1"}, {"id": 226, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#3$1", "focus": "l"}}, {"id": 227, "prop": "name", "attributes": {"content": "나이가 들어 노망이 든 것처럼 보일 수도 있겠지만, 그래도 얼굴 보고 직접 묻고 싶은 게 있었습니다……", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#3$1"}, {"id": 228, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#12$1", "focus": "l"}}, {"id": 229, "prop": "name", "attributes": {"content": "정말 다른 방법이 없습니까?", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#12$1"}, {"id": 230, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_172_svrash_1#1$1", "focus": "r"}}, {"id": 231, "prop": "name", "attributes": {"content": "자작님께서는 캐스터 공작이 원하는 게 광산 몇 개가 다가 아니라는 걸 알고 계시겠죠.", "name": "엔시오데스"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 232, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_172_svrash_1#9$1", "focus": "r"}}, {"id": 233, "prop": "name", "attributes": {"content": "엔시아를 건드린 순간부터 이건 제가 수용할 수 없는 협상이 됐습니다.", "name": "엔시오데스"}, "figure_art": "avg_172_svrash_1#9$1"}, {"id": 234, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#15$1", "focus": "l"}}, {"id": 235, "prop": "name", "attributes": {"content": "그래서 어떻게 상대하실 생각입니까? 설마 전쟁이라도 할 생각인가요?", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#15$1"}, {"id": 236, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_172_svrash_1#1$1", "focus": "r"}}, {"id": 237, "prop": "name", "attributes": {"content": "자작님께서 저보다 잘 아시겠지만, '무력 충돌'을 마지노선으로 생각하지 않았다면, 아마 쉐라그는 이미 캐스터 공작의 손아귀에 들어갔을 겁니다.", "name": "엔시오데스"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 238, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#11$1", "focus": "l"}}, {"id": 239, "prop": "multiline", "attributes": {"name": "해럴드", "content": "저야 물론…… "}}, {"id": 240, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#16$1", "focus": "l"}}, {"id": 241, "prop": "multiline", "attributes": {"name": "해럴드", "content": "하아, 무슨 말을 해야 좋을까요."}}, {"id": 242, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#3$1", "focus": "l"}}, {"id": 243, "prop": "name", "attributes": {"content": "그 노인네의 성격은 잘 알고 계시잖습니까. 상황이 이 지경까지 왔으니, 절대 가만있지 않을 겁니다.", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#3$1"}, {"id": 244, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#11$1", "focus": "l"}}, {"id": 245, "prop": "name", "attributes": {"content": "엔시오데스 님, 전 당신이 진심으로 걱정됩니다. 이제 어떡하실 생각인가요.", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#11$1"}, {"id": 246, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_172_svrash_1#2$1", "focus": "r"}}, {"id": 247, "prop": "name", "attributes": {"content": "다른 방법이 있을까요? '순리를 따르는 것'을 제외한다면 말이죠.", "name": "엔시오데스"}, "figure_art": "avg_172_svrash_1#2$1"}, {"id": 248, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_172_svrash_1#1$1", "focus": "r"}}, {"id": 249, "prop": "name", "attributes": {"content": "그나저나, 자작께서도 캐스터 공작과 오래 알고 지냈던 사이 아닙니까?", "name": "엔시오데스"}, "figure_art": "avg_172_svrash_1#1$1"}, {"id": 250, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#7$1", "focus": "l"}}, {"id": 251, "prop": "multiline", "attributes": {"name": "해럴드", "content": "저요? "}}, {"id": 252, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#6$1", "focus": "l"}}, {"id": 253, "prop": "multiline", "attributes": {"name": "해럴드", "content": "어휴, 아닙니다. 전혀요."}}, {"id": 254, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "focus": "l"}}, {"id": 255, "prop": "name", "attributes": {"content": "몇 년 전까지만 해도 가끔 일상적인 이야기를 나누곤 했어요. 늘 캐스터 후손들 얘기를 하면서, 쓸만한 놈이 하나도 없다며 이를 갈더군요.", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 256, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#14$1", "focus": "l"}}, {"id": 257, "prop": "name", "attributes": {"content": "근데, 그럴수록 일처리 방식이 급해지더군요. 그 노인네가 젊었을 적에는 속을 헤아리기 어려운 사람이었는지 누가 상상이나 할 수 있겠습니까……", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#14$1"}, {"id": 258, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_172_svrash_1#4$1", "focus": "r"}}, {"id": 259, "prop": "name", "attributes": {"content": "10여 년 전에 저도 공작님을 뵈었던 적이 있는데, 그때 봤던 그 고귀하고 우아한 자태가 아직도 눈에 선합니다.", "name": "엔시오데스"}, "figure_art": "avg_172_svrash_1#4$1"}, {"id": 260, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "focus": "l"}}, {"id": 261, "prop": "name", "attributes": {"content": "하하, 저한테 그런 말은 하실 필요 없습니다.", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 262, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#4$1", "focus": "l"}}, {"id": 263, "prop": "name", "attributes": {"content": "저는 알아요. 그 노인네는 그 거만한 귀족 행세를 절대 고치지 못할 겁니다.", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#4$1"}, {"id": 264, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#14$1", "focus": "l"}}, {"id": 265, "prop": "name", "attributes": {"content": "뒤에서 아무리 계산기를 두드려도 겉으로는 당당하고 체면 있는 모습을 보여야 하니까요.", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#14$1"}, {"id": 266, "prop": "dialog", "attributes": {}}, {"id": 267, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#14$1", "focus": "none"}}, {"id": 268, "prop": "playsound", "attributes": {"key": "$doorknockquite"}}, {"id": 269, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 270, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "focus": "l"}}, {"id": 271, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_172_svrash_1#11$1", "focus": "l"}}, {"id": 272, "prop": "name", "attributes": {"content": "……여기까지 하죠. 부하 직원이 더 급한 일로 엔시오데스 님을 찾고 있으니, 저도 이만 가봐야겠습니다.", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 273, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_172_svrash_1#11$1", "focus": "r"}}, {"id": 274, "prop": "name", "attributes": {"content": "……자작님과의 교류로 배운 게 많습니다.", "name": "엔시오데스"}, "figure_art": "avg_172_svrash_1#11$1"}, {"id": 275, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_172_svrash_1#10$1", "focus": "r"}}, {"id": 276, "prop": "name", "attributes": {"content": "추후 더 좋은 날을 잡아 쉐라그에 초대하겠습니다.", "name": "엔시오데스"}, "figure_art": "avg_172_svrash_1#10$1"}, {"id": 277, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#4$1", "focus": "l"}}, {"id": 278, "prop": "name", "attributes": {"content": "하하, 그러면 더할 나위 없이 좋을 것 같군요!", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#4$1"}, {"id": 279, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#1$1", "focus": "l"}}, {"id": 280, "prop": "name", "attributes": {"content": "아, 참……", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#1$1"}, {"id": 281, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#6$1", "focus": "l"}}, {"id": 282, "prop": "name", "attributes": {"content": "(작은 목소리로) 공작을 만나거든 제가 뒤에서 노인네라고 부르고 다닌다는 건 비밀로 해주십시오.", "name": "해럴드"}, "figure_art": "avg_4114_harold_1#6$1"}, {"id": 283, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_172_svrash_1#10$1", "focus": "r"}}, {"id": 284, "prop": "name", "attributes": {"content": "……물론입니다, 자작님.", "name": "엔시오데스"}, "figure_art": "avg_172_svrash_1#10$1"}, {"id": 285, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4114_harold_1#6$1", "focus": "l"}}, {"id": 286, "prop": "name", "attributes": {"content": "물론……", "name": "해럴드"}