, "loop": "true", "channel": "bgs", "volume": 0.4}}, {"id": 123, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 124, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_136_hsguma_1#5$1", "duration": 0.5}}, {"id": 125, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 126, "prop": "name", "attributes": {"content": "(부인의 바이크?)", "name": "호시구마"}, "figure_art": "avg_136_hsguma_1#5$1"}, {"id": 127, "prop": "dialog", "attributes": {}}, {"id": 128, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_136_hsguma_1#2$1"}}, {"id": 129, "prop": "PlaySound", "attributes": {"key": "$motorbikestart"}}, {"id": 130, "prop": "charslot", "attributes": {"duration": 0.5}}, {"id": 131, "prop": "CameraShake", "attributes": {"xstrength": 5.0, "ystrength": 5.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 132, "prop": "name", "attributes": {"content": "외뿔의 오니가 바이크에 몸을 바짝 붙인 채, 직진 구간이 끝나는 지점을 노리고 그대로 돌진했다."}}, {"id": 133, "prop": "name", "attributes": {"content": "그녀는 휘몰아치는 바람 때문에 추격자와의 거리를 가늠할 수 없었다……"}}, {"id": 134, "prop": "dialog", "attributes": {}}, {"id": 135, "prop": "CameraShake", "attributes": {"duration": 1.0, "xstrength": 15.0, "ystrength": 15.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 136, "prop": "StopSound", "attributes": {"channel": "bgs", "fadetime": 1.0}}, {"id": 137, "prop": "PlaySound", "attributes": {"key": "$drift", "volume": 0.6}}, {"id": 138, "prop": "Delay", "attributes": {"time": 1.5}}, {"id": 139, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#2$1", "duration": 1.0}}, {"id": 140, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 141, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#2$1", "focus": "l"}}, {"id": 142, "prop": "name", "attributes": {"content": "왜 멈췄죠?", "name": "호시구마"}}, {"id": 143, "prop": "dialog", "attributes": {}}, {"id": 144, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1645_1#4$1", "duration": 1.0}}, {"id": 145, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 146, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1645_1#4$1", "focus": "r"}}, {"id": 147, "prop": "name", "attributes": {"content": "경주하자는 건 아니었고, 그냥 같이 달려본 거예요.", "name": "후미즈키"}}, {"id": 148, "prop": "name", "attributes": {"content": "그이에게 듣기로는, 스와이어가 뉴시에스타로 출발하기 전에 남아 있는 분들의 부담을 덜어주겠다고 근위국 일을 깔끔하게 처리해 뒀다던데요.", "name": "후미즈키"}}, {"id": 149, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#2$1", "focus": "l"}}, {"id": 150, "prop": "name", "attributes": {"content": "맞아요. 스와이어가 일을 깔끔하게 처리하고 가준 덕분에 저도 여기에 올 시간이 났던 거고요.", "name": "호시구마"}}, {"id": 151, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1645_1#4$1", "focus": "r"}}, {"id": 152, "prop": "name", "attributes": {"content": "그랬겠죠. 호시구마 경감님은 뭐 때문에 답답하신 거죠?", "name": "후미즈키"}}, {"id": 153, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#9$1", "focus": "l"}}, {"id": 154, "prop": "name", "attributes": {"content": "……얼굴에 쓰여 있나요?", "name": "호시구마"}}, {"id": 155, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1645_1#4$1", "focus": "r"}}, {"id": 156, "prop": "name", "attributes": {"content": "그건 아니에요.", "name": "후미즈키"}}, {"id": 157, "prop": "name", "attributes": {"content": "엑셀을 끝까지 밟아도 마음이 가라앉지 않는다면, 혼자서 끙끙 앓을 문제가 아니죠.", "name": "후미즈키"}}, {"id": 158, "prop": "name", "attributes": {"content": "하필이면 첸과 스와이어가 부재중이라, 주제넘지만 같은 고향 사람인 제가 끼어들 수밖에요.", "name": "후미즈키"}}, {"id": 159, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#5$1", "focus": "l"}}, {"id": 160, "prop": "name", "attributes": {"content": "같은 고향…… 이라고요?", "name": "호시구마"}}, {"id": 161, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1645_1#4$1", "focus": "r"}}, {"id": 162, "prop": "name", "attributes": {"content": "맞아요, 같은 고향이에요.", "name": "후미즈키"}}, {"id": 163, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#2$1", "focus": "l"}}, {"id": 164, "prop": "name", "attributes": {"content": "정말 부인한테는 숨길 수가 없군요. 사실 최근에 편지 한 통을 받았는데……", "name": "호시구마"}}, {"id": 165, "prop": "Dialog", "attributes": {}}, {"id": 166, "prop": "PlaySound", "attributes": {"key": "$d_avg_paper1", "volume": 1.0}}, {"id": 167, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 168, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 169, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 170, "prop": "Sticker", "attributes": {"id": "st1", "text": "안녕한가", "x": 200.0, "y": 130.0, "alignment": "left", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 171, "prop": "Sticker", "attributes": {"id": "st2", "text": "여름이 끝나가지만, 아직 더위가 완전히 가시지 않았으니 부디 건강에 유의해 주길. 20년 동안 많은 일이 있었다. 편지는 쓰지 않는 편이 더 좋을 거라 생각했지만, 결국 펜을 들게 되었구나. 정말 미안하군.", "multi": "true", "x": 200.0, "y": 200.0, "alignment": "left", "size": 24.0, "delay": 0.04, "width": 900.0, "block": "true"}}, {"id": 172, "prop": "Sticker", "attributes": {"id": "st2", "text": "\\n이렇게 편지를 쓰는 건 다름이 아니라, 우리가 십수 년을 함께 지낸 고향 카지마치가 곧 세상에서 사라지기 때문이다.", "x": 300.0, "y": 300.0, "alignment": "left", "multi": "true", "size": 24.0, "delay": 0.04, "width": 900.0, "block": "true"}}, {"id": 173, "prop": "Sticker", "attributes": {"id": "st2", "text": "\\n땅이야 모르겠지만, 우리 인간에겐 정이란 게 있는 법이니까. 간소하게라도 카지마치의 장례를 치러 마지막을 보내려 한다.", "x": 300.0, "y": 340.0, "alignment": "left", "multi": "true", "size": 24.0, "delay": 0.04, "width": 900.0, "block": "true"}}, {"id": 174, "prop": "Sticker", "attributes": {"id": "st2", "text": "\\n이 늙고 쇠약한 몸으로 얼마 남지 않은 여생에 옛 벗을 다시 만날 수 있다면 더할 나위 없이 기쁠 것 같구나.", "x": 300.0, "y": 380.0, "alignment": "left", "size": 24.0, "multi": "true", "delay": 0.04, "width": 900.0, "block": "true"}}, {"id": 175, "prop": "Sticker", "attributes": {"id": "st3", "text": "그럼", "x": 200.0, "y": 580.0, "alignment": "right", "size": 24.0, "delay": 0.04, "width": 900.0, "multi": "true", "block": "true"}}, {"id": 176, "prop": "Sticker", "attributes": {"id": "st3", "text": "\\n텟사이", "x": 200.0, "y": 510.0, "alignment": "right", "size": 24.0, "delay": 0.04, "width": 900.0, "multi": "true", "block": "true"}}, {"id": 177, "prop": "Sticker", "attributes": {"id": "st2", "duration": 1.0}}, {"id": 178, "prop": "Sticker", "attributes": {"id": "st3", "duration": 1.0}}, {"id": 179, "prop": "Sticker", "attributes": {"id": "st1", "duration": 1.0}}, {"id": 180, "prop": "Dialog", "attributes": {}}, {"id": 181, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 182, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#2$1", "duration": 1.0}}, {"id": 183, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1645_1#1$1", "duration": 1.0}}, {"id": 184, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 185, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1645_1#3$1", "focus": "r"}}, {"id": 186, "prop": "name", "attributes": {"content": "참으로 정중한…… 아니, 고풍스러운 문체네요.", "name": "후미즈키"}}, {"id": 187, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1645_1#1$1", "focus": "r"}}, {"id": 188, "prop": "name", "attributes": {"content": "이분이 그때 호시구마 경감을 용문으로 피신하게 해준 반야의 '아버님'이신가요?", "name": "후미즈키"}}, {"id": 189, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#2$1", "focus": "l"}}, {"id": 190, "prop": "name", "attributes": {"content": "네. 텟사이 아저씨라고 불렀던 사람입니다. 이제 시간도 많이 흘렀으니, 아마 7~80세 정도 되었을 겁니다.", "name": "호시구마"}}, {"id": 191, "prop": "name", "attributes": {"content": "그리고 카지마치는 제가 미츠쿠에를 떠나기 전에 살던 곳이죠.", "name": "호시구마"}}, {"id": 192, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1645_1#1$1", "focus": "r"}}, {"id": 193, "prop": "name", "attributes": {"content": "그렇다면, 카지마치가 '사라지기 전'에 가보는 게 도리 아닐까요?", "name": "후미즈키"}}, {"id": 194, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#2$1", "focus": "l"}}, {"id": 195, "prop": "name", "attributes": {"content": "……솔직히 말하자면, 용문에 왔을 때, 여기서 오래 살아볼까도 생각했고, 못 살겠거든 다른 지역으로 가볼까도 생각했습니다. 심지어 극동을 떠났던 것처럼 염국을 떠날 생각도 해봤지만, 돌아갈 생각만큼은 해본 적 없죠.", "name": "호시구마"}}, {"id": 196, "prop": "name", "attributes": {"content": "20년이 지났습니다. 이젠 미츠쿠에가 어떻게 변했는지도 모르죠. 돌아가는 것보다, 여기서 바이크나 타고, 일 끝나고 볶음면이나 한 그릇 사 먹는 게 더 편해요.", "name": "호시구마"}}, {"id": 197, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1645_1#4$1", "focus": "r"}}, {"id": 198, "prop": "name", "attributes": {"content": "근데 이유가 생겼잖아요? 장례를 치러야 하니, 집에 가야죠.", "name": "후미즈키"}}, {"id": 199, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#5$1", "focus": "l"}}, {"id": 200, "prop": "name", "attributes": {"content": "……", "name": "호시구마"}}, {"id": 201, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1645_1#1$1", "focus": "r"}}, {"id": 202, "prop": "name", "attributes": {"content": "당신은 용문의 가장 단단한 방패가 되어 헌신해 줬어요. 그이, 린 씨, 저, 그리고 당신의 친구들 모두가 지켜봤답니다.", "name": "후미즈키"}}, {"id": 203, "prop": "name", "attributes": {"content": "하지만 당신은 거기에만 머물러 있을 분이 아니에요.", "name": "후미즈키"}}, {"id": 204, "prop": "name", "attributes": {"content": "첸은 떠났고, 위시아는 아버지의 자리를 이어받을 거예요. 근위국 국장만으로는 이 판을 유지할 수 없어요.", "name": "후미즈키"}}, {"id": 205, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#3$1", "focus": "l"}}, {"id": 206, "prop": "name", "attributes": {"content": "그건 제가 직무를 소홀히 해서……", "name": "호시구마"}}, {"id": 207, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1645_1#1$1", "focus": "r"}}, {"id": 208, "prop": "name", "attributes": {"content": "그런 말씀 마세요.", "name": "후미즈키"}}, {"id": 209, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1645_1#2$1", "focus": "r"}}, {"id": 210, "prop": "name", "attributes": {"content": "첸이 용문을 떠나기 전에, 두 분은 대화를 나누셨죠. 제 의사와 상관없이, 그런 말들은 결국 저에게도 들려온답니다.", "name": "후미즈키"}}, {"id": 211, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1645_1#1$1", "focus": "r"}}, {"id": 212, "prop": "name", "attributes": {"content": "당신이 억누르고 있는 일들이 영원히 해결되지 않는 것이라 해도, 돌아가서 보고, 남아 있는 사람들과 대화를 나누는 것만으로도 좋아질 거예요.", "name": "후미즈키"}}, {"id": 213, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#2$1", "focus": "l"}}, {"id": 214, "prop": "name", "attributes": {"content": "……알겠습니다.", "name": "호시구마"}}, {"id": 215, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1645_1#4$1", "focus": "r"}}, {"id": 216, "prop": "name", "attributes": {"content": "그리고, 돌아올 때 극동의 간장 센베이 좀 부탁드릴게요.", "name": "후미즈키"}}, {"id": 217, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#2$1", "focus": "l"}}, {"id": 218, "prop": "name", "attributes": {"content": "센베이?", "name": "호시구마"}}, {"id": 219, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1645_1#4$1", "focus": "r"}}, {"id": 220, "prop": "name", "attributes": {"content": "근위국 근처에 누가 센베이 가게가 생겼다길래, 극동식인 줄 알고 가서 주문했거든요.", "name": "후미즈키"}}, {"id": 221, "prop": "name", "attributes": {"content": "그런데 따끈따끈한 반죽에 향긋한 파울비스트 알, 튀긴 고기와 파를 감싼 음식이 올라왔을 때, 그제야 이건 극동식이 아니라, 강제식 전병인 걸 알았어요.", "name": "후미즈키"}}, {"id": 222, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 223, "prop": "Dialog", "attributes": {}}, {"id": 224, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 225, "prop": "charslot", "attributes": {}}, {"id": 226, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 0.0, "amount": 0.0, "block": "true"}}, {"id": 227, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 228, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#2$1"}}, {"id": 229, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1898_1#1$1"}}, {"id": 230, "prop": "Background", "attributes": {"image": "bg_offce", "screenadapt": "coverall"}}, {"id": 231, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 232, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 233, "prop": "playMusic", "attributes": {"intro": "$darkness02_intro", "key": "$darkness02_loop", "volume": 0.6}}, {"id": 234, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#2$1", "focus": "l"}}, {"id": 235, "prop": "name", "attributes": {"content": "이제 오해가 풀렸겠지, 코레토 형사.", "name": "호시구마"}}, {"id": 236, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1898_1#1$1", "focus": "r"}}, {"id": 237, "prop": "name", "attributes": {"content": "그러니까, '킨세키가이' 회장으로부터 본인의 근거지인 카지마치의 장례식에 와달라는 편지를 받았고, 같은 고향 사람의 설득 때문에 돌아왔다는 건가?", "name": "코레토 형사"}}, {"id": 238, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#2$1", "focus": "l"}}, {"id": 239, "prop": "name", "attributes": {"content": "맞아.", "name": "호시구마"}}, {"id": 240, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1898_1#1$1", "focus": "r"}}, {"id": 241, "prop": "name", "attributes": {"content": "그 같은 고향 사람은……", "name": "코레토 형사"}}, {"id": 242, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#2$1", "focus": "l"}}, {"id": 243, "prop": "name", "attributes": {"content": "누구인지는 중요하지 않아.", "name": "호시구마"}}, {"id": 244, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1898_1#1$1", "focus": "r"}}, {"id": 245, "prop": "name", "attributes": {"content": "중요하지 않다고? 그 사람이 아니었다면, 네가 그렇게 당당히 미츠쿠에 거리를 활보할 수 있었을까?", "name": "코레토 형사"}}, {"id": 246, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#12$1", "focus": "l"}}, {"id": 247, "prop": "name", "attributes": {"content": "물론이지.", "name": "호시구마"}}, {"id": 248, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1898_1#7$1", "focus": "r"}}, {"id": 249, "prop": "name", "attributes": {"content": "……", "name": "코레토 형사"}}, {"id": 250, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1898_1#2$1", "focus": "r"}}, {"id": 251, "prop": "name", "attributes": {"content": "그렇다면, 여기서 24시간을 채우고 나가.", "name": "코레토 형사"}}, {"id": 252, "prop": "name", "attributes": {"content": "어차피 경찰서도 지금 한가하거든. 하루에 걸려 오는 신고 전화 중에 진짜 사건은 몇 개 안 되지.", "name": "코레토 형사"}}, {"id": 253, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#2$1", "focus": "l"}}, {"id": 254, "prop": "name", "attributes": {"content": "그럼 전화를 왜 하는 거지?", "name": "호시구마"}}, {"id": 255, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1898_1#1$1", "focus": "r"}}, {"id": 256, "prop": "name", "attributes": {"content": "괴담의 단서를 찾았다면서 자세히 조사해 달래.", "name": "코레토 형사"}}, {"id": 257, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#2$1", "focus": "l"}}, {"id": 258, "prop": "name", "attributes": {"content": "……괴담?", "name": "호시구마"}}, {"id": 259, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1898_1#1$1", "focus": "r"}}, {"id": 260, "prop": "name", "attributes": {"content": "하아. 정말로 미츠쿠에에 안 온 지 오래됐나 보군.", "name": "코레토 형사"}}, {"id": 261, "prop": "name", "attributes": {"content": "경찰서는 이제 경찰서 같지가 않아졌어. 한가한 인간들이 우리를 영무국 취급하기 시작한 지 꽤……", "name": "코레토 형사"}}, {"id": 262, "prop": "dialog", "attributes": {}}, {"id": 263, "prop": "playsound", "attributes": {"key": "$doorknockquite"}}, {"id": 264, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 265, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 266, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1898_1#1$1", "focus": "r"}}, {"id": 267, "prop": "name", "attributes": {"content": "누구지?", "name": "코레토 형사"}}, {"id": 268, "prop": "dialog", "attributes": {}}, {"id": 269, "prop": "charslot", "attributes": {}}, {"id": 270, "prop": "playsound", "attributes": {"key": "$d_avg_walkfast"}}, {"id": 271, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 272, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1915_1#1$1", "duration": 1.0}}, {"id": 273, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 274, "prop": "name", "attributes": {"content": "밖에 누가 찾아왔습니다. 미후네 씨…… 입니다.", "name": "당직 경찰"}, "figure_art": "avg_npc_1915_1#1$1"}, {"id": 275, "prop": "charslot", "attributes": {}}, {"id": 276, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#2$1", "focus": "r"}}, {"id": 277, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1898_1#2$1", "focus": "r"}}, {"id": 278, "prop": "name", "attributes": {"content": "일에 찌든 형색의 형사는 호시구마를 한번 보고 다시 문밖을 바라보더니 얼굴에 노골적인 분노를 띠었다."}}, {"id": 279, "prop": "charslot", "attributes": {}}, {"id": 280, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1915_1#1$1"}}, {"id": 281, "prop": "name", "attributes": {"content": "혹시 중요한 상황이라면 제가 가서 시간을 좀 끌까요?", "name": "당직 경찰"}}, {"id": 282, "prop": "charslot", "attributes": {}}, {"id": 283, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#2$1", "focus": "r"}}, {"id": 284, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1898_1#2$1", "focus": "r"}}, {"id": 285, "prop": "name", "attributes": {"content": "시간을 끈다고? 아마 가서 세 마디도 채 못 나누고 저 녀석은 어딘가로 전화를 하겠지, 그리고 이쪽의 전화가 울리게 될 거야.", "name": "코레토 형사"}}, {"id": 286, "prop": "charslot", "attributes": {}}, {"id": 287, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1915_1#1$1"}}, {"id": 288, "prop": "name", "attributes": {"content": "……", "name": "당직 경찰"}}, {"id": 289, "prop": "charslot", "attributes": {}}, {"id": 290, "prop": "charslot", "attributes": {"slot": "left", "name": "avg_136_hsguma_1#2$1", "focus": "r"}}, {"id": 291, "prop": "charslot", "attributes": {"slot": "right", "name": "avg_npc_1898_1#2$1", "focus": "r"}}, {"id": 292, "prop": "name", "attributes": {"content": "들어오라고 해……", "name": "코레토 형사"}}, {"id": 293, "prop": "Dialog", "attributes": {}}, {"id": 294, "prop": "playsound", "attributes": {"key": "$dooropenquite"}}, {"id": 295, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 296, "prop": "charslot", "attributes": {}}, {"id": 297, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1896_1#1$1"}}, {"id": 298, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 299, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 300, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 301, "prop": "name", "attributes": {"content": "형사의 말이 끝나기도 전에, 거구의 피디아가 방 안으로 성큼성큼 들어오더니, 옆에 있는 경찰은 거들떠보지도 않고 바로 호시구마의 곁으로 다가왔다."}}, {"id": 302, "prop": "charslot", "attributes": {}}, {"id": 303, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_136_hsguma_1#9$1"}}, {"id": 304, "prop": "name", "attributes": {"content": "킨베에?!", "name": "호시구마"}, "figure_art": "avg_136_hsguma_1#9$1"}, {"id": 305, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1896_1#4$1"}}, {"id": 306, "prop": "name", "attributes": {"content": "호시구마, 걱정 마라. 내가 있으면 경찰이 널 건드릴 수 없을 테니까.", "name": "킨베에?"}, "figure_art": "avg_npc_1896_1#4$1"}, {"id": 307, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1898_1#3$1"}}, {"id": 308, "prop": "name", "attributes": {"content": "(헛웃음) 하, 하. 미후네 코헤이 씨. 출세하기 전 이름으로 불리는 건 오랜만이겠네?", "name": "코레토 형사"}, "figure_art": "avg_npc_1898_1#3$1"}, {"id": 309, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1896_1#1$1"}}, {"id": 310, "prop": "name", "attributes": {"content": "어이, 코레토 형사. 너도 그렇게 불러보는 건 어때?", "name": "미후네"}, "figure_art": "avg_npc_1896_1#1$1"}, {"id": 311, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1898_1#2$1"}}, {"id": 312, "prop": "name", "attributes": {"content": "……", "name": "코레토 형사"}, "figure_art": "avg_npc_1898_1#2$1"}, {"id": 313, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1896_1#1$1"}}, {"id": 314, "prop": "name", "attributes": {"content": "그래, 눈치가 빨라서 좋군.", "name": "미후네"}, "figure_art": "avg_npc_1896_1#1$1"}, {"id": 315, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_136_hsguma_1#2$1"}}, {"id": 316, "prop": "name", "attributes": {"content": "미후네……", "name": "호시구마"}, "figure_art": "avg_136_hsguma_1#2$1"}, {"id": 317, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1896_1#9$1"}}, {"id": 318, "prop": "name", "attributes": {"content": "호시구마, 네 앞에서 나는 언제나 킨베에야.", "name": "미후네"}, "figure_art": "avg_npc_1896_1#9$1"}, {"id": 319, "prop": "name", "attributes": {"content": "가자. 집으로 돌아가야지.", "name": "미후네"}, "figure_art": "avg_npc_1896_1#9$1"}, {"id": 320, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1915_1#1$1"}}, {"id": 321, "prop": "name", "attributes": {"content": "코레토 씨는 아직……", "name": "당직 경찰"}, "figure_art": "avg_npc_1915_1#1$1"}, {"id": 322, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1896_1#6$1"}}, {"id": 323, "prop": "name", "attributes": {"content": "아직 뭐가 어쨌다는 거지? 나한테 제대로 설명도 하지 않았는데, 경찰이 멋대로 사람을 잡아갈 권리가 있나? 설마 20년 전 그 사건 때문인가?", "name": "미후네"}, "figure_art": "avg_npc_1896_1#6$1"}, {"id": 324, "prop": "name", "attributes": {"content": "안타깝지만, 공소시효는 이미 지났다. 그것도 몇 년 전에 말이야. 호쿠인이 공소시효 제도를 개정했다고 해서 난인의 경찰도 같이 까불어도 된다는 뜻은 아니야.", "name": "미후네"}, "figure_art": "avg_npc_1896_1#6$1"}, {"id": 325, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1915_1#1$1"}}, {"id": 326, "prop": "name", "attributes": {"content": "모욕적인 언사는 멈추시죠. 공소시효가 지났다고 해도……", "name": "당직 경찰"}, "figure_art": "avg_npc_1915_1#1$1"}, {"id": 327, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1896_1#6$1"}}, {"id": 328, "prop": "name", "attributes": {"content": "공소시효가 지났는데, 경찰이 무슨 자격으로 사람을 여기 붙잡아둘 수 있지? 의원 질의, TV 생중계, 여론의 추궁을 피할 수 있는 이유를 대봐.", "name": "미후네"}, "figure_art": "avg_npc_1896_1#6$1"}, {"id": 329, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1915_1#1$1"}}, {"id": 330, "prop": "name", "attributes": {"content": "그건 협박입니다!", "name": "당직 경찰"}, "figure_art": "avg_npc_1915_1#1$1"}, {"id": 331, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1896_1#6$1"}}, {"id": 332, "prop": "name", "attributes": {"content": "이건 내가 권리를 행사하는 방식이야.", "name": "미후네"}, "figure_art": "avg_npc_1896_1#6$1"}, {"id": 333, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1915_1#1$1"}}, {"id": 334, "prop": "name", "attributes": {"content": "코레토 씨!", "name": "당직 경찰"}, "figure_art": "avg_npc_1915_1#1$1"}, {"id": 335, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1898_1#1$1"}}, {"id": 336, "prop": "name", "attributes": {"content": "……보내줘.", "name": "코레토 형사"}, "figure_art": "avg_npc_1898_1#1$1"}, {"id": 337, "prop": "charslot", "attributes": {}}, {"id": 338, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_136_hsguma_1#2$1", "focus": "l"}}, {"id": 339, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1896_1#6$1", "focus": "l"}}, {"id": 340, "prop": "name", "attributes": {"content": "……킨베에, 텟사이 아저씨가 보낸 거야?", "name": "호시구마"}, "figure_art": "avg_136_hsguma_1#2$1"}, {"id": 341, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1896_1#1$1", "focus": "r"}}, {"id": 342, "prop": "name", "attributes": {"content": "킨세키가이 전체가 너를 기다리고 있어. 가자. 이 경찰들은 그만 상대하고.", "name": "미후네"}, "figure_art": "avg_npc_1896_1#1$1"}, {"id": 343, "prop": "dialog", "attributes": {}}, {"id": 344, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 345, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.6}}, {"id": 346, "prop": "playsound", "attributes": {"key": "$d_gen_walk_n", "volume": 0.8, "delay": 0.15, "channel": "b"}}, {"id": 347, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 348, "prop": "Dialog", "attributes": {}}, {"id": 349, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 350, "prop": "charslot", "attributes": {}}, {"id": 351, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 352, "prop": "bgeffect", "attributes": {"name": "$eb_sunshine_upperedge", "layer": 2.0, "x": 0.0}}, {"id": 353, "prop": "curtain", "attributes": {"direction": 0.0, "fillfrom": 0.01, "fillto": 0.25, "block": "true"}}, {"id": 354, "prop": "curtain", "attributes": {"direction": 4.0, "fillfrom": 0.01, "fillto": 0.25, "block": "true"}}, {"id": 355, "prop": "Background", "attributes": {"image": "64_g1_jindastreet_d", "screenadapt": "coverall", "xScale": 1.2, "yScale": 1.2}}, {"id": 356, "prop": "BackgroundTween", "attributes": {"xFrom": 0.0, "xTo": 0.0, "duration": 45.0}}, {"id": 357, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 358, "prop": "playMusic", "attributes": {"key": "$saferoom_loop", "volume": 0.6}}, {"id": 359, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 360, "prop": "name", "attributes": {"content": "경찰서에서 나와 오른쪽으로 꺾어, 길을 건넜다."}}, {"id": 361, "prop": "name", "attributes": {"content": "대낮의 니타 거리가 호시구마의 눈앞에 펼쳐졌다."}}, {"id": 362, "prop": "name", "attributes": {"content": "생기 없는 하얀 햇살이 거리를 무미건조하게 비추고 있었다. 네온 불빛이 사라진 지금, 콘크리트 건물의 외벽은 본래의 색을 드러내고 있었다."}}, {"id": 363, "prop": "name", "attributes": {"content": "출근 시간이었다. 무표정인 회사원들이 바쁘게 걸음을 재촉하고 있었고, 아직 문을 열지 않은 가게, 계속 호객 행위를 하고 있지만 밤처럼 화려하진 않은 가게를 지나갔다."}}, {"id": 364, "prop": "name", "attributes": {"content": "어젯밤 길거리의 토사물이 누구의 것인지, 유혹에 이끌려 거액을 쓴 이가 누구인지 이제는 알 수 없었다."}}, {"id": 365, "prop": "dialog", "attributes": {}}, {"id": 366, "prop": "Dialog", "attributes": {}}, {"id": 367, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 368, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 369, "prop": "bgeffect", "attributes": {}}, {"id": 370, "prop": "curtain", "attributes": {}}, {"id": 371, "prop": "Delay", "attributes": {"time": 0.25}}, {"id": 372, "prop": "Background", "attributes": {"image": "64_g1_jindastreet_d", "screenadapt": "coverall"}}, {"id": 373, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 374, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 375, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_136_hsguma_1#2$1", "duration": 1.0}}, {"id": 376, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1896_1#9$1", "duration": 1.0}}, {"id": 377, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 378, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1896_1#9$1", "focus": "r"}}, {"id": 379, "prop": "name", "attributes": {"content": "그나저나 정말 오랜만이군! 용문에서 잘 지냈나? 몇 년 동안 소식이 없길래, 거기서 무슨 일이라도 생긴 줄 알고 걱정돼서 죽는 줄 알았어!", "name": "미후네"}, "figure_art": "avg_npc_1896_1#9$1"}, {"id": 380, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_136_hsguma_1#5$1", "focus": "l"}}, {"id": 381, "prop": "name", "attributes": {"content": "시간이 많이 흘렀잖아, 그래서 난 이제 킨세키가이 사람이 아니라고 생각했지.", "name": "호시구마"}, "figure_art": "avg_136_hsguma_1#5$1"}, {"id": 382, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1896_1#9$1", "focus": "r"}}, {"id": 383, "prop": "name", "attributes": {"content": "그게 무슨 소리야? 네가 돌아오기만 한다면 아무리 운명이 장난을 친다고 해도, 소식이 끊긴다 해도, 우리는 가족이야.", "name": "미후네"}, "figure_art": "avg_npc_1896_1#9$1"}, {"id": 384, "prop": "name", "attributes": {"content": "지난 20년간, 킨세키가이가 네게 '추방'이나 '절연'한다는 통보를 했던가? 한 번도 없었다고.", "name": "미후네"}, "figure_art": "avg_npc_1896_1#9$1"}, {"id": 385, "prop": "name", "attributes": {"content": "다른 건 몰라도, 지금까지도 회의할 때 어르신의 왼쪽 자리는 언제나 비어 있었어. 너는 늘 킨세키가이의 부두목이자, 후계자였지.", "name": "미후네"}, "figure_art": "avg_npc_1896_1#9$1"}, {"id": 386, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_136_hsguma_1#2$1", "focus": "l"}}, {"id": 387, "prop": "name", "attributes": {"content": "그럼 너는……?", "name": "호시구마"}, "figure_art": "avg_136_hsguma_1#2$1"}, {"id": 388, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1896_1#9$1", "focus": "r"}}, {"id": 389, "prop": "name", "attributes": {"content": "난 부두목 보좌일 뿐이야.", "name": "미후네"}, "figure_art": "avg_npc_1896_1#9$1"}, {"id": 390, "prop": "name", "attributes": {"content": "절대 어르신께서 노망났다고 생각하지 마. 모두가 인정한 일이니까.", "name": "미후네"}, "figure_art": "avg_npc_1896_1#9$1"}, {"id": 391, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1896_1#1$1", "focus": "r"}}, {"id": 392, "prop": "name", "attributes": {"content": "20년 전에, 네가 나서서 그 의원 후보를 죽인 게 아니었다면, 킨세키가이 전체가 카지마치에서 쫓겨나고, 그 인간의 여론 공세에 산산조각 났을 거야.", "name": "미후네"}, "figure_art": "avg_npc_1896_1#1$1"}, {"id": 393, "prop": "name", "attributes": {"content": "그 다음, 너는 우리를 그 일과 엮이지 않게 하기 위해 홀로 살인이라는 무거운 짐을 지고 용문으로 떠났지. 그 덕분에 킨세키가이가 유지될 수 있었던 거야.", "name": "미후네"}, "figure_art": "avg_npc_1896_1#1$1"}, {"id": 394, "prop": "name", "attributes": {"content": "넌 우리를 위해 큰 희생을 했어, 근데 우리가 너를 버린다면, 그게 과연 인간이 할 짓일까?", "name": "미후네"}, "figure_art": "avg_npc_1896_1#1$1"}, {"id": 395, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_136_hsguma_1#2$1", "focus": "l"}}, {"id": 396, "prop": "name", "attributes": {"content": "……그렇게 말하지 마.", "name": "호시구마"}, "figure_art": "avg_136_hsguma_1#2$1"}, {"id": 397, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1896_1#1$1", "focus": "r"}}, {"id": 398, "prop": "name", "attributes": {"content": "이건 명명백백한 사실이야, 내가 하는 말이 틀렸나?", "name": "미후네"}, "figure_art": "avg_npc_1896_1#1$1"}, {"id": 399, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_136_hsguma_1#2$1", "focus": "l"}}, {"id": 400, "prop": "name", "attributes": {"content": "킨베에, 옛날 일은 나중에 얘기하자.", "name": "호시구마"}, "figure_art": "avg_136_hsguma_1#2$1"}, {"id": 401, "prop": "name", "attributes": {"content": "텟사이 아저씨가 카지마치의 장례식을 열겠다면서 편지를 보냈어. 너한테 이런 얘기한 적 있어?", "name": "호시구마"}, "figure_art": "avg_136_hsguma_1#2$1"}, {"id": 402, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1896_1#5$1", "focus": "r"}}, {"id": 403, "prop": "name", "attributes": {"content": "장례식이라고?!", "name": "미후네"}, "figure_art": "avg_npc_1896_1#5$1"}, {"id": 404, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1896_1#4$1", "focus": "r"}}, {"id": 405, "prop": "name", "attributes": {"content": "장례식…… 아니지, 그게 어떻게 장례식일 수 있지?", "name": "미후네"}, "figure_art": "avg_npc_1896_1#4$1"}, {"id": 406, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1896_1#6$1", "focus": "r"}}, {"id": 407, "prop": "name", "attributes": {"content": "오니 누님, 아무래도 여기저기 돌아다닐 시간이 없을 것 같아. 얼른 카지마치로 돌아가서 어르신께 확실하게 여쭤보자고.", "name": "미후네"}, "figure_art": "avg_npc_1896_1#6$1"}, {"id": 408, "prop": "charslot", "attributes": {"duration": 0.5}}, {"id": 409, "prop": "playsound", "attributes": {"key": "$d_avg_walkfast"}}, {"id": 410, "prop": "name", "attributes": {"content": "거구의 피디아가 발걸음을 재촉하며, 카지마치 방향으로 급히 걸어갔다."}}, {"id": 411, "prop": "name", "attributes": {"content": "거구의 피디아는 보폭이 큰 데다가 빠르게 걸었다. 결국 호시구마는 종종걸음으로 그를 뒤따라가야 했다."}}, {"id": 412, "prop": "Dialog", "attributes": {}}, {"id": 413, "prop": "Delay", "attributes": {"time": 2.0}}, {"id": 414, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 415, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 416, "prop": "hidecgitem", "attributes": {}}, {"id": 417, "prop": "Image", "attributes": {}}, {"id": 418, "prop": "charslot", "attributes": {}}, {"id": 419, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}