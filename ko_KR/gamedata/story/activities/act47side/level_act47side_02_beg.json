_2034_1#7$1"}, {"id": 101, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2034_1#7$1", "focus": "l"}}, {"id": 102, "prop": "name", "attributes": {"content": "말해. 누구냐, 넌.", "name": "고든"}, "figure_art": "avg_npc_2034_1#7$1"}, {"id": 103, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4214_cairn_1#7$1", "focus": "r"}}, {"id": 104, "prop": "name", "attributes": {"content": "……해설원……", "name": "오클리?"}, "figure_art": "avg_4214_cairn_1#7$1"}, {"id": 105, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2034_1#7$1", "focus": "l"}}, {"id": 106, "prop": "name", "attributes": {"content": "근성은 있군.", "name": "고든"}, "figure_art": "avg_npc_2034_1#7$1"}, {"id": 107, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4214_cairn_1#9$1", "focus": "r"}}, {"id": 108, "prop": "name", "attributes": {"content": "여, 여행 갈 때 필요한 그런 해설원!", "name": "오클리?"}, "figure_art": "avg_4214_cairn_1#9$1"}, {"id": 109, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4214_cairn_1#9$1", "focus": "r"}}, {"id": 110, "prop": "name", "attributes": {"content": "이름은 펀, 여행…… 가이드야.", "name": "펀"}, "figure_art": "avg_4214_cairn_1#9$1"}, {"id": 111, "prop": "dialog", "attributes": {}}, {"id": 112, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 113, "prop": "Dialog", "attributes": {}}, {"id": 114, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 115, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 116, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 117, "prop": "charslot", "attributes": {}}, {"id": 118, "prop": "Background", "attributes": {"image": "bg_hotel", "screenadapt": "coverall"}}, {"id": 119, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_1000_1#3$1"}}, {"id": 120, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2037_1#1$1"}}, {"id": 121, "prop": "Blocker", "a