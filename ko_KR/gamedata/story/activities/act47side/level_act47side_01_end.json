ime": 0.0, "keep": "true", "initamount": 1.0, "amount": 0.0, "block": "false"}}, {"id": 152, "prop": "Background", "attributes": {"image": "38_g10_ecolab", "screenadapt": "coverall"}}, {"id": 153, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 154, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4212_nasti_1#1$1", "posfrom": "10,0", "posto": "10,0"}}, {"id": 155, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2039_1#7$1", "posfrom": "-10,0", "posto": "-10,0"}}, {"id": 156, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 157, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 158, "prop": "playMusic", "attributes": {"key": "$darkness_03_loop", "volume": 0.6}}, {"id": 159, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 160, "prop": "name", "attributes": {"content": "내스티 주임님, 럭키 치스티비스트 외식업은 내일부로 입주 자격이 말소될 겁니다.", "name": "스카이"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 161, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 162, "prop": "name", "attributes": {"content": "재검사는 통과 못 했어?", "name": "내스티"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 163, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 164, "prop": "name", "attributes": {"content": "기준치보다 많이 부족해요. 이 파크에 제일 먼저 입주한 업종 전환 기업 중 하나인데, 그때는 '하늘 열풍'에 편승해 심사 기준이 느슨해서……", "name": "스카이"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 165, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#5$1"}}, {"id": 166, "prop": "name", "attributes": {"content": "그럼 거기 테스터들은, 어떻게 돼?", "name": "내스티"}, "figure_art": "avg_4212_nasti_1#5$1"}, {"id": 167, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#8$1"}}, {"id": 168, "prop": "name", "attributes": {"content": "거기 대표는 모터 종류도 구분할 줄 몰라요. 그냥 '프로펠러 파라다이스'란 이름만 팔아서 한몫 잡으려던 거겠죠……", "name": "스카이"}, "figure_art": "avg_npc_2039_1#8$1"}, {"id": 169, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#5$1"}}, {"id": 170, "prop": "name", "attributes": {"content": "네? 방금 뭐라고 하셨어요?", "name": "스카이"}, "figure_art": "avg_npc_2039_1#5$1"}, {"id": 171, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#4$1"}}, {"id": 172, "prop": "name", "attributes": {"content": "아무것도 아니야. 너는 이 파크의 이름이 꽤 마음에 드나 봐.", "name": "내스티"}, "figure_art": "avg_4212_nasti_1#4$1"}, {"id": 173, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 174, "prop": "name", "attributes": {"content": "저는 여기를 그냥 '스텔라리아'로 불렀으면 좋겠어요.", "name": "스카이"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 175, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 176, "prop": "name", "attributes": {"content": "스카이, 네가 고리형 실험실의 기술 유산 공개를 반대한다는 건 알아.", "name": "내스티"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 177, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 178, "prop": "name", "attributes": {"content": "제가 '총괄 대행'의 결정을 지적할 생각은 없지만, 지나치게 보수적인 결정은 우리가 받아야 할 존중을 잃게 할 뿐이에요.", "name": "스카이"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 179, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 180, "prop": "name", "attributes": {"content": "아주 적은 데이터 지원만으로도 수많은 과학기술 기업들이 새 생명을 얻게 되었지만, 수천만 컬럼비아 국민들을 비추던 그 고리형 실험실은 5살 어린아이도 가지고 놀 수 있는 지능 개발 장난감으로 전락했다고요……", "name": "스카이"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 181, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 182, "prop": "name", "attributes": {"content": "지금 모든 컬럼비아인이 '스페이스'니 '우주'니 떠들어대지만, 정작 이 새로운 어휘가 크리스틴이 공개한 실험 일지에서 나왔다는 사실을 거의 아무도 기억하지 못합니다.", "name": "스카이"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 183, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 184, "prop": "name", "attributes": {"content": "진정한 의미에서 크리스틴을 추모하는 인간은 이제 단 한 사람도 없어요. 심지어, 내스티 주임님조차도.", "name": "스카이"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 185, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 186, "prop": "name", "attributes": {"content": "기록하고 돌아보는 건 역사학자의 일이야. 우리는 검증된 데이터를 분석하고, 실질적이고 유효한 방향만 따르는 것뿐이지.", "name": "내스티"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 187, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 188, "prop": "name", "attributes": {"content": "그래서, 그 데이터와 방향이 지금 어떻게 됐는데요?", "name": "스카이"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 189, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 190, "prop": "name", "attributes": {"content": "지난 2년 동안, 라인 랩은 10여 개의 소형 실험실을 인수했고, 크고 작은 프로젝트들이 추진되고 있지만, 유독 크리스틴의 유산만은 보류된 채로 남아 있어요.", "name": "스카이"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 191, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 192, "prop": "name", "attributes": {"content": "이번 전시회에서 우리는 라인 랩의 스텔라리아 후속 연구 성과를 최초로 공개해, 삼류 과학기술 기업들을 탄복하게 만들고, 하늘 탐색이라는 영역으로 돌아와 다시 대중들의 시야에 들어가야 합니다.", "name": "스카이"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 193, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 194, "prop": "name", "attributes": {"content": "생태원이 고리형 실험실에서 전송된 데이터를 기반으로 하고 있다는 것도 알고 있고, 식물로 에너지를 전달하고 에너지 공급 시스템을 구축하는 게 공학적인 측면에서 얼마나 대단한 성과인지도 저는 잘 알고 있어요.", "name": "스카이"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 195, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#8$1"}}, {"id": 196, "prop": "name", "attributes": {"content": "모종 재배, 플랜터 유닛 설치, 엔지니어링 점검은 모두 우리의 연구를 더 발전시키기 위한 과정이죠…… 하지만 프리뷰에조차 얼굴을 비추지 못하는 '식물원' 하나로 정말 충분하다고 할 수 있을까요?", "name": "스카이"}, "figure_art": "avg_npc_2039_1#8$1"}, {"id": 197, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#8$1"}}, {"id": 198, "prop": "name", "attributes": {"content": "……", "name": "내스티"}, "figure_art": "avg_4212_nasti_1#8$1"}, {"id": 199, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 200, "prop": "name", "attributes": {"content": "제발 알려주세요, 주임님. 그날 밤이 오기 전, 아무도 크리스틴이 천막을 뚫으려 했다는 걸 몰랐듯이, 라인 랩에도 더 큰 목표가 있는 거죠? 그렇죠?", "name": "스카이"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 201, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 202, "prop": "name", "attributes": {"content": "트리마운츠의 그날 밤은 이미 오래전의 일이야.", "name": "내스티"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 203, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 204, "prop": "name", "attributes": {"content": "……", "name": "스카이"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 205, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#1$1"}}, {"id": 206, "prop": "name", "attributes": {"content": "다음 기업 점검이나 준비해. 순서가 조금 바뀌었으니까 유의하고.", "name": "내스티"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 207, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 208, "prop": "name", "attributes": {"content": "네.", "name": "스카이"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 209, "prop": "dialog", "attributes": {}}, {"id": 210, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "-10,0", "posto": "-30,0", "duration": 0.8, "isblock": "false"}}, {"id": 211, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 212, "prop": "charslot", "attributes": {"slot": "r", "focus": "r"}}, {"id": 213, "prop": "name", "attributes": {"content": "스카이.", "name": "내스티"}}, {"id": 214, "prop": "dialog", "attributes": {}}, {"id": 215, "prop": "delay", "attributes": {"time": 0.3}}, {"id": 216, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#7$1"}}, {"id": 217, "prop": "name", "attributes": {"content": "……", "name": "스카이"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 218, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#4$1"}}, {"id": 219, "prop": "name", "attributes": {"content": "네 심정은 이해해. 네가 크리스틴에게 고무되어 라인 랩에 들어온 것도 알고 있고.", "name": "내스티"}, "figure_art": "avg_4212_nasti_1#4$1"}, {"id": 220, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#8$1"}}, {"id": 221, "prop": "name", "attributes": {"content": "그날 밤, 하늘을 올려다본 사람은 많았지만, 모두가 그 빛을 좇은 건 아니었어.", "name": "내스티"}, "figure_art": "avg_4212_nasti_1#8$1"}, {"id": 222, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#4$1"}}, {"id": 223, "prop": "name", "attributes": {"content": "네가 첫걸음을 내디딘 이유를 잊지 마.", "name": "내스티"}, "figure_art": "avg_4212_nasti_1#4$1"}, {"id": 224, "prop": "charslot", "attributes": {"slot": "l", "focus": "l", "name": "avg_npc_2039_1#3$1"}}, {"id": 225, "prop": "name", "attributes": {"content": "……점검 자료부터 준비하겠습니다, 주임님.", "name": "스카이"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 226, "prop": "dialog", "attributes": {}}, {"id": 227, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 228, "prop": "charslot", "attributes": {"slot": "l", "posfrom": "-30,0", "posto": "-50,0", "afrom": 1.0, "ato": 0.0, "duration": 1.0, "isblock": "true"}}, {"id": 229, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 230, "prop": "charslot", "attributes": {"slot": "r", "focus": "r", "name": "avg_4212_nasti_1#9$1"}}, {"id": 231, "prop": "name", "attributes": {"content": "……", "name": "내스티"}, "figure_art": "avg_4212_nasti_1#9$1"}, {"id": 232, "prop": "dialog", "attributes": {}}, {"id": 233, "prop": "Dialog", "attributes": {}}, {"id": 234, "prop": "Bl