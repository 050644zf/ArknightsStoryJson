$1", "focus": "r"}}, {"id": 167, "prop": "name", "attributes": {"content": "암요 암요!", "name": "오클리"}, "figure_art": "avg_npc_1000_1#2$1"}, {"id": 168, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1000_1#3$1", "focus": "r"}}, {"id": 169, "prop": "name", "attributes": {"content": "그럼 장관님도 기억하시겠죠? 저희 둘이 이 '사랑스러운 새끼들'을 무사히 내보내고 입단속만 확실히 한다면……", "name": "오클리"}, "figure_art": "avg_npc_1000_1#3$1"}, {"id": 170, "prop": "dialog", "attributes": {}}, {"id": 171, "prop": "charslot", "attributes": {}}, {"id": 172, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2034_1#1$1", "isblock": "true"}}, {"id": 173, "prop": "name", "attributes": {"content": "우리 사이의 일은 깨끗이 끝나는 거지.", "name": "고든"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 174, "prop": "dialog", "attributes": {}}, {"id": 175, "prop": "charslot", "attributes": {}}, {"id": 176, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4214_cairn_1#3$1", "posfrom": "50,0", "posto": "50,0"}}, {"id": 177, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1000_1#1$1", "posfrom": "50,0", "posto": "50,0", "isblock": "true"}}, {"id": 178, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_1000_1#1$1", "focus": "r"}}, {"id": 179, "prop": "name", "attributes": {"content": "좋아요!", "name": "오클리"}, "figure_art": "avg_npc_1000_1#1$1"}, {"id": 180, "prop": "dialog", "attributes": {}}, {"id": 181, "prop": "charslot", "attributes": {}}, {"id": 182, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2034_1#9$1", "isblock": "true"}}, {"id": 183, "prop": "name", "attributes": {"content": "방심하지 마라, 내스티는 아직 생태원에서 철수하지 않았어. 실패작이 벽을 뒤덮은 상황에서도 밤낮없이 연구를 계속하고 있으니까.", "name": "고든"}, "figure_art": "avg_npc_2034_1#9$1"}, {"id": 184, "prop": "dialog", "attributes": {}}, {"id": 185, "prop": "charslot", "attributes": {}}, {"id": 186, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_4214_cairn_1#4$1", "posfrom": "50,0", "posto": "50,0"}}, {"id": 187, "prop": "cha