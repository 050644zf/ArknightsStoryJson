pc_2034_1#1$1", "focus": "l"}}, {"id": 206, "prop": "name", "attributes": {"content": "그쪽 상황은 어때? 계획이 틀어지면 내스티를 억지로 잡아끌어서라도 붙잡아 둬야 해.", "name": "고든"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 207, "prop": "charslot", "attributes": {"slot": "l", "focus": "n"}}, {"id": 208, "prop": "interlude", "attributes": {"channel": 3.0, "switch": "true"}}, {"id": 209, "prop": "name", "attributes": {"content": "걱정하지 마십시오, 장관님.", "name": "머시아"}}, {"id": 210, "prop": "name", "attributes": {"content": "이렇게 많은 사고가 발생한 건 모두 제가 소홀했던 탓입니다……", "name": "머시아"}}, {"id": 211, "prop": "name", "attributes": {"content": "내스티 주임을 잘 주시하고 있다가 생태원 밖으로 유인해서 시간을 최대한 벌어드리겠습니다.", "name": "머시아"}}, {"id": 212, "prop": "interlude", "attributes": {"channel": 3.0, "switch": "false"}}, {"id": 213, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2034_1#3$1", "focus": "l"}}, {"id": 214, "prop": "name", "attributes": {"content": "좋아.", "name": "고든"}, "figure_art": "avg_npc_2034_1#3$1"}, {"id": 215, "prop": "dialog", "attributes": {}}, {"id": 216, "prop": "PlaySound", "attributes": {"key": "$d_gen_transmissionget"}}, {"id": 217, "prop": "interlude", "attributes": {"channel": 3.0, "clear": "true", "tsfrom": "1,1", "tsto": "0,1", "tsduration": 0.5}}, {"id": 218, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 219, "prop": "interlude", "attributes": {"channel": 3.0, "clear": "true"}}, {"id": 220, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2034_1#1$1", "focus": "l", "isblock": "true"}}, {"id": 221, "prop": "name", "attributes": {"content": "봐라, 이런 중요한 때가 되면 머시도 이렇게 믿음직스러워지잖아.", "name": "고든"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 222, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2034_1#1$1", "focus": "l", "isblock": "true"}}, {"id": 223, "prop": "name", "attributes": {"content": "너희 둘도 정신 바짝 차려. 수송구에 거의 다 왔으니.", "name": "고든"}, "figure_art": "avg_npc_2034_1#1$1"}, {"id": 224, "prop": "dialog", "attributes": {}}, {"id": 225, "prop": "charslot", "