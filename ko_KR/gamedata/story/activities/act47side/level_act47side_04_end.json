_2037_1#13$1", "focus": "r"}}, {"id": 244, "prop": "name", "attributes": {"content": "상황을 보고하세요.", "name": "머시아"}, "figure_art": "avg_npc_2037_1#13$1"}, {"id": 245, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2046_1#1$1", "focus": "l"}}, {"id": 246, "prop": "name", "attributes": {"content": "2팀이 낮에 수집한 정보에 따르면, 라인 랩의 기술 인력은 실험 구역에서 확실히 철수했고, 지금 이 구역에 드나드는 건 내스티 주임과 조수 한 명뿐입니다. 다만……", "name": "메이랜더 특수요원"}, "figure_art": "avg_npc_2046_1#1$1"}, {"id": 247, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2037_1#13$1", "focus": "r"}}, {"id": 248, "prop": "name", "attributes": {"content": "이곳에 머문 시간이 이해할 수 없을 정도로 길다는 거죠.", "name": "머시아"}, "figure_art": "avg_npc_2037_1#13$1"}, {"id": 249, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2046_1#1$1", "focus": "l"}}, {"id": 250, "prop": "name", "attributes": {"content": "……그렇습니다.", "name": "메이랜더 특수요원"}, "figure_art": "avg_npc_2046_1#1$1"}, {"id": 251, "prop": "name", "attributes": {"content": "죄송합니다. 당신의 팀원으로서 당신의 판단을 더욱 신뢰해야 했는데, 라인 랩은 확실히 전시관 지하에 무언가를 숨겨둔 것 같습니다.", "name": "메이랜더 특수요원"}, "figure_art": "avg_npc_2046_1#1$1"}, {"id": 252, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2037_1#14$1", "focus": "r"}}, {"id": 253, "prop": "name", "attributes": {"content": "사과는 괜찮아요. 각 과학기술 기업을 감시하는 게 원래 제 임무였으니까요.", "name": "머시아"}, "figure_art": "avg_npc_2037_1#14$1"}, {"id": 254, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2046_1#1$1", "focus": "l"}}, {"id": 255, "prop": "name", "attributes": {"content": "더 깊이 수색한다면, 아마 내스티 주임 쪽은……", "name": "메이랜더 특수요원"}, "figure_art": "avg_npc_2046_1#1$1"}, {"id": 256, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2037_1#6$1", "focus": "r"}}, {"id": 257, "prop": "name", "attributes": {"content": "걱정 말고, 제 계획대로만 진행하세요. 순조롭다면 최소 20분 정도는 벌 수 있을 거예요.", "name": "머시아"}, "figure_art": "avg_npc_2037_1#6$1"}, {"id": 258, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_2037_1#17$1", "focus": "r"}}, {"id": 259, "prop": "name", "attributes": {"content": "절대 거절할 수 없는 선물을 준비했거든요.", "name": "머시아"}, "figure_art": "avg_npc_2037_1#17$1"}, {"id": 260, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 261, "prop": "Dialog", "attributes": {}}, {"id": 262, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 263, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 264, "prop": "charslot", "attributes": {}}, {"id": 265, "prop": "Background", "attributes": {"image": "38_g5_rhinelab_indoor", "screenadapt": "coverall"}}, {"id": 266, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 267, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 268, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 269, "prop": "PlaySound", "attributes": {"key": "$keyboard"}}, {"id": 270, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 271, "prop": "PlaySound", "attributes": {"key": "$d_avg_aircraftalarm", "volume": 0.2}}, {"id": 272, "prop": "delay", "attributes": {"time": 2.5}}, {"id": 273, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4212_nasti_1#1$1", "duration": 0.8}}, {"id": 274, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2039_1#7$1", "duration": 0.8, "isblock": "true"}}, {"id": 275, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2039_1#7$1", "focus": "l"}}, {"id": 276, "prop": "name", "attributes": {"content": "……", "name": "스카이"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 277, "prop": "playMusic", "attributes": {"key": "$darkness_03_loop", "volume": 0.6}}, {"id": 278, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2039_1#12$1", "focus": "l"}}, {"id": 279, "prop": "name", "attributes": {"content": "으아악!!!", "name": "스카이"}, "figure_art": "avg_npc_2039_1#12$1"}, {"id": 280, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4212_nasti_1#1$1", "focus": "r"}}, {"id": 281, "prop": "name", "attributes": {"content": "한 번 더.", "name": "내스티"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 282, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2039_1#3$1", "focus": "l"}}, {"id": 283, "prop": "name", "attributes": {"content": "내스티 주임님, 생태원과 부유 플랜터 유닛의 프로그램이 이 시스템으로 구현된 건가요?", "name": "스카이"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 284, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2039_1#3$1", "focus": "l"}}, {"id": 285, "prop": "name", "attributes": {"content": "아무리 사물을 원격 조종하는 게 밴시의 특기라고 해도, 소리를 매개체로 삼는 방식을 버리고, 주문을 모듈에 저장해 자체 순환으로 결함을 복구하게 만든 건, 그야말로 시대의 획기적인 발명이에요!", "name": "스카이"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 286, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2039_1#3$1", "focus": "l"}}, {"id": 287, "prop": "name", "attributes": {"content": "만약 전부 주문으로 작동한다면……", "name": "스카이"}, "figure_art": "avg_npc_2039_1#3$1"}, {"id": 288, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4212_nasti_1#2$1", "focus": "r"}}, {"id": 289, "prop": "name", "attributes": {"content": "추측성 논문을 너무 본 것 같네, 스카이.", "name": "내스티"}, "figure_art": "avg_4212_nasti_1#2$1"}, {"id": 290, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2039_1#7$1", "focus": "l"}}, {"id": 291, "prop": "name", "attributes": {"content": "저를 포함해 대부분 사람들이 밴시에 대해 잘 몰라요. 밴시들은 협곡에 살며, 그곳을 잘 떠나지 않는다고 하던데……", "name": "스카이"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 292, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2039_1#7$1", "focus": "l"}}, {"id": 293, "prop": "name", "attributes": {"content": "컬럼비아에 오기 전에는 주임님도 그곳에 계셨던 거예요?", "name": "스카이"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 294, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4212_nasti_1#1$1", "focus": "r"}}, {"id": 295, "prop": "name", "attributes": {"content": "내 기억이 시작된 곳은 카즈델이야. 나중에 동족이 날 거둬서 협곡으로 데려갔고.", "name": "내스티"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 296, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2039_1#5$1", "focus": "l"}}, {"id": 297, "prop": "name", "attributes": {"content": "거긴 어떤 곳이에요?", "name": "스카이"}, "figure_art": "avg_npc_2039_1#5$1"}, {"id": 298, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4212_nasti_1#4$1", "focus": "r"}}, {"id": 299, "prop": "name", "attributes": {"content": "세속과는 거리가 먼 평화로운 곳이야.", "name": "내스티"}, "figure_art": "avg_4212_nasti_1#4$1"}, {"id": 300, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4212_nasti_1#4$1", "focus": "r"}}, {"id": 301, "prop": "name", "attributes": {"content": "강가의 풀밭, 울창한 숲, 꽃은 지지 않고, 열매도 떨어지지 않아. 재앙은 말할 것도 없고, 비조차 좀처럼 그 고요함을 깨뜨리지 않지.", "name": "내스티"}, "figure_art": "avg_4212_nasti_1#4$1"}, {"id": 302, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2039_1#7$1", "focus": "l"}}, {"id": 303, "prop": "name", "attributes": {"content": "그렇다면, 왜 그곳을 떠난 건가요?", "name": "스카이"}, "figure_art": "avg_npc_2039_1#7$1"}, {"id": 304, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_4212_nasti_1#1$1", "focus": "r"}}, {"id": 305, "prop": "name", "attributes": {"content": "……", "name": "내스티"}, "figure_art": "avg_4212_nasti_1#1$1"}, {"id": 306, "prop": "dialog", "attributes": {}}, {"id": 307, "prop": "charslot", "attributes": {"slot": "l", "focus": "n"}}, {"id": 308, "prop": "PlaySound", "attributes": {"key": "$doorknockquite", "volume": 1.0}}, {"id": 309, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 310, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_2039_1#5$1", "focus": "l"}}, {"id": 311, "prop": "name", "attributes": {"content": "이 늦은 시간에 누구지?", "name": "스카이"}, "figure_art": "avg_npc_2039_1#5$1"}, {"id": 312, "prop": "dialog", "attributes": {}}, {"id": 313, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 314, "prop": "charslot", "attributes": {"slot": "l", "name": "