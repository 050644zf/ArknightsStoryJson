ock": "true"}}, {"id": 152, "prop": "PlaySound", "attributes": {"key": "$d_avg_sea", "volume": 0.6, "loop": "true", "channel": "sea"}}, {"id": 153, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 154, "prop": "name", "attributes": {"content": "……"}}, {"id": 155, "prop": "Dialog", "attributes": {}}, {"id": 156, "prop": "stopSound", "attributes": {"key": "$d_avg_sea", "fadetime": 0.5, "channel": "sea"}}, {"id": 157, "prop": "PlaySound", "attributes": {"key": "$d_avg_spiritwhoosh", "volume": 0.6}}, {"id": 158, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 159, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 160, "prop": "charslot", "attributes": {}}, {"id": 161, "prop": "Background", "attributes": {"image": "bg_wilderness_n", "screenadapt": "coverall"}}, {"id": 162, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 163, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 164, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 165, "prop": "name", "attributes": {"content": "\t역시 무츠미에게 사키코는 필요 없어.", "name": "'무츠미'"}}, {"id": 166, "prop": "Dialog", "attributes": {}}, {"id": 167, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 168, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 169, "prop": "charslot", "attributes": {}}, {"id": 170, "prop": "Background", "attributes": {"image": "65_g2_dreamcastlehall", "screenadapt": "coverall", "block": "true"}}, {"id": 171, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 172, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 173, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 174, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#19$1", "focus": "m"}}, {"id": 175, "prop": "CameraShake", "attributes": {"duration": 0.3, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 176, "prop": "name", "attributes": {"content": "아하하…… 아하하하하핫!", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#19$1"}, {"id": 177, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#19$1", "focus": "m"}}, {"id": 178, "prop": "name", "attributes": {"content": "\t네 그 꼴사납고, 무력하고, 웃기는 얼굴, 전부 잘 봤어.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#19$1"}, {"id": 179, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "focus": "m"}}, {"id": 180, "prop": "name", "attributes": {"content": "처음에는 꿈이 깨져버렸지만, 이걸로 무승부쯤 되려나.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 181, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "focus": "m"}}, {"id": 182, "prop": "name", "attributes": {"content": "\t후훗, 그래도 고마워. 네가 그 아이들의 꿈을 몇 번이나 들락날락해준 덕분에……", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 183, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#1$1", "focus": "m"}}, {"id": 184, "prop": "name", "attributes": {"content": "\t증명되었거든…… 내가 만든 꿈이 완벽하고, 흠잡을 데 없다는 게.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#1$1"}, {"id": 185, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#1$1", "focus": "m"}}, {"id": 186, "prop": "name", "attributes": {"content": "\t이걸로 그 녀석도 인정할 수밖에 없을 거야. 나야말로 꿈의 성에서 가장 뛰어난 천재라는 걸.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#1$1"}, {"id": 187, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$1", "focus": "m"}}, {"id": 188, "prop": "name", "attributes": {"content": "그 녀석……?", "name": "토가와 사키코"}, "figure_art": "avg_4182_oblvns_1#9$1"}, {"id": 189, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#5$1", "focus": "m"}}, {"id": 190, "prop": "name", "attributes": {"content": "\t꿈속에서 만났잖아?", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#5$1"}, {"id": 191, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#17$1", "focus": "m"}}, {"id": 192, "prop": "name", "attributes": {"content": "\t공주님 같은 옷을 입고, 시대에 뒤떨어진 말투를 쓰는 그 녀석 말이야.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#17$1"}, {"id": 193, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#17$1", "focus": "m"}}, {"id": 194, "prop": "name", "attributes": {"content": "\t그 녀석 곁에 있으면 불편해서 견딜 수가 없어.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#17$1"}, {"id": 195, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#4$1", "focus": "m"}}, {"id": 196, "prop": "name", "attributes": {"content": "아이리스 씨야말로 꿈의 성의 주인이에요. 당신은 그저 가짜일 뿐이에요!", "name": "토가와 사키코"}, "figure_art": "avg_4182_oblvns_1#4$1"}, {"id": 197, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#4$1", "focus": "m"}}, {"id": 198, "prop": "name", "attributes": {"content": "아이리스 씨는 말씀하셨어요. 아무리 멋진 꿈이라도, 언젠가는 깨어날 때가 온다고……", "name": "토가와 사키코"}, "figure_art": "avg_4182_oblvns_1#4$1"}, {"id": 199, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$1", "focus": "m"}}, {"id": 200, "prop": "name", "attributes": {"content": "큭……!", "name": "토가와 사키코"}, "figure_art": "avg_4182_oblvns_1#14$1"}, {"id": 201, "prop": "name", "attributes": {"content": "사키코의 목은 갑자기 얼어붙은 것처럼 소리를 낼 수 없게 되었다."}}, {"id": 202, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#15$1", "focus": "m"}}, {"id": 203, "prop": "name", "attributes": {"content": "\t너를 보고 있으면 왜 짜증이 나는지, 드디어 알았어.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#15$1"}, {"id": 204, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#9$1", "focus": "m"}}, {"id": 205, "prop": "name", "attributes": {"content": "\t너, 아이리스랑 똑같아. 처음부터 남의 의견을 들을 생각도 없고, 입만 열면 언제나 번지르르한 말뿐이지.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#9$1"}, {"id": 206, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#9$1", "focus": "m"}}, {"id": 207, "prop": "name", "attributes": {"content": "\t인생을 맡아두겠다는 둥 했지만, 결국 모두가 자기 곁을 떠나는 게 싫었을 뿐이잖아.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#9$1"}, {"id": 208, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#9$1", "focus": "m"}}, {"id": 209, "prop": "name", "attributes": {"content": "\t네 인생, 전부 다 봤어. 몰락한 아가씨가 미련하게 발버둥 치는 모습을 말이야.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#9$1"}, {"id": 210, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#10$1", "focus": "m"}}, {"id": 211, "prop": "name", "attributes": {"content": "\t내 뜻대로 하고 싶어, 다른 사람에게 비참한 날 보여주고 싶지 않아…… 네 행동은 전부 그랬지.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#10$1"}, {"id": 212, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#10$1", "focus": "m"}}, {"id": 213, "prop": "name", "attributes": {"content": "\t오만하고, 제멋대로에…… 정말 구제 불능이야.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#10$1"}, {"id": 214, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#16$1", "focus": "m"}}, {"id": 215, "prop": "name", "attributes": {"content": "\t네 밴드, 결국 뭐였어? '계약' 같은 거창한 말로 묶어두고, 밴드 놀이나 하고 있었을 뿐이잖아.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#16$1"}, {"id": 216, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#1$1", "focus": "m"}}, {"id": 217, "prop": "name", "attributes": {"content": "\t그 아이들은 지금 자신의 행복을 손에 넣었어. 그래서 너 같은 건 버려버렸지. 우후훗…… 너, 또 외톨이가 돼버렸네.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#1$1"}, {"id": 218, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#1$1", "focus": "m"}}, {"id": 219, "prop": "name", "attributes": {"content": "\t그래도 아이리스의 말을 믿겠다고 한다면…… 좋아, 너를 위해서 다시 한번 멋진 꿈을 준비해 줄게.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#1$1"}, {"id": 220, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#1$1", "focus": "m"}}, {"id": 221, "prop": "name", "attributes": {"content": "\t설령 머리로는 현실이 아니라는 걸 알아도, 계속 보고 싶어지는 완벽한 꿈을.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#1$1"}, {"id": 222, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#1$1", "focus": "m"}}, {"id": 223, "prop": "name", "attributes": {"content": "\t다른 아이들처럼, 내 꿈에 빠져서 헤어 나오지 못하게 될 거야.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#1$1"}, {"id": 224, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$1", "focus": "m"}}, {"id": 225, "prop": "name", "attributes": {"content": "큭……!", "name": "토가와 사키코"}, "figure_art": "avg_4182_oblvns_1#14$1"}, {"id": 226, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#11$1", "focus": "m"}}, {"id": 227, "prop": "name", "attributes": {"content": "\t말하고 싶어? 그럼 마지막으로 한마디만 하게 해줄게.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#11$1"}, {"id": 228, "prop": "dialog", "attributes": {}}, {"id": 229, "prop": "charslot", "attributes": {}}, {"id": 230, "prop": "name", "attributes": {"content": "악마 같은 소녀는, 사슬을 푸는 듯한 손짓으로 허공에 어떤 모양을 그렸다."}}, {"id": 231, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#4$1", "focus": "m"}}, {"id": 232, "prop": "name", "attributes": {"content": "저는……", "name": "토가와 사키코"}, "figure_art": "avg_4182_oblvns_1#4$1"}, {"id": 233, "prop": "dialog", "attributes": {}}, {"id": 234, "prop": "charslot", "attributes": {}}, {"id": 235, "prop": "name", "attributes": {"content": "사슬이 다시 무자비하게 조여들었다."}}, {"id": 236, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#19$1", "focus": "m"}}, {"id": 237, "prop": "name", "attributes": {"content": "\t아하하하하핫……", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#19$1"}, {"id": 238, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "focus": "m"}}, {"id": 239, "prop": "name", "attributes": {"content": "\t역시 넌, 조용히 있을 때가 훨씬 귀여워!", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 240, "prop": "name", "attributes": {"content": "모피어스는 계속 몸부림치는 사키코에게 한 걸음씩 다가가, 오른손을 뻗어 사키코의 뺨에 가져다 댔다."}}, {"id": 241, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "focus": "m"}}, {"id": 242, "prop": "name", "attributes": {"content": "\t가짜 공주님. 네가 이상한 나라를 헤매는 사이에, 나는 똑똑히 이해했어.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 243, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "focus": "m"}}, {"id": 244, "prop": "name", "attributes": {"content": "\t네가 무엇에 굶주려 있고, 무엇을 원하며, 무엇을 두려워하는지를 말이야.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 245, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "focus": "m"}}, {"id": 246, "prop": "name", "attributes": {"content": "\t그러니까 걱정하지 마. 이번에는 완벽한 꿈을 보여줄게. 꿈이라는 걸 똑똑히 알면서도, 절대로 깨고 싶지 않아지는 걸로.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 247, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#17$1", "focus": "m"}}, {"id": 248, "prop": "name", "attributes": {"content": " 잘 자. 고귀하고, 교활하고, 제멋대로인 인형 씨.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#17$1"}, {"id": 249, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#17$1", "focus": "m"}}, {"id": 250, "prop": "name", "attributes": {"content": "\t좋은 꿈 꿔.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#17$1"}, {"id": 251, "prop": "Dialog", "attributes": {}}, {"id": 252, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 253, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 254, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 255, "prop": "charslot", "attributes": {}}, {"id": 256, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 257, "prop": "name", "attributes": {"content": "덜컹, 덜컹."}}, {"id": 258, "prop": "name", "attributes": {"content": "사키코, 사키코?", "name": "???"}}, {"id": 259, "prop": "dialog", "attributes": {}}, {"id": 260, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 261, "prop": "name", "attributes": {"content": "으응……", "name": "토가와 사키코"}}, {"id": 262, "prop": "dialog", "attributes": {}}, {"id": 263, "prop": "Background", "attributes": {"image": "46_g1_transporter", "screenadapt": "coverall", "block": "true"}}, {"id": 264, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 265, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 266, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 267, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#4$2", "focus": "m"}}, {"id": 268, "prop": "name", "attributes": {"content": "당신이 말하는 대로는……!", "name": "토가와 사키코"}, "figure_art": "avg_4182_oblvns_1#4$2"}, {"id": 269, "prop": "charslot", "attributes": {}}, {"id": 270, "prop": "name", "attributes": {"content": "사키코는 무심코 소리쳤지만, 그곳은 이미 성 안이 아니었고, 모피어스도 모습을 감춘 상태였다."}}, {"id": 271, "prop": "dialog", "attributes": {}}, {"id": 272, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_290_vigna_1#4$1", "focus": "m", "duration": 1.0}}, {"id": 273, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 274, "prop": "PlayMusic", "attributes": {"intro": "$mist_intro", "key": "$mist_loop", "volume": 0.6}}, {"id": 275, "prop": "name", "attributes": {"content": "\t괜찮아? 안색이 아주 나쁜데. 또 악몽이라도 꾼 거야?", "name": "비그나"}, "figure_art": "avg_290_vigna_1#4$1"}, {"id": 276, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$2", "focus": "m"}}, {"id": 277, "prop": "name", "attributes": {"content": "또…… 꿈속으로 돌아왔군요.", "name": "토가와 사키코"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 278, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_290_vigna_1#4$1", "focus": "m"}}, {"id": 279, "prop": "name", "attributes": {"content": "\t무슨 말도 안 되는 소리를 하고 있어. 방금 일어났잖아.", "name": "비그나"}, "figure_art": "avg_290_vigna_1#4$1"}, {"id": 280, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_290_vigna_1#4$1", "focus": "m"}}, {"id": 281, "prop": "name", "attributes": {"content": "\t혹시 아직 잠이 덜 깬 거야?", "name": "비그나"}, "figure_art": "avg_290_vigna_1#4$1"}, {"id": 282, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#6$2", "focus": "m"}}, {"id": 283, "prop": "name", "attributes": {"content": "아이리스 씨와 베나 씨도 계시는군요……", "name": "토가와 사키코"}, "figure_art": "avg_4182_oblvns_1#6$2"}, {"id": 284, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_338_iris_1#1$1", "focus": "m"}}, {"id": 285, "prop": "name", "attributes": {"content": "처음 뵙겠습니다…… 자기소개는 안 했던 것 같은데요?", "name": "아이리스"}, "figure_art": "avg_338_iris_1#1$1"}, {"id": 286, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_369_bena_1#5$1", "focus": "m"}}, {"id": 287, "prop": "name", "attributes": {"content": "그래. 우리가 도착했을 땐 이미 자고 있었어.", "name": "베나"}, "figure_art": "avg_369_bena_1#5$1"}, {"id": 288, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#6$2", "focus": "m"}}, {"id": 289, "prop": "name", "attributes": {"content": "비그나 씨와 제가 먼저 타고 있었다는 건…… 새로운 꿈으로 바뀌었다는 거네요……", "name": "토가와 사키코"}, "figure_art": "avg_4182_oblvns_1#6$2"}, {"id": 290, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_290_vigna_1#11$1", "focus": "m"}}, {"id": 291, "prop": "name", "attributes": {"content": "\t사키코, 아까부터 왜 자꾸 이상한 소리만……", "name": "비그나"}, "figure_art": "avg_290_vigna_1#11$1"}, {"id": 292, "prop": "dialog", "attributes": {}}, {"id": 293, "prop": "charslot", "attributes": {}}, {"id": 294, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 295, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 296, "prop": "Subtitle", "attributes": {"text": "지금은, 아이리스 씨의 지인인 안 씨를 찾아가기 위해 빅토리아의 작은 마을로 향하는 중……", "x": 300.0, "y": 350.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 297, "prop": "Subtitle", "attributes": {"text": "하지만, 곧 타이어가 펑크 나서 수리를 위해 대기하게 돼요. 그래서 도착도 늦어지고……", "x": 300.0, "y": 350.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 298, "prop": "subtitle", "attributes": {}}, {"id": 299, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 300, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 301, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$2", "focus": "m"}}, {"id": 302, "prop": "name", "attributes": {"content": "저희, 지금부터 빅토리아로 안 씨를 찾으러 가는 거죠?", "name": "토가와 사키코"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 303, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_290_vigna_1#11$1", "focus": "m"}}, {"id": 304, "prop": "name", "attributes": {"content": "\t엇, 안 씨가 누구야? 아이리스는 알아?", "name": "비그나"}, "figure_art": "avg_290_vigna_1#11$1"}, {"id": 305, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_338_iris_1#4$1", "focus": "m"}}, {"id": 306, "prop": "name", "attributes": {"content": "안 씨……? 사키코 씨의 친구분인가요?", "name": "아이리스"}, "figure_art": "avg_338_iris_1#4$1"}, {"id": 307, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#14$2", "focus": "m"}}, {"id": 308, "prop": "name", "attributes": {"content": "어…… 안 씨를 모르시나요?", "name": "토가와 사키코"}, "figure_art": "avg_4182_oblvns_1#14$2"}, {"id": 309, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#10$2", "focus": "m"}}, {"id": 310, "prop": "name", "attributes": {"content": "그럼, 저와 비그나 씨는 무엇 때문에……?", "name": "토가와 사키코"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 311, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_290_vigna_1#1$1", "focus": "m"}}, {"id": 312, "prop": "name", "attributes": {"content": "\t마침 일할 곳이 사키코네 집 근처잖아? 그래서 이참에 집에 들러서, 가족과 함께 쉬게 할 생각이었어.", "name": "비그나"}, "figure_art": "avg_290_vigna_1#1$1"}, {"id": 313, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_290_vigna_1#5$1", "focus": "m"}}, {"id": 314, "prop": "name", "attributes": {"content": " 일이 바빠서, 계속 집에 못 돌아갔을 테니까.", "name": "비그나"}, "figure_art": "avg_290_vigna_1#5$1"}, {"id": 315, "prop": "dialog", "attributes": {}}, {"id": 316, "prop": "charslot", "attributes": {}}, {"id": 317, "prop": "PlaySound", "attributes": {"key": "$drift", "volume": 0.6}}, {"id": 318, "prop": "CameraShake", "attributes": {"duration": 2.0, "xstrength": 20.0, "ystrength": 20.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 319, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 320, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_338_iris_1#4$1", "focus": "m"}}, {"id": 321, "prop": "name", "attributes": {"content": "차가 갑자기 멈췄어요! 무슨 일이죠?!", "name": "아이리스"}, "figure_art": "avg_338_iris_1#4$1"}, {"id": 322, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_369_bena_1#5$1", "focus": "m"}}, {"id": 323, "prop": "name", "attributes": {"content": "진짜 펑크 난 건 아니겠지?!", "name": "베나"}, "figure_art": "avg_369_bena_1#5$1"}, {"id": 324, "prop": "charslot", "attributes": {}}, {"id": 325, "prop": "name", "attributes": {"content": "하아, 하아…… 하, 하마터면 버든비스트와 부딪힐 뻔했어요!", "name": "기사"}, "figure_art": "avg_369_bena_1#5$1"}, {"id": 326, "prop": "name", "attributes": {"content": "다행히 아무 일도 없었습니다. 바로 다시 출발하겠습니다!", "name": "기사"}, "figure_art": "avg_369_bena_1#5$1"}, {"id": 327, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#10$2", "focus": "m"}}, {"id": 328, "prop": "name", "attributes": {"content": "……", "name": "토가와 사키코"}, "figure_art": "avg_4182_oblvns_1#10$2"}, {"id": 329, "prop": "charslot", "attributes": {}}, {"id": 330, "prop": "name", "attributes": {"content": "엔진 시동이 걸리는 소리와 함께, 창밖의 풍경이 다시 움직이기 시작했다."}}, {"id": 331, "prop": "Dialog", "attributes": {}}, {"id": 332, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 333, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 334, "prop": "charslot", "attributes": {}}, {"id": 335, "prop": "Background", "attributes": {"image": "bg_wilderness_d", "screenadapt": "coverall", "block": "true"}}, {"id": 336, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 337, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 338, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 339, "prop": "name", "attributes": {"content": "같은 풍경, 같은 동행자."}}, {"id": 340, "prop": "name", "attributes": {"content": "하지만 꿈속에서는, 이미 변화가 일어나고 있었다."}}, {"id": 341, "prop": "Dialog", "attributes": {}}, {"id": 342, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 343, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 344, "prop": "charslot", "attributes": {}}, {"id": 345, "prop": "Image", "attributes": {}}, {"id": 346, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}