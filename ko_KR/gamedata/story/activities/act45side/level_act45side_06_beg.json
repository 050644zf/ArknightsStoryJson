ion": 0.3, "xstrength": 10.0, "ystrength": 12.0, "vibrato": 30.0, "randomness": 30.0, "fadeout": "false"}}, {"id": 79, "prop": "name", "attributes": {"content": "……!", "name": "토가와 사키코"}, "figure_art": "avg_4182_oblvns_1#6$1"}, {"id": 80, "prop": "charslot", "attributes": {}}, {"id": 81, "prop": "name", "attributes": {"content": "심장이 격렬하게 뛰고, 호흡이 흐트러지며, 등에선 식은땀이 배어 나왔다."}}, {"id": 82, "prop": "name", "attributes": {"content": "잠에서 깨어나긴 했지만, 너무나도 지독한 방식이었다."}}, {"id": 83, "prop": "dialog", "attributes": {}}, {"id": 84, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n", "volume": 1.0}}, {"id": 85, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "focus": "m", "duration": 1.0}}, {"id": 86, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 87, "prop": "name", "attributes": {"content": "\t아주 리얼했지?", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 88, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "focus": "m"}}, {"id": 89, "prop": "name", "attributes": {"content": "\t높은 곳에서 땅으로 떨어지면서……", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 90, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "focus": "m"}}, {"id": 91, "prop": "name", "attributes": {"content": "\t꿈은 산산조각 나고, '꿈이 없는 경계'에 갇혀 도망칠 수도 없지…… 대체 어떤 감각일까.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 92, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$1", "focus": "m"}}, {"id": 93, "prop": "name", "attributes": {"content": "여러분의 꿈…… 분명 멋진 꿈이기는 했어요. 하지만, 언제까지나 빠져있어서는 안 돼요.", "name": "토가와 사키코"}, "figure_art": "avg_4182_oblvns_1#9$1"}, {"id": 94, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$1", "focus": "m"}}, {"id": 95, "prop": "name", "attributes": {"content": "마음의 가장 약한 부분을 엿보고, 그것을 각색해서 몇 번이나 눈앞에 드러내는…… 그런 꿈에는요.", "name": "토가와 사키코"}, "figure_art": "avg_4182_oblvns_1#9$1"}, {"id": 96, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#1$1", "focus": "m"}}, {"id": 97, "prop": "name", "attributes": {"content": "\t어머, 그럴까?", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#1$1"}, {"id": 98, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#1$1", "focus": "m"}}, {"id": 99, "prop": "name", "attributes": {"content": "\t그 아이들, 네가 꿈에 들어오기 전까지는 너에 대한 것도, 그 시시한 밴드도 거의 잊어버렸는걸.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#1$1"}, {"id": 100, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#9$1", "focus": "m"}}, {"id": 101, "prop": "name", "attributes": {"content": "아니요, Ave{@nbs}Mujica는 하나의 '계약'이에요. 그분들의 인생은 제가……", "name": "토가와 사키코"}, "figure_art": "avg_4182_oblvns_1#9$1"}, {"id": 102, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#13$1", "focus": "m"}}, {"id": 103, "prop": "name", "attributes": {"content": "\t그런 거, 너 말고는 아무도 신경 쓰지 않아.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#13$1"}, {"id": 104, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4182_oblvns_1#4$1", "focus": "m"}}, {"id": 105, "prop": "name", "attributes": {"content": "무슨……!", "name": "토가와 사키코"}, "figure_art": "avg_4182_oblvns_1#4$1"}, {"id": 106, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#18$1", "focus": "m"}}, {"id": 107, "prop": "name", "attributes": {"content": "자기 귀로 들었잖아?", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#18$1"}, {"id": 108, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1942_1#15$1", "focus": "m"}}, {"id": 109, "prop": "name", "attributes": {"content": "그 아이들이 널 거부하는 걸.", "name": "모피어스"}, "figure_art": "avg_npc_1942_1#15$1"}, {"id": 110, "prop": "Dialog", "attributes": {}}, {"id": 111, "prop": "PlaySound", "attributes": {"key": "$d_avg_spiritwhoosh", "volume": 0.6}}, {"id": 112, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 113, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 114, "prop": "charslot", "attributes": {}}, {"id": 115, "prop": "Background", "attributes": {"image": "bg_lmstreet_1", "screenadapt": "coverall"}}, {"id": 116, "prop": "Delay", "attributes": {"time": 0.5}}, {"id": 117, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 118, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 119, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#2$3", "focus": "m"}}, {"id": 120, "prop": "name", "attributes": {"content": "싫어. 여기 있는 사람들은 모두 배우로서의 나를 사랑해 주고 있는걸.", "name": "유텐지 냐무"}, "figure_art": "avg_4185_amoris_1#2$3"}, {"id": 121, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#7$3", "focus": "m"}}, {"id": 122, "prop": "name", "attributes": {"content": "나, 그걸 위해서 모든 걸 다 바쳤거든? 그런데 이제 와서 전부 거짓말이었습니다~ 라는 거야?", "name": "유텐지 냐무"}, "figure_art": "avg_4185_amoris_1#7$3"}, {"id": 123, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#2$4", "focus": "m"}}, {"id": 124, "prop": "name", "attributes": {"content": "웃기지 마. 그딴 거 절대 인정 안 할 거니까!", "name": "유텐지 냐무"}, "figure_art": "avg_4185_amoris_1#2$4"}, {"id": 125, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#2$4", "focus": "m"}}, {"id": 126, "prop": "name", "attributes": {"content": "여기, 내 꿈이잖아? 너도 밴드도 상관없어.", "name": "유텐지 냐무"}, "figure_art": "avg_4185_amoris_1#2$4"}, {"id": 127, "prop": "Dialog", "attributes": {}}, {"id": 128, "prop": "PlaySound", "attributes": {"key": "$d_avg_spiritwhoosh", "volume": 0.6}}, {"id": 129, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 130, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 131, "prop": "charslot", "attributes": {}}, {"id": 132, "prop": "Background", "attributes": {"ima