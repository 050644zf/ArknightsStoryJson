tes": {"content": "당신이 살던 당구장이 아니라, 당신이 있어야 할 곳으로요.", "name": "토가와 사키코"}}, {"id": 234, "prop": "name", "attributes": {"content": "무슨 뜻인지 모르겠군요.", "name": "야하타 우미리"}}, {"id": 235, "prop": "name", "attributes": {"content": "모른다고 해도, 반드시 당신을 되찾을 거예요. 이런 곳에서 죽게 할 수는 없으니까요.", "name": "토가와 사키코"}}, {"id": 236, "prop": "name", "attributes": {"content": "프랜시스 씨 쪽을 노린 건, 보스의 부하예요.", "name": "토가와 사키코"}}, {"id": 237, "prop": "Dialog", "attributes": {}}, {"id": 238, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 239, "prop": "name", "attributes": {"content": "당신을 함정에 빠뜨릴 인간이, 당신이 원하는 안식처를 줄 리는 없죠.", "name": "토가와 사키코"}}, {"id": 240, "prop": "name", "attributes": {"content": "그런…… 하지만……", "name": "야하타 우미리"}}, {"id": 241, "prop": "name", "attributes": {"content": "몇 번이고 이용당하고, 버리는 말 취급받고…… 이게 당신이 원하던 삶의 방식, 그리고 당신이 원하던 '신뢰'인가요?", "name": "토가와 사키코"}}, {"id": 242, "prop": "name", "attributes": {"content": "당신은 여기 오래 머물면서도, 단 한 사람도 상처 입히려 하지 않았어요.", "name": "토가와 사키코"}}, {"id": 243, "prop": "name", "attributes": {"content": "아까 악기 케이스를 봤어요. 안에 든 건 당신의 베이스겠죠?", "name": "토가와 사키코"}}, {"id": 244, "prop": "name", "attributes": {"content": "야하타 씨, 이런 곳에서 고통받을 필요 없어요.", "name": "토가와 사키코"}}, {"id": 245, "prop": "name", "attributes": {"content": "야하타 씨, 저와 함께 돌아가요.", "name": "토가와 사키코"}}, {"id": 246, "prop": "Dialog", "attributes": {}}, {"id": 247, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 248, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 249, "prop": "stopsound", "attributes": {"channel": "hr", "fadetime": 2.0}}, {"id": 250, "prop": "image", "attributes": {}}, {"id": 251, "prop": "charslot", "attributes": {}}, {"id": 252, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}