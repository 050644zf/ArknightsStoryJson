 1.5}}, {"id": 138, "prop": "PlaySound", "attributes": {"key": "$d_avg_trnpndor", "volume": 0.7}}, {"id": 139, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 140, "prop": "Background", "attributes": {"image": "bg_rooftop_2", "screenadapt": "coverall", "fadetime": 1.0, "block": "true"}}, {"id": 141, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 142, "prop": "name", "attributes": {"content": "소녀는 전화를 들고 문을 연 뒤 베란다로 나갔다."}}, {"id": 143, "prop": "name", "attributes": {"content": "냐무, 저녁은 묵었나? 요즘 많이 바쁘제?", "name": "전화 너머의 목소리"}}, {"id": 144, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "m"}}, {"id": 145, "prop": "name", "attributes": {"content": "응, 묵었다.", "name": "유텐지 냐무"}, "figure_art": "avg_4185_amoris_1#1$3"}, {"id": 146, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "n"}}, {"id": 147, "prop": "name", "attributes": {"content": "우리집 보리가 또 풍년이라 아이가. 매일 아침 일찍부터 가서, 해질 때까지 일만 했다 안 카나.", "name": "전화 너머의 목소리"}}, {"id": 148, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#8$3", "focus": "m"}}, {"id": 149, "prop": "name", "attributes": {"content": "하아, 저번에 말 안 했나? 무리하지 말고, 시골에서 편하게 있으믄 된다고.", "name": "유텐지 냐무"}, "figure_art": "avg_4185_amoris_1#8$3"}, {"id": 150, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#8$3", "focus": "n"}}, {"id": 151, "prop": "name", "attributes": {"content": "니가 피곤할까 봐 걱정돼서 안 카나. 피곤하믄 한번 쉬러 내려온나.", "name": "전화 너머의 목소리"}}, {"id": 152, "prop": "name", "attributes": {"content": "아 맞다, 올 연휴에 뭐 묵고 싶은 거 없나? 아부지랑 같이 준비해 놓을 테니까……", "name": "전화 너머의 목소리"}}, {"id": 153, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#3$4", "focus": "m"}}, {"id": 154, "prop": "name", "attributes": {"content": "연휴에는 몬 간다! 다들 쉴 때가 내 제일 바쁠 때 아이가……", "name": "유텐지 냐무"}, "figure_art": "avg_4185_amoris_1#3$4"}, {"id": 155, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#3$4", "focus": "n"}}, {"id": 156, "prop": "name", "attributes": {"content": "그런가……", "name": "전화 너머의 목소리"}}, {"id": 157, "prop": "name", "attributes": {"content": "(희미하게 들리는 목소리) 엄마, 누나 드디어 전화받았나?", "name": "전화 너머의 목소리"}}, {"id": 158, "prop": "PlaySound", "attributes": {"key": "$d_avg_walkfast", "volume": 0.3}}, {"id": 159, "prop": "name", "attributes": {"content": "(가까워지는 발소리)", "name": "전화 너머의 목소리"}}, {"id": 160, "prop": "name", "attributes": {"content": "누나야! TV에서 누나야 나오는 새 영화 예고편 하더라!", "name": "전화 너머의 목소리"}}, {"id": 161, "prop": "name", "attributes": {"content": "이짝에 영화관이 없는 게 아숩다. 있었으면 표 샀을 텐데……", "name": "전화 너머의 목소리"}}, {"id": 162, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#8$3", "focus": "m"}}, {"id": 163, "prop": "name", "attributes": {"content": "후후, 걱정 마레이. 난중에 디스크 나오믄, 누나가 거기 보내주께.", "name": "유텐지 냐무"}, "figure_art": "avg_4185_amoris_1#8$3"}, {"id": 164, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#8$3", "focus": "n"}}, {"id": 165, "prop": "name", "attributes": {"content": "좋다~!", "name": "전화 너머의 목소리"}}, {"id": 166, "prop": "name", "attributes": {"content": "누나야, 영화에서 드럼 치던 거 억수로 멋있더라!", "name": "전화 너머의 목소리"}}, {"id": 167, "prop": "name", "attributes": {"content": "내도 요즘, 누나야가 예전에 쓰던 걸로 드럼 연습 시작했다 아이가!", "name": "전화 너머의 목소리"}}, {"id": 168, "prop": "name", "attributes": {"content": "누나야는 요즘 점점 드럼 실력이 느는 것 같데! 내도 언젠가는, 누나야처럼 무대에서 라이브 하고 싶데이!", "name": "전화 너머의 목소리"}}, {"id": 169, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "m"}}, {"id": 170, "prop": "name", "attributes": {"content": "내는…… 아하하, 요즘에는 마이 바빠서, 별로 연습 몬 했다.", "name": "유텐지 냐무"}, "figure_art": "avg_4185_amoris_1#1$3"}, {"id": 171, "prop": "name", "attributes": {"content": "캐도, 연습 게을리할 생각은 없데이. 내일 마침 쉬는 날이고, 같이 연습 열심히 하제이~!", "name": "유텐지 냐무"}, "figure_art": "avg_4185_amoris_1#1$3"}, {"id": 172, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "n"}}, {"id": 173, "prop": "name", "attributes": {"content": "응! 엄마가 이제 자라 카니까, 누나야도 고마 자라!", "name": "전화 너머의 목소리"}}, {"id": 174, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "m"}}, {"id": 175, "prop": "name", "attributes": {"content": "다들 건강 잘 챙기고~ 잘 자그래이~", "name": "유텐지 냐무"}, "figure_art": "avg_4185_amoris_1#1$3"}, {"id": 176, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "n"}}, {"id": 177, "prop": "name", "attributes": {"content": "잘 자래이~", "name": "전화 너머의 목소리"}}, {"id": 178, "prop": "Dialog", "attributes": {}}, {"id": 179, "prop": "charslot", "attributes": {}}, {"id": 180, "prop": "PlaySound", "attributes": {"key": "$d_avg_phonestop", "volume": 1.0}}, {"id": 181, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 182, "prop": "PlaySound", "attributes": {"key": "$phonevibration", "volume": 0.8}}, {"id": 183, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 184, "prop": "PlaySound", "attributes": {"key": "$d_avg_ringoff", "volume": 1.0}}, {"id": 185, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 186, "prop": "name", "attributes": {"content": "냐무 씨, 방금 소속사에서 급하게 연락이 왔는데, 대형 버라이어티 프로그램 출연 제의가 들어왔대요.", "name": "전화 너머의 목소리"}}, {"id": 187, "prop": "name", "attributes": {"content": "녹화는 내일 저녁 8시부터 다음 날 새벽 2시까지로 예정되어 있어요. 괜찮으시겠어요?", "name": "전화 너머의 목소리"}}, {"id": 188, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#4$3", "focus": "m"}}, {"id": 189, "prop": "name", "attributes": {"content": "꽤 갑작스럽네요……", "name": "유텐지 냐무"}, "figure_art": "avg_4185_amoris_1#4$3"}, {"id": 190, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#4$3", "focus": "n"}}, {"id": 191, "prop": "name", "attributes": {"content": "그게…… 다른 게스트 한 분이, 아이돌 소라 씨라서요.", "name": "전화 너머의 목소리"}}, {"id": 192, "prop": "name", "attributes": {"content": "소라 씨는 우리 쪽에 뒤지지 않을 정도로 인기 있는 아이돌인 데다가, 업계 안팎을 불문하고 평판이 아주 좋은 분이에요.", "name": "전화 너머의 목소리"}}, {"id": 193, "prop": "name", "attributes": {"content": "이건 이목을 끌 수 있는 절호의 기회예요. 타이트한 스케줄이지만, 다시없을 기회니까……", "name": "전화 너머의 목소리"}}, {"id": 194, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#2$3", "focus": "m"}}, {"id": 195, "prop": "name", "attributes": {"content": "……", "name": "유텐지 냐무"}, "figure_art": "avg_4185_amoris_1#2$3"}, {"id": 196, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "m"}}, {"id": 197, "prop": "name", "attributes": {"content": "그러면…… “여러분과 함께 출연하는 걸 기대하고 있을게요!” 라고 전해주세요.", "name": "유텐지 냐무"}, "figure_art": "avg_4185_amoris_1#1$3"}, {"id": 198, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "n"}}, {"id": 199, "prop": "name", "attributes": {"content": "알겠습니다. 그러면 오늘 일은 끝났네요.", "name": "전화 너머의 목소리"}}, {"id": 200, "prop": "name", "attributes": {"content": "고생하셨어요, 냐무 씨. 안녕히 주무세요.", "name": "전화 너머의 목소리"}}, {"id": 201, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#2$3", "focus": "m"}}, {"id": 202, "prop": "name", "attributes": {"content": "(……적어도 오늘은 드디어 편하게 잘 수 있겠네.)", "name": "유텐지 냐무"}, "figure_art": "avg_4185_amoris_1#2$3"}, {"id": 203, "prop": "Dialog", "attributes": {}}, {"id": 204, "prop": "PlaySound", "attributes": {"key": "$d_avg_phonestop", "volume": 1.0}}, {"id": 205, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 206, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4185_amoris_1#1$3", "focus": "m"}}, {"id": 207, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 208, "prop": "PlaySound", "attributes": {"key": "$d_avg_walk_stage", "volume": 1.0, "loop": "false", "channel": "nw1"}}, {"id": 209, "prop": "stopsound", "attributes": {"fadetime": 3.0, "channel": "nw1"}}, {"id": 210, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 211, "prop": "delay", "attributes": {"time": 1.5}}, {"id": 212, "prop": "PlaySound", "attributes": {"key": "$d_avg_trnclsdor", "volume": 0.7}}, {"id": 213, "prop": "Delay", "attribu