ame", "attributes": {"content": "……만트라……", "name": "가까워졌다 멀어졌다 하는 목소리"}}, {"id": 141, "prop": "dialog", "attributes": {}}, {"id": 142, "prop": "image", "attributes": {}}, {"id": 143, "prop": "charslot", "attributes": {}}, {"id": 144, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 145, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1730_1#2$1"}}, {"id": 146, "prop": "Background", "attributes": {"image": "bg_ibindoor", "screenadapt": "coverall"}}, {"id": 147, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 148, "prop": "name", "attributes": {"content": "만트라!", "name": "라이디언"}, "figure_art": "avg_npc_1730_1#2$1"}, {"id": 149, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#6$1"}}, {"id": 150, "prop": "name", "attributes": {"content": "……어?", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#6$1"}, {"id": 151, "prop": "playMusic", "attributes": {"intro": "$ponder_intro", "key": "$ponder_loop", "volume": 0.6}}, {"id": 152, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1730_1#5$1"}}, {"id": 153, "prop": "name", "attributes": {"content": "아까부터 미동도 없었어.", "name": "라이디언"}, "figure_art": "avg_npc_1730_1#5$1"}, {"id": 154, "prop": "name", "attributes": {"content": "당신이 이러는 건 처음 봐…… 무슨 일이야?", "name": "라이디언"}, "figure_art": "avg_npc_1730_1#5$1"}, {"id": 155, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#3$1"}}, {"id": 156, "prop": "name", "attributes": {"content": "너희들은 아무것도 못 들었어?", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#3$1"}, {"id": 157, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1730_1#4$1"}}, {"id": 158, "prop": "name", "attributes": {"content": "뭐가 들려?", "name": "라이디언"}, "figure_art": "avg_npc_1730_1#4$1"}, {"id": 159, "prop": "charslot", "attributes": {}}, {"id": 160, "prop": "name", "attributes": {"content": "만트라는 곧바로 대답하진 않았다."}}, {"id": 161, "prop": "name", "attributes": {"content": "주위를 둘러본 그녀는 광부들의 자세가 조금 전과 다르다는 걸 발견했다. 그녀는 눈살을 찌푸리며 옆으로 돌아보았다."}}, {"id": 162, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#10$1"}}, {"id": 163, "prop": "name", "attributes": {"content": "알로이즈는 어디 있지?", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#10$1"}, {"id": 164, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1730_1#3$1"}}, {"id": 165, "prop": "name", "attributes": {"content": "내 말을 듣고 뛰쳐나갔어.", "name": "라이디언"}, "figure_art": "avg_npc_1730_1#3$1"}, {"id": 166, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 167, "prop": "name", "attributes": {"content": "그러니까, 너는 조금 전에 확실히 우리에게 떠나라고 했네.", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 168, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1730_1#5$1"}}, {"id": 169, "prop": "name", "attributes": {"content": "맞아. 하지만 왜 떠나라고 소리쳤는지 전혀 기억나질 않아…… 너무 이상해.", "name": "라이디언"}, "figure_art": "avg_npc_1730_1#5$1"}, {"id": 170, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 171, "prop": "name", "attributes": {"content": "정신계 오리지늄 아츠 때문이야.", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 172, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1730_1#4$1"}}, {"id": 173, "prop": "name", "attributes": {"content": "확실해? 우린 전문 훈련을 받았잖아. 그런 공격에 전혀 무방비 상태였을 리 없어.", "name": "라이디언"}, "figure_art": "avg_npc_1730_1#4$1"}, {"id": 174, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#4$1"}}, {"id": 175, "prop": "name", "attributes": {"content": "라이디언, 단기 기억에 간섭이 있었는지 확인해 봐.", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#4$1"}, {"id": 176, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1730_1#3$1"}}, {"id": 177, "prop": "name", "attributes": {"content": "어떤 간섭?", "name": "라이디언"}, "figure_art": "avg_npc_1730_1#3$1"}, {"id": 178, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#4$1"}}, {"id": 179, "prop": "name", "attributes": {"content": "내가 할 수 있는 간섭.", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#4$1"}, {"id": 180, "prop": "name", "attributes": {"content": "한 번은 내가 메커니스트에게 너를 찾아 '덴디'와 '액시'를 빌리는 걸 잊게 한 적이 있어. 그건 본질적으로 기억을 지운 게 아니라, 기억의 형성을 차단한 거야.", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#4$1"}, {"id": 181, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1730_1#4$1"}}, {"id": 182, "prop": "name", "attributes": {"content": "기억나…… 당신이 그때 처음 오리지늄 아츠를 쓴 거였지? 대뇌에 정보가 저장되지 않으면 기억의 누락, 즉 망각이 일어나지.", "name": "라이디언"}, "figure_art": "avg_npc_1730_1#4$1"}, {"id": 183, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 184, "prop": "name", "attributes": {"content": "맞아, 그건 네 제안이었어. 인체의 전기 신호에 대한 이해와 응용은 네가 나보다 훨씬 경험이 더 많았으니까.", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 185, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1730_1#2$1"}}, {"id": 186, "prop": "name", "attributes": {"content": "그럼, 여기 당신과 같은 오리지늄 아츠를 쓰는 자가 있다는 거야?", "name": "라이디언"}, "figure_art": "avg_npc_1730_1#2$1"}, {"id": 187, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 188, "prop": "name", "attributes": {"content": "확실치 않아. 내가 너희들보다 더 많이 보고 들어서 그럴 수도 있어.", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 189, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1730_1#5$1"}}, {"id": 190, "prop": "name", "attributes": {"content": "그게 무슨 뜻이야?", "name": "라이디언"}, "figure_art": "avg_npc_1730_1#5$1"}, {"id": 191, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#4$1"}}, {"id": 192, "prop": "name", "attributes": {"content": "라이디언, 우르수스의 유로지비가 여기 있을지도 몰라.", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#4$1"}, {"id": 193, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1730_1#4$1"}}, {"id": 194, "prop": "name", "attributes": {"content": "유로지비? 갑자기 그 얘기는 왜……", "name": "라이디언"}, "figure_art": "avg_npc_1730_1#4$1"}, {"id": 195, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1730_1#2$1"}}, {"id": 196, "prop": "name", "attributes": {"content": "뭐? 유로지비가 여기 있다고? 우르수스의 마지막 유로지비는 2년 전 디에티 그라이퍼부르크에서 불에 타 죽었잖아. 이렇게 빨리 또 다른 유로지비가 나올 수 있어?", "name": "라이디언"}, "figure_art": "avg_npc_1730_1#2$1"}, {"id": 197, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 198, "prop": "name", "attributes": {"content": "모르겠어. 이제 확인해 봐야지.", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 199, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1730_1#2$1"}}, {"id": 200, "prop": "name", "attributes": {"content": "만약 정말로 유로지비가 존재하고, 이 무리에 숨어 있었는데 내가 여태까지 눈치채지 못했다면…… 이건 정말 위험한 상황이야.", "name": "라이디언"}, "figure_art": "avg_npc_1730_1#2$1"}, {"id": 201, "prop": "name", "attributes": {"content": "다른 사람들한테 경계하라고 전할게, 당신도 조심해.", "name": "라이디언"}, "figure_art": "avg_npc_1730_1#2$1"}, {"id": 202, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 203, "prop": "name", "attributes": {"content": "이 위험은 물리적인 게 아니야. 적어도 아직까지는.", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 204, "prop": "name", "attributes": {"content": "필요하면 즉시 도움을 요청할게.", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 205, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1730_1#2$1"}}, {"id": 206, "prop": "name", "attributes": {"content": "잊지 마.", "name": "라이디언"}, "figure_art": "avg_npc_1730_1#2$1"}, {"id": 207, "prop": "Dialog", "attributes": {}}, {"id": 208, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 209, "prop": "charslot", "attributes": {}}, {"id": 210, "prop": "PlaySound", "attributes": {"key": "$d_gen_walk_n"}}, {"id": 211, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 212, "prop": "name", "attributes": {"content": "만트라는 돌아서서 몇 초 전 붉은빛이 있었던 그 위치로 향했다."}}, {"id": 213, "prop": "name", "attributes": {"content": "가는 동안, 서로 부대끼던 광부들이 그녀에게 길을 비켜 주거나, 그녀를 향해 손을 뻗었다."}}, {"id": 214, "prop": "dialog", "attributes": {}}, {"id": 215, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4207_branch_1#1$1"}}, {"id": 216, "prop": "name", "attributes": {"content": "저기, 누구…… 찾으세요?", "name": "베토치키"}, "figure_art": "avg_4207_branch_1#1$1"}, {"id": 217, "prop": "name", "attributes": {"content": "우린, 디에티, 그라이퍼부르크로, 떠날 수, 있는 거죠?", "name": "베토치키"}, "figure_art": "avg_4207_branch_1#1$1"}, {"id": 218, "prop": "name", "attributes": {"content": "우린, 사, 살아남을 수, 있겠죠……?", "name": "베토치키"}, "figure_art": "avg_4207_branch_1#1$1"}, {"id": 219, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 220, "prop": "name", "attributes": {"content": "(고개를 끄덕인다)", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 221, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4207_branch_1#1$1"}}, {"id": 222, "prop": "name", "attributes": {"content": "그런데, 다, 다른, 사람들, 안 떠나고, 싶나 봐요? 비얀 아저씨, 물어봤는데, 안 간대요.", "name": "베토치키"}, "figure_art": "avg_4207_branch_1#1$1"}, {"id": 223, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4207_branch_1#10$1"}}, {"id": 224, "prop": "name", "attributes": {"content": "아저씨, 상처가, 썩고, 있는데도…… 더는, 도망치기, 싫대요.", "name": "베토치키"}, "figure_art": "avg_4207_branch_1#10$1"}, {"id": 225, "prop": "name", "attributes": {"content": "그래도, 사는 게…… 그 어떤, 것보다, 중요한 거, 아닌가요?", "name": "베토치키"}, "figure_art": "avg_4207_branch_1#10$1"}, {"id": 226, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#2$1"}}, {"id": 227, "prop": "name", "attributes": {"content": "……", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#2$1"}, {"id": 228, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4207_branch_1#1$1"}}, {"id": 229, "prop": "name", "attributes": {"content": "대답이, 없으시네요……", "name": "베토치키"}, "figure_art": "avg_4207_branch_1#1$1"}, {"id": 230, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1969_1#1$1"}}, {"id": 231, "prop": "name", "attributes": {"content": "외지인.", "name": "지친 광부"}, "figure_art": "avg_npc_1969_1#1$1"}, {"id": 232, "prop": "name", "attributes": {"content": "나댜를 만나러 가려는 거지? 그럼 무릎을 꿇고 올려다봐야 해.", "name": "지친 광부"}, "figure_art": "avg_npc_1969_1#1$1"}, {"id": 233, "prop": "name", "attributes": {"content": "나댜를 바라보며, 참회하고 용서를 받아. 그러면 지금까지 몸부림치면서 한 번도 평온을 얻지 못한 자신이 얼마나 어리석었는지 깨닫게 될 거다.", "name": "지친 광부"}, "figure_art": "avg_npc_1969_1#1$1"}, {"id": 234, "prop": "charslot", "attributes": {}}, {"id": 235, "prop": "name", "attributes": {"content": "만트라는 긍정도 부정도 하지 않았다. 그녀는 오리지늄 아츠로 그들과 대화하지 않았고, 그저 고개를 끄덕이며 방 안 깊숙한 곳으로 시선을 고정한 채 그들을 스쳐 지나갔다."}}, {"id": 236, "prop": "name", "attributes": {"content": "알게 될 거야…… 나댜에게 가면 알게 될 거야.", "name": "지친 광부"}, "figure_art": "avg_npc_1969_1#1$1"}, {"id": 237, "prop": "name", "attributes": {"content": "방 안 가장 깊숙한 곳에, 구부정하고 왜소해 보이는 회백색 형체가 마치 조각상처럼 고요히 앉아 있었다."}}, {"id": 238, "prop": "Dialog", "attributes": {}}, {"id": 239, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 240, "prop": "charslot", "attributes": {}}, {"id": 241, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 242, "prop": "Background", "attributes": {"image": "66_g15_ursusvillage_ruins", "screenadapt": "coverall"}}, {"id": 243, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 244, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 245, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#11$1", "duration": 0.5}}, {"id": 246, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 247, "prop": "name", "attributes": {"content": "……유로지비?", "name": "알로이즈"}, "figure_art": "avg_npc_1966_1#11$1"}, {"id": 248, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#5$1"}}, {"id": 249, "prop": "name", "attributes": {"content": "말도 안 돼, 절대 그럴 리 없어! 그놈은 이미 죽었어!", "name": "알로이즈"}, "figure_art": "avg_npc_1966_1#5$1"}, {"id": 250, "prop": "name", "attributes": {"content": "당시 폐하께서 자비를 베풀어 죄를 선고하기 전에, 그놈에게 자기 죄를 변호하도록 허락하셨어.", "name": "알로이즈"}, "figure_art": "avg_npc_1966_1#5$1"}, {"id": 251, "prop": "name", "attributes": {"content": "그 결과, 꼬박 7일! 그놈은 꼬박 7일 동안 물 한 모금조차 마시지 않은 채, 단 한순간도 쉬지 않고 궤변만 늘어놓으면서 시간을 끌었어.", "name": "알로이즈"}, "figure_art": "avg_npc_1966_1#5$1"}, {"id": 252, "prop": "name", "attributes": {"content": "심지어 그놈은 제국 의회의 중앙에 서서, 방청하러 온 모든 사람들에게 이렇게 말했어……", "name": "알로이즈"}, "figure_art": "avg_npc_1966_1#5$1"}, {"id": 253, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#8$1"}}, {"id": 254, "prop": "name", "attributes": {"content": "“그대들을 용서한다”고!", "name": "알로이즈"}, "figure_art": "avg_npc_1966_1#8$1"}, {"id": 255, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#4$1"}}, {"id": 256, "prop": "name", "attributes": {"content": "결국 폐하께서 참다못해 직접 사형을 선고했지. 하지만 그놈에게 현혹된 신자들이 형장을 덮치는 바람에, 디에티 그라이퍼부르크에는 지난 10년 이래 가장 큰 폭동이 일어났어.", "name": "알로이즈"}, "figure_art": "avg_npc_1966_1#4$1"}, {"id": 257, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1730_1#3$1"}}, {"id": 258, "prop": "name", "attributes": {"content": "그건 우리도 알아.", "name": "라이디언"}, "figure_art": "avg_npc_1730_1#3$1"}, {"id": 259, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1966_1#10$1"}}, {"id": 260, "prop": "name", "attributes": {"content": "……", "name": "알로이즈"}, "figure_art": "avg_npc_1966_1#10$1"}, {"id": 261, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1730_1#5$1"}}, {"id": 262, "prop": "name", "attributes": {"content": "문제는, 만트라가 유로지비라고 말한 이상, 상대가 그럴만한 흔적을 보였다는 거야.", "name": "라이디언"}, "figure_art": "avg_npc_1730_1#5$1"}, {"id": 263, "prop": "name", "attributes": {"content": "우리가 할 수 있는 건 자신을 지키면서, 만트라의 소식을 기다리는 것뿐이야.", "name": "라이디언"}, "figure_art": "avg_npc_1730_1#5$1"}, {"id": 264, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 265, "prop": "Dialog", "attributes": {}}, {"id": 266, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 267, "prop": "charslot", "attributes": {}}, {"id": 268, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 269, "prop": "Background", "attributes": {"image": "bg_ibindoor", "screenadapt": "coverall"}}, {"id": 270, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 271, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 272, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 273, "prop": "name", "attributes": {"content": "……", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 274, "prop": "charslot", "attributes": {"slot": "m", "focus": "n"}}, {"id": 275, "prop": "name", "attributes": {"content": "만트라는 광부가 말했던 것처럼 무릎을 꿇지는 않았다."}}, {"id": 276, "prop": "name", "attributes": {"content": "만트라는 역광이 드리운 그림자 속으로 걸어 들어가, 정면을 똑바로 응시했다. 마치 눈앞에 자신을 되돌아보는 한 쌍의 눈동자가 있는 것처럼."}}, {"id": 277, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 278, "prop": "name", "attributes": {"content": "네가 '들린'다는 거, 다 알아.", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 279, "prop": "dialog", "attributes": {}}, {"id": 280, "prop": "charslot", "attributes": {}}, {"id": 281, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 282, "prop": "playMusic", "attributes": {"intro": "$kjerag_n_intro", "key": "$kjerag_n_loop", "volume": 0.6}}, {"id": 283, "prop": "focusout", "attributes": {"duration": 1.5, "type": "bg", "from": 0.0, "to": 1.0}}, {"id": 284, "prop": "Blocker", "attributes": {"a": 0.6, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5, "block": "true"}}, {"id": 285, "prop": "Subtitle", "attributes": {"text": "들리고 말고, 그대의 의문이 들린다.", "x": 300.0, "y": 370.0, "alignment": "center", "size": 24.0, "delay": 0.04, "width": 700.0}}, {"id": 286, "prop": "subtitle", "attributes": {}}, {"id": 287, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.0, "block": "true"}}, {"id": 288, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 289, "prop": "name", "attributes": {"content": "네가 내 오리지늄 아츠와 화법을 흉내 낸 것만은 아니길 바랄게, 유로지비.", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 290, "prop": "charslot", "attributes": {}}, {"id": 291, "prop": "dialog", "attributes": {}}, {"id": 292, "prop": "Blocker", "attributes": {"a": 0.2, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 1.5}}, {"id": 293, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 294, "prop": "name", "attributes": {"content": "'유로지비'…… 그렇게 불러도 상관없어.", "name": "나댜"}}, {"id": 295, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 296, "prop": "name", "attributes": {"content": "무슨 의미야?", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 297, "prop": "charslot", "attributes": {}}, {"id": 298, "prop": "name", "attributes": {"content": "가브리일, 솔로미다, 베스메르트, 아브로라, 나댜…… 그리고 '유로지비'.", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 299, "prop": "name", "attributes": {"content": "모두, 나야.", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 300, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 301, "prop": "name", "attributes": {"content": "……대답해, 왜 이 고통받는 사람들 속에 섞여 있었지?", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 302, "prop": "charslot", "attributes": {}}, {"id": 303, "prop": "name", "attributes": {"content": "포교 때문에.", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 304, "prop": "name", "attributes": {"content": "나는 이 드넓은 땅을 거닐며, 사람들을 고통에서 구원할 것이다.", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 305, "prop": "name", "attributes": {"content": "그 또한, 내가 그녀를 보았고, 그녀를 들었기 때문이지.", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 306, "prop": "name", "attributes": {"content": "그녀의 고통이 나를 머물게 했고, 나도 그 때문에 멈춰 섰다.", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 307, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 308, "prop": "name", "attributes": {"content": "누구지? 그 '그녀'라는 사람은?", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 309, "prop": "charslot", "attributes": {}}, {"id": 310, "prop": "name", "attributes": {"content": "고통받은 한 영혼.", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 311, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 312, "prop": "name", "attributes": {"content": "그녀를 속여서 너를 '나댜'라고 부르게 한 건가?", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 313, "prop": "charslot", "attributes": {}}, {"id": 314, "prop": "name", "attributes": {"content": "속인 적은 없다.", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 315, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 316, "prop": "name", "attributes": {"content": "헛소리.", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 317, "prop": "charslot", "attributes": {}}, {"id": 318, "prop": "name", "attributes": {"content": "그녀는 그대처럼 물었고, 나는 나처럼 대답했다.", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 319, "prop": "name", "attributes": {"content": "그뿐이다.", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 320, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 321, "prop": "name", "attributes": {"content": "의미 없는 대답이야. 말해, 네 정체는 뭐지?", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 322, "prop": "charslot", "attributes": {}}, {"id": 323, "prop": "name", "attributes": {"content": "그대도 나를 봤을 것이다.", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 324, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 325, "prop": "name", "attributes": {"content": "내가 본 건 무질서한 환영이야.", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 326, "prop": "charslot", "attributes": {}}, {"id": 327, "prop": "name", "attributes": {"content": "맞아, 그게 나다.", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 328, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 329, "prop": "name", "attributes": {"content": "하지만 다른 사람들 눈에는, 그렇지 않아.", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 330, "prop": "name", "attributes": {"content": "설명해.", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 331, "prop": "charslot", "attributes": {}}, {"id": 332, "prop": "name", "attributes": {"content": "세상 사람들이 본 내 모습은, 나에 대한 그들의 인식과 기대의 투영일 뿐이다.", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 333, "prop": "name", "attributes": {"content": "모든 영혼 속에서, 오직 그대만이 내 존재의 이유를 이해할 거라 생각했는데.", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 334, "prop": "name", "attributes": {"content": "왜냐하면……", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 335, "prop": "name", "attributes": {"content": "그대는 미완의 조각상이니까. 그대는 과거에……", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 336, "prop": "name", "attributes": {"content": "'내'가 될 터였던 존재였으니까.", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 337, "prop": "name", "attributes": {"content": "만트라는 눈앞의 기괴한 환영을 노려봤지만, 그 환영에서 자신의 판단에 도움이 될 만한 정보를 얻을 수 있을지는 판단이 서지 않았다."}}, {"id": 338, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 339, "prop": "name", "attributes": {"content": "……", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 340, "prop": "charslot", "attributes": {}}, {"id": 341, "prop": "name", "attributes": {"content": "아주 오래전, 그대는 까맣게 썩은 살점을 도려낸 적이 있었지.", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 342, "prop": "name", "attributes": {"content": "나도 마찬가지다. 놈은 나를 쫓았고, 나는 놈을 쫓았다. 마치 호흡 중간중간에 몸에서 썩은 살점을 도려내듯이.", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 343, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_4204_mantra_1#1$1"}}, {"id": 344, "prop": "name", "attributes": {"content": "황당한 비유로군.", "name": "만트라"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 345, "prop": "charslot", "attributes": {}}, {"id": 346, "prop": "name", "attributes": {"content": "아니, 간단한 이치다.", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 347, "prop": "name", "attributes": {"content": "만약 이미 썩어버려, 더 이상 신체의 다른 부분과 숨결을 나누지 않는다면……", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 348, "prop": "name", "attributes": {"content": "그걸 붙잡고 있을 이유가 있을까?", "name": "나댜"}, "figure_art": "avg_4204_mantra_1#1$1"}, {"id": 349, "prop": "Dialog", "attributes": {}}, {"id": 350, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 351, "prop": "charslot", "attributes": {}}, {"id": 352, "prop": "CameraEffect", "attributes": {"effect": "Grayscale", "fadetime": 0.0, "keep": "true", "initamount": 0.0, "amount": 1.0, "block": "true"}}, {"id": 353, "prop": "Image", "attributes": {"image": "avg_8_29", "screenadapt": "coverall"}}, {"id": 354, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 355, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 356, "prop": "name", "attributes": {"content": "……그게……", "name": "만트라"}}, {"id": 357, "prop": "Dialog", "attributes": {}}, {"id": 358, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 359, "prop": "charslot", "attributes": {}}, {"id": 360, "prop": "Image", "attributes": {"image": "66_i01", "screenadapt": "coverall"}}, {"id": 361, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g":