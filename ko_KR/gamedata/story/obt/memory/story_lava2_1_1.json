1$1", "duration": 2.0}}, {"id": 138, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 139, "prop": "name", "attributes": {"content": "호기심 많은 아이가 어머니 뒤에서 빼꼼 고개를 내밀곤, 방문한 살카즈 소녀를 엿보고 있었다."}}, {"id": 140, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_243", "focus": "l"}}, {"id": 141, "prop": "name", "attributes": {"content": "일사, 방으로 돌아가렴.", "name": "이웃 B"}, "figure_art": "avg_npc_243"}, {"id": 142, "prop": "charslot", "attributes": {}}, {"id": 143, "prop": "charslot", "attributes": {"slot": "m", "name": "char_1011_purgatory_1#1"}}, {"id": 144, "prop": "name", "attributes": {"content": "실은 저희가 여기로 이사 온 지 얼마 안 돼서……", "name": "라바"}, "figure_art": "avg_npc_243"}, {"id": 145, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_243"}}, {"id": 146, "prop": "name", "attributes": {"content": "알아요. 이 근처 이웃집 문을 다 두드리던데, 무슨 일이에요?", "name": "이웃 B"}, "figure_art": "avg_npc_243"}, {"id": 147, "prop": "charslot", "attributes": {"slot": "m", "name": "char_1011_purgatory_1#1"}}, {"id": 148, "prop": "name", "attributes": {"content": "언니가 음식을 하는 데 고춧가루를 못 찾아서요, 괜찮으면 좀 빌릴 수 있을까요?", "name": "라바"}, "figure_art": "avg_npc_243"}, {"id": 149, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_243"}}, {"id": 150, "prop": "name", "attributes": {"content": "……그런 거였군요. 문 앞에서 잠시 기다리세요.", "name": "이웃 B"}, "figure_art": "avg_npc_243"}, {"id": 151, "prop": "Character", "attributes": {}}, {"id": 152, "prop": "Dialog", "attributes": {}}, {"id": 153, "prop": "name", "attributes": {"content": "문이 닫혔다가 살며시 다시 열렸다. 호기심에 찬 작은 얼굴이 튀어나와선, 라바를 바라봤다…… 정확히 말하자면 라바 머리 위의 뿔을."}}, {"id": 154, "prop": "name", "attributes": {"content": "아이는 약간 긴장한 듯 침을 삼키고, 오랫동안 망설인 끝에 라바에게 손을 내밀었다."}}, {"id": 155, "prop": "name", "attributes": {"content": "라바는 이미 오는 길에 이러한 시선에 익숙해져서, 그냥 가만히 서 있었다. 이윽고 그 여자 아이의 작은 손가락이 점점 가까이 다가오더니, 라바의 옷자락에 닿았다."}}, {"id": 156, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_661_1#1$1"}}, {"id": 157, "prop": "name", "attributes": {"content": "와…… 진짜 옷이다, 주술로 바꾼 게 아니네요.", "name": "호기심 많은 아이"}, "figure_art": "avg_npc_661_1#1$1"}, {"id": 158, "prop": "charslot", "attributes": {"slot": "m", "name": "char_1011_purgatory_1#4"}}, {"id": 159, "prop": "name", "attributes": {"content": "하아?", "name": "라바"}, "figure_art": "char_1011_purgatory_1#4"}, {"id": 160, "prop": "dialog", "attributes": {}}, {"id": 161, "prop": "charslot", "attributes": {}}, {"id": 162, "prop": "PlaySound", "attributes": {"key": "$d_avg_ceramicrack"}}, {"id": 163, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 164, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_243"}}, {"id": 165, "prop": "name", "attributes": {"content": "일사! 이리 오렴!", "name": "이웃 B"}, "figure_art": "avg_npc_243"}, {"id": 166, "prop": "dialog", "attributes": {}}, {"id": 167, "prop": "charslot", "attributes": {}}, {"id": 168, "prop": "name", "attributes": {"content": "그 어머니는 손에 있던 물건을 내던지고 달려와 자신의 아이를 뒤로 감쌌다. 그녀의 얼굴에 나타난 표정은 더 이상 침착해 보이지 않았다."}}, {"id": 169, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_243"}}, {"id": 170, "prop": "name", "attributes": {"content": "우리 집에는 그쪽이 원하는 게 없네요, 이만 가세요.", "name": "이웃 B"}, "figure_art": "avg_npc_243"}, {"id": 171, "prop": "charslot", "attributes": {"slot": "m", "name": "char_1011_purgatory_1#1"}}, {"id": 172, "prop": "name", "attributes": {"content": "……", "name": "라바"}, "figure_art": "char_1011_purgatory_1#1"}, {"id": 173, "prop": "Dialog", "attributes": {}}, {"id": 174, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 175, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 176, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 177, "prop": "charslot", "attributes": {}}, {"id": 178, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 179, "prop": "Background", "attributes": {"image": "34_g1_victoriavillage", "screenadapt": "coverall", "block": "true"}}, {"id": 180, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 181, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 182, "prop": "PlayMusic", "attributes": {"intro": "$m_dia_street_intro", "key": "$m_dia_street_loop", "volume": 0.6}}, {"id": 183, "prop": "name", "attributes": {"content": "바스락바스락, 일사는 다락방 창문을 통해 집 밖으로 기어 나와, 잔뜩 신이 나선 친구들에게 암호를 보냈다. 잠시 후, 마을 사람들은 잇따라 발걸음을 멈추고, 멀리서 그 기이한 광경을 바라봤다……"}}, {"id": 184, "prop": "name", "attributes": {"content": "환영받지 못하는 살카즈 한 명이 냉랭한 표정으로 마을을 거닐었고, 그 뒤 멀지 않은 곳에서 한 무리의 아이들이 그녀를 살금살금 따라가고 있었다."}}, {"id": 185, "prop": "name", "attributes": {"content": "아이들은 이따금 덤불 뒤에 숨었다가, 또 때로는 몸을 굴러 나무 뒤로 잽싸게 숨으며, 서로 눈을 깜빡이며 암호를 주고받고, 때때로 상상 속의 무전기를 손에 대고 말했다."}}, {"id": 186, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_661_1#1$1"}}, {"id": 187, "prop": "name", "attributes": {"content": "보고, 악마는 이미 톰네 집 짚 더미 앞에 도착했고, 곧 톰의 집 문 앞에 도착할 예정이다. 이상!", "name": "일사"}, "figure_art": "avg_npc_661_1#1$1"}, {"id": 188, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_240"}}, {"id": 189, "prop": "name", "attributes": {"content": "오케이, 수성포 준비 완료!", "name": "테오"}, "figure_art": "avg_npc_240"}, {"id": 190, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_418_1#1$1"}}, {"id": 191, "prop": "name", "attributes": {"content": "얘들아, 저 사람에게 새총을 겨누지 말렴. 그러면 위험하단다……", "name": "걱정되는 행인"}, "figure_art": "avg_npc_418_1#1$1"}, {"id": 192, "prop": "dialog", "attributes": {}}, {"id": 193, "prop": "charslot", "attributes": {}}, {"id": 194, "prop": "name", "attributes": {"content": "어른들이 끼어들자, 아이들은 파울비스트처럼 소리를 지르며 사방으로 흩어졌다가, 이내 곧 다시 모여들었다."}}, {"id": 195, "prop": "charslot", "attributes": {"slot": "m", "name": "char_1011_purgatory_1#1"}}, {"id": 196, "prop": "name", "attributes": {"content": "쯧, 이 녀석들……", "name": "라바"}, "figure_art": "char_1011_purgatory_1#1"}, {"id": 197, "prop": "charslot", "attributes": {}}, {"id": 198, "prop": "name", "attributes": {"content": "큰일이야, 악마가 우리를 발견했어! 빨리 철수해!", "name": "아이들"}, "figure_art": "char_1011_purgatory_1#1"}, {"id": 199, "prop": "charslot", "attributes": {"slot": "m", "name": "char_1011_purgatory_1#1"}}, {"id": 200, "prop": "name", "attributes": {"content": "악마……?", "name": "라바"}, "figure_art": "char_1011_purgatory_1#1"}, {"id": 201, "prop": "charslot", "attributes": {"slot": "m", "name": "char_1011_purgatory_1#1"}}, {"id": 202, "prop": "name", "attributes": {"content": "(짜증 나네, 빨리 겁줘서 쫓아내야겠어.)", "name": "라바"}, "figure_art": "char_1011_purgatory_1#1"}, {"id": 203, "prop": "dialog", "attributes": {}}, {"id": 204, "prop": "charslot", "attributes": {}}, {"id": 205, "prop": "PlaySound", "attributes": {"key": "$d_avg_firemagic", "volume": 1.0}}, {"id": 206, "prop": "delay", "attributes": {"time": 3.0}}, {"id": 207, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_700_1#1$1"}}, {"id": 208, "prop": "name", "attributes": {"content": "빨리 봐봐, 악마가 지나간 길에 반짝이는 발자국이 있어. 저게 대체 뭐지?", "name": "로즈"}, "figure_art": "avg_npc_700_1#1$1"}, {"id": 209, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_240"}}, {"id": 210, "prop": "name", "attributes": {"content": "가만히 있어, 내가 정찰해 볼게…… 우와아, 불이야! 악마가 지나간 길에 불이 붙었어!", "name": "테오"}, "figure_art": "avg_npc_240"}, {"id": 211, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_661_1#1$1"}}, {"id": 212, "prop": "name", "attributes": {"content": "어디 봐봐…… 진짜다! 땅에 있는 발자국이 전부 다 불타고 있어, 완전 대단해!", "name": "일사"}, "figure_art": "avg_npc_661_1#1$1"}, {"id": 213, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_700_1#1$1"}}, {"id": 214, "prop": "name", "attributes": {"content": "앗, 멀어져 가잖아, 빨리 쫓아가자!", "name": "로즈"}, "figure_art": "avg_npc_700_1#1$1"}, {"id": 215, "prop": "charslot", "attributes": {"slot": "m", "name": "char_1011_purgatory_1#4"}}, {"id": 216, "prop": "name", "attributes": {"content": "(뭐야, 이래도 안 무서워?)", "name": "라바"}, "figure_art": "char_1011_purgatory_1#4"}, {"id": 217, "prop": "dialog", "attributes": {}}, {"id": 218, "prop": "charslot", "attributes": {}}, {"id": 219, "prop": "name", "attributes": {"content": "라바는 아이들의 손에 있는 새총을 잠시 바라봤다."}}, {"id": 220, "prop": "charslot", "attributes": {"slot": "m", "name": "char_1011_purgatory_1#1"}}, {"id": 221, "prop": "name", "attributes": {"content": "칫, 됐어. 괜히 다치게 하면 귀찮으니까. 좀 더 무서운 걸 보여줘야겠네.", "name": "라바"}, "figure_art": "char_1011_purgatory_1#1"}, {"id": 222, "prop": "charslot", "attributes": {"slot": "m", "name": "char_1011_purgatory_1#2"}}, {"id": 223, "prop": "name", "attributes": {"content": "에취……", "name": "라바"}, "figure_art": "char_1011_purgatory_1#2"}, {"id": 224, "prop": "dialog", "attributes": {}}, {"id": 225, "prop": "charslot", "attributes": {}}, {"id": 226, "prop": "PlaySound", "attributes": {"key": "$d_avg_firemagic", "volume": 1.0}}, {"id": 227, "prop": "delay", "attributes": {"time": 3.0}}, {"id": 228, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_240"}}, {"id": 229, "prop": "name", "attributes": {"content": "악마가 재채기를 하더니 불을 뿜어냈어! 우와, 악마한테서 불꽃 날개가 나왔어!", "name": "테오"}, "figure_art": "avg_npc_240"}, {"id": 230, "prop": "charslot", "attributes": {}}, {"id": 231, "prop": "charslot", "attributes": {"slot": "l", "name": "avg_npc_661_1#1$1"}}, {"id": 232, "prop": "charslot", "attributes": {"slot": "r", "name": "avg_npc_700_1#1$1"}}, {"id": 233, "prop": "name", "attributes": {"content": "와……! 너무……", "name": "일사&로즈"}, "figure_art": "avg_npc_240"}, {"id": 234, "prop": "name", "attributes": {"content": "너무 멋지다!", "name": "일사&로즈"}, "figure_art": "avg_npc_240"}, {"id": 235, "prop": "charslot", "attributes": {}}, {"id": 236, "prop": "charslot", "attributes": {"slot": "m", "name": "char_1011_purgatory_1#3"}}, {"id": 237, "prop": "name", "attributes": {"content": "…… 그래도 꽤 보는 눈이 있네, 꼬마녀석들.", "name": "라바"}, "figure_art": "avg_npc_240"}, {"id": 238, "prop": "Dialog", "attributes": {}}, {"id": 239, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 240, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 241, "prop": "charslot", "attributes": {}}, {"id": 242, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 243, "prop": "cameraEffect", "attributes": {"effect": "Grayscale", "keep": "true", "amount": 1.0, "fadetime": 0.0}}, {"id": 244, "prop": "Background", "attributes": {"image": "bg_rhodesinpatientcenter", "screenadapt": "coverall", "block": "true"}}, {"id": 245, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 246, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 247, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1456_1#1$1"}}, {"id": 248, "prop": "name", "attributes": {"content": "(끊임없이 흐느낀다)", "name": "겁에 질린 꼬마 환자"}, "figure_art": "avg_npc_1456_1#1$1"}, {"id": 249, "prop": "charslot", "attributes": {"slot": "m", "name": "char_1011_purgatory_1#1"}}, {"id": 250, "prop": "name", "attributes": {"content": "어……", "name": "라바"}, "figure_art": "char_1011_purgatory_1#1"}, {"id": 251, "prop": "dialog", "attributes": {}}, {"id": 252, "prop": "charslot", "attributes": {}}, {"id": 253, "prop": "name", "attributes": {"content": "어쩔 줄 몰라 하던 라바는 주머니를 더듬어 손에 잡히는 사탕을 꺼내 아이를 달래주려 했지만, 곧 히비스커스가 아이들은 반드시 공복으로 채혈을 받아야 한다고 당부한 것이 생각났다."}}, {"id": 254, "prop": "name", "attributes": {"content": "얄미운 언니 같으니. 도와달라고 불러놓고선…… 동족이 옆에 있는 걸 보면 전쟁으로 부모를 잃은 아이들도 그렇게 무서워하지 않을 거라는 둥 말했는데, 아이들은 아까부터 계속 울기만 했다!"}}, {"id": 255, "prop": "name", "attributes": {"content": "병실 곳곳에서 터져 나오는 울음소리에 그녀는 어찌해야 좋을지 알 수 없었다. 매일, 매일, 전쟁이 계속되는 한, 이런 울음소리는 멈추지 않을 것이다."}}, {"id": 256, "prop": "charslot", "attributes": {"slot": "m", "name": "char_1011_purgatory_1#1"}}, {"id": 257, "prop": "name", "attributes": {"content": "음…… 너희들, 혹시 불꽃놀이 보고 싶어?", "name": "라바"}, "figure_art": "char_1011_purgatory_1#1"}, {"id": 258, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_1456_1#1$1"}}, {"id": 259, "prop": "name", "attributes": {"content": "(흐느낀다)", "name": "겁에 질린 꼬마 환자"}, "figure_art": "avg_npc_1456_1#1$1"}, {"id": 260, "prop": "charslot", "attributes": {"slot": "m", "name": "char_1011_purgatory_1#1"}}, {"id": 261, "prop": "name", "attributes": {"content": "그럼 그냥 보고 싶은 걸로 칠 테니까, 잘 봐. 기회는 한 번뿐이야.", "name": "라바"}, "figure_art": "char_1011_purgatory_1#1"}, {"id": 262, "prop": "charslot", "attributes": {"slot": "m", "name": "char_1011_purgatory_1#1"}}, {"id": 263, "prop": "name", "attributes": {"content": "크흠.", "name": "라바"}, "figure_art": "char_1011_purgatory_1#1"}, {"id": 264, "prop": "charslot", "attributes": {"slot": "m", "name": "char_1011_purgatory_1#2"}}, {"id": 265, "prop": "name", "attributes": {"content": "불꽃이여, 이 대지를 밝혀라!", "name": "라바"}, "figure_art": "char_1011_purgatory_1#2"}, {"id": 266, "prop": "dialog", "attributes": {}}, {"id": 267, "prop": "charslot", "attributes": {}}, {"id": 268, "prop": "playsound", "attributes": {"key": "$d_avg_firemagic", "volume": 0.7}}, {"id": 269, "prop": "PlaySound", "attributes": {"key": "$firemagic_explosion", "volume": 1.0, "delay": 1.2}}, {"id": 270, "prop": "delay", "attributes": {"time": 1.2}}, {"id": 271, "prop": "CameraShake", "attributes": {"duration": 1.5, "xstrength": 40.0, "ystrength": 40.0, "vibrato": 30.0, "randomness": 90.0, "fadeout": "true", "block": "false"}}, {"id": 272, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 273, "prop": "name", "attributes": {"content": "한 송이 불꽃으로 만들어진 폭죽이 천장으로 치솟더니, 병실 위에서 터졌다. 라바는 아이들의 표정을 살며시 훔쳐봤다. 아이들은 모두 불꽃에 매료되어 잠시나마 울음을 잊은 것 같았다."}}, {"id": 274, "prop": "Dialog", "attributes": {}}, {"id": 275, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 276, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 277, "prop": "charslot", "attributes": {}}, {"id": 278, "prop": "name", "attributes": {"content": "그리고 그 불꽃은 소방 장치를 작동시켜서, 모두를 곤란할 정도로 젖게 했다. 어느새 병실의 울음소리가 잠시나마 웃음소리로 바뀌었다."}}, {"id": 279, "prop": "name", "attributes": {"content": "역시 아이들은 어디에서나 똑같았다. 그런 얕은 수로도 속일 수 있으니까 말이다."}}, {"id": 280, "prop": "name", "attributes": {"content": "정말 어디에서나…… 똑같을까?"}}, {"id": 281, "prop": "Dialog", "attributes": {}}, {"id": 282, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 283, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 284, "prop": "charslot", "attributes": {}}, {"id": 285, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 286, "prop": "cameraEffect", "attributes": {"effect": "Grayscale", "keep": "true", "amount": 0.0, "fadetime": 0.0}}, {"id": 287, "prop": "Background", "attributes": {"image": "bg_snowconutryinside", "screenadapt": "coverall", "block": "true"}}, {"id": 288, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 289, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 290, "prop": "playmusic", "attributes": {"intro": "$path_intro", "key": "$path_loop", "volume": 0.6}}, {"id": 291, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1024_hbisc2_1#1$1"}}, {"id": 292, "prop": "name", "attributes": {"content": "라바, 돌아왔구나. 주변 이웃들은 어때?", "name": "히비스커스"}, "figure_art": "avg_1024_hbisc2_1#1$1"}, {"id": 293, "prop": "charslot", "attributes": {"slot": "m", "name": "char_1011_purgatory_1#1"}}, {"id": 294, "prop": "name", "attributes": {"content": "이웃들? 난 그냥 고춧가루 빌리러 간 거였어……", "name": "라바"}, "figure_art": "char_1011_purgatory_1#1"}, {"id": 295, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1024_hbisc2_1#1$1"}}, {"id": 296, "prop": "name", "attributes": {"content": "한 바퀴 둘러보고 나니 안심이 됐어? 누구랑 싸운 건 아니지?", "name": "히비스커스"}, "figure_art": "avg_1024_hbisc2_1#1$1"}, {"id": 297, "prop": "charslot", "attributes": {"slot": "m", "name": "char_1011_purgatory_1#1"}}, {"id": 298, "prop": "name", "attributes": {"content": "난 그냥 고춧가루를 빌리러 간 것뿐이라니까.", "name": "라바"}, "figure_art": "char_1011_purgatory_1#1"}, {"id": 299, "prop": "dialog", "attributes": {}}, {"id": 300, "prop": "charslot", "attributes": {}}, {"id": 301, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovement", "volume": 1.0}}, {"id": 302, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 303, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1024_hbisc2_1#3$1"}}, {"id": 304, "prop": "name", "attributes": {"content": "라바? 뭘 찾고 있어? 문밖에 있는 꼬마들은 새로 사귄 친구들이야? 넌 여전히 아이들이랑 잘 놀아주나 보구나……", "name": "히비스커스"}, "figure_art": "avg_1024_hbisc2_1#3$1"}, {"id": 305, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_1024_hbisc2_1#3$1"}}, {"id": 306, "prop": "name", "attributes": {"content": "어라, 짐 한 보따리를 들고…… 또 나가 버렸네?", "name": "히비스커스"}, "figure_art": "avg_1024_hbisc2_1#3$1"}, {"id": 307, "prop": "Dialog", "attributes": {}}, {"id": 308, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 309, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 310, "prop": "charslot", "attributes": {}}, {"id": 311, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 312, "prop": "Background", "attributes": {"image": "34_g1_victoriavillage", "screenadapt": "coverall", "block": "true"}}, {"id": 313, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 314, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 315, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_661_1#1$1"}}, {"id": 316, "prop": "name", "attributes": {"content": "보고, 악마가 집에서 나왔다! 현재 작은 화원에 도착했음, 이상!", "name": "일사"}, "figure_art": "avg_npc_661_1#1$1"}, {"id": 317, "prop": "dialog", "attributes": {}}, {"id": 318, "prop": "charslot", "attributes": {}}, {"id": 319, "prop": "PlaySound", "attributes": {"key": "$d_avg_firemagic", "volume": 1.0}}, {"id": 320, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 321, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_240"}}, {"id": 322, "prop": "name", "attributes": {"content": "와! 불이다! 내 말은 악, 악마가 불꽃을 조종해서…… 나무줄기를 태웠다는 말이야! 보고, 악마가 대량의 나뭇가지로 수상하고 거대한 무언가를 짓고 있다!", "name": "테오"}, "figure_art": "avg_npc_240"}, {"id": 323, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_661_1#1$1"}}, {"id": 324, "prop": "name", "attributes": {"content": "그 거대한 게 어떤 건지, 정확히 좀 말해봐!", "name": "일사"}, "figure_art": "avg_npc_661_1#1$1"}, {"id": 325, "prop": "dialog", "attributes": {}}, {"id": 326, "prop": "charslot", "attributes": {}}, {"id": 327, "prop": "PlaySound", "attributes": {"key": "$d_avg_clothmovement", "volume": 1.0}}, {"id": 328, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 329, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_240"}}, {"id": 330, "prop": "name", "attributes": {"content": "잘 모르겠어! 보고, 악마가 지금 하얀 침대 시트를 털어서 펼치더니…… 아니, 하얀 주술 재료야. 그걸 나뭇가지 위에 펼치고 있음, 정보 요원 분석 요청 바람!", "name": "테오"}, "figure_art": "avg_npc_240"}, {"id": 331, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_700_1#1$1"}}, {"id": 332, "prop": "name", "attributes": {"content": "정보 요원 도착! 음, 내가 보기엔, 이건 분명…… 뭔가 위험한 제단인 거 같아.", "name": "로즈"}, "figure_art": "avg_npc_700_1#1$1"}, {"id": 333, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_700_1#1$1"}}, {"id": 334, "prop": "name", "attributes": {"content": "맞아, 나뭇가지로 저 장막을 지탱하잖아. 봐봐, 악마가 쓰러진 나무줄기를 밀고 왔어. 저건 아마도 제물을 놓는 제단 같아.", "name": "로즈"}, "figure_art": "avg_npc_700_1#1$1"}, {"id": 335, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_240"}}, {"id": 336, "prop": "name", "attributes": {"content": "(숨을 들이쉬며) 마을이 위험해!", "name": "테오"}, "figure_art": "avg_npc_240"}, {"id": 337, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_240"}}, {"id": 338, "prop": "name", "attributes": {"content": "(몸을 움츠린다)", "name": "테오"}, "figure_art": "avg_npc_240"}, {"id": 339, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_661_1#1$1"}}, {"id": 340, "prop": "name", "attributes": {"content": "겁, 겁쟁이! 우리가 잘 지켜보고, 우리 마을을 지켜야지!", "name": "일사"}, "figure_art": "avg_npc_661_1#1$1"}, {"id": 341, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_700_1#1$1"}}, {"id": 342, "prop": "name", "attributes": {"content": "잠깐! 악마가 새로운 물건을 꺼냈어! 무슨 기계 장치 같은데…… 프로젝터? 아니, 분명 무슨 주술을 시전하기 위한 장치일 거야!", "name": "로즈"}, "figure_art": "avg_npc_700_1#1$1"}, {"id": 343, "prop": "Dialog", "attributes": {}}, {"id": 344, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 345, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 346, "prop": "charslot", "attributes": {}}, {"id": 347, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 348, "prop": "playsound", "attributes": {"key": "$d_avg_devicebeep"}}, {"id": 349, "prop": "delay", "attributes": {"time": 0.5}}, {"id": 350, "prop": "Background", "attributes": {"image": "bg_black", "screenadapt": "coverall", "block": "true"}}, {"id": 351, "prop": "Image", "attributes": {"image": "ac6_6", "screenadapt": "coverall", "fadetime": 0.0}}, {"id": 352, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "false"}}, {"id": 353, "prop": "name", "attributes": {"content": "그 말이 끝나기 무섭게, 기기가 켜지면서 하얀 '주술 재료' 위에 고층 빌딩보다도 더 거대한, 포효하는 거대 괴수가 나타났다."}}, {"id": 354, "prop": "charslot", "attributes": {}}, {"id": 355, "prop": "name", "attributes": {"content": "꺅……!", "name": "아이들"}}, {"id": 356, "prop": "Dialog", "attributes": {}}, {"id": 357, "prop": "Blocker", "attributes": {"a": 0.7, "r": 0.95, "g": 0.95, "b": 0.95, "fadetime": 0.02, "block": "true"}}, {"id": 358, "prop": "PlaySound", "attributes": {"key": "$d_sp_ballista"}}, {"id": 359, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.95, "g": 0.95, "b": 0.95, "fadetime": 0.25, "block": "true"}}, {"id": 360, "prop": "CameraShake", "attributes": {"duration": 0.6, "xstrength": 5.0, "ystrength": 8.0, "vibrato": 30.0, "randomness": 90.0, "block": "true"}}, {"id": 361, "prop": "dialog", "attributes": {}}, {"id": 362, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 363, "prop": "name", "attributes": {"content": "쾅! 파악!"}}, {"id": 364, "prop": "name", "attributes": {"content": "그 '주술 재료'에 비친 화면 속에서, 변이한 거대 괴수는 순식간에 고층 빌딩을 짓밟아 가루로 만들었다. 절망에 빠진 사람들은 울부짖고 도망치며, 영웅의 등장을 기대하고 있었다."}}, {"id": 365, "prop": "name", "attributes": {"content": "라바, 로도스 아일랜드의 정예 오퍼레이터, 아츠 마스터이자 재해 전문가. 지금 이 순간, 도시의 안위가 그녀의 손에 달려있었다."}}, {"id": 366, "prop": "charslot", "attributes": {}}, {"id": 367, "prop": "name", "attributes": {"content": "빨리 저거 봐봐! 영웅이 왔어!", "name": "아이들"}}, {"id": 368, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_240"}}, {"id": 369, "prop": "name", "attributes": {"content": "어? 거대 괴수를 물리치는 영웅이 왠지 저 악마…… 아니, 저 사람이랑…… 완전 똑같지 않아?", "name": "테오"}, "figure_art": "avg_npc_240"}, {"id": 370, "prop": "Dialog", "attributes": {}}, {"id": 371, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 372, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 373, "prop": "charslot", "attributes": {}}, {"id": 374, "prop": "image", "attributes": {}}, {"id": 375, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 376, "prop": "Background", "attributes": {"image": "34_g1_victoriavillage", "screenadapt": "coverall", "block": "true"}}, {"id": 377, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 378, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 379, "prop": "name", "attributes": {"content": "라바는 아이들이 말한 '제단' 위에 당당하게 앉아, 편안하게 영화를 즐기는 척했다……"}}, {"id": 380, "prop": "name", "attributes": {"content": "그녀가 아직 개봉하지 않은 영화를 가져온 건, 원래는 부모님을 즐겁게 해주고 싶어서였다."}}, {"id": 381, "prop": "name", "attributes": {"content": "억지로 집어넣은 과장된 스토리가 우습다고 생각했었지만, 지금 보니 전체적인 효과는 꽤 괜찮은 것 같았다."}}, {"id": 382, "prop": "name", "attributes": {"content": "아이들은 저마다 그녀를 몰래 쳐다보며, 그녀와 영화 속 영웅의 생김새를 비교했다."}}, {"id": 383, "prop": "name", "attributes": {"content": "아이들은 비록 염국 말을 알아듣진 못했지만, 영화 속 특수 효과에 매료되어 자신도 모르게 좀 더, 조금씩 가까이 다가가 나중엔 거의 라바의 곁에 붙은 꼴이 됐다."}}, {"id": 384, "prop": "Dialog", "attributes": {}}, {"id": 385, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 386, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 387, "prop": "charslot", "attributes": {}}, {"id": 388, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 389, "prop": "Background", "attributes": {"image": "34_g1_victoriavillage", "screenadapt": "coverall", "block": "true"}}, {"id": 390, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 2.0, "block": "true"}}, {"id": 391, "prop": "delay", "attributes": {"time": 1.0}}, {"id": 392, "prop": "charslot", "attributes": {"slot": "m", "name": "char_1011_purgatory_1#3"}}, {"id": 393, "prop": "name", "attributes": {"content": "(흥, 제법 보는 눈이 있네. 그렇다면 슬슬 요 녀석들에게 진짜를 좀 보여줘야겠는걸……)", "name": "라바"}, "figure_art": "char_1011_purgatory_1#3"}, {"id": 394, "prop": "dialog", "attributes": {}}, {"id": 395, "prop": "charslot", "attributes": {"duration": 1.0}}, {"id": 396, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 397, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_661_1#1$1"}}, {"id": 398, "prop": "name", "attributes": {"content": "큰일이야, 거대 괴수가 집을 짓밟으려 해. 영웅님, 빨리 도망쳐!", "name": "일사"}, "figure_art": "avg_npc_661_1#1$1"}, {"id": 399, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_240"}}, {"id": 400, "prop": "name", "attributes": {"content": "영웅은 도망가지 않아. 봐, 영웅이 이제 불꽃을 발사하려 해!", "name": "테오"}, "figure_art": "avg_npc_240"}, {"id": 401, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_700_1#1$1"}}, {"id": 402, "prop": "name", "attributes": {"content": "저기…… 너희 둘, 그, 그 사람은?", "name": "로즈"}, "figure_art": "avg_npc_700_1#1$1"}, {"id": 403, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_661_1#1$1"}}, {"id": 404, "prop": "name", "attributes": {"content": "꺄아악, 거대 괴수가 쫓아오고 있어!", "name": "일사"}, "figure_art": "avg_npc_661_1#1$1"}, {"id": 405, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_700_1#1$1"}}, {"id": 406, "prop": "name", "attributes": {"content": "저기! 다들! 그, 그 사람이 사라졌다구! 그, 우리 이웃 말이야……", "name": "로즈"}, "figure_art": "avg_npc_700_1#1$1"}, {"id": 407, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_240"}}, {"id": 408, "prop": "name", "attributes": {"content": "앗! 그 사람, 방금까지 여기 앉아 있었는데, 어디로 간 거지?", "name": "테오"}, "figure_art": "avg_npc_240"}, {"id": 409, "prop": "dialog", "attributes": {}}, {"id": 410, "prop": "charslot", "attributes": {}}, {"id": 411, "prop": "playsound", "attributes": {"key": "$d_avg_firemagic", "volume": 0.7}}, {"id": 412, "prop": "PlaySound", "attributes": {"key": "$firemagic_explosion", "volume": 1.0, "delay": 1.2}}, {"id": 413, "prop": "delay", "attributes": {"time": 1.2}}, {"id": 414, "prop": "name", "attributes": {"content": "라바가 원래 앉아 있던 자리는 어느새 텅 비어 있었다. 갑자기, 한줄기 불꽃이 그들의 뒤에서 엄습해, 그 침대 시트로 만든 스크린을 향해 발사되었고, 아이들은 비명을 질렀다."}}, {"id": 415, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_700_1#1$1"}}, {"id": 416, "prop": "name", "attributes": {"content": "저기, 이…… 이거 진짜 제단 아니야? 우린 깜빡 속아서 올라온 거라고!", "name": "로즈"}, "figure_art": "avg_npc_700_1#1$1"}, {"id": 417, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_661_1#1$1"}}, {"id": 418, "prop": "name", "attributes": {"content": "빨리 도망가…… 빨리…… 앗!", "name": "일사"}, "figure_art": "avg_npc_661_1#1$1"}, {"id": 419, "prop": "dialog", "attributes": {}}, {"id": 420, "prop": "charslot", "attributes": {}}, {"id": 421, "prop": "name", "attributes": {"content": "하지만 아이들은 곧 걸음을 멈췄고, 눈앞의 광경에 놀란 나머지 말을 잊었다."}}, {"id": 422, "prop": "dialog", "attributes": {}}, {"id": 423, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2050_1#1$1", "duration": 2.0}}, {"id": 424, "prop": "delay", "attributes": {"time": 3.0}}, {"id": 425, "prop": "name", "attributes": {"content": "그들의 눈앞에는 전투복으로 갈아입은 한 늠름한 여성이 서 있었다. 그녀는 멋지면서도 시크하게 손을 휘둘렀고, 불꽃은 '주술 재료', 즉 침대 시트로 만든 스크린을 덮쳤다."}}, {"id": 426, "prop": "name", "attributes": {"content": "스크린 위의 거대 괴수가 고통스럽게 울부짖으며, 잿더미로 변했다. 불꽃은 그러고 나서야 꺼졌지만, 주변의 꽃과 풀들은 조금도 다치지 않았다."}}, {"id": 427, "prop": "charslot", "attributes": {}}, {"id": 428, "prop": "name", "attributes": {"content": "와아!", "name": "아이들"}, "figure_art": "avg_npc_2050_1#1$1"}, {"id": 429, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_661_1#1$1"}}, {"id": 430, "prop": "name", "attributes": {"content": "대단해! 영웅님, 정말로 거대 괴수를 물리친 적이 있어?", "name": "일사"}, "figure_art": "avg_npc_661_1#1$1"}, {"id": 431, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_240"}}, {"id": 432, "prop": "name", "attributes": {"content": "방금 기술, 가르쳐 주면 안 돼?", "name": "테오"}, "figure_art": "avg_npc_240"}, {"id": 433, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_700_1#1$1"}}, {"id": 434, "prop": "name", "attributes": {"content": "전투복이 정말 예쁘고, 음, 멋져요!", "name": "로즈"}, "figure_art": "avg_npc_700_1#1$1"}, {"id": 435, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_661_1#1$1"}}, {"id": 436, "prop": "name", "attributes": {"content": "저기 영웅님, 내가 먼저 물어봤으니까, 나한테 먼저 대답해 줘…… 앗! …… 엄마?", "name": "일사"}, "figure_art": "avg_npc_661_1#1$1"}, {"id": 437, "prop": "dialog", "attributes": {}}, {"id": 438, "prop": "charslot", "attributes": {}}, {"id": 439, "prop": "name", "attributes": {"content": "영화가 불꽃 속에서 막을 내리자, 아이들은 그제야 자신들의 부모가 이미 멀지 않은 곳에서 긴장한 채로 그들을 바라보고 있었다는 걸 깨달았다. 부모들은 다가와, 이렇다 저렇다 말하지 않고 아이들을 집으로 끌고 갔다."}}, {"id": 440, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_243"}}, {"id": 441, "prop": "name", "attributes": {"content": "일사, 몰래 멋대로 뛰쳐나오지 말라고 했지. 오늘 밤엔 방에서 잘 반성하도록 해.", "name": "일사의 어머니"}, "figure_art": "avg_npc_243"}, {"id": 442, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_661_1#1$1"}}, {"id": 443, "prop": "name", "attributes": {"content": "그만 좀 잡아당겨, 엄마. 나 방금, 정말 엄청난 걸 봤는데……", "name": "일사"}, "figure_art": "avg_npc_661_1#1$1"}, {"id": 444, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_243"}}, {"id": 445, "prop": "name", "attributes": {"content": "그만, 말하지 마.", "name": "일사의 엄마"}, "figure_art": "avg_npc_243"}, {"id": 446, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2050_1#1$1"}}, {"id": 447, "prop": "name", "attributes": {"content": "……", "name": "라바"}, "figure_art": "avg_npc_2050_1#1$1"}, {"id": 448, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2050_1#1$1"}}, {"id": 449, "prop": "name", "attributes": {"content": "참 빨리도 도망가네. 내가 저 사람들보다 송곳니나 날개 한 쌍이 더 달린 것도 아닌데……", "name": "라바"}, "figure_art": "avg_npc_2050_1#1$1"}, {"id": 450, "prop": "charslot", "attributes": {"slot": "m", "name": "avg_npc_2050_1#1$1"}}, {"id": 451, "prop": "name", "attributes": {"content": "됐어, 다 가고 나니 이제야 좀 조용해졌네. 귀찮게 꼬마들 달래줄 필요도 없고 뭐, 시끄러워서 짜증 났었는데 말이지.", "name": "라바"}, "figure_art": "avg_npc_2050_1#1$1"}, {"id": 452, "prop": "dialog", "attributes": {}}, {"id": 453, "prop": "charslot", "attributes": {}}, {"id": 454, "prop": "delay", "attributes": {"time": 2.0}}, {"id": 455, "prop": "name", "attributes": {"content": "이건……?", "name": "라바"}}, {"id": 456, "prop": "name", "attributes": {"content": "……", "name": "라바"}}, {"id": 457, "prop": "dialog", "attributes": {}}, {"id": 458, "prop": "charslot", "attributes": {}}, {"id": 459, "prop": "name", "attributes": {"content": "일사가 원래 앉아 있던 자리에, 고춧가루 한 병이 조용히 놓여 있었다. 라바는 잠시 멍하니 있다가, 고개를 들어 감사의 인사를 하려 했지만, 마을 사람들은 이미 사라지고 없었다."}}, {"id": 460, "prop": "name", "attributes": {"content": "그래서 그녀는 물건을 챙겨 집으로 걸어갔다. 그 발걸음이 왠지 조금 가벼워진 듯했다."}}, {"id": 461, "prop": "Dialog", "attributes": {}}, {"id": 462, "prop": "Delay", "attributes": {"time": 1.0}}, {"id": 463, "prop": "Dialog", "attributes": {}}, {"id": 464, "prop": "Blocker", "attributes": {"a": 0.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 0.0, "block": "true"}}, {"id": 465, "prop": "Blocker", "attributes": {"a": 1.0, "r": 0.0, "g": 0.0, "b": 0.0, "fadetime": 3.0, "block": "true"}}, {"id": 466, "prop": "stopmusic", "attributes": {"fadetime": 2.0}}, {"id": 467, "prop": "Character", "attributes": {}}, {"id": 468, "prop": "Image", "attributes": {}}, {"id": 469, "prop": "name", "attributes": {"content": ""}}], "OPTIONTRACE": true}